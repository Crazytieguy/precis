README.md
     1вҶ’# go-multierror
    10вҶ’> **Note**: As of Go 1.20, the standard library provides [`errors.Join`](https://pkg.go.dev/errors#Join) which offers similar functionality for combining multiple errors. **For new projects, we recommend using `errors.Join` from the standard library.** This package provides additional features like custom formatting, the `Group` pattern for concurrent error collection, and utility functions (`Append`, `Flatten`, `Prefix`).
    11вҶ’
    12вҶ’## Migrating to `errors.Join`
    14вҶ’**Basic error aggregation:**
    15вҶ’```go
    16вҶ’// Before (go-multierror)
    17вҶ’var result error
    18вҶ’result = multierror.Append(result, err1)
    19вҶ’result = multierror.Append(result, err2)
    20вҶ’return result
    21вҶ’
    22вҶ’// After (stdlib)
    23вҶ’var errs []error
    24вҶ’if err1 != nil {
    25вҶ’    errs = append(errs, err1)
    26вҶ’}
    27вҶ’if err2 != nil {
    28вҶ’    errs = append(errs, err2)
    29вҶ’}
    30вҶ’if len(errs) > 0 {
    31вҶ’    return errors.Join(errs...)
    32вҶ’}
    33вҶ’return nil
    34вҶ’```
    35вҶ’
    36вҶ’**Custom formatting:**
    37вҶ’```go
    38вҶ’// go-multierror allows custom formatting
    39вҶ’// With stdlib, wrap the joined error with a custom type if needed
    40вҶ’type FormattedError struct {
    41вҶ’    errs []error
    42вҶ’}
    43вҶ’
    44вҶ’func (e *FormattedError) Error() string {
    45вҶ’    // Your custom format here
    46вҶ’    return fmt.Sprintf("multiple errors: %v", e.errs)
    47вҶ’}
    48вҶ’
    49вҶ’func (e *FormattedError) Unwrap() []error {
    50вҶ’    return e.errs
    51вҶ’}
    52вҶ’```
    53вҶ’
    54вҶ’**Concurrent error collection (Group):**
    55вҶ’```go
    56вҶ’// golang.org/x/sync/errgroup returns only the first error:
    57вҶ’import "golang.org/x/sync/errgroup"
    58вҶ’
    59вҶ’g := new(errgroup.Group)
    60вҶ’g.Go(func() error { return task1() })
    61вҶ’g.Go(func() error { return task2() })
    62вҶ’err := g.Wait() // Returns first error only
    63вҶ’
    64вҶ’// To collect ALL errors like multierror.Group does, use a mutex:
    65вҶ’type ErrorCollector struct {
    66вҶ’    mu   sync.Mutex
    67вҶ’    errs []error
    68вҶ’}
    69вҶ’
    70вҶ’func (ec *ErrorCollector) Add(err error) {
    71вҶ’    if err != nil {
    72вҶ’        ec.mu.Lock()
    73вҶ’        ec.errs = append(ec.errs, err)
    74вҶ’        ec.mu.Unlock()
    75вҶ’    }
    76вҶ’}
    77вҶ’
    78вҶ’func (ec *ErrorCollector) Err() error {
    79вҶ’    ec.mu.Lock()
    80вҶ’    defer ec.mu.Unlock()
    81вҶ’    if len(ec.errs) == 0 {
    82вҶ’        return nil
    83вҶ’    }
    84вҶ’    return errors.Join(ec.errs...)
    85вҶ’}
    86вҶ’```
    87вҶ’
    88вҶ’---

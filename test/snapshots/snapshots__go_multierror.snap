multierror.go
    11вҶ’// Error is an error type to track multiple errors. This is used to
    12вҶ’// accumulate errors in cases and return them as a single "error".
    13вҶ’type Error struct {
    14вҶ’	Errors      []error
    15вҶ’	ErrorFormat ErrorFormatFunc
    16вҶ’}
    18вҶ’func (e *Error) Error() string {
    19вҶ’	fn := e.ErrorFormat
    20вҶ’	if fn == nil {
    21вҶ’		fn = ListFormatFunc
    22вҶ’	}
    23вҶ’
    24вҶ’	return fn(e.Errors)
    25вҶ’}

     6тЖТclass RendererContext:
     7тЖТ    """
     8тЖТ    Context key for storing, and utility for retrieving the renderer instance from the rendering context.
     9тЖТ    """
    10тЖТ
    11тЖТ    @classmethod
    12тЖТ    def from_context(cls, context: Context) -> RendererType:
    13тЖТ        """
    14тЖТ        Returns the renderer instance from the given context.
    15тЖТ
    16тЖТ        Arguments:
    17тЖТ            context: The context the renderer instance should be loaded from.
    18тЖТ
    19тЖТ        Raises:
    20тЖТ            KeyError: If no renderer instance was found in the context.
    21тЖТ            TypeError: If the value corresponding to `RendererContext` in the context is not a renderer.
    22тЖТ        """
    23тЖТ        renderer = context[cls]
    24тЖТ
    25тЖТ        if not is_renderer(renderer):
    26тЖТ            raise TypeError("The value corresponding to RendererContext in the context must be a renderer.")
    27тЖТ
    28тЖТ        return renderer


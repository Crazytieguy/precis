     6‚Üíclass RendererContext:
     7‚Üí    """
     8‚Üí    Context key for storing, and utility for retrieving the renderer instance from the rendering context.
     9‚Üí    """
    10‚Üí
    11‚Üí    @classmethod
    12‚Üí    def from_context(cls, context: Context) -> RendererType:
    13‚Üí        """
    14‚Üí        Returns the renderer instance from the given context.
    15‚Üí
    16‚Üí        Arguments:
    17‚Üí            context: The context the renderer instance should be loaded from.
    18‚Üí
    19‚Üí        Raises:
    20‚Üí            KeyError: If no renderer instance was found in the context.
    21‚Üí            TypeError: If the value corresponding to `RendererContext` in the context is not a renderer.
    22‚Üí        """
    23‚Üí        renderer = context[cls]
    24‚Üí
    25‚Üí        if not is_renderer(renderer):
    26‚Üí            raise TypeError("The value corresponding to RendererContext in the context must be a renderer.")
    27‚Üí
    28‚Üí        return renderer


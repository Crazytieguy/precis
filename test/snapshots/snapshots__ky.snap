    68Рєњexport type ForceRetryOptions = {
    69Рєњ	/**
    70Рєњ	Custom delay in milliseconds before retrying.
    71Рєњ
    72Рєњ	If not provided, uses the default retry delay calculation based on `retry.delay` configuration.
    73Рєњ
    74Рєњ	**Note:** Custom delays bypass jitter and `backoffLimit`. This is intentional, as custom delays often come from server responses (e.g., `Retry-After` headers) and should be respected exactly as specified.
    75Рєњ	*/
    76Рєњ	delay?: number;
    77Рєњ
    78Рєњ	/**
    79Рєњ	Error code for the retry.
    80Рєњ
    81Рєњ	This machine-readable identifier will be included in the error message passed to `beforeRetry` hooks, allowing you to distinguish between different types of forced retries.
    82Рєњ
    83Рєњ	@example
    84Рєњ	```
    85Рєњ	return ky.retry({code: 'RATE_LIMIT'});
    86Рєњ	// Resulting error message: 'Forced retry: RATE_LIMIT'
    87Рєњ	```
    88Рєњ	*/
    89Рєњ	code?: string;
    90Рєњ
    91Рєњ	/**
    92Рєњ	Original error that caused the retry.
    93Рєњ
    94Рєњ	This allows you to preserve the error chain when forcing a retry based on caught exceptions. The error will be set as the `cause` of the `ForceRetryError`, enabling proper error chain traversal.
    95Рєњ
    96Рєњ	@example
    97Рєњ	```
    98Рєњ	try {
    99Рєњ		const data = await response.clone().json();
   100Рєњ		validateBusinessLogic(data);
   101Рєњ	} catch (error) {
   102Рєњ		return ky.retry({
   103Рєњ			code: 'VALIDATION_FAILED',
   104Рєњ			cause: error  // Preserves original error in chain
   105Рєњ		});
   106Рєњ	}
   107Рєњ	```
   108Рєњ	*/
   109Рєњ	cause?: Error;
   110Рєњ
   111Рєњ	/**
   112Рєњ	Custom request to use for the retry.
   113Рєњ
   114Рєњ	This allows you to modify or completely replace the request during a forced retry. The custom request becomes the starting point for the retry - `beforeRetry` hooks can still further modify it if needed.
   115Рєњ
   116Рєњ	**Note:** The custom request's `signal` will be replaced with Ky's managed signal to handle timeouts and user-provided abort signals correctly. If the original request body has been consumed, you must provide a new body or clone the request before consuming.
   117Рєњ
   118Рєњ	@example
   119Рєњ	```
   120Рєњ	// Fallback to a different endpoint
   121Рєњ	return ky.retry({
   122Рєњ		request: new Request('https://backup-api.com/endpoint', {
   123Рєњ			method: request.method,
   124Рєњ			headers: request.headers,
   125Рєњ		}),
   126Рєњ		code: 'BACKUP_ENDPOINT'
   127Рєњ	});
   128Рєњ
   129Рєњ	// Retry with refreshed authentication token
   130Рєњ	const data = await response.clone().json();
   131Рєњ	return ky.retry({
   132Рєњ		request: new Request(request, {
   133Рєњ			headers: {
   134Рєњ				...Object.fromEntries(request.headers),
   135Рєњ				'Authorization': `Bearer ${data.newToken}`
   136Рєњ			}
   137Рєњ		}),
   138Рєњ		code: 'TOKEN_REFRESHED'
   139Рєњ	});
   140Рєњ	```
   141Рєњ	*/
   142Рєњ	request?: Request;
   143Рєњ};

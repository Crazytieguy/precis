    68Ôćĺexport type ForceRetryOptions = {
    69Ôćĺ	/**
    70Ôćĺ	Custom delay in milliseconds before retrying.
    71Ôćĺ
    72Ôćĺ	If not provided, uses the default retry delay calculation based on `retry.delay` configuration.
    73Ôćĺ
    74Ôćĺ	**Note:** Custom delays bypass jitter and `backoffLimit`. This is intentional, as custom delays often come from server responses (e.g., `Retry-After` headers) and should be respected exactly as specified.
    75Ôćĺ	*/
    76Ôćĺ	delay?: number;
    77Ôćĺ
    78Ôćĺ	/**
    79Ôćĺ	Error code for the retry.
    80Ôćĺ
    81Ôćĺ	This machine-readable identifier will be included in the error message passed to `beforeRetry` hooks, allowing you to distinguish between different types of forced retries.
    82Ôćĺ
    83Ôćĺ	@example
    84Ôćĺ	```
    85Ôćĺ	return ky.retry({code: 'RATE_LIMIT'});
    86Ôćĺ	// Resulting error message: 'Forced retry: RATE_LIMIT'
    87Ôćĺ	```
    88Ôćĺ	*/
    89Ôćĺ	code?: string;
    90Ôćĺ
    91Ôćĺ	/**
    92Ôćĺ	Original error that caused the retry.
    93Ôćĺ
    94Ôćĺ	This allows you to preserve the error chain when forcing a retry based on caught exceptions. The error will be set as the `cause` of the `ForceRetryError`, enabling proper error chain traversal.
    95Ôćĺ
    96Ôćĺ	@example
    97Ôćĺ	```
    98Ôćĺ	try {
    99Ôćĺ		const data = await response.clone().json();
   100Ôćĺ		validateBusinessLogic(data);
   101Ôćĺ	} catch (error) {
   102Ôćĺ		return ky.retry({
   103Ôćĺ			code: 'VALIDATION_FAILED',
   104Ôćĺ			cause: error  // Preserves original error in chain
   105Ôćĺ		});
   106Ôćĺ	}
   107Ôćĺ	```
   108Ôćĺ	*/
   109Ôćĺ	cause?: Error;
   110Ôćĺ
   111Ôćĺ	/**
   112Ôćĺ	Custom request to use for the retry.
   113Ôćĺ
   114Ôćĺ	This allows you to modify or completely replace the request during a forced retry. The custom request becomes the starting point for the retry - `beforeRetry` hooks can still further modify it if needed.
   115Ôćĺ
   116Ôćĺ	**Note:** The custom request's `signal` will be replaced with Ky's managed signal to handle timeouts and user-provided abort signals correctly. If the original request body has been consumed, you must provide a new body or clone the request before consuming.
   117Ôćĺ
   118Ôćĺ	@example
   119Ôćĺ	```
   120Ôćĺ	// Fallback to a different endpoint
   121Ôćĺ	return ky.retry({
   122Ôćĺ		request: new Request('https://backup-api.com/endpoint', {
   123Ôćĺ			method: request.method,
   124Ôćĺ			headers: request.headers,
   125Ôćĺ		}),
   126Ôćĺ		code: 'BACKUP_ENDPOINT'
   127Ôćĺ	});
   128Ôćĺ
   129Ôćĺ	// Retry with refreshed authentication token
   130Ôćĺ	const data = await response.clone().json();
   131Ôćĺ	return ky.retry({
   132Ôćĺ		request: new Request(request, {
   133Ôćĺ			headers: {
   134Ôćĺ				...Object.fromEntries(request.headers),
   135Ôćĺ				'Authorization': `Bearer ${data.newToken}`
   136Ôćĺ			}
   137Ôćĺ		}),
   138Ôćĺ		code: 'TOKEN_REFRESHED'
   139Ôćĺ	});
   140Ôćĺ	```
   141Ôćĺ	*/
   142Ôćĺ	request?: Request;
   143Ôćĺ};

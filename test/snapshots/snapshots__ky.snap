    80вҶ’
    81вҶ’			return value;
    82вҶ’		})
    83вҶ’	}).json();
    84вҶ’	```
    85вҶ’	*/
    86вҶ’	stringifyJson?: (data: unknown) => string;
    87вҶ’
    88вҶ’	/**
    89вҶ’	Search parameters to include in the request URL. Setting this will override all existing search parameters in the input URL.
    90вҶ’

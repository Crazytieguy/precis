    31‚Üí	ConfigFile   string // Override config file path
    32‚Üí	MaxSteps     int    // Override max steps (0 = use default)
    33‚Üí	Streaming    bool   // Enable streaming (default from config)
    34‚Üí	Quiet        bool   // Suppress debug output
    35‚Üí}

    16→// MCPHost provides programmatic access to mcphost functionality, allowing
    17→// integration of MCP tools and LLM interactions into Go applications. It manages
    18→// agents, sessions, and model configurations.
    19→type MCPHost struct {
    20→	agent       *agent.Agent
    21→	sessionMgr  *session.Manager
    22→	modelString string
    23→}
    25→// Options configures MCPHost creation with optional overrides for model,
    26→// prompts, configuration, and behavior settings. All fields are optional
    27→// and will use CLI defaults if not specified.
    28→type Options struct {
    29→	Model        string // Override model (e.g., "anthropic:claude-3-sonnet")
    30→	SystemPrompt string // Override system prompt
    31→	ConfigFile   string // Override config file path
    32→	MaxSteps     int    // Override max steps (0 = use default)
    33→	Streaming    bool   // Enable streaming (default from config)
    34→	Quiet        bool   // Suppress debug output
    35→}
    37→// New creates an MCPHost instance using the same initialization as the CLI.
    38→// It loads configuration, initializes MCP servers, creates the LLM model, and
    39→// sets up the agent for interaction. Returns an error if initialization fails.
    40→func New(ctx context.Context, opts *Options) (*MCPHost, error) {

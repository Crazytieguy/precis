     8‚Üí// Message is an alias for session.Message providing SDK users with access
     9‚Üí// to message structures for conversation history and tool interactions.
    10‚Üítype Message = session.Message
    12‚Üí// ToolCall is an alias for session.ToolCall representing a tool invocation
    13‚Üí// with its name, arguments, and result within a conversation.
    14‚Üítype ToolCall = session.ToolCall
    16‚Üí// ConvertToSchemaMessage converts an SDK message to the underlying schema message
    17‚Üí// format used by the agent for LLM interactions.
    18‚Üífunc ConvertToSchemaMessage(msg *Message) *schema.Message {
    19‚Üí	return msg.ConvertToSchemaMessage()
    20‚Üí}
    22‚Üí// ConvertFromSchemaMessage converts a schema message from the agent to an SDK
    23‚Üí// message format for use in the SDK API.
    24‚Üífunc ConvertFromSchemaMessage(msg *schema.Message) Message {
    25‚Üí	return session.ConvertFromSchemaMessage(msg)
    26‚Üí}

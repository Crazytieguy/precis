    23â†’}
    25â†’// Options configures MCPHost creation with optional overrides for model,
    26â†’// prompts, configuration, and behavior settings. All fields are optional
    27â†’// and will use CLI defaults if not specified.
    28â†’type Options struct {
    29â†’	Model        string // Override model (e.g., "anthropic:claude-3-sonnet")
    30â†’	SystemPrompt string // Override system prompt
    31â†’	ConfigFile   string // Override config file path
    32â†’	MaxSteps     int    // Override max steps (0 = use default)
    33â†’	Streaming    bool   // Enable streaming (default from config)
    34â†’	Quiet        bool   // Suppress debug output
    35â†’}
    40â†’func New(ctx context.Context, opts *Options) (*MCPHost, error) {

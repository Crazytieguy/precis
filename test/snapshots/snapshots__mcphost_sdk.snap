    16â†’// MCPHost provides programmatic access to mcphost functionality, allowing
    17â†’// integration of MCP tools and LLM interactions into Go applications. It manages
    18â†’// agents, sessions, and model configurations.
    19â†’type MCPHost struct {
    20â†’	agent       *agent.Agent
    21â†’	sessionMgr  *session.Manager

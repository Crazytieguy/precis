    16‚Üí// MCPHost provides programmatic access to mcphost functionality, allowing
    17‚Üí// integration of MCP tools and LLM interactions into Go applications. It manages
    18‚Üí// agents, sessions, and model configurations.
    19‚Üítype MCPHost struct {
    20‚Üí	agent       *agent.Agent
    21‚Üí	sessionMgr  *session.Manager
    22‚Üí	modelString string
    23‚Üí}
    25‚Üí// Options configures MCPHost creation with optional overrides for model,
    26‚Üí// prompts, configuration, and behavior settings. All fields are optional
    27‚Üí// and will use CLI defaults if not specified.
    28‚Üítype Options struct {
    29‚Üí	Model        string // Override model (e.g., "anthropic:claude-3-sonnet")
    30‚Üí	SystemPrompt string // Override system prompt
    31‚Üí	ConfigFile   string // Override config file path
    32‚Üí	MaxSteps     int    // Override max steps (0 = use default)
    33‚Üí	Streaming    bool   // Enable streaming (default from config)
    34‚Üí	Quiet        bool   // Suppress debug output
    35‚Üí}

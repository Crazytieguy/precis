docs/readme.md
     7→### Usage
     9→Superstruct allows you to define the shape of data you want to validate:
    10→
    11→```js
    12→import { assert, object, number, string, array } from 'superstruct'
    13→
    14→const Article = object({
    15→  id: number(),
    16→  title: string(),
    17→  tags: array(string()),
    18→  author: object({
    19→    id: number(),
    20→  }),
    21→})
    22→
    23→const data = {
    24→  id: 34,
    25→  title: 'Hello World',
    26→  tags: ['news', 'features'],
    27→  author: {
    28→    id: 1,
    29→  },
    30→}
    31→
      →…


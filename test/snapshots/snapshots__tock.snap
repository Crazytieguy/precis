demo/demo_script.sh
     2вҶ’
     3вҶ’# Auto-start asciinema recording if not already running
     4вҶ’if [ -z "$ASCIINEMA_REC" ]; then
     5вҶ’    OUTPUT_FILE="./demo/demo.cast"
     6вҶ’    
     7вҶ’    # Remove existing recording file
     8вҶ’    rm -f "$OUTPUT_FILE"
     9вҶ’    echo "Starting asciinema recording to $OUTPUT_FILE..."
    10вҶ’
    11вҶ’    # Re-run this script inside asciinema, setting the flag to prevent infinite loop
    12вҶ’    asciinema rec -c "env ASCIINEMA_REC=1 $0" "$OUTPUT_FILE"
    13вҶ’    echo "Recording finished. Saved to $OUTPUT_FILE"
    14вҶ’    exit 0
    15вҶ’fi
    16вҶ’
    17вҶ’# Configuration
    18вҶ’# Run from the root of the repository
    19вҶ’BINARY="./bin/tock"
    20вҶ’DATA_FILE="./demo/demo_data.txt"
    21вҶ’export TOCK_FILE="$DATA_FILE"
    22вҶ’
    23вҶ’# Colors
    24вҶ’GREEN='\033[0;32m'
    25вҶ’BLUE='\033[0;34m'
    26вҶ’NC='\033[0m' # No Color
    27вҶ’YELLOW='\033[0;33m'
    28вҶ’WHITE='\033[1;37m'
    29вҶ’
    30вҶ’# Helper function to print command and wait for enter
    31вҶ’p() {
    32вҶ’    echo -e "${GREEN}$ $1${NC}"
    33вҶ’    read -r
    34вҶ’}
    35вҶ’
    36вҶ’# Wait for enter then clear
    37вҶ’c() {
    38вҶ’    read -r
    39вҶ’    clear
    40вҶ’}
    41вҶ’
    42вҶ’run() {
    43вҶ’    p "$1"
    44вҶ’    eval "$1"
    45вҶ’    echo ""
    46вҶ’}
    47вҶ’
    48вҶ’# Setup
    49вҶ’mkdir -p demo
    50вҶ’rm -f "$DATA_FILE"
    51вҶ’

    30→# Helper function to print command and wait for enter
    31→p() {
    32→    echo -e "${GREEN}$ $1${NC}"
    33→    read -r
    34→}
    35→
    36→# Wait for enter then clear
    37→c() {
    38→    read -r
    39→    clear
    40→}
    41→
    42→run() {
    43→    p "$1"
    44→    eval "$1"
    45→    echo ""
    46→}

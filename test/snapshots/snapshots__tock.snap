     2→
     3→# Auto-start asciinema recording if not already running
     4→if [ -z "$ASCIINEMA_REC" ]; then
     5→    OUTPUT_FILE="./demo/demo.cast"
     6→    
     7→    # Remove existing recording file
     8→    rm -f "$OUTPUT_FILE"
     9→    echo "Starting asciinema recording to $OUTPUT_FILE..."
    10→
    11→    # Re-run this script inside asciinema, setting the flag to prevent infinite loop
    12→    asciinema rec -c "env ASCIINEMA_REC=1 $0" "$OUTPUT_FILE"
    13→    echo "Recording finished. Saved to $OUTPUT_FILE"
    14→    exit 0
    15→fi
    16→

     9‚Üí// Activity represents a time tracking entry.
    10‚Üítype Activity struct {
    11‚Üí	Description string     `json:"description"`
    12‚Üí	Project     string     `json:"project"`
    13‚Üí	StartTime   time.Time  `json:"start_time"`

    19‚Üífunc (a Activity) ID() string {
    20‚Üí	return a.StartTime.Format("150405")
    21‚Üí}
    23‚Üífunc (a Activity) Duration() time.Duration {
    24‚Üí	if a.EndTime != nil {
    25‚Üí		return a.EndTime.Sub(a.StartTime)
    26‚Üí	}
    27‚Üí	return time.Since(a.StartTime)
    28‚Üí}
    30‚Üí// DurationString returns the duration formatted as "HH:MM:SS".
    31‚Üífunc (a Activity) DurationString() string {
    32‚Üí	d := a.Duration().Round(time.Second)
    33‚Üí	h := d / time.Hour
    34‚Üí	d %= time.Hour
    35‚Üí	m := d / time.Minute
    36‚Üí	d %= time.Minute
    37‚Üí	s := d / time.Second
    38‚Üí	return fmt.Sprintf("%02d:%02d:%02d", h, m, s)
    39‚Üí}

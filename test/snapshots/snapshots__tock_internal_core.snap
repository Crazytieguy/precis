models/activity.go
     3→import (
     4→	"encoding/json"
     5→	"fmt"
     6→	"time"
     7→)
     9→// Activity represents a time tracking entry.
    10→type Activity struct {
    11→	Description string     `json:"description"`
    12→	Project     string     `json:"project"`
    13→	StartTime   time.Time  `json:"start_time"`
    14→	EndTime     *time.Time `json:"end_time,omitempty"` // nil if active
    15→	Notes       string     `json:"notes,omitempty"`
    16→	Tags        []string   `json:"tags,omitempty"`
    17→}
    19→func (a Activity) ID() string {
    20→	return a.StartTime.Format("150405")
    21→}
    23→func (a Activity) Duration() time.Duration {
    24→	if a.EndTime != nil {
    25→		return a.EndTime.Sub(a.StartTime)
    26→	}
    27→	return time.Since(a.StartTime)
    28→}
    30→// DurationString returns the duration formatted as "HH:MM:SS".
    31→func (a Activity) DurationString() string {
    32→	d := a.Duration().Round(time.Second)
    33→	h := d / time.Hour
    34→	d %= time.Hour
    35→	m := d / time.Minute
    36→	d %= time.Minute
    37→	s := d / time.Second
    38→	return fmt.Sprintf("%02d:%02d:%02d", h, m, s)
    39→}
    41→func (a Activity) MarshalJSON() ([]byte, error) {
    42→	type Alias Activity
    43→	return json.Marshal(&struct {
    44→		Alias
    45→
    46→		Duration string `json:"duration"`
    47→	}{
    48→		Alias:    (Alias)(a),
    49→		Duration: a.DurationString(),
    50→	})
    51→}


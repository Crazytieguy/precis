    41тЖТexport type DistributeMatchingUnions<a, p> = IsAny<a> extends true
    42тЖТ  ? any
    43тЖТ  : BuildMany<a, Distribute<FindUnionsMany<a, p>>>;
    80тЖТexport type FindUnions<
    81тЖТ  a,
    82тЖТ  p,
    83тЖТ  path extends PropertyKey[] = []
    84тЖТ> = unknown extends p
    85тЖТ  ? []
    86тЖТ  : IsAny<p> extends true
    87тЖТ  ? [] // Don't try to find unions after 5 levels
    88тЖТ  : Length<path> extends 5
    89тЖТ  ? []
    90тЖТ  : IsUnion<a> extends true
    91тЖТ  ? [
    92тЖТ      {
    93тЖТ        cases: a extends any
    94тЖТ          ? {
    95тЖТ              value: a;
    96тЖТ              subUnions: FindUnionsMany<a, p, path>;
    97тЖТ            }
    98тЖТ          : never;
    99тЖТ        path: path;
   100тЖТ      }
   101тЖТ    ]
   102тЖТ  : [a, p] extends [readonly any[], readonly any[]]
   103тЖТ  ? [a, p] extends [
   104тЖТ      readonly [infer a1, infer a2, infer a3, infer a4, infer a5],
   105тЖТ      readonly [infer p1, infer p2, infer p3, infer p4, infer p5]
   106тЖТ    ]
   107тЖТ    ? [
   108тЖТ        ...FindUnions<a1, p1, [...path, 0]>,
   109тЖТ        ...FindUnions<a2, p2, [...path, 1]>,
   110тЖТ        ...FindUnions<a3, p3, [...path, 2]>,
   111тЖТ        ...FindUnions<a4, p4, [...path, 3]>,
   112тЖТ        ...FindUnions<a5, p5, [...path, 4]>
   113тЖТ      ]
   114тЖТ    : [a, p] extends [
   115тЖТ        readonly [infer a1, infer a2, infer a3, infer a4],
   116тЖТ        readonly [infer p1, infer p2, infer p3, infer p4]
   117тЖТ      ]

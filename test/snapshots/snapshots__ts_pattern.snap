   110вЖТ        ...FindUnions<a3, p3, [...path, 2]>,
   111вЖТ        ...FindUnions<a4, p4, [...path, 3]>,
   112вЖТ        ...FindUnions<a5, p5, [...path, 4]>
   113вЖТ      ]
   114вЖТ    : [a, p] extends [
   115вЖТ        readonly [infer a1, infer a2, infer a3, infer a4],

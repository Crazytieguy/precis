    42‚Üí  ? any
    43‚Üí  : BuildMany<a, Distribute<FindUnionsMany<a, p>>>;
    80‚Üíexport type FindUnions<
    81‚Üí  a,
    82‚Üí  p,
    83‚Üí  path extends PropertyKey[] = []
    84‚Üí> = unknown extends p
    85‚Üí  ? []
    86‚Üí  : IsAny<p> extends true
    87‚Üí  ? [] // Don't try to find unions after 5 levels
    88‚Üí  : Length<path> extends 5
    89‚Üí  ? []
    90‚Üí  : IsUnion<a> extends true
    91‚Üí  ? [
    92‚Üí      {
    93‚Üí        cases: a extends any
    94‚Üí          ? {
    95‚Üí              value: a;
    96‚Üí              subUnions: FindUnionsMany<a, p, path>;
    97‚Üí            }
    98‚Üí          : never;
    99‚Üí        path: path;
   100‚Üí      }
   101‚Üí    ]
   102‚Üí  : [a, p] extends [readonly any[], readonly any[]]
   103‚Üí  ? [a, p] extends [
   104‚Üí      readonly [infer a1, infer a2, infer a3, infer a4, infer a5],

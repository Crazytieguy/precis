    50тЖТexport interface Matcher<
    51тЖТ  input,
    52тЖТ  narrowed,
    53тЖТ  // Type of what this pattern selected from the input
    54тЖТ  matcherType extends MatcherType = 'default',
    55тЖТ  selections extends SelectionType = None,
    56тЖТ  // Type to exclude from the input union because
    57тЖТ  // it has been fully matched by this pattern
    58тЖТ  excluded = narrowed
    59тЖТ> {
    60тЖТ  [matcher](): MatcherProtocol<
    61тЖТ    input,
    62тЖТ    narrowed,
    63тЖТ    matcherType,
    64тЖТ    selections,
    65тЖТ    excluded
    66тЖТ  >;
    67тЖТ  // only used for array matchers
    68тЖТ  [symbols.isVariadic]?: boolean;
    69тЖТ}

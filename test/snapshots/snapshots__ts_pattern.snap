    50‚Üíexport interface Matcher<
    51‚Üí  input,
    52‚Üí  narrowed,
    53‚Üí  // Type of what this pattern selected from the input
    54‚Üí  matcherType extends MatcherType = 'default',
    55‚Üí  selections extends SelectionType = None,
    56‚Üí  // Type to exclude from the input union because
    57‚Üí  // it has been fully matched by this pattern
    58‚Üí  excluded = narrowed
    59‚Üí> {
    60‚Üí  [matcher](): MatcherProtocol<
    61‚Üí    input,
    62‚Üí    narrowed,
    63‚Üí    matcherType,
    64‚Üí    selections,
    65‚Üí    excluded
    66‚Üí  >;
    67‚Üí  // only used for array matchers
    68‚Üí  [symbols.isVariadic]?: boolean;
    69‚Üí}

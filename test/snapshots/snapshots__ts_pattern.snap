    80вЖТexport type FindUnions<
    81вЖТ  a,
    82вЖТ  p,
    83вЖТ  path extends PropertyKey[] = []
    84вЖТ> = unknown extends p
    85вЖТ  ? []
    86вЖТ  : IsAny<p> extends true
    87вЖТ  ? [] // Don't try to find unions after 5 levels
    88вЖТ  : Length<path> extends 5
    89вЖТ  ? []
    90вЖТ  : IsUnion<a> extends true
    91вЖТ  ? [
    92вЖТ      {
    93вЖТ        cases: a extends any
    94вЖТ          ? {
    95вЖТ              value: a;
    96вЖТ              subUnions: FindUnionsMany<a, p, path>;
    97вЖТ            }
    98вЖТ          : never;
    99вЖТ        path: path;
   100вЖТ      }
   101вЖТ    ]
   102вЖТ  : [a, p] extends [readonly any[], readonly any[]]
   103вЖТ  ? [a, p] extends [
   104вЖТ      readonly [infer a1, infer a2, infer a3, infer a4, infer a5],
   105вЖТ      readonly [infer p1, infer p2, infer p3, infer p4, infer p5]

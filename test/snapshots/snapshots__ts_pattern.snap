    22тЖТexport type Match<
    23тЖТ  i,
    24тЖТ  o,
    25тЖТ  handledCases extends any[] = [],
    26тЖТ  inferredOutput = never
    27тЖТ> = {
    28тЖТ  /**
    29тЖТ   * `.with(pattern, handler)` Registers a pattern and an handler function that
    30тЖТ   * will be called if the pattern matches the input value.
    31тЖТ   *
    32тЖТ   * [Read the documentation for `.with()` on GitHub](https://github.com/gvergnaud/ts-pattern#with)
    33тЖТ   **/
    34тЖТ  with<
    35тЖТ    const p extends Pattern<i>,
    36тЖТ    c,
    37тЖТ    value extends MatchedValue<i, InvertPattern<p, i>>
    38тЖТ  >(
    39тЖТ    pattern: IsNever<p> extends true
    40тЖТ      ? /**
    41тЖТ         * HACK: Using `IsNever<p>` here is a hack to
    42тЖТ         * make sure the type checker forwards
    43тЖТ         * the input type parameter to pattern
    44тЖТ         * creator functions like `P.when`, `P.not`
    45тЖТ         * `P.union` when they are passed to `.with`
    46тЖТ         * directly.
    47тЖТ         */
    48тЖТ        Pattern<i>
    49тЖТ      : p,
    50тЖТ    handler: (
    51тЖТ      selections: FindSelected<value, p>,
    52тЖТ      value: value
    53тЖТ    ) => PickReturnValue<o, c>
    54тЖТ  ): InvertPatternForExclude<p, value> extends infer excluded
    55тЖТ    ? Match<
    56тЖТ        Exclude<i, excluded>,
    57тЖТ        o,
    58тЖТ        [...handledCases, excluded],
    59тЖТ        Union<inferredOutput, c>
    60тЖТ      >
    61тЖТ    : never;
    62тЖТ
    63тЖТ  with<

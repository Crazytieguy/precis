    50вЖТexport interface Matcher<
    51вЖТ  input,
    52вЖТ  narrowed,
    53вЖТ  // Type of what this pattern selected from the input
    54вЖТ  matcherType extends MatcherType = 'default',
    55вЖТ  selections extends SelectionType = None,
    56вЖТ  // Type to exclude from the input union because
    57вЖТ  // it has been fully matched by this pattern
    58вЖТ  excluded = narrowed
    59вЖТ> {
    60вЖТ  [matcher](): MatcherProtocol<
    61вЖТ    input,
    62вЖТ    narrowed,
    63вЖТ    matcherType,
    64вЖТ    selections,
    65вЖТ    excluded
    66вЖТ  >;
    67вЖТ  // only used for array matchers
    68вЖТ  [symbols.isVariadic]?: boolean;

   106тЖТexport type InvertPattern<p, input> = Equal<Pattern<input>, p> extends true
   107тЖТ  ? never
   108тЖТ  : InvertPatternInternal<p, input>;
   303тЖТexport type InvertPatternForExclude<p, i> = Equal<Pattern<i>, p> extends true
   304тЖТ  ? never
   305тЖТ  : InvertPatternForExcludeInternal<p, i>;


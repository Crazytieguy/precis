     1‚Üí//go:build !appengine && gc && !purego
     2‚Üí// +build !appengine
     3‚Üí// +build gc
     4‚Üí// +build !purego
     5‚Üí
     6‚Üí#include "textflag.h"
     7‚Üí
     8‚Üí// Registers:
     9‚Üí#define h      AX
    10‚Üí#define d      AX
    11‚Üí#define p      SI // pointer to advance through b
    12‚Üí#define n      DX
    13‚Üí#define end    BX // loop end
    14‚Üí#define v1     R8
    15‚Üí#define v2     R9
    16‚Üí#define v3     R10
    17‚Üí#define v4     R11
    18‚Üí#define x      R12
    19‚Üí#define prime1 R13
    20‚Üí#define prime2 R14
    21‚Üí#define prime4 DI
    22‚Üí
    23‚Üí#define round(acc, x) \
    24‚Üí	IMULQ prime2, x   \
    25‚Üí	ADDQ  x, acc      \
    26‚Üí	ROLQ  $31, acc    \
    27‚Üí	IMULQ prime1, acc
    28‚Üí
    29‚Üí// round0 performs the operation x = round(0, x).
    30‚Üí#define round0(x) \
    31‚Üí	IMULQ prime2, x \
    32‚Üí	ROLQ  $31, x    \
    33‚Üí	IMULQ prime1, x
    34‚Üí
    35‚Üí// mergeRound applies a merge round on the two registers acc and x.
    36‚Üí// It assumes that prime1, prime2, and prime4 have been loaded.
    37‚Üí#define mergeRound(acc, x) \
    38‚Üí	round0(x)         \
    39‚Üí	XORQ  x, acc      \
    40‚Üí	IMULQ prime1, acc \
    41‚Üí	ADDQ  prime4, acc
    42‚Üí
    43‚Üí// blockLoop processes as many 32-byte blocks as possible,
    44‚Üí// updating v1, v2, v3, and v4. It assumes that there is at least one block
    45‚Üí// to process.
    46‚Üí#define blockLoop() \
    47‚Üíloop:  \
    48‚Üí	MOVQ +0(p), x  \
    49‚Üí	round(v1, x)   \

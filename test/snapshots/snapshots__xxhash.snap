     1‚Üí//go:build !appengine && gc && !purego
     2‚Üí// +build !appengine
     3‚Üí// +build gc
     4‚Üí// +build !purego
     5‚Üí
     6‚Üí#include "textflag.h"
     7‚Üí
     8‚Üí// Registers:
     9‚Üí#define digest	R1
    10‚Üí#define h	R2 // return value
    11‚Üí#define p	R3 // input pointer
    12‚Üí#define n	R4 // input length
    13‚Üí#define nblocks	R5 // n / 32
    14‚Üí#define prime1	R7
    15‚Üí#define prime2	R8
    16‚Üí#define prime3	R9
    17‚Üí#define prime4	R10
    18‚Üí#define prime5	R11
    19‚Üí#define v1	R12
    20‚Üí#define v2	R13
    21‚Üí#define v3	R14
    22‚Üí#define v4	R15
    23‚Üí#define x1	R20
    24‚Üí#define x2	R21
    25‚Üí#define x3	R22
    26‚Üí#define x4	R23
    27‚Üí
    28‚Üí#define round(acc, x) \
    29‚Üí	MADD prime2, acc, x, acc \
    30‚Üí	ROR  $64-31, acc         \
    31‚Üí	MUL  prime1, acc
    32‚Üí
    33‚Üí// round0 performs the operation x = round(0, x).
    34‚Üí#define round0(x) \
    35‚Üí	MUL prime2, x \
    36‚Üí	ROR $64-31, x \
    37‚Üí	MUL prime1, x
    38‚Üí
    39‚Üí#define mergeRound(acc, x) \
    40‚Üí	round0(x)                     \
    41‚Üí	EOR  x, acc                   \
    42‚Üí	MADD acc, prime4, prime1, acc
    43‚Üí
    44‚Üí// blockLoop processes as many 32-byte blocks as possible,
    45‚Üí// updating v1, v2, v3, and v4. It assumes that n >= 32.
    46‚Üí#define blockLoop() \
    47‚Üí	LSR     $5, n, nblocks  \
    48‚Üí	PCALIGN $16             \
    49‚Üí	loop:                   \

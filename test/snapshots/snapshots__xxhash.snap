    23â†’#define round(acc, x) \
    24â†’	IMULQ prime2, x   \
    25â†’	ADDQ  x, acc      \
    26â†’	ROLQ  $31, acc    \
    27â†’	IMULQ prime1, acc
    28â†’
    29â†’// round0 performs the operation x = round(0, x).
    30â†’#define round0(x) \
    31â†’	IMULQ prime2, x \
    32â†’	ROLQ  $31, x    \
    33â†’	IMULQ prime1, x
    34â†’
    35â†’// mergeRound applies a merge round on the two registers acc and x.
    36â†’// It assumes that prime1, prime2, and prime4 have been loaded.
    37â†’#define mergeRound(acc, x) \
    38â†’	round0(x)         \
    39â†’	XORQ  x, acc      \
    40â†’	IMULQ prime1, acc \
    41â†’	ADDQ  prime4, acc
    42â†’

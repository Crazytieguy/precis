   420Рєњ///
   421Рєњ/// This is a reasonable return type to use throughout your application but also
   422Рєњ/// for `fn main`; if you do, failures will be printed along with any
   423Рєњ/// [context][Context] and a backtrace if one was captured.
   424Рєњ///
   425Рєњ/// `anyhow::Result` may be used with one *or* two type parameters.
   426Рєњ///
   427Рєњ/// ```rust
   428Рєњ/// use anyhow::Result;
   429Рєњ///
   430Рєњ/// # const IGNORE: &str = stringify! {
   431Рєњ/// fn demo1() -> Result<T> {...}
   432Рєњ///            // ^ equivalent to std::result::Result<T, anyhow::Error>
   433Рєњ///
   434Рєњ/// fn demo2() -> Result<T, OtherError> {...}
   435Рєњ///            // ^ equivalent to std::result::Result<T, OtherError>
   436Рєњ/// # };

   417‚Üí}
   419‚Üí/// `Result<T, Error>`
   420‚Üí///
   421‚Üí/// This is a reasonable return type to use throughout your application but also
   422‚Üí/// for `fn main`; if you do, failures will be printed along with any
   423‚Üí/// [context][Context] and a backtrace if one was captured.
   424‚Üí///
   425‚Üí/// `anyhow::Result` may be used with one *or* two type parameters.
   426‚Üí///
   427‚Üí/// ```rust
   428‚Üí/// use anyhow::Result;
   429‚Üí///
   430‚Üí/// # const IGNORE: &str = stringify! {
   431‚Üí/// fn demo1() -> Result<T> {...}
   432‚Üí///            // ^ equivalent to std::result::Result<T, anyhow::Error>
   433‚Üí///
   434‚Üí/// fn demo2() -> Result<T, OtherError> {...}
   435‚Üí///            // ^ equivalent to std::result::Result<T, OtherError>
   436‚Üí/// # };
   437‚Üí/// ```
   438‚Üí///
   439‚Üí/// # Example
   440‚Üí///
   441‚Üí/// ```
   442‚Üí/// # pub trait Deserialize {}
   443‚Üí/// #
   444‚Üí/// # mod serde_json {
   445‚Üí/// #     use super::Deserialize;
   446‚Üí/// #     use std::io;
   447‚Üí/// #
   448‚Üí/// #     pub fn from_str<T: Deserialize>(json: &str) -> io::Result<T> {
   449‚Üí/// #         unimplemented!()
   450‚Üí/// #     }
   451‚Üí/// # }
   452‚Üí/// #
   453‚Üí/// # #[derive(Debug)]
   454‚Üí/// # struct ClusterMap;
   455‚Üí/// #
   456‚Üí/// # impl Deserialize for ClusterMap {}
   457‚Üí/// #
   458‚Üí/// use anyhow::Result;
   459‚Üí///
   460‚Üí/// fn main() -> Result<()> {
   461‚Üí///     # return Ok(());
   462‚Üí///     let config = std::fs::read_to_string("cluster.json")?;
   463‚Üí///     let map: ClusterMap = serde_json::from_str(&config)?;
   464‚Üí///     println!("cluster info: {:#?}", map);
   465‚Üí///     Ok(())
   466‚Üí/// }
   467‚Üí/// ```
   468‚Üípub type Result<T, E = Error> = core::result::Result<T, E>;
   470‚Üí/// Provides the `context` method for `Result`.
   471‚Üí///

   288‚Üí/// The `Error` type, a wrapper around a dynamic error type.
   289‚Üí///
   290‚Üí/// `Error` works a lot like `Box<dyn std::error::Error>`, but with these
   291‚Üí/// differences:
   292‚Üí///
   293‚Üí/// - `Error` requires that the error is `Send`, `Sync`, and `'static`.
   294‚Üí/// - `Error` guarantees that a backtrace is available, even if the underlying
   295‚Üí///   error type does not provide one.
   296‚Üí/// - `Error` is represented as a narrow pointer &mdash; exactly one word in
   297‚Üí///   size instead of two.
   298‚Üí///
   299‚Üí/// <br>
   300‚Üí///
   301‚Üí/// # Display representations
   302‚Üí///
   303‚Üí/// When you print an error object using "{}" or to_string(), only the outermost
   304‚Üí/// underlying error or context is printed, not any of the lower level causes.
   305‚Üí/// This is exactly as if you had called the Display impl of the error from
   306‚Üí/// which you constructed your anyhow::Error.
   307‚Üí///
   308‚Üí/// ```console
   309‚Üí/// Failed to read instrs from ./path/to/instrs.json
   310‚Üí/// ```
   311‚Üí///
   312‚Üí/// To print causes as well using anyhow's default formatting of causes, use the
   313‚Üí/// alternate selector "{:#}".
   314‚Üí///
   315‚Üí/// ```console
   316‚Üí/// Failed to read instrs from ./path/to/instrs.json: No such file or directory (os error 2)
   317‚Üí/// ```
   318‚Üí///
      ‚Üí‚Ä¶
   390‚Üípub struct Error {
   391‚Üí    inner: Own<ErrorImpl>,
   392‚Üí}
   394‚Üí/// Iterator of a chain of source errors.
   395‚Üí///
   396‚Üí/// This type is the iterator returned by [`Error::chain`].
   397‚Üí///
   398‚Üí/// # Example
   399‚Üí///
   400‚Üí/// ```
   401‚Üí/// use anyhow::Error;
   402‚Üí/// use std::io;
   403‚Üí///
   404‚Üí/// pub fn underlying_io_error_kind(error: &Error) -> Option<io::ErrorKind> {
   405‚Üí///     for cause in error.chain() {
   406‚Üí///         if let Some(io_error) = cause.downcast_ref::<io::Error>() {
   407‚Üí///             return Some(io_error.kind());
   408‚Üí///         }
   409‚Üí///     }
   410‚Üí///     None
   411‚Üí/// }
   412‚Üí/// ```
   413‚Üí#[cfg(any(feature = "std", not(anyhow_no_core_error)))]
   414‚Üí#[derive(Clone)]
   415‚Üípub struct Chain<'a> {

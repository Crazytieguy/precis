   279‚Üítrait StdError: Debug + Display {
   280‚Üí    fn source(&self) -> Option<&(dyn StdError + 'static)> {
   288‚Üí/// The `Error` type, a wrapper around a dynamic error type.
   289‚Üí///
   290‚Üí/// `Error` works a lot like `Box<dyn std::error::Error>`, but with these
   291‚Üí/// differences:
   292‚Üí///
   293‚Üí/// - `Error` requires that the error is `Send`, `Sync`, and `'static`.
   294‚Üí/// - `Error` guarantees that a backtrace is available, even if the underlying
   295‚Üí///   error type does not provide one.
   296‚Üí/// - `Error` is represented as a narrow pointer &mdash; exactly one word in
   297‚Üí///   size instead of two.
   298‚Üí///
   299‚Üí/// <br>
   300‚Üí///
   301‚Üí/// # Display representations
   302‚Üí///
   303‚Üí/// When you print an error object using "{}" or to_string(), only the outermost
   304‚Üí/// underlying error or context is printed, not any of the lower level causes.
   305‚Üí/// This is exactly as if you had called the Display impl of the error from
   306‚Üí/// which you constructed your anyhow::Error.
   307‚Üí///
   308‚Üí/// ```console
   309‚Üí/// Failed to read instrs from ./path/to/instrs.json
   310‚Üí/// ```
   311‚Üí///
   312‚Üí/// To print causes as well using anyhow's default formatting of causes, use the
   313‚Üí/// alternate selector "{:#}".
   314‚Üí///
   315‚Üí/// ```console
   316‚Üí/// Failed to read instrs from ./path/to/instrs.json: No such file or directory (os error 2)
   317‚Üí/// ```
   318‚Üí///
   319‚Üí/// The Debug format "{:?}" includes your backtrace if one was captured. Note
   320‚Üí/// that this is the representation you get by default if you return an error
   321‚Üí/// from `fn main` instead of printing it explicitly yourself.
   322‚Üí///
   323‚Üí/// ```console
   324‚Üí/// Error: Failed to read instrs from ./path/to/instrs.json
   325‚Üí///
   326‚Üí/// Caused by:
   327‚Üí///     No such file or directory (os error 2)
   328‚Üí/// ```
   329‚Üí///
   330‚Üí/// and if there is a backtrace available:
   331‚Üí///
   332‚Üí/// ```console
   333‚Üí/// Error: Failed to read instrs from ./path/to/instrs.json
   334‚Üí///
   335‚Üí/// Caused by:
   336‚Üí///     No such file or directory (os error 2)
   337‚Üí///
   338‚Üí/// Stack backtrace:
   339‚Üí///    0: <E as anyhow::context::ext::StdError>::ext_context
   340‚Üí///              at /git/anyhow/src/backtrace.rs:26
   341‚Üí///    1: core::result::Result<T,E>::map_err
   342‚Üí///              at /git/rustc/src/libcore/result.rs:596
   343‚Üí///    2: anyhow::context::<impl anyhow::Context<T,E> for core::result::Result<T,E>>::with_context
   344‚Üí///              at /git/anyhow/src/context.rs:58
   345‚Üí///    3: testing::main
   346‚Üí///              at src/main.rs:5
   347‚Üí///    4: std::rt::lang_start
   348‚Üí///              at /git/rustc/src/libstd/rt.rs:61
   349‚Üí///    5: main
   350‚Üí///    6: __libc_start_main
   351‚Üí///    7: _start
   352‚Üí/// ```
   353‚Üí///
   354‚Üí/// To see a conventional struct-style Debug representation, use "{:#?}".
   355‚Üí///
   356‚Üí/// ```console
   357‚Üí/// Error {
   358‚Üí///     context: "Failed to read instrs from ./path/to/instrs.json",
   359‚Üí///     source: Os {
   360‚Üí///         code: 2,
   361‚Üí///         kind: NotFound,
   362‚Üí///         message: "No such file or directory",
   363‚Üí///     },
   364‚Üí/// }
   365‚Üí/// ```
   366‚Üí///
   367‚Üí/// If none of the built-in representations are appropriate and you would prefer
   368‚Üí/// to render the error and its cause chain yourself, it can be done something
   369‚Üí/// like this:
   370‚Üí///
   371‚Üí/// ```
   372‚Üí/// use anyhow::{Context, Result};
   373‚Üí///
   374‚Üí/// fn main() {
   375‚Üí///     if let Err(err) = try_main() {
   376‚Üí///         eprintln!("ERROR: {}", err);
   377‚Üí///         err.chain().skip(1).for_each(|cause| eprintln!("because: {}", cause));
   378‚Üí///         std::process::exit(1);
   379‚Üí///     }
   380‚Üí/// }
   381‚Üí///
   382‚Üí/// fn try_main() -> Result<()> {
   383‚Üí///     # const IGNORE: &str = stringify! {
   384‚Üí///     ...
   385‚Üí///     # };
   386‚Üí///     # Ok(())
   387‚Üí/// }
   388‚Üí/// ```
   389‚Üí#[repr(transparent)]
   390‚Üípub struct Error {
   394‚Üí/// Iterator of a chain of source errors.
   395‚Üí///
   396‚Üí/// This type is the iterator returned by [`Error::chain`].
   397‚Üí///
   398‚Üí/// # Example
   399‚Üí///
   400‚Üí/// ```
   401‚Üí/// use anyhow::Error;
   402‚Üí/// use std::io;
   403‚Üí///
   404‚Üí/// pub fn underlying_io_error_kind(error: &Error) -> Option<io::ErrorKind> {
   405‚Üí///     for cause in error.chain() {
   406‚Üí///         if let Some(io_error) = cause.downcast_ref::<io::Error>() {
   407‚Üí///             return Some(io_error.kind());
   408‚Üí///         }
   409‚Üí///     }
   410‚Üí///     None
   411‚Üí/// }
   412‚Üí/// ```
   413‚Üí#[cfg(any(feature = "std", not(anyhow_no_core_error)))]
   414‚Üí#[derive(Clone)]
   415‚Üípub struct Chain<'a> {
   419‚Üí/// `Result<T, Error>`
   420‚Üí///
   421‚Üí/// This is a reasonable return type to use throughout your application but also
   422‚Üí/// for `fn main`; if you do, failures will be printed along with any
   423‚Üí/// [context][Context] and a backtrace if one was captured.
   424‚Üí///
   425‚Üí/// `anyhow::Result` may be used with one *or* two type parameters.
   426‚Üí///
   427‚Üí/// ```rust
   428‚Üí/// use anyhow::Result;
   429‚Üí///
   430‚Üí/// # const IGNORE: &str = stringify! {
   431‚Üí/// fn demo1() -> Result<T> {...}
   432‚Üí///            // ^ equivalent to std::result::Result<T, anyhow::Error>
   433‚Üí///
   434‚Üí/// fn demo2() -> Result<T, OtherError> {...}
   435‚Üí///            // ^ equivalent to std::result::Result<T, OtherError>
   436‚Üí/// # };
   437‚Üí/// ```
   438‚Üí///
   439‚Üí/// # Example
   440‚Üí///
   441‚Üí/// ```
   442‚Üí/// # pub trait Deserialize {}
   443‚Üí/// #
   444‚Üí/// # mod serde_json {
   445‚Üí/// #     use super::Deserialize;
   446‚Üí/// #     use std::io;
   447‚Üí/// #
   448‚Üí/// #     pub fn from_str<T: Deserialize>(json: &str) -> io::Result<T> {
   449‚Üí/// #         unimplemented!()
   450‚Üí/// #     }
   451‚Üí/// # }
   452‚Üí/// #
   453‚Üí/// # #[derive(Debug)]
   454‚Üí/// # struct ClusterMap;
   455‚Üí/// #
   456‚Üí/// # impl Deserialize for ClusterMap {}
   457‚Üí/// #
   458‚Üí/// use anyhow::Result;
   459‚Üí///
   460‚Üí/// fn main() -> Result<()> {
   461‚Üí///     # return Ok(());
   462‚Üí///     let config = std::fs::read_to_string("cluster.json")?;
   463‚Üí///     let map: ClusterMap = serde_json::from_str(&config)?;
   464‚Üí///     println!("cluster info: {:#?}", map);
   465‚Üí///     Ok(())
   466‚Üí/// }
   467‚Üí/// ```
   468‚Üípub type Result<T, E = Error> = core::result::Result<T, E>;
   470‚Üí/// Provides the `context` method for `Result`.
   471‚Üí///
   472‚Üí/// This trait is sealed and cannot be implemented for types outside of
   473‚Üí/// `anyhow`.
   474‚Üí///
   475‚Üí/// <br>
   476‚Üí///
   477‚Üí/// # Example
   478‚Üí///
   479‚Üí/// ```
   480‚Üí/// use anyhow::{Context, Result};
   481‚Üí/// use std::fs;
   482‚Üí/// use std::path::PathBuf;
   483‚Üí///
   484‚Üí/// pub struct ImportantThing {
   485‚Üí///     path: PathBuf,
   486‚Üí/// }
   487‚Üí///
   488‚Üí/// impl ImportantThing {
   489‚Üí///     # const IGNORE: &'static str = stringify! {
   490‚Üí///     pub fn detach(&mut self) -> Result<()> {...}
   491‚Üí///     # };
   492‚Üí///     # fn detach(&mut self) -> Result<()> {
   493‚Üí///     #     unimplemented!()
   494‚Üí///     # }
   495‚Üí/// }
   496‚Üí///
   497‚Üí/// pub fn do_it(mut it: ImportantThing) -> Result<Vec<u8>> {
   498‚Üí///     it.detach().context("Failed to detach the important thing")?;
   499‚Üí///
   500‚Üí///     let path = &it.path;
   501‚Üí///     let content = fs::read(path)
   502‚Üí///         .with_context(|| format!("Failed to read instrs from {}", path.display()))?;
   503‚Üí///
   504‚Üí///     Ok(content)
   505‚Üí/// }
   506‚Üí/// ```
   507‚Üí///
   508‚Üí/// When printed, the outermost context would be printed first and the lower
   509‚Üí/// level underlying causes would be enumerated below.
   510‚Üí///
   511‚Üí/// ```console
   512‚Üí/// Error: Failed to read instrs from ./path/to/instrs.json
   513‚Üí///
   514‚Üí/// Caused by:
   515‚Üí///     No such file or directory (os error 2)
   516‚Üí/// ```
   517‚Üí///
   518‚Üí/// Refer to the [Display representations] documentation for other forms in
   519‚Üí/// which this context chain can be rendered.
   520‚Üí///
   521‚Üí/// [Display representations]: Error#display-representations
   522‚Üí///
   523‚Üí/// <br>
   524‚Üí///
   525‚Üí/// # Effect on downcasting
   526‚Üí///
   527‚Üí/// After attaching context of type `C` onto an error of type `E`, the resulting
   528‚Üí/// `anyhow::Error` may be downcast to `C` **or** to `E`.
   529‚Üí///
   530‚Üí/// That is, in codebases that rely on downcasting, Anyhow's context supports
   531‚Üí/// both of the following use cases:
   532‚Üí///
   533‚Üí///   - **Attaching context whose type is insignificant onto errors whose type
   534‚Üí///     is used in downcasts.**
   535‚Üí///
   536‚Üí///     In other error libraries whose context is not designed this way, it can
   537‚Üí///     be risky to introduce context to existing code because new context might
   538‚Üí///     break existing working downcasts. In Anyhow, any downcast that worked
   539‚Üí///     before adding context will continue to work after you add a context, so
   540‚Üí///     you should freely add human-readable context to errors wherever it would
   541‚Üí///     be helpful.
   542‚Üí///
   543‚Üí///     ```
   544‚Üí///     # use anyhow::bail;
   545‚Üí///     # use thiserror::Error;
   546‚Üí///     #
   547‚Üí///     # #[derive(Error, Debug)]
   548‚Üí///     # #[error("???")]
   549‚Üí///     # struct SuspiciousError;
   550‚Üí///     #
   551‚Üí///     # fn helper() -> Result<()> {
   552‚Üí///     #     bail!(SuspiciousError);
   553‚Üí///     # }
   554‚Üí///     #
   555‚Üí///     use anyhow::{Context, Result};
   556‚Üí///
   557‚Üí///     fn do_it() -> Result<()> {
   558‚Üí///         helper().context("Failed to complete the work")?;
   559‚Üí///         # const IGNORE: &str = stringify! {
   560‚Üí///         ...
   561‚Üí///         # };
   562‚Üí///         # unreachable!()
   563‚Üí///     }
   564‚Üí///
   565‚Üí///     fn main() {
   566‚Üí///         let err = do_it().unwrap_err();
   567‚Üí///         if let Some(e) = err.downcast_ref::<SuspiciousError>() {
   568‚Üí///             // If helper() returned SuspiciousError, this downcast will
   569‚Üí///             // correctly succeed even with the context in between.
   570‚Üí///             # return;
   571‚Üí///         }
   572‚Üí///         # panic!("expected downcast to succeed");
   573‚Üí///     }
   574‚Üí///     ```
   575‚Üí///
   576‚Üí///   - **Attaching context whose type is used in downcasts onto errors whose
   577‚Üí///     type is insignificant.**
   578‚Üí///
   579‚Üí///     Some codebases prefer to use machine-readable context to categorize
   580‚Üí///     lower level errors in a way that will be actionable to higher levels of
   581‚Üí///     the application.
   582‚Üí///
   583‚Üí///     ```
   584‚Üí///     # use anyhow::bail;
   585‚Üí///     # use thiserror::Error;
   586‚Üí///     #
   587‚Üí///     # #[derive(Error, Debug)]
   588‚Üí///     # #[error("???")]
   589‚Üí///     # struct HelperFailed;
   590‚Üí///     #
   591‚Üí///     # fn helper() -> Result<()> {
   592‚Üí///     #     bail!("no such file or directory");
   593‚Üí///     # }
   594‚Üí///     #
   595‚Üí///     use anyhow::{Context, Result};
   596‚Üí///
   597‚Üí///     fn do_it() -> Result<()> {
   598‚Üí///         helper().context(HelperFailed)?;
   599‚Üí///         # const IGNORE: &str = stringify! {
   600‚Üí///         ...
   601‚Üí///         # };
   602‚Üí///         # unreachable!()
   603‚Üí///     }
   604‚Üí///
   605‚Üí///     fn main() {
   606‚Üí///         let err = do_it().unwrap_err();
   607‚Üí///         if let Some(e) = err.downcast_ref::<HelperFailed>() {
   608‚Üí///             // If helper failed, this downcast will succeed because
   609‚Üí///             // HelperFailed is the context that has been attached to
   610‚Üí///             // that error.
   611‚Üí///             # return;
   612‚Üí///         }
   613‚Üí///         # panic!("expected downcast to succeed");
   614‚Üí///     }
   615‚Üí///     ```
   616‚Üípub trait Context<T, E>: context::private::Sealed {
   617‚Üí    /// Wrap the error value with additional context.
   618‚Üí    fn context<C>(self, context: C) -> Result<T, Error>
   619‚Üí    where
   620‚Üí        C: Display + Send + Sync + 'static;
   622‚Üí    /// Wrap the error value with additional context that is evaluated lazily
   623‚Üí    /// only once an error does occur.
   624‚Üí    fn with_context<C, F>(self, f: F) -> Result<T, Error>
   625‚Üí    where
   626‚Üí        C: Display + Send + Sync + 'static,
   627‚Üí        F: FnOnce() -> C;
   630‚Üí/// Equivalent to `Ok::<_, anyhow::Error>(value)`.
   631‚Üí///
   632‚Üí/// This simplifies creation of an `anyhow::Result` in places where type
   633‚Üí/// inference cannot deduce the `E` type of the result &mdash; without needing

macros.rs
     1‚Üí/// Return early with an error.
     2‚Üí///
     3‚Üí/// This macro is equivalent to
     4‚Üí/// <code>return Err([anyhow!($args\...)][anyhow!])</code>.
     5‚Üí///
     6‚Üí/// The surrounding function's or closure's return value is required to be
     7‚Üí/// <code>Result&lt;_, [anyhow::Error][crate::Error]&gt;</code>.
     8‚Üí///
     9‚Üí/// [anyhow!]: crate::anyhow
    10‚Üí///
    11‚Üí/// # Example
    12‚Üí///
    13‚Üí/// ```
    14‚Üí/// # use anyhow::{bail, Result};
    15‚Üí/// #
    16‚Üí/// # fn has_permission(user: usize, resource: usize) -> bool {
    17‚Üí/// #     true
    18‚Üí/// # }
    19‚Üí/// #
    20‚Üí/// # fn main() -> Result<()> {
    21‚Üí/// #     let user = 0;
    22‚Üí/// #     let resource = 0;
    23‚Üí/// #
    24‚Üí/// if !has_permission(user, resource) {
    25‚Üí///     bail!("permission denied for accessing {}", resource);
    26‚Üí/// }
    27‚Üí/// #     Ok(())
    28‚Üí/// # }
    29‚Üí/// ```
    30‚Üí///
    31‚Üí/// ```
    32‚Üí/// # use anyhow::{bail, Result};
    33‚Üí/// # use thiserror::Error;
    34‚Üí/// #
    35‚Üí/// # const MAX_DEPTH: usize = 1;
    36‚Üí/// #
    37‚Üí/// #[derive(Error, Debug)]
    38‚Üí/// enum ScienceError {
    39‚Üí///     #[error("recursion limit exceeded")]
    40‚Üí///     RecursionLimitExceeded,
    41‚Üí///     # #[error("...")]
    42‚Üí///     # More = (stringify! {
    43‚Üí///     ...
    44‚Üí///     # }, 1).1,
    45‚Üí/// }
    46‚Üí///
    47‚Üí/// # fn main() -> Result<()> {
    48‚Üí/// #     let depth = 0;
    49‚Üí/// #
    50‚Üí/// if depth > MAX_DEPTH {
    51‚Üí///     bail!(ScienceError::RecursionLimitExceeded);
    52‚Üí/// }
    53‚Üí/// #     Ok(())
    54‚Üí/// # }
    55‚Üí/// ```
    56‚Üí#[macro_export]
    57‚Üí#[cfg_attr(not(anyhow_no_clippy_format_args), clippy::format_args)]
    58‚Üímacro_rules! bail {
    70‚Üímacro_rules! __ensure {
   174‚Üí/// Construct an ad-hoc error from a string or existing non-`anyhow` error
   175‚Üí/// value.
   176‚Üí///
   177‚Üí/// This evaluates to an [`Error`][crate::Error]. It can take either just a
   178‚Üí/// string, or a format string with arguments. It also can take any custom type
   179‚Üí/// which implements `Debug` and `Display`.
   180‚Üí///
   181‚Üí/// If called with a single argument whose type implements `std::error::Error`
   182‚Üí/// (in addition to `Debug` and `Display`, which are always required), then that
   183‚Üí/// Error impl's `source` is preserved as the `source` of the resulting
   184‚Üí/// `anyhow::Error`.
   185‚Üí///
   186‚Üí/// # Example

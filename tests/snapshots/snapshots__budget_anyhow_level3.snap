   640‚Üí/// error[E0282]: type annotations needed for `std::result::Result<i32, E>`
   641‚Üí///   --> src/main.rs:11:13
   642‚Üí///    |
   643‚Üí/// 11 |     let _ = anyhow::Result::Ok(1);
   644‚Üí///    |         -   ^^^^^^^^^^^^^^^^^^ cannot infer type for type parameter `E` declared on the enum `Result`
   645‚Üí///    |         |
   646‚Üí///    |         consider giving this pattern the explicit type `std::result::Result<i32, E>`, where the type parameter `E` is specified
   647‚Üí/// ```
   648‚Üí#[allow(non_snake_case)]
   649‚Üí#[inline]
   650‚Üípub fn Ok<T>(value: T) -> Result<T> {

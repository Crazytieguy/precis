   433‚Üí///
   434‚Üí/// fn demo2() -> Result<T, OtherError> {...}
   435‚Üí///            // ^ equivalent to std::result::Result<T, OtherError>
   436‚Üí/// # };
   437‚Üí/// ```
   438‚Üí///

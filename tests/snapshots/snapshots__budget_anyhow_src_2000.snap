   419тЖТ/// `Result<T, Error>`
   420тЖТ///
   421тЖТ/// This is a reasonable return type to use throughout your application but also
   422тЖТ/// for `fn main`; if you do, failures will be printed along with any
   423тЖТ/// [context][Context] and a backtrace if one was captured.
   424тЖТ///
   425тЖТ/// `anyhow::Result` may be used with one *or* two type parameters.
   426тЖТ///
   427тЖТ/// ```rust
   428тЖТ/// use anyhow::Result;
   429тЖТ///
   430тЖТ/// # const IGNORE: &str = stringify! {
   431тЖТ/// fn demo1() -> Result<T> {...}
   432тЖТ///            // ^ equivalent to std::result::Result<T, anyhow::Error>
   433тЖТ///
   434тЖТ/// fn demo2() -> Result<T, OtherError> {...}
   435тЖТ///            // ^ equivalent to std::result::Result<T, OtherError>
   436тЖТ/// # };
   437тЖТ/// ```
   438тЖТ///
   439тЖТ/// # Example
   440тЖТ///
   441тЖТ/// ```
   442тЖТ/// # pub trait Deserialize {}
   443тЖТ/// #
   444тЖТ/// # mod serde_json {
   445тЖТ/// #     use super::Deserialize;
   446тЖТ/// #     use std::io;
   447тЖТ/// #
   448тЖТ/// #     pub fn from_str<T: Deserialize>(json: &str) -> io::Result<T> {
   449тЖТ/// #         unimplemented!()
   450тЖТ/// #     }
   451тЖТ/// # }
   452тЖТ/// #
   453тЖТ/// # #[derive(Debug)]
   454тЖТ/// # struct ClusterMap;
   455тЖТ/// #
   456тЖТ/// # impl Deserialize for ClusterMap {}
   457тЖТ/// #
   458тЖТ/// use anyhow::Result;
   459тЖТ///
   460тЖТ/// fn main() -> Result<()> {
   461тЖТ///     # return Ok(());
   462тЖТ///     let config = std::fs::read_to_string("cluster.json")?;
   463тЖТ///     let map: ClusterMap = serde_json::from_str(&config)?;
   464тЖТ///     println!("cluster info: {:#?}", map);
   465тЖТ///     Ok(())
   466тЖТ/// }
   467тЖТ/// ```
   468тЖТpub type Result<T, E = Error> = core::result::Result<T, E>;

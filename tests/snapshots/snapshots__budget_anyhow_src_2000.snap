   419вҶ’/// `Result<T, Error>`
   420вҶ’///
   421вҶ’/// This is a reasonable return type to use throughout your application but also
   422вҶ’/// for `fn main`; if you do, failures will be printed along with any
   423вҶ’/// [context][Context] and a backtrace if one was captured.
   424вҶ’///
   425вҶ’/// `anyhow::Result` may be used with one *or* two type parameters.
   426вҶ’///
   427вҶ’/// ```rust
   428вҶ’/// use anyhow::Result;
   429вҶ’///
   430вҶ’/// # const IGNORE: &str = stringify! {
   431вҶ’/// fn demo1() -> Result<T> {...}
   432вҶ’///            // ^ equivalent to std::result::Result<T, anyhow::Error>
   433вҶ’///
   434вҶ’/// fn demo2() -> Result<T, OtherError> {...}
   435вҶ’///            // ^ equivalent to std::result::Result<T, OtherError>
   436вҶ’/// # };
   437вҶ’/// ```
   438вҶ’///
   439вҶ’/// # Example
   440вҶ’///
   441вҶ’/// ```
   442вҶ’/// # pub trait Deserialize {}
   443вҶ’/// #
   444вҶ’/// # mod serde_json {
   445вҶ’/// #     use super::Deserialize;
   446вҶ’/// #     use std::io;
   447вҶ’/// #
   448вҶ’/// #     pub fn from_str<T: Deserialize>(json: &str) -> io::Result<T> {
   449вҶ’/// #         unimplemented!()
   450вҶ’/// #     }
   451вҶ’/// # }
   452вҶ’/// #
   453вҶ’/// # #[derive(Debug)]
   454вҶ’/// # struct ClusterMap;
   455вҶ’/// #
   456вҶ’/// # impl Deserialize for ClusterMap {}
   457вҶ’/// #
   458вҶ’/// use anyhow::Result;
   459вҶ’///
   460вҶ’/// fn main() -> Result<()> {
   461вҶ’///     # return Ok(());
   462вҶ’///     let config = std::fs::read_to_string("cluster.json")?;
   463вҶ’///     let map: ClusterMap = serde_json::from_str(&config)?;
   464вҶ’///     println!("cluster info: {:#?}", map);
   465вҶ’///     Ok(())
   466вҶ’/// }
   467вҶ’/// ```

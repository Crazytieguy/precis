    67→            </CMDKWrapper>
    68→          )}
    69→        </AnimatePresence>
    70→
    71→        <ThemeContext.Provider value={{ theme, setTheme }}>
    72→          <ThemeSwitcher />
    73→        </ThemeContext.Provider>
    74→
    75→        <div aria-hidden className={styles.line} />
    76→
    77→        <Codeblock />
    78→      </div>
    79→      <Footer />
    80→    </main>
    81→  )
    82→}

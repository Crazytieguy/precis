    54Ôćĺfunction commandScoreInner(
    55Ôćĺ  string,
    56Ôćĺ  abbreviation,
    57Ôćĺ  lowerString,
    58Ôćĺ  lowerAbbreviation,
    59Ôćĺ  stringIndex,
    60Ôćĺ  abbreviationIndex,

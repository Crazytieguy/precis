    66Ôćĺ    }
    67Ôćĺ    return PENALTY_NOT_COMPLETE
    68Ôćĺ  }
    69Ôćĺ
    70Ôćĺ  var memoizeKey = `${stringIndex},${abbreviationIndex}`
    71Ôćĺ  if (memoizedResults[memoizeKey] !== undefined) {
    72Ôćĺ    return memoizedResults[memoizeKey]
    73Ôćĺ  }
    74Ôćĺ

   150‚Üífunction formatInput(string) {
   151‚Üí  // convert all valid space characters to space so they match each other
   152‚Üí  return string.toLowerCase().replace(COUNT_SPACE_REGEXP, ' ')
   153‚Üí}
   155‚Üíexport function commandScore(string: string, abbreviation: string, aliases: string[]): number {
   156‚Üí  /* NOTE:
   157‚Üí   * in the original, we used to do the lower-casing on each recursive call, but this meant that toLowerCase()
   158‚Üí   * was the dominating cost in the algorithm, passing both is a little ugly, but considerably faster.
   159‚Üí   */
   160‚Üí  string = aliases && aliases.length > 0 ? `${string + ' ' + aliases.join(' ')}` : string
   161‚Üí  return commandScoreInner(string, abbreviation, formatInput(string), formatInput(abbreviation), 0, 0, {})
   162‚Üí}


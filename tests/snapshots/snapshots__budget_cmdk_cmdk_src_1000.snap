   150тЖТfunction formatInput(string) {
   151тЖТ  // convert all valid space characters to space so they match each other
   152тЖТ  return string.toLowerCase().replace(COUNT_SPACE_REGEXP, ' ')
   153тЖТ}
   155тЖТexport function commandScore(string: string, abbreviation: string, aliases: string[]): number {
   156тЖТ  /* NOTE:
   157тЖТ   * in the original, we used to do the lower-casing on each recursive call, but this meant that toLowerCase()
   158тЖТ   * was the dominating cost in the algorithm, passing both is a little ugly, but considerably faster.
   159тЖТ   */
   160тЖТ  string = aliases && aliases.length > 0 ? `${string + ' ' + aliases.join(' ')}` : string
   161тЖТ  return commandScoreInner(string, abbreviation, formatInput(string), formatInput(abbreviation), 0, 0, {})
   162тЖТ}

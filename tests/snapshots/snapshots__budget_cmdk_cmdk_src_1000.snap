   993тЖТfunction useLazyRef<T>(fn: () => T) {
   994тЖТ  const ref = React.useRef<T>()
   995тЖТ
   996тЖТ  if (ref.current === undefined) {
   997тЖТ    ref.current = fn()
   998тЖТ  }
   999тЖТ
  1000тЖТ  return ref as React.MutableRefObject<T>
  1001тЖТ}
  1003тЖТ/** Run a selector against the store state. */
  1004тЖТfunction useCmdk<T = any>(selector: (state: State) => T): T {
  1005тЖТ  const store = useStore()
  1006тЖТ  const cb = () => selector(store.snapshot())
  1007тЖТ  return React.useSyncExternalStore(store.subscribe, cb, cb)
  1008тЖТ}

  1061тЖТfunction renderChildren(children: React.ReactElement) {
  1062тЖТ  const childrenType = children.type as any
  1063тЖТ  // The children is a component
  1064тЖТ  if (typeof childrenType === 'function') return childrenType(children.props)
  1065тЖТ  // The children is a component with `forwardRef`
  1066тЖТ  else if ('render' in childrenType) return childrenType.render(children.props)
  1067тЖТ  // It's a string, boolean, etc.
  1068тЖТ  else return children
  1069тЖТ}
  1071тЖТfunction SlottableWithNestedChildren(

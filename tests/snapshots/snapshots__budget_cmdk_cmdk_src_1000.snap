  1003‚Üí/** Run a selector against the store state. */
  1004‚Üífunction useCmdk<T = any>(selector: (state: State) => T): T {
  1005‚Üí  const store = useStore()
  1006‚Üí  const cb = () => selector(store.snapshot())
  1007‚Üí  return React.useSyncExternalStore(store.subscribe, cb, cb)
  1008‚Üí}

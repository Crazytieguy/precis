   963Ôćĺfunction findNextSibling(el: Element, selector: string) {
   964Ôćĺ  let sibling = el.nextElementSibling
   965Ôćĺ
   966Ôćĺ  while (sibling) {
   967Ôćĺ    if (sibling.matches(selector)) return sibling
   968Ôćĺ    sibling = sibling.nextElementSibling
   969Ôćĺ  }
   970Ôćĺ}
   972Ôćĺfunction findPreviousSibling(el: Element, selector: string) {
   973Ôćĺ  let sibling = el.previousElementSibling
   974Ôćĺ
   975Ôćĺ  while (sibling) {
   976Ôćĺ    if (sibling.matches(selector)) return sibling
   977Ôćĺ    sibling = sibling.previousElementSibling
   978Ôćĺ  }
   979Ôćĺ}
   981Ôćĺfunction useAsRef<T>(data: T) {
   982Ôćĺ  const ref = React.useRef<T>(data)
   983Ôćĺ
   984Ôćĺ  useLayoutEffect(() => {
   985Ôćĺ    ref.current = data
   986Ôćĺ  })
   987Ôćĺ
   988Ôćĺ  return ref
   989Ôćĺ}
   991Ôćĺconst useLayoutEffect = typeof window === 'undefined' ? React.useEffect : React.useLayoutEffect
   993Ôćĺfunction useLazyRef<T>(fn: () => T) {
   994Ôćĺ  const ref = React.useRef<T>()
   995Ôćĺ
   996Ôćĺ  if (ref.current === undefined) {
   997Ôćĺ    ref.current = fn()
   998Ôćĺ  }
   999Ôćĺ
  1000Ôćĺ  return ref as React.MutableRefObject<T>
  1001Ôćĺ}
  1003Ôćĺ/** Run a selector against the store state. */
  1004Ôćĺfunction useCmdk<T = any>(selector: (state: State) => T): T {
  1005Ôćĺ  const store = useStore()
  1006Ôćĺ  const cb = () => selector(store.snapshot())
  1007Ôćĺ  return React.useSyncExternalStore(store.subscribe, cb, cb)
  1008Ôćĺ}
  1010Ôćĺfunction useValue(
  1011Ôćĺ  id: string,
  1012Ôćĺ  ref: React.RefObject<HTMLElement>,
  1013Ôćĺ  deps: (string | React.ReactNode | React.RefObject<HTMLElement>)[],
  1014Ôćĺ  aliases: string[] = [],
  1015Ôćĺ) {
  1016Ôćĺ  const valueRef = React.useRef<string>()
  1017Ôćĺ  const context = useCommand()
  1018Ôćĺ
  1019Ôćĺ  useLayoutEffect(() => {
  1020Ôćĺ    const value = (() => {
  1021Ôćĺ      for (const part of deps) {
  1022Ôćĺ        if (typeof part === 'string') {
  1023Ôćĺ          return part.trim()
  1024Ôćĺ        }
  1025Ôćĺ
  1026Ôćĺ        if (typeof part === 'object' && 'current' in part) {
  1027Ôćĺ          if (part.current) {
  1028Ôćĺ            return part.current.textContent?.trim()
  1029Ôćĺ          }
  1030Ôćĺ          return valueRef.current
  1031Ôćĺ        }
  1032Ôćĺ      }
  1033Ôćĺ    })()
  1034Ôćĺ
  1035Ôćĺ    const keywords = aliases.map((alias) => alias.trim())
  1036Ôćĺ
  1037Ôćĺ    context.value(id, value, keywords)
  1038Ôćĺ    ref.current?.setAttribute(VALUE_ATTR, value)
  1039Ôćĺ    valueRef.current = value
  1040Ôćĺ  })
  1041Ôćĺ
  1042Ôćĺ  return valueRef
  1043Ôćĺ}
  1045Ôćĺ/** Imperatively run a function on the next layout effect cycle. */
  1046Ôćĺconst useScheduleLayoutEffect = () => {
  1047Ôćĺ  const [s, ss] = React.useState<object>()
  1048Ôćĺ  const fns = useLazyRef(() => new Map<string | number, () => void>())
  1049Ôćĺ
  1050Ôćĺ  useLayoutEffect(() => {
  1051Ôćĺ    fns.current.forEach((f) => f())
  1052Ôćĺ    fns.current = new Map()
  1053Ôćĺ  }, [s])
  1054Ôćĺ
  1055Ôćĺ  return (id: string | number, cb: () => void) => {
  1056Ôćĺ    fns.current.set(id, cb)
  1057Ôćĺ    ss({})
  1058Ôćĺ  }
  1059Ôćĺ}
  1061Ôćĺfunction renderChildren(children: React.ReactElement) {
  1062Ôćĺ  const childrenType = children.type as any
  1063Ôćĺ  // The children is a component
  1064Ôćĺ  if (typeof childrenType === 'function') return childrenType(children.props)
  1065Ôćĺ  // The children is a component with `forwardRef`
  1066Ôćĺ  else if ('render' in childrenType) return childrenType.render(children.props)
  1067Ôćĺ  // It's a string, boolean, etc.
  1068Ôćĺ  else return children
  1069Ôćĺ}
  1071Ôćĺfunction SlottableWithNestedChildren(
  1072Ôćĺ  { asChild, children }: { asChild?: boolean; children?: React.ReactNode },
  1073Ôćĺ  render: (child: React.ReactNode) => JSX.Element,
  1074Ôćĺ) {
  1075Ôćĺ  if (asChild && React.isValidElement(children)) {
  1076Ôćĺ    return React.cloneElement(renderChildren(children), { ref: (children as any).ref }, render(children.props.children))
  1077Ôćĺ  }

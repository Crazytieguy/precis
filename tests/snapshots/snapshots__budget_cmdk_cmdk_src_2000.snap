   659→/**
   660→ * Command menu item. Becomes active on pointer enter or through keyboard navigation.
   661→ * Preferably pass a `value`, otherwise the value will be inferred from `children` or
   662→ * the rendered item's `textContent`.
   663→ */
   664→const Item = React.forwardRef<HTMLDivElement, ItemProps>((props, forwardedRef) => {
   665→  const id = useId()
   666→  const ref = React.useRef<HTMLDivElement>(null)
   667→  const groupContext = React.useContext(GroupContext)
   668→  const context = useCommand()
   669→  const propsRef = useAsRef(props)
   670→  const forceMount = propsRef.current?.forceMount ?? groupContext?.forceMount
   671→
   672→  useLayoutEffect(() => {
   673→    if (!forceMount) {
   674→      return context.item(id, groupContext?.id)
   675→    }
   676→  }, [forceMount])
   677→
   678→  const value = useValue(id, ref, [props.value, props.children, ref], props.keywords)
   679→
   680→  const store = useStore()
   681→  const selected = useCmdk((state) => state.value && state.value === value.current)
   682→  const render = useCmdk((state) =>
   683→    forceMount ? true : context.filter() === false ? true : !state.search ? true : state.filtered.items.get(id) > 0,
   684→  )
   685→
   686→  React.useEffect(() => {
   687→    const element = ref.current
   688→    if (!element || props.disabled) return
   689→    element.addEventListener(SELECT_EVENT, onSelect)
   690→    return () => element.removeEventListener(SELECT_EVENT, onSelect)
   691→  }, [render, props.onSelect, props.disabled])
   692→
   693→  function onSelect() {
   694→    select()
   695→    propsRef.current.onSelect?.(value.current)
   696→  }
   697→
   698→  function select() {
   699→    store.setState('value', value.current, true)
   700→  }
   701→
   702→  if (!render) return null
   703→
   704→  const { disabled, value: _, onSelect: __, forceMount: ___, keywords: ____, ...etc } = props
   705→
   706→  return (
   707→    <Primitive.div
   708→      ref={composeRefs(ref, forwardedRef)}
   709→      {...etc}
   710→      id={id}
   711→      cmdk-item=""
   712→      role="option"
   713→      aria-disabled={Boolean(disabled)}
   714→      aria-selected={Boolean(selected)}
   715→      data-disabled={Boolean(disabled)}
   716→      data-selected={Boolean(selected)}
   717→      onPointerMove={disabled || context.getDisablePointerSelection() ? undefined : select}
   718→      onClick={disabled ? undefined : onSelect}
   719→    >
   720→      {props.children}
   721→    </Primitive.div>
   722→  )
   723→})

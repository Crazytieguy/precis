   155Ôćĺexport function commandScore(string: string, abbreviation: string, aliases: string[]): number {
   156Ôćĺ  /* NOTE:
   157Ôćĺ   * in the original, we used to do the lower-casing on each recursive call, but this meant that toLowerCase()
   158Ôćĺ   * was the dominating cost in the algorithm, passing both is a little ugly, but considerably faster.
   159Ôćĺ   */
   160Ôćĺ  string = aliases && aliases.length > 0 ? `${string + ' ' + aliases.join(' ')}` : string
   161Ôćĺ  return commandScoreInner(string, abbreviation, formatInput(string), formatInput(abbreviation), 0, 0, {})
   162Ôćĺ}

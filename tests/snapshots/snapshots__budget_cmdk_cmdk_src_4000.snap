   405‚Üí      })
   406‚Üí      .forEach((item) => {
   407‚Üí        const group = item.closest(GROUP_ITEMS_SELECTOR)
   408‚Üí
   409‚Üí        if (group) {
   410‚Üí          group.appendChild(item.parentElement === group ? item : item.closest(`${GROUP_ITEMS_SELECTOR} > *`))
   411‚Üí        } else {
   412‚Üí          listInsertionElement.appendChild(
   413‚Üí            item.parentElement === listInsertionElement ? item : item.closest(`${GROUP_ITEMS_SELECTOR} > *`),
   414‚Üí          )
   415‚Üí        }
   416‚Üí      })
   417‚Üí
   418‚Üí    groups
   419‚Üí      .sort((a, b) => b[1] - a[1])
   420‚Üí      .forEach((group) => {
   421‚Üí        const element = listInnerRef.current?.querySelector(
   422‚Üí          `${GROUP_SELECTOR}[${VALUE_ATTR}="${encodeURIComponent(group[0])}"]`,
   423‚Üí        )
   424‚Üí        element?.parentElement.appendChild(element)
   425‚Üí      })
   426‚Üí  }
   427‚Üí
   428‚Üí  function selectFirstItem() {
   429‚Üí    const item = getValidItems().find((item) => item.getAttribute('aria-disabled') !== 'true')

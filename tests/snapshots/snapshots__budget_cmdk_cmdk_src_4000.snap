   659→/**
   660→ * Command menu item. Becomes active on pointer enter or through keyboard navigation.
   661→ * Preferably pass a `value`, otherwise the value will be inferred from `children` or
   662→ * the rendered item's `textContent`.
   663→ */
   664→const Item = React.forwardRef<HTMLDivElement, ItemProps>((props, forwardedRef) => {
   665→  const id = useId()
   666→  const ref = React.useRef<HTMLDivElement>(null)
   667→  const groupContext = React.useContext(GroupContext)
   668→  const context = useCommand()
   669→  const propsRef = useAsRef(props)
   670→  const forceMount = propsRef.current?.forceMount ?? groupContext?.forceMount
   671→
   672→  useLayoutEffect(() => {
   673→    if (!forceMount) {
   674→      return context.item(id, groupContext?.id)
   675→    }
   676→  }, [forceMount])
   677→
   678→  const value = useValue(id, ref, [props.value, props.children, ref], props.keywords)
   679→
   680→  const store = useStore()
   681→  const selected = useCmdk((state) => state.value && state.value === value.current)
   682→  const render = useCmdk((state) =>
   683→    forceMount ? true : context.filter() === false ? true : !state.search ? true : state.filtered.items.get(id) > 0,
   684→  )
   685→
   686→  React.useEffect(() => {
   687→    const element = ref.current
   688→    if (!element || props.disabled) return
   689→    element.addEventListener(SELECT_EVENT, onSelect)
   690→    return () => element.removeEventListener(SELECT_EVENT, onSelect)
   691→  }, [render, props.onSelect, props.disabled])
   692→
   693→  function onSelect() {
   694→    select()
   695→    propsRef.current.onSelect?.(value.current)
   696→  }
   697→
   698→  function select() {
   699→    store.setState('value', value.current, true)
   700→  }
   701→
   702→  if (!render) return null
   703→
   704→  const { disabled, value: _, onSelect: __, forceMount: ___, keywords: ____, ...etc } = props
   705→
   706→  return (
   707→    <Primitive.div
   708→      ref={composeRefs(ref, forwardedRef)}
   709→      {...etc}
   710→      id={id}
   711→      cmdk-item=""
   712→      role="option"
   713→      aria-disabled={Boolean(disabled)}
   714→      aria-selected={Boolean(selected)}
   715→      data-disabled={Boolean(disabled)}
   716→      data-selected={Boolean(selected)}
   717→      onPointerMove={disabled || context.getDisablePointerSelection() ? undefined : select}
   718→      onClick={disabled ? undefined : onSelect}
   719→    >
   720→      {props.children}
   721→    </Primitive.div>
   722→  )
   723→})
   725→/**
   726→ * Group command menu items together with a heading.
   727→ * Grouped items are always shown together.
   728→ */
   729→const Group = React.forwardRef<HTMLDivElement, GroupProps>((props, forwardedRef) => {
   730→  const { heading, children, forceMount, ...etc } = props
   731→  const id = useId()
   732→  const ref = React.useRef<HTMLDivElement>(null)
   733→  const headingRef = React.useRef<HTMLDivElement>(null)
   734→  const headingId = useId()
   735→  const context = useCommand()
   736→  const render = useCmdk((state) =>
   737→    forceMount ? true : context.filter() === false ? true : !state.search ? true : state.filtered.groups.has(id),
   738→  )
   739→
   740→  useLayoutEffect(() => {
   741→    return context.group(id)
   742→  }, [])
   743→
   744→  useValue(id, ref, [props.value, props.heading, headingRef])
   745→
   746→  const contextValue = React.useMemo(() => ({ id, forceMount }), [forceMount])
   747→
   748→  return (
   749→    <Primitive.div
   750→      ref={composeRefs(ref, forwardedRef)}
   751→      {...etc}
   752→      cmdk-group=""
   753→      role="presentation"
   754→      hidden={render ? undefined : true}
   755→    >
   756→      {heading && (
   757→        <div ref={headingRef} cmdk-group-heading="" aria-hidden id={headingId}>
   758→          {heading}
   759→        </div>
   760→      )}
   761→      {SlottableWithNestedChildren(props, (child) => (
   762→        <div cmdk-group-items="" role="group" aria-labelledby={heading ? headingId : undefined}>
   763→          <GroupContext.Provider value={contextValue}>{child}</GroupContext.Provider>
   764→        </div>
   765→      ))}
   766→    </Primitive.div>
   767→  )
   768→})
   770→/**
   771→ * A visual and semantic separator between items or groups.
   772→ * Visible when the search query is empty or `alwaysRender` is true, hidden otherwise.
   773→ */
   774→const Separator = React.forwardRef<HTMLDivElement, SeparatorProps>((props, forwardedRef) => {
   775→  const { alwaysRender, ...etc } = props
   776→  const ref = React.useRef<HTMLDivElement>(null)
   777→  const render = useCmdk((state) => !state.search)
   778→
   779→  if (!alwaysRender && !render) return null
   780→  return <Primitive.div ref={composeRefs(ref, forwardedRef)} {...etc} cmdk-separator="" role="separator" />
   781→})
   783→/**
   784→ * Command menu input.
   785→ * All props are forwarded to the underyling `input` element.
   786→ */
   787→const Input = React.forwardRef<HTMLInputElement, InputProps>((props, forwardedRef) => {
   788→  const { onValueChange, ...etc } = props
   789→  const isControlled = props.value != null
   790→  const store = useStore()
   791→  const search = useCmdk((state) => state.search)
   792→  const selectedItemId = useCmdk((state) => state.selectedItemId)
   793→  const context = useCommand()
   794→
   795→  React.useEffect(() => {
   796→    if (props.value != null) {
   797→      store.setState('search', props.value)
   798→    }
   799→  }, [props.value])
   800→
   801→  return (
   802→    <Primitive.input
   803→      ref={forwardedRef}
   804→      {...etc}
   805→      cmdk-input=""
   806→      autoComplete="off"
   807→      autoCorrect="off"
   808→      spellCheck={false}
   809→      aria-autocomplete="list"
   810→      role="combobox"
   811→      aria-expanded={true}
   812→      aria-controls={context.listId}
   813→      aria-labelledby={context.labelId}
   814→      aria-activedescendant={selectedItemId}
   815→      id={context.inputId}
   816→      type="text"
   817→      value={isControlled ? props.value : search}
   818→      onChange={(e) => {
   819→        if (!isControlled) {
   820→          store.setState('search', e.target.value)
   821→        }
   822→
   823→        onValueChange?.(e.target.value)
   824→      }}
   825→    />
   826→  )
   827→})
   829→/**
   830→ * Contains `Item`, `Group`, and `Separator`.
   831→ * Use the `--cmdk-list-height` CSS variable to animate height based on the number of results.
   832→ */
   833→const List = React.forwardRef<HTMLDivElement, ListProps>((props, forwardedRef) => {
   834→  const { children, label = 'Suggestions', ...etc } = props
   835→  const ref = React.useRef<HTMLDivElement>(null)
   836→  const height = React.useRef<HTMLDivElement>(null)
   837→  const selectedItemId = useCmdk((state) => state.selectedItemId)
   838→  const context = useCommand()
   839→
   840→  React.useEffect(() => {
   841→    if (height.current && ref.current) {
   842→      const el = height.current
   843→      const wrapper = ref.current
   844→      let animationFrame
   845→      const observer = new ResizeObserver(() => {
   846→        animationFrame = requestAnimationFrame(() => {
   847→          const height = el.offsetHeight
   848→          wrapper.style.setProperty(`--cmdk-list-height`, height.toFixed(1) + 'px')
   849→        })
   850→      })
   851→      observer.observe(el)
   852→      return () => {
   853→        cancelAnimationFrame(animationFrame)
   854→        observer.unobserve(el)
   855→      }
   856→    }
   857→  }, [])
   858→
   859→  return (
   860→    <Primitive.div
   861→      ref={composeRefs(ref, forwardedRef)}
   862→      {...etc}
   863→      cmdk-list=""
   864→      role="listbox"
   865→      tabIndex={-1}
   866→      aria-activedescendant={selectedItemId}
   867→      aria-label={label}
   868→      id={context.listId}
   869→    >
   870→      {SlottableWithNestedChildren(props, (child) => (
   871→        <div ref={composeRefs(height, context.listInnerRef)} cmdk-list-sizer="">
   872→          {child}
   873→        </div>
   874→      ))}
   875→    </Primitive.div>
   876→  )
   877→})
   879→/**
   880→ * Renders the command menu in a Radix Dialog.
   881→ */
   882→const Dialog = React.forwardRef<HTMLDivElement, DialogProps>((props, forwardedRef) => {
   883→  const { open, onOpenChange, overlayClassName, contentClassName, container, ...etc } = props
   884→  return (
   885→    <RadixDialog.Root open={open} onOpenChange={onOpenChange}>
   886→      <RadixDialog.Portal container={container}>
   887→        <RadixDialog.Overlay cmdk-overlay="" className={overlayClassName} />
   888→        <RadixDialog.Content aria-label={props.label} cmdk-dialog="" className={contentClassName}>
   889→          <Command ref={forwardedRef} {...etc} />
   890→        </RadixDialog.Content>
   891→      </RadixDialog.Portal>
   892→    </RadixDialog.Root>
   893→  )
   894→})
   896→/**
   897→ * Automatically renders when there are no results for the search query.
   898→ */
   899→const Empty = React.forwardRef<HTMLDivElement, EmptyProps>((props, forwardedRef) => {
   900→  const render = useCmdk((state) => state.filtered.count === 0)
   901→
   902→  if (!render) return null
   903→  return <Primitive.div ref={forwardedRef} {...props} cmdk-empty="" role="presentation" />
   904→})
   906→/**
   907→ * You should conditionally render this with `progress` while loading asynchronous items.
   908→ */
   909→const Loading = React.forwardRef<HTMLDivElement, LoadingProps>((props, forwardedRef) => {
   910→  const { progress, children, label = 'Loading...', ...etc } = props
   911→
   912→  return (
   913→    <Primitive.div
   914→      ref={forwardedRef}
   915→      {...etc}
   916→      cmdk-loading=""
   917→      role="progressbar"
   918→      aria-valuenow={progress}
   919→      aria-valuemin={0}
   920→      aria-valuemax={100}
   921→      aria-label={label}
   922→    >
   923→      {SlottableWithNestedChildren(props, (child) => (
   924→        <div aria-hidden>{child}</div>
   925→      ))}
   926→    </Primitive.div>
   927→  )
   928→})
   930→const pkg = Object.assign(Command, {
   931→  List,
   932→  Item,
   933→  Input,
   934→  Group,
   935→  Separator,
   936→  Dialog,
   937→  Empty,
   938→  Loading,
   939→})
   955→/**
   956→ *
   957→ *
   958→ * Helpers
   959→ *
   960→ *
   961→ */
   962→
   963→function findNextSibling(el: Element, selector: string) {
   964→  let sibling = el.nextElementSibling
   965→
   966→  while (sibling) {
   967→    if (sibling.matches(selector)) return sibling
   968→    sibling = sibling.nextElementSibling
   969→  }
   970→}
   972→function findPreviousSibling(el: Element, selector: string) {
   973→  let sibling = el.previousElementSibling
   974→
   975→  while (sibling) {
   976→    if (sibling.matches(selector)) return sibling
   977→    sibling = sibling.previousElementSibling
   978→  }
   979→}
   981→function useAsRef<T>(data: T) {
   982→  const ref = React.useRef<T>(data)
   983→
   984→  useLayoutEffect(() => {
   985→    ref.current = data
   986→  })
   987→
   988→  return ref
   989→}
   991→const useLayoutEffect = typeof window === 'undefined' ? React.useEffect : React.useLayoutEffect
   993→function useLazyRef<T>(fn: () => T) {
   994→  const ref = React.useRef<T>()
   995→
   996→  if (ref.current === undefined) {
   997→    ref.current = fn()
   998→  }
   999→
  1000→  return ref as React.MutableRefObject<T>
  1001→}
  1003→/** Run a selector against the store state. */
  1004→function useCmdk<T = any>(selector: (state: State) => T): T {
  1005→  const store = useStore()
  1006→  const cb = () => selector(store.snapshot())
  1007→  return React.useSyncExternalStore(store.subscribe, cb, cb)
  1008→}
  1010→function useValue(
  1011→  id: string,
  1012→  ref: React.RefObject<HTMLElement>,
  1013→  deps: (string | React.ReactNode | React.RefObject<HTMLElement>)[],
  1014→  aliases: string[] = [],
  1015→) {
  1016→  const valueRef = React.useRef<string>()
  1017→  const context = useCommand()
  1018→
  1019→  useLayoutEffect(() => {
  1020→    const value = (() => {
  1021→      for (const part of deps) {
  1022→        if (typeof part === 'string') {
  1023→          return part.trim()
  1024→        }
  1025→
  1026→        if (typeof part === 'object' && 'current' in part) {
  1027→          if (part.current) {
  1028→            return part.current.textContent?.trim()
  1029→          }
  1030→          return valueRef.current
  1031→        }
  1032→      }
  1033→    })()
  1034→
  1035→    const keywords = aliases.map((alias) => alias.trim())
  1036→
  1037→    context.value(id, value, keywords)
  1038→    ref.current?.setAttribute(VALUE_ATTR, value)
  1039→    valueRef.current = value
  1040→  })
  1041→
  1042→  return valueRef
  1043→}
  1045→/** Imperatively run a function on the next layout effect cycle. */
  1046→const useScheduleLayoutEffect = () => {
  1047→  const [s, ss] = React.useState<object>()
  1048→  const fns = useLazyRef(() => new Map<string | number, () => void>())
  1049→
  1050→  useLayoutEffect(() => {
  1051→    fns.current.forEach((f) => f())
  1052→    fns.current = new Map()
  1053→  }, [s])
  1054→
  1055→  return (id: string | number, cb: () => void) => {
  1056→    fns.current.set(id, cb)
  1057→    ss({})
  1058→  }
  1059→}
  1061→function renderChildren(children: React.ReactElement) {
  1062→  const childrenType = children.type as any
  1063→  // The children is a component
  1064→  if (typeof childrenType === 'function') return childrenType(children.props)
  1065→  // The children is a component with `forwardRef`
  1066→  else if ('render' in childrenType) return childrenType.render(children.props)
  1067→  // It's a string, boolean, etc.
  1068→  else return children
  1069→}
  1071→function SlottableWithNestedChildren(
  1072→  { asChild, children }: { asChild?: boolean; children?: React.ReactNode },
  1073→  render: (child: React.ReactNode) => JSX.Element,
  1074→) {
  1075→  if (asChild && React.isValidElement(children)) {
  1076→    return React.cloneElement(renderChildren(children), { ref: (children as any).ref }, render(children.props.children))
  1077→  }
  1078→  return render(children)
  1079→}
  1081→const srOnlyStyles = {
  1082→  position: 'absolute',
  1083→  width: '1px',
  1084→  height: '1px',
  1085→  padding: '0',
  1086→  margin: '-1px',
  1087→  overflow: 'hidden',
  1088→  clip: 'rect(0, 0, 0, 0)',
  1089→  whiteSpace: 'nowrap',
  1090→  borderWidth: '0',
  1091→} as const

   315‚Üí          store.emit()
   316‚Üí        })
   317‚Üí
   318‚Üí        return () => {
   319‚Üí          ids.current.delete(id)
   320‚Üí          allItems.current.delete(id)
   321‚Üí          state.current.filtered.items.delete(id)
   322‚Üí          const selectedItem = getSelectedItem()
   323‚Üí
   324‚Üí          // Batch this, multiple items could be removed in one pass
   325‚Üí          schedule(4, () => {
   326‚Üí            filterItems()
   327‚Üí
   328‚Üí            // The item removed have been the selected one,
   329‚Üí            // so selection should be moved to the first
   330‚Üí            if (selectedItem?.getAttribute('id') === id) selectFirstItem()
   331‚Üí
   332‚Üí            store.emit()
   333‚Üí          })
   334‚Üí        }
   335‚Üí      },
   336‚Üí      // Track group lifecycle (mount, unmount)
   337‚Üí      group: (id) => {
   338‚Üí        if (!allGroups.current.has(id)) {
   339‚Üí          allGroups.current.set(id, new Set())
   340‚Üí        }
   341‚Üí
   342‚Üí        return () => {
   343‚Üí          ids.current.delete(id)
   344‚Üí          allGroups.current.delete(id)
   345‚Üí        }
   346‚Üí      },
   347‚Üí      filter: () => {
   348‚Üí        return propsRef.current.shouldFilter
   349‚Üí      },
   350‚Üí      label: label || props['aria-label'],
   351‚Üí      getDisablePointerSelection: () => {
   352‚Üí        return propsRef.current.disablePointerSelection
   353‚Üí      },
   354‚Üí      listId,
   355‚Üí      inputId,
   356‚Üí      labelId,
   357‚Üí      listInnerRef,
   358‚Üí    }),
   359‚Üí    [],
   360‚Üí  )
   361‚Üí
   362‚Üí  function score(value: string, keywords?: string[]) {
   363‚Üí    const filter = propsRef.current?.filter ?? defaultFilter
   364‚Üí    return value ? filter(value, state.current.search, keywords) : 0
   365‚Üí  }
   366‚Üí
   367‚Üí  /** Sorts items by score, and groups by highest item score. */
   368‚Üí  function sort() {
   369‚Üí    if (
   370‚Üí      !state.current.search ||
   371‚Üí      // Explicitly false, because true | undefined is the default
   372‚Üí      propsRef.current.shouldFilter === false
   373‚Üí    ) {
   374‚Üí      return
   375‚Üí    }
   376‚Üí
   377‚Üí    const scores = state.current.filtered.items
   378‚Üí
   379‚Üí    // Sort the groups
   380‚Üí    const groups: [string, number][] = []
   381‚Üí    state.current.filtered.groups.forEach((value) => {
   382‚Üí      const items = allGroups.current.get(value)
   383‚Üí
   384‚Üí      // Get the maximum score of the group's items
   385‚Üí      let max = 0
   386‚Üí      items.forEach((item) => {
   387‚Üí        const score = scores.get(item)
   388‚Üí        max = Math.max(score, max)
   389‚Üí      })
   390‚Üí
   391‚Üí      groups.push([value, max])
   392‚Üí    })
   393‚Üí
   394‚Üí    // Sort items within groups to bottom
   395‚Üí    // Sort items outside of groups
   396‚Üí    // Sort groups to bottom (pushes all non-grouped items to the top)
   397‚Üí    const listInsertionElement = listInnerRef.current
   398‚Üí
   399‚Üí    // Sort the items
   400‚Üí    getValidItems()
   401‚Üí      .sort((a, b) => {
   402‚Üí        const valueA = a.getAttribute('id')
   403‚Üí        const valueB = b.getAttribute('id')

   963‚Üífunction findNextSibling(el: Element, selector: string) {
   964‚Üí  let sibling = el.nextElementSibling
   965‚Üí
   966‚Üí  while (sibling) {
   967‚Üí    if (sibling.matches(selector)) return sibling
   968‚Üí    sibling = sibling.nextElementSibling
   969‚Üí  }
   970‚Üí}
   972‚Üífunction findPreviousSibling(el: Element, selector: string) {

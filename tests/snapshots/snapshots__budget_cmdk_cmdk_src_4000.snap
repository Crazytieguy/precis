    54‚Üífunction commandScoreInner(
    55‚Üí  string,
    56‚Üí  abbreviation,
    57‚Üí  lowerString,
    58‚Üí  lowerAbbreviation,
    59‚Üí  stringIndex,
    60‚Üí  abbreviationIndex,
    61‚Üí  memoizedResults,
    62‚Üí) {
    63‚Üí  if (abbreviationIndex === abbreviation.length) {
    64‚Üí    if (stringIndex === string.length) {
    65‚Üí      return SCORE_CONTINUE_MATCH
    66‚Üí    }
    67‚Üí    return PENALTY_NOT_COMPLETE
    68‚Üí  }
    69‚Üí
    70‚Üí  var memoizeKey = `${stringIndex},${abbreviationIndex}`
    71‚Üí  if (memoizedResults[memoizeKey] !== undefined) {
    72‚Üí    return memoizedResults[memoizeKey]
    73‚Üí  }
    74‚Üí
    75‚Üí  var abbreviationChar = lowerAbbreviation.charAt(abbreviationIndex)
    76‚Üí  var index = lowerString.indexOf(abbreviationChar, stringIndex)
    77‚Üí  var highScore = 0
    78‚Üí
    79‚Üí  var score, transposedScore, wordBreaks, spaceBreaks
    80‚Üí
    81‚Üí  while (index >= 0) {
    82‚Üí    score = commandScoreInner(
    83‚Üí      string,
    84‚Üí      abbreviation,
    85‚Üí      lowerString,
    86‚Üí      lowerAbbreviation,
    87‚Üí      index + 1,
    88‚Üí      abbreviationIndex + 1,
    89‚Üí      memoizedResults,
    90‚Üí    )
    91‚Üí    if (score > highScore) {
    92‚Üí      if (index === stringIndex) {
    93‚Üí        score *= SCORE_CONTINUE_MATCH
    94‚Üí      } else if (IS_GAP_REGEXP.test(string.charAt(index - 1))) {
    95‚Üí        score *= SCORE_NON_SPACE_WORD_JUMP
    96‚Üí        wordBreaks = string.slice(stringIndex, index - 1).match(COUNT_GAPS_REGEXP)
    97‚Üí        if (wordBreaks && stringIndex > 0) {
    98‚Üí          score *= Math.pow(PENALTY_SKIPPED, wordBreaks.length)
    99‚Üí        }
   100‚Üí      } else if (IS_SPACE_REGEXP.test(string.charAt(index - 1))) {
   101‚Üí        score *= SCORE_SPACE_WORD_JUMP
   102‚Üí        spaceBreaks = string.slice(stringIndex, index - 1).match(COUNT_SPACE_REGEXP)
   103‚Üí        if (spaceBreaks && stringIndex > 0) {
   104‚Üí          score *= Math.pow(PENALTY_SKIPPED, spaceBreaks.length)
   105‚Üí        }
   106‚Üí      } else {
   107‚Üí        score *= SCORE_CHARACTER_JUMP
   108‚Üí        if (stringIndex > 0) {
   109‚Üí          score *= Math.pow(PENALTY_SKIPPED, index - stringIndex)
   110‚Üí        }
   111‚Üí      }
   112‚Üí
   113‚Üí      if (string.charAt(index) !== abbreviation.charAt(abbreviationIndex)) {
   114‚Üí        score *= PENALTY_CASE_MISMATCH
   115‚Üí      }
   116‚Üí    }
   117‚Üí
   118‚Üí    if (
   119‚Üí      (score < SCORE_TRANSPOSITION &&
   120‚Üí        lowerString.charAt(index - 1) === lowerAbbreviation.charAt(abbreviationIndex + 1)) ||
   121‚Üí      (lowerAbbreviation.charAt(abbreviationIndex + 1) === lowerAbbreviation.charAt(abbreviationIndex) && // allow duplicate letters. Ref #7428
   122‚Üí        lowerString.charAt(index - 1) !== lowerAbbreviation.charAt(abbreviationIndex))
   123‚Üí    ) {
   124‚Üí      transposedScore = commandScoreInner(
   125‚Üí        string,
   126‚Üí        abbreviation,
   127‚Üí        lowerString,
   128‚Üí        lowerAbbreviation,
   129‚Üí        index + 1,
   130‚Üí        abbreviationIndex + 2,
   131‚Üí        memoizedResults,
   132‚Üí      )
   133‚Üí
   134‚Üí      if (transposedScore * SCORE_TRANSPOSITION > score) {
   135‚Üí        score = transposedScore * SCORE_TRANSPOSITION
   136‚Üí      }
   137‚Üí    }
   138‚Üí
   139‚Üí    if (score > highScore) {
   140‚Üí      highScore = score
   141‚Üí    }
   142‚Üí
   143‚Üí    index = lowerString.indexOf(abbreviationChar, index + 1)
   144‚Üí  }
   145‚Üí
   146‚Üí  memoizedResults[memoizeKey] = highScore
   147‚Üí  return highScore
   148‚Üí}
   150‚Üífunction formatInput(string) {
   151‚Üí  // convert all valid space characters to space so they match each other
   152‚Üí  return string.toLowerCase().replace(COUNT_SPACE_REGEXP, ' ')
   153‚Üí}
   155‚Üíexport function commandScore(string: string, abbreviation: string, aliases: string[]): number {
   156‚Üí  /* NOTE:
   157‚Üí   * in the original, we used to do the lower-casing on each recursive call, but this meant that toLowerCase()
   158‚Üí   * was the dominating cost in the algorithm, passing both is a little ugly, but considerably faster.
   159‚Üí   */
   160‚Üí  string = aliases && aliases.length > 0 ? `${string + ' ' + aliases.join(' ')}` : string
   161‚Üí  return commandScoreInner(string, abbreviation, formatInput(string), formatInput(abbreviation), 0, 0, {})
   162‚Üí}


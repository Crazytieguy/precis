  1053→  }, [s])
  1054→
  1055→  return (id: string | number, cb: () => void) => {
  1056→    fns.current.set(id, cb)
  1057→    ss({})
  1058→  }
  1059→}
  1061→function renderChildren(children: React.ReactElement) {

   266‚Üí          }
   267‚Üí        }
   268‚Üí
   269‚Üí        // Notify subscribers that state has changed
   270‚Üí        store.emit()
   271‚Üí      },
   272‚Üí      emit: () => {
   273‚Üí        listeners.current.forEach((l) => l())
   274‚Üí      },
   275‚Üí    }
   276‚Üí  }, [])
   277‚Üí
   278‚Üí  const context: Context = React.useMemo(
   279‚Üí    () => ({
   280‚Üí      // Keep id ‚Üí {value, keywords} mapping up-to-date
   281‚Üí      value: (id, value, keywords) => {
   282‚Üí        if (value !== ids.current.get(id)?.value) {
   283‚Üí          ids.current.set(id, { value, keywords })
   284‚Üí          state.current.filtered.items.set(id, score(value, keywords))
   285‚Üí          schedule(2, () => {
   286‚Üí            sort()
   287‚Üí            store.emit()
   288‚Üí          })
   289‚Üí        }
   290‚Üí      },
   291‚Üí      // Track item lifecycle (mount, unmount)
   292‚Üí      item: (id, groupId) => {
   293‚Üí        allItems.current.add(id)
   294‚Üí
   295‚Üí        // Track this item within the group
   296‚Üí        if (groupId) {
   297‚Üí          if (!allGroups.current.has(groupId)) {
   298‚Üí            allGroups.current.set(groupId, new Set([id]))
   299‚Üí          } else {
   300‚Üí            allGroups.current.get(groupId).add(id)
   301‚Üí          }
   302‚Üí        }
   303‚Üí
   304‚Üí        // Batch this, multiple items can mount in one pass
   305‚Üí        // and we should not be filtering/sorting/emitting each time
   306‚Üí        schedule(3, () => {
   307‚Üí          filterItems()
   308‚Üí          sort()

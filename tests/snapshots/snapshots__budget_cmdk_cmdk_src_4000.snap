   183‚Üí      groups: new Set(),
   184‚Üí    },
   185‚Üí  }))
   186‚Üí  const allItems = useLazyRef<Set<string>>(() => new Set()) // [...itemIds]
   187‚Üí  const allGroups = useLazyRef<Map<string, Set<string>>>(() => new Map()) // groupId ‚Üí [...itemIds]
   188‚Üí  const ids = useLazyRef<Map<string, { value: string; keywords?: string[] }>>(() => new Map()) // id ‚Üí { value, keywords }
   189‚Üí  const listeners = useLazyRef<Set<() => void>>(() => new Set()) // [...rerenders]
   190‚Üí  const propsRef = useAsRef(props)
   191‚Üí  const {
   192‚Üí    label,
   193‚Üí    children,
   194‚Üí    value,
   195‚Üí    onValueChange,
   196‚Üí    filter,
   197‚Üí    shouldFilter,
   198‚Üí    loop,
   199‚Üí    disablePointerSelection = false,
   200‚Üí    vimBindings = true,
   201‚Üí    ...etc
   202‚Üí  } = props
   203‚Üí
   204‚Üí  const listId = useId()
   205‚Üí  const labelId = useId()
   206‚Üí  const inputId = useId()
   207‚Üí
   208‚Üí  const listInnerRef = React.useRef<HTMLDivElement>(null)
   209‚Üí
   210‚Üí  const schedule = useScheduleLayoutEffect()
   211‚Üí
   212‚Üí  /** Controlled mode `value` handling. */
   213‚Üí  useLayoutEffect(() => {
   214‚Üí    if (value !== undefined) {
   215‚Üí      const v = value.trim()
   216‚Üí      state.current.value = v
   217‚Üí      store.emit()
   218‚Üí    }
   219‚Üí  }, [value])
   220‚Üí
   221‚Üí  useLayoutEffect(() => {
   222‚Üí    schedule(6, scrollSelectedIntoView)
   223‚Üí  }, [])
   224‚Üí
   225‚Üí  const store: Store = React.useMemo(() => {
   226‚Üí    return {
   227‚Üí      subscribe: (cb) => {
   228‚Üí        listeners.current.add(cb)
   229‚Üí        return () => listeners.current.delete(cb)
   230‚Üí      },
   231‚Üí      snapshot: () => {
   232‚Üí        return state.current
   233‚Üí      },
   234‚Üí      setState: (key, value, opts) => {
   235‚Üí        if (Object.is(state.current[key], value)) return
   236‚Üí        state.current[key] = value
   237‚Üí
   238‚Üí        if (key === 'search') {
   239‚Üí          // Filter synchronously before emitting back to children
   240‚Üí          filterItems()
   241‚Üí          sort()
   242‚Üí          schedule(1, selectFirstItem)
   243‚Üí        } else if (key === 'value') {
   244‚Üí          // Force focus input or root so accessibility works
   245‚Üí          if (document.activeElement.hasAttribute('cmdk-input') || document.activeElement.hasAttribute('cmdk-root')) {
   246‚Üí            const input = document.getElementById(inputId)
   247‚Üí            if (input) input.focus()
   248‚Üí            else document.getElementById(listId)?.focus()
   249‚Üí          }
   250‚Üí
   251‚Üí          schedule(7, () => {
   252‚Üí            state.current.selectedItemId = getSelectedItem()?.id
   253‚Üí            store.emit()
   254‚Üí          })
   255‚Üí
   256‚Üí          // opts is a boolean referring to whether it should NOT be scrolled into view
   257‚Üí          if (!opts) {
   258‚Üí            // Scroll the selected item into view
   259‚Üí            schedule(5, scrollSelectedIntoView)
   260‚Üí          }

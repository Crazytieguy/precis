   169‚Üíconst Command = React.forwardRef<HTMLDivElement, CommandProps>((props, forwardedRef) => {
   170‚Üí  const state = useLazyRef<State>(() => ({
   171‚Üí    /** Value of the search query. */
   172‚Üí    search: '',
   173‚Üí    /** Currently selected item value. */
   174‚Üí    value: props.value ?? props.defaultValue ?? '',
   175‚Üí    /** Currently selected item id. */
   176‚Üí    selectedItemId: undefined,
   177‚Üí    filtered: {

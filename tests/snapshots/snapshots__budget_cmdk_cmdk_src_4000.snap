   678‚Üí  const value = useValue(id, ref, [props.value, props.children, ref], props.keywords)
   679‚Üí
   680‚Üí  const store = useStore()
   681‚Üí  const selected = useCmdk((state) => state.value && state.value === value.current)
   682‚Üí  const render = useCmdk((state) =>
   683‚Üí    forceMount ? true : context.filter() === false ? true : !state.search ? true : state.filtered.items.get(id) > 0,
   684‚Üí  )

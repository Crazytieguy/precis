   433‚Üí
   434‚Üí  /** Filters the current items. */
   435‚Üí  function filterItems() {
   436‚Üí    if (
   437‚Üí      !state.current.search ||
   438‚Üí      // Explicitly false, because true | undefined is the default
   439‚Üí      propsRef.current.shouldFilter === false
   440‚Üí    ) {
   441‚Üí      state.current.filtered.count = allItems.current.size

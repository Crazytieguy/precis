   963‚Üífunction findNextSibling(el: Element, selector: string) {
   964‚Üí  let sibling = el.nextElementSibling
   965‚Üí
   966‚Üí  while (sibling) {
   967‚Üí    if (sibling.matches(selector)) return sibling
   968‚Üí    sibling = sibling.nextElementSibling
   969‚Üí  }
   970‚Üí}
   972‚Üífunction findPreviousSibling(el: Element, selector: string) {
   973‚Üí  let sibling = el.previousElementSibling
   974‚Üí
   975‚Üí  while (sibling) {
   976‚Üí    if (sibling.matches(selector)) return sibling
   977‚Üí    sibling = sibling.previousElementSibling
   978‚Üí  }
   979‚Üí}
   981‚Üífunction useAsRef<T>(data: T) {
   982‚Üí  const ref = React.useRef<T>(data)
   983‚Üí
   984‚Üí  useLayoutEffect(() => {
   985‚Üí    ref.current = data
   986‚Üí  })
   987‚Üí
   988‚Üí  return ref
   989‚Üí}
   991‚Üíconst useLayoutEffect = typeof window === 'undefined' ? React.useEffect : React.useLayoutEffect
   993‚Üífunction useLazyRef<T>(fn: () => T) {
   994‚Üí  const ref = React.useRef<T>()
   995‚Üí
   996‚Üí  if (ref.current === undefined) {
   997‚Üí    ref.current = fn()
   998‚Üí  }
   999‚Üí
  1000‚Üí  return ref as React.MutableRefObject<T>
  1001‚Üí}
  1003‚Üí/** Run a selector against the store state. */
  1004‚Üífunction useCmdk<T = any>(selector: (state: State) => T): T {
  1005‚Üí  const store = useStore()
  1006‚Üí  const cb = () => selector(store.snapshot())
  1007‚Üí  return React.useSyncExternalStore(store.subscribe, cb, cb)
  1008‚Üí}
  1010‚Üífunction useValue(
  1011‚Üí  id: string,
  1012‚Üí  ref: React.RefObject<HTMLElement>,
  1013‚Üí  deps: (string | React.ReactNode | React.RefObject<HTMLElement>)[],
  1014‚Üí  aliases: string[] = [],
  1015‚Üí) {
  1016‚Üí  const valueRef = React.useRef<string>()
  1017‚Üí  const context = useCommand()
  1018‚Üí
  1019‚Üí  useLayoutEffect(() => {
  1020‚Üí    const value = (() => {
  1021‚Üí      for (const part of deps) {
  1022‚Üí        if (typeof part === 'string') {
  1023‚Üí          return part.trim()
  1024‚Üí        }
  1025‚Üí
  1026‚Üí        if (typeof part === 'object' && 'current' in part) {
  1027‚Üí          if (part.current) {
  1028‚Üí            return part.current.textContent?.trim()
  1029‚Üí          }
  1030‚Üí          return valueRef.current
  1031‚Üí        }
  1032‚Üí      }
  1033‚Üí    })()
  1034‚Üí
  1035‚Üí    const keywords = aliases.map((alias) => alias.trim())
  1036‚Üí
  1037‚Üí    context.value(id, value, keywords)
  1038‚Üí    ref.current?.setAttribute(VALUE_ATTR, value)
  1039‚Üí    valueRef.current = value
  1040‚Üí  })
  1041‚Üí
  1042‚Üí  return valueRef
  1043‚Üí}
  1045‚Üí/** Imperatively run a function on the next layout effect cycle. */
  1046‚Üíconst useScheduleLayoutEffect = () => {
  1047‚Üí  const [s, ss] = React.useState<object>()
  1048‚Üí  const fns = useLazyRef(() => new Map<string | number, () => void>())
  1049‚Üí
  1050‚Üí  useLayoutEffect(() => {
  1051‚Üí    fns.current.forEach((f) => f())
  1052‚Üí    fns.current = new Map()
  1053‚Üí  }, [s])
  1054‚Üí
  1055‚Üí  return (id: string | number, cb: () => void) => {
  1056‚Üí    fns.current.set(id, cb)
  1057‚Üí    ss({})
  1058‚Üí  }
  1059‚Üí}
  1061‚Üífunction renderChildren(children: React.ReactElement) {
  1062‚Üí  const childrenType = children.type as any
  1063‚Üí  // The children is a component
  1064‚Üí  if (typeof childrenType === 'function') return childrenType(children.props)
  1065‚Üí  // The children is a component with `forwardRef`
  1066‚Üí  else if ('render' in childrenType) return childrenType.render(children.props)
  1067‚Üí  // It's a string, boolean, etc.
  1068‚Üí  else return children
  1069‚Üí}
  1071‚Üífunction SlottableWithNestedChildren(
  1072‚Üí  { asChild, children }: { asChild?: boolean; children?: React.ReactNode },
  1073‚Üí  render: (child: React.ReactNode) => JSX.Element,
  1074‚Üí) {
  1075‚Üí  if (asChild && React.isValidElement(children)) {

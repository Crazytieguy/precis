cmdk/src/index.tsx
    10→type Children = { children?: React.ReactNode }
    11→type DivProps = React.ComponentPropsWithoutRef<typeof Primitive.div>
    13→type LoadingProps = Children &
    14→  DivProps & {
    15→    /** Estimated progress of loading asynchronous options. */
    16→    progress?: number
    17→    /**
    18→     * Accessible label for this loading progressbar. Not shown visibly.
    19→     */
    20→    label?: string
    21→  }
    23→type EmptyProps = Children & DivProps & {}
    24→type SeparatorProps = DivProps & {
    25→  /** Whether this separator should always be rendered. Useful if you disable automatic filtering. */
    26→  alwaysRender?: boolean
    27→}
    28→type DialogProps = RadixDialog.DialogProps &
    29→  CommandProps & {
    30→    /** Provide a className to the Dialog overlay. */
    31→    overlayClassName?: string
    32→    /** Provide a className to the Dialog content. */
    33→    contentClassName?: string
    34→    /** Provide a custom element the Dialog should portal into. */
    35→    container?: HTMLElement
    36→  }
    37→type ListProps = Children &
    38→  DivProps & {
    39→    /**
    40→     * Accessible label for this List of suggestions. Not shown visibly.
    41→     */
    42→    label?: string
    43→  }
    44→type ItemProps = Children &

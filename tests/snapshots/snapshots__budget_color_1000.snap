   211→func (c *Color) unset() {
   403→// sequence returns a formatted SGR sequence to be plugged into a "\x1b[...m"
   404→// an example output might be: "1;36" -> bold cyan
   405→func (c *Color) sequence() string {
   406→	format := make([]string, len(c.params))
   407→	for i, v := range c.params {
   408→		format[i] = strconv.Itoa(int(v))
   409→	}
   410→
   411→	return strings.Join(format, ";")
   412→}
   414→// wrap wraps the s string with the colors attributes. The string is ready to
   415→// be printed.
   416→func (c *Color) wrap(s string) string {
   417→	if c.isNoColorSet() {
   418→		return s
   419→	}
   420→
   421→	return c.format() + s + c.unformat()
   422→}

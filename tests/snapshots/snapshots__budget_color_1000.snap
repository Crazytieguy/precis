    17‚Üí	// false or true based on the stdout's file descriptor referring to a terminal
    18‚Üí	// or not. It's also set to true if the NO_COLOR environment variable is
    19‚Üí	// set (regardless of its value). This is a global option and affects all
    20‚Üí	// colors. For more control over each color block use the methods
    21‚Üí	// DisableColor() individually.
    22‚Üí	NoColor = noColorIsSet() || os.Getenv("TERM") == "dumb" ||
    23‚Üí		(!isatty.IsTerminal(os.Stdout.Fd()) && !isatty.IsCygwinTerminal(os.Stdout.Fd()))
    25‚Üí	// Output defines the standard output of the print functions. By default,
    26‚Üí	// os.Stdout is used.
    27‚Üí	Output = colorable.NewColorableStdout()
    29‚Üí	// Error defines a color supporting writer for os.Stderr.
    30‚Üí	Error = colorable.NewColorableStderr()
    32‚Üí	// colorsCache is used to reduce the count of created Color objects and
    33‚Üí	// allows to reuse already created objects with required Attribute.
    34‚Üí	colorsCache   = make(map[Attribute]*Color)

   211‚Üífunc (c *Color) unset() {
   403‚Üí// sequence returns a formatted SGR sequence to be plugged into a "\x1b[...m"
   404‚Üí// an example output might be: "1;36" -> bold cyan
   405‚Üífunc (c *Color) sequence() string {
   406‚Üí	format := make([]string, len(c.params))
   407‚Üí	for i, v := range c.params {
   408‚Üí		format[i] = strconv.Itoa(int(v))
   409‚Üí	}
   410‚Üí
   411‚Üí	return strings.Join(format, ";")
   412‚Üí}
   414‚Üí// wrap wraps the s string with the colors attributes. The string is ready to
   415‚Üí// be printed.
   416‚Üífunc (c *Color) wrap(s string) string {
   417‚Üí	if c.isNoColorSet() {
   418‚Üí		return s
   419‚Üí	}
   420‚Üí
   421‚Üí	return c.format() + s + c.unformat()
   422‚Üí}

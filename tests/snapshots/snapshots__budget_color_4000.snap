   219‚Üí// SetWriter is used to set the SGR sequence with the given io.Writer. This is
   220‚Üí// a low-level function, and users should use the higher-level functions, such
   221‚Üí// as color.Fprint, color.Print, etc.
   222‚Üífunc (c *Color) SetWriter(w io.Writer) *Color {
   223‚Üí	if c.isNoColorSet() {
   224‚Üí		return c
   225‚Üí	}
   226‚Üí
   227‚Üí	fmt.Fprint(w, c.format())
   228‚Üí	return c
   229‚Üí}
   231‚Üí// UnsetWriter resets all escape attributes and clears the output with the give
   232‚Üí// io.Writer. Usually should be called after SetWriter().
   233‚Üífunc (c *Color) UnsetWriter(w io.Writer) {
   234‚Üí	if c.isNoColorSet() {
   235‚Üí		return
   236‚Üí	}
   237‚Üí
   238‚Üí	fmt.Fprintf(w, "%s[%dm", escape, Reset)
   239‚Üí}
   241‚Üí// Add is used to chain SGR parameters. Use as many as parameters to combine
   242‚Üí// and create custom color objects. Example: Add(color.FgRed, color.Underline).
   243‚Üífunc (c *Color) Add(value ...Attribute) *Color {
   244‚Üí	c.params = append(c.params, value...)
   245‚Üí	return c
   246‚Üí}
   248‚Üí// Fprint formats using the default formats for its operands and writes to w.
   249‚Üí// Spaces are added between operands when neither is a string.
   250‚Üí// It returns the number of bytes written and any write error encountered.
   251‚Üí// On Windows, users should wrap w with colorable.NewColorable() if w is of
   252‚Üí// type *os.File.
   253‚Üífunc (c *Color) Fprint(w io.Writer, a ...interface{}) (n int, err error) {
   254‚Üí	c.SetWriter(w)
   255‚Üí	defer c.UnsetWriter(w)
   256‚Üí
   257‚Üí	return fmt.Fprint(w, a...)
   258‚Üí}
   260‚Üí// Print formats using the default formats for its operands and writes to
   261‚Üí// standard output. Spaces are added between operands when neither is a
   262‚Üí// string. It returns the number of bytes written and any write error
   263‚Üí// encountered. This is the standard fmt.Print() method wrapped with the given
   264‚Üí// color.
   265‚Üífunc (c *Color) Print(a ...interface{}) (n int, err error) {
   266‚Üí	c.Set()
   267‚Üí	defer c.unset()
   268‚Üí
   269‚Üí	return fmt.Fprint(Output, a...)
   270‚Üí}
   272‚Üí// Fprintf formats according to a format specifier and writes to w.
   273‚Üí// It returns the number of bytes written and any write error encountered.
   274‚Üí// On Windows, users should wrap w with colorable.NewColorable() if w is of
   275‚Üí// type *os.File.
   276‚Üífunc (c *Color) Fprintf(w io.Writer, format string, a ...interface{}) (n int, err error) {
   277‚Üí	c.SetWriter(w)
   278‚Üí	defer c.UnsetWriter(w)
   279‚Üí
   280‚Üí	return fmt.Fprintf(w, format, a...)
   281‚Üí}
   283‚Üí// Printf formats according to a format specifier and writes to standard output.
   284‚Üí// It returns the number of bytes written and any write error encountered.
   285‚Üí// This is the standard fmt.Printf() method wrapped with the given color.
   286‚Üífunc (c *Color) Printf(format string, a ...interface{}) (n int, err error) {
   287‚Üí	c.Set()
   288‚Üí	defer c.unset()
   289‚Üí
   290‚Üí	return fmt.Fprintf(Output, format, a...)
   291‚Üí}
   293‚Üí// Fprintln formats using the default formats for its operands and writes to w.
   294‚Üí// Spaces are always added between operands and a newline is appended.
   295‚Üí// On Windows, users should wrap w with colorable.NewColorable() if w is of
   296‚Üí// type *os.File.
   297‚Üífunc (c *Color) Fprintln(w io.Writer, a ...interface{}) (n int, err error) {
   298‚Üí	return fmt.Fprintln(w, c.wrap(sprintln(a...)))
   299‚Üí}
   301‚Üí// Println formats using the default formats for its operands and writes to
   302‚Üí// standard output. Spaces are always added between operands and a newline is
   303‚Üí// appended. It returns the number of bytes written and any write error
   304‚Üí// encountered. This is the standard fmt.Print() method wrapped with the given
   305‚Üí// color.
   306‚Üífunc (c *Color) Println(a ...interface{}) (n int, err error) {
   307‚Üí	return fmt.Fprintln(Output, c.wrap(sprintln(a...)))
   308‚Üí}
   310‚Üí// Sprint is just like Print, but returns a string instead of printing it.
   311‚Üífunc (c *Color) Sprint(a ...interface{}) string {
   312‚Üí	return c.wrap(fmt.Sprint(a...))
   313‚Üí}
   315‚Üí// Sprintln is just like Println, but returns a string instead of printing it.
   316‚Üífunc (c *Color) Sprintln(a ...interface{}) string {
   317‚Üí	return c.wrap(sprintln(a...)) + "\n"
   318‚Üí}
   320‚Üí// Sprintf is just like Printf, but returns a string instead of printing it.
   321‚Üífunc (c *Color) Sprintf(format string, a ...interface{}) string {
   322‚Üí	return c.wrap(fmt.Sprintf(format, a...))
   323‚Üí}
   325‚Üí// FprintFunc returns a new function that prints the passed arguments as
   326‚Üí// colorized with color.Fprint().
   327‚Üífunc (c *Color) FprintFunc() func(w io.Writer, a ...interface{}) {
   328‚Üí	return func(w io.Writer, a ...interface{}) {
   329‚Üí		c.Fprint(w, a...)
   330‚Üí	}
   331‚Üí}
   333‚Üí// PrintFunc returns a new function that prints the passed arguments as

   403→// sequence returns a formatted SGR sequence to be plugged into a "\x1b[...m"
   404→// an example output might be: "1;36" -> bold cyan
   405→func (c *Color) sequence() string {
   406→	format := make([]string, len(c.params))
   407→	for i, v := range c.params {
   408→		format[i] = strconv.Itoa(int(v))
   409→	}
   410→
   411→	return strings.Join(format, ";")
   412→}
   414→// wrap wraps the s string with the colors attributes. The string is ready to
   415→// be printed.
   416→func (c *Color) wrap(s string) string {
   417→	if c.isNoColorSet() {
   418→		return s
   419→	}
   420→
   421→	return c.format() + s + c.unformat()
   422→}
   424→func (c *Color) format() string {
   428→func (c *Color) unformat() string {
   443→// DisableColor disables the color output. Useful to not change any existing
   444→// code and still being able to output. Can be used for flags like
   445→// "--no-color". To enable back use EnableColor() method.
   446→func (c *Color) DisableColor() {
   447→	c.noColor = boolPtr(true)
   448→}
   450→// EnableColor enables the color output. Use it in conjunction with
   451→// DisableColor(). Otherwise, this method has no side effects.
   452→func (c *Color) EnableColor() {
   453→	c.noColor = boolPtr(false)
   454→}
   456→func (c *Color) isNoColorSet() bool {
   466→// Equals returns a boolean value indicating whether two colors are equal.
   467→func (c *Color) Equals(c2 *Color) bool {
   468→	if c == nil && c2 == nil {
   469→		return true
   470→	}
   471→	if c == nil || c2 == nil {
   472→		return false
   473→	}
   474→	if len(c.params) != len(c2.params) {
   475→		return false
   476→	}
   477→
   478→	for _, attr := range c.params {
   479→		if !c2.attrExists(attr) {
   480→			return false
   481→		}
   482→	}
   483→
   484→	return true
   485→}
   487→func (c *Color) attrExists(a Attribute) bool {
   497→func boolPtr(v bool) *bool {
   501→func getCachedColor(p Attribute) *Color {
   514→func colorPrint(format string, p Attribute, a ...interface{}) {
   528→func colorString(format string, p Attribute, a ...interface{}) string {
   538→// Black is a convenient helper function to print with black foreground. A
   539→// newline is appended to format by default.
   540→func Black(format string, a ...interface{}) { colorPrint(format, FgBlack, a...) }
   542→// Red is a convenient helper function to print with red foreground. A
   543→// newline is appended to format by default.
   544→func Red(format string, a ...interface{}) { colorPrint(format, FgRed, a...) }
   546→// Green is a convenient helper function to print with green foreground. A

    15→var (
    16→	// NoColor defines if the output is colorized or not. It's dynamically set to
    17→	// false or true based on the stdout's file descriptor referring to a terminal
    18→	// or not. It's also set to true if the NO_COLOR environment variable is
    19→	// set (regardless of its value). This is a global option and affects all
    20→	// colors. For more control over each color block use the methods
    21→	// DisableColor() individually.
    22→	NoColor = noColorIsSet() || os.Getenv("TERM") == "dumb" ||
    23→		(!isatty.IsTerminal(os.Stdout.Fd()) && !isatty.IsCygwinTerminal(os.Stdout.Fd()))
    25→	// Output defines the standard output of the print functions. By default,
    26→	// os.Stdout is used.
    27→	Output = colorable.NewColorableStdout()
    29→	// Error defines a color supporting writer for os.Stderr.
    30→	Error = colorable.NewColorableStderr()
    32→	// colorsCache is used to reduce the count of created Color objects and
    33→	// allows to reuse already created objects with required Attribute.
    34→	colorsCache   = make(map[Attribute]*Color)
    35→	colorsCacheMu sync.Mutex // protects colorsCache
    38→// noColorIsSet returns true if the environment variable NO_COLOR is set to a non-empty string.
    39→func noColorIsSet() bool {
    40→	return os.Getenv("NO_COLOR") != ""
    41→}
    43→// Color defines a custom color object which is defined by SGR parameters.
    44→type Color struct {
    45→	params  []Attribute
    46→	noColor *bool
    47→}
    49→// Attribute defines a single SGR Code
    50→type Attribute int
    52→const escape = "\x1b"
    54→// Base attributes
    55→const (
    56→	Reset Attribute = iota
    57→	Bold
    58→	Faint
    59→	Italic
    60→	Underline
    61→	BlinkSlow
    62→	BlinkRapid
    63→	ReverseVideo
    64→	Concealed
    65→	CrossedOut
    68→const (
    69→	ResetBold Attribute = iota + 22
    70→	ResetItalic
    71→	ResetUnderline
    72→	ResetBlinking
    74→	ResetReversed
    75→	ResetConcealed
    76→	ResetCrossedOut
    79→var mapResetAttributes map[Attribute]Attribute = map[Attribute]Attribute{
    80→	Bold:         ResetBold,
    81→	Faint:        ResetBold,
    82→	Italic:       ResetItalic,
    83→	Underline:    ResetUnderline,
      →…
    91→// Foreground text colors
    92→const (
    93→	FgBlack Attribute = iota + 30
    94→	FgRed
    95→	FgGreen
    96→	FgYellow
    97→	FgBlue
    98→	FgMagenta
    99→	FgCyan
   100→	FgWhite
   102→	// used internally for 256 and 24-bit coloring
   103→	foreground
   106→// Foreground Hi-Intensity text colors
   107→const (
   108→	FgHiBlack Attribute = iota + 90
   109→	FgHiRed
   110→	FgHiGreen
   111→	FgHiYellow
   112→	FgHiBlue
   113→	FgHiMagenta
   114→	FgHiCyan
   115→	FgHiWhite
   118→// Background text colors
   119→const (
   120→	BgBlack Attribute = iota + 40
   121→	BgRed
   122→	BgGreen
   123→	BgYellow
   124→	BgBlue
   125→	BgMagenta
   126→	BgCyan
   127→	BgWhite
   129→	// used internally for 256 and 24-bit coloring
   130→	background
   133→// Background Hi-Intensity text colors
   134→const (
   135→	BgHiBlack Attribute = iota + 100
   136→	BgHiRed
   137→	BgHiGreen
   138→	BgHiYellow
   139→	BgHiBlue
   140→	BgHiMagenta
   141→	BgHiCyan
   142→	BgHiWhite
   145→// New returns a newly created color object.
   146→func New(value ...Attribute) *Color {
   147→	c := &Color{
   148→		params: make([]Attribute, 0),
   149→	}
   150→
   151→	if noColorIsSet() {
   152→		c.noColor = boolPtr(true)
   153→	}
   154→
   155→	c.Add(value...)
   156→	return c
   157→}
   159→// RGB returns a new foreground color in 24-bit RGB.
   160→func RGB(r, g, b int) *Color {
   161→	return New(foreground, 2, Attribute(r), Attribute(g), Attribute(b))
   162→}
   164→// BgRGB returns a new background color in 24-bit RGB.
   165→func BgRGB(r, g, b int) *Color {
   166→	return New(background, 2, Attribute(r), Attribute(g), Attribute(b))
   167→}
   169→// AddRGB is used to chain foreground RGB SGR parameters. Use as many as parameters to combine
   170→// and create custom color objects. Example: .Add(34, 0, 12).Add(255, 128, 0).
   171→func (c *Color) AddRGB(r, g, b int) *Color {
   172→	c.params = append(c.params, foreground, 2, Attribute(r), Attribute(g), Attribute(b))
   173→	return c
   174→}
   176→// AddRGB is used to chain background RGB SGR parameters. Use as many as parameters to combine
   177→// and create custom color objects. Example: .Add(34, 0, 12).Add(255, 128, 0).
   178→func (c *Color) AddBgRGB(r, g, b int) *Color {
   179→	c.params = append(c.params, background, 2, Attribute(r), Attribute(g), Attribute(b))
   180→	return c
   181→}
   183→// Set sets the given parameters immediately. It will change the color of
   184→// output with the given SGR parameters until color.Unset() is called.
   185→func Set(p ...Attribute) *Color {
   186→	c := New(p...)
   187→	c.Set()
   188→	return c
   189→}
   191→// Unset resets all escape attributes and clears the output. Usually should
   192→// be called after Set().
   193→func Unset() {
   194→	if NoColor {
   195→		return
   196→	}
   197→
   198→	fmt.Fprintf(Output, "%s[%dm", escape, Reset)
   199→}
   201→// Set sets the SGR sequence.
   202→func (c *Color) Set() *Color {
   203→	if c.isNoColorSet() {
   204→		return c
   205→	}
   206→
   207→	fmt.Fprint(Output, c.format())
   208→	return c
   209→}
   211→func (c *Color) unset() {
   219→// SetWriter is used to set the SGR sequence with the given io.Writer. This is
   220→// a low-level function, and users should use the higher-level functions, such
   221→// as color.Fprint, color.Print, etc.
   222→func (c *Color) SetWriter(w io.Writer) *Color {
   223→	if c.isNoColorSet() {
   224→		return c
   225→	}
   226→
   227→	fmt.Fprint(w, c.format())
   228→	return c
   229→}
   231→// UnsetWriter resets all escape attributes and clears the output with the give
   232→// io.Writer. Usually should be called after SetWriter().
   233→func (c *Color) UnsetWriter(w io.Writer) {
   234→	if c.isNoColorSet() {
   235→		return
   236→	}
   237→
   238→	fmt.Fprintf(w, "%s[%dm", escape, Reset)
   239→}
   241→// Add is used to chain SGR parameters. Use as many as parameters to combine
   242→// and create custom color objects. Example: Add(color.FgRed, color.Underline).
   243→func (c *Color) Add(value ...Attribute) *Color {
   244→	c.params = append(c.params, value...)
   245→	return c
   246→}
   248→// Fprint formats using the default formats for its operands and writes to w.
   249→// Spaces are added between operands when neither is a string.
   250→// It returns the number of bytes written and any write error encountered.
   251→// On Windows, users should wrap w with colorable.NewColorable() if w is of
   252→// type *os.File.
   253→func (c *Color) Fprint(w io.Writer, a ...interface{}) (n int, err error) {
   254→	c.SetWriter(w)
   255→	defer c.UnsetWriter(w)
   256→
   257→	return fmt.Fprint(w, a...)
   258→}
   260→// Print formats using the default formats for its operands and writes to
   261→// standard output. Spaces are added between operands when neither is a
   262→// string. It returns the number of bytes written and any write error
   263→// encountered. This is the standard fmt.Print() method wrapped with the given
   264→// color.
   265→func (c *Color) Print(a ...interface{}) (n int, err error) {
   266→	c.Set()
   267→	defer c.unset()
   268→
   269→	return fmt.Fprint(Output, a...)
   270→}
   272→// Fprintf formats according to a format specifier and writes to w.
   273→// It returns the number of bytes written and any write error encountered.
   274→// On Windows, users should wrap w with colorable.NewColorable() if w is of
   275→// type *os.File.
   276→func (c *Color) Fprintf(w io.Writer, format string, a ...interface{}) (n int, err error) {
   277→	c.SetWriter(w)
   278→	defer c.UnsetWriter(w)
   279→
   280→	return fmt.Fprintf(w, format, a...)
   281→}
   283→// Printf formats according to a format specifier and writes to standard output.
   284→// It returns the number of bytes written and any write error encountered.
   285→// This is the standard fmt.Printf() method wrapped with the given color.
   286→func (c *Color) Printf(format string, a ...interface{}) (n int, err error) {
   287→	c.Set()
   288→	defer c.unset()
   289→
   290→	return fmt.Fprintf(Output, format, a...)
   291→}
   293→// Fprintln formats using the default formats for its operands and writes to w.
   294→// Spaces are always added between operands and a newline is appended.
   295→// On Windows, users should wrap w with colorable.NewColorable() if w is of
   296→// type *os.File.
   297→func (c *Color) Fprintln(w io.Writer, a ...interface{}) (n int, err error) {
   298→	return fmt.Fprintln(w, c.wrap(sprintln(a...)))
   299→}
   301→// Println formats using the default formats for its operands and writes to
   302→// standard output. Spaces are always added between operands and a newline is
   303→// appended. It returns the number of bytes written and any write error
   304→// encountered. This is the standard fmt.Print() method wrapped with the given
   305→// color.
   306→func (c *Color) Println(a ...interface{}) (n int, err error) {
   307→	return fmt.Fprintln(Output, c.wrap(sprintln(a...)))
   308→}
   310→// Sprint is just like Print, but returns a string instead of printing it.
   311→func (c *Color) Sprint(a ...interface{}) string {
   312→	return c.wrap(fmt.Sprint(a...))
   313→}
   315→// Sprintln is just like Println, but returns a string instead of printing it.
   316→func (c *Color) Sprintln(a ...interface{}) string {
   317→	return c.wrap(sprintln(a...)) + "\n"
   318→}
   320→// Sprintf is just like Printf, but returns a string instead of printing it.
   321→func (c *Color) Sprintf(format string, a ...interface{}) string {
   322→	return c.wrap(fmt.Sprintf(format, a...))
   323→}

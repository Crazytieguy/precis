    15вҶ’var (
    16вҶ’	// NoColor defines if the output is colorized or not. It's dynamically set to
    17вҶ’	// false or true based on the stdout's file descriptor referring to a terminal
    18вҶ’	// or not. It's also set to true if the NO_COLOR environment variable is
    19вҶ’	// set (regardless of its value). This is a global option and affects all
    20вҶ’	// colors. For more control over each color block use the methods
    21вҶ’	// DisableColor() individually.
    22вҶ’	NoColor = noColorIsSet() || os.Getenv("TERM") == "dumb" ||
    23вҶ’		(!isatty.IsTerminal(os.Stdout.Fd()) && !isatty.IsCygwinTerminal(os.Stdout.Fd()))
    25вҶ’	// Output defines the standard output of the print functions. By default,
    26вҶ’	// os.Stdout is used.
    27вҶ’	Output = colorable.NewColorableStdout()
    29вҶ’	// Error defines a color supporting writer for os.Stderr.
    30вҶ’	Error = colorable.NewColorableStderr()

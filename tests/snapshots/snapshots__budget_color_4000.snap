   145‚Üí// New returns a newly created color object.
   146‚Üífunc New(value ...Attribute) *Color {
   147‚Üí	c := &Color{
   148‚Üí		params: make([]Attribute, 0),
   149‚Üí	}
   150‚Üí
   151‚Üí	if noColorIsSet() {
   152‚Üí		c.noColor = boolPtr(true)
   153‚Üí	}
   154‚Üí
   155‚Üí	c.Add(value...)
   156‚Üí	return c
   157‚Üí}
   159‚Üí// RGB returns a new foreground color in 24-bit RGB.
   160‚Üífunc RGB(r, g, b int) *Color {
   161‚Üí	return New(foreground, 2, Attribute(r), Attribute(g), Attribute(b))
   162‚Üí}
   164‚Üí// BgRGB returns a new background color in 24-bit RGB.
   165‚Üífunc BgRGB(r, g, b int) *Color {
   166‚Üí	return New(background, 2, Attribute(r), Attribute(g), Attribute(b))
   167‚Üí}
   169‚Üí// AddRGB is used to chain foreground RGB SGR parameters. Use as many as parameters to combine
   170‚Üí// and create custom color objects. Example: .Add(34, 0, 12).Add(255, 128, 0).
   171‚Üífunc (c *Color) AddRGB(r, g, b int) *Color {
   172‚Üí	c.params = append(c.params, foreground, 2, Attribute(r), Attribute(g), Attribute(b))
   173‚Üí	return c
   174‚Üí}
   176‚Üí// AddRGB is used to chain background RGB SGR parameters. Use as many as parameters to combine
   177‚Üí// and create custom color objects. Example: .Add(34, 0, 12).Add(255, 128, 0).
   178‚Üífunc (c *Color) AddBgRGB(r, g, b int) *Color {
   179‚Üí	c.params = append(c.params, background, 2, Attribute(r), Attribute(g), Attribute(b))
   180‚Üí	return c
   181‚Üí}
   183‚Üí// Set sets the given parameters immediately. It will change the color of
   184‚Üí// output with the given SGR parameters until color.Unset() is called.
   185‚Üífunc Set(p ...Attribute) *Color {
   186‚Üí	c := New(p...)
   187‚Üí	c.Set()
   188‚Üí	return c
   189‚Üí}
   191‚Üí// Unset resets all escape attributes and clears the output. Usually should
   192‚Üí// be called after Set().
   193‚Üífunc Unset() {
   194‚Üí	if NoColor {
   195‚Üí		return
   196‚Üí	}
   197‚Üí
   198‚Üí	fmt.Fprintf(Output, "%s[%dm", escape, Reset)
   199‚Üí}
   201‚Üí// Set sets the SGR sequence.
   202‚Üífunc (c *Color) Set() *Color {
   203‚Üí	if c.isNoColorSet() {
   204‚Üí		return c
   205‚Üí	}
   206‚Üí
   207‚Üí	fmt.Fprint(Output, c.format())
   208‚Üí	return c
   209‚Üí}

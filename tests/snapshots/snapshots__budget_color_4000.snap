   538→// Black is a convenient helper function to print with black foreground. A
   539→// newline is appended to format by default.
   540→func Black(format string, a ...interface{}) { colorPrint(format, FgBlack, a...) }
   542→// Red is a convenient helper function to print with red foreground. A
   543→// newline is appended to format by default.
   544→func Red(format string, a ...interface{}) { colorPrint(format, FgRed, a...) }
   546→// Green is a convenient helper function to print with green foreground. A
   547→// newline is appended to format by default.
   548→func Green(format string, a ...interface{}) { colorPrint(format, FgGreen, a...) }
   550→// Yellow is a convenient helper function to print with yellow foreground.
   551→// A newline is appended to format by default.
   552→func Yellow(format string, a ...interface{}) { colorPrint(format, FgYellow, a...) }
   554→// Blue is a convenient helper function to print with blue foreground. A
   555→// newline is appended to format by default.
   556→func Blue(format string, a ...interface{}) { colorPrint(format, FgBlue, a...) }
   558→// Magenta is a convenient helper function to print with magenta foreground.

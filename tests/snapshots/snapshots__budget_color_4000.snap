   403â†’// sequence returns a formatted SGR sequence to be plugged into a "\x1b[...m"
   404â†’// an example output might be: "1;36" -> bold cyan
   405â†’func (c *Color) sequence() string {
   406â†’	format := make([]string, len(c.params))
   407â†’	for i, v := range c.params {
   408â†’		format[i] = strconv.Itoa(int(v))
   409â†’	}
   410â†’
   411â†’	return strings.Join(format, ";")
   412â†’}
   414â†’// wrap wraps the s string with the colors attributes. The string is ready to

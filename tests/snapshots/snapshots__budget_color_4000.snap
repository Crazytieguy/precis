   373→// SprintFunc returns a new function that returns colorized strings for the
   374→// given arguments with fmt.Sprint(). Useful to put into or mix into other
   375→// string. Windows users should use this in conjunction with color.Output, example:
   376→//
   377→//	put := New(FgYellow).SprintFunc()
   378→//	fmt.Fprintf(color.Output, "This is a %s", put("warning"))
   379→func (c *Color) SprintFunc() func(a ...interface{}) string {
   380→	return func(a ...interface{}) string {
   381→		return c.wrap(fmt.Sprint(a...))
   382→	}
   383→}
   385→// SprintfFunc returns a new function that returns colorized strings for the
   386→// given arguments with fmt.Sprintf(). Useful to put into or mix into other
   387→// string. Windows users should use this in conjunction with color.Output.
   388→func (c *Color) SprintfFunc() func(format string, a ...interface{}) string {
   389→	return func(format string, a ...interface{}) string {
   390→		return c.wrap(fmt.Sprintf(format, a...))
   391→	}
   392→}
   394→// SprintlnFunc returns a new function that returns colorized strings for the
   395→// given arguments with fmt.Sprintln(). Useful to put into or mix into other
   396→// string. Windows users should use this in conjunction with color.Output.
   397→func (c *Color) SprintlnFunc() func(a ...interface{}) string {
   398→	return func(a ...interface{}) string {
   399→		return c.wrap(sprintln(a...)) + "\n"
   400→	}

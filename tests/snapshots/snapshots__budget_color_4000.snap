   466‚Üí// Equals returns a boolean value indicating whether two colors are equal.
   467‚Üífunc (c *Color) Equals(c2 *Color) bool {
   468‚Üí	if c == nil && c2 == nil {
   469‚Üí		return true
   470‚Üí	}
   471‚Üí	if c == nil || c2 == nil {
   472‚Üí		return false
   473‚Üí	}
   474‚Üí	if len(c.params) != len(c2.params) {
   475‚Üí		return false
   476‚Üí	}
   477‚Üí
   478‚Üí	for _, attr := range c.params {
   479‚Üí		if !c2.attrExists(attr) {
   480‚Üí			return false
   481‚Üí		}
   482‚Üí	}
   483‚Üí
   484‚Üí	return true
   485‚Üí}

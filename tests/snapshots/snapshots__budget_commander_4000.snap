   261вҶ’/**
   262вҶ’ * This class is to make it easier to work with dual options, without changing the existing
   263вҶ’ * implementation. We support separate dual options for separate positive and negative options,
   264вҶ’ * like `--build` and `--no-build`, which share a single option value. This works nicely for some
   265вҶ’ * use cases, but is tricky for others where we want separate behaviours despite
   266вҶ’ * the single shared option value.
   267вҶ’ */
   268вҶ’class DualOptions {
   269вҶ’  /**
   270вҶ’   * @param {Option[]} options
   271вҶ’   */
   272вҶ’  constructor(options) {
   273вҶ’    this.positiveOptions = new Map();
   274вҶ’    this.negativeOptions = new Map();
   275вҶ’    this.dualOptions = new Set();
   276вҶ’    options.forEach((option) => {
   277вҶ’      if (option.negate) {
   278вҶ’        this.negativeOptions.set(option.attributeName(), option);
   279вҶ’      } else {
   280вҶ’        this.positiveOptions.set(option.attributeName(), option);
   281вҶ’      }
   282вҶ’    });
   283вҶ’    this.negativeOptions.forEach((value, key) => {
   284вҶ’      if (this.positiveOptions.has(key)) {
   285вҶ’        this.dualOptions.add(key);
   286вҶ’      }
   287вҶ’    });
   288вҶ’  }
   289вҶ’
   290вҶ’  /**
   291вҶ’   * Did the value come from the option, and not from possible matching dual option?
   292вҶ’   *
   293вҶ’   * @param {*} value
   294вҶ’   * @param {Option} option
   295вҶ’   * @returns {boolean}
   296вҶ’   */
   297вҶ’  valueFromOption(value, option) {
   298вҶ’    const optionKey = option.attributeName();
   299вҶ’    if (!this.dualOptions.has(optionKey)) return true;
   300вҶ’
   301вҶ’    // Use the value to deduce if (probably) came from the option.
   302вҶ’    const preset = this.negativeOptions.get(optionKey).presetArg;
   303вҶ’    const negativeValue = preset !== undefined ? preset : false;
   304вҶ’    return option.negate === (negativeValue === value);
   305вҶ’  }
   306вҶ’}

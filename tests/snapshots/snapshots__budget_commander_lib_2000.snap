   333→  // long flag, double dash and at least one character
   334→  const longFlagExp = /^--[^-]/;
   335→
   336→  const flagParts = flags.split(/[ |,]+/).concat('guard');
   337→  // Normal is short and/or long.
   338→  if (shortFlagExp.test(flagParts[0])) shortFlag = flagParts.shift();

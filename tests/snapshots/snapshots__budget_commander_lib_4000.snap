   550→    // Usage has lots of parts the user might like to color separately! Assume default usage string which is formed like:
   551→    //    command subcommand [options] [command] <foo> [bar]
   552→    return str
   553→      .split(' ')
   554→      .map((word) => {
   555→        if (word === '[options]') return this.styleOptionText(word);
   556→        if (word === '[command]') return this.styleSubcommandText(word);
   557→        if (word[0] === '[' || word[0] === '<')
   558→          return this.styleArgumentText(word);
   559→        return this.styleCommandText(word); // Restrict to initial words?

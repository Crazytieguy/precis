   276→    options.forEach((option) => {
   277→      if (option.negate) {
   278→        this.negativeOptions.set(option.attributeName(), option);
   279→      } else {
   280→        this.positiveOptions.set(option.attributeName(), option);
   281→      }
   282→    });

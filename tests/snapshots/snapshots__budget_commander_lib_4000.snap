   136→ * Takes an argument and returns its human readable equivalent for help usage.
   137→ *
   138→ * @param {Argument} arg
   139→ * @return {string}
   140→ * @private
   143→function humanReadableArgName(arg) {
   144→  const nameOutput = arg.name() + (arg.variadic === true ? '...' : '');
   145→
   146→  return arg.required ? '<' + nameOutput + '>' : '[' + nameOutput + ']';
   147→}


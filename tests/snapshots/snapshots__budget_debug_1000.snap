   143‚Üí/**
   144‚Üí * Colorize log arguments if enabled.
   145‚Üí *
   146‚Üí * @api public
   147‚Üí */
   148‚Üí
   149‚Üífunction formatArgs(args) {
   150‚Üí	args[0] = (this.useColors ? '%c' : '') +
   151‚Üí		this.namespace +
   152‚Üí		(this.useColors ? ' %c' : ' ') +
   153‚Üí		args[0] +
   154‚Üí		(this.useColors ? '%c ' : ' ') +
   155‚Üí		'+' + module.exports.humanize(this.diff);
   156‚Üí
   157‚Üí	if (!this.useColors) {
   158‚Üí		return;
   159‚Üí	}

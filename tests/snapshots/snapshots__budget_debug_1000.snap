   192‚Üí
   193‚Üífunction log(...args) {
   194‚Üí	return process.stderr.write(util.formatWithOptions(exports.inspectOpts, ...args) + '\n');
   195‚Üí}
   197‚Üí/**
   198‚Üí * Save `namespaces`.
   199‚Üí *
   200‚Üí * @param {String} namespaces

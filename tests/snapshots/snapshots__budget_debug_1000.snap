   203‚Üífunction save(namespaces) {
   204‚Üí	if (namespaces) {
   205‚Üí		process.env.DEBUG = namespaces;
   206‚Üí	} else {
   207‚Üí		// If you set a process.env field to null or undefined, it gets cast to the
   208‚Üí		// string 'null' or 'undefined'. Just delete instead.
   209‚Üí		delete process.env.DEBUG;
   210‚Üí	}
   211‚Üí}
   213‚Üí/**

   224‚Üí/**
   225‚Üí * Init logic for `debug` instances.
   226‚Üí *
   227‚Üí * Create a new `inspectOpts` object in case `useColors` is set
   228‚Üí * differently for a particular `debug` instance.
   229‚Üí */
   230‚Üí
   231‚Üífunction init(debug) {
   232‚Üí	debug.inspectOpts = {};
   233‚Üí
   234‚Üí	const keys = Object.keys(exports.inspectOpts);
   235‚Üí	for (let i = 0; i < keys.length; i++) {
   236‚Üí		debug.inspectOpts[keys[i]] = exports.inspectOpts[keys[i]];
   237‚Üí	}
   238‚Üí}

   236‚Üí/**
   237‚Üí * Localstorage attempts to return the localstorage.
   238‚Üí *
   239‚Üí * This is necessary because safari throws
   240‚Üí * when a user disables cookies/localstorage
   241‚Üí * and you attempt to access it.
   242‚Üí *
   243‚Üí * @return {LocalStorage}
   244‚Üí * @api private
   245‚Üí */
   246‚Üí
   247‚Üífunction localstorage() {
   248‚Üí	try {
   249‚Üí		// TVMLKit (Apple TV JS Runtime) does not have a window object, just localStorage in the global context
   250‚Üí		// The Browser also has localStorage in the global context.
   251‚Üí		return localStorage;
   252‚Üí	} catch (error) {
   253‚Üí		// Swallow
   254‚Üí		// XXX (@Qix-) should we be logging these?
   255‚Üí	}
   256‚Üí}

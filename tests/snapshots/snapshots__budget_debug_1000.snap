   115‚Üífunction useColors() {
   116‚Üí	// NB: In an Electron preload script, document will be defined but not fully
   117‚Üí	// initialized. Since we know we're in Chrome, we'll just detect this case
   118‚Üí	// explicitly
   119‚Üí	if (typeof window !== 'undefined' && window.process && (window.process.type === 'renderer' || window.process.__nwjs)) {
   120‚Üí		return true;
   121‚Üí	}
   122‚Üí
   123‚Üí	// Internet Explorer and Edge do not support colors.
   124‚Üí	if (typeof navigator !== 'undefined' && navigator.userAgent && navigator.userAgent.toLowerCase().match(/(edge|trident)\/(\d+)/)) {
   125‚Üí		return false;
   126‚Üí	}
   127‚Üí
   128‚Üí	let m;
   129‚Üí
   130‚Üí	// Is webkit? http://stackoverflow.com/a/16459606/376773
   131‚Üí	// document is undefined in react-native: https://github.com/facebook/react-native/pull/1632
   132‚Üí	// eslint-disable-next-line no-return-assign

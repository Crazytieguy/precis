   151‚Üí/**
   152‚Üí * Is stdout a TTY? Colored output is enabled when `true`.
   153‚Üí */
   154‚Üí
   155‚Üífunction useColors() {
   156‚Üí	return 'colors' in exports.inspectOpts ?
   157‚Üí		Boolean(exports.inspectOpts.colors) :
   158‚Üí		tty.isatty(process.stderr.fd);

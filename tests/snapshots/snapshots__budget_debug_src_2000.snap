   162‚Üí * Adds ANSI color escape codes if enabled.
   163‚Üí *
   164‚Üí * @api public
   167‚Üífunction formatArgs(args) {
   168‚Üí	const {namespace: name, useColors} = this;
   169‚Üí
   170‚Üí	if (useColors) {
   171‚Üí		const c = this.color;
   172‚Üí		const colorCode = '\u001B[3' + (c < 8 ? c : '8;5;' + c);
   173‚Üí		const prefix = `  ${colorCode};1m${name} \u001B[0m`;
   174‚Üí
   175‚Üí		args[0] = prefix + args[0].split('\n').join('\n' + prefix);
   176‚Üí		args.push(colorCode + 'm+' + module.exports.humanize(this.diff) + '\u001B[0m');
   177‚Üí	} else {
   178‚Üí		args[0] = getDate() + name + ' ' + args[0];
   179‚Üí	}
   180‚Üí}
   182‚Üífunction getDate() {
   183‚Üí	if (exports.inspectOpts.hideDate) {
   184‚Üí		return '';
   185‚Üí	}
   186‚Üí	return new Date().toISOString() + ' ';
   187‚Üí}

   190в†’ * @api public
   191в†’ */
   192в†’exports.log = console.debug || console.log || (() => {});
   193в†’
   194в†’/**
   195в†’ * Save `namespaces`.
   196в†’ *
   197в†’ * @param {String} namespaces
   198в†’ * @api private
   199в†’ */
   200в†’function save(namespaces) {
   201в†’	try {
   202в†’		if (namespaces) {
   203в†’			exports.storage.setItem('debug', namespaces);
   204в†’		} else {
   205в†’			exports.storage.removeItem('debug');
   206в†’		}
   207в†’	} catch (error) {
   208в†’		// Swallow
   209в†’		// XXX (@Qix-) should we be logging these?
   210в†’	}
   211в†’}
   212в†’
   213в†’/**
   214в†’ * Load `namespaces`.
   215в†’ *
   216в†’ * @return {String} returns the previously persisted debug modes
   217в†’ * @api private
   218в†’ */
   219в†’function load() {
   220в†’	let r;
   221в†’	try {
   222в†’		r = exports.storage.getItem('debug') || exports.storage.getItem('DEBUG') ;
   223в†’	} catch (error) {
   224в†’		// Swallow
   225в†’		// XXX (@Qix-) should we be logging these?
   226в†’	}
   227в†’
   228в†’	// If debug isn't set in LS, and we're in Electron, try to load $DEBUG
   229в†’	if (!r && typeof process !== 'undefined' && 'env' in process) {
   230в†’		r = process.env.DEBUG;
   231в†’	}
   232в†’
   233в†’	return r;
   234в†’}

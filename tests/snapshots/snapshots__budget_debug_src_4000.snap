   106в†’/**
   107в†’ * Currently only WebKit-based Web Inspectors, Firefox >= v31,
   108в†’ * and the Firebug extension (any Firefox version) are known
   109в†’ * to support "%c" CSS customizations.
   110в†’ *
   111в†’ * TODO: add a `localStorage` variable to explicitly enable/disable colors
   112в†’ */
   113в†’
   114в†’// eslint-disable-next-line complexity
   115в†’function useColors() {
   116в†’	// NB: In an Electron preload script, document will be defined but not fully
   117в†’	// initialized. Since we know we're in Chrome, we'll just detect this case
   118в†’	// explicitly
   119в†’	if (typeof window !== 'undefined' && window.process && (window.process.type === 'renderer' || window.process.__nwjs)) {
   120в†’		return true;
   121в†’	}
   122в†’
   123в†’	// Internet Explorer and Edge do not support colors.
   124в†’	if (typeof navigator !== 'undefined' && navigator.userAgent && navigator.userAgent.toLowerCase().match(/(edge|trident)\/(\d+)/)) {
   125в†’		return false;
   126в†’	}
   127в†’
   128в†’	let m;
   129в†’
   130в†’	// Is webkit? http://stackoverflow.com/a/16459606/376773
   131в†’	// document is undefined in react-native: https://github.com/facebook/react-native/pull/1632
   132в†’	// eslint-disable-next-line no-return-assign
   133в†’	return (typeof document !== 'undefined' && document.documentElement && document.documentElement.style && document.documentElement.style.WebkitAppearance) ||
   134в†’		// Is firebug? http://stackoverflow.com/a/398120/376773
   135в†’		(typeof window !== 'undefined' && window.console && (window.console.firebug || (window.console.exception && window.console.table))) ||
   136в†’		// Is firefox >= v31?
   137в†’		// https://developer.mozilla.org/en-US/docs/Tools/Web_Console#Styling_messages
   138в†’		(typeof navigator !== 'undefined' && navigator.userAgent && (m = navigator.userAgent.toLowerCase().match(/firefox\/(\d+)/)) && parseInt(m[1], 10) >= 31) ||
   139в†’		// Double check webkit in userAgent just in case we are in a worker
   140в†’		(typeof navigator !== 'undefined' && navigator.userAgent && navigator.userAgent.toLowerCase().match(/applewebkit\/(\d+)/));
   141в†’}

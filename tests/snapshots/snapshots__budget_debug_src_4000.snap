   155в†’function useColors() {
   156в†’	return 'colors' in exports.inspectOpts ?
   157в†’		Boolean(exports.inspectOpts.colors) :
   158в†’		tty.isatty(process.stderr.fd);
   159в†’}
   160в†’
   161в†’/**
   162в†’ * Adds ANSI color escape codes if enabled.
   163в†’ *
   164в†’ * @api public
   165в†’ */
   166в†’
   167в†’function formatArgs(args) {
   168в†’	const {namespace: name, useColors} = this;
   169в†’
   170в†’	if (useColors) {
   171в†’		const c = this.color;
   172в†’		const colorCode = '\u001B[3' + (c < 8 ? c : '8;5;' + c);
   173в†’		const prefix = `  ${colorCode};1m${name} \u001B[0m`;
   174в†’
   175в†’		args[0] = prefix + args[0].split('\n').join('\n' + prefix);
   176в†’		args.push(colorCode + 'm+' + module.exports.humanize(this.diff) + '\u001B[0m');
   177в†’	} else {
   178в†’		args[0] = getDate() + name + ' ' + args[0];
   179в†’	}
   180в†’}
   181в†’
   182в†’function getDate() {
   183в†’	if (exports.inspectOpts.hideDate) {
   184в†’		return '';
   185в†’	}
   186в†’	return new Date().toISOString() + ' ';
   187в†’}
   188в†’
   189в†’/**
   190в†’ * Invokes `util.formatWithOptions()` with the specified arguments and writes to stderr.
   191в†’ */
   192в†’
   193в†’function log(...args) {
   194в†’	return process.stderr.write(util.formatWithOptions(exports.inspectOpts, ...args) + '\n');
   195в†’}
   196в†’
   197в†’/**
   198в†’ * Save `namespaces`.
   199в†’ *
   200в†’ * @param {String} namespaces
   201в†’ * @api private
   202в†’ */
   203в†’function save(namespaces) {
   204в†’	if (namespaces) {
   205в†’		process.env.DEBUG = namespaces;
   206в†’	} else {
   207в†’		// If you set a process.env field to null or undefined, it gets cast to the
   208в†’		// string 'null' or 'undefined'. Just delete instead.
   209в†’		delete process.env.DEBUG;
   210в†’	}
   211в†’}
   212в†’
   213в†’/**
   214в†’ * Load `namespaces`.
   215в†’ *
   216в†’ * @return {String} returns the previously persisted debug modes
   217в†’ * @api private
   218в†’ */
   219в†’
   220в†’function load() {
   221в†’	return process.env.DEBUG;
   222в†’}
   223в†’
   224в†’/**
   225в†’ * Init logic for `debug` instances.
   226в†’ *
   227в†’ * Create a new `inspectOpts` object in case `useColors` is set
   228в†’ * differently for a particular `debug` instance.

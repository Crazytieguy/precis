   143в†’/**
   144в†’ * Colorize log arguments if enabled.
   145в†’ *
   146в†’ * @api public
   147в†’ */
   148в†’
   149в†’function formatArgs(args) {
   150в†’	args[0] = (this.useColors ? '%c' : '') +
   151в†’		this.namespace +
   152в†’		(this.useColors ? ' %c' : ' ') +
   153в†’		args[0] +
   154в†’		(this.useColors ? '%c ' : ' ') +
   155в†’		'+' + module.exports.humanize(this.diff);
   156в†’
   157в†’	if (!this.useColors) {
   158в†’		return;
   159в†’	}
   160в†’
   161в†’	const c = 'color: ' + this.color;
   162в†’	args.splice(1, 0, c, 'color: inherit');
   163в†’
   164в†’	// The final "%c" is somewhat tricky, because there could be other
   165в†’	// arguments passed either before or after the %c, so we need to
   166в†’	// figure out the correct index to insert the CSS into
   167в†’	let index = 0;
   168в†’	let lastC = 0;
   169в†’	args[0].replace(/%[a-zA-Z%]/g, match => {
   170в†’		if (match === '%%') {
   171в†’			return;
   172в†’		}
   173в†’		index++;
   174в†’		if (match === '%c') {
   175в†’			// We only are interested in the *last* %c
   176в†’			// (the user may have provided their own)
   177в†’			lastC = index;
   178в†’		}
   179в†’	});
   180в†’
   181в†’	args.splice(lastC, 0, c);
   182в†’}

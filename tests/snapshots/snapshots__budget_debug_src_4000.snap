   236в†’/**
   237в†’ * Localstorage attempts to return the localstorage.
   238в†’ *
   239в†’ * This is necessary because safari throws
   240в†’ * when a user disables cookies/localstorage
   241в†’ * and you attempt to access it.
   242в†’ *
   243в†’ * @return {LocalStorage}
   244в†’ * @api private
   245в†’ */
   246в†’
   247в†’function localstorage() {
   248в†’	try {
   249в†’		// TVMLKit (Apple TV JS Runtime) does not have a window object, just localStorage in the global context
   250в†’		// The Browser also has localStorage in the global context.
   251в†’		return localStorage;
   252в†’	} catch (error) {
   253в†’		// Swallow
   254в†’		// XXX (@Qix-) should we be logging these?
   255в†’	}
   256в†’}

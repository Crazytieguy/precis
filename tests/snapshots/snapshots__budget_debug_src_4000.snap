   118в†’/**
   119в†’ * Build up the default `inspectOpts` object from the environment variables.
   120в†’ *
   121в†’ *   $ DEBUG_COLORS=no DEBUG_DEPTH=10 DEBUG_SHOW_HIDDEN=enabled node script.js
   122в†’ */
   123в†’
   124в†’exports.inspectOpts = Object.keys(process.env).filter(key => {
   125в†’	return /^debug_/i.test(key);
   126в†’}).reduce((obj, key) => {
   127в†’	// Camel-case
   128в†’	const prop = key
   129в†’		.substring(6)
   130в†’		.toLowerCase()
   131в†’		.replace(/_([a-z])/g, (_, k) => {
   132в†’			return k.toUpperCase();
   133в†’		});
   134в†’
   135в†’	// Coerce string value into JS value
   136в†’	let val = process.env[key];
   137в†’	if (/^(yes|on|true|enabled)$/i.test(val)) {
   138в†’		val = true;
   139в†’	} else if (/^(no|off|false|disabled)$/i.test(val)) {
   140в†’		val = false;
   141в†’	} else if (val === 'null') {
   142в†’		val = null;
   143в†’	} else {
   144в†’		val = Number(val);
   145в†’	}
   146в†’
   147в†’	obj[prop] = val;
   148в†’	return obj;
   149в†’}, {});

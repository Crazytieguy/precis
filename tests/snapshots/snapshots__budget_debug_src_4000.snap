   233в†’
   234в†’	const keys = Object.keys(exports.inspectOpts);
   235в†’	for (let i = 0; i < keys.length; i++) {
   236в†’		debug.inspectOpts[keys[i]] = exports.inspectOpts[keys[i]];
   237в†’	}
   238в†’}
   239в†’
   240в†’module.exports = require('./common')(exports);
   241в†’
   242в†’const {formatters} = module.exports;
   243в†’
   244в†’/**
   245в†’ * Map %o to `util.inspect()`, all on a single line.
   246в†’ */
   247в†’
   248в†’formatters.o = function (v) {
   249в†’	this.inspectOpts.colors = this.useColors;
   250в†’	return util.inspect(v, this.inspectOpts)
   251в†’		.split('\n')
   252в†’		.map(str => str.trim())
   253в†’		.join(' ');
   254в†’};
   255в†’
   256в†’/**
   257в†’ * Map %O to `util.inspect()`, allowing multiple lines if needed.
   258в†’ */
   259в†’
   260в†’formatters.O = function (v) {
   261в†’	this.inspectOpts.colors = this.useColors;
   262в†’	return util.inspect(v, this.inspectOpts);
   263в†’};

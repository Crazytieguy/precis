    25вҶ’export interface DotenvConfigOptions {
    26вҶ’  /**
    27вҶ’   * Default: `path.resolve(process.cwd(), '.env')`
    28вҶ’   *
    29вҶ’   * Specify a custom path if your file containing environment variables is located elsewhere.
    30вҶ’   * Can also be an array of strings, specifying multiple paths.
    31вҶ’   *
    32вҶ’   * example: `require('dotenv').config({ path: '/custom/path/to/.env' })`
    33вҶ’   * example: `require('dotenv').config({ path: ['/path/to/first.env', '/path/to/second.env'] })`
    34вҶ’   */
    35вҶ’  path?: string | string[] | URL;
    36вҶ’
    37вҶ’  /**
    38вҶ’   * Default: `utf8`
    39вҶ’   *
    40вҶ’   * Specify the encoding of your file containing environment variables.
    41вҶ’   *
    42вҶ’   * example: `require('dotenv').config({ encoding: 'latin1' })`
    43вҶ’   */
    44вҶ’  encoding?: string;
    45вҶ’
    46вҶ’  /**
    47вҶ’   * Default: `false`
    48вҶ’   *
    49вҶ’   * Suppress all output (except errors).
    50вҶ’   *
    51вҶ’   * example: `require('dotenv').config({ quiet: true })`
    52вҶ’   */
    53вҶ’  quiet?: boolean;
    54вҶ’
    55вҶ’  /**
    56вҶ’   * Default: `false`
    57вҶ’   *
    58вҶ’   * Turn on logging to help debug why certain keys or values are not being set as you expect.
    59вҶ’   *
    60вҶ’   * example: `require('dotenv').config({ debug: process.env.DEBUG })`
    61вҶ’   */
    62вҶ’  debug?: boolean;
    63вҶ’
    64вҶ’  /**
    65вҶ’   * Default: `false`
    66вҶ’   *
    67вҶ’   * Override any environment variables that have already been set on your machine with values from your .env file.
    68вҶ’   *
    69вҶ’   * example: `require('dotenv').config({ override: true })`
    70вҶ’   */
    71вҶ’  override?: boolean;
    72вҶ’
    73вҶ’  /**
    74вҶ’   * Default: `process.env`
    75вҶ’   *
    76вҶ’   * Specify an object to write your secrets to. Defaults to process.env environment variables.
    77вҶ’   *
    78вҶ’   * example: `const processEnv = {}; require('dotenv').config({ processEnv: processEnv })`
    79вҶ’   */
    80вҶ’  processEnv?: DotenvPopulateInput;
    81вҶ’
    82вҶ’  /**
    83вҶ’   * Default: `undefined`
    84вҶ’   *
    85вҶ’   * Pass the DOTENV_KEY directly to config options. Defaults to looking for process.env.DOTENV_KEY environment variable. Note this only applies to decrypting .env.vault files. If passed as null or undefined, or not passed at all, dotenv falls back to its traditional job of parsing a .env file.
    86вҶ’   *
    87вҶ’   * example: `require('dotenv').config({ DOTENV_KEY: 'dotenv://:key_1234вҖҰ@dotenvx.com/vault/.env.vault?environment=production' })`
    88вҶ’   */
    89вҶ’  DOTENV_KEY?: string;
    90вҶ’}
    92вҶ’export interface DotenvConfigOutput {
    93вҶ’  error?: DotenvError;
    94вҶ’  parsed?: DotenvParseOutput;
    95вҶ’}
    97вҶ’type DotenvError = Error & {
    98вҶ’  code: 
    99вҶ’    | 'MISSING_DATA'
   100вҶ’    | 'INVALID_DOTENV_KEY'
   101вҶ’    | 'NOT_FOUND_DOTENV_ENVIRONMENT'
   102вҶ’    | 'DECRYPTION_FAILED'
   103вҶ’    | 'OBJECT_REQUIRED';
   104вҶ’}
   106вҶ’export interface DotenvPopulateOptions {
   107вҶ’  /**
   108вҶ’   * Default: `false`
   109вҶ’   *
   110вҶ’   * Turn on logging to help debug why certain keys or values are not being set as you expect.
   111вҶ’   *
   112вҶ’   * example: `require('dotenv').config({ debug: process.env.DEBUG })`
   113вҶ’   */
   114вҶ’  debug?: boolean;
   115вҶ’
   116вҶ’  /**
   117вҶ’   * Default: `false`
   118вҶ’   *
   119вҶ’   * Override any environment variables that have already been set on your machine with values from your .env file.
   120вҶ’   *
   121вҶ’   * example: `require('dotenv').config({ override: true })`
   122вҶ’   */
   123вҶ’  override?: boolean;
   124вҶ’}
   126вҶ’export interface DotenvPopulateInput {
   127вҶ’  [name: string]: string | undefined;
   128вҶ’}

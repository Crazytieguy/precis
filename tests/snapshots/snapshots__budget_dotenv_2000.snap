    44тЖТ  encoding?: string;
    45тЖТ
    46тЖТ  /**
    47тЖТ   * Default: `false`
    48тЖТ   *
    49тЖТ   * Suppress all output (except errors).
    50тЖТ   *
    51тЖТ   * example: `require('dotenv').config({ quiet: true })`
    52тЖТ   */
    53тЖТ  quiet?: boolean;
    54тЖТ
    55тЖТ  /**
    56тЖТ   * Default: `false`
    57тЖТ   *
    58тЖТ   * Turn on logging to help debug why certain keys or values are not being set as you expect.
    59тЖТ   *
    60тЖТ   * example: `require('dotenv').config({ debug: process.env.DEBUG })`

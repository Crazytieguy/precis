    43вҶ’   */
    44вҶ’  encoding?: string;
    45вҶ’
    46вҶ’  /**
    47вҶ’   * Default: `false`
    48вҶ’   *
    49вҶ’   * Suppress all output (except errors).
    50вҶ’   *
    51вҶ’   * example: `require('dotenv').config({ quiet: true })`
    52вҶ’   */
    53вҶ’  quiet?: boolean;
    54вҶ’
    55вҶ’  /**
    56вҶ’   * Default: `false`
    57вҶ’   *
    58вҶ’   * Turn on logging to help debug why certain keys or values are not being set as you expect.
    59вҶ’   *
    60вҶ’   * example: `require('dotenv').config({ debug: process.env.DEBUG })`
    61вҶ’   */
    62вҶ’  debug?: boolean;
    63вҶ’
    64вҶ’  /**
    65вҶ’   * Default: `false`
    66вҶ’   *
    67вҶ’   * Override any environment variables that have already been set on your machine with values from your .env file.
    68вҶ’   *
    69вҶ’   * example: `require('dotenv').config({ override: true })`
    70вҶ’   */
    71вҶ’  override?: boolean;
    72вҶ’
    73вҶ’  /**
    74вҶ’   * Default: `process.env`
    75вҶ’   *
    76вҶ’   * Specify an object to write your secrets to. Defaults to process.env environment variables.
    77вҶ’   *
    78вҶ’   * example: `const processEnv = {}; require('dotenv').config({ processEnv: processEnv })`
    79вҶ’   */
    80вҶ’  processEnv?: DotenvPopulateInput;
    81вҶ’
    82вҶ’  /**
    83вҶ’   * Default: `undefined`
    84вҶ’   *
    85вҶ’   * Pass the DOTENV_KEY directly to config options. Defaults to looking for process.env.DOTENV_KEY environment variable. Note this only applies to decrypting .env.vault files. If passed as null or undefined, or not passed at all, dotenv falls back to its traditional job of parsing a .env file.
    86вҶ’   *
    87вҶ’   * example: `require('dotenv').config({ DOTENV_KEY: 'dotenv://:key_1234вҖҰ@dotenvx.com/vault/.env.vault?environment=production' })`
    88вҶ’   */
    89вҶ’  DOTENV_KEY?: string;
    90вҶ’}
    92вҶ’export interface DotenvConfigOutput {

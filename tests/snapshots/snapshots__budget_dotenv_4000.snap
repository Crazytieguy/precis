   108вҶ’   * Default: `false`
   109вҶ’   *
   110вҶ’   * Turn on logging to help debug why certain keys or values are not being set as you expect.
   111вҶ’   *
   112вҶ’   * example: `require('dotenv').config({ debug: process.env.DEBUG })`
   113вҶ’   */
   114вҶ’  debug?: boolean;
   115вҶ’
   116вҶ’  /**
   117вҶ’   * Default: `false`
   118вҶ’   *
   119вҶ’   * Override any environment variables that have already been set on your machine with values from your .env file.
   120вҶ’   *
   121вҶ’   * example: `require('dotenv').config({ override: true })`
   122вҶ’   */
   123вҶ’  override?: boolean;
   124вҶ’}
   126вҶ’export interface DotenvPopulateInput {

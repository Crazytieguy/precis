   135→ * @param options - additional options. example: `{ path: './custom/path', encoding: 'latin1', quiet: false, debug: true, override: false }`
   136→ * @returns an object with a `parsed` key if successful or `error` key if an error occurred. example: { parsed: { KEY: 'value' } }
   137→ *
   138→ */
   139→export function config(options?: DotenvConfigOptions): DotenvConfigOutput;
   140→

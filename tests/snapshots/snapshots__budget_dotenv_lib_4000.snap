   147→ * @returns an object with a `parsed` key if successful or `error` key if an error occurred. example: { parsed: { KEY: 'value' } }
   148→ *
   149→ */
   150→export function configDotenv(options?: DotenvConfigOptions): DotenvConfigOutput;

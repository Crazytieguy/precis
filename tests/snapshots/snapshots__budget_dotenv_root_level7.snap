    87â†’  'âڑ™ï¸ڈ  specify custom .env file path with { path: \'/custom/path/.env\' }',
    88â†’  'âڑ™ï¸ڈ  enable debug logging with { debug: true }',
    89â†’  'âڑ™ï¸ڈ  override existing env vars with { override: true }',

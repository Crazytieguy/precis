     4вҶ’use super::{Either, Left, Right};
     6вҶ’/// Provides methods for converting a type `Self` into either a [`Left`] or [`Right`]
     7вҶ’/// variant of [`Either<Self, Self>`](Either).
     8вҶ’///
     9вҶ’/// The [`into_either`](IntoEither::into_either) method takes a [`bool`] to determine
    10вҶ’/// whether to convert to [`Left`] or [`Right`].
    11вҶ’///
    12вҶ’/// The [`into_either_with`](IntoEither::into_either_with) method takes a
      вҶ’вҖҰ
    14вҶ’pub trait IntoEither: Sized {
    15вҶ’    /// Converts `self` into a [`Left`] variant of [`Either<Self, Self>`](Either)
    16вҶ’    /// if `into_left` is `true`.
    17вҶ’    /// Converts `self` into a [`Right`] variant of [`Either<Self, Self>`](Either)
    18вҶ’    /// otherwise.
    19вҶ’    ///
    20вҶ’    /// # Examples
    21вҶ’    ///
    22вҶ’    /// ```
    23вҶ’    /// use either::{IntoEither, Left, Right};
    24вҶ’    ///
    25вҶ’    /// let x = 0;
    26вҶ’    /// assert_eq!(x.into_either(true), Left(x));
    27вҶ’    /// assert_eq!(x.into_either(false), Right(x));
    28вҶ’    /// ```
    29вҶ’    fn into_either(self, into_left: bool) -> Either<Self, Self> {
    30вҶ’        if into_left {
    31вҶ’            Left(self)
    32вҶ’        } else {
    33вҶ’            Right(self)
    34вҶ’        }
    35вҶ’    }
    36вҶ’
    37вҶ’    /// Converts `self` into a [`Left`] variant of [`Either<Self, Self>`](Either)
    38вҶ’    /// if `into_left(&self)` returns `true`.
    39вҶ’    /// Converts `self` into a [`Right`] variant of [`Either<Self, Self>`](Either)
    40вҶ’    /// otherwise.
    41вҶ’    ///
    42вҶ’    /// # Examples
    43вҶ’    ///
    44вҶ’    /// ```
    45вҶ’    /// use either::{IntoEither, Left, Right};
    46вҶ’    ///
    47вҶ’    /// fn is_even(x: &u8) -> bool {
    48вҶ’    ///     x % 2 == 0
    49вҶ’    /// }
    50вҶ’    ///
    51вҶ’    /// let x = 0;
    52вҶ’    /// assert_eq!(x.into_either_with(is_even), Left(x));
    53вҶ’    /// assert_eq!(x.into_either_with(|x| !is_even(x)), Right(x));
    54вҶ’    /// ```
    55вҶ’    fn into_either_with<F>(self, into_left: F) -> Either<Self, Self>
    56вҶ’    where
    57вҶ’        F: FnOnce(&Self) -> bool,
    58вҶ’    {
    59вҶ’        let into_left = into_left(&self);
    60вҶ’        self.into_either(into_left)
    61вҶ’    }
    62вҶ’}

    41Ôćĺ/// The enum `Either` with variants `Left` and `Right` is a general purpose
    42Ôćĺ/// sum type with two cases.
    43Ôćĺ///
    44Ôćĺ/// The `Either` type is symmetric and treats its variants the same way, without
    45Ôćĺ/// preference.
    46Ôćĺ/// (For representing success or error, use the regular `Result` enum instead.)
    47Ôćĺ#[cfg_attr(feature = "serde", derive(serde::Serialize, serde::Deserialize))]
    48Ôćĺ#[derive(Copy, PartialEq, Eq, PartialOrd, Ord, Hash, Debug)]
    49Ôćĺpub enum Either<L, R> {
    50Ôćĺ    /// A value of type `L`.
    51Ôćĺ    Left(L),
    52Ôćĺ    /// A value of type `R`.
    53Ôćĺ    Right(R),
    54Ôćĺ}
    56Ôćĺ/// Evaluate the provided expression for both [`Either::Left`] and [`Either::Right`].
    57Ôćĺ///
    58Ôćĺ/// This macro is useful in cases where both sides of [`Either`] can be interacted with
    59Ôćĺ/// in the same way even though the don't share the same type.
    60Ôćĺ///
    61Ôćĺ/// Syntax: `either::for_both!(` *expression* `,` *pattern* `=>` *expression* `)`
    62Ôćĺ///
    63Ôćĺ/// # Example
    64Ôćĺ///
    65Ôćĺ/// ```
    66Ôćĺ/// use either::Either;
    67Ôćĺ///
    68Ôćĺ/// fn length(owned_or_borrowed: Either<String, &'static str>) -> usize {
    69Ôćĺ///     either::for_both!(owned_or_borrowed, s => s.len())
    70Ôćĺ/// }
    71Ôćĺ///
    72Ôćĺ/// fn main() {
    73Ôćĺ///     let borrowed = Either::Right("Hello world!");
    74Ôćĺ///     let owned = Either::Left("Hello world!".to_owned());
    75Ôćĺ///
    76Ôćĺ///     assert_eq!(length(borrowed), 12);
    77Ôćĺ///     assert_eq!(length(owned), 12);
    78Ôćĺ/// }
    79Ôćĺ/// ```
    80Ôćĺ#[macro_export]
    81Ôćĺmacro_rules! for_both {
    82Ôćĺ    ($value:expr, $pattern:pat => $result:expr) => {
    83Ôćĺ        match $value {
    84Ôćĺ            $crate::Either::Left($pattern) => $result,
    85Ôćĺ            $crate::Either::Right($pattern) => $result,
    86Ôćĺ        }
    87Ôćĺ    };
    88Ôćĺ}
    90Ôćĺ/// Macro for unwrapping the left side of an [`Either`], which fails early
    91Ôćĺ/// with the opposite side. Can only be used in functions that return
    92Ôćĺ/// `Either` because of the early return of `Right` that it provides.
    93Ôćĺ///
    94Ôćĺ/// See also [`try_right!`] for its dual, which applies the same just to the
    95Ôćĺ/// right side.
    96Ôćĺ///
    97Ôćĺ/// # Example
    98Ôćĺ///
    99Ôćĺ/// ```
   100Ôćĺ/// use either::{Either, Left, Right};
   101Ôćĺ///
   102Ôćĺ/// fn twice(wrapper: Either<u32, &str>) -> Either<u32, &str> {
   103Ôćĺ///     let value = either::try_left!(wrapper);
   104Ôćĺ///     Left(value * 2)
   105Ôćĺ/// }
   106Ôćĺ///
   107Ôćĺ/// fn main() {
   108Ôćĺ///     assert_eq!(twice(Left(2)), Left(4));
   109Ôćĺ///     assert_eq!(twice(Right("ups")), Right("ups"));
   110Ôćĺ/// }
   111Ôćĺ/// ```
   112Ôćĺ#[macro_export]
   113Ôćĺmacro_rules! try_left {
   114Ôćĺ    ($expr:expr) => {
   115Ôćĺ        match $expr {
   116Ôćĺ            $crate::Left(val) => val,
   117Ôćĺ            $crate::Right(err) => return $crate::Right(::core::convert::From::from(err)),
   118Ôćĺ        }
   119Ôćĺ    };
   120Ôćĺ}
   122Ôćĺ/// Dual to [`try_left!`], see its documentation for more information.
   123Ôćĺ#[macro_export]
   124Ôćĺmacro_rules! try_right {
   125Ôćĺ    ($expr:expr) => {
   126Ôćĺ        match $expr {
   127Ôćĺ            $crate::Left(err) => return $crate::Left(::core::convert::From::from(err)),
   128Ôćĺ            $crate::Right(val) => val,
   129Ôćĺ        }
   130Ôćĺ    };
   131Ôćĺ}
   133Ôćĺmacro_rules! map_either {
   134Ôćĺ    ($value:expr, $pattern:pat => $result:expr) => {
   135Ôćĺ        match $value {
   136Ôćĺ            Left($pattern) => Left($result),
   137Ôćĺ            Right($pattern) => Right($result),
   138Ôćĺ        }
   139Ôćĺ    };
   140Ôćĺ}

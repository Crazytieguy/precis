     4â†’use super::{Either, Left, Right};
     6â†’/// Provides methods for converting a type `Self` into either a [`Left`] or [`Right`]
     7â†’/// variant of [`Either<Self, Self>`](Either).
     8â†’///
     9â†’/// The [`into_either`](IntoEither::into_either) method takes a [`bool`] to determine
    10â†’/// whether to convert to [`Left`] or [`Right`].
    11â†’///
    12â†’/// The [`into_either_with`](IntoEither::into_either_with) method takes a
    13â†’/// [predicate function](FnOnce) to determine whether to convert to [`Left`] or [`Right`].
    14â†’pub trait IntoEither: Sized {
    15â†’    /// Converts `self` into a [`Left`] variant of [`Either<Self, Self>`](Either)
    16â†’    /// if `into_left` is `true`.
    17â†’    /// Converts `self` into a [`Right`] variant of [`Either<Self, Self>`](Either)
    18â†’    /// otherwise.
    19â†’    ///
    20â†’    /// # Examples
    21â†’    ///
    22â†’    /// ```
    23â†’    /// use either::{IntoEither, Left, Right};
    24â†’    ///
    25â†’    /// let x = 0;
    26â†’    /// assert_eq!(x.into_either(true), Left(x));
    27â†’    /// assert_eq!(x.into_either(false), Right(x));
    28â†’    /// ```
    29â†’    fn into_either(self, into_left: bool) -> Either<Self, Self> {
    30â†’        if into_left {
    31â†’            Left(self)
    32â†’        } else {
    33â†’            Right(self)
    34â†’        }
    35â†’    }
    37â†’    /// Converts `self` into a [`Left`] variant of [`Either<Self, Self>`](Either)
    38â†’    /// if `into_left(&self)` returns `true`.
    39â†’    /// Converts `self` into a [`Right`] variant of [`Either<Self, Self>`](Either)
    40â†’    /// otherwise.
    41â†’    ///
    42â†’    /// # Examples
    43â†’    ///
    44â†’    /// ```
    45â†’    /// use either::{IntoEither, Left, Right};
    46â†’    ///
    47â†’    /// fn is_even(x: &u8) -> bool {
    48â†’    ///     x % 2 == 0
    49â†’    /// }
    50â†’    ///
    51â†’    /// let x = 0;
    52â†’    /// assert_eq!(x.into_either_with(is_even), Left(x));
    53â†’    /// assert_eq!(x.into_either_with(|x| !is_even(x)), Right(x));
    54â†’    /// ```
    55â†’    fn into_either_with<F>(self, into_left: F) -> Either<Self, Self>
    56â†’    where
    57â†’        F: FnOnce(&Self) -> bool,
    58â†’    {
    59â†’        let into_left = into_left(&self);
    60â†’        self.into_either(into_left)
    61â†’    }

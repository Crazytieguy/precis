     6Рєњ/// Provides methods for converting a type `Self` into either a [`Left`] or [`Right`]
     7Рєњ/// variant of [`Either<Self, Self>`](Either).
     8Рєњ///
     9Рєњ/// The [`into_either`](IntoEither::into_either) method takes a [`bool`] to determine
    10Рєњ/// whether to convert to [`Left`] or [`Right`].
    11Рєњ///
    12Рєњ/// The [`into_either_with`](IntoEither::into_either_with) method takes a
    13Рєњ/// [predicate function](FnOnce) to determine whether to convert to [`Left`] or [`Right`].
    14Рєњpub trait IntoEither: Sized {
    15Рєњ    /// Converts `self` into a [`Left`] variant of [`Either<Self, Self>`](Either)
    16Рєњ    /// if `into_left` is `true`.
    17Рєњ    /// Converts `self` into a [`Right`] variant of [`Either<Self, Self>`](Either)
    18Рєњ    /// otherwise.
    19Рєњ    ///
    20Рєњ    /// # Examples
    21Рєњ    ///
    22Рєњ    /// ```
    23Рєњ    /// use either::{IntoEither, Left, Right};
    24Рєњ    ///
    25Рєњ    /// let x = 0;
    26Рєњ    /// assert_eq!(x.into_either(true), Left(x));
    27Рєњ    /// assert_eq!(x.into_either(false), Right(x));
    28Рєњ    /// ```
    29Рєњ    fn into_either(self, into_left: bool) -> Either<Self, Self> {
    30Рєњ        if into_left {
    31Рєњ            Left(self)
    32Рєњ        } else {
    33Рєњ            Right(self)
    34Рєњ        }
    35Рєњ    }
    36Рєњ
    37Рєњ    /// Converts `self` into a [`Left`] variant of [`Either<Self, Self>`](Either)
    38Рєњ    /// if `into_left(&self)` returns `true`.
    39Рєњ    /// Converts `self` into a [`Right`] variant of [`Either<Self, Self>`](Either)
    40Рєњ    /// otherwise.
    41Рєњ    ///
    42Рєњ    /// # Examples
    43Рєњ    ///
    44Рєњ    /// ```
    45Рєњ    /// use either::{IntoEither, Left, Right};
    46Рєњ    ///
    47Рєњ    /// fn is_even(x: &u8) -> bool {
    48Рєњ    ///     x % 2 == 0
    49Рєњ    /// }
    50Рєњ    ///
    51Рєњ    /// let x = 0;
    52Рєњ    /// assert_eq!(x.into_either_with(is_even), Left(x));
    53Рєњ    /// assert_eq!(x.into_either_with(|x| !is_even(x)), Right(x));
    54Рєњ    /// ```
    55Рєњ    fn into_either_with<F>(self, into_left: F) -> Either<Self, Self>
    56Рєњ    where
    57Рєњ        F: FnOnce(&Self) -> bool,
    58Рєњ    {
    59Рєњ        let into_left = into_left(&self);
    60Рєњ        self.into_either(into_left)
    61Рєњ    }
    62Рєњ}

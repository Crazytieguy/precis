    39Рєњpub use crate::Either::{Left, Right};
    41Рєњ/// The enum `Either` with variants `Left` and `Right` is a general purpose
    42Рєњ/// sum type with two cases.
    43Рєњ///
    44Рєњ/// The `Either` type is symmetric and treats its variants the same way, without
    45Рєњ/// preference.
    46Рєњ/// (For representing success or error, use the regular `Result` enum instead.)
    47Рєњ#[cfg_attr(feature = "serde", derive(serde::Serialize, serde::Deserialize))]
    48Рєњ#[derive(Copy, PartialEq, Eq, PartialOrd, Ord, Hash, Debug)]
    49Рєњpub enum Either<L, R> {
    50Рєњ    /// A value of type `L`.
    51Рєњ    Left(L),
    52Рєњ    /// A value of type `R`.
    53Рєњ    Right(R),
    54Рєњ}
    56Рєњ/// Evaluate the provided expression for both [`Either::Left`] and [`Either::Right`].
    57Рєњ///
    58Рєњ/// This macro is useful in cases where both sides of [`Either`] can be interacted with
    59Рєњ/// in the same way even though the don't share the same type.
    60Рєњ///
    61Рєњ/// Syntax: `either::for_both!(` *expression* `,` *pattern* `=>` *expression* `)`
    62Рєњ///
    63Рєњ/// # Example
    64Рєњ///
    65Рєњ/// ```
    66Рєњ/// use either::Either;
    67Рєњ///
    68Рєњ/// fn length(owned_or_borrowed: Either<String, &'static str>) -> usize {
    69Рєњ///     either::for_both!(owned_or_borrowed, s => s.len())
    70Рєњ/// }
    71Рєњ///
    72Рєњ/// fn main() {
    73Рєњ///     let borrowed = Either::Right("Hello world!");
    74Рєњ///     let owned = Either::Left("Hello world!".to_owned());
    75Рєњ///
    76Рєњ///     assert_eq!(length(borrowed), 12);
    77Рєњ///     assert_eq!(length(owned), 12);
    78Рєњ/// }
    79Рєњ/// ```
    80Рєњ#[macro_export]
    81Рєњmacro_rules! for_both {
    82Рєњ    ($value:expr, $pattern:pat => $result:expr) => {
    83Рєњ        match $value {
    84Рєњ            $crate::Either::Left($pattern) => $result,
    85Рєњ            $crate::Either::Right($pattern) => $result,
    86Рєњ        }
    87Рєњ    };
    88Рєњ}
    90Рєњ/// Macro for unwrapping the left side of an [`Either`], which fails early
    91Рєњ/// with the opposite side. Can only be used in functions that return
    92Рєњ/// `Either` because of the early return of `Right` that it provides.
    93Рєњ///
    94Рєњ/// See also [`try_right!`] for its dual, which applies the same just to the
    95Рєњ/// right side.
    96Рєњ///
    97Рєњ/// # Example
    98Рєњ///
    99Рєњ/// ```
   100Рєњ/// use either::{Either, Left, Right};
   101Рєњ///
   102Рєњ/// fn twice(wrapper: Either<u32, &str>) -> Either<u32, &str> {
   103Рєњ///     let value = either::try_left!(wrapper);
   104Рєњ///     Left(value * 2)
   105Рєњ/// }
   106Рєњ///
   107Рєњ/// fn main() {
   108Рєњ///     assert_eq!(twice(Left(2)), Left(4));
   109Рєњ///     assert_eq!(twice(Right("ups")), Right("ups"));
   110Рєњ/// }
   111Рєњ/// ```
   112Рєњ#[macro_export]
   113Рєњmacro_rules! try_left {
   114Рєњ    ($expr:expr) => {
   115Рєњ        match $expr {
   116Рєњ            $crate::Left(val) => val,
   117Рєњ            $crate::Right(err) => return $crate::Right(::core::convert::From::from(err)),
   118Рєњ        }
   119Рєњ    };
   120Рєњ}
   122Рєњ/// Dual to [`try_left!`], see its documentation for more information.
   123Рєњ#[macro_export]
   124Рєњmacro_rules! try_right {
   125Рєњ    ($expr:expr) => {
   126Рєњ        match $expr {
   127Рєњ            $crate::Left(err) => return $crate::Left(::core::convert::From::from(err)),
   128Рєњ            $crate::Right(val) => val,
   129Рєњ        }
   130Рєњ    };
   131Рєњ}
   133Рєњmacro_rules! map_either {
   134Рєњ    ($value:expr, $pattern:pat => $result:expr) => {
   135Рєњ        match $value {
   136Рєњ            Left($pattern) => Left($result),
   137Рєњ            Right($pattern) => Right($result),
   138Рєњ        }
   139Рєњ    };
   140Рєњ}

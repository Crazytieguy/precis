    39тЖТpub use crate::Either::{Left, Right};
    41тЖТ/// The enum `Either` with variants `Left` and `Right` is a general purpose
    42тЖТ/// sum type with two cases.
    43тЖТ///
    44тЖТ/// The `Either` type is symmetric and treats its variants the same way, without
    45тЖТ/// preference.
    46тЖТ/// (For representing success or error, use the regular `Result` enum instead.)
    47тЖТ#[cfg_attr(feature = "serde", derive(serde::Serialize, serde::Deserialize))]
    48тЖТ#[derive(Copy, PartialEq, Eq, PartialOrd, Ord, Hash, Debug)]
    49тЖТpub enum Either<L, R> {
    50тЖТ    /// A value of type `L`.
    51тЖТ    Left(L),
    52тЖТ    /// A value of type `R`.
    53тЖТ    Right(R),
    54тЖТ}
    56тЖТ/// Evaluate the provided expression for both [`Either::Left`] and [`Either::Right`].
    57тЖТ///
    58тЖТ/// This macro is useful in cases where both sides of [`Either`] can be interacted with
    59тЖТ/// in the same way even though the don't share the same type.
    60тЖТ///
    61тЖТ/// Syntax: `either::for_both!(` *expression* `,` *pattern* `=>` *expression* `)`
    62тЖТ///
    63тЖТ/// # Example
    64тЖТ///
    65тЖТ/// ```
    66тЖТ/// use either::Either;
    67тЖТ///
    68тЖТ/// fn length(owned_or_borrowed: Either<String, &'static str>) -> usize {
    69тЖТ///     either::for_both!(owned_or_borrowed, s => s.len())
    70тЖТ/// }
    71тЖТ///
    72тЖТ/// fn main() {
    73тЖТ///     let borrowed = Either::Right("Hello world!");
    74тЖТ///     let owned = Either::Left("Hello world!".to_owned());
    75тЖТ///
    76тЖТ///     assert_eq!(length(borrowed), 12);
    77тЖТ///     assert_eq!(length(owned), 12);
    78тЖТ/// }
    79тЖТ/// ```
    80тЖТ#[macro_export]
    81тЖТmacro_rules! for_both {
    82тЖТ    ($value:expr, $pattern:pat => $result:expr) => {
    83тЖТ        match $value {
    84тЖТ            $crate::Either::Left($pattern) => $result,
    85тЖТ            $crate::Either::Right($pattern) => $result,
    86тЖТ        }
    87тЖТ    };
    88тЖТ}
    90тЖТ/// Macro for unwrapping the left side of an [`Either`], which fails early
    91тЖТ/// with the opposite side. Can only be used in functions that return
    92тЖТ/// `Either` because of the early return of `Right` that it provides.
    93тЖТ///
    94тЖТ/// See also [`try_right!`] for its dual, which applies the same just to the
    95тЖТ/// right side.
    96тЖТ///
    97тЖТ/// # Example
    98тЖТ///
    99тЖТ/// ```
   100тЖТ/// use either::{Either, Left, Right};
   101тЖТ///
   102тЖТ/// fn twice(wrapper: Either<u32, &str>) -> Either<u32, &str> {
   103тЖТ///     let value = either::try_left!(wrapper);
   104тЖТ///     Left(value * 2)
   105тЖТ/// }
   106тЖТ///
   107тЖТ/// fn main() {
   108тЖТ///     assert_eq!(twice(Left(2)), Left(4));
   109тЖТ///     assert_eq!(twice(Right("ups")), Right("ups"));
   110тЖТ/// }
   111тЖТ/// ```
   112тЖТ#[macro_export]
   113тЖТmacro_rules! try_left {
   114тЖТ    ($expr:expr) => {
   115тЖТ        match $expr {
   116тЖТ            $crate::Left(val) => val,
   117тЖТ            $crate::Right(err) => return $crate::Right(::core::convert::From::from(err)),
   118тЖТ        }
   119тЖТ    };
   120тЖТ}
   122тЖТ/// Dual to [`try_left!`], see its documentation for more information.
   123тЖТ#[macro_export]
   124тЖТmacro_rules! try_right {
   125тЖТ    ($expr:expr) => {
   126тЖТ        match $expr {
   127тЖТ            $crate::Left(err) => return $crate::Left(::core::convert::From::from(err)),
   128тЖТ            $crate::Right(val) => val,
   129тЖТ        }
   130тЖТ    };
   131тЖТ}
   133тЖТmacro_rules! map_either {
   134тЖТ    ($value:expr, $pattern:pat => $result:expr) => {
   135тЖТ        match $value {
   136тЖТ            Left($pattern) => Left($result),
   137тЖТ            Right($pattern) => Right($result),
   138тЖТ        }
   139тЖТ    };
   140тЖТ}

src/into_either.rs
     4‚Üíuse super::{Either, Left, Right};
     6‚Üí/// Provides methods for converting a type `Self` into either a [`Left`] or [`Right`]
     7‚Üí/// variant of [`Either<Self, Self>`](Either).
     8‚Üí///
     9‚Üí/// The [`into_either`](IntoEither::into_either) method takes a [`bool`] to determine
    10‚Üí/// whether to convert to [`Left`] or [`Right`].
    11‚Üí///
    12‚Üí/// The [`into_either_with`](IntoEither::into_either_with) method takes a
    13‚Üí/// [predicate function](FnOnce) to determine whether to convert to [`Left`] or [`Right`].
    14‚Üípub trait IntoEither: Sized {
    15‚Üí    /// Converts `self` into a [`Left`] variant of [`Either<Self, Self>`](Either)
    16‚Üí    /// if `into_left` is `true`.
    17‚Üí    /// Converts `self` into a [`Right`] variant of [`Either<Self, Self>`](Either)
    18‚Üí    /// otherwise.
    19‚Üí    ///
    20‚Üí    /// # Examples
    21‚Üí    ///
    22‚Üí    /// ```
    23‚Üí    /// use either::{IntoEither, Left, Right};
    24‚Üí    ///
    25‚Üí    /// let x = 0;
    26‚Üí    /// assert_eq!(x.into_either(true), Left(x));
    27‚Üí    /// assert_eq!(x.into_either(false), Right(x));
    28‚Üí    /// ```
    29‚Üí    fn into_either(self, into_left: bool) -> Either<Self, Self> {
    30‚Üí        if into_left {
    31‚Üí            Left(self)
    32‚Üí        } else {
    33‚Üí            Right(self)
    34‚Üí        }
    35‚Üí    }
    37‚Üí    /// Converts `self` into a [`Left`] variant of [`Either<Self, Self>`](Either)
    38‚Üí    /// if `into_left(&self)` returns `true`.
    39‚Üí    /// Converts `self` into a [`Right`] variant of [`Either<Self, Self>`](Either)
    40‚Üí    /// otherwise.
    41‚Üí    ///
    42‚Üí    /// # Examples
    43‚Üí    ///
    44‚Üí    /// ```
    45‚Üí    /// use either::{IntoEither, Left, Right};
    46‚Üí    ///
    47‚Üí    /// fn is_even(x: &u8) -> bool {
    48‚Üí    ///     x % 2 == 0
    49‚Üí    /// }
    50‚Üí    ///
    51‚Üí    /// let x = 0;
    52‚Üí    /// assert_eq!(x.into_either_with(is_even), Left(x));
    53‚Üí    /// assert_eq!(x.into_either_with(|x| !is_even(x)), Right(x));
    54‚Üí    /// ```
    55‚Üí    fn into_either_with<F>(self, into_left: F) -> Either<Self, Self>
    56‚Üí    where
    57‚Üí        F: FnOnce(&Self) -> bool,
    58‚Üí    {
    59‚Üí        let into_left = into_left(&self);
    60‚Üí        self.into_either(into_left)
    61‚Üí    }
    64‚Üíimpl<T> IntoEither for T {}


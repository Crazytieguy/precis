  1527→        }
  1528→        fn check_mut<T: AsMut<$t>>() {}
  1529→        fn propagate_mut<T1: AsMut<$t>, T2: AsMut<$t>>() {
  1530→            check_mut::<Either<T1, T2>>()
  1531→        }
  1532→    }};
  1533→}
  1536→fn _unsized_ref_propagation() {

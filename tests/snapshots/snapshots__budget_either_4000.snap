    36‚Üíuse serde::{Deserialize, Deserializer, Serialize, Serializer};
    38‚Üí#[derive(serde::Serialize, serde::Deserialize)]
    39‚Üí#[serde(untagged)]
    40‚Üíenum Either<L, R> {
    41‚Üí    Left(L),
    42‚Üí    Right(R),
    43‚Üí}
    45‚Üípub fn serialize<L, R, S>(this: &super::Either<L, R>, serializer: S) -> Result<S::Ok, S::Error>
    46‚Üíwhere
    47‚Üí    S: Serializer,
    48‚Üí    L: Serialize,
    49‚Üí    R: Serialize,
    50‚Üí{
    51‚Üí    let untagged = match this {
    52‚Üí        super::Either::Left(left) => Either::Left(left),
    53‚Üí        super::Either::Right(right) => Either::Right(right),
    54‚Üí    };
    55‚Üí    untagged.serialize(serializer)
    56‚Üí}
    58‚Üípub fn deserialize<'de, L, R, D>(deserializer: D) -> Result<super::Either<L, R>, D::Error>
    59‚Üíwhere
    60‚Üí    D: Deserializer<'de>,
    61‚Üí    L: Deserialize<'de>,
    62‚Üí    R: Deserialize<'de>,
    63‚Üí{
    64‚Üí    match Either::deserialize(deserializer) {
    65‚Üí        Ok(Either::Left(left)) => Ok(super::Either::Left(left)),
    66‚Üí        Ok(Either::Right(right)) => Ok(super::Either::Right(right)),
    67‚Üí        Err(error) => Err(error),
    68‚Üí    }
    69‚Üí}

src/serde_untagged_optional.rs
    36‚Üíuse serde::{Deserialize, Deserializer, Serialize, Serializer};
    38‚Üí#[derive(Serialize, Deserialize)]
    39‚Üí#[serde(untagged)]
    40‚Üíenum Either<L, R> {
    41‚Üí    Left(L),
    42‚Üí    Right(R),
    43‚Üí}
    45‚Üípub fn serialize<L, R, S>(
    46‚Üí    this: &Option<super::Either<L, R>>,
    47‚Üí    serializer: S,
    48‚Üí) -> Result<S::Ok, S::Error>
    49‚Üíwhere
    50‚Üí    S: Serializer,
    51‚Üí    L: Serialize,
    52‚Üí    R: Serialize,
    53‚Üí{
    54‚Üí    let untagged = match this {
    55‚Üí        Some(super::Either::Left(left)) => Some(Either::Left(left)),
    56‚Üí        Some(super::Either::Right(right)) => Some(Either::Right(right)),
    57‚Üí        None => None,
    58‚Üí    };
    59‚Üí    untagged.serialize(serializer)
    60‚Üí}
    62‚Üípub fn deserialize<'de, L, R, D>(deserializer: D) -> Result<Option<super::Either<L, R>>, D::Error>
    63‚Üíwhere
    64‚Üí    D: Deserializer<'de>,
    65‚Üí    L: Deserialize<'de>,
    66‚Üí    R: Deserialize<'de>,
    67‚Üí{
    68‚Üí    match Option::deserialize(deserializer) {
    69‚Üí        Ok(Some(Either::Left(left))) => Ok(Some(super::Either::Left(left))),
    70‚Üí        Ok(Some(Either::Right(right))) => Ok(Some(super::Either::Right(right))),
    71‚Üí        Ok(None) => Ok(None),
    72‚Üí        Err(error) => Err(error),
    73‚Üí    }
    74‚Üí}

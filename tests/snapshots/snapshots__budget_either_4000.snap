    11ÔåÆ///
    12ÔåÆ/// The [`into_either_with`](IntoEither::into_either_with) method takes a
    13ÔåÆ/// [predicate function](FnOnce) to determine whether to convert to [`Left`] or [`Right`].
    14ÔåÆpub trait IntoEither: Sized {
    15ÔåÆ    /// Converts `self` into a [`Left`] variant of [`Either<Self, Self>`](Either)
    16ÔåÆ    /// if `into_left` is `true`.
    17ÔåÆ    /// Converts `self` into a [`Right`] variant of [`Either<Self, Self>`](Either)
    18ÔåÆ    /// otherwise.
    19ÔåÆ    ///
    20ÔåÆ    /// # Examples
    21ÔåÆ    ///
    22ÔåÆ    /// ```
    23ÔåÆ    /// use either::{IntoEither, Left, Right};
    24ÔåÆ    ///
    25ÔåÆ    /// let x = 0;
    26ÔåÆ    /// assert_eq!(x.into_either(true), Left(x));
    27ÔåÆ    /// assert_eq!(x.into_either(false), Right(x));
    28ÔåÆ    /// ```
    29ÔåÆ    fn into_either(self, into_left: bool) -> Either<Self, Self> {
    30ÔåÆ        if into_left {
    31ÔåÆ            Left(self)
    32ÔåÆ        } else {
    33ÔåÆ            Right(self)
    34ÔåÆ        }
    35ÔåÆ    }
    37ÔåÆ    /// Converts `self` into a [`Left`] variant of [`Either<Self, Self>`](Either)
    38ÔåÆ    /// if `into_left(&self)` returns `true`.
    39ÔåÆ    /// Converts `self` into a [`Right`] variant of [`Either<Self, Self>`](Either)
    40ÔåÆ    /// otherwise.
    41ÔåÆ    ///
    42ÔåÆ    /// # Examples
    43ÔåÆ    ///
    44ÔåÆ    /// ```
    45ÔåÆ    /// use either::{IntoEither, Left, Right};
    46ÔåÆ    ///
    47ÔåÆ    /// fn is_even(x: &u8) -> bool {
    48ÔåÆ    ///     x % 2 == 0
    49ÔåÆ    /// }
    50ÔåÆ    ///
    51ÔåÆ    /// let x = 0;
    52ÔåÆ    /// assert_eq!(x.into_either_with(is_even), Left(x));
    53ÔåÆ    /// assert_eq!(x.into_either_with(|x| !is_even(x)), Right(x));
    54ÔåÆ    /// ```
    55ÔåÆ    fn into_either_with<F>(self, into_left: F) -> Either<Self, Self>
    56ÔåÆ    where
    57ÔåÆ        F: FnOnce(&Self) -> bool,
    58ÔåÆ    {
    59ÔåÆ        let into_left = into_left(&self);
    60ÔåÆ        self.into_either(into_left)
    61ÔåÆ    }

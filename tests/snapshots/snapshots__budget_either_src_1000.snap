     4тЖТuse super::{Either, Left, Right};
     6тЖТ/// Provides methods for converting a type `Self` into either a [`Left`] or [`Right`]
     7тЖТ/// variant of [`Either<Self, Self>`](Either).
     8тЖТ///
     9тЖТ/// The [`into_either`](IntoEither::into_either) method takes a [`bool`] to determine
    10тЖТ/// whether to convert to [`Left`] or [`Right`].
    11тЖТ///
    12тЖТ/// The [`into_either_with`](IntoEither::into_either_with) method takes a
    13тЖТ/// [predicate function](FnOnce) to determine whether to convert to [`Left`] or [`Right`].
    14тЖТpub trait IntoEither: Sized {
    15тЖТ    /// Converts `self` into a [`Left`] variant of [`Either<Self, Self>`](Either)
    16тЖТ    /// if `into_left` is `true`.
    17тЖТ    /// Converts `self` into a [`Right`] variant of [`Either<Self, Self>`](Either)
    18тЖТ    /// otherwise.
    19тЖТ    ///
    20тЖТ    /// # Examples
    21тЖТ    ///
    22тЖТ    /// ```
    23тЖТ    /// use either::{IntoEither, Left, Right};
    24тЖТ    ///
    25тЖТ    /// let x = 0;
    26тЖТ    /// assert_eq!(x.into_either(true), Left(x));
    27тЖТ    /// assert_eq!(x.into_either(false), Right(x));
    28тЖТ    /// ```
    29тЖТ    fn into_either(self, into_left: bool) -> Either<Self, Self> {
    30тЖТ        if into_left {
    31тЖТ            Left(self)
    32тЖТ        } else {
    33тЖТ            Right(self)
    34тЖТ        }
    35тЖТ    }
    36тЖТ
    37тЖТ    /// Converts `self` into a [`Left`] variant of [`Either<Self, Self>`](Either)
    38тЖТ    /// if `into_left(&self)` returns `true`.
    39тЖТ    /// Converts `self` into a [`Right`] variant of [`Either<Self, Self>`](Either)
    40тЖТ    /// otherwise.
    41тЖТ    ///
    42тЖТ    /// # Examples
    43тЖТ    ///
    44тЖТ    /// ```
    45тЖТ    /// use either::{IntoEither, Left, Right};
    46тЖТ    ///
    47тЖТ    /// fn is_even(x: &u8) -> bool {
    48тЖТ    ///     x % 2 == 0
    49тЖТ    /// }
    50тЖТ    ///
    51тЖТ    /// let x = 0;
    52тЖТ    /// assert_eq!(x.into_either_with(is_even), Left(x));
    53тЖТ    /// assert_eq!(x.into_either_with(|x| !is_even(x)), Right(x));
    54тЖТ    /// ```
    55тЖТ    fn into_either_with<F>(self, into_left: F) -> Either<Self, Self>
    56тЖТ    where
    57тЖТ        F: FnOnce(&Self) -> bool,
    58тЖТ    {
    59тЖТ        let into_left = into_left(&self);
    60тЖТ        self.into_either(into_left)
    61тЖТ    }
    62тЖТ}

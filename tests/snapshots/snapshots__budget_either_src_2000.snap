     6Ôćĺ/// Provides methods for converting a type `Self` into either a [`Left`] or [`Right`]
     7Ôćĺ/// variant of [`Either<Self, Self>`](Either).
     8Ôćĺ///
     9Ôćĺ/// The [`into_either`](IntoEither::into_either) method takes a [`bool`] to determine
    10Ôćĺ/// whether to convert to [`Left`] or [`Right`].
    11Ôćĺ///
    12Ôćĺ/// The [`into_either_with`](IntoEither::into_either_with) method takes a
    13Ôćĺ/// [predicate function](FnOnce) to determine whether to convert to [`Left`] or [`Right`].
    14Ôćĺpub trait IntoEither: Sized {
    15Ôćĺ    /// Converts `self` into a [`Left`] variant of [`Either<Self, Self>`](Either)
    16Ôćĺ    /// if `into_left` is `true`.
    17Ôćĺ    /// Converts `self` into a [`Right`] variant of [`Either<Self, Self>`](Either)
    18Ôćĺ    /// otherwise.
    19Ôćĺ    ///
    20Ôćĺ    /// # Examples
    21Ôćĺ    ///
    22Ôćĺ    /// ```
    23Ôćĺ    /// use either::{IntoEither, Left, Right};
    24Ôćĺ    ///
    25Ôćĺ    /// let x = 0;
    26Ôćĺ    /// assert_eq!(x.into_either(true), Left(x));
    27Ôćĺ    /// assert_eq!(x.into_either(false), Right(x));
    28Ôćĺ    /// ```
    29Ôćĺ    fn into_either(self, into_left: bool) -> Either<Self, Self> {
    30Ôćĺ        if into_left {
    31Ôćĺ            Left(self)
    32Ôćĺ        } else {
    33Ôćĺ            Right(self)
    34Ôćĺ        }
    35Ôćĺ    }
    36Ôćĺ
    37Ôćĺ    /// Converts `self` into a [`Left`] variant of [`Either<Self, Self>`](Either)
    38Ôćĺ    /// if `into_left(&self)` returns `true`.
    39Ôćĺ    /// Converts `self` into a [`Right`] variant of [`Either<Self, Self>`](Either)
    40Ôćĺ    /// otherwise.
    41Ôćĺ    ///
    42Ôćĺ    /// # Examples
    43Ôćĺ    ///
    44Ôćĺ    /// ```
    45Ôćĺ    /// use either::{IntoEither, Left, Right};
    46Ôćĺ    ///
    47Ôćĺ    /// fn is_even(x: &u8) -> bool {
    48Ôćĺ    ///     x % 2 == 0
    49Ôćĺ    /// }
    50Ôćĺ    ///
    51Ôćĺ    /// let x = 0;
    52Ôćĺ    /// assert_eq!(x.into_either_with(is_even), Left(x));
    53Ôćĺ    /// assert_eq!(x.into_either_with(|x| !is_even(x)), Right(x));
    54Ôćĺ    /// ```
    55Ôćĺ    fn into_either_with<F>(self, into_left: F) -> Either<Self, Self>
    56Ôćĺ    where
    57Ôćĺ        F: FnOnce(&Self) -> bool,
    58Ôćĺ    {
    59Ôćĺ        let into_left = into_left(&self);
    60Ôćĺ        self.into_either(into_left)
    61Ôćĺ    }
    62Ôćĺ}

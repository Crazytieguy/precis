  1521‚Üí/// A helper macro to check if AsRef and AsMut are implemented for a given type.
  1522‚Üímacro_rules! check_t {
  1523‚Üí    ($t:ty) => {{
  1524‚Üí        fn check_ref<T: AsRef<$t>>() {}

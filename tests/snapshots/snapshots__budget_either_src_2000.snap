    39‚Üípub use crate::Either::{Left, Right};
    41‚Üí/// The enum `Either` with variants `Left` and `Right` is a general purpose
    42‚Üí/// sum type with two cases.
    43‚Üí///
    44‚Üí/// The `Either` type is symmetric and treats its variants the same way, without
    45‚Üí/// preference.
    46‚Üí/// (For representing success or error, use the regular `Result` enum instead.)
    47‚Üí#[cfg_attr(feature = "serde", derive(serde::Serialize, serde::Deserialize))]
    48‚Üí#[derive(Copy, PartialEq, Eq, PartialOrd, Ord, Hash, Debug)]
    49‚Üípub enum Either<L, R> {
    50‚Üí    /// A value of type `L`.
    51‚Üí    Left(L),
    52‚Üí    /// A value of type `R`.
    53‚Üí    Right(R),
    54‚Üí}
    56‚Üí/// Evaluate the provided expression for both [`Either::Left`] and [`Either::Right`].
    57‚Üí///
    58‚Üí/// This macro is useful in cases where both sides of [`Either`] can be interacted with
    59‚Üí/// in the same way even though the don't share the same type.
    60‚Üí///
    61‚Üí/// Syntax: `either::for_both!(` *expression* `,` *pattern* `=>` *expression* `)`
    62‚Üí///
    63‚Üí/// # Example
    64‚Üí///
    65‚Üí/// ```
    66‚Üí/// use either::Either;
    67‚Üí///
    68‚Üí/// fn length(owned_or_borrowed: Either<String, &'static str>) -> usize {
    69‚Üí///     either::for_both!(owned_or_borrowed, s => s.len())
    70‚Üí/// }
    71‚Üí///
    72‚Üí/// fn main() {
    73‚Üí///     let borrowed = Either::Right("Hello world!");
    74‚Üí///     let owned = Either::Left("Hello world!".to_owned());
    75‚Üí///
    76‚Üí///     assert_eq!(length(borrowed), 12);
    77‚Üí///     assert_eq!(length(owned), 12);
    78‚Üí/// }
    79‚Üí/// ```
    80‚Üí#[macro_export]
    81‚Üímacro_rules! for_both {
    82‚Üí    ($value:expr, $pattern:pat => $result:expr) => {
    83‚Üí        match $value {
    84‚Üí            $crate::Either::Left($pattern) => $result,
    85‚Üí            $crate::Either::Right($pattern) => $result,
    86‚Üí        }
    87‚Üí    };
    88‚Üí}
    90‚Üí/// Macro for unwrapping the left side of an [`Either`], which fails early
    91‚Üí/// with the opposite side. Can only be used in functions that return
    92‚Üí/// `Either` because of the early return of `Right` that it provides.
    93‚Üí///
    94‚Üí/// See also [`try_right!`] for its dual, which applies the same just to the
    95‚Üí/// right side.
    96‚Üí///
    97‚Üí/// # Example
    98‚Üí///
    99‚Üí/// ```
   100‚Üí/// use either::{Either, Left, Right};
   101‚Üí///
   102‚Üí/// fn twice(wrapper: Either<u32, &str>) -> Either<u32, &str> {
   103‚Üí///     let value = either::try_left!(wrapper);
   104‚Üí///     Left(value * 2)
   105‚Üí/// }
   106‚Üí///
   107‚Üí/// fn main() {
   108‚Üí///     assert_eq!(twice(Left(2)), Left(4));
   109‚Üí///     assert_eq!(twice(Right("ups")), Right("ups"));
   110‚Üí/// }
   111‚Üí/// ```
   112‚Üí#[macro_export]
   113‚Üímacro_rules! try_left {
   114‚Üí    ($expr:expr) => {
   115‚Üí        match $expr {
   116‚Üí            $crate::Left(val) => val,
   117‚Üí            $crate::Right(err) => return $crate::Right(::core::convert::From::from(err)),
   118‚Üí        }
   119‚Üí    };
   120‚Üí}
   122‚Üí/// Dual to [`try_left!`], see its documentation for more information.
   123‚Üí#[macro_export]
   124‚Üímacro_rules! try_right {
   125‚Üí    ($expr:expr) => {
   126‚Üí        match $expr {
   127‚Üí            $crate::Left(err) => return $crate::Left(::core::convert::From::from(err)),
   128‚Üí            $crate::Right(val) => val,
   129‚Üí        }
   130‚Üí    };
   131‚Üí}
   133‚Üímacro_rules! map_either {
   134‚Üí    ($value:expr, $pattern:pat => $result:expr) => {
   135‚Üí        match $value {
   136‚Üí            Left($pattern) => Left($result),
   137‚Üí            Right($pattern) => Right($result),
   138‚Üí        }
   139‚Üí    };
   140‚Üí}

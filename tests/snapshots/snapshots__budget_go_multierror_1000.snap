flatten.go
     6вҶ’// Flatten flattens the given error, merging any *Errors together into
     7вҶ’// a single *Error.
     8вҶ’func Flatten(err error) error {
    20вҶ’func flatten(err error, flatErr *Error) {
    21вҶ’	switch err := err.(type) {
    22вҶ’	case *Error:
    23вҶ’		for _, e := range err.Errors {
    24вҶ’			flatten(e, flatErr)
    25вҶ’		}
    26вҶ’	default:
    27вҶ’		flatErr.Errors = append(flatErr.Errors, err)
    28вҶ’	}
    29вҶ’}

append.go
     6тЖТ// Append is a helper function that will append more errors
     7тЖТ// onto an Error in order to create a larger multi-error.
     8тЖТ//
     9тЖТ// If err is not a multierror.Error, then it will be turned into
    10тЖТ// one. If any of the errs are multierr.Error, they will be flattened
    11тЖТ// one level into err.
    12тЖТ// Any nil errors within errs will be ignored. If err is nil, a new
    13тЖТ// *Error will be returned.
    14тЖТfunc Append(err error, errs ...error) *Error {
    15тЖТ	switch err := err.(type) {
    16тЖТ	case *Error:
    17тЖТ		// Typed nils can reach here, so initialize if we are nil
    18тЖТ		if err == nil {
    19тЖТ			err = new(Error)
    20тЖТ		}
    21тЖТ
    22тЖТ		// Go through each error and flatten
    23тЖТ		for _, e := range errs {
    24тЖТ			switch e := e.(type) {
    25тЖТ			case *Error:
    26тЖТ				if e != nil {
    27тЖТ					err.Errors = append(err.Errors, e.Errors...)
    28тЖТ				}
    29тЖТ			default:
    30тЖТ				if e != nil {
    31тЖТ					err.Errors = append(err.Errors, e)
    32тЖТ				}
    33тЖТ			}
    34тЖТ		}
    35тЖТ
    36тЖТ		return err
    37тЖТ	default:
    38тЖТ		newErrs := make([]error, 0, len(errs)+1)
    39тЖТ		if err != nil {
    40тЖТ			newErrs = append(newErrs, err)
    41тЖТ		}
    42тЖТ		newErrs = append(newErrs, errs...)
    43тЖТ
    44тЖТ		return Append(&Error{}, newErrs...)
    45тЖТ	}
    46тЖТ}
flatten.go
     6тЖТ// Flatten flattens the given error, merging any *Errors together into
     7тЖТ// a single *Error.
     8тЖТfunc Flatten(err error) error {
     9тЖТ	// If it isn't an *Error, just return the error as-is
    10тЖТ	if _, ok := err.(*Error); !ok {
    11тЖТ		return err
    12тЖТ	}
    13тЖТ
    14тЖТ	// Otherwise, make the result and flatten away!
    15тЖТ	flatErr := new(Error)
    16тЖТ	flatten(err, flatErr)
    17тЖТ	return flatErr
    18тЖТ}
    20тЖТfunc flatten(err error, flatErr *Error) {
    21тЖТ	switch err := err.(type) {
    22тЖТ	case *Error:
    23тЖТ		for _, e := range err.Errors {
    24тЖТ			flatten(e, flatErr)
    25тЖТ		}
    26тЖТ	default:
    27тЖТ		flatErr.Errors = append(flatErr.Errors, err)
    28тЖТ	}
    29тЖТ}
format.go
     6тЖТimport (
     7тЖТ	"fmt"
     8тЖТ	"strings"
     9тЖТ)
    11тЖТ// ErrorFormatFunc is a function callback that is called by Error to
    12тЖТ// turn the list of errors into a string.
    13тЖТtype ErrorFormatFunc func([]error) string
    15тЖТ// ListFormatFunc is a basic formatter that outputs the number of errors
    16тЖТ// that occurred along with a bullet point list of the errors.
    17тЖТfunc ListFormatFunc(es []error) string {
    18тЖТ	if len(es) == 1 {
    19тЖТ		return fmt.Sprintf("1 error occurred:\n\t* %s\n\n", es[0])
    20тЖТ	}
    21тЖТ
    22тЖТ	points := make([]string, len(es))
    23тЖТ	for i, err := range es {
    24тЖТ		points[i] = fmt.Sprintf("* %s", err)
    25тЖТ	}
    26тЖТ
    27тЖТ	return fmt.Sprintf(
    28тЖТ		"%d errors occurred:\n\t%s\n\n",
    29тЖТ		len(es), strings.Join(points, "\n\t"))
    30тЖТ}
group.go
     6тЖТimport "sync"
     8тЖТ// Group is a collection of goroutines which return errors that need to be
     9тЖТ// coalesced.
    10тЖТtype Group struct {
    11тЖТ	mutex sync.Mutex
    12тЖТ	err   *Error
    13тЖТ	wg    sync.WaitGroup
    14тЖТ}
    16тЖТ// Go calls the given function in a new goroutine.
    17тЖТ//
    18тЖТ// If the function returns an error it is added to the group multierror which
    19тЖТ// is returned by Wait.
    20тЖТfunc (g *Group) Go(f func() error) {
    21тЖТ	g.wg.Add(1)
    22тЖТ
    23тЖТ	go func() {
    24тЖТ		defer g.wg.Done()
    25тЖТ
    26тЖТ		if err := f(); err != nil {
    27тЖТ			g.mutex.Lock()
    28тЖТ			g.err = Append(g.err, err)
    29тЖТ			g.mutex.Unlock()
    30тЖТ		}
    31тЖТ	}()
    32тЖТ}
    34тЖТ// Wait blocks until all function calls from the Go method have returned, then
    35тЖТ// returns the multierror.
    36тЖТfunc (g *Group) Wait() *Error {
    37тЖТ	g.wg.Wait()
    38тЖТ	g.mutex.Lock()
    39тЖТ	defer g.mutex.Unlock()
    40тЖТ	return g.err
    41тЖТ}
multierror.go
     6тЖТimport (
     7тЖТ	"errors"
     8тЖТ	"fmt"
     9тЖТ)
    11тЖТ// Error is an error type to track multiple errors. This is used to
    12тЖТ// accumulate errors in cases and return them as a single "error".
    13тЖТtype Error struct {
    14тЖТ	Errors      []error
    15тЖТ	ErrorFormat ErrorFormatFunc
    16тЖТ}
    18тЖТfunc (e *Error) Error() string {
    19тЖТ	fn := e.ErrorFormat
    20тЖТ	if fn == nil {
    21тЖТ		fn = ListFormatFunc
    22тЖТ	}
    23тЖТ
    24тЖТ	return fn(e.Errors)
    25тЖТ}
    27тЖТ// ErrorOrNil returns an error interface if this Error represents
    28тЖТ// a list of errors, or returns nil if the list of errors is empty. This
    29тЖТ// function is useful at the end of accumulation to make sure that the value
    30тЖТ// returned represents the existence of errors.
    31тЖТfunc (e *Error) ErrorOrNil() error {
    32тЖТ	if e == nil {
    33тЖТ		return nil
    34тЖТ	}
    35тЖТ	if len(e.Errors) == 0 {
    36тЖТ		return nil
    37тЖТ	}
    38тЖТ
    39тЖТ	return e
    40тЖТ}
    42тЖТfunc (e *Error) GoString() string {
    43тЖТ	return fmt.Sprintf("*%#v", *e)
    44тЖТ}
    46тЖТ// WrappedErrors returns the list of errors that this Error is wrapping. It is
    47тЖТ// an implementation of the errwrap.Wrapper interface so that multierror.Error
    48тЖТ// can be used with that library.
    49тЖТ//
    50тЖТ// This method is not safe to be called concurrently. Unlike accessing the
    51тЖТ// Errors field directly, this function also checks if the multierror is nil to
    52тЖТ// prevent a null-pointer panic. It satisfies the errwrap.Wrapper interface.
    53тЖТfunc (e *Error) WrappedErrors() []error {
    54тЖТ	if e == nil {
    55тЖТ		return nil
    56тЖТ	}
    57тЖТ	return e.Errors
    58тЖТ}
    60тЖТ// Unwrap returns an error from Error (or nil if there are no errors).
    61тЖТ// This error returned will further support Unwrap to get the next error,
    62тЖТ// etc. The order will match the order of Errors in the multierror.Error
    63тЖТ// at the time of calling.
    64тЖТ//
    65тЖТ// The resulting error supports errors.As/Is/Unwrap so you can continue
    66тЖТ// to use the stdlib errors package to introspect further.
    67тЖТ//
    68тЖТ// This will perform a shallow copy of the errors slice. Any errors appended
    69тЖТ// to this error after calling Unwrap will not be available until a new
    70тЖТ// Unwrap is called on the multierror.Error.
    71тЖТfunc (e *Error) Unwrap() error {
    72тЖТ	// If we have no errors then we do nothing
    73тЖТ	if e == nil || len(e.Errors) == 0 {
    74тЖТ		return nil
    75тЖТ	}
    76тЖТ
    77тЖТ	// If we have exactly one error, we can just return that directly.
    78тЖТ	if len(e.Errors) == 1 {
    79тЖТ		return e.Errors[0]
    80тЖТ	}
    81тЖТ
    82тЖТ	// Shallow copy the slice
    83тЖТ	errs := make([]error, len(e.Errors))
    84тЖТ	copy(errs, e.Errors)
    85тЖТ	return chain(errs)
    86тЖТ}
    88тЖТ// chain implements the interfaces necessary for errors.Is/As/Unwrap to
    89тЖТ// work in a deterministic way with multierror. A chain tracks a list of
    90тЖТ// errors while accounting for the current represented error. This lets
    91тЖТ// Is/As be meaningful.
    92тЖТ//
    93тЖТ// Unwrap returns the next error. In the cleanest form, Unwrap would return
    94тЖТ// the wrapped error here but we can't do that if we want to properly
    95тЖТ// get access to all the errors. Instead, users are recommended to use
    96тЖТ// Is/As to get the correct error type out.
    97тЖТ//
    98тЖТ// Precondition: []error is non-empty (len > 0)
    99тЖТtype chain []error
   101тЖТ// Error implements the error interface
   102тЖТfunc (e chain) Error() string {
   103тЖТ	return e[0].Error()
   104тЖТ}
   106тЖТ// Unwrap implements errors.Unwrap by returning the next error in the
   107тЖТ// chain or nil if there are no more errors.
   108тЖТfunc (e chain) Unwrap() error {
   109тЖТ	if len(e) == 1 {
   110тЖТ		return nil
   111тЖТ	}
   112тЖТ
   113тЖТ	return e[1:]
   114тЖТ}
   116тЖТ// As implements errors.As by attempting to map to the current value.
   117тЖТfunc (e chain) As(target interface{}) bool {
   118тЖТ	return errors.As(e[0], target)
   119тЖТ}
   121тЖТ// Is implements errors.Is by comparing the current value directly.
   122тЖТfunc (e chain) Is(target error) bool {
   123тЖТ	return errors.Is(e[0], target)
   124тЖТ}
prefix.go
     6тЖТimport (
     7тЖТ	"fmt"
     8тЖТ)
    10тЖТ// Prefix is a helper function that will prefix some text
    11тЖТ// to the given error. If the error is a multierror.Error, then
    12тЖТ// it will be prefixed to each wrapped error.
    13тЖТ//
    14тЖТ// This is useful to use when appending multiple multierrors
    15тЖТ// together in order to give better scoping.
    16тЖТfunc Prefix(err error, prefix string) error {
    17тЖТ	if err == nil {
    18тЖТ		return nil
    19тЖТ	}
    20тЖТ
    21тЖТ	switch err := err.(type) {
    22тЖТ	case *Error:
    23тЖТ		// Typed nils can reach here, so initialize if we are nil
    24тЖТ		if err == nil {
    25тЖТ			err = new(Error)
    26тЖТ		}
    27тЖТ
    28тЖТ		// Wrap each of the errors
    29тЖТ		for i, e := range err.Errors {
    30тЖТ			err.Errors[i] = fmt.Errorf("%s %s", prefix, e)
    31тЖТ		}
    32тЖТ
    33тЖТ		return err
    34тЖТ	default:
    35тЖТ		return fmt.Errorf("%s %s", prefix, err)
    36тЖТ	}
    37тЖТ}
sort.go
     6тЖТ// Len implements sort.Interface function for length
     7тЖТfunc (err *Error) Len() int {
     8тЖТ	if err == nil {
     9тЖТ		return 0
    10тЖТ	}
    11тЖТ
    12тЖТ	return len(err.Errors)
    13тЖТ}
    15тЖТ// Swap implements sort.Interface function for swapping elements
    16тЖТfunc (err Error) Swap(i, j int) {
    17тЖТ	err.Errors[i], err.Errors[j] = err.Errors[j], err.Errors[i]
    18тЖТ}
    20тЖТ// Less implements sort.Interface function for determining order
    21тЖТfunc (err Error) Less(i, j int) bool {
    22тЖТ	return err.Errors[i].Error() < err.Errors[j].Error()
    23тЖТ}

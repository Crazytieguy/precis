append.go
     6â†’// Append is a helper function that will append more errors
     7â†’// onto an Error in order to create a larger multi-error.
     8â†’//
     9â†’// If err is not a multierror.Error, then it will be turned into
    10â†’// one. If any of the errs are multierr.Error, they will be flattened
    11â†’// one level into err.
    12â†’// Any nil errors within errs will be ignored. If err is nil, a new
    13â†’// *Error will be returned.
    14â†’func Append(err error, errs ...error) *Error {
    15â†’	switch err := err.(type) {
    16â†’	case *Error:
    17â†’		// Typed nils can reach here, so initialize if we are nil
    18â†’		if err == nil {
    19â†’			err = new(Error)
    20â†’		}
    21â†’
    22â†’		// Go through each error and flatten
    23â†’		for _, e := range errs {
    24â†’			switch e := e.(type) {
    25â†’			case *Error:
    26â†’				if e != nil {
    27â†’					err.Errors = append(err.Errors, e.Errors...)
    28â†’				}
    29â†’			default:
    30â†’				if e != nil {
    31â†’					err.Errors = append(err.Errors, e)
    32â†’				}
    33â†’			}
    34â†’		}
    35â†’
    36â†’		return err
    37â†’	default:
    38â†’		newErrs := make([]error, 0, len(errs)+1)
    39â†’		if err != nil {
    40â†’			newErrs = append(newErrs, err)
    41â†’		}
    42â†’		newErrs = append(newErrs, errs...)
    43â†’
    44â†’		return Append(&Error{}, newErrs...)
    45â†’	}
    46â†’}
flatten.go
     6â†’// Flatten flattens the given error, merging any *Errors together into
     7â†’// a single *Error.
     8â†’func Flatten(err error) error {
     9â†’	// If it isn't an *Error, just return the error as-is
    10â†’	if _, ok := err.(*Error); !ok {
    11â†’		return err
    12â†’	}
    13â†’
    14â†’	// Otherwise, make the result and flatten away!
    15â†’	flatErr := new(Error)
    16â†’	flatten(err, flatErr)
    17â†’	return flatErr
    18â†’}
    20â†’func flatten(err error, flatErr *Error) {
    21â†’	switch err := err.(type) {
    22â†’	case *Error:
    23â†’		for _, e := range err.Errors {
    24â†’			flatten(e, flatErr)
    25â†’		}
    26â†’	default:
    27â†’		flatErr.Errors = append(flatErr.Errors, err)
    28â†’	}
    29â†’}
format.go
    11â†’// ErrorFormatFunc is a function callback that is called by Error to
    12â†’// turn the list of errors into a string.
    13â†’type ErrorFormatFunc func([]error) string
    15â†’// ListFormatFunc is a basic formatter that outputs the number of errors
    16â†’// that occurred along with a bullet point list of the errors.
    17â†’func ListFormatFunc(es []error) string {
    18â†’	if len(es) == 1 {
    19â†’		return fmt.Sprintf("1 error occurred:\n\t* %s\n\n", es[0])
    20â†’	}
    21â†’
    22â†’	points := make([]string, len(es))
    23â†’	for i, err := range es {
    24â†’		points[i] = fmt.Sprintf("* %s", err)
    25â†’	}
    26â†’
    27â†’	return fmt.Sprintf(
    28â†’		"%d errors occurred:\n\t%s\n\n",
    29â†’		len(es), strings.Join(points, "\n\t"))
    30â†’}
group.go
     8â†’// Group is a collection of goroutines which return errors that need to be
     9â†’// coalesced.
    10â†’type Group struct {
    11â†’	mutex sync.Mutex
    12â†’	err   *Error
    13â†’	wg    sync.WaitGroup
    14â†’}
    16â†’// Go calls the given function in a new goroutine.
    17â†’//
    18â†’// If the function returns an error it is added to the group multierror which
    19â†’// is returned by Wait.
    20â†’func (g *Group) Go(f func() error) {
    21â†’	g.wg.Add(1)
    22â†’
    23â†’	go func() {
    24â†’		defer g.wg.Done()
    25â†’
    26â†’		if err := f(); err != nil {
    27â†’			g.mutex.Lock()
    28â†’			g.err = Append(g.err, err)
    29â†’			g.mutex.Unlock()
    30â†’		}
    31â†’	}()
    32â†’}
    34â†’// Wait blocks until all function calls from the Go method have returned, then
    35â†’// returns the multierror.
    36â†’func (g *Group) Wait() *Error {
    37â†’	g.wg.Wait()
    38â†’	g.mutex.Lock()
    39â†’	defer g.mutex.Unlock()
    40â†’	return g.err
    41â†’}
multierror.go
    11â†’// Error is an error type to track multiple errors. This is used to
    12â†’// accumulate errors in cases and return them as a single "error".
    13â†’type Error struct {
    14â†’	Errors      []error
    15â†’	ErrorFormat ErrorFormatFunc
    16â†’}
    18â†’func (e *Error) Error() string {
    19â†’	fn := e.ErrorFormat
    20â†’	if fn == nil {
    21â†’		fn = ListFormatFunc
    22â†’	}
    23â†’
    24â†’	return fn(e.Errors)
    25â†’}
    27â†’// ErrorOrNil returns an error interface if this Error represents
    28â†’// a list of errors, or returns nil if the list of errors is empty. This
    29â†’// function is useful at the end of accumulation to make sure that the value
    30â†’// returned represents the existence of errors.
    31â†’func (e *Error) ErrorOrNil() error {
    32â†’	if e == nil {
    33â†’		return nil
    34â†’	}
    35â†’	if len(e.Errors) == 0 {
    36â†’		return nil
    37â†’	}
    38â†’
    39â†’	return e
    40â†’}
    42â†’func (e *Error) GoString() string {
    43â†’	return fmt.Sprintf("*%#v", *e)
    44â†’}
    46â†’// WrappedErrors returns the list of errors that this Error is wrapping. It is
    47â†’// an implementation of the errwrap.Wrapper interface so that multierror.Error
    48â†’// can be used with that library.
    49â†’//
    50â†’// This method is not safe to be called concurrently. Unlike accessing the
    51â†’// Errors field directly, this function also checks if the multierror is nil to
    52â†’// prevent a null-pointer panic. It satisfies the errwrap.Wrapper interface.
    53â†’func (e *Error) WrappedErrors() []error {
    54â†’	if e == nil {
    55â†’		return nil
    56â†’	}
    57â†’	return e.Errors
    58â†’}
    60â†’// Unwrap returns an error from Error (or nil if there are no errors).
    61â†’// This error returned will further support Unwrap to get the next error,
    62â†’// etc. The order will match the order of Errors in the multierror.Error
    63â†’// at the time of calling.
    64â†’//
    65â†’// The resulting error supports errors.As/Is/Unwrap so you can continue
    66â†’// to use the stdlib errors package to introspect further.
    67â†’//
    68â†’// This will perform a shallow copy of the errors slice. Any errors appended
    69â†’// to this error after calling Unwrap will not be available until a new
    70â†’// Unwrap is called on the multierror.Error.
    71â†’func (e *Error) Unwrap() error {
    72â†’	// If we have no errors then we do nothing
    73â†’	if e == nil || len(e.Errors) == 0 {
    74â†’		return nil
    75â†’	}
    76â†’
    77â†’	// If we have exactly one error, we can just return that directly.
    78â†’	if len(e.Errors) == 1 {
    79â†’		return e.Errors[0]
    80â†’	}
    81â†’
    82â†’	// Shallow copy the slice
    83â†’	errs := make([]error, len(e.Errors))
    84â†’	copy(errs, e.Errors)
    85â†’	return chain(errs)
    86â†’}
    88â†’// chain implements the interfaces necessary for errors.Is/As/Unwrap to
    89â†’// work in a deterministic way with multierror. A chain tracks a list of
    90â†’// errors while accounting for the current represented error. This lets
    91â†’// Is/As be meaningful.
    92â†’//
    93â†’// Unwrap returns the next error. In the cleanest form, Unwrap would return
    94â†’// the wrapped error here but we can't do that if we want to properly
    95â†’// get access to all the errors. Instead, users are recommended to use
    96â†’// Is/As to get the correct error type out.
    97â†’//
    98â†’// Precondition: []error is non-empty (len > 0)
    99â†’type chain []error
   101â†’// Error implements the error interface
   102â†’func (e chain) Error() string {
   103â†’	return e[0].Error()
   104â†’}
   106â†’// Unwrap implements errors.Unwrap by returning the next error in the
   107â†’// chain or nil if there are no more errors.
   108â†’func (e chain) Unwrap() error {
   109â†’	if len(e) == 1 {
   110â†’		return nil
   111â†’	}
   112â†’
   113â†’	return e[1:]
   114â†’}
   116â†’// As implements errors.As by attempting to map to the current value.
   117â†’func (e chain) As(target interface{}) bool {
   118â†’	return errors.As(e[0], target)
   119â†’}
   121â†’// Is implements errors.Is by comparing the current value directly.
   122â†’func (e chain) Is(target error) bool {
   123â†’	return errors.Is(e[0], target)
   124â†’}
prefix.go
    10â†’// Prefix is a helper function that will prefix some text
    11â†’// to the given error. If the error is a multierror.Error, then
    12â†’// it will be prefixed to each wrapped error.
    13â†’//
    14â†’// This is useful to use when appending multiple multierrors
    15â†’// together in order to give better scoping.
    16â†’func Prefix(err error, prefix string) error {
    17â†’	if err == nil {
    18â†’		return nil
    19â†’	}
    20â†’
    21â†’	switch err := err.(type) {
    22â†’	case *Error:
    23â†’		// Typed nils can reach here, so initialize if we are nil
    24â†’		if err == nil {
    25â†’			err = new(Error)
    26â†’		}
    27â†’
    28â†’		// Wrap each of the errors
    29â†’		for i, e := range err.Errors {
    30â†’			err.Errors[i] = fmt.Errorf("%s %s", prefix, e)
    31â†’		}
    32â†’
    33â†’		return err
    34â†’	default:
    35â†’		return fmt.Errorf("%s %s", prefix, err)
    36â†’	}
    37â†’}
sort.go
     6â†’// Len implements sort.Interface function for length
     7â†’func (err *Error) Len() int {
     8â†’	if err == nil {
     9â†’		return 0
    10â†’	}
    11â†’
    12â†’	return len(err.Errors)
    13â†’}
    15â†’// Swap implements sort.Interface function for swapping elements
    16â†’func (err Error) Swap(i, j int) {
    17â†’	err.Errors[i], err.Errors[j] = err.Errors[j], err.Errors[i]
    18â†’}
    20â†’// Less implements sort.Interface function for determining order
    21â†’func (err Error) Less(i, j int) bool {
    22â†’	return err.Errors[i].Error() < err.Errors[j].Error()
    23â†’}

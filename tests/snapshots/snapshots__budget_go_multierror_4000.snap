multierror.go
     6ÔåÆimport (
     7ÔåÆ	"errors"
     8ÔåÆ	"fmt"
     9ÔåÆ)
    11ÔåÆ// Error is an error type to track multiple errors. This is used to
    12ÔåÆ// accumulate errors in cases and return them as a single "error".
    13ÔåÆtype Error struct {
    14ÔåÆ	Errors      []error
    15ÔåÆ	ErrorFormat ErrorFormatFunc
    16ÔåÆ}
    18ÔåÆfunc (e *Error) Error() string {
    19ÔåÆ	fn := e.ErrorFormat
    20ÔåÆ	if fn == nil {
    21ÔåÆ		fn = ListFormatFunc
    22ÔåÆ	}
    23ÔåÆ
    24ÔåÆ	return fn(e.Errors)
    25ÔåÆ}
    27ÔåÆ// ErrorOrNil returns an error interface if this Error represents
    28ÔåÆ// a list of errors, or returns nil if the list of errors is empty. This
    29ÔåÆ// function is useful at the end of accumulation to make sure that the value
    30ÔåÆ// returned represents the existence of errors.
    31ÔåÆfunc (e *Error) ErrorOrNil() error {
    32ÔåÆ	if e == nil {
    33ÔåÆ		return nil
    34ÔåÆ	}
    35ÔåÆ	if len(e.Errors) == 0 {
    36ÔåÆ		return nil
    37ÔåÆ	}
    38ÔåÆ
    39ÔåÆ	return e
    40ÔåÆ}
    42ÔåÆfunc (e *Error) GoString() string {
    43ÔåÆ	return fmt.Sprintf("*%#v", *e)
    44ÔåÆ}
    46ÔåÆ// WrappedErrors returns the list of errors that this Error is wrapping. It is
    47ÔåÆ// an implementation of the errwrap.Wrapper interface so that multierror.Error
    48ÔåÆ// can be used with that library.
    49ÔåÆ//
    50ÔåÆ// This method is not safe to be called concurrently. Unlike accessing the
    51ÔåÆ// Errors field directly, this function also checks if the multierror is nil to
    52ÔåÆ// prevent a null-pointer panic. It satisfies the errwrap.Wrapper interface.
    53ÔåÆfunc (e *Error) WrappedErrors() []error {
    54ÔåÆ	if e == nil {
    55ÔåÆ		return nil
    56ÔåÆ	}
    57ÔåÆ	return e.Errors
    58ÔåÆ}
    60ÔåÆ// Unwrap returns an error from Error (or nil if there are no errors).
    61ÔåÆ// This error returned will further support Unwrap to get the next error,
    62ÔåÆ// etc. The order will match the order of Errors in the multierror.Error
    63ÔåÆ// at the time of calling.
    64ÔåÆ//
    65ÔåÆ// The resulting error supports errors.As/Is/Unwrap so you can continue
    66ÔåÆ// to use the stdlib errors package to introspect further.
    67ÔåÆ//
    68ÔåÆ// This will perform a shallow copy of the errors slice. Any errors appended
    69ÔåÆ// to this error after calling Unwrap will not be available until a new
    70ÔåÆ// Unwrap is called on the multierror.Error.
    71ÔåÆfunc (e *Error) Unwrap() error {
    72ÔåÆ	// If we have no errors then we do nothing
    73ÔåÆ	if e == nil || len(e.Errors) == 0 {
    74ÔåÆ		return nil
    75ÔåÆ	}
    76ÔåÆ
    77ÔåÆ	// If we have exactly one error, we can just return that directly.
    78ÔåÆ	if len(e.Errors) == 1 {
    79ÔåÆ		return e.Errors[0]
    80ÔåÆ	}
    81ÔåÆ
    82ÔåÆ	// Shallow copy the slice
      ÔåÆÔÇĞ
    88ÔåÆ// chain implements the interfaces necessary for errors.Is/As/Unwrap to
    89ÔåÆ// work in a deterministic way with multierror. A chain tracks a list of
    90ÔåÆ// errors while accounting for the current represented error. This lets
    91ÔåÆ// Is/As be meaningful.
    92ÔåÆ//
    93ÔåÆ// Unwrap returns the next error. In the cleanest form, Unwrap would return
    94ÔåÆ// the wrapped error here but we can't do that if we want to properly
    95ÔåÆ// get access to all the errors. Instead, users are recommended to use
    96ÔåÆ// Is/As to get the correct error type out.
    97ÔåÆ//
    98ÔåÆ// Precondition: []error is non-empty (len > 0)
    99ÔåÆtype chain []error
   101ÔåÆ// Error implements the error interface
   102ÔåÆfunc (e chain) Error() string {
   103ÔåÆ	return e[0].Error()
   104ÔåÆ}
   106ÔåÆ// Unwrap implements errors.Unwrap by returning the next error in the
   107ÔåÆ// chain or nil if there are no more errors.
   108ÔåÆfunc (e chain) Unwrap() error {
   109ÔåÆ	if len(e) == 1 {
   110ÔåÆ		return nil
   111ÔåÆ	}
   112ÔåÆ
   113ÔåÆ	return e[1:]
   114ÔåÆ}
   116ÔåÆ// As implements errors.As by attempting to map to the current value.
   117ÔåÆfunc (e chain) As(target interface{}) bool {
   118ÔåÆ	return errors.As(e[0], target)
   119ÔåÆ}
   121ÔåÆ// Is implements errors.Is by comparing the current value directly.
   122ÔåÆfunc (e chain) Is(target error) bool {
   123ÔåÆ	return errors.Is(e[0], target)
   124ÔåÆ}


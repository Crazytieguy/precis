    13‚Üífunc TestFlatten(t *testing.T) {
    14‚Üí	original := &Error{
    15‚Üí		Errors: []error{
    16‚Üí			errors.New("one"),
    17‚Üí			&Error{
    18‚Üí				Errors: []error{
    19‚Üí					errors.New("two"),
    20‚Üí					&Error{
    21‚Üí						Errors: []error{
    22‚Üí							errors.New("three"),
    23‚Üí						},
    24‚Üí					},
    25‚Üí				},
    26‚Üí			},
    27‚Üí		},
    28‚Üí	}
    29‚Üí
    30‚Üí	expected := `3 errors occurred:
    31‚Üí	* one
    32‚Üí	* two
    33‚Üí	* three
    34‚Üí
    35‚Üí`
    36‚Üí	actual := fmt.Sprintf("%s", Flatten(original))
    37‚Üí
    38‚Üí	if expected != actual {
    39‚Üí		t.Fatalf("expected: %s, got: %s", expected, actual)
    40‚Üí	}
    41‚Üí}
    43‚Üífunc TestFlatten_nonError(t *testing.T) {
    44‚Üí	err := errors.New("foo")
    45‚Üí	actual := Flatten(err)
    46‚Üí	if !reflect.DeepEqual(actual, err) {
    47‚Üí		t.Fatalf("bad: %#v", actual)
    48‚Üí	}
    49‚Üí}

format.go
     6‚Üíimport (
     7‚Üí	"fmt"
     8‚Üí	"strings"
     9‚Üí)
    11‚Üí// ErrorFormatFunc is a function callback that is called by Error to
    12‚Üí// turn the list of errors into a string.
    13‚Üítype ErrorFormatFunc func([]error) string
    15‚Üí// ListFormatFunc is a basic formatter that outputs the number of errors
    16‚Üí// that occurred along with a bullet point list of the errors.
    17‚Üífunc ListFormatFunc(es []error) string {
    18‚Üí	if len(es) == 1 {
    19‚Üí		return fmt.Sprintf("1 error occurred:\n\t* %s\n\n", es[0])
    20‚Üí	}
    21‚Üí
    22‚Üí	points := make([]string, len(es))
    23‚Üí	for i, err := range es {
    24‚Üí		points[i] = fmt.Sprintf("* %s", err)
    25‚Üí	}
    26‚Üí
    27‚Üí	return fmt.Sprintf(
    28‚Üí		"%d errors occurred:\n\t%s\n\n",
    29‚Üí		len(es), strings.Join(points, "\n\t"))
    30‚Üí}


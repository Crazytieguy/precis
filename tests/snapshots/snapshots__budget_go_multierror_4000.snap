group.go
     6ŌåÆimport "sync"
     8ŌåÆ// Group is a collection of goroutines which return errors that need to be
     9ŌåÆ// coalesced.
    10ŌåÆtype Group struct {
    11ŌåÆ	mutex sync.Mutex
    12ŌåÆ	err   *Error
    13ŌåÆ	wg    sync.WaitGroup
    14ŌåÆ}
    16ŌåÆ// Go calls the given function in a new goroutine.
    17ŌåÆ//
    18ŌåÆ// If the function returns an error it is added to the group multierror which
    19ŌåÆ// is returned by Wait.
    20ŌåÆfunc (g *Group) Go(f func() error) {
    21ŌåÆ	g.wg.Add(1)
    22ŌåÆ
    23ŌåÆ	go func() {
    24ŌåÆ		defer g.wg.Done()
    25ŌåÆ
    26ŌåÆ		if err := f(); err != nil {
    27ŌåÆ			g.mutex.Lock()
    28ŌåÆ			g.err = Append(g.err, err)
    29ŌåÆ			g.mutex.Unlock()
    30ŌåÆ		}
    31ŌåÆ	}()
    32ŌåÆ}
    34ŌåÆ// Wait blocks until all function calls from the Go method have returned, then
    35ŌåÆ// returns the multierror.
    36ŌåÆfunc (g *Group) Wait() *Error {
    37ŌåÆ	g.wg.Wait()
    38ŌåÆ	g.mutex.Lock()
    39ŌåÆ	defer g.mutex.Unlock()
    40ŌåÆ	return g.err
    41ŌåÆ}


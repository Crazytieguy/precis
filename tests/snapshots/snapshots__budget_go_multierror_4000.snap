group.go
     6ÔåÆimport "sync"
     8ÔåÆ// Group is a collection of goroutines which return errors that need to be
     9ÔåÆ// coalesced.
    10ÔåÆtype Group struct {
    11ÔåÆ	mutex sync.Mutex
    12ÔåÆ	err   *Error
    13ÔåÆ	wg    sync.WaitGroup
    14ÔåÆ}
    16ÔåÆ// Go calls the given function in a new goroutine.
    17ÔåÆ//
    18ÔåÆ// If the function returns an error it is added to the group multierror which
    19ÔåÆ// is returned by Wait.
    20ÔåÆfunc (g *Group) Go(f func() error) {
    21ÔåÆ	g.wg.Add(1)
    22ÔåÆ
    23ÔåÆ	go func() {
    24ÔåÆ		defer g.wg.Done()
    25ÔåÆ
    26ÔåÆ		if err := f(); err != nil {
    27ÔåÆ			g.mutex.Lock()
    28ÔåÆ			g.err = Append(g.err, err)
    29ÔåÆ			g.mutex.Unlock()
    30ÔåÆ		}
    31ÔåÆ	}()
      ÔåÆÔÇĞ
    34ÔåÆ// Wait blocks until all function calls from the Go method have returned, then
    35ÔåÆ// returns the multierror.
    36ÔåÆfunc (g *Group) Wait() *Error {
    37ÔåÆ	g.wg.Wait()
    38ÔåÆ	g.mutex.Lock()
    39ÔåÆ	defer g.mutex.Unlock()
    40ÔåÆ	return g.err
    41ÔåÆ}


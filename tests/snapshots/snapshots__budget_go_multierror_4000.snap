sort.go
     6ÔåÆ// Len implements sort.Interface function for length
     7ÔåÆfunc (err *Error) Len() int {
     8ÔåÆ	if err == nil {
     9ÔåÆ		return 0
    10ÔåÆ	}
    11ÔåÆ
    12ÔåÆ	return len(err.Errors)
    13ÔåÆ}
    15ÔåÆ// Swap implements sort.Interface function for swapping elements
    16ÔåÆfunc (err Error) Swap(i, j int) {
    17ÔåÆ	err.Errors[i], err.Errors[j] = err.Errors[j], err.Errors[i]
    18ÔåÆ}
    20ÔåÆ// Less implements sort.Interface function for determining order
    21ÔåÆfunc (err Error) Less(i, j int) bool {
    22ÔåÆ	return err.Errors[i].Error() < err.Errors[j].Error()
    23ÔåÆ}


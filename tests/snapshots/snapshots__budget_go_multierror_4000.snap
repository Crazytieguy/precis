group.go
     6Ôćĺimport "sync"
     8Ôćĺ// Group is a collection of goroutines which return errors that need to be
     9Ôćĺ// coalesced.
    10Ôćĺtype Group struct {
    11Ôćĺ	mutex sync.Mutex
    12Ôćĺ	err   *Error
    13Ôćĺ	wg    sync.WaitGroup
    14Ôćĺ}
    16Ôćĺ// Go calls the given function in a new goroutine.
    17Ôćĺ//
    18Ôćĺ// If the function returns an error it is added to the group multierror which
    19Ôćĺ// is returned by Wait.
    20Ôćĺfunc (g *Group) Go(f func() error) {
    21Ôćĺ	g.wg.Add(1)
    22Ôćĺ
    23Ôćĺ	go func() {
    24Ôćĺ		defer g.wg.Done()
    25Ôćĺ
    26Ôćĺ		if err := f(); err != nil {
    27Ôćĺ			g.mutex.Lock()
    28Ôćĺ			g.err = Append(g.err, err)
    29Ôćĺ			g.mutex.Unlock()
    30Ôćĺ		}
    31Ôćĺ	}()
      ÔćĺÔÇŽ
    34Ôćĺ// Wait blocks until all function calls from the Go method have returned, then
    35Ôćĺ// returns the multierror.
    36Ôćĺfunc (g *Group) Wait() *Error {
    37Ôćĺ	g.wg.Wait()
    38Ôćĺ	g.mutex.Lock()
    39Ôćĺ	defer g.mutex.Unlock()
    40Ôćĺ	return g.err
    41Ôćĺ}


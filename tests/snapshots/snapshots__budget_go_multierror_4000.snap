    11‚Üífunc TestAppend_Error(t *testing.T) {
    12‚Üí	original := &Error{
    13‚Üí		Errors: []error{errors.New("foo")},
    14‚Üí	}
    15‚Üí
    16‚Üí	result := Append(original, errors.New("bar"))
    17‚Üí	if len(result.Errors) != 2 {
    18‚Üí		t.Fatalf("wrong len: %d", len(result.Errors))
    19‚Üí	}
    20‚Üí
    21‚Üí	original = &Error{}
    22‚Üí	result = Append(original, errors.New("bar"))
    23‚Üí	if len(result.Errors) != 1 {
    24‚Üí		t.Fatalf("wrong len: %d", len(result.Errors))
    25‚Üí	}
    26‚Üí
    27‚Üí	// Test when a typed nil is passed
    28‚Üí	var e *Error
    29‚Üí	result = Append(e, errors.New("baz"))
    30‚Üí	if len(result.Errors) != 1 {
    31‚Üí		t.Fatalf("wrong len: %d", len(result.Errors))
    32‚Üí	}
    33‚Üí
    34‚Üí	// Test flattening
    35‚Üí	original = &Error{
    36‚Üí		Errors: []error{errors.New("foo")},
    37‚Üí	}
    38‚Üí
    39‚Üí	result = Append(original, Append(nil, errors.New("foo"), errors.New("bar")))
    40‚Üí	if len(result.Errors) != 3 {
    41‚Üí		t.Fatalf("wrong len: %d", len(result.Errors))
    42‚Üí	}
    43‚Üí}

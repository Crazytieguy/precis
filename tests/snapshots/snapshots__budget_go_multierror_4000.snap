     6ŌåÆ// Len implements sort.Interface function for length
     7ŌåÆfunc (err *Error) Len() int {
     8ŌåÆ	if err == nil {
     9ŌåÆ		return 0
    10ŌåÆ	}
    11ŌåÆ

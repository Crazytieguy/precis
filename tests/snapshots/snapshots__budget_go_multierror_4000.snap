    19→		return fmt.Sprintf("1 error occurred:\n\t* %s\n\n", es[0])
    20→	}
    21→
    22→	points := make([]string, len(es))
    23→	for i, err := range es {
    24→		points[i] = fmt.Sprintf("* %s", err)
    25→	}
    26→

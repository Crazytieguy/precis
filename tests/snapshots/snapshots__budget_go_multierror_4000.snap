     6ŌåÆimport (
     7ŌåÆ	"fmt"
     8ŌåÆ)
    10ŌåÆ// Prefix is a helper function that will prefix some text
    11ŌåÆ// to the given error. If the error is a multierror.Error, then
    12ŌåÆ// it will be prefixed to each wrapped error.
    13ŌåÆ//
    14ŌåÆ// This is useful to use when appending multiple multierrors
    15ŌåÆ// together in order to give better scoping.
    16ŌåÆfunc Prefix(err error, prefix string) error {
    17ŌåÆ	if err == nil {
    18ŌåÆ		return nil
    19ŌåÆ	}
    20ŌåÆ
    21ŌåÆ	switch err := err.(type) {
    22ŌåÆ	case *Error:
    23ŌåÆ		// Typed nils can reach here, so initialize if we are nil
    24ŌåÆ		if err == nil {
    25ŌåÆ			err = new(Error)
    26ŌåÆ		}
    27ŌåÆ
    28ŌåÆ		// Wrap each of the errors
    29ŌåÆ		for i, e := range err.Errors {
    30ŌåÆ			err.Errors[i] = fmt.Errorf("%s %s", prefix, e)
    31ŌåÆ		}
    32ŌåÆ
    33ŌåÆ		return err
    34ŌåÆ	default:
    35ŌåÆ		return fmt.Errorf("%s %s", prefix, err)
    36ŌåÆ	}
    37ŌåÆ}


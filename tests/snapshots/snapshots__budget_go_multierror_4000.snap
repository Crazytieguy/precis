flatten.go
     6‚Üí// Flatten flattens the given error, merging any *Errors together into
     7‚Üí// a single *Error.
     8‚Üífunc Flatten(err error) error {
     9‚Üí	// If it isn't an *Error, just return the error as-is
    10‚Üí	if _, ok := err.(*Error); !ok {
    11‚Üí		return err
    12‚Üí	}
    13‚Üí
    14‚Üí	// Otherwise, make the result and flatten away!
    15‚Üí	flatErr := new(Error)
    16‚Üí	flatten(err, flatErr)
    17‚Üí	return flatErr
    18‚Üí}
    20‚Üífunc flatten(err error, flatErr *Error) {
    21‚Üí	switch err := err.(type) {
    22‚Üí	case *Error:
    23‚Üí		for _, e := range err.Errors {
    24‚Üí			flatten(e, flatErr)
    25‚Üí		}
    26‚Üí	default:
    27‚Üí		flatErr.Errors = append(flatErr.Errors, err)
    28‚Üí	}
    29‚Üí}


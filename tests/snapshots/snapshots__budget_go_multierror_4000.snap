    11Ôćĺ// Error is an error type to track multiple errors. This is used to
    12Ôćĺ// accumulate errors in cases and return them as a single "error".
    13Ôćĺtype Error struct {
    14Ôćĺ	Errors      []error
    15Ôćĺ	ErrorFormat ErrorFormatFunc
    16Ôćĺ}
    18Ôćĺfunc (e *Error) Error() string {
    19Ôćĺ	fn := e.ErrorFormat
    20Ôćĺ	if fn == nil {
    21Ôćĺ		fn = ListFormatFunc
    22Ôćĺ	}
    23Ôćĺ
    24Ôćĺ	return fn(e.Errors)
    25Ôćĺ}
    27Ôćĺ// ErrorOrNil returns an error interface if this Error represents
    28Ôćĺ// a list of errors, or returns nil if the list of errors is empty. This
    29Ôćĺ// function is useful at the end of accumulation to make sure that the value
    30Ôćĺ// returned represents the existence of errors.
    31Ôćĺfunc (e *Error) ErrorOrNil() error {
    32Ôćĺ	if e == nil {
    33Ôćĺ		return nil
    34Ôćĺ	}
    35Ôćĺ	if len(e.Errors) == 0 {
    36Ôćĺ		return nil
    37Ôćĺ	}
    38Ôćĺ
    39Ôćĺ	return e
    40Ôćĺ}
    42Ôćĺfunc (e *Error) GoString() string {
    43Ôćĺ	return fmt.Sprintf("*%#v", *e)
    44Ôćĺ}
    46Ôćĺ// WrappedErrors returns the list of errors that this Error is wrapping. It is
    47Ôćĺ// an implementation of the errwrap.Wrapper interface so that multierror.Error
    48Ôćĺ// can be used with that library.
    49Ôćĺ//
    50Ôćĺ// This method is not safe to be called concurrently. Unlike accessing the
    51Ôćĺ// Errors field directly, this function also checks if the multierror is nil to
    52Ôćĺ// prevent a null-pointer panic. It satisfies the errwrap.Wrapper interface.
    53Ôćĺfunc (e *Error) WrappedErrors() []error {
    54Ôćĺ	if e == nil {
    55Ôćĺ		return nil
    56Ôćĺ	}
    57Ôćĺ	return e.Errors
    58Ôćĺ}
    60Ôćĺ// Unwrap returns an error from Error (or nil if there are no errors).
    61Ôćĺ// This error returned will further support Unwrap to get the next error,
    62Ôćĺ// etc. The order will match the order of Errors in the multierror.Error
    63Ôćĺ// at the time of calling.
    64Ôćĺ//
    65Ôćĺ// The resulting error supports errors.As/Is/Unwrap so you can continue
    66Ôćĺ// to use the stdlib errors package to introspect further.
    67Ôćĺ//
    68Ôćĺ// This will perform a shallow copy of the errors slice. Any errors appended
    69Ôćĺ// to this error after calling Unwrap will not be available until a new
    70Ôćĺ// Unwrap is called on the multierror.Error.
    71Ôćĺfunc (e *Error) Unwrap() error {
    72Ôćĺ	// If we have no errors then we do nothing
    73Ôćĺ	if e == nil || len(e.Errors) == 0 {
    74Ôćĺ		return nil
    75Ôćĺ	}
    76Ôćĺ
    77Ôćĺ	// If we have exactly one error, we can just return that directly.
    78Ôćĺ	if len(e.Errors) == 1 {
    79Ôćĺ		return e.Errors[0]
    80Ôćĺ	}
    81Ôćĺ
    82Ôćĺ	// Shallow copy the slice
      ÔćĺÔÇŽ
    88Ôćĺ// chain implements the interfaces necessary for errors.Is/As/Unwrap to
    89Ôćĺ// work in a deterministic way with multierror. A chain tracks a list of
    90Ôćĺ// errors while accounting for the current represented error. This lets
    91Ôćĺ// Is/As be meaningful.
    92Ôćĺ//
    93Ôćĺ// Unwrap returns the next error. In the cleanest form, Unwrap would return
    94Ôćĺ// the wrapped error here but we can't do that if we want to properly
    95Ôćĺ// get access to all the errors. Instead, users are recommended to use
    96Ôćĺ// Is/As to get the correct error type out.
    97Ôćĺ//
    98Ôćĺ// Precondition: []error is non-empty (len > 0)
    99Ôćĺtype chain []error
   101Ôćĺ// Error implements the error interface
   102Ôćĺfunc (e chain) Error() string {
   103Ôćĺ	return e[0].Error()
   104Ôćĺ}
   106Ôćĺ// Unwrap implements errors.Unwrap by returning the next error in the
   107Ôćĺ// chain or nil if there are no more errors.
   108Ôćĺfunc (e chain) Unwrap() error {
   109Ôćĺ	if len(e) == 1 {
   110Ôćĺ		return nil
   111Ôćĺ	}
   112Ôćĺ
   113Ôćĺ	return e[1:]
   114Ôćĺ}
   116Ôćĺ// As implements errors.As by attempting to map to the current value.
   117Ôćĺfunc (e chain) As(target interface{}) bool {
   118Ôćĺ	return errors.As(e[0], target)
   119Ôćĺ}
   121Ôćĺ// Is implements errors.Is by comparing the current value directly.
   122Ôćĺfunc (e chain) Is(target error) bool {
   123Ôćĺ	return errors.Is(e[0], target)
   124Ôćĺ}


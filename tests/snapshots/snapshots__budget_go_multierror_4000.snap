     6ŌåÆimport (
     7ŌåÆ	"errors"
     8ŌåÆ	"fmt"
     9ŌåÆ)
    11ŌåÆ// Error is an error type to track multiple errors. This is used to
    12ŌåÆ// accumulate errors in cases and return them as a single "error".
    13ŌåÆtype Error struct {
    14ŌåÆ	Errors      []error
    15ŌåÆ	ErrorFormat ErrorFormatFunc
    16ŌåÆ}
    18ŌåÆfunc (e *Error) Error() string {
    19ŌåÆ	fn := e.ErrorFormat
    20ŌåÆ	if fn == nil {
    21ŌåÆ		fn = ListFormatFunc
    22ŌåÆ	}
    23ŌåÆ
    24ŌåÆ	return fn(e.Errors)
    25ŌåÆ}
    27ŌåÆ// ErrorOrNil returns an error interface if this Error represents
    28ŌåÆ// a list of errors, or returns nil if the list of errors is empty. This
    29ŌåÆ// function is useful at the end of accumulation to make sure that the value
    30ŌåÆ// returned represents the existence of errors.
    31ŌåÆfunc (e *Error) ErrorOrNil() error {
    32ŌåÆ	if e == nil {
    33ŌåÆ		return nil
    34ŌåÆ	}
    35ŌåÆ	if len(e.Errors) == 0 {
    36ŌåÆ		return nil
    37ŌåÆ	}
    38ŌåÆ
    39ŌåÆ	return e
    40ŌåÆ}
    42ŌåÆfunc (e *Error) GoString() string {
    43ŌåÆ	return fmt.Sprintf("*%#v", *e)
    44ŌåÆ}
    46ŌåÆ// WrappedErrors returns the list of errors that this Error is wrapping. It is
    47ŌåÆ// an implementation of the errwrap.Wrapper interface so that multierror.Error
    48ŌåÆ// can be used with that library.
    49ŌåÆ//
    50ŌåÆ// This method is not safe to be called concurrently. Unlike accessing the
    51ŌåÆ// Errors field directly, this function also checks if the multierror is nil to
    52ŌåÆ// prevent a null-pointer panic. It satisfies the errwrap.Wrapper interface.
    53ŌåÆfunc (e *Error) WrappedErrors() []error {
    54ŌåÆ	if e == nil {
    55ŌåÆ		return nil
    56ŌåÆ	}
    57ŌåÆ	return e.Errors
    58ŌåÆ}
    60ŌåÆ// Unwrap returns an error from Error (or nil if there are no errors).
    61ŌåÆ// This error returned will further support Unwrap to get the next error,
    62ŌåÆ// etc. The order will match the order of Errors in the multierror.Error
    63ŌåÆ// at the time of calling.
    64ŌåÆ//
    65ŌåÆ// The resulting error supports errors.As/Is/Unwrap so you can continue
    66ŌåÆ// to use the stdlib errors package to introspect further.
    67ŌåÆ//
    68ŌåÆ// This will perform a shallow copy of the errors slice. Any errors appended
    69ŌåÆ// to this error after calling Unwrap will not be available until a new
    70ŌåÆ// Unwrap is called on the multierror.Error.
    71ŌåÆfunc (e *Error) Unwrap() error {
    72ŌåÆ	// If we have no errors then we do nothing
    73ŌåÆ	if e == nil || len(e.Errors) == 0 {
    74ŌåÆ		return nil
    75ŌåÆ	}
    76ŌåÆ
    77ŌåÆ	// If we have exactly one error, we can just return that directly.
    78ŌåÆ	if len(e.Errors) == 1 {
    79ŌåÆ		return e.Errors[0]
    80ŌåÆ	}
    81ŌåÆ
    82ŌåÆ	// Shallow copy the slice
    83ŌåÆ	errs := make([]error, len(e.Errors))
    84ŌåÆ	copy(errs, e.Errors)
    85ŌåÆ	return chain(errs)
    86ŌåÆ}
    88ŌåÆ// chain implements the interfaces necessary for errors.Is/As/Unwrap to
      ŌåÆŌĆ”
    99ŌåÆtype chain []error
   101ŌåÆ// Error implements the error interface
   102ŌåÆfunc (e chain) Error() string {
   103ŌåÆ	return e[0].Error()
   104ŌåÆ}
   106ŌåÆ// Unwrap implements errors.Unwrap by returning the next error in the
   107ŌåÆ// chain or nil if there are no more errors.
   108ŌåÆfunc (e chain) Unwrap() error {
   109ŌåÆ	if len(e) == 1 {
   110ŌåÆ		return nil
   111ŌåÆ	}
   112ŌåÆ
   113ŌåÆ	return e[1:]
   114ŌåÆ}
   116ŌåÆ// As implements errors.As by attempting to map to the current value.
   117ŌåÆfunc (e chain) As(target interface{}) bool {
   118ŌåÆ	return errors.As(e[0], target)
   119ŌåÆ}
   121ŌåÆ// Is implements errors.Is by comparing the current value directly.
   122ŌåÆfunc (e chain) Is(target error) bool {
   123ŌåÆ	return errors.Is(e[0], target)
   124ŌåÆ}


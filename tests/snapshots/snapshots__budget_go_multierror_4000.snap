    15ŌåÆ// Swap implements sort.Interface function for swapping elements
    16ŌåÆfunc (err Error) Swap(i, j int) {
    17ŌåÆ	err.Errors[i], err.Errors[j] = err.Errors[j], err.Errors[i]
    18ŌåÆ}
    20ŌåÆ// Less implements sort.Interface function for determining order
    21ŌåÆfunc (err Error) Less(i, j int) bool {
    22ŌåÆ	return err.Errors[i].Error() < err.Errors[j].Error()
    23ŌåÆ}


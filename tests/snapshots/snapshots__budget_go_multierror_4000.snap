flatten.go
     6ŌåÆ// Flatten flattens the given error, merging any *Errors together into
     7ŌåÆ// a single *Error.
     8ŌåÆfunc Flatten(err error) error {
     9ŌåÆ	// If it isn't an *Error, just return the error as-is
    10ŌåÆ	if _, ok := err.(*Error); !ok {
    11ŌåÆ		return err
    12ŌåÆ	}
    13ŌåÆ
    14ŌåÆ	// Otherwise, make the result and flatten away!
    15ŌåÆ	flatErr := new(Error)
    16ŌåÆ	flatten(err, flatErr)
    17ŌåÆ	return flatErr
    18ŌåÆ}

append.go
     6ÔåÆ// Append is a helper function that will append more errors
     7ÔåÆ// onto an Error in order to create a larger multi-error.
     8ÔåÆ//
     9ÔåÆ// If err is not a multierror.Error, then it will be turned into
    10ÔåÆ// one. If any of the errs are multierr.Error, they will be flattened
    11ÔåÆ// one level into err.
    12ÔåÆ// Any nil errors within errs will be ignored. If err is nil, a new
    13ÔåÆ// *Error will be returned.
    14ÔåÆfunc Append(err error, errs ...error) *Error {
    15ÔåÆ	switch err := err.(type) {
    16ÔåÆ	case *Error:
    17ÔåÆ		// Typed nils can reach here, so initialize if we are nil
    18ÔåÆ		if err == nil {
    19ÔåÆ			err = new(Error)
    20ÔåÆ		}
    21ÔåÆ
    22ÔåÆ		// Go through each error and flatten
    23ÔåÆ		for _, e := range errs {
    24ÔåÆ			switch e := e.(type) {
    25ÔåÆ			case *Error:

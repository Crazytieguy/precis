sort.go
     6Ôćĺ// Len implements sort.Interface function for length
     7Ôćĺfunc (err *Error) Len() int {
     8Ôćĺ	if err == nil {
     9Ôćĺ		return 0
    10Ôćĺ	}
    11Ôćĺ
    12Ôćĺ	return len(err.Errors)
    13Ôćĺ}
    15Ôćĺ// Swap implements sort.Interface function for swapping elements
    16Ôćĺfunc (err Error) Swap(i, j int) {
    17Ôćĺ	err.Errors[i], err.Errors[j] = err.Errors[j], err.Errors[i]
    18Ôćĺ}
    20Ôćĺ// Less implements sort.Interface function for determining order
    21Ôćĺfunc (err Error) Less(i, j int) bool {
    22Ôćĺ	return err.Errors[i].Error() < err.Errors[j].Error()
    23Ôćĺ}


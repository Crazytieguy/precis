     6Ôćĺ// Append is a helper function that will append more errors
     7Ôćĺ// onto an Error in order to create a larger multi-error.
     8Ôćĺ//
     9Ôćĺ// If err is not a multierror.Error, then it will be turned into
    10Ôćĺ// one. If any of the errs are multierr.Error, they will be flattened
    11Ôćĺ// one level into err.
    12Ôćĺ// Any nil errors within errs will be ignored. If err is nil, a new
    13Ôćĺ// *Error will be returned.
    14Ôćĺfunc Append(err error, errs ...error) *Error {
    15Ôćĺ	switch err := err.(type) {
    16Ôćĺ	case *Error:
    17Ôćĺ		// Typed nils can reach here, so initialize if we are nil
    18Ôćĺ		if err == nil {
    19Ôćĺ			err = new(Error)
    20Ôćĺ		}
    21Ôćĺ
    22Ôćĺ		// Go through each error and flatten
    23Ôćĺ		for _, e := range errs {
    24Ôćĺ			switch e := e.(type) {

flatten.go
     6ÔåÆ// Flatten flattens the given error, merging any *Errors together into
     7ÔåÆ// a single *Error.
     8ÔåÆfunc Flatten(err error) error {
     9ÔåÆ	// If it isn't an *Error, just return the error as-is
    10ÔåÆ	if _, ok := err.(*Error); !ok {
    11ÔåÆ		return err
    12ÔåÆ	}
    13ÔåÆ
    14ÔåÆ	// Otherwise, make the result and flatten away!
    15ÔåÆ	flatErr := new(Error)
    16ÔåÆ	flatten(err, flatErr)
    17ÔåÆ	return flatErr
    18ÔåÆ}
    20ÔåÆfunc flatten(err error, flatErr *Error) {
    21ÔåÆ	switch err := err.(type) {
    22ÔåÆ	case *Error:
    23ÔåÆ		for _, e := range err.Errors {
    24ÔåÆ			flatten(e, flatErr)
    25ÔåÆ		}
    26ÔåÆ	default:
    27ÔåÆ		flatErr.Errors = append(flatErr.Errors, err)
    28ÔåÆ	}
    29ÔåÆ}


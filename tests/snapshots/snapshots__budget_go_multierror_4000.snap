    10ÔåÆ// Prefix is a helper function that will prefix some text
    11ÔåÆ// to the given error. If the error is a multierror.Error, then
    12ÔåÆ// it will be prefixed to each wrapped error.
    13ÔåÆ//
    14ÔåÆ// This is useful to use when appending multiple multierrors
    15ÔåÆ// together in order to give better scoping.
    16ÔåÆfunc Prefix(err error, prefix string) error {
    17ÔåÆ	if err == nil {
    18ÔåÆ		return nil
    19ÔåÆ	}
    20ÔåÆ
    21ÔåÆ	switch err := err.(type) {
    22ÔåÆ	case *Error:
    23ÔåÆ		// Typed nils can reach here, so initialize if we are nil
    24ÔåÆ		if err == nil {
    25ÔåÆ			err = new(Error)
    26ÔåÆ		}
    27ÔåÆ

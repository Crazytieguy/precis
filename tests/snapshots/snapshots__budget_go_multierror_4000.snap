flatten.go
     6Ôćĺ// Flatten flattens the given error, merging any *Errors together into
     7Ôćĺ// a single *Error.
     8Ôćĺfunc Flatten(err error) error {
     9Ôćĺ	// If it isn't an *Error, just return the error as-is
    10Ôćĺ	if _, ok := err.(*Error); !ok {
    11Ôćĺ		return err
    12Ôćĺ	}
    13Ôćĺ
    14Ôćĺ	// Otherwise, make the result and flatten away!
    15Ôćĺ	flatErr := new(Error)
    16Ôćĺ	flatten(err, flatErr)
    17Ôćĺ	return flatErr
    18Ôćĺ}
    20Ôćĺfunc flatten(err error, flatErr *Error) {
    21Ôćĺ	switch err := err.(type) {
    22Ôćĺ	case *Error:
    23Ôćĺ		for _, e := range err.Errors {
    24Ôćĺ			flatten(e, flatErr)
    25Ôćĺ		}
    26Ôćĺ	default:
    27Ôćĺ		flatErr.Errors = append(flatErr.Errors, err)
    28Ôćĺ	}
    29Ôćĺ}


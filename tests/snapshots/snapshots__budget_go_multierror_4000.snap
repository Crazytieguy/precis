     6ŌåÆimport (
     7ŌåÆ	"fmt"
     8ŌåÆ	"strings"
     9ŌåÆ)
    11ŌåÆ// ErrorFormatFunc is a function callback that is called by Error to
    12ŌåÆ// turn the list of errors into a string.
    13ŌåÆtype ErrorFormatFunc func([]error) string
    15ŌåÆ// ListFormatFunc is a basic formatter that outputs the number of errors
    16ŌåÆ// that occurred along with a bullet point list of the errors.
    17ŌåÆfunc ListFormatFunc(es []error) string {
    18ŌåÆ	if len(es) == 1 {
    19ŌåÆ		return fmt.Sprintf("1 error occurred:\n\t* %s\n\n", es[0])
    20ŌåÆ	}
    21ŌåÆ
    22ŌåÆ	points := make([]string, len(es))
    23ŌåÆ	for i, err := range es {
    24ŌåÆ		points[i] = fmt.Sprintf("* %s", err)
    25ŌåÆ	}
    26ŌåÆ
    27ŌåÆ	return fmt.Sprintf(
    28ŌåÆ		"%d errors occurred:\n\t%s\n\n",
    29ŌåÆ		len(es), strings.Join(points, "\n\t"))
    30ŌåÆ}


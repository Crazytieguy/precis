append.go
     6ŌåÆ// Append is a helper function that will append more errors
     7ŌåÆ// onto an Error in order to create a larger multi-error.
     8ŌåÆ//
     9ŌåÆ// If err is not a multierror.Error, then it will be turned into
    10ŌåÆ// one. If any of the errs are multierr.Error, they will be flattened
    11ŌåÆ// one level into err.
    12ŌåÆ// Any nil errors within errs will be ignored. If err is nil, a new
    13ŌåÆ// *Error will be returned.
    14ŌåÆfunc Append(err error, errs ...error) *Error {
    15ŌåÆ	switch err := err.(type) {
    16ŌåÆ	case *Error:
    17ŌåÆ		// Typed nils can reach here, so initialize if we are nil
    18ŌåÆ		if err == nil {
    19ŌåÆ			err = new(Error)
    20ŌåÆ		}
    21ŌåÆ
    22ŌåÆ		// Go through each error and flatten
    23ŌåÆ		for _, e := range errs {
    24ŌåÆ			switch e := e.(type) {
    25ŌåÆ			case *Error:
    26ŌåÆ				if e != nil {
    27ŌåÆ					err.Errors = append(err.Errors, e.Errors...)
    28ŌåÆ				}
    29ŌåÆ			default:
    30ŌåÆ				if e != nil {
    31ŌåÆ					err.Errors = append(err.Errors, e)
    32ŌåÆ				}
    33ŌåÆ			}
    34ŌåÆ		}
    35ŌåÆ
    36ŌåÆ		return err
    37ŌåÆ	default:
      ŌåÆ	ŌĆ”


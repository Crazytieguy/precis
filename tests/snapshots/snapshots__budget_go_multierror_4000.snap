group.go
     6‚Üíimport "sync"
     8‚Üí// Group is a collection of goroutines which return errors that need to be
     9‚Üí// coalesced.
    10‚Üítype Group struct {
    11‚Üí	mutex sync.Mutex
    12‚Üí	err   *Error
    13‚Üí	wg    sync.WaitGroup
    14‚Üí}
    16‚Üí// Go calls the given function in a new goroutine.
    17‚Üí//
    18‚Üí// If the function returns an error it is added to the group multierror which
    19‚Üí// is returned by Wait.
    20‚Üífunc (g *Group) Go(f func() error) {
    21‚Üí	g.wg.Add(1)
    22‚Üí
    23‚Üí	go func() {
    24‚Üí		defer g.wg.Done()
    25‚Üí
    26‚Üí		if err := f(); err != nil {
    27‚Üí			g.mutex.Lock()
    28‚Üí			g.err = Append(g.err, err)
    29‚Üí			g.mutex.Unlock()
    30‚Üí		}
    31‚Üí	}()
    32‚Üí}
    34‚Üí// Wait blocks until all function calls from the Go method have returned, then
    35‚Üí// returns the multierror.
    36‚Üífunc (g *Group) Wait() *Error {
    37‚Üí	g.wg.Wait()
    38‚Üí	g.mutex.Lock()
    39‚Üí	defer g.mutex.Unlock()
    40‚Üí	return g.err
    41‚Üí}

group_test.go
     6‚Üíimport (
     7‚Üí	"errors"
     8‚Üí	"strings"
     9‚Üí	"testing"
    10‚Üí)
    12‚Üífunc TestGroup(t *testing.T) {
    13‚Üí	err1 := errors.New("group_test: 1")
    14‚Üí	err2 := errors.New("group_test: 2")
    15‚Üí
    16‚Üí	cases := []struct {
    17‚Üí		errs      []error
    18‚Üí		nilResult bool
    19‚Üí	}{
    20‚Üí		{errs: []error{}, nilResult: true},
    21‚Üí		{errs: []error{nil}, nilResult: true},
    22‚Üí		{errs: []error{err1}},
    23‚Üí		{errs: []error{err1, nil}},
    24‚Üí		{errs: []error{err1, nil, err2}},
    25‚Üí	}
    26‚Üí
    27‚Üí	for _, tc := range cases {
    28‚Üí		var g Group
    29‚Üí
    30‚Üí		for _, err := range tc.errs {
    31‚Üí			err := err
    32‚Üí			g.Go(func() error { return err })
    33‚Üí
    34‚Üí		}
    35‚Üí
    36‚Üí		gErr := g.Wait()
    37‚Üí		if gErr != nil {
    38‚Üí			for i := range tc.errs {
    39‚Üí				if tc.errs[i] != nil && !strings.Contains(gErr.Error(), tc.errs[i].Error()) {
    40‚Üí					t.Fatalf("expected error to contain %q, actual: %v", tc.errs[i].Error(), gErr)
    41‚Üí				}
    42‚Üí			}
    43‚Üí		} else if !tc.nilResult {
    44‚Üí			t.Fatalf("Group.Wait() should not have returned nil for errs: %v", tc.errs)
    45‚Üí		}
    46‚Üí	}
    47‚Üí}

multierror.go
     6‚Üíimport (
     7‚Üí	"errors"
     8‚Üí	"fmt"
     9‚Üí)
    11‚Üí// Error is an error type to track multiple errors. This is used to
    12‚Üí// accumulate errors in cases and return them as a single "error".
    13‚Üítype Error struct {
    14‚Üí	Errors      []error
    15‚Üí	ErrorFormat ErrorFormatFunc
    16‚Üí}
    18‚Üífunc (e *Error) Error() string {
    19‚Üí	fn := e.ErrorFormat
    20‚Üí	if fn == nil {
    21‚Üí		fn = ListFormatFunc
    22‚Üí	}
    23‚Üí
    24‚Üí	return fn(e.Errors)
    25‚Üí}
    27‚Üí// ErrorOrNil returns an error interface if this Error represents
    28‚Üí// a list of errors, or returns nil if the list of errors is empty. This
    29‚Üí// function is useful at the end of accumulation to make sure that the value
    30‚Üí// returned represents the existence of errors.
    31‚Üífunc (e *Error) ErrorOrNil() error {
    32‚Üí	if e == nil {
    33‚Üí		return nil
    34‚Üí	}
    35‚Üí	if len(e.Errors) == 0 {
    36‚Üí		return nil
    37‚Üí	}
    38‚Üí
    39‚Üí	return e
    40‚Üí}
    42‚Üífunc (e *Error) GoString() string {
    43‚Üí	return fmt.Sprintf("*%#v", *e)
    44‚Üí}
    46‚Üí// WrappedErrors returns the list of errors that this Error is wrapping. It is
    47‚Üí// an implementation of the errwrap.Wrapper interface so that multierror.Error
    48‚Üí// can be used with that library.
    49‚Üí//
    50‚Üí// This method is not safe to be called concurrently. Unlike accessing the
    51‚Üí// Errors field directly, this function also checks if the multierror is nil to
    52‚Üí// prevent a null-pointer panic. It satisfies the errwrap.Wrapper interface.
    53‚Üífunc (e *Error) WrappedErrors() []error {
    54‚Üí	if e == nil {
    55‚Üí		return nil
    56‚Üí	}
    57‚Üí	return e.Errors
    58‚Üí}
    60‚Üí// Unwrap returns an error from Error (or nil if there are no errors).
    61‚Üí// This error returned will further support Unwrap to get the next error,
    62‚Üí// etc. The order will match the order of Errors in the multierror.Error
    63‚Üí// at the time of calling.
    64‚Üí//
    65‚Üí// The resulting error supports errors.As/Is/Unwrap so you can continue
    66‚Üí// to use the stdlib errors package to introspect further.
    67‚Üí//
    68‚Üí// This will perform a shallow copy of the errors slice. Any errors appended
    69‚Üí// to this error after calling Unwrap will not be available until a new
    70‚Üí// Unwrap is called on the multierror.Error.
    71‚Üífunc (e *Error) Unwrap() error {
    72‚Üí	// If we have no errors then we do nothing
    73‚Üí	if e == nil || len(e.Errors) == 0 {
    74‚Üí		return nil
    75‚Üí	}
    76‚Üí
    77‚Üí	// If we have exactly one error, we can just return that directly.
    78‚Üí	if len(e.Errors) == 1 {
    79‚Üí		return e.Errors[0]
    80‚Üí	}
    81‚Üí
    82‚Üí	// Shallow copy the slice
    83‚Üí	errs := make([]error, len(e.Errors))
    84‚Üí	copy(errs, e.Errors)
    85‚Üí	return chain(errs)
    86‚Üí}
    88‚Üí// chain implements the interfaces necessary for errors.Is/As/Unwrap to
    89‚Üí// work in a deterministic way with multierror. A chain tracks a list of
    90‚Üí// errors while accounting for the current represented error. This lets
    91‚Üí// Is/As be meaningful.
    92‚Üí//
    93‚Üí// Unwrap returns the next error. In the cleanest form, Unwrap would return
    94‚Üí// the wrapped error here but we can't do that if we want to properly
    95‚Üí// get access to all the errors. Instead, users are recommended to use
    96‚Üí// Is/As to get the correct error type out.
    97‚Üí//
    98‚Üí// Precondition: []error is non-empty (len > 0)
    99‚Üítype chain []error
   101‚Üí// Error implements the error interface
   102‚Üífunc (e chain) Error() string {
   103‚Üí	return e[0].Error()
   104‚Üí}
   106‚Üí// Unwrap implements errors.Unwrap by returning the next error in the
   107‚Üí// chain or nil if there are no more errors.
   108‚Üífunc (e chain) Unwrap() error {
   109‚Üí	if len(e) == 1 {
   110‚Üí		return nil
   111‚Üí	}
   112‚Üí
   113‚Üí	return e[1:]
   114‚Üí}
   116‚Üí// As implements errors.As by attempting to map to the current value.
   117‚Üífunc (e chain) As(target interface{}) bool {
   118‚Üí	return errors.As(e[0], target)
   119‚Üí}
   121‚Üí// Is implements errors.Is by comparing the current value directly.
   122‚Üífunc (e chain) Is(target error) bool {
   123‚Üí	return errors.Is(e[0], target)
   124‚Üí}

multierror_test.go
     6‚Üíimport (
     7‚Üí	"errors"
     8‚Üí	"fmt"
     9‚Üí	"reflect"
    10‚Üí	"testing"
    11‚Üí)
    13‚Üífunc TestError_Impl(t *testing.T) {
    14‚Üí	var _ error = new(Error)
    15‚Üí}
    17‚Üífunc TestErrorError_custom(t *testing.T) {
    18‚Üí	errors := []error{
    19‚Üí		errors.New("foo"),
    20‚Üí		errors.New("bar"),
    21‚Üí	}
    22‚Üí
    23‚Üí	fn := func(es []error) string {
    24‚Üí		return "foo"
    25‚Üí	}
    26‚Üí
    27‚Üí	multi := &Error{Errors: errors, ErrorFormat: fn}
    28‚Üí	if multi.Error() != "foo" {
    29‚Üí		t.Fatalf("bad: %s", multi.Error())
    30‚Üí	}
    31‚Üí}
    33‚Üífunc TestErrorError_default(t *testing.T) {
    34‚Üí	expected := `2 errors occurred:
    35‚Üí	* foo
    36‚Üí	* bar
    37‚Üí
    38‚Üí`
    39‚Üí
    40‚Üí	errors := []error{
    41‚Üí		errors.New("foo"),
    42‚Üí		errors.New("bar"),
    43‚Üí	}
    44‚Üí
    45‚Üí	multi := &Error{Errors: errors}
    46‚Üí	if multi.Error() != expected {
    47‚Üí		t.Fatalf("bad: %s", multi.Error())
    48‚Üí	}
    49‚Üí}
    51‚Üífunc TestErrorErrorOrNil(t *testing.T) {
    52‚Üí	err := new(Error)
    53‚Üí	if err.ErrorOrNil() != nil {
    54‚Üí		t.Fatalf("bad: %#v", err.ErrorOrNil())
    55‚Üí	}
    56‚Üí
    57‚Üí	err.Errors = []error{errors.New("foo")}
    58‚Üí	if v := err.ErrorOrNil(); v == nil {
    59‚Üí		t.Fatal("should not be nil")
    60‚Üí	} else if !reflect.DeepEqual(v, err) {
    61‚Üí		t.Fatalf("bad: %#v", v)
    62‚Üí	}
    63‚Üí}
    65‚Üífunc TestErrorWrappedErrors(t *testing.T) {
    66‚Üí	errors := []error{
    67‚Üí		errors.New("foo"),
    68‚Üí		errors.New("bar"),
    69‚Üí	}
    70‚Üí
    71‚Üí	multi := &Error{Errors: errors}
    72‚Üí	if !reflect.DeepEqual(multi.Errors, multi.WrappedErrors()) {
    73‚Üí		t.Fatalf("bad: %s", multi.WrappedErrors())
    74‚Üí	}
    75‚Üí
    76‚Üí	multi = nil
    77‚Üí	if err := multi.WrappedErrors(); err != nil {
    78‚Üí		t.Fatalf("bad: %#v", multi)
    79‚Üí	}
    80‚Üí}
    82‚Üífunc TestErrorUnwrap(t *testing.T) {
    83‚Üí	t.Run("with errors", func(t *testing.T) {
    84‚Üí		err := &Error{Errors: []error{
    85‚Üí			errors.New("foo"),
    86‚Üí			errors.New("bar"),
    87‚Üí			errors.New("baz"),
    88‚Üí		}}
    89‚Üí
    90‚Üí		var current error = err
    91‚Üí		for i := 0; i < len(err.Errors); i++ {
    92‚Üí			current = errors.Unwrap(current)
    93‚Üí			if !errors.Is(current, err.Errors[i]) {
    94‚Üí				t.Fatal("should be next value")
    95‚Üí			}
    96‚Üí		}
    97‚Üí
    98‚Üí		if errors.Unwrap(current) != nil {
    99‚Üí			t.Fatal("should be nil at the end")
   100‚Üí		}
   101‚Üí	})
   102‚Üí
   103‚Üí	t.Run("with no errors", func(t *testing.T) {
   104‚Üí		err := &Error{Errors: nil}
   105‚Üí		if errors.Unwrap(err) != nil {
   106‚Üí			t.Fatal("should be nil")
   107‚Üí		}
   108‚Üí	})
   109‚Üí
   110‚Üí	t.Run("with nil multierror", func(t *testing.T) {
   111‚Üí		var err *Error
   112‚Üí		if errors.Unwrap(err) != nil {
   113‚Üí			t.Fatal("should be nil")
   114‚Üí		}
   115‚Üí	})
   116‚Üí}
   118‚Üífunc TestErrorIs(t *testing.T) {
   119‚Üí	errBar := errors.New("bar")
   120‚Üí
   121‚Üí	t.Run("with errBar", func(t *testing.T) {
   122‚Üí		err := &Error{Errors: []error{
   123‚Üí			errors.New("foo"),
   124‚Üí			errBar,
   125‚Üí			errors.New("baz"),
   126‚Üí		}}
   127‚Üí
   128‚Üí		if !errors.Is(err, errBar) {
   129‚Üí			t.Fatal("should be true")
   130‚Üí		}
   131‚Üí	})
   132‚Üí
   133‚Üí	t.Run("with errBar wrapped by fmt.Errorf", func(t *testing.T) {
   134‚Üí		err := &Error{Errors: []error{
   135‚Üí			errors.New("foo"),
   136‚Üí			fmt.Errorf("errorf: %w", errBar),
   137‚Üí			errors.New("baz"),
   138‚Üí		}}
   139‚Üí
   140‚Üí		if !errors.Is(err, errBar) {
   141‚Üí			t.Fatal("should be true")
   142‚Üí		}
   143‚Üí	})
   144‚Üí
   145‚Üí	t.Run("without errBar", func(t *testing.T) {
   146‚Üí		err := &Error{Errors: []error{
   147‚Üí			errors.New("foo"),
   148‚Üí			errors.New("baz"),
   149‚Üí		}}
   150‚Üí
   151‚Üí		if errors.Is(err, errBar) {
   152‚Üí			t.Fatal("should be false")
   153‚Üí		}
   154‚Üí	})
   155‚Üí}
   157‚Üífunc TestErrorAs(t *testing.T) {
   158‚Üí	match := &nestedError{}
   159‚Üí
   160‚Üí	t.Run("with the value", func(t *testing.T) {
   161‚Üí		err := &Error{Errors: []error{
   162‚Üí			errors.New("foo"),
   163‚Üí			match,
   164‚Üí			errors.New("baz"),
   165‚Üí		}}
   166‚Üí
   167‚Üí		var target *nestedError
   168‚Üí		if !errors.As(err, &target) {
   169‚Üí			t.Fatal("should be true")
   170‚Üí		}
   171‚Üí		if target == nil {
   172‚Üí			t.Fatal("target should not be nil")
   173‚Üí		}
   174‚Üí	})
   175‚Üí
   176‚Üí	t.Run("with the value wrapped by fmt.Errorf", func(t *testing.T) {
   177‚Üí		err := &Error{Errors: []error{
   178‚Üí			errors.New("foo"),
   179‚Üí			fmt.Errorf("errorf: %w", match),
   180‚Üí			errors.New("baz"),
   181‚Üí		}}
   182‚Üí
   183‚Üí		var target *nestedError
   184‚Üí		if !errors.As(err, &target) {
   185‚Üí			t.Fatal("should be true")
   186‚Üí		}
   187‚Üí		if target == nil {
   188‚Üí			t.Fatal("target should not be nil")
   189‚Üí		}
   190‚Üí	})
   191‚Üí
   192‚Üí	t.Run("without the value", func(t *testing.T) {
   193‚Üí		err := &Error{Errors: []error{
   194‚Üí			errors.New("foo"),
   195‚Üí			errors.New("baz"),
   196‚Üí		}}
   197‚Üí
   198‚Üí		var target *nestedError
   199‚Üí		if errors.As(err, &target) {
   200‚Üí			t.Fatal("should be false")
   201‚Üí		}
   202‚Üí		if target != nil {
   203‚Üí			t.Fatal("target should be nil")
   204‚Üí		}
   205‚Üí	})
   206‚Üí}
   208‚Üí// nestedError implements error and is used for tests.
   209‚Üítype nestedError struct{}
   211‚Üífunc (*nestedError) Error() string { return "" }

prefix.go
     6‚Üíimport (
     7‚Üí	"fmt"
     8‚Üí)
    10‚Üí// Prefix is a helper function that will prefix some text
    11‚Üí// to the given error. If the error is a multierror.Error, then
    12‚Üí// it will be prefixed to each wrapped error.
    13‚Üí//
    14‚Üí// This is useful to use when appending multiple multierrors
    15‚Üí// together in order to give better scoping.
    16‚Üífunc Prefix(err error, prefix string) error {
    17‚Üí	if err == nil {
    18‚Üí		return nil
    19‚Üí	}
    20‚Üí
    21‚Üí	switch err := err.(type) {
    22‚Üí	case *Error:
    23‚Üí		// Typed nils can reach here, so initialize if we are nil
    24‚Üí		if err == nil {
    25‚Üí			err = new(Error)
    26‚Üí		}
    27‚Üí
    28‚Üí		// Wrap each of the errors
    29‚Üí		for i, e := range err.Errors {
    30‚Üí			err.Errors[i] = fmt.Errorf("%s %s", prefix, e)
    31‚Üí		}
    32‚Üí
    33‚Üí		return err
    34‚Üí	default:
    35‚Üí		return fmt.Errorf("%s %s", prefix, err)
    36‚Üí	}
    37‚Üí}

prefix_test.go
     6‚Üíimport (
     7‚Üí	"errors"
     8‚Üí	"testing"
     9‚Üí)
    11‚Üífunc TestPrefix_Error(t *testing.T) {
    12‚Üí	original := &Error{
    13‚Üí		Errors: []error{errors.New("foo")},
    14‚Üí	}
    15‚Üí
    16‚Üí	result := Prefix(original, "bar")
    17‚Üí	if result.(*Error).Errors[0].Error() != "bar foo" {
    18‚Üí		t.Fatalf("bad: %s", result)
    19‚Üí	}
    20‚Üí}
    22‚Üífunc TestPrefix_NilError(t *testing.T) {
    23‚Üí	var err error
    24‚Üí	result := Prefix(err, "bar")
    25‚Üí	if result != nil {
    26‚Üí		t.Fatalf("bad: %#v", result)
    27‚Üí	}
    28‚Üí}
    30‚Üífunc TestPrefix_NonError(t *testing.T) {
    31‚Üí	original := errors.New("foo")
    32‚Üí	result := Prefix(original, "bar")
    33‚Üí	if result == nil {
    34‚Üí		t.Fatal("error result was nil")
    35‚Üí	}
    36‚Üí	if result.Error() != "bar foo" {
    37‚Üí		t.Fatalf("bad: %s", result)
    38‚Üí	}
    39‚Üí}

sort.go
     6‚Üí// Len implements sort.Interface function for length
     7‚Üífunc (err *Error) Len() int {
     8‚Üí	if err == nil {
     9‚Üí		return 0
    10‚Üí	}
    11‚Üí
    12‚Üí	return len(err.Errors)
    13‚Üí}
    15‚Üí// Swap implements sort.Interface function for swapping elements
    16‚Üífunc (err Error) Swap(i, j int) {
    17‚Üí	err.Errors[i], err.Errors[j] = err.Errors[j], err.Errors[i]
    18‚Üí}
    20‚Üí// Less implements sort.Interface function for determining order
    21‚Üífunc (err Error) Less(i, j int) bool {
    22‚Üí	return err.Errors[i].Error() < err.Errors[j].Error()
    23‚Üí}

sort_test.go
     6‚Üíimport (
     7‚Üí	"errors"
     8‚Üí	"reflect"
     9‚Üí	"sort"
    10‚Üí	"testing"
    11‚Üí)
    13‚Üífunc TestSortSingle(t *testing.T) {
    14‚Üí	errFoo := errors.New("foo")
    15‚Üí
    16‚Üí	expected := []error{
    17‚Üí		errFoo,
    18‚Üí	}
    19‚Üí
    20‚Üí	err := &Error{
    21‚Üí		Errors: []error{
    22‚Üí			errFoo,
    23‚Üí		},
    24‚Üí	}
    25‚Üí
    26‚Üí	sort.Sort(err)
    27‚Üí	if !reflect.DeepEqual(err.Errors, expected) {
    28‚Üí		t.Fatalf("bad: %#v", err)
    29‚Üí	}
    30‚Üí}
    32‚Üífunc TestSortMultiple(t *testing.T) {
    33‚Üí	errBar := errors.New("bar")
    34‚Üí	errBaz := errors.New("baz")
    35‚Üí	errFoo := errors.New("foo")
    36‚Üí
    37‚Üí	expected := []error{
    38‚Üí		errBar,
    39‚Üí		errBaz,
    40‚Üí		errFoo,
    41‚Üí	}
    42‚Üí
    43‚Üí	err := &Error{
    44‚Üí		Errors: []error{
    45‚Üí			errFoo,
    46‚Üí			errBar,
    47‚Üí			errBaz,
    48‚Üí		},
    49‚Üí	}
    50‚Üí
    51‚Üí	sort.Sort(err)
    52‚Üí	if !reflect.DeepEqual(err.Errors, expected) {
    53‚Üí		t.Fatalf("bad: %#v", err)
    54‚Üí	}
    55‚Üí}

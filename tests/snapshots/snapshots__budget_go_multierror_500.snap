multierror.go
    11→// Error is an error type to track multiple errors. This is used to
    12→// accumulate errors in cases and return them as a single "error".
    13→type Error struct {
    14→	Errors      []error
    15→	ErrorFormat ErrorFormatFunc
    16→}
    18→func (e *Error) Error() string {
    19→	fn := e.ErrorFormat
    20→	if fn == nil {
    21→		fn = ListFormatFunc
    22→	}
    23→
    24→	return fn(e.Errors)
    25→}
    31→func (e *Error) ErrorOrNil() error {
    42→func (e *Error) GoString() string {
    43→	return fmt.Sprintf("*%#v", *e)
    44→}

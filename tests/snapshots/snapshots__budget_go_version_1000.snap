    30‚Üífunc getSemverRegexp() *regexp.Regexp {
    37‚Üí// The raw regular expression string used for testing the validity
    38‚Üí// of a version.
    39‚Üíconst (
    40‚Üí	VersionRegexpRaw string = `v?([0-9]+(\.[0-9]+)*?)` +
    41‚Üí		`(-([0-9]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)|(-?([A-Za-z\-~]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)))?` +
    42‚Üí		`(\+([0-9A-Za-z\-~]+(\.[0-9A-Za-z\-~]+)*))?` +
    43‚Üí		`?`
    44‚Üí
    45‚Üí	// SemverRegexpRaw requires a separator between version and prerelease
    46‚Üí	SemverRegexpRaw string = `v?([0-9]+(\.[0-9]+)*?)` +
    47‚Üí		`(-([0-9]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)|(-([A-Za-z\-~]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)))?` +
    48‚Üí		`(\+([0-9A-Za-z\-~]+(\.[0-9A-Za-z\-~]+)*))?` +
    49‚Üí		`?`
    50‚Üí)

    31â†’// Constraint represents a single constraint for a version, such as
    32â†’// ">= 1.0".
    33â†’type Constraint struct {
    34â†’	f        constraintFunc
    35â†’	op       operator
    36â†’	check    *Version
    37â†’	original string
    38â†’}
    40â†’func (c *Constraint) Equals(con *Constraint) bool {
    41â†’	return c.op == con.op && c.check.Equal(con.check)
    42â†’}
    44â†’// Constraints is a slice of constraints. We make a custom type so that
    45â†’// we can add methods to it.
    46â†’type Constraints []*Constraint

    19тЖТfunc getConstraintRegexp() *regexp.Regexp {
    31тЖТ// Constraint represents a single constraint for a version, such as
    32тЖТ// ">= 1.0".
    33тЖТtype Constraint struct {
    34тЖТ	f        constraintFunc
    35тЖТ	op       operator
    36тЖТ	check    *Version
    37тЖТ	original string
    38тЖТ}
    40тЖТfunc (c *Constraint) Equals(con *Constraint) bool {
    41тЖТ	return c.op == con.op && c.check.Equal(con.check)
    42тЖТ}
    44тЖТ// Constraints is a slice of constraints. We make a custom type so that
    45тЖТ// we can add methods to it.
    46тЖТtype Constraints []*Constraint
    48тЖТtype constraintFunc func(v, c *Version) bool
    50тЖТtype constraintOperation struct {
    51тЖТ	op operator
    52тЖТ	f  constraintFunc
    53тЖТ}
    55тЖТ// NewConstraint will parse one or more constraints from the given
    56тЖТ// constraint string. The string must be a comma-separated list of
    57тЖТ// constraints.
    58тЖТfunc NewConstraint(v string) (Constraints, error) {
    59тЖТ	vs := strings.Split(v, ",")
    60тЖТ	result := make([]*Constraint, len(vs))
    61тЖТ	for i, single := range vs {
    62тЖТ		c, err := parseSingle(single)
    63тЖТ		if err != nil {
    64тЖТ			return nil, err
    65тЖТ		}
    66тЖТ
    67тЖТ		result[i] = c
    68тЖТ	}
    69тЖТ
    70тЖТ	return Constraints(result), nil
    71тЖТ}
    73тЖТ// MustConstraints is a helper that wraps a call to a function
    74тЖТ// returning (Constraints, error) and panics if error is non-nil.
    75тЖТfunc MustConstraints(c Constraints, err error) Constraints {
    76тЖТ	if err != nil {
    77тЖТ		panic(err)
    78тЖТ	}
    79тЖТ
    80тЖТ	return c
    81тЖТ}
    83тЖТ// Check tests if a version satisfies all the constraints.
    84тЖТfunc (cs Constraints) Check(v *Version) bool {
    85тЖТ	for _, c := range cs {
    86тЖТ		if !c.Check(v) {
    87тЖТ			return false

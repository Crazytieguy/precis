    19→func getConstraintRegexp() *regexp.Regexp {
    31→// Constraint represents a single constraint for a version, such as
    32→// ">= 1.0".
    33→type Constraint struct {
    34→	f        constraintFunc
    35→	op       operator
    36→	check    *Version
    37→	original string
    38→}
    40→func (c *Constraint) Equals(con *Constraint) bool {
    41→	return c.op == con.op && c.check.Equal(con.check)
    42→}
    44→// Constraints is a slice of constraints. We make a custom type so that
    45→// we can add methods to it.
    46→type Constraints []*Constraint
    48→type constraintFunc func(v, c *Version) bool
    50→type constraintOperation struct {
    51→	op operator
    52→	f  constraintFunc
    53→}
    55→// NewConstraint will parse one or more constraints from the given
    56→// constraint string. The string must be a comma-separated list of
    57→// constraints.
    58→func NewConstraint(v string) (Constraints, error) {
    59→	vs := strings.Split(v, ",")
    60→	result := make([]*Constraint, len(vs))
    61→	for i, single := range vs {
    62→		c, err := parseSingle(single)
    63→		if err != nil {
    64→			return nil, err
    65→		}
    66→
    67→		result[i] = c
    68→	}
    69→
    70→	return Constraints(result), nil
    71→}
    73→// MustConstraints is a helper that wraps a call to a function
    74→// returning (Constraints, error) and panics if error is non-nil.
    75→func MustConstraints(c Constraints, err error) Constraints {
    76→	if err != nil {
    77→		panic(err)
    78→	}
    79→
    80→	return c
    81→}
    83→// Check tests if a version satisfies all the constraints.
    84→func (cs Constraints) Check(v *Version) bool {
    85→	for _, c := range cs {
    86→		if !c.Check(v) {
    87→			return false
    88→		}
    89→	}
    90→
    91→	return true
    92→}
    94→// Equals compares Constraints with other Constraints
    95→// for equality. This may not represent logical equivalence
    96→// of compared constraints.
    97→// e.g. even though '>0.1,>0.2' is logically equivalent
    98→// to '>0.2' it is *NOT* treated as equal.
    99→//
   100→// Missing operator is treated as equal to '=', whitespaces
   101→// are ignored and constraints are sorted before comparison.
   102→func (cs Constraints) Equals(c Constraints) bool {
   103→	if len(cs) != len(c) {
   104→		return false
   105→	}
   106→
   107→	// make copies to retain order of the original slices
   108→	left := make(Constraints, len(cs))
   109→	copy(left, cs)
   110→	sort.Stable(left)
   111→	right := make(Constraints, len(c))
   112→	copy(right, c)
   113→	sort.Stable(right)
   114→
   115→	// compare sorted slices
   116→	for i, con := range left {
   117→		if !con.Equals(right[i]) {
   118→			return false
   119→		}
   120→	}
   121→
   122→	return true
   123→}
   125→func (cs Constraints) Len() int {
   126→	return len(cs)
   127→}
   129→func (cs Constraints) Less(i, j int) bool {
   130→	if cs[i].op < cs[j].op {
   131→		return true
   132→	}
   133→	if cs[i].op > cs[j].op {
   134→		return false
   135→	}
   136→
   137→	return cs[i].check.LessThan(cs[j].check)
   138→}
   140→func (cs Constraints) Swap(i, j int) {
   141→	cs[i], cs[j] = cs[j], cs[i]
   142→}
   144→// Returns the string format of the constraints
   145→func (cs Constraints) String() string {
   146→	csStr := make([]string, len(cs))
   147→	for i, c := range cs {
   148→		csStr[i] = c.String()
   149→	}
   150→
   151→	return strings.Join(csStr, ",")
   152→}
   154→// Check tests if a constraint is validated by the given version.
   155→func (c *Constraint) Check(v *Version) bool {
   156→	return c.f(v, c.check)
   157→}
   159→// Prerelease returns true if the version underlying this constraint
   160→// contains a prerelease field.
   161→func (c *Constraint) Prerelease() bool {
   162→	return len(c.check.Prerelease()) > 0
   163→}
   165→func (c *Constraint) String() string {
   166→	return c.original
   167→}

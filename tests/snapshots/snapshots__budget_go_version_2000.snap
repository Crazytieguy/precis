   307‚Üí// Core returns a new version constructed from only the MAJOR.MINOR.PATCH
   308‚Üí// segments of the version, without prerelease or metadata.
   309‚Üífunc (v *Version) Core() *Version {
   310‚Üí	segments := v.Segments64()
   311‚Üí	segmentsOnly := fmt.Sprintf("%d.%d.%d", segments[0], segments[1], segments[2])
   312‚Üí	return Must(NewVersion(segmentsOnly))
   313‚Üí}
   315‚Üí// Equal tests if two versions are equal.
   316‚Üífunc (v *Version) Equal(o *Version) bool {
   317‚Üí	if v == nil || o == nil {
   318‚Üí		return v == o
   319‚Üí	}
   320‚Üí
   321‚Üí	return v.Compare(o) == 0
   322‚Üí}
   324‚Üí// GreaterThan tests if this version is greater than another version.
   325‚Üífunc (v *Version) GreaterThan(o *Version) bool {
   326‚Üí	return v.Compare(o) > 0
   327‚Üí}
   329‚Üí// GreaterThanOrEqual tests if this version is greater than or equal to another version.
   330‚Üífunc (v *Version) GreaterThanOrEqual(o *Version) bool {
   331‚Üí	return v.Compare(o) >= 0
   332‚Üí}
   334‚Üí// LessThan tests if this version is less than another version.
   335‚Üífunc (v *Version) LessThan(o *Version) bool {
   336‚Üí	return v.Compare(o) < 0
   337‚Üí}
   339‚Üí// LessThanOrEqual tests if this version is less than or equal to another version.
   340‚Üífunc (v *Version) LessThanOrEqual(o *Version) bool {
   341‚Üí	return v.Compare(o) <= 0
   342‚Üí}
   344‚Üí// Metadata returns any metadata that was part of the version
   345‚Üí// string.
   346‚Üí//
   347‚Üí// Metadata is anything that comes after the "+" in the version.
   348‚Üí// For example, with "1.2.3+beta", the metadata is "beta".
   349‚Üífunc (v *Version) Metadata() string {
   350‚Üí	return v.metadata
   351‚Üí}
   353‚Üí// Prerelease returns any prerelease data that is part of the version,
   354‚Üí// or blank if there is no prerelease data.
   355‚Üí//
   356‚Üí// Prerelease information is anything that comes after the "-" in the
   357‚Üí// version (but before any metadata). For example, with "1.2.3-beta",
   358‚Üí// the prerelease information is "beta".
   359‚Üífunc (v *Version) Prerelease() string {
   360‚Üí	return v.pre
   361‚Üí}
   363‚Üí// Segments returns the numeric segments of the version as a slice of ints.
   364‚Üí//
   365‚Üí// This excludes any metadata or pre-release information. For example,
   366‚Üí// for a version "1.2.3-beta", segments will return a slice of
   367‚Üí// 1, 2, 3.
   368‚Üífunc (v *Version) Segments() []int {
   369‚Üí	segmentSlice := make([]int, len(v.segments))
   370‚Üí	for i, v := range v.segments {
   371‚Üí		segmentSlice[i] = int(v)
   372‚Üí	}
   373‚Üí	return segmentSlice
   374‚Üí}
   376‚Üí// Segments64 returns the numeric segments of the version as a slice of int64s.
   377‚Üí//
   378‚Üí// This excludes any metadata or pre-release information. For example,
   379‚Üí// for a version "1.2.3-beta", segments will return a slice of
   380‚Üí// 1, 2, 3.
   381‚Üífunc (v *Version) Segments64() []int64 {
   382‚Üí	result := make([]int64, len(v.segments))
   383‚Üí	copy(result, v.segments)
   384‚Üí	return result
   385‚Üí}
   387‚Üí// String returns the full version string included pre-release
   388‚Üí// and metadata information.
   389‚Üí//
   390‚Üí// This value is rebuilt according to the parsed segments and other
   391‚Üí// information. Therefore, ambiguities in the version string such as
   392‚Üí// prefixed zeroes (1.04.0 => 1.4.0), `v` prefix (v1.0.0 => 1.0.0), and
   393‚Üí// missing parts (1.0 => 1.0.0) will be made into a canonicalized form
   394‚Üí// as shown in the parenthesized examples.
   395‚Üífunc (v *Version) String() string {
   396‚Üí	return string(v.bytes())
   397‚Üí}
   399‚Üífunc (v *Version) bytes() []byte {
   421‚Üí// Original returns the original parsed version as-is, including any
   422‚Üí// potential whitespace, `v` prefix, etc.
   423‚Üífunc (v *Version) Original() string {
   424‚Üí	return v.original

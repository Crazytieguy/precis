   159→// Prerelease returns true if the version underlying this constraint
   160→// contains a prerelease field.
   161→func (c *Constraint) Prerelease() bool {
   162→	return len(c.check.Prerelease()) > 0
   163→}
   165→func (c *Constraint) String() string {

   117→	}
   118→
   119→	return v
   120→}
   122→// Compare compares this version to another version. This
   123→// returns -1, 0, or 1 if this version is smaller, equal,
   124→// or larger than the other version, respectively.
   125→//
   126→// If you want boolean results, use the LessThan, Equal,
   127→// GreaterThan, GreaterThanOrEqual or LessThanOrEqual methods.
   128→func (v *Version) Compare(other *Version) int {
   129→	// A quick, efficient equality check
   130→	if v.String() == other.String() {
   131→		return 0
   132→	}
   133→
   134→	// If the segments are the same, we must compare on prerelease info
   135→	if v.equalSegments(other) {
   136→		preSelf := v.Prerelease()
   137→		preOther := other.Prerelease()
   138→		if preSelf == "" && preOther == "" {
   139→			return 0
   140→		}
   141→		if preSelf == "" {
   142→			return 1
   143→		}
   144→		if preOther == "" {
   145→			return -1
   146→		}
   147→
   148→		return comparePrereleases(preSelf, preOther)
   149→	}
   150→

   307тЖТ// Core returns a new version constructed from only the MAJOR.MINOR.PATCH
   308тЖТ// segments of the version, without prerelease or metadata.
   309тЖТfunc (v *Version) Core() *Version {
   310тЖТ	segments := v.Segments64()
   311тЖТ	segmentsOnly := fmt.Sprintf("%d.%d.%d", segments[0], segments[1], segments[2])
   312тЖТ	return Must(NewVersion(segmentsOnly))
   313тЖТ}
   315тЖТ// Equal tests if two versions are equal.
   316тЖТfunc (v *Version) Equal(o *Version) bool {
   317тЖТ	if v == nil || o == nil {
   318тЖТ		return v == o
   319тЖТ	}
   320тЖТ
   321тЖТ	return v.Compare(o) == 0
   322тЖТ}
   324тЖТ// GreaterThan tests if this version is greater than another version.
   325тЖТfunc (v *Version) GreaterThan(o *Version) bool {
   326тЖТ	return v.Compare(o) > 0
   327тЖТ}
   329тЖТ// GreaterThanOrEqual tests if this version is greater than or equal to another version.
   330тЖТfunc (v *Version) GreaterThanOrEqual(o *Version) bool {
   331тЖТ	return v.Compare(o) >= 0
   332тЖТ}
   334тЖТ// LessThan tests if this version is less than another version.
   335тЖТfunc (v *Version) LessThan(o *Version) bool {
   336тЖТ	return v.Compare(o) < 0
   337тЖТ}
   339тЖТ// LessThanOrEqual tests if this version is less than or equal to another version.
   340тЖТfunc (v *Version) LessThanOrEqual(o *Version) bool {
   341тЖТ	return v.Compare(o) <= 0
   342тЖТ}
   344тЖТ// Metadata returns any metadata that was part of the version
   345тЖТ// string.
   346тЖТ//
   347тЖТ// Metadata is anything that comes after the "+" in the version.
   348тЖТ// For example, with "1.2.3+beta", the metadata is "beta".
   349тЖТfunc (v *Version) Metadata() string {
   350тЖТ	return v.metadata
   351тЖТ}
   353тЖТ// Prerelease returns any prerelease data that is part of the version,
   354тЖТ// or blank if there is no prerelease data.
   355тЖТ//
   356тЖТ// Prerelease information is anything that comes after the "-" in the
   357тЖТ// version (but before any metadata). For example, with "1.2.3-beta",
   358тЖТ// the prerelease information is "beta".
   359тЖТfunc (v *Version) Prerelease() string {
   360тЖТ	return v.pre
   361тЖТ}
   363тЖТ// Segments returns the numeric segments of the version as a slice of ints.
   364тЖТ//
   365тЖТ// This excludes any metadata or pre-release information. For example,
   366тЖТ// for a version "1.2.3-beta", segments will return a slice of
   367тЖТ// 1, 2, 3.
   368тЖТfunc (v *Version) Segments() []int {
   369тЖТ	segmentSlice := make([]int, len(v.segments))
   370тЖТ	for i, v := range v.segments {
   371тЖТ		segmentSlice[i] = int(v)
   372тЖТ	}
   373тЖТ	return segmentSlice
   374тЖТ}
   376тЖТ// Segments64 returns the numeric segments of the version as a slice of int64s.
   377тЖТ//
   378тЖТ// This excludes any metadata or pre-release information. For example,
   379тЖТ// for a version "1.2.3-beta", segments will return a slice of
   380тЖТ// 1, 2, 3.
   381тЖТfunc (v *Version) Segments64() []int64 {
   382тЖТ	result := make([]int64, len(v.segments))
   383тЖТ	copy(result, v.segments)
   384тЖТ	return result
   385тЖТ}
   387тЖТ// String returns the full version string included pre-release
   388тЖТ// and metadata information.
   389тЖТ//
   390тЖТ// This value is rebuilt according to the parsed segments and other
   391тЖТ// information. Therefore, ambiguities in the version string such as
   392тЖТ// prefixed zeroes (1.04.0 => 1.4.0), `v` prefix (v1.0.0 => 1.0.0), and
   393тЖТ// missing parts (1.0 => 1.0.0) will be made into a canonicalized form
   394тЖТ// as shown in the parenthesized examples.
   395тЖТfunc (v *Version) String() string {
   396тЖТ	return string(v.bytes())
   397тЖТ}
   399тЖТfunc (v *Version) bytes() []byte {
   421тЖТ// Original returns the original parsed version as-is, including any
   422тЖТ// potential whitespace, `v` prefix, etc.
   423тЖТfunc (v *Version) Original() string {
   424тЖТ	return v.original
   425тЖТ}
   427тЖТ// UnmarshalText implements encoding.TextUnmarshaler interface.
   428тЖТfunc (v *Version) UnmarshalText(b []byte) error {
   429тЖТ	temp, err := NewVersion(string(b))
   430тЖТ	if err != nil {
   431тЖТ		return err
   432тЖТ	}
   433тЖТ
   434тЖТ	*v = *temp
   435тЖТ
   436тЖТ	return nil
   437тЖТ}
   439тЖТ// MarshalText implements encoding.TextMarshaler interface.
   440тЖТfunc (v *Version) MarshalText() ([]byte, error) {
   441тЖТ	return []byte(v.String()), nil
   442тЖТ}
   444тЖТ// Scan implements the sql.Scanner interface.
   445тЖТfunc (v *Version) Scan(src interface{}) error {
   446тЖТ	switch src := src.(type) {
   447тЖТ	case string:
   448тЖТ		return v.UnmarshalText([]byte(src))
   449тЖТ	case nil:
   450тЖТ		return nil
   451тЖТ	default:
   452тЖТ		return fmt.Errorf("cannot scan %T as Version", src)
   453тЖТ	}
   454тЖТ}
   456тЖТ// Value implements the driver.Valuer interface.
   457тЖТfunc (v *Version) Value() (driver.Value, error) {
   458тЖТ	return v.String(), nil
   459тЖТ}
version_collection.go
     6тЖТ// Collection is a type that implements the sort.Interface interface
     7тЖТ// so that versions can be sorted.
     8тЖТtype Collection []*Version
    10тЖТfunc (v Collection) Len() int {
    11тЖТ	return len(v)
    12тЖТ}
    14тЖТfunc (v Collection) Less(i, j int) bool {
    15тЖТ	return v[i].LessThan(v[j])
    16тЖТ}
    18тЖТfunc (v Collection) Swap(i, j int) {
    19тЖТ	v[i], v[j] = v[j], v[i]
    20тЖТ}

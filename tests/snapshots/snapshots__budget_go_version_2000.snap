version_collection.go
     6Ôćĺ// Collection is a type that implements the sort.Interface interface
     7Ôćĺ// so that versions can be sorted.
     8Ôćĺtype Collection []*Version
    10Ôćĺfunc (v Collection) Len() int {
    11Ôćĺ	return len(v)
    12Ôćĺ}
    14Ôćĺfunc (v Collection) Less(i, j int) bool {
    15Ôćĺ	return v[i].LessThan(v[j])
    16Ôćĺ}
    18Ôćĺfunc (v Collection) Swap(i, j int) {
    19Ôćĺ	v[i], v[j] = v[j], v[i]
    20Ôćĺ}


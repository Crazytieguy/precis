   427‚Üí// UnmarshalText implements encoding.TextUnmarshaler interface.
   428‚Üífunc (v *Version) UnmarshalText(b []byte) error {
   429‚Üí	temp, err := NewVersion(string(b))
   430‚Üí	if err != nil {
   431‚Üí		return err
   432‚Üí	}
   433‚Üí
   434‚Üí	*v = *temp
   435‚Üí
   436‚Üí	return nil
   437‚Üí}
   439‚Üí// MarshalText implements encoding.TextMarshaler interface.
   440‚Üífunc (v *Version) MarshalText() ([]byte, error) {
   441‚Üí	return []byte(v.String()), nil
   442‚Üí}
   444‚Üí// Scan implements the sql.Scanner interface.
   445‚Üífunc (v *Version) Scan(src interface{}) error {
   446‚Üí	switch src := src.(type) {
   447‚Üí	case string:
   448‚Üí		return v.UnmarshalText([]byte(src))
   449‚Üí	case nil:
   450‚Üí		return nil
   451‚Üí	default:
   452‚Üí		return fmt.Errorf("cannot scan %T as Version", src)
   453‚Üí	}
   454‚Üí}
   456‚Üí// Value implements the driver.Valuer interface.
   457‚Üífunc (v *Version) Value() (driver.Value, error) {
   458‚Üí	return v.String(), nil
   459‚Üí}

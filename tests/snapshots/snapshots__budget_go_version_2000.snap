    23тЖТfunc getVersionRegexp() *regexp.Regexp {
    30тЖТfunc getSemverRegexp() *regexp.Regexp {
    37тЖТ// The raw regular expression string used for testing the validity
    38тЖТ// of a version.
    39тЖТconst (
    40тЖТ	VersionRegexpRaw string = `v?([0-9]+(\.[0-9]+)*?)` +
    41тЖТ		`(-([0-9]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)|(-?([A-Za-z\-~]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)))?` +
    42тЖТ		`(\+([0-9A-Za-z\-~]+(\.[0-9A-Za-z\-~]+)*))?` +
    43тЖТ		`?`
    45тЖТ	// SemverRegexpRaw requires a separator between version and prerelease
    46тЖТ	SemverRegexpRaw string = `v?([0-9]+(\.[0-9]+)*?)` +
    47тЖТ		`(-([0-9]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)|(-([A-Za-z\-~]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)))?` +
    48тЖТ		`(\+([0-9A-Za-z\-~]+(\.[0-9A-Za-z\-~]+)*))?` +
    49тЖТ		`?`
    52тЖТ// Version represents a single version.
    53тЖТtype Version struct {
    54тЖТ	metadata string
    55тЖТ	pre      string
    56тЖТ	segments []int64
    57тЖТ	si       int
    58тЖТ	original string
    59тЖТ}
    61тЖТ// NewVersion parses the given version and returns a new
    62тЖТ// Version.
    63тЖТfunc NewVersion(v string) (*Version, error) {
    64тЖТ	return newVersion(v, getVersionRegexp())
    65тЖТ}
    67тЖТ// NewSemver parses the given version and returns a new
    68тЖТ// Version that adheres strictly to SemVer specs
    69тЖТ// https://semver.org/
    70тЖТfunc NewSemver(v string) (*Version, error) {
    71тЖТ	return newVersion(v, getSemverRegexp())
    72тЖТ}

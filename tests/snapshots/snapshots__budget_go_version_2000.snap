    19‚Üífunc getConstraintRegexp() *regexp.Regexp {
    31‚Üí// Constraint represents a single constraint for a version, such as
    32‚Üí// ">= 1.0".
    33‚Üítype Constraint struct {
    34‚Üí	f        constraintFunc
    35‚Üí	op       operator
    36‚Üí	check    *Version
    37‚Üí	original string
    38‚Üí}
    40‚Üífunc (c *Constraint) Equals(con *Constraint) bool {
    41‚Üí	return c.op == con.op && c.check.Equal(con.check)
    42‚Üí}
    44‚Üí// Constraints is a slice of constraints. We make a custom type so that
    45‚Üí// we can add methods to it.
    46‚Üítype Constraints []*Constraint
    48‚Üítype constraintFunc func(v, c *Version) bool
    50‚Üítype constraintOperation struct {
    51‚Üí	op operator
    52‚Üí	f  constraintFunc
    53‚Üí}
    55‚Üí// NewConstraint will parse one or more constraints from the given
    56‚Üí// constraint string. The string must be a comma-separated list of
    57‚Üí// constraints.
    58‚Üífunc NewConstraint(v string) (Constraints, error) {
    59‚Üí	vs := strings.Split(v, ",")
    60‚Üí	result := make([]*Constraint, len(vs))
    61‚Üí	for i, single := range vs {
    62‚Üí		c, err := parseSingle(single)
    63‚Üí		if err != nil {
    64‚Üí			return nil, err
    65‚Üí		}
    66‚Üí
    67‚Üí		result[i] = c
    68‚Üí	}
    69‚Üí
    70‚Üí	return Constraints(result), nil
    71‚Üí}
    73‚Üí// MustConstraints is a helper that wraps a call to a function
    74‚Üí// returning (Constraints, error) and panics if error is non-nil.
    75‚Üífunc MustConstraints(c Constraints, err error) Constraints {
    76‚Üí	if err != nil {
    77‚Üí		panic(err)
    78‚Üí	}
    79‚Üí
    80‚Üí	return c
    81‚Üí}
    83‚Üí// Check tests if a version satisfies all the constraints.
    84‚Üífunc (cs Constraints) Check(v *Version) bool {
    85‚Üí	for _, c := range cs {
    86‚Üí		if !c.Check(v) {
    87‚Üí			return false
    88‚Üí		}
    89‚Üí	}
    90‚Üí
    91‚Üí	return true
    92‚Üí}
    94‚Üí// Equals compares Constraints with other Constraints
    95‚Üí// for equality. This may not represent logical equivalence
    96‚Üí// of compared constraints.
    97‚Üí// e.g. even though '>0.1,>0.2' is logically equivalent
    98‚Üí// to '>0.2' it is *NOT* treated as equal.
    99‚Üí//
   100‚Üí// Missing operator is treated as equal to '=', whitespaces
   101‚Üí// are ignored and constraints are sorted before comparison.
   102‚Üífunc (cs Constraints) Equals(c Constraints) bool {
   103‚Üí	if len(cs) != len(c) {
   104‚Üí		return false
   105‚Üí	}
   106‚Üí
   107‚Üí	// make copies to retain order of the original slices
   108‚Üí	left := make(Constraints, len(cs))
   109‚Üí	copy(left, cs)
   110‚Üí	sort.Stable(left)
   111‚Üí	right := make(Constraints, len(c))
   112‚Üí	copy(right, c)
   113‚Üí	sort.Stable(right)
   114‚Üí
   115‚Üí	// compare sorted slices
   116‚Üí	for i, con := range left {
   117‚Üí		if !con.Equals(right[i]) {
   118‚Üí			return false
   119‚Üí		}
   120‚Üí	}
   121‚Üí
   122‚Üí	return true
   123‚Üí}
   125‚Üífunc (cs Constraints) Len() int {
   126‚Üí	return len(cs)
   127‚Üí}
   129‚Üífunc (cs Constraints) Less(i, j int) bool {
   130‚Üí	if cs[i].op < cs[j].op {
   131‚Üí		return true
   132‚Üí	}
   133‚Üí	if cs[i].op > cs[j].op {
   134‚Üí		return false
   135‚Üí	}
   136‚Üí
   137‚Üí	return cs[i].check.LessThan(cs[j].check)
   138‚Üí}
   140‚Üífunc (cs Constraints) Swap(i, j int) {
   141‚Üí	cs[i], cs[j] = cs[j], cs[i]
   142‚Üí}
   144‚Üí// Returns the string format of the constraints
   145‚Üífunc (cs Constraints) String() string {
   146‚Üí	csStr := make([]string, len(cs))
   147‚Üí	for i, c := range cs {
   148‚Üí		csStr[i] = c.String()
   149‚Üí	}
   150‚Üí
   151‚Üí	return strings.Join(csStr, ",")
   152‚Üí}
   154‚Üí// Check tests if a constraint is validated by the given version.
   155‚Üífunc (c *Constraint) Check(v *Version) bool {
   156‚Üí	return c.f(v, c.check)
   157‚Üí}
   159‚Üí// Prerelease returns true if the version underlying this constraint
   160‚Üí// contains a prerelease field.
   161‚Üífunc (c *Constraint) Prerelease() bool {
   162‚Üí	return len(c.check.Prerelease()) > 0
   163‚Üí}
   165‚Üífunc (c *Constraint) String() string {
   166‚Üí	return c.original
   167‚Üí}

   122‚Üí// Compare compares this version to another version. This
   123‚Üí// returns -1, 0, or 1 if this version is smaller, equal,
   124‚Üí// or larger than the other version, respectively.
   125‚Üí//
   126‚Üí// If you want boolean results, use the LessThan, Equal,
   127‚Üí// GreaterThan, GreaterThanOrEqual or LessThanOrEqual methods.
   128‚Üífunc (v *Version) Compare(other *Version) int {
   129‚Üí	// A quick, efficient equality check
   130‚Üí	if v.String() == other.String() {
   131‚Üí		return 0
   132‚Üí	}
   133‚Üí
   134‚Üí	// If the segments are the same, we must compare on prerelease info
   135‚Üí	if v.equalSegments(other) {
   136‚Üí		preSelf := v.Prerelease()
   137‚Üí		preOther := other.Prerelease()
   138‚Üí		if preSelf == "" && preOther == "" {
   139‚Üí			return 0
   140‚Üí		}
   141‚Üí		if preSelf == "" {
   142‚Üí			return 1
   143‚Üí		}
   144‚Üí		if preOther == "" {
   145‚Üí			return -1
   146‚Üí		}
   147‚Üí
   148‚Üí		return comparePrereleases(preSelf, preOther)
   149‚Üí	}
   150‚Üí
   151‚Üí	segmentsSelf := v.Segments64()
   152‚Üí	segmentsOther := other.Segments64()

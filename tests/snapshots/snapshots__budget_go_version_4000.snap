    67ÔåÆ// NewSemver parses the given version and returns a new
    68ÔåÆ// Version that adheres strictly to SemVer specs
    69ÔåÆ// https://semver.org/
    70ÔåÆfunc NewSemver(v string) (*Version, error) {

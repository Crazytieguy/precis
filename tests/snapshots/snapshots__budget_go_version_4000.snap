version.go
     6ÔåÆimport (
     7ÔåÆ	"database/sql/driver"
     8ÔåÆ	"fmt"
     9ÔåÆ	"regexp"
    10ÔåÆ	"strconv"
    11ÔåÆ	"strings"
    12ÔåÆ	"sync"
    13ÔåÆ)
    15ÔåÆ// The compiled regular expression used to test the validity of a version.
    16ÔåÆvar (
    17ÔåÆ	versionRegexp     *regexp.Regexp
    18ÔåÆ	versionRegexpOnce sync.Once
    19ÔåÆ	semverRegexp      *regexp.Regexp
    20ÔåÆ	semverRegexpOnce  sync.Once
    23ÔåÆfunc getVersionRegexp() *regexp.Regexp {
    24ÔåÆ	versionRegexpOnce.Do(func() {
    25ÔåÆ		versionRegexp = regexp.MustCompile("^" + VersionRegexpRaw + "$")
    26ÔåÆ	})
    27ÔåÆ	return versionRegexp
    28ÔåÆ}
    30ÔåÆfunc getSemverRegexp() *regexp.Regexp {
    31ÔåÆ	semverRegexpOnce.Do(func() {
    32ÔåÆ		semverRegexp = regexp.MustCompile("^" + SemverRegexpRaw + "$")
    33ÔåÆ	})
    34ÔåÆ	return semverRegexp
    35ÔåÆ}
    37ÔåÆ// The raw regular expression string used for testing the validity
    38ÔåÆ// of a version.
    39ÔåÆconst (
    40ÔåÆ	VersionRegexpRaw string = `v?([0-9]+(\.[0-9]+)*?)` +
    41ÔåÆ		`(-([0-9]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)|(-?([A-Za-z\-~]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)))?` +

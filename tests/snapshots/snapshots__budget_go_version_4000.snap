   307→// Core returns a new version constructed from only the MAJOR.MINOR.PATCH
   308→// segments of the version, without prerelease or metadata.
   309→func (v *Version) Core() *Version {
   310→	segments := v.Segments64()
   311→	segmentsOnly := fmt.Sprintf("%d.%d.%d", segments[0], segments[1], segments[2])
   312→	return Must(NewVersion(segmentsOnly))
   313→}
   315→// Equal tests if two versions are equal.
   316→func (v *Version) Equal(o *Version) bool {
   317→	if v == nil || o == nil {
   318→		return v == o
   319→	}
   320→
   321→	return v.Compare(o) == 0
   322→}
   324→// GreaterThan tests if this version is greater than another version.
   325→func (v *Version) GreaterThan(o *Version) bool {
   326→	return v.Compare(o) > 0
   327→}
   329→// GreaterThanOrEqual tests if this version is greater than or equal to another version.
   330→func (v *Version) GreaterThanOrEqual(o *Version) bool {
   331→	return v.Compare(o) >= 0
   332→}
   334→// LessThan tests if this version is less than another version.
   335→func (v *Version) LessThan(o *Version) bool {
   336→	return v.Compare(o) < 0
   337→}
   339→// LessThanOrEqual tests if this version is less than or equal to another version.
   340→func (v *Version) LessThanOrEqual(o *Version) bool {
   341→	return v.Compare(o) <= 0
   342→}
   344→// Metadata returns any metadata that was part of the version
   345→// string.
   346→//
   347→// Metadata is anything that comes after the "+" in the version.
   348→// For example, with "1.2.3+beta", the metadata is "beta".
   349→func (v *Version) Metadata() string {
   350→	return v.metadata
   351→}
   353→// Prerelease returns any prerelease data that is part of the version,
   354→// or blank if there is no prerelease data.
   355→//
   356→// Prerelease information is anything that comes after the "-" in the
   357→// version (but before any metadata). For example, with "1.2.3-beta",
   358→// the prerelease information is "beta".
   359→func (v *Version) Prerelease() string {
   360→	return v.pre
   361→}
   363→// Segments returns the numeric segments of the version as a slice of ints.
   364→//
   365→// This excludes any metadata or pre-release information. For example,
   366→// for a version "1.2.3-beta", segments will return a slice of
   367→// 1, 2, 3.
   368→func (v *Version) Segments() []int {
   369→	segmentSlice := make([]int, len(v.segments))
   370→	for i, v := range v.segments {
   371→		segmentSlice[i] = int(v)
   372→	}
   373→	return segmentSlice
   374→}
   376→// Segments64 returns the numeric segments of the version as a slice of int64s.
   377→//
   378→// This excludes any metadata or pre-release information. For example,
   379→// for a version "1.2.3-beta", segments will return a slice of
   380→// 1, 2, 3.
   381→func (v *Version) Segments64() []int64 {
   382→	result := make([]int64, len(v.segments))
   383→	copy(result, v.segments)
   384→	return result
   385→}
   387→// String returns the full version string included pre-release
   388→// and metadata information.
   389→//
   390→// This value is rebuilt according to the parsed segments and other
   391→// information. Therefore, ambiguities in the version string such as
   392→// prefixed zeroes (1.04.0 => 1.4.0), `v` prefix (v1.0.0 => 1.0.0), and
   393→// missing parts (1.0 => 1.0.0) will be made into a canonicalized form
   394→// as shown in the parenthesized examples.
   395→func (v *Version) String() string {
   396→	return string(v.bytes())
   397→}
   399→func (v *Version) bytes() []byte {
   400→	var buf []byte
   401→	for i, s := range v.segments {
   402→		if i > 0 {
   403→			buf = append(buf, '.')
   404→		}
   405→		buf = strconv.AppendInt(buf, s, 10)
   406→	}
   407→
   408→	if v.pre != "" {
   409→		buf = append(buf, '-')
   410→		buf = append(buf, v.pre...)
   411→	}
   412→
   413→	if v.metadata != "" {
   414→		buf = append(buf, '+')

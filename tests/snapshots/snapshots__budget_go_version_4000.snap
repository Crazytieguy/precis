version.go
     6→import (
     7→	"database/sql/driver"
     8→	"fmt"
     9→	"regexp"
    10→	"strconv"
    11→	"strings"
    12→	"sync"
    13→)
    15→// The compiled regular expression used to test the validity of a version.
    16→var (
    17→	versionRegexp     *regexp.Regexp
    18→	versionRegexpOnce sync.Once
    19→	semverRegexp      *regexp.Regexp
    20→	semverRegexpOnce  sync.Once
    21→)
    23→func getVersionRegexp() *regexp.Regexp {
    24→	versionRegexpOnce.Do(func() {
    25→		versionRegexp = regexp.MustCompile("^" + VersionRegexpRaw + "$")
    26→	})
    27→	return versionRegexp
    28→}
    30→func getSemverRegexp() *regexp.Regexp {
    31→	semverRegexpOnce.Do(func() {
    32→		semverRegexp = regexp.MustCompile("^" + SemverRegexpRaw + "$")
    33→	})
    34→	return semverRegexp
    35→}
    37→// The raw regular expression string used for testing the validity
    38→// of a version.
    39→const (
    40→	VersionRegexpRaw string = `v?([0-9]+(\.[0-9]+)*?)` +
    41→		`(-([0-9]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)|(-?([A-Za-z\-~]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)))?` +
    42→		`(\+([0-9A-Za-z\-~]+(\.[0-9A-Za-z\-~]+)*))?` +
    43→		`?`
    44→
    45→	// SemverRegexpRaw requires a separator between version and prerelease
    46→	SemverRegexpRaw string = `v?([0-9]+(\.[0-9]+)*?)` +
    47→		`(-([0-9]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)|(-([A-Za-z\-~]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)))?` +
    48→		`(\+([0-9A-Za-z\-~]+(\.[0-9A-Za-z\-~]+)*))?` +
    49→		`?`
    50→)
    52→// Version represents a single version.
    53→type Version struct {
    54→	metadata string
    55→	pre      string
    56→	segments []int64
    57→	si       int
    58→	original string
    59→}
    61→// NewVersion parses the given version and returns a new
    62→// Version.
    63→func NewVersion(v string) (*Version, error) {
    64→	return newVersion(v, getVersionRegexp())
    65→}
    67→// NewSemver parses the given version and returns a new
    68→// Version that adheres strictly to SemVer specs
    69→// https://semver.org/
    70→func NewSemver(v string) (*Version, error) {
    71→	return newVersion(v, getSemverRegexp())
    72→}
    74→func newVersion(v string, pattern *regexp.Regexp) (*Version, error) {
    75→	matches := pattern.FindStringSubmatch(v)
    76→	if matches == nil {
    77→		return nil, fmt.Errorf("malformed version: %s", v)
    78→	}
    79→	segmentsStr := strings.Split(matches[1], ".")
    80→	segments := make([]int64, len(segmentsStr))
    81→	for i, str := range segmentsStr {
    82→		val, err := strconv.ParseInt(str, 10, 64)
    83→		if err != nil {
    84→			return nil, fmt.Errorf(
    85→				"error parsing version: %s", err)
    86→		}
    87→
    88→		segments[i] = val
    89→	}
      →…
   112→// Must is a helper that wraps a call to a function returning (*Version, error)
   113→// and panics if error is non-nil.
   114→func Must(v *Version, err error) *Version {
   115→	if err != nil {
   116→		panic(err)
   117→	}
   118→
   119→	return v
   120→}
   122→// Compare compares this version to another version. This
   123→// returns -1, 0, or 1 if this version is smaller, equal,
   124→// or larger than the other version, respectively.
   125→//
   126→// If you want boolean results, use the LessThan, Equal,
   127→// GreaterThan, GreaterThanOrEqual or LessThanOrEqual methods.
   128→func (v *Version) Compare(other *Version) int {
   129→	// A quick, efficient equality check
   130→	if v.String() == other.String() {
   131→		return 0
   132→	}
   133→
   134→	// If the segments are the same, we must compare on prerelease info
   135→	if v.equalSegments(other) {
   136→		preSelf := v.Prerelease()
   137→		preOther := other.Prerelease()
   138→		if preSelf == "" && preOther == "" {
   139→			return 0
   140→		}
   141→		if preSelf == "" {
   142→			return 1
   143→		}
   144→		if preOther == "" {
   145→			return -1
   146→		}
   147→
   148→		return comparePrereleases(preSelf, preOther)
   149→	}
   150→
   151→	segmentsSelf := v.Segments64()
   152→	segmentsOther := other.Segments64()
   153→	// Get the highest specificity (hS), or if they're equal, just use segmentSelf length
   154→	lenSelf := len(segmentsSelf)
   155→	lenOther := len(segmentsOther)
   156→	hS := lenSelf
   157→	if lenSelf < lenOther {
   158→		hS = lenOther
   159→	}
   160→	// Compare the segments
   161→	// Because a constraint could have more/less specificity than the version it's
   162→	// checking, we need to account for a lopsided or jagged comparison
   163→	for i := 0; i < hS; i++ {
   164→		if i > lenSelf-1 {
   165→			// This means Self had the lower specificity
   166→			// Check to see if the remaining segments in Other are all zeros
   167→			if !allZero(segmentsOther[i:]) {
   168→				// if not, it means that Other has to be greater than Self
   169→				return -1
   170→			}
   171→			break
   172→		} else if i > lenOther-1 {
   173→			// this means Other had the lower specificity
   174→			// Check to see if the remaining segments in Self are all zeros -
   175→			if !allZero(segmentsSelf[i:]) {
   176→				// if not, it means that Self has to be greater than Other
   177→				return 1
   178→			}
   179→			break
   180→		}
   181→		lhs := segmentsSelf[i]
   182→		rhs := segmentsOther[i]
   183→		if lhs == rhs {
   184→			continue
   185→		} else if lhs < rhs {
   186→			return -1
   187→		}
   188→		// Otherwise, rhs was > lhs, they're not equal
   189→		return 1
   190→	}
   191→
   192→	// if we got this far, they're equal
   193→	return 0
   194→}
   196→func (v *Version) equalSegments(other *Version) bool {
   197→	segmentsSelf := v.Segments64()
   198→	segmentsOther := other.Segments64()
   199→
   200→	if len(segmentsSelf) != len(segmentsOther) {
   201→		return false
   202→	}
   203→	for i, v := range segmentsSelf {
   204→		if v != segmentsOther[i] {
   205→			return false
   206→		}
   207→	}
   208→	return true
   209→}

   272ÔåÆ
   273ÔåÆ	// split both pre releases for analyse their parts
   274ÔåÆ	selfPreReleaseMeta := strings.Split(v, ".")
   275ÔåÆ	otherPreReleaseMeta := strings.Split(other, ".")
   276ÔåÆ
   277ÔåÆ	selfPreReleaseLen := len(selfPreReleaseMeta)
   278ÔåÆ	otherPreReleaseLen := len(otherPreReleaseMeta)
   279ÔåÆ
   280ÔåÆ	biggestLen := otherPreReleaseLen
   281ÔåÆ	if selfPreReleaseLen > otherPreReleaseLen {
   282ÔåÆ		biggestLen = selfPreReleaseLen
   283ÔåÆ	}
   284ÔåÆ
   285ÔåÆ	// loop for parts to find the first difference

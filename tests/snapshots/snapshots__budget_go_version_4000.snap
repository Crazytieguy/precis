   232ÔåÆ	var otherInt int64
   233ÔåÆ	otherNumeric := true
   234ÔåÆ	otherInt, err = strconv.ParseInt(preOther, 10, 64)
   235ÔåÆ	if err != nil {
   236ÔåÆ		otherNumeric = false

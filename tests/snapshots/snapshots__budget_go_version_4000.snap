     6→import (
     7→	"fmt"
     8→	"regexp"
     9→	"sort"
    10→	"strings"
    11→	"sync"
    12→)
    14→var (
    15→	constraintRegexp     *regexp.Regexp
    16→	constraintRegexpOnce sync.Once
    17→)
    19→func getConstraintRegexp() *regexp.Regexp {
    20→	constraintRegexpOnce.Do(func() {
    21→		// This heavy lifting only happens the first time this function is called
    22→		constraintRegexp = regexp.MustCompile(fmt.Sprintf(
    23→			`^\s*(%s)\s*(%s)\s*$`,
    24→			`<=|>=|!=|~>|<|>|=|`,
    25→			VersionRegexpRaw,
    26→		))
    27→	})
    28→	return constraintRegexp
    29→}
    31→// Constraint represents a single constraint for a version, such as
    32→// ">= 1.0".
    33→type Constraint struct {
    34→	f        constraintFunc
    35→	op       operator
    36→	check    *Version
    37→	original string
    38→}
    40→func (c *Constraint) Equals(con *Constraint) bool {
    41→	return c.op == con.op && c.check.Equal(con.check)
    42→}
    44→// Constraints is a slice of constraints. We make a custom type so that
    45→// we can add methods to it.
    46→type Constraints []*Constraint
    48→type constraintFunc func(v, c *Version) bool
    50→type constraintOperation struct {
    51→	op operator
    52→	f  constraintFunc
    53→}
    55→// NewConstraint will parse one or more constraints from the given
    56→// constraint string. The string must be a comma-separated list of
    57→// constraints.
    58→func NewConstraint(v string) (Constraints, error) {
    59→	vs := strings.Split(v, ",")
    60→	result := make([]*Constraint, len(vs))
    61→	for i, single := range vs {
    62→		c, err := parseSingle(single)
    63→		if err != nil {
    64→			return nil, err
    65→		}
    66→
    67→		result[i] = c
    68→	}
    69→
    70→	return Constraints(result), nil
    71→}
    73→// MustConstraints is a helper that wraps a call to a function
    74→// returning (Constraints, error) and panics if error is non-nil.
    75→func MustConstraints(c Constraints, err error) Constraints {
    76→	if err != nil {
    77→		panic(err)
    78→	}
    79→
    80→	return c
    81→}
    83→// Check tests if a version satisfies all the constraints.
    84→func (cs Constraints) Check(v *Version) bool {
    85→	for _, c := range cs {
    86→		if !c.Check(v) {
    87→			return false
    88→		}
    89→	}
    90→
    91→	return true
    92→}
    94→// Equals compares Constraints with other Constraints
    95→// for equality. This may not represent logical equivalence
    96→// of compared constraints.
    97→// e.g. even though '>0.1,>0.2' is logically equivalent
    98→// to '>0.2' it is *NOT* treated as equal.
    99→//
   100→// Missing operator is treated as equal to '=', whitespaces
   101→// are ignored and constraints are sorted before comparison.
   102→func (cs Constraints) Equals(c Constraints) bool {
   103→	if len(cs) != len(c) {
   104→		return false
   105→	}
   106→
   107→	// make copies to retain order of the original slices
   108→	left := make(Constraints, len(cs))
   109→	copy(left, cs)
   110→	sort.Stable(left)
   111→	right := make(Constraints, len(c))
   112→	copy(right, c)
   113→	sort.Stable(right)
   114→
   115→	// compare sorted slices
   116→	for i, con := range left {
   117→		if !con.Equals(right[i]) {
   118→			return false
   119→		}
   120→	}
   121→
   122→	return true
   123→}
   125→func (cs Constraints) Len() int {
   126→	return len(cs)
   127→}
   129→func (cs Constraints) Less(i, j int) bool {
   130→	if cs[i].op < cs[j].op {
   131→		return true
   132→	}
   133→	if cs[i].op > cs[j].op {
   134→		return false
   135→	}
   136→
   137→	return cs[i].check.LessThan(cs[j].check)
   138→}
   140→func (cs Constraints) Swap(i, j int) {
   141→	cs[i], cs[j] = cs[j], cs[i]
   142→}
   144→// Returns the string format of the constraints
   145→func (cs Constraints) String() string {
   146→	csStr := make([]string, len(cs))
   147→	for i, c := range cs {
   148→		csStr[i] = c.String()
   149→	}
   150→
   151→	return strings.Join(csStr, ",")
   152→}
   154→// Check tests if a constraint is validated by the given version.
   155→func (c *Constraint) Check(v *Version) bool {
   156→	return c.f(v, c.check)
   157→}
   159→// Prerelease returns true if the version underlying this constraint
   160→// contains a prerelease field.
   161→func (c *Constraint) Prerelease() bool {
   162→	return len(c.check.Prerelease()) > 0
   163→}
   165→func (c *Constraint) String() string {
   166→	return c.original
   167→}
   169→func parseSingle(v string) (*Constraint, error) {
   170→	matches := getConstraintRegexp().FindStringSubmatch(v)
   171→	if matches == nil {
   172→		return nil, fmt.Errorf("malformed constraint: %s", v)
   173→	}
   174→
   175→	check, err := NewVersion(matches[2])
   176→	if err != nil {
   177→		return nil, err
   178→	}
   179→
   180→	var cop constraintOperation
   181→	switch matches[1] {
   182→	case "=":
   183→		cop = constraintOperation{op: equal, f: constraintEqual}
   184→	case "!=":
      →…
   208→func prereleaseCheck(v, c *Version) bool {
   209→	switch vPre, cPre := v.Prerelease() != "", c.Prerelease() != ""; {
   210→	case cPre && vPre:
   211→		// A constraint with a pre-release can only match a pre-release version
   212→		// with the same base segments.
   213→		return v.equalSegments(c)
   214→
   215→	case !cPre && vPre:
   216→		// A constraint without a pre-release can only match a version without a
   217→		// pre-release.
   218→		return false
   219→
   220→	case cPre && !vPre:
   221→		// OK, except with the pessimistic operator
   222→	case !cPre && !vPre:
   223→		// OK
      →…
   228→//-------------------------------------------------------------------
   229→// Constraint functions
   230→//-------------------------------------------------------------------
   231→
   232→type operator rune
   234→const (
   235→	equal            operator = '='
   236→	notEqual         operator = '≠'
   237→	greaterThan      operator = '>'
   238→	lessThan         operator = '<'
   239→	greaterThanEqual operator = '≥'
   240→	lessThanEqual    operator = '≤'
   241→	pessimistic      operator = '~'
   242→)
   244→func constraintEqual(v, c *Version) bool {
   245→	return v.Equal(c)
   246→}
   248→func constraintNotEqual(v, c *Version) bool {
   249→	return !v.Equal(c)
   250→}
   252→func constraintGreaterThan(v, c *Version) bool {
   253→	return prereleaseCheck(v, c) && v.Compare(c) == 1
   254→}
   256→func constraintLessThan(v, c *Version) bool {
   257→	return prereleaseCheck(v, c) && v.Compare(c) == -1
   258→}
   260→func constraintGreaterThanEqual(v, c *Version) bool {
   261→	return prereleaseCheck(v, c) && v.Compare(c) >= 0
   262→}
   264→func constraintLessThanEqual(v, c *Version) bool {
   265→	return prereleaseCheck(v, c) && v.Compare(c) <= 0
   266→}
   268→func constraintPessimistic(v, c *Version) bool {
   269→	// Using a pessimistic constraint with a pre-release, restricts versions to pre-releases
   270→	if !prereleaseCheck(v, c) || (c.Prerelease() != "" && v.Prerelease() == "") {
   271→		return false
   272→	}
   273→
   274→	// If the version being checked is naturally less than the constraint, then there
   275→	// is no way for the version to be valid against the constraint
   276→	if v.LessThan(c) {
   277→		return false
   278→	}
   279→	// We'll use this more than once, so grab the length now so it's a little cleaner
   280→	// to write the later checks
   281→	cs := len(c.segments)
   282→

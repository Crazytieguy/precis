   307ÔåÆ// Core returns a new version constructed from only the MAJOR.MINOR.PATCH
   308ÔåÆ// segments of the version, without prerelease or metadata.
   309ÔåÆfunc (v *Version) Core() *Version {
   310ÔåÆ	segments := v.Segments64()
   311ÔåÆ	segmentsOnly := fmt.Sprintf("%d.%d.%d", segments[0], segments[1], segments[2])
   312ÔåÆ	return Must(NewVersion(segmentsOnly))
   313ÔåÆ}
   315ÔåÆ// Equal tests if two versions are equal.
   316ÔåÆfunc (v *Version) Equal(o *Version) bool {
   317ÔåÆ	if v == nil || o == nil {
   318ÔåÆ		return v == o
   319ÔåÆ	}
   320ÔåÆ
   321ÔåÆ	return v.Compare(o) == 0
   322ÔåÆ}
   324ÔåÆ// GreaterThan tests if this version is greater than another version.
   325ÔåÆfunc (v *Version) GreaterThan(o *Version) bool {
   326ÔåÆ	return v.Compare(o) > 0
   327ÔåÆ}
   329ÔåÆ// GreaterThanOrEqual tests if this version is greater than or equal to another version.
   330ÔåÆfunc (v *Version) GreaterThanOrEqual(o *Version) bool {
   331ÔåÆ	return v.Compare(o) >= 0
   332ÔåÆ}
   334ÔåÆ// LessThan tests if this version is less than another version.
   335ÔåÆfunc (v *Version) LessThan(o *Version) bool {
   336ÔåÆ	return v.Compare(o) < 0
   337ÔåÆ}
   339ÔåÆ// LessThanOrEqual tests if this version is less than or equal to another version.
   340ÔåÆfunc (v *Version) LessThanOrEqual(o *Version) bool {
   341ÔåÆ	return v.Compare(o) <= 0
   342ÔåÆ}
   344ÔåÆ// Metadata returns any metadata that was part of the version
   345ÔåÆ// string.
   346ÔåÆ//
   347ÔåÆ// Metadata is anything that comes after the "+" in the version.
   348ÔåÆ// For example, with "1.2.3+beta", the metadata is "beta".
   349ÔåÆfunc (v *Version) Metadata() string {
   350ÔåÆ	return v.metadata
   351ÔåÆ}
   353ÔåÆ// Prerelease returns any prerelease data that is part of the version,
   354ÔåÆ// or blank if there is no prerelease data.
   355ÔåÆ//
   356ÔåÆ// Prerelease information is anything that comes after the "-" in the
   357ÔåÆ// version (but before any metadata). For example, with "1.2.3-beta",
   358ÔåÆ// the prerelease information is "beta".
   359ÔåÆfunc (v *Version) Prerelease() string {
   360ÔåÆ	return v.pre
   361ÔåÆ}
   363ÔåÆ// Segments returns the numeric segments of the version as a slice of ints.
   364ÔåÆ//
   365ÔåÆ// This excludes any metadata or pre-release information. For example,
   366ÔåÆ// for a version "1.2.3-beta", segments will return a slice of
   367ÔåÆ// 1, 2, 3.
   368ÔåÆfunc (v *Version) Segments() []int {
   369ÔåÆ	segmentSlice := make([]int, len(v.segments))
   370ÔåÆ	for i, v := range v.segments {
   371ÔåÆ		segmentSlice[i] = int(v)
   372ÔåÆ	}
   373ÔåÆ	return segmentSlice
   374ÔåÆ}
   376ÔåÆ// Segments64 returns the numeric segments of the version as a slice of int64s.
   377ÔåÆ//
   378ÔåÆ// This excludes any metadata or pre-release information. For example,
   379ÔåÆ// for a version "1.2.3-beta", segments will return a slice of
   380ÔåÆ// 1, 2, 3.
   381ÔåÆfunc (v *Version) Segments64() []int64 {
   382ÔåÆ	result := make([]int64, len(v.segments))
   383ÔåÆ	copy(result, v.segments)
   384ÔåÆ	return result
   385ÔåÆ}
   387ÔåÆ// String returns the full version string included pre-release
   388ÔåÆ// and metadata information.
   389ÔåÆ//
   390ÔåÆ// This value is rebuilt according to the parsed segments and other
   391ÔåÆ// information. Therefore, ambiguities in the version string such as
   392ÔåÆ// prefixed zeroes (1.04.0 => 1.4.0), `v` prefix (v1.0.0 => 1.0.0), and
   393ÔåÆ// missing parts (1.0 => 1.0.0) will be made into a canonicalized form
   394ÔåÆ// as shown in the parenthesized examples.
   395ÔåÆfunc (v *Version) String() string {
   396ÔåÆ	return string(v.bytes())
   397ÔåÆ}
   399ÔåÆfunc (v *Version) bytes() []byte {
   400ÔåÆ	var buf []byte
   401ÔåÆ	for i, s := range v.segments {
   402ÔåÆ		if i > 0 {
   403ÔåÆ			buf = append(buf, '.')
   404ÔåÆ		}
   405ÔåÆ		buf = strconv.AppendInt(buf, s, 10)
   406ÔåÆ	}
   407ÔåÆ
   408ÔåÆ	if v.pre != "" {
   409ÔåÆ		buf = append(buf, '-')
   410ÔåÆ		buf = append(buf, v.pre...)
   411ÔåÆ	}
   412ÔåÆ
   413ÔåÆ	if v.metadata != "" {
   414ÔåÆ		buf = append(buf, '+')
   415ÔåÆ		buf = append(buf, v.metadata...)
   416ÔåÆ	}
   417ÔåÆ

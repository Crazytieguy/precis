README.md
     1ÔåÆ# Versioning Library for Go
     6ÔåÆgo-version is a library for parsing versions and version constraints,
     7ÔåÆand verifying versions against a set of constraints. go-version
     8ÔåÆcan sort a collection of versions properly, handles prerelease/beta
     9ÔåÆversions, can increment versions, etc.
    10ÔåÆ
    11ÔåÆVersions used with go-version must follow [SemVer](http://semver.org/).
    12ÔåÆ
    13ÔåÆ## Installation and Usage
    15ÔåÆPackage documentation can be found on
    16ÔåÆ[Go Reference](https://pkg.go.dev/github.com/hashicorp/go-version).
    17ÔåÆ
    18ÔåÆInstallation can be done with a normal `go get`:
    19ÔåÆ
    20ÔåÆ```
    21ÔåÆ$ go get github.com/hashicorp/go-version
    22ÔåÆ```
    23ÔåÆ
    24ÔåÆ#### Version Parsing and Comparison
    26ÔåÆ```go
    27ÔåÆv1, err := version.NewVersion("1.2")
    28ÔåÆv2, err := version.NewVersion("1.5+metadata")
    29ÔåÆ
    30ÔåÆ// Comparison example. There is also GreaterThan, Equal, and just
    31ÔåÆ// a simple Compare that returns an int allowing easy >=, <=, etc.
    32ÔåÆif v1.LessThan(v2) {
    33ÔåÆ    fmt.Printf("%s is less than %s", v1, v2)
    34ÔåÆ}
    35ÔåÆ```
    36ÔåÆ
    37ÔåÆ#### Version Constraints
    39ÔåÆ```go
    40ÔåÆv1, err := version.NewVersion("1.2")
    41ÔåÆ
    42ÔåÆ// Constraints example.
    43ÔåÆconstraints, err := version.NewConstraint(">= 1.0, < 1.4")
    44ÔåÆif constraints.Check(v1) {
    45ÔåÆ	fmt.Printf("%s satisfies constraints %s", v1, constraints)
    46ÔåÆ}
    47ÔåÆ```
    48ÔåÆ
    49ÔåÆ#### Version Sorting
    51ÔåÆ```go
    52ÔåÆversionsRaw := []string{"1.1", "0.7.1", "1.4-beta", "1.4", "2"}
    53ÔåÆversions := make([]*version.Version, len(versionsRaw))
    54ÔåÆfor i, raw := range versionsRaw {
    55ÔåÆ    v, _ := version.NewVersion(raw)
    56ÔåÆ    versions[i] = v
    57ÔåÆ}
    58ÔåÆ
    59ÔåÆ// After this, the versions are properly sorted
    60ÔåÆsort.Sort(version.Collection(versions))
    61ÔåÆ```
    62ÔåÆ
    63ÔåÆ## Issues and Contributing
    65ÔåÆIf you find an issue with this library, please report an issue. If you'd
    66ÔåÆlike, we welcome any contributions. Fork this library and submit a pull
    67ÔåÆrequest.

constraint.go
     6ÔåÆimport (
     7ÔåÆ	"fmt"
     8ÔåÆ	"regexp"
     9ÔåÆ	"sort"
    10ÔåÆ	"strings"
    11ÔåÆ	"sync"
    12ÔåÆ)
    14ÔåÆvar (
    15ÔåÆ	constraintRegexp     *regexp.Regexp
    16ÔåÆ	constraintRegexpOnce sync.Once
    19ÔåÆfunc getConstraintRegexp() *regexp.Regexp {
    20ÔåÆ	constraintRegexpOnce.Do(func() {
    21ÔåÆ		// This heavy lifting only happens the first time this function is called
    22ÔåÆ		constraintRegexp = regexp.MustCompile(fmt.Sprintf(
    23ÔåÆ			`^\s*(%s)\s*(%s)\s*$`,
    24ÔåÆ			`<=|>=|!=|~>|<|>|=|`,
    25ÔåÆ			VersionRegexpRaw,
    26ÔåÆ		))
    27ÔåÆ	})
    28ÔåÆ	return constraintRegexp
    29ÔåÆ}
    31ÔåÆ// Constraint represents a single constraint for a version, such as
    32ÔåÆ// ">= 1.0".
    33ÔåÆtype Constraint struct {
    34ÔåÆ	f        constraintFunc
    35ÔåÆ	op       operator
    36ÔåÆ	check    *Version
    37ÔåÆ	original string
    38ÔåÆ}
    40ÔåÆfunc (c *Constraint) Equals(con *Constraint) bool {
    41ÔåÆ	return c.op == con.op && c.check.Equal(con.check)
    42ÔåÆ}
    44ÔåÆ// Constraints is a slice of constraints. We make a custom type so that
    45ÔåÆ// we can add methods to it.
    46ÔåÆtype Constraints []*Constraint
    48ÔåÆtype constraintFunc func(v, c *Version) bool
    50ÔåÆtype constraintOperation struct {
    51ÔåÆ	op operator
    52ÔåÆ	f  constraintFunc
    53ÔåÆ}
    55ÔåÆ// NewConstraint will parse one or more constraints from the given
    56ÔåÆ// constraint string. The string must be a comma-separated list of
    57ÔåÆ// constraints.
    58ÔåÆfunc NewConstraint(v string) (Constraints, error) {
    59ÔåÆ	vs := strings.Split(v, ",")
    60ÔåÆ	result := make([]*Constraint, len(vs))
    61ÔåÆ	for i, single := range vs {
    62ÔåÆ		c, err := parseSingle(single)
    63ÔåÆ		if err != nil {
    64ÔåÆ			return nil, err
    65ÔåÆ		}
    66ÔåÆ
    67ÔåÆ		result[i] = c
    68ÔåÆ	}
    69ÔåÆ
    70ÔåÆ	return Constraints(result), nil
    71ÔåÆ}
    73ÔåÆ// MustConstraints is a helper that wraps a call to a function
    74ÔåÆ// returning (Constraints, error) and panics if error is non-nil.
    75ÔåÆfunc MustConstraints(c Constraints, err error) Constraints {
    76ÔåÆ	if err != nil {
    77ÔåÆ		panic(err)
    78ÔåÆ	}
    79ÔåÆ
    80ÔåÆ	return c
    81ÔåÆ}
    83ÔåÆ// Check tests if a version satisfies all the constraints.
    84ÔåÆfunc (cs Constraints) Check(v *Version) bool {
    85ÔåÆ	for _, c := range cs {
    86ÔåÆ		if !c.Check(v) {
    87ÔåÆ			return false
    88ÔåÆ		}
    89ÔåÆ	}
    90ÔåÆ
    91ÔåÆ	return true
    92ÔåÆ}
    94ÔåÆ// Equals compares Constraints with other Constraints
    95ÔåÆ// for equality. This may not represent logical equivalence
    96ÔåÆ// of compared constraints.
    97ÔåÆ// e.g. even though '>0.1,>0.2' is logically equivalent
    98ÔåÆ// to '>0.2' it is *NOT* treated as equal.
    99ÔåÆ//
   100ÔåÆ// Missing operator is treated as equal to '=', whitespaces
   101ÔåÆ// are ignored and constraints are sorted before comparison.
   102ÔåÆfunc (cs Constraints) Equals(c Constraints) bool {
   103ÔåÆ	if len(cs) != len(c) {
   104ÔåÆ		return false
   105ÔåÆ	}
   106ÔåÆ
   107ÔåÆ	// make copies to retain order of the original slices
   108ÔåÆ	left := make(Constraints, len(cs))
   109ÔåÆ	copy(left, cs)
   110ÔåÆ	sort.Stable(left)
   111ÔåÆ	right := make(Constraints, len(c))
   112ÔåÆ	copy(right, c)
   113ÔåÆ	sort.Stable(right)
   114ÔåÆ
   115ÔåÆ	// compare sorted slices
   116ÔåÆ	for i, con := range left {
   117ÔåÆ		if !con.Equals(right[i]) {
   118ÔåÆ			return false
   119ÔåÆ		}
   120ÔåÆ	}
   121ÔåÆ
   122ÔåÆ	return true
   123ÔåÆ}
   125ÔåÆfunc (cs Constraints) Len() int {
   126ÔåÆ	return len(cs)
   127ÔåÆ}
   129ÔåÆfunc (cs Constraints) Less(i, j int) bool {
   130ÔåÆ	if cs[i].op < cs[j].op {
   131ÔåÆ		return true
   132ÔåÆ	}
   133ÔåÆ	if cs[i].op > cs[j].op {
   134ÔåÆ		return false
   135ÔåÆ	}
   136ÔåÆ
   137ÔåÆ	return cs[i].check.LessThan(cs[j].check)
   138ÔåÆ}
   140ÔåÆfunc (cs Constraints) Swap(i, j int) {
   141ÔåÆ	cs[i], cs[j] = cs[j], cs[i]
   142ÔåÆ}
   144ÔåÆ// Returns the string format of the constraints
   145ÔåÆfunc (cs Constraints) String() string {
   146ÔåÆ	csStr := make([]string, len(cs))
   147ÔåÆ	for i, c := range cs {
   148ÔåÆ		csStr[i] = c.String()
   149ÔåÆ	}
   150ÔåÆ
   151ÔåÆ	return strings.Join(csStr, ",")
   152ÔåÆ}
   154ÔåÆ// Check tests if a constraint is validated by the given version.
   155ÔåÆfunc (c *Constraint) Check(v *Version) bool {
   156ÔåÆ	return c.f(v, c.check)
   157ÔåÆ}
   159ÔåÆ// Prerelease returns true if the version underlying this constraint
   160ÔåÆ// contains a prerelease field.
   161ÔåÆfunc (c *Constraint) Prerelease() bool {
   162ÔåÆ	return len(c.check.Prerelease()) > 0
   163ÔåÆ}
   165ÔåÆfunc (c *Constraint) String() string {
   166ÔåÆ	return c.original
   167ÔåÆ}
   169ÔåÆfunc parseSingle(v string) (*Constraint, error) {
   170ÔåÆ	matches := getConstraintRegexp().FindStringSubmatch(v)
   171ÔåÆ	if matches == nil {
   172ÔåÆ		return nil, fmt.Errorf("malformed constraint: %s", v)
   173ÔåÆ	}
   174ÔåÆ
   175ÔåÆ	check, err := NewVersion(matches[2])
   176ÔåÆ	if err != nil {
   177ÔåÆ		return nil, err
   178ÔåÆ	}
   179ÔåÆ
   180ÔåÆ	var cop constraintOperation
   181ÔåÆ	switch matches[1] {
   182ÔåÆ	case "=":
   183ÔåÆ		cop = constraintOperation{op: equal, f: constraintEqual}
   184ÔåÆ	case "!=":
   185ÔåÆ		cop = constraintOperation{op: notEqual, f: constraintNotEqual}
   186ÔåÆ	case ">":
   187ÔåÆ		cop = constraintOperation{op: greaterThan, f: constraintGreaterThan}
      ÔåÆÔÇĞ
   208ÔåÆfunc prereleaseCheck(v, c *Version) bool {
   209ÔåÆ	switch vPre, cPre := v.Prerelease() != "", c.Prerelease() != ""; {
   210ÔåÆ	case cPre && vPre:
   211ÔåÆ		// A constraint with a pre-release can only match a pre-release version
   212ÔåÆ		// with the same base segments.
   213ÔåÆ		return v.equalSegments(c)
   214ÔåÆ
   215ÔåÆ	case !cPre && vPre:
   216ÔåÆ		// A constraint without a pre-release can only match a version without a
   217ÔåÆ		// pre-release.
   218ÔåÆ		return false
   219ÔåÆ
   220ÔåÆ	case cPre && !vPre:
   221ÔåÆ		// OK, except with the pessimistic operator
   222ÔåÆ	case !cPre && !vPre:
   223ÔåÆ		// OK
   224ÔåÆ	}
   225ÔåÆ	return true
   226ÔåÆ}
   228ÔåÆ//-------------------------------------------------------------------
   229ÔåÆ// Constraint functions
   230ÔåÆ//-------------------------------------------------------------------
   231ÔåÆ
   232ÔåÆtype operator rune
   234ÔåÆconst (
   235ÔåÆ	equal            operator = '='
   236ÔåÆ	notEqual         operator = 'Ôëá'
   237ÔåÆ	greaterThan      operator = '>'
   238ÔåÆ	lessThan         operator = '<'
   239ÔåÆ	greaterThanEqual operator = 'ÔëÑ'
   240ÔåÆ	lessThanEqual    operator = 'Ôëñ'
   241ÔåÆ	pessimistic      operator = '~'
   244ÔåÆfunc constraintEqual(v, c *Version) bool {
   245ÔåÆ	return v.Equal(c)
   246ÔåÆ}
   248ÔåÆfunc constraintNotEqual(v, c *Version) bool {
   249ÔåÆ	return !v.Equal(c)
   250ÔåÆ}
   252ÔåÆfunc constraintGreaterThan(v, c *Version) bool {
   253ÔåÆ	return prereleaseCheck(v, c) && v.Compare(c) == 1
   254ÔåÆ}
   256ÔåÆfunc constraintLessThan(v, c *Version) bool {
   257ÔåÆ	return prereleaseCheck(v, c) && v.Compare(c) == -1
   258ÔåÆ}
   260ÔåÆfunc constraintGreaterThanEqual(v, c *Version) bool {
   261ÔåÆ	return prereleaseCheck(v, c) && v.Compare(c) >= 0
   262ÔåÆ}
   264ÔåÆfunc constraintLessThanEqual(v, c *Version) bool {
   265ÔåÆ	return prereleaseCheck(v, c) && v.Compare(c) <= 0
   266ÔåÆ}
   268ÔåÆfunc constraintPessimistic(v, c *Version) bool {
   269ÔåÆ	// Using a pessimistic constraint with a pre-release, restricts versions to pre-releases
   270ÔåÆ	if !prereleaseCheck(v, c) || (c.Prerelease() != "" && v.Prerelease() == "") {
   271ÔåÆ		return false
   272ÔåÆ	}
   273ÔåÆ

   421ÔåÆ// Original returns the original parsed version as-is, including any
   422ÔåÆ// potential whitespace, `v` prefix, etc.
   423ÔåÆfunc (v *Version) Original() string {
   424ÔåÆ	return v.original
   425ÔåÆ}
   427ÔåÆ// UnmarshalText implements encoding.TextUnmarshaler interface.
   428ÔåÆfunc (v *Version) UnmarshalText(b []byte) error {
   429ÔåÆ	temp, err := NewVersion(string(b))
   430ÔåÆ	if err != nil {
   431ÔåÆ		return err
   432ÔåÆ	}
   433ÔåÆ
   434ÔåÆ	*v = *temp
   435ÔåÆ
   436ÔåÆ	return nil
   437ÔåÆ}
   439ÔåÆ// MarshalText implements encoding.TextMarshaler interface.
   440ÔåÆfunc (v *Version) MarshalText() ([]byte, error) {
   441ÔåÆ	return []byte(v.String()), nil
   442ÔåÆ}
   444ÔåÆ// Scan implements the sql.Scanner interface.
   445ÔåÆfunc (v *Version) Scan(src interface{}) error {
   446ÔåÆ	switch src := src.(type) {
   447ÔåÆ	case string:
   448ÔåÆ		return v.UnmarshalText([]byte(src))
   449ÔåÆ	case nil:
   450ÔåÆ		return nil
   451ÔåÆ	default:
   452ÔåÆ		return fmt.Errorf("cannot scan %T as Version", src)
   453ÔåÆ	}
   454ÔåÆ}
   456ÔåÆ// Value implements the driver.Valuer interface.
   457ÔåÆfunc (v *Version) Value() (driver.Value, error) {
   458ÔåÆ	return v.String(), nil
   459ÔåÆ}

version_collection.go
     6ÔåÆ// Collection is a type that implements the sort.Interface interface
     7ÔåÆ// so that versions can be sorted.
     8ÔåÆtype Collection []*Version
    10ÔåÆfunc (v Collection) Len() int {
    11ÔåÆ	return len(v)
    12ÔåÆ}
    14ÔåÆfunc (v Collection) Less(i, j int) bool {
    15ÔåÆ	return v[i].LessThan(v[j])
    16ÔåÆ}
    18ÔåÆfunc (v Collection) Swap(i, j int) {
    19ÔåÆ	v[i], v[j] = v[j], v[i]
    20ÔåÆ}


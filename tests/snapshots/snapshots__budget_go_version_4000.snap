    19вҶ’func getConstraintRegexp() *regexp.Regexp {
    31вҶ’// Constraint represents a single constraint for a version, such as
    32вҶ’// ">= 1.0".
    33вҶ’type Constraint struct {
    34вҶ’	f        constraintFunc
    35вҶ’	op       operator
    36вҶ’	check    *Version
    37вҶ’	original string
    38вҶ’}
    40вҶ’func (c *Constraint) Equals(con *Constraint) bool {
    41вҶ’	return c.op == con.op && c.check.Equal(con.check)
    42вҶ’}
    44вҶ’// Constraints is a slice of constraints. We make a custom type so that
    45вҶ’// we can add methods to it.
    46вҶ’type Constraints []*Constraint
    48вҶ’type constraintFunc func(v, c *Version) bool
    50вҶ’type constraintOperation struct {
    51вҶ’	op operator
    52вҶ’	f  constraintFunc
    53вҶ’}
    55вҶ’// NewConstraint will parse one or more constraints from the given
    56вҶ’// constraint string. The string must be a comma-separated list of
    57вҶ’// constraints.
    58вҶ’func NewConstraint(v string) (Constraints, error) {
    59вҶ’	vs := strings.Split(v, ",")
    60вҶ’	result := make([]*Constraint, len(vs))
    61вҶ’	for i, single := range vs {
    62вҶ’		c, err := parseSingle(single)
    63вҶ’		if err != nil {
    64вҶ’			return nil, err
    65вҶ’		}
    66вҶ’
    67вҶ’		result[i] = c
    68вҶ’	}
    69вҶ’
    70вҶ’	return Constraints(result), nil
    71вҶ’}
    73вҶ’// MustConstraints is a helper that wraps a call to a function
    74вҶ’// returning (Constraints, error) and panics if error is non-nil.
    75вҶ’func MustConstraints(c Constraints, err error) Constraints {
    76вҶ’	if err != nil {
    77вҶ’		panic(err)
    78вҶ’	}
    79вҶ’
    80вҶ’	return c
    81вҶ’}
    83вҶ’// Check tests if a version satisfies all the constraints.
    84вҶ’func (cs Constraints) Check(v *Version) bool {
    85вҶ’	for _, c := range cs {
    86вҶ’		if !c.Check(v) {
    87вҶ’			return false
    88вҶ’		}
    89вҶ’	}
    90вҶ’
    91вҶ’	return true
    92вҶ’}
    94вҶ’// Equals compares Constraints with other Constraints
    95вҶ’// for equality. This may not represent logical equivalence
    96вҶ’// of compared constraints.
    97вҶ’// e.g. even though '>0.1,>0.2' is logically equivalent
    98вҶ’// to '>0.2' it is *NOT* treated as equal.
    99вҶ’//
   100вҶ’// Missing operator is treated as equal to '=', whitespaces
   101вҶ’// are ignored and constraints are sorted before comparison.
   102вҶ’func (cs Constraints) Equals(c Constraints) bool {
   103вҶ’	if len(cs) != len(c) {
   104вҶ’		return false
   105вҶ’	}
   106вҶ’
   107вҶ’	// make copies to retain order of the original slices
   108вҶ’	left := make(Constraints, len(cs))
   109вҶ’	copy(left, cs)
   110вҶ’	sort.Stable(left)
   111вҶ’	right := make(Constraints, len(c))
   112вҶ’	copy(right, c)
   113вҶ’	sort.Stable(right)
   114вҶ’
   115вҶ’	// compare sorted slices
   116вҶ’	for i, con := range left {
   117вҶ’		if !con.Equals(right[i]) {
   118вҶ’			return false
   119вҶ’		}
   120вҶ’	}
   121вҶ’
   122вҶ’	return true
   123вҶ’}
   125вҶ’func (cs Constraints) Len() int {
   126вҶ’	return len(cs)
   127вҶ’}
   129вҶ’func (cs Constraints) Less(i, j int) bool {
   130вҶ’	if cs[i].op < cs[j].op {
   131вҶ’		return true
   132вҶ’	}
   133вҶ’	if cs[i].op > cs[j].op {
   134вҶ’		return false
   135вҶ’	}
   136вҶ’
   137вҶ’	return cs[i].check.LessThan(cs[j].check)
   138вҶ’}
   140вҶ’func (cs Constraints) Swap(i, j int) {
   141вҶ’	cs[i], cs[j] = cs[j], cs[i]
   142вҶ’}
   144вҶ’// Returns the string format of the constraints
   145вҶ’func (cs Constraints) String() string {
   146вҶ’	csStr := make([]string, len(cs))
   147вҶ’	for i, c := range cs {
   148вҶ’		csStr[i] = c.String()
   149вҶ’	}
   150вҶ’
   151вҶ’	return strings.Join(csStr, ",")
   152вҶ’}
   154вҶ’// Check tests if a constraint is validated by the given version.
   155вҶ’func (c *Constraint) Check(v *Version) bool {
   156вҶ’	return c.f(v, c.check)
   157вҶ’}
   159вҶ’// Prerelease returns true if the version underlying this constraint
   160вҶ’// contains a prerelease field.
   161вҶ’func (c *Constraint) Prerelease() bool {
   162вҶ’	return len(c.check.Prerelease()) > 0
   163вҶ’}
   165вҶ’func (c *Constraint) String() string {
   166вҶ’	return c.original
   167вҶ’}

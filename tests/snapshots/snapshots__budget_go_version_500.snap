    15‚Üí// The compiled regular expression used to test the validity of a version.
    16‚Üívar (
    17‚Üí	versionRegexp     *regexp.Regexp
    18‚Üí	versionRegexpOnce sync.Once
    37‚Üí// The raw regular expression string used for testing the validity
    38‚Üí// of a version.
    39‚Üíconst (
    40‚Üí	VersionRegexpRaw string = `v?([0-9]+(\.[0-9]+)*?)` +
    41‚Üí		`(-([0-9]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)|(-?([A-Za-z\-~]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)))?` +
    45‚Üí	// SemverRegexpRaw requires a separator between version and prerelease
    46‚Üí	SemverRegexpRaw string = `v?([0-9]+(\.[0-9]+)*?)` +
    47‚Üí		`(-([0-9]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)|(-([A-Za-z\-~]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)))?` +
    48‚Üí		`(\+([0-9A-Za-z\-~]+(\.[0-9A-Za-z\-~]+)*))?` +
    49‚Üí		`?`
    52‚Üí// Version represents a single version.
    53‚Üítype Version struct {
    54‚Üí	metadata string
    55‚Üí	pre      string
    56‚Üí	segments []int64
    57‚Üí	si       int
    58‚Üí	original string
    59‚Üí}
version_collection.go
     6‚Üí// Collection is a type that implements the sort.Interface interface
     7‚Üí// so that versions can be sorted.
     8‚Üítype Collection []*Version
    10‚Üífunc (v Collection) Len() int {
    11‚Üí	return len(v)
    12‚Üí}
    14‚Üífunc (v Collection) Less(i, j int) bool {
    15‚Üí	return v[i].LessThan(v[j])
    16‚Üí}
    18‚Üífunc (v Collection) Swap(i, j int) {
    19‚Üí	v[i], v[j] = v[j], v[i]
    20‚Üí}

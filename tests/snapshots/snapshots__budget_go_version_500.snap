constraint.go
    31â†’// Constraint represents a single constraint for a version, such as
    32â†’// ">= 1.0".
    33â†’type Constraint struct {
    34â†’	f        constraintFunc
    35â†’	op       operator
    36â†’	check    *Version
    37â†’	original string
    38â†’}
    40â†’func (c *Constraint) Equals(con *Constraint) bool {
    41â†’	return c.op == con.op && c.check.Equal(con.check)
    42â†’}
    44â†’// Constraints is a slice of constraints. We make a custom type so that
    45â†’// we can add methods to it.
    46â†’type Constraints []*Constraint
    50â†’type constraintOperation struct {
    51â†’	op operator
    52â†’	f  constraintFunc
    53â†’}
   125â†’func (cs Constraints) Len() int {
   126â†’	return len(cs)
   127â†’}
   129â†’func (cs Constraints) Less(i, j int) bool {
   130â†’	if cs[i].op < cs[j].op {
   131â†’		return true
   132â†’	}
   133â†’	if cs[i].op > cs[j].op {
   134â†’		return false
   135â†’	}
   136â†’
   137â†’	return cs[i].check.LessThan(cs[j].check)
   138â†’}
   140â†’func (cs Constraints) Swap(i, j int) {
   141â†’	cs[i], cs[j] = cs[j], cs[i]
   142â†’}
   165â†’func (c *Constraint) String() string {
   166â†’	return c.original
   167â†’}

    15â†’// The compiled regular expression used to test the validity of a version.
    16â†’var (
    17â†’	versionRegexp     *regexp.Regexp
    18â†’	versionRegexpOnce sync.Once
    19â†’	semverRegexp      *regexp.Regexp
    20â†’	semverRegexpOnce  sync.Once
    21â†’)
    37â†’// The raw regular expression string used for testing the validity
    38â†’// of a version.
    39â†’const (
    40â†’	VersionRegexpRaw string = `v?([0-9]+(\.[0-9]+)*?)` +
    41â†’		`(-([0-9]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)|(-?([A-Za-z\-~]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)))?` +
    42â†’		`(\+([0-9A-Za-z\-~]+(\.[0-9A-Za-z\-~]+)*))?` +
    43â†’		`?`
    44â†’
    45â†’	// SemverRegexpRaw requires a separator between version and prerelease
    46â†’	SemverRegexpRaw string = `v?([0-9]+(\.[0-9]+)*?)` +
    47â†’		`(-([0-9]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)|(-([A-Za-z\-~]+[0-9A-Za-z\-~]*(\.[0-9A-Za-z\-~]+)*)))?` +
    48â†’		`(\+([0-9A-Za-z\-~]+(\.[0-9A-Za-z\-~]+)*))?` +
    49â†’		`?`
    52â†’// Version represents a single version.
    53â†’type Version struct {
    54â†’	metadata string
    55â†’	pre      string
    56â†’	segments []int64
    57â†’	si       int
    58â†’	original string
    59â†’}
version_collection.go
     6â†’// Collection is a type that implements the sort.Interface interface
     7â†’// so that versions can be sorted.
     8â†’type Collection []*Version
    10â†’func (v Collection) Len() int {
    11â†’	return len(v)
    12â†’}
    14â†’func (v Collection) Less(i, j int) bool {
    15â†’	return v[i].LessThan(v[j])
    16â†’}
    18â†’func (v Collection) Swap(i, j int) {
    19â†’	v[i], v[j] = v[j], v[i]
    20â†’}

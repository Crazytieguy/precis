    34→def ordinal(value: NumberOrString, gender: str = "male") -> str:
    35→    """Converts an integer to its ordinal as a string.
    36→
    37→    For example, 1 is "1st", 2 is "2nd", 3 is "3rd", etc. Works for any integer or
    38→    anything `int()` will turn into an integer. Anything else will return the output
    39→    of str(value).
    40→
    41→    Examples:
    42→        ```pycon
    43→        >>> ordinal(1)
    44→        '1st'
    45→        >>> ordinal(1002)
    46→        '1002nd'
    47→        >>> ordinal(103)
    48→        '103rd'
    49→        >>> ordinal(4)
    50→        '4th'
    51→        >>> ordinal(12)
    52→        '12th'
    53→        >>> ordinal(101)
    54→        '101st'
    55→        >>> ordinal(111)
    56→        '111th'
    57→        >>> ordinal("something else")
    58→        'something else'
    59→        >>> ordinal([1, 2, 3]) == "[1, 2, 3]"
    60→        True
    61→
    62→        ```
    63→
    64→    Args:
    65→        value (int, str, float): Integer to convert.
    66→        gender (str): Gender for translations. Accepts either "male" or "female".
    67→
    68→    Returns:
    69→        str: Ordinal string.
    70→    """
    71→    import math

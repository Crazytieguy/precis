   110→def intcomma(value: NumberOrString, ndigits: int | None = None) -> str:
   111→    """Converts an integer to a string containing commas every three digits.
   112→
   113→    For example, 3000 becomes "3,000" and 45000 becomes "45,000". To maintain some
   114→    compatibility with Django's `intcomma`, this function also accepts floats.
   115→
   116→    Examples:
   117→        ```pycon
   118→        >>> intcomma(100)
   119→        '100'
   120→        >>> intcomma("1000")
   121→        '1,000'
   122→        >>> intcomma(1_000_000)
   123→        '1,000,000'
   124→        >>> intcomma(1_234_567.25)
   125→        '1,234,567.25'
   126→        >>> intcomma(1234.5454545, 2)
   127→        '1,234.55'
   128→        >>> intcomma(14308.40, 1)
   129→        '14,308.4'
   130→        >>> intcomma("14308.40", 1)
   131→        '14,308.4'
   132→        >>> intcomma(None)
   133→        'None'
   134→
   135→        ```
   136→
   137→    Args:
   138→        value (int, float, str): Integer or float to convert.
   139→        ndigits (int, None): Digits of precision for rounding after the decimal point.
   140→
   141→    Returns:
   142→        str: String containing commas every three digits.
   143→    """
   144→    import math
   145→
   146→    thousands_sep = thousands_separator()
   195→def intword(value: NumberOrString, format: str = "%.1f") -> str:
   196→    """Converts a large integer to a friendly text representation.
   197→
   198→    Works best for numbers over 1 million. For example, 1_000_000 becomes "1.0 million",
   199→    1_200_000 becomes "1.2 million" and "1_200_000_000" becomes "1.2 billion". Supports
   200→    up to decillion (33 digits) and googol (100 digits).
   201→
   202→    Examples:
   203→        ```pycon
   204→        >>> intword("100")
   205→        '100'
   206→        >>> intword("12400")
   207→        '12.4 thousand'
   208→        >>> intword("1000000")
   209→        '1.0 million'
   210→        >>> intword(1_200_000_000)
   211→        '1.2 billion'
   212→        >>> intword(8100000000000000000000000000000000)
   213→        '8.1 decillion'
   214→        >>> intword(None)
   215→        'None'
   216→        >>> intword("1234000", "%0.3f")
   217→        '1.234 million'
   218→
   219→        ```
   220→
   221→    Args:
   222→        value (int, float, str): Integer to convert.
   223→        format (str): To change the number of decimal or general format of the number
   224→            portion.
   225→
   226→    Returns:
   227→        str: Friendly text representation as a string, unless the value passed could not
   228→            be coaxed into an `int`.
   229→    """
   230→    import math
   231→
   232→    try:
   269→def apnumber(value: NumberOrString) -> str:
   270→    """Converts an integer to Associated Press style.
   271→
   272→    Examples:
   273→      ```pycon
   274→      >>> apnumber(0)
   275→      'zero'
   276→      >>> apnumber(5)
   277→      'five'
   278→      >>> apnumber(10)
   279→      '10'
   280→      >>> apnumber("7")
   281→      'seven'
   282→      >>> apnumber("foo")
   283→      'foo'
   284→      >>> apnumber(None)
   285→      'None'
   286→
   287→      ```
   288→
   289→    Args:
   290→        value (int, float, str): Integer to convert.
   291→
   292→    Returns:
   293→        str: For numbers 0-9, the number spelled out. Otherwise, the number. This always
   294→            returns a string unless the value was not `int`-able, then `str(value)`
   295→            is returned.
   296→    """
   297→    import math
   298→

   101→def _gettext(message: str) -> str:
   102→    """Get translation.
   103→
   104→    Args:
   105→        message (str): Text to translate.
   106→
   107→    Returns:
   108→        str: Translated text.
   109→    """
   110→    return get_translation().gettext(message)
   113→def _pgettext(msgctxt: str, message: str) -> str:
   114→    """Fetches a particular translation.
   115→
   116→    It works with `msgctxt` .po modifiers and allows duplicate keys with different
   117→    translations.
   118→
   119→    Args:
   120→        msgctxt (str): Context of the translation.
   121→        message (str): Text to translate.
   122→
   123→    Returns:
   124→        str: Translated text.
   125→    """
   126→    return get_translation().pgettext(msgctxt, message)
   129→def _ngettext(message: str, plural: str, num: int) -> str:
   130→    """Plural version of _gettext.
   131→
   132→    Args:
   133→        message (str): Singular text to translate.
   134→        plural (str): Plural text to translate.
   135→        num (int): The number (e.g. item count) to determine translation for the
   136→            respective grammatical number.
   137→
   138→    Returns:
   139→        str: Translated text.
   140→    """
   141→    return get_translation().ngettext(message, plural, num)
   144→def _gettext_noop(message: str) -> str:
   145→    """Mark a string as a translation string without translating it.
   146→
   147→    Example usage:
   148→    ```python
   149→    CONSTANTS = [_gettext_noop('first'), _gettext_noop('second')]
   150→    def num_name(n):
   151→        return _gettext(CONSTANTS[n])
   152→    ```
   153→
   154→    Args:
   155→        message (str): Text to translate in the future.
   156→
   157→    Returns:
   158→        str: Original text, unchanged.
   159→    """
   160→    return message
   163→def _ngettext_noop(singular: str, plural: str) -> tuple[str, str]:
   164→    """Mark two strings as pluralized translations without translating them.
   165→
   166→    Example usage:
   167→    ```python
   168→    CONSTANTS = [ngettext_noop('first', 'firsts'), ngettext_noop('second', 'seconds')]
   169→    def num_name(n):
   170→        return _ngettext(*CONSTANTS[n])
   171→    ```
   172→
   173→    Args:
   174→        singular (str): Singular text to translate in the future.
   175→        plural (str): Plural text to translate in the future.
   176→
   177→    Returns:
   178→        tuple: Original text, unchanged.
   179→    """
   180→    return singular, plural
   183→def thousands_separator() -> str:
   184→    """Return the thousands separator for a locale, default to comma.
   185→
   186→    Returns:
   187→         str: Thousands separator.
   188→    """
   196→def decimal_separator() -> str:
   197→    """Return the decimal separator for a locale, default to dot.
   198→
   199→    Returns:
   200→         str: Decimal separator.
   201→    """


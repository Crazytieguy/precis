     5→import datetime as dt
     6→import importlib
     8→import pytest
     9→from freezegun import freeze_time
    11→import humanize
    17→@freeze_time("2020-02-02")
    18→def test_i18n() -> None:
    19→    three_seconds = NOW - dt.timedelta(seconds=3)
    20→    one_min_three_seconds = dt.timedelta(milliseconds=67_000)
    21→
    22→    assert humanize.naturaltime(three_seconds) == "3 seconds ago"
    23→    assert humanize.ordinal(5) == "5th"
    24→    assert humanize.precisedelta(one_min_three_seconds) == "1 minute and 7 seconds"
    25→
    26→    try:
    27→        humanize.i18n.activate("ru_RU")
    28→        assert humanize.naturaltime(three_seconds) == "3 секунды назад"
    29→        assert humanize.ordinal(5) == "5ый"
    30→        assert humanize.precisedelta(one_min_three_seconds) == "1 минута и 7 секунд"
    31→
    32→    except FileNotFoundError:
    33→        pytest.skip("Generate .mo with scripts/generate-translation-binaries.sh")
    34→
    35→    finally:
    36→        humanize.i18n.deactivate()
    37→        assert humanize.naturaltime(three_seconds) == "3 seconds ago"
    38→        assert humanize.ordinal(5) == "5th"

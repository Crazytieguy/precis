    58→# These are not considered "public" interfaces, but require tests anyway.
    59→
    60→
    61→def test_date_and_delta() -> None:
    62→    now = dt.datetime.now()
    63→    td = dt.timedelta
    64→    int_tests = (3, 29, 86399, 86400, 86401 * 30)
    65→    date_tests = [now - td(seconds=x) for x in int_tests]
    66→    td_tests = [td(seconds=x) for x in int_tests]
    67→    results = [(now - td(seconds=x), td(seconds=x)) for x in int_tests]
    68→    for t in (int_tests, date_tests, td_tests):
    69→        for arg, result in zip(t, results):
    70→            date, d = time._date_and_delta(arg)
    71→            assert_equal_datetime(date, result[0])
    72→            assert_equal_timedelta(d, result[1])
    73→    assert time._date_and_delta("NaN") == (None, "NaN")

     5→from math import log
    36→def naturalsize(
    37→    value: float | str,
    38→    binary: bool = False,
    39→    gnu: bool = False,
    40→    format: str = "%.1f",
    41→) -> str:
    42→    """Format a number of bytes like a human-readable filesize (e.g. 10 kB).
    43→
    44→    By default, decimal suffixes (kB, MB) are used.
    45→
    46→    Non-GNU modes are compatible with jinja2's `filesizeformat` filter.
    47→
    48→    Examples:
    49→        ```pycon
    50→        >>> naturalsize(3000000)
    51→        '3.0 MB'
    52→        >>> naturalsize(300, False, True)
    53→        '300B'
    54→        >>> naturalsize(3000, False, True)
    55→        '2.9K'
    56→        >>> naturalsize(3000, False, True, "%.3f")
    57→        '2.930K'
    58→        >>> naturalsize(3000, True)
    59→        '2.9 KiB'
    60→        >>> naturalsize(10**28)
    61→        '10.0 RB'
    62→        >>> naturalsize(10**34 * 3)
    63→        '30000.0 QB'
    64→        >>> naturalsize(-4096, True)
    65→        '-4.0 KiB'
    66→
    67→        ```
    68→
    69→    Args:
    70→        value (int, float, str): Integer to convert.
    71→        binary (bool): If `True`, uses binary suffixes (KiB, MiB) with base
    72→            2<sup>10</sup> instead of 10<sup>3</sup>.
    73→        gnu (bool): If `True`, the binary argument is ignored and GNU-style
    74→            (`ls -sh` style) prefixes are used (K, M) with the 2**10 definition.
    75→        format (str): Custom formatter.
    76→
    77→    Returns:
    78→        str: Human readable representation of a filesize.
    79→    """
    80→    if gnu:
    81→        suffix = suffixes["gnu"]
    82→    elif binary:
    83→        suffix = suffixes["binary"]
    84→    else:
    85→        suffix = suffixes["decimal"]
    86→
    87→    base = 1024 if (gnu or binary) else 1000
    88→    bytes_ = float(value)
    89→    abs_bytes = abs(bytes_)
    90→
    91→    if abs_bytes == 1 and not gnu:
    92→        return f"{int(bytes_)} Byte"
    93→
    94→    if abs_bytes < base:
    95→        return f"{int(bytes_)}B" if gnu else f"{int(bytes_)} Bytes"
    96→

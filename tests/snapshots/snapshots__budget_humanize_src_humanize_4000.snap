    58‚Üídef activate(
    59‚Üí    locale: str | None, path: str | os.PathLike[str] | None = None
    60‚Üí) -> gettext_module.NullTranslations:
    61‚Üí    """Activate internationalisation.
    62‚Üí
    63‚Üí    Set `locale` as current locale. Search for locale in directory `path`.
    64‚Üí
    65‚Üí    Args:
    66‚Üí        locale (str | None): Language name, e.g. `en_GB`. If `None`, defaults to no
    67‚Üí            transaltion. Similar to calling ``deactivate()``.
    68‚Üí        path (str | pathlib.Path): Path to search for locales.
    69‚Üí
    70‚Üí    Returns:
    71‚Üí        dict: Translations.
    72‚Üí
    73‚Üí    Raises:
    74‚Üí        FileNotFoundError: If humanize cannot find the locale folder.
    75‚Üí    """
    76‚Üí    if locale is None or locale.startswith("en"):
    77‚Üí        _CURRENT.locale = None
    78‚Üí        return _TRANSLATIONS[None]

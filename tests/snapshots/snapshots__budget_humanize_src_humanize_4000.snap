    56‚Üí        >>> naturalsize(3000, False, True, "%.3f")
    57‚Üí        '2.930K'
    58‚Üí        >>> naturalsize(3000, True)
    59‚Üí        '2.9 KiB'
    60‚Üí        >>> naturalsize(10**28)
    61‚Üí        '10.0 RB'
    62‚Üí        >>> naturalsize(10**34 * 3)
    63‚Üí        '30000.0 QB'
    64‚Üí        >>> naturalsize(-4096, True)

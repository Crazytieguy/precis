     3Ôćĺconst encode = (obj, opt = {}) => {
     4Ôćĺ  if (typeof opt === 'string') {
     5Ôćĺ    opt = { section: opt }
     6Ôćĺ  }
     7Ôćĺ  opt.align = opt.align === true
     8Ôćĺ  opt.newline = opt.newline === true
     9Ôćĺ  opt.sort = opt.sort === true
    10Ôćĺ  opt.whitespace = opt.whitespace === true || opt.align === true
    11Ôćĺ  // The `typeof` check is required because accessing the `process` directly fails on browsers.
    12Ôćĺ  /* istanbul ignore next */
    13Ôćĺ  opt.platform = opt.platform || (typeof process !== 'undefined' && process.platform)
    14Ôćĺ  opt.bracketedArray = opt.bracketedArray !== false
    15Ôćĺ
    16Ôćĺ  /* istanbul ignore next */
    17Ôćĺ  const eol = opt.platform === 'win32' ? '\r\n' : '\n'
    18Ôćĺ  const separator = opt.whitespace ? ' = ' : '='
    19Ôćĺ  const children = []
    20Ôćĺ
    21Ôćĺ  const keys = opt.sort ? Object.keys(obj).sort() : Object.keys(obj)
    22Ôćĺ
    23Ôćĺ  let padToChars = 0
    24Ôćĺ  // If aligning on the separator, then padToChars is determined as follows:
    25Ôćĺ  // 1. Get the keys
    26Ôćĺ  // 2. Exclude keys pointing to objects unless the value is null or an array
    27Ôćĺ  // 3. Add `[]` to array keys
    28Ôćĺ  // 4. Ensure non empty set of keys
    29Ôćĺ  // 5. Reduce the set to the longest `safe` key
    30Ôćĺ  // 6. Get the `safe` length
    31Ôćĺ  if (opt.align) {
    32Ôćĺ    padToChars = safe(
    33Ôćĺ      (
    34Ôćĺ        keys
    35Ôćĺ          .filter(k => obj[k] === null || Array.isArray(obj[k]) || typeof obj[k] !== 'object')
    36Ôćĺ          .map(k => Array.isArray(obj[k]) ? `${k}[]` : k)
    37Ôćĺ      )
    38Ôćĺ        .concat([''])
    39Ôćĺ        .reduce((a, b) => safe(a).length >= safe(b).length ? a : b)
    40Ôćĺ    ).length
    41Ôćĺ  }
    42Ôćĺ
    43Ôćĺ  let out = ''
    44Ôćĺ  const arraySuffix = opt.bracketedArray ? '[]' : ''
    45Ôćĺ
    46Ôćĺ  for (const k of keys) {
    47Ôćĺ    const val = obj[k]
    48Ôćĺ    if (val && Array.isArray(val)) {
    49Ôćĺ      for (const item of val) {
    50Ôćĺ        out += safe(`${k}${arraySuffix}`).padEnd(padToChars, ' ') + separator + safe(item) + eol
    51Ôćĺ      }
    52Ôćĺ    } else if (val && typeof val === 'object') {
    53Ôćĺ      children.push(k)
    54Ôćĺ    } else {
    55Ôćĺ      out += safe(k).padEnd(padToChars, ' ') + separator + safe(val) + eol
    56Ôćĺ    }
    57Ôćĺ  }
    58Ôćĺ
    59Ôćĺ  if (opt.section && out.length) {
    60Ôćĺ    out = '[' + safe(opt.section) + ']' + (opt.newline ? eol + eol : eol) + out
    61Ôćĺ  }
    62Ôćĺ
    63Ôćĺ  for (const k of children) {
    64Ôćĺ    const nk = splitSections(k, '.').join('\\.')
    65Ôćĺ    const section = (opt.section ? opt.section + '.' : '') + nk
    66Ôćĺ    const child = encode(obj[k], {
    67Ôćĺ      ...opt,
    68Ôćĺ      section,
    69Ôćĺ    })
    70Ôćĺ    if (out.length && child.length) {
    71Ôćĺ      out += eol
    72Ôćĺ    }
    73Ôćĺ
    74Ôćĺ    out += child
    75Ôćĺ  }
    76Ôćĺ
    77Ôćĺ  return out
    78Ôćĺ}
    80Ôćĺfunction splitSections (str, separator) {
    81Ôćĺ  var lastMatchIndex = 0
    82Ôćĺ  var lastSeparatorIndex = 0
    83Ôćĺ  var nextIndex = 0
    84Ôćĺ  var sections = []
    85Ôćĺ
    86Ôćĺ  do {
    87Ôćĺ    nextIndex = str.indexOf(separator, lastMatchIndex)
    88Ôćĺ
    89Ôćĺ    if (nextIndex !== -1) {
    90Ôćĺ      lastMatchIndex = nextIndex + separator.length
    91Ôćĺ
    92Ôćĺ      if (nextIndex > 0 && str[nextIndex - 1] === '\\') {
    93Ôćĺ        continue
    94Ôćĺ      }
    95Ôćĺ
    96Ôćĺ      sections.push(str.slice(lastSeparatorIndex, nextIndex))
    97Ôćĺ      lastSeparatorIndex = nextIndex + separator.length
    98Ôćĺ    }
    99Ôćĺ  } while (nextIndex !== -1)
   100Ôćĺ
   101Ôćĺ  sections.push(str.slice(lastSeparatorIndex))
   102Ôćĺ
   103Ôćĺ  return sections
   104Ôćĺ}
   106Ôćĺconst decode = (str, opt = {}) => {
   107Ôćĺ  opt.bracketedArray = opt.bracketedArray !== false
   108Ôćĺ  const out = Object.create(null)
   109Ôćĺ  let p = out
   110Ôćĺ  let section = null
   111Ôćĺ  //          section          |key      = value
   112Ôćĺ  const re = /^\[([^\]]*)\]\s*$|^([^=]+)(=(.*))?$/i
   113Ôćĺ  const lines = str.split(/[\r\n]+/g)
   114Ôćĺ  const duplicates = {}
   115Ôćĺ
   116Ôćĺ  for (const line of lines) {
   117Ôćĺ    if (!line || line.match(/^\s*[;#]/) || line.match(/^\s*$/)) {
   118Ôćĺ      continue
   119Ôćĺ    }
   120Ôćĺ    const match = line.match(re)
   121Ôćĺ    if (!match) {
   122Ôćĺ      continue
   123Ôćĺ    }
   124Ôćĺ    if (match[1] !== undefined) {
   125Ôćĺ      section = unsafe(match[1])
   126Ôćĺ      if (section === '__proto__') {
   127Ôćĺ        // not allowed
   128Ôćĺ        // keep parsing the section, but don't attach it.
   129Ôćĺ        p = Object.create(null)
   130Ôćĺ        continue
   131Ôćĺ      }
   132Ôćĺ      p = out[section] = out[section] || Object.create(null)
   133Ôćĺ      continue
   134Ôćĺ    }
   135Ôćĺ    const keyRaw = unsafe(match[2])
   136Ôćĺ    let isArray
   137Ôćĺ    if (opt.bracketedArray) {
   138Ôćĺ      isArray = keyRaw.length > 2 && keyRaw.slice(-2) === '[]'
   139Ôćĺ    } else {
   140Ôćĺ      duplicates[keyRaw] = (duplicates?.[keyRaw] || 0) + 1
   141Ôćĺ      isArray = duplicates[keyRaw] > 1
   142Ôćĺ    }
   143Ôćĺ    const key = isArray && keyRaw.endsWith('[]')
   144Ôćĺ      ? keyRaw.slice(0, -2) : keyRaw
   145Ôćĺ
   146Ôćĺ    if (key === '__proto__') {
   147Ôćĺ      continue
   148Ôćĺ    }
   149Ôćĺ    const valueRaw = match[3] ? unsafe(match[4]) : true
   150Ôćĺ    const value = valueRaw === 'true' ||
   151Ôćĺ      valueRaw === 'false' ||
   152Ôćĺ      valueRaw === 'null' ? JSON.parse(valueRaw)
   153Ôćĺ      : valueRaw
   154Ôćĺ
   155Ôćĺ    // Convert keys with '[]' suffix to an array
   156Ôćĺ    if (isArray) {
   157Ôćĺ      if (!hasOwnProperty.call(p, key)) {
   158Ôćĺ        p[key] = []
   159Ôćĺ      } else if (!Array.isArray(p[key])) {
   160Ôćĺ        p[key] = [p[key]]
   161Ôćĺ      }
   162Ôćĺ    }
   163Ôćĺ
   164Ôćĺ    // safeguard against resetting a previously defined
   165Ôćĺ    // array by accidentally forgetting the brackets
   166Ôćĺ    if (Array.isArray(p[key])) {
   167Ôćĺ      p[key].push(value)
   168Ôćĺ    } else {
   169Ôćĺ      p[key] = value
   170Ôćĺ    }
   171Ôćĺ  }
   172Ôćĺ
   173Ôćĺ  // {a:{y:1},"a.b":{x:2}} --> {a:{y:1,b:{x:2}}}
   174Ôćĺ  // use a filter to return the keys that have to be deleted.
   175Ôćĺ  const remove = []
   176Ôćĺ  for (const k of Object.keys(out)) {
   177Ôćĺ    if (!hasOwnProperty.call(out, k) ||
   178Ôćĺ      typeof out[k] !== 'object' ||
   179Ôćĺ      Array.isArray(out[k])) {
   180Ôćĺ      continue
   181Ôćĺ    }
   182Ôćĺ
   183Ôćĺ    // see if the parent section is also an object.
   184Ôćĺ    // if so, add it to that, and mark this one for deletion
   185Ôćĺ    const parts = splitSections(k, '.')
   186Ôćĺ    p = out
   187Ôćĺ    const l = parts.pop()
   188Ôćĺ    const nl = l.replace(/\\\./g, '.')
   189Ôćĺ    for (const part of parts) {
   190Ôćĺ      if (part === '__proto__') {
   191Ôćĺ        continue
   192Ôćĺ      }
   193Ôćĺ      if (!hasOwnProperty.call(p, part) || typeof p[part] !== 'object') {
   194Ôćĺ        p[part] = Object.create(null)
   195Ôćĺ      }
   196Ôćĺ      p = p[part]
   197Ôćĺ    }
   198Ôćĺ    if (p === out && nl === l) {
   199Ôćĺ      continue
   200Ôćĺ    }
   201Ôćĺ
   202Ôćĺ    p[nl] = out[k]
   203Ôćĺ    remove.push(k)
   204Ôćĺ  }
   205Ôćĺ  for (const del of remove) {
   206Ôćĺ    delete out[del]
   207Ôćĺ  }
   208Ôćĺ
   209Ôćĺ  return out
   210Ôćĺ}
   212Ôćĺconst isQuoted = val => {
   213Ôćĺ  return (val.startsWith('"') && val.endsWith('"')) ||
   214Ôćĺ    (val.startsWith("'") && val.endsWith("'"))
   215Ôćĺ}
   217Ôćĺconst safe = val => {
   218Ôćĺ  if (
   219Ôćĺ    typeof val !== 'string' ||
   220Ôćĺ    val.match(/[=\r\n]/) ||
   221Ôćĺ    val.match(/^\[/) ||
   222Ôćĺ    (val.length > 1 && isQuoted(val)) ||
   223Ôćĺ    val !== val.trim()
   224Ôćĺ  ) {
   225Ôćĺ    return JSON.stringify(val)
   226Ôćĺ  }
   227Ôćĺ  return val.split(';').join('\\;').split('#').join('\\#')
   228Ôćĺ}
   230Ôćĺconst unsafe = val => {
   231Ôćĺ  val = (val || '').trim()
   232Ôćĺ  if (isQuoted(val)) {
   233Ôćĺ    // remove the single quotes before calling JSON.parse
   234Ôćĺ    if (val.charAt(0) === "'") {
   235Ôćĺ      val = val.slice(1, -1)
   236Ôćĺ    }
   237Ôćĺ    try {
   238Ôćĺ      val = JSON.parse(val)
   239Ôćĺ    } catch {
   240Ôćĺ      // ignore errors
   241Ôćĺ    }
   242Ôćĺ  } else {
   243Ôćĺ    // walk the val to find the first not-escaped ; character
   244Ôćĺ    let esc = false
   245Ôćĺ    let unesc = ''
   246Ôćĺ    for (let i = 0, l = val.length; i < l; i++) {
   247Ôćĺ      const c = val.charAt(i)
   248Ôćĺ      if (esc) {
   249Ôćĺ        if ('\\;#'.indexOf(c) !== -1) {
   250Ôćĺ          unesc += c
   251Ôćĺ        } else {
   252Ôćĺ          unesc += '\\' + c
   253Ôćĺ        }
   254Ôćĺ
   255Ôćĺ        esc = false
   256Ôćĺ      } else if (';#'.indexOf(c) !== -1) {
   257Ôćĺ        break
   258Ôćĺ      } else if (c === '\\') {
   259Ôćĺ        esc = true
   260Ôćĺ      } else {
   261Ôćĺ        unesc += c
   262Ôćĺ      }
   263Ôćĺ    }
   264Ôćĺ    if (esc) {
   265Ôćĺ      unesc += '\\'
   266Ôćĺ    }
   267Ôćĺ
   268Ôćĺ    return unesc.trim()
   269Ôćĺ  }
   270Ôćĺ  return val
   271Ôćĺ}


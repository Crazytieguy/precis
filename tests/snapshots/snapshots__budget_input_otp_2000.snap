packages/input-otp/src/sync-timeouts.ts
     1в†’export function syncTimeouts(cb: (...args: any[]) => unknown): number[] {
     2в†’  const t1 = setTimeout(cb, 0) // For faster machines
     3в†’  const t2 = setTimeout(cb, 1_0)
     4в†’  const t3 = setTimeout(cb, 5_0)

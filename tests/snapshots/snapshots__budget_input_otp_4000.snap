   478→
   479→<details>
   480→<summary>If you want to use Context props:</summary>
   481→
   482→```diff
   483→+import { OTPInputContext } from 'input-otp'
   484→
   485→function MyForm() {
   486→  return (
   487→    <OTPInput
   488→-     // First remove the `render` prop
   489→-     render={...}
   490→    >
   491→      <OTPInputWrapper />
   492→    </OTPInput>
   493→  )
   494→}
   495→
   496→+function OTPInputWrapper() {
   497→+ const inputContext = React.useContext(OTPInputContext)
   498→+ return (
   499→+   <>
   500→+     {inputContext.slots.map((slot, idx) => (
   501→+       <Slot key={idx} {...slot} />
   502→+     ))}
   503→+   </>
   504→+ )
   505→+}
   506→```
   507→
   508→NOTE: this also affects the selected caret position after a touch/click.

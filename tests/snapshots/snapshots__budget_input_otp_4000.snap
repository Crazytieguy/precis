    10‚Üíexport const OTPInputContext = React.createContext<RenderProps>(
    11‚Üí  {} as RenderProps,
    12‚Üí)
    14‚Üíexport const OTPInput = React.forwardRef<HTMLInputElement, OTPInputProps>(
    15‚Üí  (
    16‚Üí    {
    17‚Üí      value: uncheckedValue,
    18‚Üí      onChange: uncheckedOnChange,
    19‚Üí      maxLength,
    20‚Üí      textAlign = 'left',
    21‚Üí      pattern,
    22‚Üí      placeholder,
    23‚Üí      inputMode = 'numeric',
    24‚Üí      onComplete,
    25‚Üí      pushPasswordManagerStrategy = 'increase-width',
    26‚Üí      pasteTransformer,
    27‚Üí      containerClassName,
    28‚Üí      noScriptCSSFallback = NOSCRIPT_CSS_FALLBACK,
    29‚Üí
    30‚Üí      render,
    31‚Üí      children,
    32‚Üí
    33‚Üí      ...props
    34‚Üí    },
    35‚Üí    ref,
    36‚Üí  ) => {
    37‚Üí    // Only used when `value` state is not provided
    38‚Üí    const [internalValue, setInternalValue] = React.useState(
    39‚Üí      typeof props.defaultValue === 'string' ? props.defaultValue : '',
    40‚Üí    )
    41‚Üí
    42‚Üí    // Definitions
    43‚Üí    const value = uncheckedValue ?? internalValue
    44‚Üí    const previousValue = usePrevious(value)
    45‚Üí    const onChange = React.useCallback(
    46‚Üí      (newValue: string) => {
    47‚Üí        uncheckedOnChange?.(newValue)
    48‚Üí        setInternalValue(newValue)
    49‚Üí      },
    50‚Üí      [uncheckedOnChange],
    51‚Üí    )
    52‚Üí    const regexp = React.useMemo(
    53‚Üí      () =>
    54‚Üí        pattern
    55‚Üí          ? typeof pattern === 'string'
    56‚Üí            ? new RegExp(pattern)
    57‚Üí            : pattern
    58‚Üí          : null,
    59‚Üí      [pattern],
    60‚Üí    )

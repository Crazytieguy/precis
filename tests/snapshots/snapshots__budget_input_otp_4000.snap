    22‚Üí
    23‚Üí    onComplete?: (...args: any[]) => unknown
    24‚Üí    pushPasswordManagerStrategy?: 'increase-width' | 'none'
    25‚Üí    pasteTransformer?: (pasted: string) => string
    26‚Üí
    27‚Üí    containerClassName?: string
    28‚Üí
    29‚Üí    noScriptCSSFallback?: string | null
    30‚Üí  }
    31‚Üí>
    32‚Üítype InputOTPRenderFn = (props: RenderProps) => React.ReactNode
    33‚Üíexport type OTPInputProps = OTPInputBaseProps &
    34‚Üí  (

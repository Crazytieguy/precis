packages/input-otp/src/sync-timeouts.ts
     1‚Üíexport function syncTimeouts(cb: (...args: any[]) => unknown): number[] {
     2‚Üí  const t1 = setTimeout(cb, 0) // For faster machines
     3‚Üí  const t2 = setTimeout(cb, 1_0)
     4‚Üí  const t3 = setTimeout(cb, 5_0)
     5‚Üí  return [t1, t2, t3]
     6‚Üí}


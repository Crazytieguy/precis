    15‚Üíexport function usePasswordManagerBadge({
    16‚Üí  containerRef,
    17‚Üí  inputRef,
    18‚Üí  pushPasswordManagerStrategy,
    19‚Üí  isFocused,
    20‚Üí}: {
    21‚Üí  containerRef: React.RefObject<HTMLDivElement>
    22‚Üí  inputRef: React.RefObject<HTMLInputElement>
    23‚Üí  pushPasswordManagerStrategy: OTPInputProps['pushPasswordManagerStrategy']
    24‚Üí  isFocused: boolean
    25‚Üí}) {
    26‚Üí  /** Password managers have a badge
    27‚Üí   *  and I'll use this state to push them
    28‚Üí   *  outside the input */
    29‚Üí  const [hasPWMBadge, setHasPWMBadge] = React.useState(false)
    30‚Üí  const [hasPWMBadgeSpace, setHasPWMBadgeSpace] = React.useState(false)
    31‚Üí  const [done, setDone] = React.useState(false)
    32‚Üí
    33‚Üí  const willPushPWMBadge = React.useMemo(() => {
    34‚Üí    if (pushPasswordManagerStrategy === 'none') {
    35‚Üí      return false
    36‚Üí    }
    37‚Üí
    38‚Üí    const increaseWidthCase =
    39‚Üí      (pushPasswordManagerStrategy === 'increase-width' ||
    40‚Üí        // TODO: remove 'experimental-no-flickering' support in 2.0.0
    41‚Üí        pushPasswordManagerStrategy === 'experimental-no-flickering') &&
    42‚Üí      hasPWMBadge &&
    43‚Üí      hasPWMBadgeSpace
    44‚Üí
    45‚Üí    return increaseWidthCase
    46‚Üí  }, [hasPWMBadge, hasPWMBadgeSpace, pushPasswordManagerStrategy])
    47‚Üí
    48‚Üí  const trackPWMBadge = React.useCallback(() => {
    49‚Üí    const container = containerRef.current
    50‚Üí    const input = inputRef.current
    51‚Üí    if (
    52‚Üí      !container ||
    53‚Üí      !input ||
    54‚Üí      done ||
    55‚Üí      pushPasswordManagerStrategy === 'none'
    56‚Üí    ) {
    57‚Üí      return
    58‚Üí    }
    59‚Üí
    60‚Üí    const elementToCompare = container
    61‚Üí
    62‚Üí    // Get the top right-center point of the container.
    63‚Üí    // That is usually where most password managers place their badge.
    64‚Üí    const rightCornerX =
    65‚Üí      elementToCompare.getBoundingClientRect().left +
    66‚Üí      elementToCompare.offsetWidth
    67‚Üí    const centereredY =
    68‚Üí      elementToCompare.getBoundingClientRect().top +
    69‚Üí      elementToCompare.offsetHeight / 2
    70‚Üí    const x = rightCornerX - PWM_BADGE_MARGIN_RIGHT
    71‚Üí    const y = centereredY
    72‚Üí

sync-timeouts.ts
     1→export function syncTimeouts(cb: (...args: any[]) => unknown): number[] {
     2→  const t1 = setTimeout(cb, 0) // For faster machines
     3→  const t2 = setTimeout(cb, 1_0)
     4→  const t3 = setTimeout(cb, 5_0)
     5→  return [t1, t2, t3]
     6→}


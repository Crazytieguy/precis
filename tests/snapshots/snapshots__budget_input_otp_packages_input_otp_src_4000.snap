   473→
   474→          const char = value[slotIdx] !== undefined ? value[slotIdx] : null
   475→          const placeholderChar = value[0] !== undefined ? null : placeholder?.[slotIdx] ?? null
   476→
   477→          return {
   478→            char,
   479→            placeholderChar,
   480→            isActive,
   481→            hasFakeCaret: isActive && char === null,
   482→          }
   483→        }),
   484→        isFocused,

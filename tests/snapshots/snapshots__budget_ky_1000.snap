    33‚Üíexport type KyOptions ‚Ä¶
   307‚Üíexport type KyOptionsRegistry ‚Ä¶
   309‚Üí/**
   310‚ÜíOptions are the same as `window.fetch`, except for the KyOptions
   311‚Üí*/
   312‚Üíexport interface Options extends KyOptions, Omit<RequestInit, 'headers'> { // eslint-disable-line @typescript-eslint/consistent-type-definitions -- This must stay an interface so that it can be extended outside of Ky for use in `ky.create`.
   313‚Üí	/**
   314‚Üí	HTTP method used to make the request.
   315‚Üí
   316‚Üí	Internally, the standard methods (`GET`, `POST`, `PUT`, `PATCH`, `HEAD` and `DELETE`) are uppercased in order to avoid server errors due to case sensitivity.
   317‚Üí	*/
   318‚Üí	method?: LiteralUnion<HttpMethod, string>;
   319‚Üí
   320‚Üí	/**
   321‚Üí	HTTP headers used to make the request.
   322‚Üí
   323‚Üí	You can pass a `Headers` instance or a plain object.
   324‚Üí
   325‚Üí	You can remove a header with `.extend()` by passing the header with an `undefined` value.
   326‚Üí
   327‚Üí	@example
   328‚Üí	```
   329‚Üí	import ky from 'ky';
   330‚Üí
   331‚Üí	const url = 'https://sindresorhus.com';
   332‚Üí
   333‚Üí	const original = ky.create({
   334‚Üí		headers: {
   335‚Üí			rainbow: 'rainbow',
   336‚Üí			unicorn: 'unicorn'
   337‚Üí		}
   338‚Üí	});
   339‚Üí
   340‚Üí	const extended = original.extend({
   341‚Üí		headers: {
   342‚Üí			rainbow: undefined
   343‚Üí		}
   344‚Üí	});
   345‚Üí
   346‚Üí	const response = await extended(url).json();
   347‚Üí
   348‚Üí	console.log('rainbow' in response);
   349‚Üí	//=> false
   350‚Üí
   351‚Üí	console.log('unicorn' in response);
   352‚Üí	//=> true
   353‚Üí	```
   354‚Üí	*/
   355‚Üí	headers?: KyHeadersInit;
   356‚Üí}
   370‚Üí/**
   371‚ÜíNormalized options passed to the `fetch` call and the `beforeRequest` hooks.
   372‚Üí*/
   373‚Üíexport interface NormalizedOptions extends RequestInit { // eslint-disable-line @typescript-eslint/consistent-type-definitions -- This must stay an interface so that it can be extended outside of Ky for use in `ky.create`.
   374‚Üí	// Extended from `RequestInit`, but ensured to be set (not optional).
   375‚Üí	method: NonNullable<RequestInit['method']>;
   376‚Üí	credentials?: NonNullable<RequestInit['credentials']>;
   377‚Üí
   378‚Üí	// Extended from custom `KyOptions`, but ensured to be set (not optional).
   379‚Üí	retry: RetryOptions;
   380‚Üí	prefixUrl: string;
   381‚Üí	onDownloadProgress: Options['onDownloadProgress'];
   382‚Üí	onUploadProgress: Options['onUploadProgress'];
   383‚Üí	context: Record<string, unknown>;
   384‚Üí}

   373Ôćĺexport interface NormalizedOptions extends RequestInit { // eslint-disable-line @typescript-eslint/consistent-type-definitions -- This must stay an interface so that it can be extended outside of Ky for use in `ky.create`.
   374Ôćĺ	// Extended from `RequestInit`, but ensured to be set (not optional).

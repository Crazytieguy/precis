   309Ôćĺ/**
   310ÔćĺOptions are the same as `window.fetch`, except for the KyOptions
   311Ôćĺ*/
   312Ôćĺexport interface Options extends KyOptions, Omit<RequestInit, 'headers'> { // eslint-disable-line @typescript-eslint/consistent-type-definitions -- This must stay an interface so that it can be extended outside of Ky for use in `ky.create`.
   313Ôćĺ	/**
   314Ôćĺ	HTTP method used to make the request.
   315Ôćĺ
   316Ôćĺ	Internally, the standard methods (`GET`, `POST`, `PUT`, `PATCH`, `HEAD` and `DELETE`) are uppercased in order to avoid server errors due to case sensitivity.
   317Ôćĺ	*/
   318Ôćĺ	method?: LiteralUnion<HttpMethod, string>;
   319Ôćĺ
   320Ôćĺ	/**
   321Ôćĺ	HTTP headers used to make the request.
   322Ôćĺ
   323Ôćĺ	You can pass a `Headers` instance or a plain object.
   324Ôćĺ
   325Ôćĺ	You can remove a header with `.extend()` by passing the header with an `undefined` value.
   326Ôćĺ
   327Ôćĺ	@example
   328Ôćĺ	```
   329Ôćĺ	import ky from 'ky';
   330Ôćĺ
   331Ôćĺ	const url = 'https://sindresorhus.com';
   332Ôćĺ
   333Ôćĺ	const original = ky.create({
   334Ôćĺ		headers: {
   335Ôćĺ			rainbow: 'rainbow',
   336Ôćĺ			unicorn: 'unicorn'
   337Ôćĺ		}
   338Ôćĺ	});
   339Ôćĺ
   340Ôćĺ	const extended = original.extend({
   341Ôćĺ		headers: {
   342Ôćĺ			rainbow: undefined
   343Ôćĺ		}
   344Ôćĺ	});
   345Ôćĺ
   346Ôćĺ	const response = await extended(url).json();
   347Ôćĺ
   348Ôćĺ	console.log('rainbow' in response);
   349Ôćĺ	//=> false
   350Ôćĺ
   351Ôćĺ	console.log('unicorn' in response);
   352Ôćĺ	//=> true
   353Ôćĺ	```
   354Ôćĺ	*/
   355Ôćĺ	headers?: KyHeadersInit;
   356Ôćĺ}
   370Ôćĺ/**

   302→/**
   303→Each key from KyOptions is present and set to `true`.
   304→
   305→This type is used for identifying and working with the known keys in KyOptions.
   306→*/
   307→export type KyOptionsRegistry = {[K in keyof KyOptions]-?: true};
   309→/**
   310→Options are the same as `window.fetch`, except for the KyOptions
   311→*/
   312→export interface Options extends KyOptions, Omit<RequestInit, 'headers'> { // eslint-disable-line @typescript-eslint/consistent-type-definitions -- This must stay an interface so that it can be extended outside of Ky for use in `ky.create`.
   313→	/**
   314→	HTTP method used to make the request.
   315→
   316→	Internally, the standard methods (`GET`, `POST`, `PUT`, `PATCH`, `HEAD` and `DELETE`) are uppercased in order to avoid server errors due to case sensitivity.
   317→	*/
   318→	method?: LiteralUnion<HttpMethod, string>;
   319→
   320→	/**
   321→	HTTP headers used to make the request.
   322→
   323→	You can pass a `Headers` instance or a plain object.
   324→
   325→	You can remove a header with `.extend()` by passing the header with an `undefined` value.
   326→
   327→	@example
   328→	```
   329→	import ky from 'ky';
   330→
   331→	const url = 'https://sindresorhus.com';
   332→
   333→	const original = ky.create({
   334→		headers: {
   335→			rainbow: 'rainbow',
   336→			unicorn: 'unicorn'
   337→		}
   338→	});
   339→
   340→	const extended = original.extend({
   341→		headers: {
   342→			rainbow: undefined
   343→		}
   344→	});
   345→
   346→	const response = await extended(url).json();
   347→
   348→	console.log('rainbow' in response);
   349→	//=> false
   350→
   351→	console.log('unicorn' in response);
   352→	//=> true
   353→	```
   354→	*/
   355→	headers?: KyHeadersInit;
   356→}
   370→/**
   371→Normalized options passed to the `fetch` call and the `beforeRequest` hooks.
   372→*/
   373→export interface NormalizedOptions extends RequestInit { // eslint-disable-line @typescript-eslint/consistent-type-definitions -- This must stay an interface so that it can be extended outside of Ky for use in `ky.create`.
   374→	// Extended from `RequestInit`, but ensured to be set (not optional).
   375→	method: NonNullable<RequestInit['method']>;

   145Ôćĺ/**
   146ÔćĺMarker returned by ky.retry() to signal a forced retry from afterResponse hooks.
   147Ôćĺ*/
   148Ôćĺexport class RetryMarker {
   149Ôćĺ	constructor(public options?: ForceRetryOptions) {}
   150Ôćĺ}
   152Ôćĺ/**
   153ÔćĺForce a retry from an `afterResponse` hook.
   154Ôćĺ
   155ÔćĺThis allows you to retry a request based on the response content, even if the response has a successful status code. The retry will respect the `retry.limit` option and skip the `shouldRetry` check. The forced retry is observable in `beforeRetry` hooks, where the error will be a `ForceRetryError`.
   156Ôćĺ
   157Ôćĺ@param options - Optional configuration for the retry.
   158Ôćĺ
   159Ôćĺ@example
   160Ôćĺ```
   161Ôćĺimport ky, {isForceRetryError} from 'ky';
   162Ôćĺ
   163Ôćĺconst api = ky.extend({
   164Ôćĺ	hooks: {
   165Ôćĺ		afterResponse: [
   166Ôćĺ			async (request, options, response) => {
   167Ôćĺ				// Retry based on response body content
   168Ôćĺ				if (response.status === 200) {
   169Ôćĺ					const data = await response.clone().json();
   170Ôćĺ
   171Ôćĺ					// Simple retry with default delay
   172Ôćĺ					if (data.error?.code === 'TEMPORARY_ERROR') {
   173Ôćĺ						return ky.retry();
   174Ôćĺ					}
   175Ôćĺ
   176Ôćĺ					// Retry with custom delay from API response
   177Ôćĺ					if (data.error?.code === 'RATE_LIMIT') {
   178Ôćĺ						return ky.retry({
   179Ôćĺ							delay: data.error.retryAfter * 1000,
   180Ôćĺ							code: 'RATE_LIMIT'
   181Ôćĺ						});
   182Ôćĺ					}
   183Ôćĺ

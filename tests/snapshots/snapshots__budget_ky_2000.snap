   309â†’/**
   310â†’Options are the same as `window.fetch`, except for the KyOptions
   311â†’*/
   312â†’export interface Options extends KyOptions, Omit<RequestInit, 'headers'> { // eslint-disable-line @typescript-eslint/consistent-type-definitions -- This must stay an interface so that it can be extended outside of Ky for use in `ky.create`.
   313â†’	/**
   314â†’	HTTP method used to make the request.
   315â†’
   316â†’	Internally, the standard methods (`GET`, `POST`, `PUT`, `PATCH`, `HEAD` and `DELETE`) are uppercased in order to avoid server errors due to case sensitivity.
   317â†’	*/
   318â†’	method?: LiteralUnion<HttpMethod, string>;
   319â†’
   320â†’	/**
   321â†’	HTTP headers used to make the request.
   322â†’
   323â†’	You can pass a `Headers` instance or a plain object.
   324â†’
   325â†’	You can remove a header with `.extend()` by passing the header with an `undefined` value.
   326â†’
   327â†’	@example
   328â†’	```
   329â†’	import ky from 'ky';
   330â†’
   331â†’	const url = 'https://sindresorhus.com';
   332â†’
   333â†’	const original = ky.create({
   334â†’		headers: {
   335â†’			rainbow: 'rainbow',
   336â†’			unicorn: 'unicorn'
   337â†’		}
   338â†’	});
   339â†’
   340â†’	const extended = original.extend({
   341â†’		headers: {
   342â†’			rainbow: undefined
   343â†’		}
   344â†’	});
   345â†’
   346â†’	const response = await extended(url).json();
   347â†’
   348â†’	console.log('rainbow' in response);
   349â†’	//=> false
   350â†’
   351â†’	console.log('unicorn' in response);
   352â†’	//=> true
   353â†’	```
   354â†’	*/
   355â†’	headers?: KyHeadersInit;
   356â†’}
   358â†’export type InternalOptions
   370â†’/**
   371â†’Normalized options passed to the `fetch` call and the `beforeRequest` hooks.
   372â†’*/
   373â†’export interface NormalizedOptions extends RequestInit { // eslint-disable-line @typescript-eslint/consistent-type-definitions -- This must stay an interface so that it can be extended outside of Ky for use in `ky.create`.
   374â†’	// Extended from `RequestInit`, but ensured to be set (not optional).
   375â†’	method: NonNullable<RequestInit['method']>;
   376â†’	credentials?: NonNullable<RequestInit['credentials']>;
   377â†’
   378â†’	// Extended from custom `KyOptions`, but ensured to be set (not optional).
   379â†’	retry: RetryOptions;
   380â†’	prefixUrl: string;
   381â†’	onDownloadProgress: Options['onDownloadProgress'];
   382â†’	onUploadProgress: Options['onUploadProgress'];
   383â†’	context: Record<string, unknown>;
   384â†’}

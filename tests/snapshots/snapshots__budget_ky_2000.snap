   145â†’/**
   146â†’Marker returned by ky.retry() to signal a forced retry from afterResponse hooks.
   147â†’*/
   148â†’export class RetryMarker {
   149â†’	constructor(public options?: ForceRetryOptions) {}
   150â†’}
   152â†’/**
   153â†’Force a retry from an `afterResponse` hook.
   154â†’
   155â†’This allows you to retry a request based on the response content, even if the response has a successful status code. The retry will respect the `retry.limit` option and skip the `shouldRetry` check. The forced retry is observable in `beforeRetry` hooks, where the error will be a `ForceRetryError`.
   156â†’
   157â†’@param options - Optional configuration for the retry.
   158â†’
   159â†’@example
   160â†’```
   161â†’import ky, {isForceRetryError} from 'ky';
   162â†’
   163â†’const api = ky.extend({
   164â†’	hooks: {
   165â†’		afterResponse: [
   166â†’			async (request, options, response) => {
   167â†’				// Retry based on response body content
   168â†’				if (response.status === 200) {
   169â†’					const data = await response.clone().json();
   170â†’
   171â†’					// Simple retry with default delay
   172â†’					if (data.error?.code === 'TEMPORARY_ERROR') {
   173â†’						return ky.retry();
   174â†’					}
   175â†’
   176â†’					// Retry with custom delay from API response
   177â†’					if (data.error?.code === 'RATE_LIMIT') {
   178â†’						return ky.retry({
   179â†’							delay: data.error.retryAfter * 1000,
   180â†’							code: 'RATE_LIMIT'
   181â†’						});
   182â†’					}
   183â†’
   184â†’					// Retry with a modified request (e.g., fallback endpoint)
   185â†’					if (data.error?.code === 'FALLBACK_TO_BACKUP') {
   186â†’						return ky.retry({
   187â†’							request: new Request('https://backup-api.com/endpoint', {
   188â†’								method: request.method,
   189â†’								headers: request.headers,
   190â†’							}),
   191â†’							code: 'BACKUP_ENDPOINT'
   192â†’						});
   193â†’					}
   194â†’
   235â†’export const retry = (options?: ForceRetryOptions) => new RetryMarker(options);

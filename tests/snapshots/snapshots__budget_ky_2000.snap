source/errors/ForceRetryError.ts
     4â†’/**
     5â†’Internal error used to signal a forced retry from afterResponse hooks.
     6â†’This is thrown when a user returns ky.retry() from an afterResponse hook.
     7â†’*/
     8â†’export class ForceRetryError extends Error {
     9â†’	override name = 'ForceRetryError' as const;
    10â†’	customDelay: number | undefined;
    11â†’	code: string | undefined;
    12â†’	customRequest: Request | undefined;
    13â†’
    14â†’	constructor(options?: ForceRetryOptions) {
    15â†’		// Runtime protection: wrap non-Error causes in NonError
    16â†’		// TypeScript type is Error for guidance, but JS users can pass anything
    17â†’		const cause = options?.cause
    18â†’			? (options.cause instanceof Error ? options.cause : new NonError(options.cause))
    19â†’			: undefined;
    20â†’
    21â†’		super(
    22â†’			options?.code ? `Forced retry: ${options.code}` : 'Forced retry',
    23â†’			cause ? {cause} : undefined,
    24â†’		);
    25â†’
    26â†’		this.customDelay = options?.delay;
    27â†’		this.code = options?.code;
    28â†’		this.customRequest = options?.request;
    29â†’	}
    30â†’}
source/errors/HTTPError.ts
     5â†’export class HTTPError<T = unknown> extends Error {
     6â†’	public response: KyResponse<T>;
     7â†’	public request: KyRequest;
     8â†’	public options: NormalizedOptions;
     9â†’
    10â†’	constructor(response: Response, request: Request, options: NormalizedOptions) {
    11â†’		const code = (response.status || response.status === 0) ? response.status : '';
    12â†’		const title = response.statusText ?? '';
    13â†’		const status = `${code} ${title}`.trim();
    14â†’		const reason = status ? `status code ${status}` : 'an unknown error';
    15â†’
    16â†’		super(`Request failed with ${reason}: ${request.method} ${request.url}`);
    17â†’
    18â†’		this.name = 'HTTPError';
    19â†’		this.response = response;
    20â†’		this.request = request;
    21â†’		this.options = options;
    22â†’	}
    23â†’}
source/errors/NonError.ts
     1â†’/**
     2â†’Wrapper for non-Error values that were thrown.
     3â†’
     4â†’In JavaScript, any value can be thrown (not just Error instances). This class wraps such values to ensure consistent error handling.
     5â†’*/
     6â†’export class NonError extends Error {
     7â†’	override name = 'NonError';
     8â†’	readonly value: unknown;
     9â†’
    10â†’	constructor(value: unknown) {
    11â†’		let message = 'Non-error value was thrown';
    12â†’
    13â†’		// Intentionally minimal as this error is just an edge-case.
    14â†’		try {
    15â†’			if (typeof value === 'string') {
    16â†’				message = value;
    17â†’			} else if (value && typeof value === 'object' && 'message' in value && typeof value.message === 'string') {
    18â†’				message = value.message;
    19â†’			}
    20â†’		} catch {
    21â†’			// Use default message if accessing properties throws
    22â†’		}
    23â†’
    24â†’		super(message);
    25â†’
    26â†’		this.value = value;
    27â†’	}
    28â†’}

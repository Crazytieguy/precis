source/errors/NonError.ts
     1Ôćĺ/**
     2ÔćĺWrapper for non-Error values that were thrown.
     3Ôćĺ
     4ÔćĺIn JavaScript, any value can be thrown (not just Error instances). This class wraps such values to ensure consistent error handling.
     5Ôćĺ*/
     6Ôćĺexport class NonError extends Error {
     7Ôćĺ	override name = 'NonError';
     8Ôćĺ	readonly value: unknown;
     9Ôćĺ
    10Ôćĺ	constructor(value: unknown) {
    11Ôćĺ		let message = 'Non-error value was thrown';
    12Ôćĺ
    13Ôćĺ		// Intentionally minimal as this error is just an edge-case.
    14Ôćĺ		try {
    15Ôćĺ			if (typeof value === 'string') {
    16Ôćĺ				message = value;
    17Ôćĺ			} else if (value && typeof value === 'object' && 'message' in value && typeof value.message === 'string') {
    18Ôćĺ				message = value.message;
    19Ôćĺ			}
    20Ôćĺ		} catch {
    21Ôćĺ			// Use default message if accessing properties throws
    22Ôćĺ		}
    23Ôćĺ
    24Ôćĺ		super(message);
    25Ôćĺ
    26Ôćĺ		this.value = value;
    27Ôćĺ	}
    28Ôćĺ}

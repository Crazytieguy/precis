     1Ôćĺimport type {ForceRetryOptions} from '../core/constants.js';
     2Ôćĺimport {NonError} from './NonError.js';
     4Ôćĺ/**
     5ÔćĺInternal error used to signal a forced retry from afterResponse hooks.
     6ÔćĺThis is thrown when a user returns ky.retry() from an afterResponse hook.
     7Ôćĺ*/
     8Ôćĺexport class ForceRetryError extends Error {
     9Ôćĺ	override name = 'ForceRetryError' as const;
    10Ôćĺ	customDelay: number | undefined;
    11Ôćĺ	code: string | undefined;
    12Ôćĺ	customRequest: Request | undefined;
    13Ôćĺ
    14Ôćĺ	constructor(options?: ForceRetryOptions) {
    15Ôćĺ		// Runtime protection: wrap non-Error causes in NonError
    16Ôćĺ		// TypeScript type is Error for guidance, but JS users can pass anything
    17Ôćĺ		const cause = options?.cause
    18Ôćĺ			? (options.cause instanceof Error ? options.cause : new NonError(options.cause))
    19Ôćĺ			: undefined;
    20Ôćĺ
    21Ôćĺ		super(
    22Ôćĺ			options?.code ? `Forced retry: ${options.code}` : 'Forced retry',
    23Ôćĺ			cause ? {cause} : undefined,
    24Ôćĺ		);
    25Ôćĺ
    26Ôćĺ		this.customDelay = options?.delay;
    27Ôćĺ		this.code = options?.code;
    28Ôćĺ		this.customRequest = options?.request;
    29Ôćĺ	}
    30Ôćĺ}

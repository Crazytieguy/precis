source/core/Ky.ts
    33â†’export class Ky {
    34â†’	static create(input: Input, options: Options): ResponsePromise {
    35â†’		const ky = new Ky(input, options);
    36â†’
    37â†’		const function_ = async (): Promise<Response> => {
    38â†’			if (typeof ky.#options.timeout === 'number' && ky.#options.timeout > maxSafeTimeout) {
    39â†’				throw new RangeError(`The \`timeout\` option cannot be greater than ${maxSafeTimeout}`);
    40â†’			}
    41â†’
    42â†’			// Delay the fetch so that body method shortcuts can set the Accept header
    43â†’			await Promise.resolve();
    44â†’			// Before using ky.request, _fetch clones it and saves the clone for future retries to use.
    45â†’			// If retry is not needed, close the cloned request's ReadableStream for memory safety.
    46â†’			let response = await ky.#fetch();
    47â†’
    48â†’			for (const hook of ky.#options.hooks.afterResponse) {
    49â†’				// Clone the response before passing to hook so we can cancel it if needed
    50â†’				const clonedResponse = ky.#decorateResponse(response.clone());
    51â†’
    52â†’				let modifiedResponse;
    53â†’				try {
    54â†’					// eslint-disable-next-line no-await-in-loop
    55â†’					modifiedResponse = await hook(
    56â†’						ky.request,
    57â†’						ky.#getNormalizedOptions(),
    58â†’						clonedResponse,
    59â†’						{retryCount: ky.#retryCount},
    60â†’					);
    61â†’				} catch (error) {
    62â†’					// Cancel both responses to prevent memory leaks when hook throws
    63â†’					ky.#cancelResponseBody(clonedResponse);
    64â†’					ky.#cancelResponseBody(response);
    65â†’					throw error;
    66â†’				}
    67â†’
    68â†’				if (modifiedResponse instanceof RetryMarker) {
   178â†’	static #normalizeSearchParams(searchParams: SearchParamsOption): SearchParamsOption {
   200â†’	constructor(input: Input, options: Options = {}) {
   201â†’		this.#input = input;
   202â†’
   203â†’		this.#options = {
   204â†’			...options,
   205â†’			headers: mergeHeaders((this.#input as Request).headers, options.headers),
   206â†’			hooks: mergeHooks(
   207â†’				{

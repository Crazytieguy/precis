source/utils/type-guards.ts
     5â†’/**
     6â†’Type guard to check if an error is a Ky error.
     7â†’
     8â†’@param error - The error to check
     9â†’@returns `true` if the error is a Ky error, `false` otherwise
    10â†’
    11â†’@example
    12â†’```
    13â†’import ky, {isKyError} from 'ky';
    14â†’try {
    15â†’	const response = await ky.get('/api/data');
    16â†’} catch (error) {
    17â†’	if (isKyError(error)) {
    18â†’		// Handle Ky-specific errors
    19â†’		console.log('Ky error occurred:', error.message);
    20â†’	} else {
    21â†’		// Handle other errors
    22â†’		console.log('Unknown error:', error);
    23â†’	}
    24â†’}
    25â†’```
    26â†’*/
    27â†’export function isKyError(error: unknown): error is HTTPError | TimeoutError | ForceRetryError {
    28â†’	return isHTTPError(error) || isTimeoutError(error) || isForceRetryError(error);
    29â†’}
    31â†’/**
    32â†’Type guard to check if an error is an HTTPError.
    33â†’
    34â†’@param error - The error to check
    35â†’@returns `true` if the error is an HTTPError, `false` otherwise
    36â†’
    37â†’@example
    38â†’```
    39â†’import ky, {isHTTPError} from 'ky';
    40â†’try {
    41â†’	const response = await ky.get('/api/data');
    42â†’} catch (error) {
    43â†’	if (isHTTPError(error)) {
    44â†’		console.log('HTTP error status:', error.response.status);
    45â†’	}
    46â†’}
    47â†’```
    48â†’*/
    49â†’export function isHTTPError<T = unknown>(error: unknown): error is HTTPError<T> {
    50â†’	return error instanceof HTTPError || ((error as any)?.name === HTTPError.name);
    51â†’}
    53â†’/**
    54â†’Type guard to check if an error is a TimeoutError.
    55â†’
    56â†’@param error - The error to check
    57â†’@returns `true` if the error is a TimeoutError, `false` otherwise
    58â†’
    59â†’@example
    60â†’```
    61â†’import ky, {isTimeoutError} from 'ky';
    62â†’try {
    63â†’	const response = await ky.get('/api/data', { timeout: 1000 });
    64â†’} catch (error) {
    65â†’	if (isTimeoutError(error)) {
    66â†’		console.log('Request timed out:', error.request.url);
    67â†’	}
    68â†’}
    69â†’```
    70â†’*/
    71â†’export function isTimeoutError(error: unknown): error is TimeoutError {
    72â†’	return error instanceof TimeoutError || ((error as any)?.name === TimeoutError.name);
    73â†’}
    75â†’/**
    76â†’Type guard to check if an error is a ForceRetryError.
    77â†’
    78â†’@param error - The error to check
    79â†’@returns `true` if the error is a ForceRetryError, `false` otherwise
    80â†’
    81â†’@example
    82â†’```
    83â†’import ky, {isForceRetryError} from 'ky';
    84â†’
    85â†’const api = ky.extend({
    86â†’	hooks: {
    87â†’		beforeRetry: [
    88â†’			({error, retryCount}) => {
    89â†’				if (isForceRetryError(error)) {
    90â†’					console.log(`Forced retry #${retryCount}: ${error.code}`);
    91â†’				}
    92â†’			}
    93â†’		]
    94â†’	}
    95â†’});
    96â†’```
    97â†’*/
    98â†’export function isForceRetryError(error: unknown): error is ForceRetryError {
    99â†’	return error instanceof ForceRetryError || ((error as any)?.name === ForceRetryError.name);
   100â†’}

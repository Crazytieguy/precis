     5‚Üí/**
     6‚ÜíType guard to check if an error is a Ky error.
     7‚Üí
     8‚Üí@param error - The error to check
     9‚Üí@returns `true` if the error is a Ky error, `false` otherwise
    10‚Üí
    11‚Üí@example
    12‚Üí```
    13‚Üíimport ky, {isKyError} from 'ky';
    14‚Üítry {
    15‚Üí	const response = await ky.get('/api/data');
    16‚Üí} catch (error) {
    17‚Üí	if (isKyError(error)) {
    18‚Üí		// Handle Ky-specific errors

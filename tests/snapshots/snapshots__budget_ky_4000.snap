   316â†’	async #calculateRetryDelay(error: unknown) {
   390â†’	#decorateResponse(response: Response): Response {
   398â†’	#cancelBody(body: ReadableStream | undefined): void {
   407â†’	#cancelResponseBody(response: Response): void {

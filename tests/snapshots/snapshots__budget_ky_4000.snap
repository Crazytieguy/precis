    58‚Üí
    59‚Üí@example
    60‚Üí```
    61‚Üíimport ky, {isTimeoutError} from 'ky';
    62‚Üítry {
    63‚Üí	const response = await ky.get('/api/data', { timeout: 1000 });
    64‚Üí} catch (error) {
    65‚Üí	if (isTimeoutError(error)) {
    66‚Üí		console.log('Request timed out:', error.request.url);
    67‚Üí	}
    68‚Üí}
    69‚Üí```
    70‚Üí*/
    71‚Üíexport function isTimeoutError(error: unknown): error is TimeoutError {
    72‚Üí	return error instanceof TimeoutError || ((error as any)?.name === TimeoutError.name);
    73‚Üí}
    75‚Üí/**

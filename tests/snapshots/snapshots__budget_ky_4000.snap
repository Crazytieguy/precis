    33‚Üíexport class Ky {
    34‚Üí	static create(input: Input, options: Options): ResponsePromise {
    35‚Üí		const ky = new Ky(input, options);
    36‚Üí
    37‚Üí		const function_ = async (): Promise<Response> => {
    38‚Üí			if (typeof ky.#options.timeout === 'number' && ky.#options.timeout > maxSafeTimeout) {
    39‚Üí				throw new RangeError(`The \`timeout\` option cannot be greater than ${maxSafeTimeout}`);
    40‚Üí			}
    41‚Üí
    42‚Üí			// Delay the fetch so that body method shortcuts can set the Accept header
    43‚Üí			await Promise.resolve();
    44‚Üí			// Before using ky.request, _fetch clones it and saves the clone for future retries to use.
    45‚Üí			// If retry is not needed, close the cloned request's ReadableStream for memory safety.
    46‚Üí			let response = await ky.#fetch();
    47‚Üí
    48‚Üí			for (const hook of ky.#options.hooks.afterResponse) {
    49‚Üí				// Clone the response before passing to hook so we can cancel it if needed
    50‚Üí				const clonedResponse = ky.#decorateResponse(response.clone());
    51‚Üí
    52‚Üí				let modifiedResponse;
    53‚Üí				try {
    54‚Üí					// eslint-disable-next-line no-await-in-loop
    55‚Üí					modifiedResponse = await hook(
    56‚Üí						ky.request,
    57‚Üí						ky.#getNormalizedOptions(),
    58‚Üí						clonedResponse,
    59‚Üí						{retryCount: ky.#retryCount},
    60‚Üí					);
    61‚Üí				} catch (error) {
    62‚Üí					// Cancel both responses to prevent memory leaks when hook throws
    63‚Üí					ky.#cancelResponseBody(clonedResponse);
    64‚Üí					ky.#cancelResponseBody(response);
    65‚Üí					throw error;
    66‚Üí				}
    67‚Üí
    68‚Üí				if (modifiedResponse instanceof RetryMarker) {
    69‚Üí					// Cancel both the cloned response passed to the hook and the current response to prevent resource leaks (especially important in Deno/Bun).
    70‚Üí					// Do not await cancellation since hooks can clone the response, leaving extra tee branches that keep cancel promises pending per the Streams spec.
    71‚Üí					ky.#cancelResponseBody(clonedResponse);
    72‚Üí					ky.#cancelResponseBody(response);
    73‚Üí					throw new ForceRetryError(modifiedResponse.options);
    74‚Üí				}
    75‚Üí
    76‚Üí				// Determine which response to use going forward
    77‚Üí				const nextResponse = modifiedResponse instanceof globalThis.Response ? modifiedResponse : response;
    78‚Üí
    79‚Üí				// Cancel any response bodies we won't use to prevent memory leaks.
    80‚Üí				// Uses fire-and-forget since hooks may have cloned the response, creating tee branches that block cancellation.
    81‚Üí				if (clonedResponse !== nextResponse) {
    82‚Üí					ky.#cancelResponseBody(clonedResponse);
    83‚Üí				}
    84‚Üí
    85‚Üí				if (response !== nextResponse) {
    86‚Üí					ky.#cancelResponseBody(response);
    87‚Üí				}
    88‚Üí
    89‚Üí				response = nextResponse;
    90‚Üí			}
    91‚Üí
    92‚Üí			ky.#decorateResponse(response);
    93‚Üí
    94‚Üí			if (!response.ok && (
    95‚Üí				typeof ky.#options.throwHttpErrors === 'function'
    96‚Üí					? ky.#options.throwHttpErrors(response.status)
    97‚Üí					: ky.#options.throwHttpErrors
    98‚Üí			)) {
    99‚Üí				let error = new HTTPError(response, ky.request, ky.#getNormalizedOptions());
   100‚Üí
   101‚Üí				for (const hook of ky.#options.hooks.beforeError) {
   102‚Üí					// eslint-disable-next-line no-await-in-loop
   103‚Üí					error = await hook(error, {retryCount: ky.#retryCount});
   104‚Üí				}
   105‚Üí
   106‚Üí				throw error;
   107‚Üí			}
   108‚Üí
   178‚Üí	static #normalizeSearchParams(searchParams: SearchParamsOption): SearchParamsOption {
   200‚Üí	constructor(input: Input, options: Options = {}) {
   201‚Üí		this.#input = input;
   202‚Üí
   203‚Üí		this.#options = {
   204‚Üí			...options,
   205‚Üí			headers: mergeHeaders((this.#input as Request).headers, options.headers),
   206‚Üí			hooks: mergeHooks(
   207‚Üí				{
   297‚Üí	#calculateDelay(): number {
   316‚Üí	async #calculateRetryDelay(error: unknown) {
   390‚Üí	#decorateResponse(response: Response): Response {
   398‚Üí	#cancelBody(body: ReadableStream | undefined): void {
   407‚Üí	#cancelResponseBody(response: Response): void {
   412‚Üí	async #retry<T extends (...arguments_: any) => Promise<any>>(function_: T): Promise<ReturnType<T> | Response | void> {
   463‚Üí	async #fetch(): Promise<Response> {
   503‚Üí	#getNormalizedOptions(): NormalizedOptions {
   512‚Üí	#assignRequest(request: Request): void {
   517‚Üí	#wrapRequestWithUploadProgress(request: Request, originalBody?: BodyInit): Request {
source/core/constants.ts
     4‚Üíexport const supportsRequestStreams = (() => {
     5‚Üí	let duplexAccessed = false;
     6‚Üí	let hasContentType = false;
     7‚Üí	const supportsReadableStream = typeof globalThis.ReadableStream === 'function';
     8‚Üí	const supportsRequest = typeof globalThis.Request === 'function';
     9‚Üí
    34‚Üíexport const supportsAbortController = typeof globalThis.AbortController === 'function';
    35‚Üíexport const supportsAbortSignal = typeof globalThis.AbortSignal === 'function' && typeof globalThis.AbortSignal.any === 'function';
    36‚Üíexport const supportsResponseStreams = typeof globalThis.ReadableStream === 'function';
    37‚Üíexport const supportsFormData = typeof globalThis.FormData === 'function';
    39‚Üíexport const requestMethods = ['get', 'post', 'put', 'patch', 'head', 'delete'] as const;
    41‚Üíconst validate = <T extends Array<true>>() => undefined as unknown as T;
    46‚Üíexport const responseTypes = {
    47‚Üí	json: 'application/json',
    48‚Üí	text: 'text/*',
    49‚Üí	formData: 'multipart/form-data',
    50‚Üí	arrayBuffer: '*/*',
    51‚Üí	blob: '*/*',
    58‚Üíexport const maxSafeTimeout = 2_147_483_647;
    61‚Üíexport const usualFormBoundarySize = new TextEncoder().encode('------WebKitFormBoundaryaxpyiPgbbPti10Rw').length;
    63‚Üíexport const stop = Symbol('stop');
    65‚Üí/**
    66‚ÜíOptions for forcing a retry via `ky.retry()`.
    67‚Üí*/
    68‚Üíexport type ForceRetryOptions = {
    69‚Üí	/**
    70‚Üí	Custom delay in milliseconds before retrying.
    71‚Üí
    72‚Üí	If not provided, uses the default retry delay calculation based on `retry.delay` configuration.
    73‚Üí
    74‚Üí	**Note:** Custom delays bypass jitter and `backoffLimit`. This is intentional, as custom delays often come from server responses (e.g., `Retry-After` headers) and should be respected exactly as specified.
    75‚Üí	*/
    76‚Üí	delay?: number;
    77‚Üí
    78‚Üí	/**
    79‚Üí	Error code for the retry.
    80‚Üí
    81‚Üí	This machine-readable identifier will be included in the error message passed to `beforeRetry` hooks, allowing you to distinguish between different types of forced retries.
    82‚Üí
    83‚Üí	@example
    84‚Üí	```
    85‚Üí	return ky.retry({code: 'RATE_LIMIT'});
    86‚Üí	// Resulting error message: 'Forced retry: RATE_LIMIT'
    87‚Üí	```
    88‚Üí	*/
    89‚Üí	code?: string;
    90‚Üí
    91‚Üí	/**
    92‚Üí	Original error that caused the retry.
    93‚Üí
    94‚Üí	This allows you to preserve the error chain when forcing a retry based on caught exceptions. The error will be set as the `cause` of the `ForceRetryError`, enabling proper error chain traversal.
    95‚Üí
    96‚Üí	@example
    97‚Üí	```
    98‚Üí	try {
    99‚Üí		const data = await response.clone().json();
   100‚Üí		validateBusinessLogic(data);
   101‚Üí	} catch (error) {
   102‚Üí		return ky.retry({
   103‚Üí			code: 'VALIDATION_FAILED',
   104‚Üí			cause: error  // Preserves original error in chain
   105‚Üí		});
   106‚Üí	}
   107‚Üí	```
   108‚Üí	*/
   109‚Üí	cause?: Error;
   110‚Üí
   111‚Üí	/**
   112‚Üí	Custom request to use for the retry.
   113‚Üí
   114‚Üí	This allows you to modify or completely replace the request during a forced retry. The custom request becomes the starting point for the retry - `beforeRetry` hooks can still further modify it if needed.
   115‚Üí
   116‚Üí	**Note:** The custom request's `signal` will be replaced with Ky's managed signal to handle timeouts and user-provided abort signals correctly. If the original request body has been consumed, you must provide a new body or clone the request before consuming.
   117‚Üí
   118‚Üí	@example
   119‚Üí	```
   120‚Üí	// Fallback to a different endpoint
   121‚Üí	return ky.retry({
   122‚Üí		request: new Request('https://backup-api.com/endpoint', {
   123‚Üí			method: request.method,
   124‚Üí			headers: request.headers,
   125‚Üí		}),
   126‚Üí		code: 'BACKUP_ENDPOINT'
   127‚Üí	});
   128‚Üí
   129‚Üí	// Retry with refreshed authentication token
   130‚Üí	const data = await response.clone().json();
   131‚Üí	return ky.retry({
   132‚Üí		request: new Request(request, {
   133‚Üí			headers: {
   134‚Üí				...Object.fromEntries(request.headers),
   135‚Üí				'Authorization': `Bearer ${data.newToken}`
   136‚Üí			}
   137‚Üí		}),
   138‚Üí		code: 'TOKEN_REFRESHED'
   139‚Üí	});
   140‚Üí	```
   141‚Üí	*/
   142‚Üí	request?: Request;
   143‚Üí};
   145‚Üí/**
   146‚ÜíMarker returned by ky.retry() to signal a forced retry from afterResponse hooks.
   147‚Üí*/
   148‚Üíexport class RetryMarker {
   149‚Üí	constructor(public options?: ForceRetryOptions) {}
   150‚Üí}
   152‚Üí/**
   153‚ÜíForce a retry from an `afterResponse` hook.
   154‚Üí
   155‚ÜíThis allows you to retry a request based on the response content, even if the response has a successful status code. The retry will respect the `retry.limit` option and skip the `shouldRetry` check. The forced retry is observable in `beforeRetry` hooks, where the error will be a `ForceRetryError`.
   156‚Üí
   157‚Üí@param options - Optional configuration for the retry.
   158‚Üí
   159‚Üí@example
   160‚Üí```
   161‚Üíimport ky, {isForceRetryError} from 'ky';
   162‚Üí
   163‚Üíconst api = ky.extend({
   164‚Üí	hooks: {
   165‚Üí		afterResponse: [
   166‚Üí			async (request, options, response) => {
   167‚Üí				// Retry based on response body content
   168‚Üí				if (response.status === 200) {
   169‚Üí					const data = await response.clone().json();
   170‚Üí
   171‚Üí					// Simple retry with default delay
   172‚Üí					if (data.error?.code === 'TEMPORARY_ERROR') {
   173‚Üí						return ky.retry();
   174‚Üí					}
   175‚Üí
   176‚Üí					// Retry with custom delay from API response
   177‚Üí					if (data.error?.code === 'RATE_LIMIT') {
   178‚Üí						return ky.retry({
   179‚Üí							delay: data.error.retryAfter * 1000,
   180‚Üí							code: 'RATE_LIMIT'
   181‚Üí						});
   182‚Üí					}
   183‚Üí
   184‚Üí					// Retry with a modified request (e.g., fallback endpoint)
   185‚Üí					if (data.error?.code === 'FALLBACK_TO_BACKUP') {
   186‚Üí						return ky.retry({
   187‚Üí							request: new Request('https://backup-api.com/endpoint', {
   188‚Üí								method: request.method,
   189‚Üí								headers: request.headers,
   190‚Üí							}),
   191‚Üí							code: 'BACKUP_ENDPOINT'
   192‚Üí						});
   193‚Üí					}
   194‚Üí
   195‚Üí					// Retry with refreshed authentication
   196‚Üí					if (data.error?.code === 'TOKEN_REFRESH' && data.newToken) {
   197‚Üí						return ky.retry({

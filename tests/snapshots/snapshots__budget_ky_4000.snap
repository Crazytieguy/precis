source/utils/type-guards.ts
     1→import {HTTPError} from '../errors/HTTPError.js';
     2→import {TimeoutError} from '../errors/TimeoutError.js';
     3→import {ForceRetryError} from '../errors/ForceRetryError.js';
     5→/**
     6→Type guard to check if an error is a Ky error.
     7→
     8→@param error - The error to check
     9→@returns `true` if the error is a Ky error, `false` otherwise
    10→
    11→@example
    12→```
    13→import ky, {isKyError} from 'ky';
    14→try {
    15→	const response = await ky.get('/api/data');
    16→} catch (error) {
    17→	if (isKyError(error)) {
    18→		// Handle Ky-specific errors
    19→		console.log('Ky error occurred:', error.message);
    20→	} else {
    21→		// Handle other errors
    22→		console.log('Unknown error:', error);
    23→	}
    24→}
    25→```
    26→*/
    27→export function isKyError(error: unknown): error is HTTPError | TimeoutError | ForceRetryError {
    28→	return isHTTPError(error) || isTimeoutError(error) || isForceRetryError(error);
    29→}
    31→/**
    32→Type guard to check if an error is an HTTPError.
    33→
    34→@param error - The error to check
    35→@returns `true` if the error is an HTTPError, `false` otherwise
    36→
    37→@example
    38→```
    39→import ky, {isHTTPError} from 'ky';
    40→try {
    41→	const response = await ky.get('/api/data');
    42→} catch (error) {
    43→	if (isHTTPError(error)) {
    44→		console.log('HTTP error status:', error.response.status);
    45→	}
    46→}
    47→```
    48→*/
    49→export function isHTTPError<T = unknown>(error: unknown): error is HTTPError<T> {
    50→	return error instanceof HTTPError || ((error as any)?.name === HTTPError.name);
    51→}
    53→/**
    54→Type guard to check if an error is a TimeoutError.
    55→
    56→@param error - The error to check
    57→@returns `true` if the error is a TimeoutError, `false` otherwise
    58→
    59→@example
    60→```
    61→import ky, {isTimeoutError} from 'ky';
    62→try {
    63→	const response = await ky.get('/api/data', { timeout: 1000 });
    64→} catch (error) {
    65→	if (isTimeoutError(error)) {
    66→		console.log('Request timed out:', error.request.url);
    67→	}
    68→}
    69→```
    70→*/
    71→export function isTimeoutError(error: unknown): error is TimeoutError {
    72→	return error instanceof TimeoutError || ((error as any)?.name === TimeoutError.name);
    73→}
    75→/**
    76→Type guard to check if an error is a ForceRetryError.
    77→
    78→@param error - The error to check
    79→@returns `true` if the error is a ForceRetryError, `false` otherwise
    80→
    81→@example
    82→```
    83→import ky, {isForceRetryError} from 'ky';
    84→
    85→const api = ky.extend({
    86→	hooks: {
    87→		beforeRetry: [
    88→			({error, retryCount}) => {
    89→				if (isForceRetryError(error)) {
    90→					console.log(`Forced retry #${retryCount}: ${error.code}`);
    91→				}
    92→			}
    93→		]
    94→	}
    95→});
    96→```
    97→*/
    98→export function isForceRetryError(error: unknown): error is ForceRetryError {
    99→	return error instanceof ForceRetryError || ((error as any)?.name === ForceRetryError.name);
   100→}


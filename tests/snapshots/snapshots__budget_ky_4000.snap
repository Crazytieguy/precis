    33‚Üí
    34‚Üí@param error - The error to check
    35‚Üí@returns `true` if the error is an HTTPError, `false` otherwise
    36‚Üí
    37‚Üí@example
    38‚Üí```
    39‚Üíimport ky, {isHTTPError} from 'ky';
    40‚Üítry {
    41‚Üí	const response = await ky.get('/api/data');
    42‚Üí} catch (error) {
    43‚Üí	if (isHTTPError(error)) {
    44‚Üí		console.log('HTTP error status:', error.response.status);
    45‚Üí	}
    46‚Üí}
    47‚Üí```
    48‚Üí*/
    49‚Üíexport function isHTTPError<T = unknown>(error: unknown): error is HTTPError<T> {
    50‚Üí	return error instanceof HTTPError || ((error as any)?.name === HTTPError.name);
    51‚Üí}
    53‚Üí/**
    54‚ÜíType guard to check if an error is a TimeoutError.
    55‚Üí
    56‚Üí@param error - The error to check

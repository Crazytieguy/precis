    63â†’export const stop = Symbol('stop');
    65â†’/**
    66â†’Options for forcing a retry via `ky.retry()`.
    67â†’*/
    68â†’export type ForceRetryOptions = {
    69â†’	/**
    70â†’	Custom delay in milliseconds before retrying.
    71â†’
    72â†’	If not provided, uses the default retry delay calculation based on `retry.delay` configuration.
    73â†’
    74â†’	**Note:** Custom delays bypass jitter and `backoffLimit`. This is intentional, as custom delays often come from server responses (e.g., `Retry-After` headers) and should be respected exactly as specified.
    75â†’	*/
    76â†’	delay?: number;
    77â†’
    78â†’	/**
    79â†’	Error code for the retry.
    80â†’
    81â†’	This machine-readable identifier will be included in the error message passed to `beforeRetry` hooks, allowing you to distinguish between different types of forced retries.
    82â†’
    83â†’	@example
    84â†’	```
    85â†’	return ky.retry({code: 'RATE_LIMIT'});
    86â†’	// Resulting error message: 'Forced retry: RATE_LIMIT'
    87â†’	```
    88â†’	*/
    89â†’	code?: string;
    90â†’
    91â†’	/**
    92â†’	Original error that caused the retry.
    93â†’
    94â†’	This allows you to preserve the error chain when forcing a retry based on caught exceptions. The error will be set as the `cause` of the `ForceRetryError`, enabling proper error chain traversal.
    95â†’
    96â†’	@example
    97â†’	```
    98â†’	try {
    99â†’		const data = await response.clone().json();
   100â†’		validateBusinessLogic(data);
   101â†’	} catch (error) {
   102â†’		return ky.retry({
   103â†’			code: 'VALIDATION_FAILED',
   104â†’			cause: error  // Preserves original error in chain
   105â†’		});
   106â†’	}
   107â†’	```
   108â†’	*/
   109â†’	cause?: Error;
   110â†’
   111â†’	/**
   112â†’	Custom request to use for the retry.
   113â†’
   114â†’	This allows you to modify or completely replace the request during a forced retry. The custom request becomes the starting point for the retry - `beforeRetry` hooks can still further modify it if needed.
   115â†’
   116â†’	**Note:** The custom request's `signal` will be replaced with Ky's managed signal to handle timeouts and user-provided abort signals correctly. If the original request body has been consumed, you must provide a new body or clone the request before consuming.
   117â†’
   118â†’	@example
   119â†’	```
   120â†’	// Fallback to a different endpoint
   121â†’	return ky.retry({
   122â†’		request: new Request('https://backup-api.com/endpoint', {
   123â†’			method: request.method,
   124â†’			headers: request.headers,
   125â†’		}),
   126â†’		code: 'BACKUP_ENDPOINT'
   127â†’	});
   128â†’
   129â†’	// Retry with refreshed authentication token
   130â†’	const data = await response.clone().json();
   131â†’	return ky.retry({
   132â†’		request: new Request(request, {
   133â†’			headers: {
   134â†’				...Object.fromEntries(request.headers),
   135â†’				'Authorization': `Bearer ${data.newToken}`
   136â†’			}
   137â†’		}),
   138â†’		code: 'TOKEN_REFRESHED'
   139â†’	});
   140â†’	```
   141â†’	*/
   142â†’	request?: Request;
   143â†’};
   145â†’/**
   146â†’Marker returned by ky.retry() to signal a forced retry from afterResponse hooks.
   147â†’*/
   148â†’export class RetryMarker {
   149â†’	constructor(public options?: ForceRetryOptions) {}
   150â†’}
   152â†’/**
   153â†’Force a retry from an `afterResponse` hook.
   154â†’
   155â†’This allows you to retry a request based on the response content, even if the response has a successful status code. The retry will respect the `retry.limit` option and skip the `shouldRetry` check. The forced retry is observable in `beforeRetry` hooks, where the error will be a `ForceRetryError`.
   156â†’
   157â†’@param options - Optional configuration for the retry.
   158â†’
   159â†’@example
   160â†’```
   161â†’import ky, {isForceRetryError} from 'ky';
   162â†’
   163â†’const api = ky.extend({
   164â†’	hooks: {
   165â†’		afterResponse: [
   166â†’			async (request, options, response) => {
   167â†’				// Retry based on response body content
   168â†’				if (response.status === 200) {
   169â†’					const data = await response.clone().json();
   170â†’
   171â†’					// Simple retry with default delay
   172â†’					if (data.error?.code === 'TEMPORARY_ERROR') {
   173â†’						return ky.retry();
   174â†’					}
   175â†’
   176â†’					// Retry with custom delay from API response
   177â†’					if (data.error?.code === 'RATE_LIMIT') {
   178â†’						return ky.retry({
   179â†’							delay: data.error.retryAfter * 1000,
   180â†’							code: 'RATE_LIMIT'
   181â†’						});
   182â†’					}
   183â†’
   184â†’					// Retry with a modified request (e.g., fallback endpoint)
   185â†’					if (data.error?.code === 'FALLBACK_TO_BACKUP') {
   186â†’						return ky.retry({
   187â†’							request: new Request('https://backup-api.com/endpoint', {
   188â†’								method: request.method,
   189â†’								headers: request.headers,
   190â†’							}),
   191â†’							code: 'BACKUP_ENDPOINT'
   192â†’						});
   193â†’					}
   194â†’
   195â†’					// Retry with refreshed authentication
   196â†’					if (data.error?.code === 'TOKEN_REFRESH' && data.newToken) {
   197â†’						return ky.retry({
   198â†’							request: new Request(request, {
   199â†’								headers: {
   200â†’									...Object.fromEntries(request.headers),
   201â†’									'Authorization': `Bearer ${data.newToken}`
   202â†’								}
   203â†’							}),
   204â†’							code: 'TOKEN_REFRESHED'
   205â†’						});
   206â†’					}
   207â†’
   208â†’					// Retry with cause to preserve error chain
   209â†’					try {
   210â†’						validateResponse(data);
   211â†’					} catch (error) {
   212â†’						return ky.retry({
   213â†’							code: 'VALIDATION_FAILED',
   214â†’							cause: error
   215â†’						});
   216â†’					}
   217â†’				}
   218â†’			}
   219â†’		],
   220â†’		beforeRetry: [
   221â†’			({error, retryCount}) => {
   222â†’				// Observable in beforeRetry hooks
   223â†’				if (isForceRetryError(error)) {
   224â†’					console.log(`Forced retry #${retryCount}: ${error.message}`);
   225â†’					// Example output: "Forced retry #1: Forced retry: RATE_LIMIT"
   226â†’				}
   227â†’			}
   228â†’		]
   229â†’	}
   230â†’});
   231â†’
   232â†’const response = await api.get('https://example.com/api');
   233â†’```
   234â†’*/
   235â†’export const retry = (options?: ForceRetryOptions) => new RetryMarker(options);
   237â†’export const kyOptionKeys: KyOptionsRegistry = {
   256â†’export const vendorSpecificOptions = {
   265â†’export const requestOptionsRegistry = {
source/errors/ForceRetryError.ts
     1â†’import type {ForceRetryOptions} from '../core/constants.js';
     2â†’import {NonError} from './NonError.js';
     4â†’/**
     5â†’Internal error used to signal a forced retry from afterResponse hooks.
     6â†’This is thrown when a user returns ky.retry() from an afterResponse hook.
     7â†’*/
     8â†’export class ForceRetryError extends Error {
     9â†’	override name = 'ForceRetryError' as const;
    10â†’	customDelay: number | undefined;
    11â†’	code: string | undefined;
    12â†’	customRequest: Request | undefined;
    13â†’
    14â†’	constructor(options?: ForceRetryOptions) {
    15â†’		// Runtime protection: wrap non-Error causes in NonError
    16â†’		// TypeScript type is Error for guidance, but JS users can pass anything
    17â†’		const cause = options?.cause
    18â†’			? (options.cause instanceof Error ? options.cause : new NonError(options.cause))
    19â†’			: undefined;
    20â†’
    21â†’		super(
    22â†’			options?.code ? `Forced retry: ${options.code}` : 'Forced retry',
    23â†’			cause ? {cause} : undefined,
    24â†’		);
    25â†’
    26â†’		this.customDelay = options?.delay;
    27â†’		this.code = options?.code;
    28â†’		this.customRequest = options?.request;
    29â†’	}
    30â†’}
source/errors/HTTPError.ts
     1â†’import type {NormalizedOptions} from '../types/options.js';
     2â†’import type {KyRequest} from '../types/request.js';
     3â†’import type {KyResponse} from '../types/response.js';
     5â†’export class HTTPError<T = unknown> extends Error {
     6â†’	public response: KyResponse<T>;
     7â†’	public request: KyRequest;
     8â†’	public options: NormalizedOptions;
     9â†’
    10â†’	constructor(response: Response, request: Request, options: NormalizedOptions) {
    11â†’		const code = (response.status || response.status === 0) ? response.status : '';
    12â†’		const title = response.statusText ?? '';
    13â†’		const status = `${code} ${title}`.trim();
    14â†’		const reason = status ? `status code ${status}` : 'an unknown error';
    15â†’
    16â†’		super(`Request failed with ${reason}: ${request.method} ${request.url}`);
    17â†’
    18â†’		this.name = 'HTTPError';
    19â†’		this.response = response;
    20â†’		this.request = request;
    21â†’		this.options = options;
    22â†’	}
    23â†’}
source/errors/NonError.ts
     1â†’/**
     2â†’Wrapper for non-Error values that were thrown.
     3â†’
     4â†’In JavaScript, any value can be thrown (not just Error instances). This class wraps such values to ensure consistent error handling.
     5â†’*/
     6â†’export class NonError extends Error {
     7â†’	override name = 'NonError';
     8â†’	readonly value: unknown;
     9â†’
    10â†’	constructor(value: unknown) {
    11â†’		let message = 'Non-error value was thrown';
    12â†’
    13â†’		// Intentionally minimal as this error is just an edge-case.
    14â†’		try {
    15â†’			if (typeof value === 'string') {
    16â†’				message = value;
    17â†’			} else if (value && typeof value === 'object' && 'message' in value && typeof value.message === 'string') {
    18â†’				message = value.message;
    19â†’			}
    20â†’		} catch {
    21â†’			// Use default message if accessing properties throws
    22â†’		}
    23â†’
    24â†’		super(message);
    25â†’
    26â†’		this.value = value;
    27â†’	}
    28â†’}

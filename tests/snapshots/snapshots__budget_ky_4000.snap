    65→/**
    66→Options for forcing a retry via `ky.retry()`.
    67→*/
    68→export type ForceRetryOptions = {
    69→	/**
    70→	Custom delay in milliseconds before retrying.
    71→
    72→	If not provided, uses the default retry delay calculation based on `retry.delay` configuration.
    73→
    74→	**Note:** Custom delays bypass jitter and `backoffLimit`. This is intentional, as custom delays often come from server responses (e.g., `Retry-After` headers) and should be respected exactly as specified.
    75→	*/
    76→	delay?: number;
    77→
    78→	/**
    79→	Error code for the retry.
    80→
    81→	This machine-readable identifier will be included in the error message passed to `beforeRetry` hooks, allowing you to distinguish between different types of forced retries.
    82→
    83→	@example
    84→	```
    85→	return ky.retry({code: 'RATE_LIMIT'});
    86→	// Resulting error message: 'Forced retry: RATE_LIMIT'
    87→	```
    88→	*/
    89→	code?: string;
    90→
    91→	/**
    92→	Original error that caused the retry.
    93→
    94→	This allows you to preserve the error chain when forcing a retry based on caught exceptions. The error will be set as the `cause` of the `ForceRetryError`, enabling proper error chain traversal.
    95→
    96→	@example
    97→	```
    98→	try {
    99→		const data = await response.clone().json();
   100→		validateBusinessLogic(data);
   101→	} catch (error) {
   102→		return ky.retry({
   103→			code: 'VALIDATION_FAILED',
   104→			cause: error  // Preserves original error in chain
   105→		});
   106→	}
   107→	```
   108→	*/
   109→	cause?: Error;
   110→
   111→	/**
   112→	Custom request to use for the retry.
   113→
   114→	This allows you to modify or completely replace the request during a forced retry. The custom request becomes the starting point for the retry - `beforeRetry` hooks can still further modify it if needed.
   115→
   116→	**Note:** The custom request's `signal` will be replaced with Ky's managed signal to handle timeouts and user-provided abort signals correctly. If the original request body has been consumed, you must provide a new body or clone the request before consuming.
   117→
   118→	@example
   119→	```
   120→	// Fallback to a different endpoint
   121→	return ky.retry({
   122→		request: new Request('https://backup-api.com/endpoint', {
   123→			method: request.method,
   124→			headers: request.headers,
   125→		}),
   126→		code: 'BACKUP_ENDPOINT'
   127→	});
   128→
   129→	// Retry with refreshed authentication token
   130→	const data = await response.clone().json();
   131→	return ky.retry({
   132→		request: new Request(request, {
   133→			headers: {
   134→				...Object.fromEntries(request.headers),
   135→				'Authorization': `Bearer ${data.newToken}`
   136→			}
   137→		}),
   138→		code: 'TOKEN_REFRESHED'
   139→	});
   140→	```
   141→	*/
   142→	request?: Request;
   143→};
   145→/**
   146→Marker returned by ky.retry() to signal a forced retry from afterResponse hooks.
   147→*/
   148→export class RetryMarker {
   149→	constructor(public options?: ForceRetryOptions) {}
   150→}
   152→/**
   153→Force a retry from an `afterResponse` hook.
   154→
   155→This allows you to retry a request based on the response content, even if the response has a successful status code. The retry will respect the `retry.limit` option and skip the `shouldRetry` check. The forced retry is observable in `beforeRetry` hooks, where the error will be a `ForceRetryError`.
   156→
   157→@param options - Optional configuration for the retry.
   158→
   159→@example
   160→```
   161→import ky, {isForceRetryError} from 'ky';
   162→
   163→const api = ky.extend({
   164→	hooks: {
   165→		afterResponse: [
   166→			async (request, options, response) => {
   167→				// Retry based on response body content
   168→				if (response.status === 200) {
   169→					const data = await response.clone().json();
   170→
   171→					// Simple retry with default delay
   172→					if (data.error?.code === 'TEMPORARY_ERROR') {
   173→						return ky.retry();
   174→					}
   175→
   176→					// Retry with custom delay from API response
   177→					if (data.error?.code === 'RATE_LIMIT') {
   178→						return ky.retry({
   179→							delay: data.error.retryAfter * 1000,
   180→							code: 'RATE_LIMIT'
   181→						});
   182→					}
   183→
   184→					// Retry with a modified request (e.g., fallback endpoint)
   185→					if (data.error?.code === 'FALLBACK_TO_BACKUP') {
   186→						return ky.retry({
   187→							request: new Request('https://backup-api.com/endpoint', {
   188→								method: request.method,
   189→								headers: request.headers,
   190→							}),
   191→							code: 'BACKUP_ENDPOINT'
   192→						});
   193→					}
   194→
   195→					// Retry with refreshed authentication
   196→					if (data.error?.code === 'TOKEN_REFRESH' && data.newToken) {
   197→						return ky.retry({
   198→							request: new Request(request, {
   199→								headers: {
   200→									...Object.fromEntries(request.headers),
   201→									'Authorization': `Bearer ${data.newToken}`
   202→								}
   203→							}),
   204→							code: 'TOKEN_REFRESHED'
   205→						});
   206→					}
   207→
   208→					// Retry with cause to preserve error chain
   209→					try {
   210→						validateResponse(data);
   211→					} catch (error) {
   212→						return ky.retry({
   213→							code: 'VALIDATION_FAILED',
   214→							cause: error
   215→						});
   216→					}
   217→				}
   218→			}
   219→		],
   220→		beforeRetry: [
   221→			({error, retryCount}) => {
   222→				// Observable in beforeRetry hooks
   223→				if (isForceRetryError(error)) {
   224→					console.log(`Forced retry #${retryCount}: ${error.message}`);
   225→					// Example output: "Forced retry #1: Forced retry: RATE_LIMIT"
   226→				}
   227→			}
   228→		]
   229→	}
   230→});
   231→
   232→const response = await api.get('https://example.com/api');
   233→```
   234→*/
   235→export const retry = (options?: ForceRetryOptions) => new RetryMarker(options);

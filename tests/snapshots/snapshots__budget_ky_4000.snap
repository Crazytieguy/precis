source/errors/ForceRetryError.ts
     4‚Üí/**
     5‚ÜíInternal error used to signal a forced retry from afterResponse hooks.
     6‚ÜíThis is thrown when a user returns ky.retry() from an afterResponse hook.
     7‚Üí*/
     8‚Üíexport class ForceRetryError extends Error {
     9‚Üí	override name = 'ForceRetryError' as const;
    10‚Üí	customDelay: number | undefined;
    11‚Üí	code: string | undefined;
    12‚Üí	customRequest: Request | undefined;
    13‚Üí
    14‚Üí	constructor(options?: ForceRetryOptions) {
    15‚Üí		// Runtime protection: wrap non-Error causes in NonError
    16‚Üí		// TypeScript type is Error for guidance, but JS users can pass anything
    17‚Üí		const cause = options?.cause
    18‚Üí			? (options.cause instanceof Error ? options.cause : new NonError(options.cause))
    19‚Üí			: undefined;
    20‚Üí
    21‚Üí		super(
    22‚Üí			options?.code ? `Forced retry: ${options.code}` : 'Forced retry',
    23‚Üí			cause ? {cause} : undefined,
    24‚Üí		);
    25‚Üí
    26‚Üí		this.customDelay = options?.delay;
    27‚Üí		this.code = options?.code;
    28‚Üí		this.customRequest = options?.request;
    29‚Üí	}
    30‚Üí}
source/errors/HTTPError.ts
     5‚Üíexport class HTTPError<T = unknown> extends Error {
     6‚Üí	public response: KyResponse<T>;
     7‚Üí	public request: KyRequest;
     8‚Üí	public options: NormalizedOptions;
     9‚Üí
    10‚Üí	constructor(response: Response, request: Request, options: NormalizedOptions) {
    11‚Üí		const code = (response.status || response.status === 0) ? response.status : '';
    12‚Üí		const title = response.statusText ?? '';
    13‚Üí		const status = `${code} ${title}`.trim();
    14‚Üí		const reason = status ? `status code ${status}` : 'an unknown error';
    15‚Üí
    16‚Üí		super(`Request failed with ${reason}: ${request.method} ${request.url}`);
    17‚Üí
    18‚Üí		this.name = 'HTTPError';
    19‚Üí		this.response = response;
    20‚Üí		this.request = request;
    21‚Üí		this.options = options;
    22‚Üí	}
    23‚Üí}
source/errors/NonError.ts
     1‚Üí/**
     2‚ÜíWrapper for non-Error values that were thrown.
     3‚Üí
     4‚ÜíIn JavaScript, any value can be thrown (not just Error instances). This class wraps such values to ensure consistent error handling.
     5‚Üí*/
     6‚Üíexport class NonError extends Error {
     7‚Üí	override name = 'NonError';
     8‚Üí	readonly value: unknown;
     9‚Üí
    10‚Üí	constructor(value: unknown) {
    11‚Üí		let message = 'Non-error value was thrown';
    12‚Üí
    13‚Üí		// Intentionally minimal as this error is just an edge-case.
    14‚Üí		try {
    15‚Üí			if (typeof value === 'string') {
    16‚Üí				message = value;
    17‚Üí			} else if (value && typeof value === 'object' && 'message' in value && typeof value.message === 'string') {
    18‚Üí				message = value.message;
    19‚Üí			}
    20‚Üí		} catch {
    21‚Üí			// Use default message if accessing properties throws
    22‚Üí		}
    23‚Üí
    24‚Üí		super(message);
    25‚Üí
    26‚Üí		this.value = value;
    27‚Üí	}
    28‚Üí}

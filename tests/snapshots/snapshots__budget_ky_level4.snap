    98‚Üí	try {
    99‚Üí		const data = await response.clone().json();
   100‚Üí		validateBusinessLogic(data);
   101‚Üí	} catch (error) {
   102‚Üí		return ky.retry({
   103‚Üí			code: 'VALIDATION_FAILED',

     1→import {requestMethods} from '../core/constants.js';
     2→import type {RetryOptions} from '../types/retry.js';
     3→import type {HttpMethod, RequestHttpMethod} from '../types/options.js';
     4→
     5→export const normalizeRequestMethod = (input: string): string =>
     6→	requestMethods.includes(input as RequestHttpMethod) ? input.toUpperCase() : input;
     7→
     8→const retryMethods: HttpMethod[] = ['get', 'put', 'head', 'delete', 'options', 'trace'];
     9→
    10→const retryStatusCodes = [408, 413, 429, 500, 502, 503, 504];
    11→
    12→const retryAfterStatusCodes = [413, 429, 503];
    13→
    14→type InternalRetryOptions = Required<Omit<RetryOptions, 'shouldRetry'>> & Pick<RetryOptions, 'shouldRetry'>;
    15→
    16→const defaultRetryOptions: InternalRetryOptions = {
    17→	limit: 2,
    18→	methods: retryMethods,
    19→	statusCodes: retryStatusCodes,
    20→	afterStatusCodes: retryAfterStatusCodes,
    21→	maxRetryAfter: Number.POSITIVE_INFINITY,
    22→	backoffLimit: Number.POSITIVE_INFINITY,
    23→	delay: attemptCount => 0.3 * (2 ** (attemptCount - 1)) * 1000,
    24→	jitter: undefined,
    25→	retryOnTimeout: false,
    26→};
    27→
    28→export const normalizeRetryOptions = (retry: number | RetryOptions = {}): InternalRetryOptions => {
    29→	if (typeof retry === 'number') {
    30→		return {
    31→			...defaultRetryOptions,
    32→			limit: retry,
    33→		};
    34→	}
    35→
    36→	if (retry.methods && !Array.isArray(retry.methods)) {
    37→		throw new Error('retry.methods must be an array');
    38→	}
    39→
    40→	retry.methods &&= retry.methods.map(method => method.toLowerCase());
    41→
    42→	if (retry.statusCodes && !Array.isArray(retry.statusCodes)) {
    43→		throw new Error('retry.statusCodes must be an array');
    44→	}
    45→
    46→	const normalizedRetry = Object.fromEntries(
    47→		Object.entries(retry).filter(([, value]) => value !== undefined),
    48→	) as RetryOptions;
    49→
    50→	return {
    51→		...defaultRetryOptions,
    52→		...normalizedRetry,
    53→	};
    54→};
utils/options.ts
     1→import {kyOptionKeys, requestOptionsRegistry, vendorSpecificOptions} from '../core/constants.js';
     2→import type {SearchParamsOption} from '../types/options.js';
     3→
     4→export const findUnknownOptions = (
     5→	request: Request,
     6→	options: Record<string, unknown>,
     7→): Record<string, unknown> => {
     8→	const unknownOptions: Record<string, unknown> = {};
     9→
    10→	for (const key in options) {
    11→		// Skip inherited properties
    12→		if (!Object.hasOwn(options, key)) {
    13→			continue;
    14→		}
    15→
    16→		// An option is passed to fetch() if:
    17→		// 1. It's not a standard RequestInit option (not in requestOptionsRegistry)
    18→		// 2. It's not a ky-specific option (not in kyOptionKeys)
    19→		// 3. Either:
    20→		//    a. It's not on the Request object, OR
    21→		//    b. It's a vendor-specific option that should always be passed (in vendorSpecificOptions)
    22→		if (!(key in requestOptionsRegistry) && !(key in kyOptionKeys) && (!(key in request) || key in vendorSpecificOptions)) {
    23→			unknownOptions[key] = options[key];
    24→		}
    25→	}
    26→
    27→	return unknownOptions;
    28→};
    29→
    30→export const hasSearchParameters = (search: SearchParamsOption): boolean => {
    31→	if (search === undefined) {
    32→		return false;
    33→	}
    34→
    35→	// The `typeof array` still gives "object", so we need different checking for array.
    36→	if (Array.isArray(search)) {
    37→		return search.length > 0;
    38→	}
    39→
    40→	if (search instanceof URLSearchParams) {
    41→		return search.size > 0;
    42→	}
    43→
    44→	// Record
    45→	if (typeof search === 'object') {
    46→		return Object.keys(search).length > 0;
    47→	}
    48→
    49→	if (typeof search === 'string') {
    50→		return search.trim().length > 0;
    51→	}
    52→
    53→	return Boolean(search);
    54→};
utils/timeout.ts
     1→import {TimeoutError} from '../errors/TimeoutError.js';
     2→
     3→export type TimeoutOptions = {
     4→	timeout: number;
     5→	fetch: typeof fetch;
     6→};
     7→
     8→// `Promise.race()` workaround (#91)
     9→export default async function timeout(
    10→	request: Request,
    11→	init: RequestInit,
    12→	abortController: AbortController | undefined,
    13→	options: TimeoutOptions,
    14→): Promise<Response> {
    15→	return new Promise((resolve, reject) => {
    16→		const timeoutId = setTimeout(() => {
    17→			if (abortController) {
    18→				abortController.abort();
    19→			}
    20→
    21→			reject(new TimeoutError(request));
    22→		}, options.timeout);
    23→
    24→		void options
    25→			.fetch(request, init)
    26→			.then(resolve)
    27→			.catch(reject)
    28→			.then(() => {
    29→				clearTimeout(timeoutId);
    30→			});
    31→	});
    32→}
utils/type-guards.ts
     1→import {HTTPError} from '../errors/HTTPError.js';
     2→import {TimeoutError} from '../errors/TimeoutError.js';
     3→import {ForceRetryError} from '../errors/ForceRetryError.js';
     4→
     5→/**
     6→Type guard to check if an error is a Ky error.
     7→
     8→@param error - The error to check
     9→@returns `true` if the error is a Ky error, `false` otherwise
    10→
    11→@example
    12→```
    13→import ky, {isKyError} from 'ky';
    14→try {
    15→	const response = await ky.get('/api/data');
    16→} catch (error) {
    17→	if (isKyError(error)) {
    18→		// Handle Ky-specific errors
    19→		console.log('Ky error occurred:', error.message);
    20→	} else {
    21→		// Handle other errors
    22→		console.log('Unknown error:', error);
    23→	}
    24→}
    25→```
    26→*/
    27→export function isKyError(error: unknown): error is HTTPError | TimeoutError | ForceRetryError {
    28→	return isHTTPError(error) || isTimeoutError(error) || isForceRetryError(error);
    29→}
    30→
    31→/**
    32→Type guard to check if an error is an HTTPError.
    33→
    34→@param error - The error to check
    35→@returns `true` if the error is an HTTPError, `false` otherwise
    36→
    37→@example
    38→```
    39→import ky, {isHTTPError} from 'ky';
    40→try {
    41→	const response = await ky.get('/api/data');
    42→} catch (error) {
    43→	if (isHTTPError(error)) {
    44→		console.log('HTTP error status:', error.response.status);
    45→	}
    46→}
    47→```
    48→*/
    49→export function isHTTPError<T = unknown>(error: unknown): error is HTTPError<T> {
    50→	return error instanceof HTTPError || ((error as any)?.name === HTTPError.name);
    51→}
    52→
    53→/**
    54→Type guard to check if an error is a TimeoutError.
    55→
    56→@param error - The error to check
    57→@returns `true` if the error is a TimeoutError, `false` otherwise
    58→
    59→@example
    60→```
    61→import ky, {isTimeoutError} from 'ky';
    62→try {
    63→	const response = await ky.get('/api/data', { timeout: 1000 });
    64→} catch (error) {
    65→	if (isTimeoutError(error)) {
    66→		console.log('Request timed out:', error.request.url);
    67→	}
    68→}
    69→```
    70→*/
    71→export function isTimeoutError(error: unknown): error is TimeoutError {
    72→	return error instanceof TimeoutError || ((error as any)?.name === TimeoutError.name);
    73→}
    74→
    75→/**
    76→Type guard to check if an error is a ForceRetryError.
    77→
    78→@param error - The error to check
    79→@returns `true` if the error is a ForceRetryError, `false` otherwise
    80→
    81→@example
    82→```
    83→import ky, {isForceRetryError} from 'ky';
    84→
    85→const api = ky.extend({
    86→	hooks: {
    87→		beforeRetry: [
    88→			({error, retryCount}) => {
    89→				if (isForceRetryError(error)) {
    90→					console.log(`Forced retry #${retryCount}: ${error.code}`);
    91→				}
    92→			}
    93→		]
    94→	}
    95→});
    96→```
    97→*/
    98→export function isForceRetryError(error: unknown): error is ForceRetryError {
    99→	return error instanceof ForceRetryError || ((error as any)?.name === ForceRetryError.name);
   100→}
utils/types.ts
     1→export type Mutable<T> = {
     2→	-readonly[P in keyof T]: T[P]
     3→};
     4→
     5→export type ObjectEntries<T> = T extends ArrayLike<infer U>
     6→	? Array<[string, U]>
     7→	: Array<{[K in keyof T]: [K, T[K]]}[keyof T]>;

types/retry.ts
     1→import type {HttpMethod} from './options.js';
     2→
     3→export type ShouldRetryState = {
     4→	/**
     5→	The error that caused the request to fail.
     6→	*/
     7→	error: Error;
     8→
     9→	/**
    10→	The number of retries attempted. Starts at 1 for the first retry.
    11→	*/
    12→	retryCount: number;
    13→};
    14→
    15→export type RetryOptions = {
    16→	/**
    17→	The number of times to retry failed requests.
    18→
    19→	@default 2
    20→	*/
    21→	limit?: number;
    22→
    23→	/**
    24→	The HTTP methods allowed to retry.
    25→
    26→	@default ['get', 'put', 'head', 'delete', 'options', 'trace']
    27→	*/
    28→	methods?: HttpMethod[];
    29→
    30→	/**
    31→	The HTTP status codes allowed to retry.
    32→
    33→	@default [408, 413, 429, 500, 502, 503, 504]
    34→	*/
    35→	statusCodes?: number[];
    36→
    37→	/**
    38→	The HTTP status codes allowed to retry with a `Retry-After` header.
    39→
    40→	@default [413, 429, 503]
    41→	*/
    42→	afterStatusCodes?: number[];
    43→
    44→	/**
    45→	If the `Retry-After` header is greater than `maxRetryAfter`, the request will be canceled.
    46→
    47→	@default Infinity
    48→	*/
    49→	maxRetryAfter?: number;
    50→
    51→	/**
    52→	The upper limit of the delay per retry in milliseconds.
    53→	To clamp the delay, set `backoffLimit` to 1000, for example.
    54→
    55→	By default, the delay is calculated in the following way:
    56→
    57→	```
    58→	0.3 * (2 ** (attemptCount - 1)) * 1000
    59→	```
    60→
    61→	The delay increases exponentially.
    62→
    63→	@default Infinity
    64→	*/
    65→	backoffLimit?: number;
    66→
    67→	/**
    68→	A function to calculate the delay between retries given `attemptCount` (starts from 1).
    69→
    70→	@default attemptCount => 0.3 * (2 ** (attemptCount - 1)) * 1000
    71→	*/
    72→	delay?: (attemptCount: number) => number;
    73→
    74→	/**
    75→	Add random jitter to retry delays to prevent thundering herd problems.
    76→
    77→	When many clients retry simultaneously (e.g., after hitting a rate limit), they can overwhelm the server again. Jitter adds randomness to break this synchronization.
    78→
    79→	Set to `true` to use full jitter, which randomizes the delay between 0 and the computed delay.
    80→
    81→	Alternatively, pass a function to implement custom jitter strategies.
    82→
    83→	@default undefined (no jitter)
    84→
    85→	@example
    86→	```
    87→	import ky from 'ky';
    88→
    89→	const json = await ky('https://example.com', {
    90→		retry: {
    91→			limit: 5,
    92→
    93→			// Full jitter (randomizes delay between 0 and computed value)
    94→			jitter: true
    95→
    96→			// Percentage jitter (80-120% of delay)
    97→			// jitter: delay => delay * (0.8 + Math.random() * 0.4)
    98→
    99→			// Absolute jitter (±100ms)
   100→			// jitter: delay => delay + (Math.random() * 200 - 100)
   101→		}
   102→	}).json();
   103→	```
   104→	*/
   105→	jitter?: boolean | ((delay: number) => number) | undefined;
   106→
   107→	/**
   108→	Whether to retry when the request times out.
   109→
   110→	@default false
   111→
   112→	@example
   113→	```
   114→	import ky from 'ky';
   115→
   116→	const json = await ky('https://example.com', {
   117→		retry: {
   118→			limit: 3,
   119→			retryOnTimeout: true
   120→		}
   121→	}).json();
   122→	```
   123→	*/
   124→	retryOnTimeout?: boolean;
   125→
   126→	/**
   127→	A function to determine whether a retry should be attempted.
   128→
   129→	This function takes precedence over all other retry checks and is called first, before any other retry validation.
   130→
   131→	**Note:** This is different from the `beforeRetry` hook:
   132→	- `shouldRetry`: Controls WHETHER to retry (called before the retry decision is made)
   133→	- `beforeRetry`: Called AFTER retry is confirmed, allowing you to modify the request
   134→
   135→	Should return:
   136→	- `true` to force a retry (bypasses `retryOnTimeout`, status code checks, and other validations)
   137→	- `false` to prevent a retry (no retry will occur)
   138→	- `undefined` to use the default retry logic (`retryOnTimeout`, status codes, etc.)
   139→
   140→	@example
   141→	```
   142→	import ky, {HTTPError} from 'ky';
   143→
   144→	const json = await ky('https://example.com', {
   145→		retry: {
   146→			limit: 3,
   147→			shouldRetry: ({error, retryCount}) => {
   148→				// Retry on specific business logic errors from API
   149→				if (error instanceof HTTPError) {
   150→					const status = error.response.status;
   151→
   152→					// Retry on 429 (rate limit) but only for first 2 attempts
   153→					if (status === 429 && retryCount <= 2) {
   154→						return true;
   155→					}
   156→
   157→					// Don't retry on 4xx errors except rate limits
   158→					if (status >= 400 && status < 500) {
   159→						return false;
   160→					}
   161→				}
   162→
   163→				// Use default retry logic for other errors
   164→				return undefined;
   165→			}
   166→		}
   167→	}).json();
   168→	```
   169→	*/
   170→	shouldRetry?: (state: ShouldRetryState) => boolean | undefined | Promise<boolean | undefined>;
   171→};
utils/body.ts
     1→import type {Options} from '../types/options.js';
     2→import {usualFormBoundarySize} from '../core/constants.js';
     3→
     4→// eslint-disable-next-line @typescript-eslint/ban-types
     5→export const getBodySize = (body?: BodyInit | null): number => {
     6→	if (!body) {
     7→		return 0;
     8→	}
     9→
    10→	if (body instanceof FormData) {
    11→		// This is an approximation, as FormData size calculation is not straightforward
    12→		let size = 0;
    13→
    14→		for (const [key, value] of body) {
    15→			size += usualFormBoundarySize;
    16→			size += new TextEncoder().encode(`Content-Disposition: form-data; name="${key}"`).length;
    17→			size += typeof value === 'string'
    18→				? new TextEncoder().encode(value).length
    19→				: value.size;
    20→		}
    21→
    22→		return size;
    23→	}
    24→
    25→	if (body instanceof Blob) {
    26→		return body.size;
    27→	}
    28→
    29→	if (body instanceof ArrayBuffer) {
    30→		return body.byteLength;
    31→	}
    32→
    33→	if (typeof body === 'string') {
    34→		return new TextEncoder().encode(body).length;
    35→	}
    36→
    37→	if (body instanceof URLSearchParams) {
    38→		return new TextEncoder().encode(body.toString()).length;
    39→	}
    40→
    41→	if ('byteLength' in body) {
    42→		return (body).byteLength;
    43→	}
    44→
    45→	if (typeof body === 'object' && body !== null) {
    46→		try {
    47→			const jsonString = JSON.stringify(body);
    48→			return new TextEncoder().encode(jsonString).length;
    49→		} catch {
    50→			return 0;
    51→		}
    52→	}
    53→
    54→	return 0; // Default case, unable to determine size
    55→};
    56→
    57→const withProgress = (stream: ReadableStream<Uint8Array>, totalBytes: number, onProgress: Options['onDownloadProgress'] | Options['onUploadProgress']): ReadableStream<Uint8Array> => {
    58→	let previousChunk: Uint8Array | undefined;
    59→	let transferredBytes = 0;
    60→
    61→	return stream.pipeThrough(new TransformStream<Uint8Array, Uint8Array>({
    62→		transform(currentChunk, controller) {
    63→			controller.enqueue(currentChunk);
    64→
    65→			if (previousChunk) {
    66→				transferredBytes += previousChunk.byteLength;
    67→
    68→				let percent = totalBytes === 0 ? 0 : transferredBytes / totalBytes;
    69→				// Avoid reporting 100% progress before the stream is actually finished (in case totalBytes is inaccurate)
    70→				if (percent >= 1) {
    71→					// Epsilon is used here to get as close as possible to 100% without reaching it.
    72→					// If we were to use 0.99 here, percent could potentially go backwards.
    73→					percent = 1 - Number.EPSILON;
    74→				}
    75→
    76→				onProgress?.({percent, totalBytes: Math.max(totalBytes, transferredBytes), transferredBytes}, previousChunk);
    77→			}
    78→
    79→			previousChunk = currentChunk;
    80→		},
    81→		flush() {
    82→			if (previousChunk) {
    83→				transferredBytes += previousChunk.byteLength;
    84→				onProgress?.({percent: 1, totalBytes: Math.max(totalBytes, transferredBytes), transferredBytes}, previousChunk);
    85→			}
    86→		},
    87→	}));
    88→};
    89→
    90→export const streamResponse = (response: Response, onDownloadProgress: Options['onDownloadProgress']) => {
    91→	if (!response.body) {
    92→		return response;
    93→	}
    94→
    95→	if (response.status === 204) {
    96→		return new Response(
    97→			null,
    98→			{
    99→				status: response.status,
   100→				statusText: response.statusText,
   101→				headers: response.headers,
   102→			},
   103→		);
   104→	}
   105→
   106→	const totalBytes = Math.max(0, Number(response.headers.get('content-length')) || 0);
   107→
   108→	return new Response(
   109→		withProgress(response.body, totalBytes, onDownloadProgress),
   110→		{
   111→			status: response.status,
   112→			statusText: response.statusText,
   113→			headers: response.headers,
   114→		},
   115→	);
   116→};
   117→
   118→// eslint-disable-next-line @typescript-eslint/ban-types
   119→export const streamRequest = (request: Request, onUploadProgress: Options['onUploadProgress'], originalBody?: BodyInit | null) => {
   120→	if (!request.body) {
   121→		return request;
   122→	}
   123→
   124→	// Use original body for size calculation since request.body is already a stream
   125→	const totalBytes = getBodySize(originalBody ?? request.body);
   126→
   127→	return new Request(request, {
   128→		// @ts-expect-error - Types are outdated.
   129→		duplex: 'half',
   130→		body: withProgress(request.body, totalBytes, onUploadProgress),
   131→	});
   132→};
utils/delay.ts
     1→// https://github.com/sindresorhus/delay/tree/ab98ae8dfcb38e1593286c94d934e70d14a4e111
     2→
     3→import {type InternalOptions} from '../types/options.js';
     4→
     5→export type DelayOptions = {
     6→	signal?: InternalOptions['signal'];
     7→};
     8→
     9→export default async function delay(
    10→	ms: number,
    11→	{signal}: DelayOptions,
    12→): Promise<void> {
    13→	return new Promise((resolve, reject) => {
    14→		if (signal) {
    15→			signal.throwIfAborted();
    16→			signal.addEventListener('abort', abortHandler, {once: true});
    17→		}
    18→
    19→		function abortHandler() {
    20→			clearTimeout(timeoutId);
    21→			reject(signal!.reason as Error);
    22→		}
    23→
    24→		const timeoutId = setTimeout(() => {
    25→			signal?.removeEventListener('abort', abortHandler);
    26→			resolve();
    27→		}, ms);
    28→	});
    29→}
utils/is.ts
     1→// eslint-disable-next-line @typescript-eslint/ban-types
     2→export const isObject = (value: unknown): value is object => value !== null && typeof value === 'object';
utils/merge.ts
     1→import type {KyHeadersInit, Options} from '../types/options.js';
     2→import type {Hooks} from '../types/hooks.js';
     3→import {supportsAbortSignal} from '../core/constants.js';
     4→import {isObject} from './is.js';
     5→
     6→export const validateAndMerge = (...sources: Array<Partial<Options> | undefined>): Partial<Options> => {
     7→	for (const source of sources) {
     8→		if ((!isObject(source) || Array.isArray(source)) && source !== undefined) {
     9→			throw new TypeError('The `options` argument must be an object');
    10→		}
    11→	}
    12→
    13→	return deepMerge({}, ...sources);
    14→};
    15→
    16→export const mergeHeaders = (source1: KyHeadersInit = {}, source2: KyHeadersInit = {}) => {
    17→	const result = new globalThis.Headers(source1 as RequestInit['headers']);
    18→	const isHeadersInstance = source2 instanceof globalThis.Headers;
    19→	const source = new globalThis.Headers(source2 as RequestInit['headers']);
    20→
    21→	for (const [key, value] of source.entries()) {
    22→		if ((isHeadersInstance && value === 'undefined') || value === undefined) {
    23→			result.delete(key);
    24→		} else {
    25→			result.set(key, value);
    26→		}
    27→	}
    28→
    29→	return result;
    30→};
    31→
    32→function newHookValue<K extends keyof Hooks>(original: Hooks, incoming: Hooks, property: K): Required<Hooks>[K] {
    33→	return (Object.hasOwn(incoming, property) && incoming[property] === undefined)
    34→		? []
    35→		: deepMerge<Required<Hooks>[K]>(original[property] ?? [], incoming[property] ?? []);
    36→}
    37→
    38→export const mergeHooks = (original: Hooks = {}, incoming: Hooks = {}): Required<Hooks> => (
    39→	{
    40→		beforeRequest: newHookValue(original, incoming, 'beforeRequest'),
    41→		beforeRetry: newHookValue(original, incoming, 'beforeRetry'),
    42→		afterResponse: newHookValue(original, incoming, 'afterResponse'),
    43→		beforeError: newHookValue(original, incoming, 'beforeError'),
    44→	}
    45→);
    46→
    47→const appendSearchParameters = (target: any, source: any): URLSearchParams => {
    48→	const result = new URLSearchParams();
    49→
    50→	for (const input of [target, source]) {
    51→		if (input === undefined) {
    52→			continue;
    53→		}
    54→
    55→		if (input instanceof URLSearchParams) {
    56→			for (const [key, value] of input.entries()) {
    57→				result.append(key, value);
    58→			}
    59→		} else if (Array.isArray(input)) {
    60→			for (const pair of input) {
    61→				if (!Array.isArray(pair) || pair.length !== 2) {
    62→					throw new TypeError('Array search parameters must be provided in [[key, value], ...] format');
    63→				}
    64→
    65→				result.append(String(pair[0]), String(pair[1]));
    66→			}
    67→		} else if (isObject(input)) {
    68→			for (const [key, value] of Object.entries(input)) {
    69→				if (value !== undefined) {
    70→					result.append(key, String(value));
    71→				}
    72→			}
    73→		} else {
    74→			// String
    75→			const parameters = new URLSearchParams(input);
    76→			for (const [key, value] of parameters.entries()) {
    77→				result.append(key, value);
    78→			}
    79→		}
    80→	}
    81→
    82→	return result;
    83→};
    84→
    85→// TODO: Make this strongly-typed (no `any`).
    86→export const deepMerge = <T>(...sources: Array<Partial<T> | undefined>): T => {
    87→	let returnValue: any = {};
    88→	let headers = {};
    89→	let hooks = {};
    90→	let searchParameters: any;
    91→	const signals: AbortSignal[] = [];
    92→
    93→	for (const source of sources) {
    94→		if (Array.isArray(source)) {
    95→			if (!Array.isArray(returnValue)) {
    96→				returnValue = [];
    97→			}
    98→
    99→			returnValue = [...returnValue, ...source];
   100→		} else if (isObject(source)) {
   101→			for (let [key, value] of Object.entries(source)) {
   102→				// Special handling for AbortSignal instances
   103→				if (key === 'signal' && value instanceof globalThis.AbortSignal) {
   104→					signals.push(value);
   105→					continue;
   106→				}
   107→
   108→				// Special handling for context - shallow merge only
   109→				if (key === 'context') {
   110→					if (value !== undefined && value !== null && (!isObject(value) || Array.isArray(value))) {
   111→						throw new TypeError('The `context` option must be an object');

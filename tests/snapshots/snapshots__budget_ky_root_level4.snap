source/types/hooks.ts
     5→export type BeforeRequestState = {
     6→	/**
     7→	The number of retries attempted. `0` for the initial request, increments with each retry.
     8→
     9→	This allows you to distinguish between initial requests and retries, which is useful when you need different behavior for retries (e.g., avoiding overwriting headers set in `beforeRetry`).
    10→	*/
    11→	retryCount: number;
    12→};
    14→export type BeforeRequestHook = (
    15→	request: KyRequest,
    16→	options: NormalizedOptions,
    17→	state: BeforeRequestState
    18→) => Request | Response | void | Promise<Request | Response | void>;
    20→export type BeforeRetryState = {
    21→	request: KyRequest;
    22→	options: NormalizedOptions;
    23→	error: Error;
    24→
    25→	/**
    26→	The number of retries attempted. Always `>= 1` since this hook is only called during retries, not on the initial request.
    27→	*/
    28→	retryCount: number;
    29→};
    30→export type BeforeRetryHook = (options: BeforeRetryState) => Request | Response | typeof stop | void | Promise<Request | Response | typeof stop | void>;
    32→export type AfterResponseState = {
    33→	/**
    34→	The number of retries attempted. `0` for the initial request, increments with each retry.
    35→
    36→	This allows you to distinguish between initial requests and retries, which is useful when you need different behavior for retries (e.g., showing a notification only on the final retry).
    37→	*/
    38→	retryCount: number;
    39→};
    41→export type AfterResponseHook = (
    42→	request: KyRequest,
    43→	options: NormalizedOptions,
    44→	response: KyResponse,
    45→	state: AfterResponseState
    46→) => Response | RetryMarker | void | Promise<Response | RetryMarker | void>;
    48→export type BeforeErrorState = {
    49→	/**
    50→	The number of retries attempted. `0` for the initial request, increments with each retry.
    51→
    52→	This allows you to distinguish between the initial request and retries, which is useful when you need different error handling based on retry attempts (e.g., showing different error messages on the final attempt).
    53→	*/
    54→	retryCount: number;
    55→};
    57→export type BeforeErrorHook = (error: HTTPError, state: BeforeErrorState) => HTTPError | Promise<HTTPError>;
    59→export type Hooks = {
    60→	/**
    61→	This hook enables you to modify the request right before it is sent. Ky will make no further changes to the request after this. The hook function receives the normalized request, options, and a state object. You could, for example, modify `request.headers` here.
    62→
    63→	The `state.retryCount` is `0` for the initial request and increments with each retry. This allows you to distinguish between initial requests and retries, which is useful when you need different behavior for retries (e.g., avoiding overwriting headers set in `beforeRetry`).
    64→
    65→	A [`Response`](https://developer.mozilla.org/en-US/docs/Web/API/Response) can be returned from this hook to completely avoid making an HTTP request. This can be used to mock a request, check an internal cache, etc. An **important** consideration when returning a `Response` from this hook is that all the following hooks will be skipped, so **ensure you only return a `Response` from the last hook**.
    66→
    67→	@example
    68→	```
    69→	import ky from 'ky';
    70→
    71→	const response = await ky('https://example.com', {
    72→		hooks: {
    73→			beforeRequest: [
    74→				(request, options, {retryCount}) => {
    75→					// Only set default auth header on initial request, not on retries
    76→					// (retries may have refreshed token set by beforeRetry)
    77→					if (retryCount === 0) {
    78→						request.headers.set('Authorization', 'token initial-token');
    79→					}
    80→				}
    81→			]
    82→		}
    83→	});
    84→	```
    85→
    86→	@default []
    87→	*/
    88→	beforeRequest?: BeforeRequestHook[];
    89→
    90→	/**
    91→	This hook enables you to modify the request right before retry. Ky will make no further changes to the request after this. The hook function receives an object with the normalized request and options, an error instance, and the retry count. You could, for example, modify `request.headers` here.
    92→
    93→	The hook can return a [`Request`](https://developer.mozilla.org/en-US/docs/Web/API/Request) to replace the outgoing retry request, or return a [`Response`](https://developer.mozilla.org/en-US/docs/Web/API/Response) to skip the retry and use that response instead. **Note:** Returning a request or response skips remaining `beforeRetry` hooks.
    94→
    95→	If the request received a response, the error will be of type `HTTPError` and the `Response` object will be available at `error.response`. Be aware that some types of errors, such as network errors, inherently mean that a response was not received. In that case, the error will not be an instance of `HTTPError`.
    96→
    97→	You can prevent Ky from retrying the request by throwing an error. Ky will not handle it in any way and the error will be propagated to the request initiator. The rest of the `beforeRetry` hooks will not be called in this case. Alternatively, you can return the [`ky.stop`](#ky.stop) symbol to do the same thing but without propagating an error (this has some limitations, see `ky.stop` docs for details).
    98→
    99→	**Modifying headers:**
   100→
   101→	@example
   102→	```
   103→	import ky from 'ky';
   104→
   105→	const response = await ky('https://example.com', {
   106→		hooks: {
   107→			beforeRetry: [
   108→				async ({request, options, error, retryCount}) => {
   109→					const token = await ky('https://example.com/refresh-token');
   110→					request.headers.set('Authorization', `token ${token}`);
   111→				}
   112→			]
   113→		}
   114→	});
   115→	```
   116→
   117→	**Modifying the request URL:**
   118→
   119→	@example
   120→	```
   121→	import ky from 'ky';
   122→
   123→	const response = await ky('https://example.com/api', {
   124→		hooks: {
   125→			beforeRetry: [
   126→				async ({request, error}) => {
   127→					// Add query parameters based on error response
   128→					if (error.response) {
   129→						const body = await error.response.json();
   130→						const url = new URL(request.url);
   131→						url.searchParams.set('processId', body.processId);
   132→						return new Request(url, request);
   133→					}
   134→				}
   135→			]
   136→		}
   137→	});
   138→	```
   139→
   140→	**Returning a cached response:**
   141→
   142→	@example
   143→	```
   144→	import ky from 'ky';
   145→
   146→	const response = await ky('https://example.com/api', {
   147→		hooks: {
   148→			beforeRetry: [
   149→				({error, retryCount}) => {
   150→					// Use cached response instead of retrying
   151→					if (retryCount > 1 && cachedResponse) {
   152→						return cachedResponse;
   153→					}
   154→				}
   155→			]
   156→		}
   157→	});
   158→	```
   159→
   160→	@default []
   161→	*/
   162→	beforeRetry?: BeforeRetryHook[];
   163→
   164→	/**
   165→	This hook enables you to read and optionally modify the response. The hook function receives normalized request, options, a clone of the response, and a state object. The return value of the hook function will be used by Ky as the response object if it's an instance of [`Response`](https://developer.mozilla.org/en-US/docs/Web/API/Response).
   166→
   167→	You can also force a retry by returning `ky.retry()` or `ky.retry(options)`. This is useful when you need to retry based on the response body content, even if the response has a successful status code. The retry will respect the retry limit and be observable in `beforeRetry` hooks.
   168→
   169→	@default []
   170→
   171→	@example
   172→	```
   173→	import ky from 'ky';
   174→
   175→	const response = await ky('https://example.com', {
   176→		hooks: {
   177→			afterResponse: [
   178→				(_request, _options, response) => {
   179→					// You could do something with the response, for example, logging.
   180→					log(response);
   181→
   182→					// Or return a `Response` instance to overwrite the response.
   183→					return new Response('A different response', {status: 200});
   184→				},
   185→
   186→				// Or retry with a fresh token on a 401 error
   187→				async (request, _options, response, state) => {
   188→					if (response.status === 401 && state.retryCount === 0) {
   189→						// Only refresh on first 401, not on subsequent retries
   190→						const {token} = await ky.post('https://example.com/auth/refresh').json();
   191→
   192→						const headers = new Headers(request.headers);
   193→						headers.set('Authorization', `Bearer ${token}`);
   194→
   195→						return ky.retry({
   196→							request: new Request(request, {headers}),
   197→							code: 'TOKEN_REFRESHED'
   198→						});
   199→					}
   200→				},
   201→
   202→				// Or force retry based on response body content
   203→				async (request, options, response) => {
   204→					if (response.status === 200) {
   205→						const data = await response.clone().json();
   206→						if (data.error?.code === 'RATE_LIMIT') {
   207→							// Force retry with custom delay from API response
   208→							return ky.retry({
   209→								delay: data.error.retryAfter * 1000,
   210→								code: 'RATE_LIMIT'
   211→							});
   212→						}
   213→					}
   214→				},
   215→
   216→				// Or show a notification only on the last retry for 5xx errors
   217→				(request, options, response, {retryCount}) => {
   218→					if (response.status >= 500 && response.status <= 599) {
   219→						if (retryCount === options.retry.limit) {
   220→							showNotification('Request failed after all retries');
   221→						}
   222→					}
   223→				}
   224→			]
   225→		}
   226→	});
   227→	```
   228→	*/
   229→	afterResponse?: AfterResponseHook[];
   230→
   231→	/**
   232→	This hook enables you to modify the `HTTPError` right before it is thrown. The hook function receives an `HTTPError` and a state object as arguments and should return an instance of `HTTPError`.
   233→
   234→	@default []
   235→
   236→	@example
   237→	```
   238→	import ky from 'ky';
   239→
   240→	await ky('https://example.com', {
   241→		hooks: {
   242→			beforeError: [
   243→				async error => {
   244→					const {response} = error;
   245→					if (response) {
   246→						const body = await response.json();
   247→						error.name = 'GitHubError';
   248→						error.message = `${body.message} (${response.status})`;
   249→					}
   250→
   251→					return error;
   252→				},
   253→
   254→				// Or show different message based on retry count
   255→				(error, {retryCount}) => {
   256→					if (retryCount === error.options.retry.limit) {
   257→						error.message = `${error.message} (failed after ${retryCount} retries)`;
   258→					}
   259→
   260→					return error;
   261→				}
   262→			]
   263→		}
   264→	});
   265→	```
   266→	*/
   267→	beforeError?: BeforeErrorHook[];
   268→};
source/types/ky.ts
     5→export type KyInstance = {
     6→	/**
     7→	Fetch the given `url`.
     8→
     9→	@param url - `Request` object, `URL` object, or URL string.
    10→	@returns A promise with `Body` method added.
    11→
    12→	@example
    13→	```
    14→	import ky from 'ky';
    15→
    16→	const json = await ky('https://example.com', {json: {foo: true}}).json();
    17→
    18→	console.log(json);
    19→	//=> `{data: '🦄'}`
    20→	```
    21→	*/
    22→	<T>(url: Input, options?: Options): ResponsePromise<T>;
    23→
    24→	/**
    25→	Fetch the given `url` using the option `{method: 'get'}`.
    26→
    27→	@param url - `Request` object, `URL` object, or URL string.
    28→	@returns A promise with `Body` methods added.
    29→	*/
    30→	get: <T>(url: Input, options?: Options) => ResponsePromise<T>;
    31→
    32→	/**
    33→	Fetch the given `url` using the option `{method: 'post'}`.
    34→
    35→	@param url - `Request` object, `URL` object, or URL string.
    36→	@returns A promise with `Body` methods added.
    37→	*/
    38→	post: <T>(url: Input, options?: Options) => ResponsePromise<T>;
    39→
    40→	/**
    41→	Fetch the given `url` using the option `{method: 'put'}`.
    42→
    43→	@param url - `Request` object, `URL` object, or URL string.
    44→	@returns A promise with `Body` methods added.
    45→	*/
    46→	put: <T>(url: Input, options?: Options) => ResponsePromise<T>;
    47→
    48→	/**
    49→	Fetch the given `url` using the option `{method: 'delete'}`.
    50→
    51→	@param url - `Request` object, `URL` object, or URL string.
    52→	@returns A promise with `Body` methods added.
    53→	*/
    54→	delete: <T>(url: Input, options?: Options) => ResponsePromise<T>;
    55→
    56→	/**
    57→	Fetch the given `url` using the option `{method: 'patch'}`.
    58→
    59→	@param url - `Request` object, `URL` object, or URL string.
    60→	@returns A promise with `Body` methods added.
    61→	*/
    62→	patch: <T>(url: Input, options?: Options) => ResponsePromise<T>;
    63→
    64→	/**
    65→	Fetch the given `url` using the option `{method: 'head'}`.
    66→
    67→	@param url - `Request` object, `URL` object, or URL string.
    68→	@returns A promise with `Body` methods added.
    69→	*/
    70→	head: (url: Input, options?: Options) => ResponsePromise;
    71→
    72→	/**
    73→	Create a new Ky instance with complete new defaults.
    74→
    75→	@returns A new Ky instance.
    76→	*/
    77→	create: (defaultOptions?: Options) => KyInstance;
    78→
    79→	/**
    80→	Create a new Ky instance with some defaults overridden with your own.
    81→
    82→	In contrast to `ky.create()`, `ky.extend()` inherits defaults from its parent.
    83→
    84→	You can also refer to parent defaults by providing a function to `.extend()`.
    85→
    86→	@example
    87→	```
    88→	import ky from 'ky';
    89→
    90→	const api = ky.create({prefixUrl: 'https://example.com/api'});
    91→
    92→	const usersApi = api.extend((options) => ({prefixUrl: `${options.prefixUrl}/users`}));
    93→
    94→	const response = await usersApi.get('123');
    95→	//=> 'https://example.com/api/users/123'
    96→
    97→	const response = await api.get('version');
    98→	//=> 'https://example.com/api/version'
    99→	```
   100→
   101→	@returns A new Ky instance.
   102→	*/
   103→	extend: (defaultOptions: Options | ((parentOptions: Options) => Options)) => KyInstance;
   104→
   105→	/**
   106→	A `Symbol` that can be returned by a `beforeRetry` hook to stop the retry. This will also short circuit the remaining `beforeRetry` hooks.
   107→
   108→	Note: Returning this symbol makes Ky abort and return with an `undefined` response. Be sure to check for a response before accessing any properties on it or use [optional chaining](https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Operators/Optional_chaining). It is also incompatible with body methods, such as `.json()` or `.text()`, because there is no response to parse. In general, we recommend throwing an error instead of returning this symbol, as that will cause Ky to abort and then throw, which avoids these limitations.
   109→
   110→	A valid use-case for `ky.stop` is to prevent retries when making requests for side effects, where the returned data is not important. For example, logging client activity to the server.
   111→
   112→	@example
   113→	```
   114→	import ky from 'ky';
   115→
   116→	const options = {
   117→		hooks: {
   118→			beforeRetry: [
   119→				async ({request, options, error, retryCount}) => {
   120→					const shouldStopRetry = await ky('https://example.com/api');
   121→					if (shouldStopRetry) {
   122→						return ky.stop;
   123→					}
   124→				}
   125→			]
   126→		}
   127→	};
   128→
   129→	// Note that response will be `undefined` in case `ky.stop` is returned.
   130→	const response = await ky.post('https://example.com', options);
   131→
   132→	// Using `.text()` or other body methods is not supported.
   133→	const text = await ky('https://example.com', options).text();
   134→	```
   135→	*/
   136→	readonly stop: typeof stop;
   137→
   138→	/**
   139→	Force a retry from an `afterResponse` hook.
   140→
   141→	This allows you to retry a request based on the response content, even if the response has a successful status code. The retry will respect the `retry.limit` option and skip the `shouldRetry` check. The forced retry is observable in `beforeRetry` hooks, where the error will be a `ForceRetryError`.
   142→
   143→	@example
   144→	```
   145→	import ky, {isForceRetryError} from 'ky';
   146→
   147→	const api = ky.extend({
   148→		hooks: {
   149→			afterResponse: [
   150→				async (request, options, response) => {
   151→					// Retry based on response body content
   152→					if (response.status === 200) {
   153→						const data = await response.clone().json();
   154→
   155→						// Simple retry with default delay
   156→						if (data.error?.code === 'TEMPORARY_ERROR') {
   157→							return ky.retry();
   158→						}
   159→
   160→						// Retry with custom delay from API response
   161→						if (data.error?.code === 'RATE_LIMIT') {
   162→							return ky.retry({
   163→								delay: data.error.retryAfter * 1000,
   164→								code: 'RATE_LIMIT'
   165→							});
   166→						}
   167→					}
   168→				}
   169→			],
   170→			beforeRetry: [
   171→				({error, retryCount}) => {
   172→					// Observable in beforeRetry hooks
   173→					if (isForceRetryError(error)) {
   174→						console.log(`Forced retry #${retryCount}: ${error.message}`);
   175→						// Example output: "Forced retry #1: Forced retry: RATE_LIMIT"
   176→					}
   177→				}
   178→			]
   179→		}
   180→	});
   181→
   182→	const response = await api.get('https://example.com/api');
   183→	```
   184→	*/
   185→	readonly retry: typeof retry;
   186→};
source/types/options.ts
     6→export type SearchParamsInit = string | string[][] | Record<string, string> | URLSearchParams | undefined;
     9→export type SearchParamsOption = SearchParamsInit | Record<string, string | number | boolean | undefined> | Array<Array<string | number | boolean>>;
    11→export type RequestHttpMethod = 'get' | 'post' | 'put' | 'patch' | 'head' | 'delete';
    12→export type HttpMethod = LiteralUnion<RequestHttpMethod | 'options' | 'trace', string>;
    14→export type Input = string | URL | Request;
    16→export type Progress = {
    17→	percent: number;
    18→	transferredBytes: number;
    19→
    20→	/**
    21→	Note: If it's not possible to retrieve the body size, it will be `0`.
    22→	*/
    23→	totalBytes: number;
    24→};
    27→export type KyHeadersInit = NonNullable<RequestInit['headers']> | Record<string, string | undefined>;
    30→Custom Ky options
    33→export type KyOptions = {
    34→	/**
    35→	Shortcut for sending JSON. Use this instead of the `body` option.
    36→
    37→	Accepts any plain object or value, which will be `JSON.stringify()`'d and sent in the body with the correct header set.
    38→	*/
    39→	json?: unknown;
    40→
    41→	/**
    42→	User-defined JSON-parsing function.
    43→
    44→	Use-cases:
    45→	1. Parse JSON via the [`bourne` package](https://github.com/hapijs/bourne) to protect from prototype pollution.
    46→	2. Parse JSON with [`reviver` option of `JSON.parse()`](https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/JSON/parse).
    47→
    48→	@default JSON.parse()
    49→
    50→	@example
    51→	```
    52→	import ky from 'ky';
    53→	import bourne from '@hapijs/bourne';
    54→
    55→	const json = await ky('https://example.com', {
    56→		parseJson: text => bourne(text)
    57→	}).json();
    58→	```
    59→	*/
    60→	parseJson?: (text: string) => unknown;
    61→
    62→	/**
    63→	User-defined JSON-stringifying function.
    64→
    65→	Use-cases:
    66→	1. Stringify JSON with a custom `replacer` function.
    67→
    68→	@default JSON.stringify()
    69→
    70→	@example
    71→	```
    72→	import ky from 'ky';
    73→	import {DateTime} from 'luxon';
    74→
    75→	const json = await ky('https://example.com', {
    76→		stringifyJson: data => JSON.stringify(data, (key, value) => {
    77→			if (key.endsWith('_at')) {
    78→				return DateTime.fromISO(value).toSeconds();
    79→			}
    80→
    81→			return value;
    82→		})
    83→	}).json();
    84→	```
    85→	*/
    86→	stringifyJson?: (data: unknown) => string;
    87→
    88→	/**
    89→	Search parameters to include in the request URL. Setting this will override all existing search parameters in the input URL.
    90→
    91→	Accepts any value supported by [`URLSearchParams()`](https://developer.mozilla.org/en-US/docs/Web/API/URLSearchParams/URLSearchParams).
    92→
    93→	When passing an object, `undefined` values are automatically filtered out, while `null` values are preserved and converted to the string `'null'`.
    94→	*/
    95→	searchParams?: SearchParamsOption;
    96→
    97→	/**
    98→	A prefix to prepend to the `input` URL when making the request. It can be any valid URL, either relative or absolute. A trailing slash `/` is optional and will be added automatically, if needed, when it is joined with `input`. Only takes effect when `input` is a string. The `input` argument cannot start with a slash `/` when using this option.
    99→
   100→	Useful when used with [`ky.extend()`](#kyextenddefaultoptions) to create niche-specific Ky-instances.
   101→
   102→	Notes:
   103→	 - After `prefixUrl` and `input` are joined, the result is resolved against the [base URL](https://developer.mozilla.org/en-US/docs/Web/API/Node/baseURI) of the page (if any).
   104→	 - Leading slashes in `input` are disallowed when using this option to enforce consistency and avoid confusion about how the `input` URL is handled, given that `input` will not follow the normal URL resolution rules when `prefixUrl` is being used, which changes the meaning of a leading slash.
   105→
   106→	@example
   107→	```
   108→	import ky from 'ky';
   109→
   110→	// On https://example.com
   111→
   112→	const response = await ky('unicorn', {prefixUrl: '/api'});
   113→	//=> 'https://example.com/api/unicorn'
   114→
   115→	const response = await ky('unicorn', {prefixUrl: 'https://cats.com'});
   116→	//=> 'https://cats.com/unicorn'
   117→	```
   118→	*/
   119→	prefixUrl?: URL | string;
   120→
   121→	/**
   122→	An object representing `limit`, `methods`, `statusCodes`, `afterStatusCodes`, and `maxRetryAfter` fields for maximum retry count, allowed methods, allowed status codes, status codes allowed to use the [`Retry-After`](https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Retry-After) time, and maximum [`Retry-After`](https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Retry-After) time.
   123→
   124→	If `retry` is a number, it will be used as `limit` and other defaults will remain in place.
   125→
   126→	If the response provides an HTTP status contained in `afterStatusCodes`, Ky will wait until the date or timeout given in the [`Retry-After`](https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Retry-After) header has passed to retry the request. If `Retry-After` is missing, the non-standard [`RateLimit-Reset`](https://www.ietf.org/archive/id/draft-polli-ratelimit-headers-02.html#section-3.3) header is used in its place as a fallback. If the provided status code is not in the list, the [`Retry-After`](https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Retry-After) header will be ignored.
   127→
   128→	If `maxRetryAfter` is set to `undefined`, it will use `options.timeout`. If [`Retry-After`](https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Retry-After) header is greater than `maxRetryAfter`, it will cancel the request.
   129→
   130→	By default, delays between retries are calculated with the function `0.3 * (2 ** (attemptCount - 1)) * 1000`, where `attemptCount` is the attempt number (starts from 1), however this can be changed by passing a `delay` function.
   131→
   132→	Retries are not triggered following a timeout.
   133→
   134→	@example
   135→	```
   136→	import ky from 'ky';
   137→
   138→	const json = await ky('https://example.com', {
   139→		retry: {
   140→			limit: 10,
   141→			methods: ['get'],
   142→			statusCodes: [413]
   143→		}
   144→	}).json();
   145→	```
   146→	*/
   147→	retry?: RetryOptions | number;
   148→
   149→	/**
   150→	Timeout in milliseconds for getting a response, including any retries. Can not be greater than 2147483647.
   151→	If set to `false`, there will be no timeout.
   152→
   153→	@default 10000
   154→	*/
   155→	timeout?: number | false;
   156→
   157→	/**
   158→	Hooks allow modifications during the request lifecycle. Hook functions may be async and are run serially.
   159→	*/
   160→	hooks?: Hooks;
   161→
   162→	/**
   163→	Throw an `HTTPError` when, after following redirects, the response has a non-2xx status code. To also throw for redirects instead of following them, set the [`redirect`](https://developer.mozilla.org/en-US/docs/Web/API/WindowOrWorkerGlobalScope/fetch#Parameters) option to `'manual'`.
   164→
   165→	Setting this to `false` may be useful if you are checking for resource availability and are expecting error responses.
   166→
   167→	You can also pass a function that accepts the HTTP status code and returns a boolean for selective error handling. Note that this can violate the principle of least surprise, so it's recommended to use the boolean form unless you have a specific use case like treating 404 responses differently.
   168→
   169→	Note: If `false`, error responses are considered successful and the request will not be retried.
   170→
   171→	@default true
   172→	*/
   173→	throwHttpErrors?: boolean | ((status: number) => boolean);
   174→
   175→	/**
   176→	Download progress event handler.
   177→
   178→	@param progress - Object containing download progress information.
   179→	@param chunk - Data that was received. Note: It's empty for the first call.
   180→
   181→	@example
   182→	```
   183→	import ky from 'ky';
   184→
   185→	const response = await ky('https://example.com', {
   186→		onDownloadProgress: (progress, chunk) => {
   187→			// Example output:
   188→			// `0% - 0 of 1271 bytes`
   189→			// `100% - 1271 of 1271 bytes`
   190→			console.log(`${progress.percent * 100}% - ${progress.transferredBytes} of ${progress.totalBytes} bytes`);
   191→		}
   192→	});
   193→	```
   194→	*/
   195→	onDownloadProgress?: (progress: Progress, chunk: Uint8Array) => void;
   196→
   197→	/**
   198→	Upload progress event handler.
   199→
   200→	@param progress - Object containing upload progress information.
   201→	@param chunk - Data that was sent. Note: It's empty for the last call.
   202→
   203→	@example
   204→	```
   205→	import ky from 'ky';
   206→
   207→	const response = await ky.post('https://example.com/upload', {
   208→		body: largeFile,
   209→		onUploadProgress: (progress, chunk) => {
   210→			// Example output:
   211→			// `0% - 0 of 1271 bytes`
   212→			// `100% - 1271 of 1271 bytes`
   213→			console.log(`${progress.percent * 100}% - ${progress.transferredBytes} of ${progress.totalBytes} bytes`);
   214→		}
   215→	});
   216→	```
   217→	*/
   218→	onUploadProgress?: (progress: Progress, chunk: Uint8Array) => void;
   219→
   220→	/**
   221→	User-defined `fetch` function.
   222→	Has to be fully compatible with the [Fetch API](https://developer.mozilla.org/en-US/docs/Web/API/Fetch_API) standard.
   223→
   224→	Use-cases:
   225→	1. Use custom `fetch` implementations like [`isomorphic-unfetch`](https://www.npmjs.com/package/isomorphic-unfetch).
   226→	2. Use the `fetch` wrapper function provided by some frameworks that use server-side rendering (SSR).
   227→
   228→	@default fetch
   229→
   230→	@example
   231→	```
   232→	import ky from 'ky';
   233→	import fetch from 'isomorphic-unfetch';
   234→
   235→	const json = await ky('https://example.com', {fetch}).json();
   236→	```
   237→	*/
   238→	fetch?: (input: Input, init?: RequestInit) => Promise<Response>;
   239→
   240→	/**
   241→	User-defined data passed to hooks.
   242→
   243→	This option allows you to pass arbitrary contextual data to hooks without polluting the request itself. The context is available in all hooks and is **guaranteed to always be an object** (never `undefined`), so you can safely access properties without optional chaining.
   244→
   245→	Use cases:
   246→	- Pass authentication tokens or API keys to hooks
   247→	- Attach request metadata for logging or debugging
   248→	- Implement conditional logic in hooks based on the request context
   249→	- Pass serverless environment bindings (e.g., Cloudflare Workers)
   250→
   251→	**Note:** Context is shallow merged. Top-level properties are merged, but nested objects are replaced. Only enumerable properties are copied.
   252→
   253→	@example
   254→	```
   255→	import ky from 'ky';
   256→
   257→	// Pass data to hooks
   258→	const api = ky.create({
   259→		hooks: {
   260→			beforeRequest: [
   261→				(request, options) => {
   262→					const {token} = options.context;
   263→					if (token) {
   264→						request.headers.set('Authorization', `Bearer ${token}`);
   265→					}
   266→				}
   267→			]
   268→		}
   269→	});
   270→
   271→	await api('https://example.com', {
   272→		context: {
   273→			token: 'secret123'
   274→		}
   275→	}).json();
   276→
   277→	// Shallow merge: only top-level properties are merged
   278→	const instance = ky.create({
   279→		context: {
   280→			a: 1,
   281→			b: {
   282→				nested: true
   283→			}
   284→		}
   285→	});
   286→
   287→	const extended = instance.extend({
   288→		context: {
   289→			b: {
   290→				updated: true
   291→			},
   292→			c: 3
   293→		}
   294→	});
   295→	// Result: {a: 1, b: {updated: true}, c: 3}
   296→	// Note: The original `b.nested` is gone (shallow merge)
   297→	```
   298→	*/
   299→	context?: Record<string, unknown>;
   300→};
   303→Each key from KyOptions is present and set to `true`.
   307→export type KyOptionsRegistry = {[K in keyof KyOptions]-?: true};
   310→Options are the same as `window.fetch`, except for the KyOptions
   312→export interface Options extends KyOptions, Omit<RequestInit, 'headers'> { // eslint-disable-line @typescript-eslint/consistent-type-definitions -- This must stay an interface so that it can be extended outside of Ky for use in `ky.create`.
   358→export type InternalOptions = Required<
   359→Omit<Options, 'hooks' | 'retry' | 'context' | 'throwHttpErrors'>,
   360→'fetch' | 'prefixUrl' | 'timeout'
   361→> & {
   362→	headers: Required<Headers>;
   363→	hooks: Required<Hooks>;
   364→	retry: Required<Omit<RetryOptions, 'shouldRetry'>> & Pick<RetryOptions, 'shouldRetry'>;
   365→	prefixUrl: string;
   366→	context: Record<string, unknown>;
   367→	throwHttpErrors: boolean | ((status: number) => boolean);
   368→};

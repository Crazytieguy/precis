     3→export type ShouldRetryState = {
     4→	/**
     5→	The error that caused the request to fail.
     6→	*/
     7→	error: Error;
     8→
     9→	/**
    10→	The number of retries attempted. Starts at 1 for the first retry.
    11→	*/
    12→	retryCount: number;
    13→};
    15→export type RetryOptions = {
    16→	/**
    17→	The number of times to retry failed requests.
    18→
    19→	@default 2
    20→	*/
    21→	limit?: number;
    22→
    23→	/**
    24→	The HTTP methods allowed to retry.
    25→
    26→	@default ['get', 'put', 'head', 'delete', 'options', 'trace']
    27→	*/
    28→	methods?: HttpMethod[];
    29→
    30→	/**
    31→	The HTTP status codes allowed to retry.
    32→
    33→	@default [408, 413, 429, 500, 502, 503, 504]
    34→	*/
    35→	statusCodes?: number[];
    36→
    37→	/**
    38→	The HTTP status codes allowed to retry with a `Retry-After` header.
    39→
    40→	@default [413, 429, 503]
    41→	*/
    42→	afterStatusCodes?: number[];
    43→
    44→	/**
    45→	If the `Retry-After` header is greater than `maxRetryAfter`, the request will be canceled.
    46→
    47→	@default Infinity
    48→	*/
    49→	maxRetryAfter?: number;
    50→
    51→	/**
    52→	The upper limit of the delay per retry in milliseconds.
    53→	To clamp the delay, set `backoffLimit` to 1000, for example.
    54→
    55→	By default, the delay is calculated in the following way:
    56→
    57→	```
    58→	0.3 * (2 ** (attemptCount - 1)) * 1000
    59→	```
    60→
    61→	The delay increases exponentially.
    62→
    63→	@default Infinity
    64→	*/
    65→	backoffLimit?: number;
    66→
    67→	/**
    68→	A function to calculate the delay between retries given `attemptCount` (starts from 1).
    69→
    70→	@default attemptCount => 0.3 * (2 ** (attemptCount - 1)) * 1000
    71→	*/
    72→	delay?: (attemptCount: number) => number;
    73→
    74→	/**
    75→	Add random jitter to retry delays to prevent thundering herd problems.
    76→
    77→	When many clients retry simultaneously (e.g., after hitting a rate limit), they can overwhelm the server again. Jitter adds randomness to break this synchronization.
    78→
    79→	Set to `true` to use full jitter, which randomizes the delay between 0 and the computed delay.
    80→
    81→	Alternatively, pass a function to implement custom jitter strategies.
    82→
    83→	@default undefined (no jitter)
    84→
    85→	@example
    86→	```
    87→	import ky from 'ky';
    88→
    89→	const json = await ky('https://example.com', {
    90→		retry: {
    91→			limit: 5,
    92→
    93→			// Full jitter (randomizes delay between 0 and computed value)
    94→			jitter: true
    95→
    96→			// Percentage jitter (80-120% of delay)
    97→			// jitter: delay => delay * (0.8 + Math.random() * 0.4)
    98→
    99→			// Absolute jitter (±100ms)
   100→			// jitter: delay => delay + (Math.random() * 200 - 100)
   101→		}
   102→	}).json();
   103→	```
   104→	*/
   105→	jitter?: boolean | ((delay: number) => number) | undefined;
   106→
   107→	/**
   108→	Whether to retry when the request times out.
   109→
   110→	@default false
   111→
   112→	@example
   113→	```
   114→	import ky from 'ky';
   115→
   116→	const json = await ky('https://example.com', {
   117→		retry: {
   118→			limit: 3,
   119→			retryOnTimeout: true
   120→		}
   121→	}).json();
   122→	```
   123→	*/
   124→	retryOnTimeout?: boolean;
   125→
   126→	/**
   127→	A function to determine whether a retry should be attempted.
   128→
   129→	This function takes precedence over all other retry checks and is called first, before any other retry validation.
   130→
   131→	**Note:** This is different from the `beforeRetry` hook:
   132→	- `shouldRetry`: Controls WHETHER to retry (called before the retry decision is made)
   133→	- `beforeRetry`: Called AFTER retry is confirmed, allowing you to modify the request
   134→
   135→	Should return:
   136→	- `true` to force a retry (bypasses `retryOnTimeout`, status code checks, and other validations)
   137→	- `false` to prevent a retry (no retry will occur)
   138→	- `undefined` to use the default retry logic (`retryOnTimeout`, status codes, etc.)
   139→
   140→	@example
   141→	```
   142→	import ky, {HTTPError} from 'ky';
   143→
   144→	const json = await ky('https://example.com', {
   145→		retry: {
   146→			limit: 3,
   147→			shouldRetry: ({error, retryCount}) => {
   148→				// Retry on specific business logic errors from API
   149→				if (error instanceof HTTPError) {
   150→					const status = error.response.status;
   151→
   152→					// Retry on 429 (rate limit) but only for first 2 attempts
   153→					if (status === 429 && retryCount <= 2) {
   154→						return true;
   155→					}
   156→
   157→					// Don't retry on 4xx errors except rate limits
   158→					if (status >= 400 && status < 500) {
   159→						return false;
   160→					}
   161→				}
   162→
   163→				// Use default retry logic for other errors
   164→				return undefined;
   165→			}
   166→		}
   167→	}).json();
   168→	```
   169→	*/
   170→	shouldRetry?: (state: ShouldRetryState) => boolean | undefined | Promise<boolean | undefined>;
   171→};

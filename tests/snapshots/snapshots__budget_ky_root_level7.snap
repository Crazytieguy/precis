source/types/hooks.ts
     5‚Üíexport type BeforeRequestState = {
     6‚Üí	/**
     7‚Üí	The number of retries attempted. `0` for the initial request, increments with each retry.
     8‚Üí
     9‚Üí	This allows you to distinguish between initial requests and retries, which is useful when you need different behavior for retries (e.g., avoiding overwriting headers set in `beforeRetry`).
    10‚Üí	*/
    11‚Üí	retryCount: number;
    12‚Üí};
    14‚Üíexport type BeforeRequestHook = (
    15‚Üí	request: KyRequest,
    16‚Üí	options: NormalizedOptions,
    17‚Üí	state: BeforeRequestState
    18‚Üí) => Request | Response | void | Promise<Request | Response | void>;
    20‚Üíexport type BeforeRetryState = {
    21‚Üí	request: KyRequest;
    22‚Üí	options: NormalizedOptions;
    23‚Üí	error: Error;
    24‚Üí
    25‚Üí	/**
    26‚Üí	The number of retries attempted. Always `>= 1` since this hook is only called during retries, not on the initial request.
    27‚Üí	*/
    28‚Üí	retryCount: number;
    29‚Üí};
    30‚Üíexport type BeforeRetryHook = (options: BeforeRetryState) => Request | Response | typeof stop | void | Promise<Request | Response | typeof stop | void>;
    32‚Üíexport type AfterResponseState = {
    33‚Üí	/**
    34‚Üí	The number of retries attempted. `0` for the initial request, increments with each retry.
    35‚Üí
    36‚Üí	This allows you to distinguish between initial requests and retries, which is useful when you need different behavior for retries (e.g., showing a notification only on the final retry).
    37‚Üí	*/
    38‚Üí	retryCount: number;
    39‚Üí};
    41‚Üíexport type AfterResponseHook = (
    42‚Üí	request: KyRequest,
    43‚Üí	options: NormalizedOptions,
    44‚Üí	response: KyResponse,
    45‚Üí	state: AfterResponseState
    46‚Üí) => Response | RetryMarker | void | Promise<Response | RetryMarker | void>;
    48‚Üíexport type BeforeErrorState = {
    49‚Üí	/**
    50‚Üí	The number of retries attempted. `0` for the initial request, increments with each retry.
    51‚Üí
    52‚Üí	This allows you to distinguish between the initial request and retries, which is useful when you need different error handling based on retry attempts (e.g., showing different error messages on the final attempt).
    53‚Üí	*/
    54‚Üí	retryCount: number;
    55‚Üí};
    57‚Üíexport type BeforeErrorHook = (error: HTTPError, state: BeforeErrorState) => HTTPError | Promise<HTTPError>;
    59‚Üíexport type Hooks = {
    60‚Üí	/**
    61‚Üí	This hook enables you to modify the request right before it is sent. Ky will make no further changes to the request after this. The hook function receives the normalized request, options, and a state object. You could, for example, modify `request.headers` here.
    62‚Üí
    63‚Üí	The `state.retryCount` is `0` for the initial request and increments with each retry. This allows you to distinguish between initial requests and retries, which is useful when you need different behavior for retries (e.g., avoiding overwriting headers set in `beforeRetry`).
    64‚Üí
    65‚Üí	A [`Response`](https://developer.mozilla.org/en-US/docs/Web/API/Response) can be returned from this hook to completely avoid making an HTTP request. This can be used to mock a request, check an internal cache, etc. An **important** consideration when returning a `Response` from this hook is that all the following hooks will be skipped, so **ensure you only return a `Response` from the last hook**.
    66‚Üí
    67‚Üí	@example
    68‚Üí	```
    69‚Üí	import ky from 'ky';
    70‚Üí
    71‚Üí	const response = await ky('https://example.com', {
    72‚Üí		hooks: {
    73‚Üí			beforeRequest: [
    74‚Üí				(request, options, {retryCount}) => {
    75‚Üí					// Only set default auth header on initial request, not on retries
    76‚Üí					// (retries may have refreshed token set by beforeRetry)
    77‚Üí					if (retryCount === 0) {
    78‚Üí						request.headers.set('Authorization', 'token initial-token');
    79‚Üí					}
    80‚Üí				}
    81‚Üí			]
    82‚Üí		}
    83‚Üí	});
    84‚Üí	```
    85‚Üí
    86‚Üí	@default []
    87‚Üí	*/
    88‚Üí	beforeRequest?: BeforeRequestHook[];
    89‚Üí
    90‚Üí	/**
    91‚Üí	This hook enables you to modify the request right before retry. Ky will make no further changes to the request after this. The hook function receives an object with the normalized request and options, an error instance, and the retry count. You could, for example, modify `request.headers` here.
    92‚Üí
    93‚Üí	The hook can return a [`Request`](https://developer.mozilla.org/en-US/docs/Web/API/Request) to replace the outgoing retry request, or return a [`Response`](https://developer.mozilla.org/en-US/docs/Web/API/Response) to skip the retry and use that response instead. **Note:** Returning a request or response skips remaining `beforeRetry` hooks.
    94‚Üí
    95‚Üí	If the request received a response, the error will be of type `HTTPError` and the `Response` object will be available at `error.response`. Be aware that some types of errors, such as network errors, inherently mean that a response was not received. In that case, the error will not be an instance of `HTTPError`.
    96‚Üí
    97‚Üí	You can prevent Ky from retrying the request by throwing an error. Ky will not handle it in any way and the error will be propagated to the request initiator. The rest of the `beforeRetry` hooks will not be called in this case. Alternatively, you can return the [`ky.stop`](#ky.stop) symbol to do the same thing but without propagating an error (this has some limitations, see `ky.stop` docs for details).
    98‚Üí
    99‚Üí	**Modifying headers:**
   100‚Üí
   101‚Üí	@example
   102‚Üí	```
   103‚Üí	import ky from 'ky';
   104‚Üí
   105‚Üí	const response = await ky('https://example.com', {
   106‚Üí		hooks: {
   107‚Üí			beforeRetry: [
   108‚Üí				async ({request, options, error, retryCount}) => {
   109‚Üí					const token = await ky('https://example.com/refresh-token');
   110‚Üí					request.headers.set('Authorization', `token ${token}`);
   111‚Üí				}
   112‚Üí			]
   113‚Üí		}
   114‚Üí	});
   115‚Üí	```
   116‚Üí
   117‚Üí	**Modifying the request URL:**
   118‚Üí
   119‚Üí	@example
   120‚Üí	```
   121‚Üí	import ky from 'ky';
   122‚Üí
   123‚Üí	const response = await ky('https://example.com/api', {
   124‚Üí		hooks: {
   125‚Üí			beforeRetry: [
   126‚Üí				async ({request, error}) => {
   127‚Üí					// Add query parameters based on error response
   128‚Üí					if (error.response) {
   129‚Üí						const body = await error.response.json();
   130‚Üí						const url = new URL(request.url);
   131‚Üí						url.searchParams.set('processId', body.processId);
   132‚Üí						return new Request(url, request);
   133‚Üí					}
   134‚Üí				}
   135‚Üí			]
   136‚Üí		}
   137‚Üí	});
   138‚Üí	```
   139‚Üí
   140‚Üí	**Returning a cached response:**
   141‚Üí
   142‚Üí	@example
   143‚Üí	```
   144‚Üí	import ky from 'ky';
   145‚Üí
   146‚Üí	const response = await ky('https://example.com/api', {
   147‚Üí		hooks: {
   148‚Üí			beforeRetry: [
   149‚Üí				({error, retryCount}) => {
   150‚Üí					// Use cached response instead of retrying
   151‚Üí					if (retryCount > 1 && cachedResponse) {
   152‚Üí						return cachedResponse;
   153‚Üí					}
   154‚Üí				}
   155‚Üí			]
   156‚Üí		}
   157‚Üí	});
   158‚Üí	```
   159‚Üí
   160‚Üí	@default []
   161‚Üí	*/
   162‚Üí	beforeRetry?: BeforeRetryHook[];
   163‚Üí
   164‚Üí	/**
   165‚Üí	This hook enables you to read and optionally modify the response. The hook function receives normalized request, options, a clone of the response, and a state object. The return value of the hook function will be used by Ky as the response object if it's an instance of [`Response`](https://developer.mozilla.org/en-US/docs/Web/API/Response).
   166‚Üí
   167‚Üí	You can also force a retry by returning `ky.retry()` or `ky.retry(options)`. This is useful when you need to retry based on the response body content, even if the response has a successful status code. The retry will respect the retry limit and be observable in `beforeRetry` hooks.
   168‚Üí
   169‚Üí	@default []
   170‚Üí
   171‚Üí	@example
   172‚Üí	```
   173‚Üí	import ky from 'ky';
   174‚Üí
   175‚Üí	const response = await ky('https://example.com', {
   176‚Üí		hooks: {
   177‚Üí			afterResponse: [
   178‚Üí				(_request, _options, response) => {
   179‚Üí					// You could do something with the response, for example, logging.
   180‚Üí					log(response);
   181‚Üí
   182‚Üí					// Or return a `Response` instance to overwrite the response.
   183‚Üí					return new Response('A different response', {status: 200});
   184‚Üí				},
   185‚Üí
   186‚Üí				// Or retry with a fresh token on a 401 error
   187‚Üí				async (request, _options, response, state) => {
   188‚Üí					if (response.status === 401 && state.retryCount === 0) {
   189‚Üí						// Only refresh on first 401, not on subsequent retries
   190‚Üí						const {token} = await ky.post('https://example.com/auth/refresh').json();
   191‚Üí
   192‚Üí						const headers = new Headers(request.headers);
   193‚Üí						headers.set('Authorization', `Bearer ${token}`);
   194‚Üí
   195‚Üí						return ky.retry({
   196‚Üí							request: new Request(request, {headers}),
   197‚Üí							code: 'TOKEN_REFRESHED'
   198‚Üí						});
   199‚Üí					}
   200‚Üí				},
   201‚Üí
   202‚Üí				// Or force retry based on response body content
   203‚Üí				async (request, options, response) => {
   204‚Üí					if (response.status === 200) {
   205‚Üí						const data = await response.clone().json();
   206‚Üí						if (data.error?.code === 'RATE_LIMIT') {
   207‚Üí							// Force retry with custom delay from API response
   208‚Üí							return ky.retry({
   209‚Üí								delay: data.error.retryAfter * 1000,
   210‚Üí								code: 'RATE_LIMIT'
   211‚Üí							});
   212‚Üí						}
   213‚Üí					}
   214‚Üí				},
   215‚Üí
   216‚Üí				// Or show a notification only on the last retry for 5xx errors
   217‚Üí				(request, options, response, {retryCount}) => {
   218‚Üí					if (response.status >= 500 && response.status <= 599) {
   219‚Üí						if (retryCount === options.retry.limit) {
   220‚Üí							showNotification('Request failed after all retries');
   221‚Üí						}
   222‚Üí					}
   223‚Üí				}
   224‚Üí			]
   225‚Üí		}
   226‚Üí	});
   227‚Üí	```
   228‚Üí	*/
   229‚Üí	afterResponse?: AfterResponseHook[];
   230‚Üí
   231‚Üí	/**
   232‚Üí	This hook enables you to modify the `HTTPError` right before it is thrown. The hook function receives an `HTTPError` and a state object as arguments and should return an instance of `HTTPError`.
   233‚Üí
   234‚Üí	@default []
   235‚Üí
   236‚Üí	@example
   237‚Üí	```
   238‚Üí	import ky from 'ky';
   239‚Üí
   240‚Üí	await ky('https://example.com', {
   241‚Üí		hooks: {
   242‚Üí			beforeError: [
   243‚Üí				async error => {
   244‚Üí					const {response} = error;
   245‚Üí					if (response) {
   246‚Üí						const body = await response.json();
   247‚Üí						error.name = 'GitHubError';
   248‚Üí						error.message = `${body.message} (${response.status})`;
   249‚Üí					}
   250‚Üí
   251‚Üí					return error;
   252‚Üí				},
   253‚Üí
   254‚Üí				// Or show different message based on retry count
   255‚Üí				(error, {retryCount}) => {
   256‚Üí					if (retryCount === error.options.retry.limit) {
   257‚Üí						error.message = `${error.message} (failed after ${retryCount} retries)`;
   258‚Üí					}
   259‚Üí
   260‚Üí					return error;
   261‚Üí				}
   262‚Üí			]
   263‚Üí		}
   264‚Üí	});
   265‚Üí	```
   266‚Üí	*/
   267‚Üí	beforeError?: BeforeErrorHook[];
   268‚Üí};
source/types/ky.ts
     5‚Üíexport type KyInstance = {
     6‚Üí	/**
     7‚Üí	Fetch the given `url`.
     8‚Üí
     9‚Üí	@param url - `Request` object, `URL` object, or URL string.
    10‚Üí	@returns A promise with `Body` method added.
    11‚Üí
    12‚Üí	@example
    13‚Üí	```
    14‚Üí	import ky from 'ky';
    15‚Üí
    16‚Üí	const json = await ky('https://example.com', {json: {foo: true}}).json();
    17‚Üí
    18‚Üí	console.log(json);
    19‚Üí	//=> `{data: 'ü¶Ñ'}`
    20‚Üí	```
    21‚Üí	*/
    22‚Üí	<T>(url: Input, options?: Options): ResponsePromise<T>;
    23‚Üí
    24‚Üí	/**
    25‚Üí	Fetch the given `url` using the option `{method: 'get'}`.
    26‚Üí
    27‚Üí	@param url - `Request` object, `URL` object, or URL string.
    28‚Üí	@returns A promise with `Body` methods added.
    29‚Üí	*/
    30‚Üí	get: <T>(url: Input, options?: Options) => ResponsePromise<T>;
    31‚Üí
    32‚Üí	/**
    33‚Üí	Fetch the given `url` using the option `{method: 'post'}`.
    34‚Üí
    35‚Üí	@param url - `Request` object, `URL` object, or URL string.
    36‚Üí	@returns A promise with `Body` methods added.
    37‚Üí	*/
    38‚Üí	post: <T>(url: Input, options?: Options) => ResponsePromise<T>;
    39‚Üí
    40‚Üí	/**
    41‚Üí	Fetch the given `url` using the option `{method: 'put'}`.
    42‚Üí
    43‚Üí	@param url - `Request` object, `URL` object, or URL string.
    44‚Üí	@returns A promise with `Body` methods added.
    45‚Üí	*/
    46‚Üí	put: <T>(url: Input, options?: Options) => ResponsePromise<T>;
    47‚Üí
    48‚Üí	/**
    49‚Üí	Fetch the given `url` using the option `{method: 'delete'}`.
    50‚Üí
    51‚Üí	@param url - `Request` object, `URL` object, or URL string.
    52‚Üí	@returns A promise with `Body` methods added.
    53‚Üí	*/
    54‚Üí	delete: <T>(url: Input, options?: Options) => ResponsePromise<T>;
    55‚Üí
    56‚Üí	/**
    57‚Üí	Fetch the given `url` using the option `{method: 'patch'}`.
    58‚Üí
    59‚Üí	@param url - `Request` object, `URL` object, or URL string.
    60‚Üí	@returns A promise with `Body` methods added.
    61‚Üí	*/
    62‚Üí	patch: <T>(url: Input, options?: Options) => ResponsePromise<T>;
    63‚Üí
    64‚Üí	/**
    65‚Üí	Fetch the given `url` using the option `{method: 'head'}`.
    66‚Üí
    67‚Üí	@param url - `Request` object, `URL` object, or URL string.
    68‚Üí	@returns A promise with `Body` methods added.
    69‚Üí	*/
    70‚Üí	head: (url: Input, options?: Options) => ResponsePromise;
    71‚Üí
    72‚Üí	/**
    73‚Üí	Create a new Ky instance with complete new defaults.
    74‚Üí
    75‚Üí	@returns A new Ky instance.
    76‚Üí	*/
    77‚Üí	create: (defaultOptions?: Options) => KyInstance;
    78‚Üí
    79‚Üí	/**
    80‚Üí	Create a new Ky instance with some defaults overridden with your own.
    81‚Üí
    82‚Üí	In contrast to `ky.create()`, `ky.extend()` inherits defaults from its parent.
    83‚Üí
    84‚Üí	You can also refer to parent defaults by providing a function to `.extend()`.
    85‚Üí
    86‚Üí	@example
    87‚Üí	```
    88‚Üí	import ky from 'ky';
    89‚Üí
    90‚Üí	const api = ky.create({prefixUrl: 'https://example.com/api'});
    91‚Üí
    92‚Üí	const usersApi = api.extend((options) => ({prefixUrl: `${options.prefixUrl}/users`}));
    93‚Üí
    94‚Üí	const response = await usersApi.get('123');
    95‚Üí	//=> 'https://example.com/api/users/123'
    96‚Üí
    97‚Üí	const response = await api.get('version');
    98‚Üí	//=> 'https://example.com/api/version'
    99‚Üí	```
   100‚Üí
   101‚Üí	@returns A new Ky instance.
   102‚Üí	*/
   103‚Üí	extend: (defaultOptions: Options | ((parentOptions: Options) => Options)) => KyInstance;
   104‚Üí
   105‚Üí	/**
   106‚Üí	A `Symbol` that can be returned by a `beforeRetry` hook to stop the retry. This will also short circuit the remaining `beforeRetry` hooks.
   107‚Üí
   108‚Üí	Note: Returning this symbol makes Ky abort and return with an `undefined` response. Be sure to check for a response before accessing any properties on it or use [optional chaining](https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Operators/Optional_chaining). It is also incompatible with body methods, such as `.json()` or `.text()`, because there is no response to parse. In general, we recommend throwing an error instead of returning this symbol, as that will cause Ky to abort and then throw, which avoids these limitations.
   109‚Üí
   110‚Üí	A valid use-case for `ky.stop` is to prevent retries when making requests for side effects, where the returned data is not important. For example, logging client activity to the server.
   111‚Üí
   112‚Üí	@example
   113‚Üí	```
   114‚Üí	import ky from 'ky';
   115‚Üí
   116‚Üí	const options = {
   117‚Üí		hooks: {
   118‚Üí			beforeRetry: [
   119‚Üí				async ({request, options, error, retryCount}) => {
   120‚Üí					const shouldStopRetry = await ky('https://example.com/api');
   121‚Üí					if (shouldStopRetry) {
   122‚Üí						return ky.stop;
   123‚Üí					}
   124‚Üí				}
   125‚Üí			]
   126‚Üí		}
   127‚Üí	};
   128‚Üí
   129‚Üí	// Note that response will be `undefined` in case `ky.stop` is returned.
   130‚Üí	const response = await ky.post('https://example.com', options);
   131‚Üí
   132‚Üí	// Using `.text()` or other body methods is not supported.
   133‚Üí	const text = await ky('https://example.com', options).text();
   134‚Üí	```
   135‚Üí	*/
   136‚Üí	readonly stop: typeof stop;
   137‚Üí
   138‚Üí	/**
   139‚Üí	Force a retry from an `afterResponse` hook.
   140‚Üí
   141‚Üí	This allows you to retry a request based on the response content, even if the response has a successful status code. The retry will respect the `retry.limit` option and skip the `shouldRetry` check. The forced retry is observable in `beforeRetry` hooks, where the error will be a `ForceRetryError`.
   142‚Üí
   143‚Üí	@example
   144‚Üí	```
   145‚Üí	import ky, {isForceRetryError} from 'ky';
   146‚Üí
   147‚Üí	const api = ky.extend({
   148‚Üí		hooks: {
   149‚Üí			afterResponse: [
   150‚Üí				async (request, options, response) => {
   151‚Üí					// Retry based on response body content
   152‚Üí					if (response.status === 200) {
   153‚Üí						const data = await response.clone().json();
   154‚Üí
   155‚Üí						// Simple retry with default delay
   156‚Üí						if (data.error?.code === 'TEMPORARY_ERROR') {
   157‚Üí							return ky.retry();
   158‚Üí						}
   159‚Üí
   160‚Üí						// Retry with custom delay from API response
   161‚Üí						if (data.error?.code === 'RATE_LIMIT') {
   162‚Üí							return ky.retry({
   163‚Üí								delay: data.error.retryAfter * 1000,
   164‚Üí								code: 'RATE_LIMIT'
   165‚Üí							});
   166‚Üí						}
   167‚Üí					}
   168‚Üí				}
   169‚Üí			],
   170‚Üí			beforeRetry: [
   171‚Üí				({error, retryCount}) => {
   172‚Üí					// Observable in beforeRetry hooks
   173‚Üí					if (isForceRetryError(error)) {
   174‚Üí						console.log(`Forced retry #${retryCount}: ${error.message}`);
   175‚Üí						// Example output: "Forced retry #1: Forced retry: RATE_LIMIT"
   176‚Üí					}
   177‚Üí				}
   178‚Üí			]
   179‚Üí		}
   180‚Üí	});
   181‚Üí
   182‚Üí	const response = await api.get('https://example.com/api');
   183‚Üí	```
   184‚Üí	*/
   185‚Üí	readonly retry: typeof retry;
   186‚Üí};
source/types/options.ts
     6‚Üíexport type SearchParamsInit = string | string[][] | Record<string, string> | URLSearchParams | undefined;
     9‚Üíexport type SearchParamsOption = SearchParamsInit | Record<string, string | number | boolean | undefined> | Array<Array<string | number | boolean>>;
    11‚Üíexport type RequestHttpMethod = 'get' | 'post' | 'put' | 'patch' | 'head' | 'delete';
    12‚Üíexport type HttpMethod = LiteralUnion<RequestHttpMethod | 'options' | 'trace', string>;
    14‚Üíexport type Input = string | URL | Request;
    16‚Üíexport type Progress = {
    17‚Üí	percent: number;
    18‚Üí	transferredBytes: number;
    19‚Üí
    20‚Üí	/**
    21‚Üí	Note: If it's not possible to retrieve the body size, it will be `0`.
    22‚Üí	*/
    23‚Üí	totalBytes: number;
    24‚Üí};
    27‚Üíexport type KyHeadersInit = NonNullable<RequestInit['headers']> | Record<string, string | undefined>;
    29‚Üí/**
    30‚ÜíCustom Ky options
    31‚Üí*/
    32‚Üí
    33‚Üíexport type KyOptions = {
    34‚Üí	/**
    35‚Üí	Shortcut for sending JSON. Use this instead of the `body` option.
    36‚Üí
    37‚Üí	Accepts any plain object or value, which will be `JSON.stringify()`'d and sent in the body with the correct header set.
    38‚Üí	*/
    39‚Üí	json?: unknown;
    40‚Üí
    41‚Üí	/**
    42‚Üí	User-defined JSON-parsing function.
    43‚Üí
    44‚Üí	Use-cases:
    45‚Üí	1. Parse JSON via the [`bourne` package](https://github.com/hapijs/bourne) to protect from prototype pollution.
    46‚Üí	2. Parse JSON with [`reviver` option of `JSON.parse()`](https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Global_Objects/JSON/parse).
    47‚Üí
    48‚Üí	@default JSON.parse()
    49‚Üí
    50‚Üí	@example
    51‚Üí	```
    52‚Üí	import ky from 'ky';
    53‚Üí	import bourne from '@hapijs/bourne';
    54‚Üí
    55‚Üí	const json = await ky('https://example.com', {
    56‚Üí		parseJson: text => bourne(text)
    57‚Üí	}).json();
    58‚Üí	```
    59‚Üí	*/
    60‚Üí	parseJson?: (text: string) => unknown;
    61‚Üí
    62‚Üí	/**
    63‚Üí	User-defined JSON-stringifying function.
    64‚Üí
    65‚Üí	Use-cases:
    66‚Üí	1. Stringify JSON with a custom `replacer` function.
    67‚Üí
    68‚Üí	@default JSON.stringify()
    69‚Üí
    70‚Üí	@example
    71‚Üí	```
    72‚Üí	import ky from 'ky';
    73‚Üí	import {DateTime} from 'luxon';
    74‚Üí
    75‚Üí	const json = await ky('https://example.com', {
    76‚Üí		stringifyJson: data => JSON.stringify(data, (key, value) => {
    77‚Üí			if (key.endsWith('_at')) {
    78‚Üí				return DateTime.fromISO(value).toSeconds();
    79‚Üí			}
    80‚Üí
    81‚Üí			return value;
    82‚Üí		})
    83‚Üí	}).json();
    84‚Üí	```
    85‚Üí	*/
    86‚Üí	stringifyJson?: (data: unknown) => string;
    87‚Üí
    88‚Üí	/**
    89‚Üí	Search parameters to include in the request URL. Setting this will override all existing search parameters in the input URL.
    90‚Üí
    91‚Üí	Accepts any value supported by [`URLSearchParams()`](https://developer.mozilla.org/en-US/docs/Web/API/URLSearchParams/URLSearchParams).
    92‚Üí
    93‚Üí	When passing an object, `undefined` values are automatically filtered out, while `null` values are preserved and converted to the string `'null'`.
    94‚Üí	*/
    95‚Üí	searchParams?: SearchParamsOption;
    96‚Üí
    97‚Üí	/**
    98‚Üí	A prefix to prepend to the `input` URL when making the request. It can be any valid URL, either relative or absolute. A trailing slash `/` is optional and will be added automatically, if needed, when it is joined with `input`. Only takes effect when `input` is a string. The `input` argument cannot start with a slash `/` when using this option.
    99‚Üí
   100‚Üí	Useful when used with [`ky.extend()`](#kyextenddefaultoptions) to create niche-specific Ky-instances.
   101‚Üí
   102‚Üí	Notes:
   103‚Üí	 - After `prefixUrl` and `input` are joined, the result is resolved against the [base URL](https://developer.mozilla.org/en-US/docs/Web/API/Node/baseURI) of the page (if any).
   104‚Üí	 - Leading slashes in `input` are disallowed when using this option to enforce consistency and avoid confusion about how the `input` URL is handled, given that `input` will not follow the normal URL resolution rules when `prefixUrl` is being used, which changes the meaning of a leading slash.
   105‚Üí
   106‚Üí	@example
   107‚Üí	```
   108‚Üí	import ky from 'ky';
   109‚Üí
   110‚Üí	// On https://example.com
   111‚Üí
   112‚Üí	const response = await ky('unicorn', {prefixUrl: '/api'});
   113‚Üí	//=> 'https://example.com/api/unicorn'
   114‚Üí
   115‚Üí	const response = await ky('unicorn', {prefixUrl: 'https://cats.com'});
   116‚Üí	//=> 'https://cats.com/unicorn'
   117‚Üí	```
   118‚Üí	*/
   119‚Üí	prefixUrl?: URL | string;
   120‚Üí
   121‚Üí	/**
   122‚Üí	An object representing `limit`, `methods`, `statusCodes`, `afterStatusCodes`, and `maxRetryAfter` fields for maximum retry count, allowed methods, allowed status codes, status codes allowed to use the [`Retry-After`](https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Retry-After) time, and maximum [`Retry-After`](https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Retry-After) time.
   123‚Üí
   124‚Üí	If `retry` is a number, it will be used as `limit` and other defaults will remain in place.
   125‚Üí
   126‚Üí	If the response provides an HTTP status contained in `afterStatusCodes`, Ky will wait until the date or timeout given in the [`Retry-After`](https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Retry-After) header has passed to retry the request. If `Retry-After` is missing, the non-standard [`RateLimit-Reset`](https://www.ietf.org/archive/id/draft-polli-ratelimit-headers-02.html#section-3.3) header is used in its place as a fallback. If the provided status code is not in the list, the [`Retry-After`](https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Retry-After) header will be ignored.
   127‚Üí
   128‚Üí	If `maxRetryAfter` is set to `undefined`, it will use `options.timeout`. If [`Retry-After`](https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Retry-After) header is greater than `maxRetryAfter`, it will cancel the request.
   129‚Üí
   130‚Üí	By default, delays between retries are calculated with the function `0.3 * (2 ** (attemptCount - 1)) * 1000`, where `attemptCount` is the attempt number (starts from 1), however this can be changed by passing a `delay` function.
   131‚Üí
   132‚Üí	Retries are not triggered following a timeout.
   133‚Üí
   134‚Üí	@example
   135‚Üí	```
   136‚Üí	import ky from 'ky';
   137‚Üí
   138‚Üí	const json = await ky('https://example.com', {
   139‚Üí		retry: {
   140‚Üí			limit: 10,
   141‚Üí			methods: ['get'],
   142‚Üí			statusCodes: [413]
   143‚Üí		}
   144‚Üí	}).json();
   145‚Üí	```
   146‚Üí	*/
   147‚Üí	retry?: RetryOptions | number;
   148‚Üí
   149‚Üí	/**
   150‚Üí	Timeout in milliseconds for getting a response, including any retries. Can not be greater than 2147483647.
   151‚Üí	If set to `false`, there will be no timeout.
   152‚Üí
   153‚Üí	@default 10000
   154‚Üí	*/
   155‚Üí	timeout?: number | false;
   156‚Üí
   157‚Üí	/**
   158‚Üí	Hooks allow modifications during the request lifecycle. Hook functions may be async and are run serially.
   159‚Üí	*/
   160‚Üí	hooks?: Hooks;
   161‚Üí
   162‚Üí	/**
   163‚Üí	Throw an `HTTPError` when, after following redirects, the response has a non-2xx status code. To also throw for redirects instead of following them, set the [`redirect`](https://developer.mozilla.org/en-US/docs/Web/API/WindowOrWorkerGlobalScope/fetch#Parameters) option to `'manual'`.
   164‚Üí
   165‚Üí	Setting this to `false` may be useful if you are checking for resource availability and are expecting error responses.
   166‚Üí
   167‚Üí	You can also pass a function that accepts the HTTP status code and returns a boolean for selective error handling. Note that this can violate the principle of least surprise, so it's recommended to use the boolean form unless you have a specific use case like treating 404 responses differently.
   168‚Üí
   169‚Üí	Note: If `false`, error responses are considered successful and the request will not be retried.
   170‚Üí
   171‚Üí	@default true
   172‚Üí	*/
   173‚Üí	throwHttpErrors?: boolean | ((status: number) => boolean);
   174‚Üí
   175‚Üí	/**
   176‚Üí	Download progress event handler.
   177‚Üí
   178‚Üí	@param progress - Object containing download progress information.
   179‚Üí	@param chunk - Data that was received. Note: It's empty for the first call.
   180‚Üí
   181‚Üí	@example
   182‚Üí	```
   183‚Üí	import ky from 'ky';
   184‚Üí
   185‚Üí	const response = await ky('https://example.com', {
   186‚Üí		onDownloadProgress: (progress, chunk) => {
   187‚Üí			// Example output:
   188‚Üí			// `0% - 0 of 1271 bytes`
   189‚Üí			// `100% - 1271 of 1271 bytes`
   190‚Üí			console.log(`${progress.percent * 100}% - ${progress.transferredBytes} of ${progress.totalBytes} bytes`);
   191‚Üí		}
   192‚Üí	});
   193‚Üí	```
   194‚Üí	*/
   195‚Üí	onDownloadProgress?: (progress: Progress, chunk: Uint8Array) => void;
   196‚Üí
   197‚Üí	/**
   198‚Üí	Upload progress event handler.
   199‚Üí
   200‚Üí	@param progress - Object containing upload progress information.
   201‚Üí	@param chunk - Data that was sent. Note: It's empty for the last call.
   202‚Üí
   203‚Üí	@example
   204‚Üí	```
   205‚Üí	import ky from 'ky';
   206‚Üí
   207‚Üí	const response = await ky.post('https://example.com/upload', {
   208‚Üí		body: largeFile,
   209‚Üí		onUploadProgress: (progress, chunk) => {
   210‚Üí			// Example output:
   211‚Üí			// `0% - 0 of 1271 bytes`
   212‚Üí			// `100% - 1271 of 1271 bytes`
   213‚Üí			console.log(`${progress.percent * 100}% - ${progress.transferredBytes} of ${progress.totalBytes} bytes`);
   214‚Üí		}
   215‚Üí	});
   216‚Üí	```
   217‚Üí	*/
   218‚Üí	onUploadProgress?: (progress: Progress, chunk: Uint8Array) => void;
   219‚Üí
   220‚Üí	/**
   221‚Üí	User-defined `fetch` function.
   222‚Üí	Has to be fully compatible with the [Fetch API](https://developer.mozilla.org/en-US/docs/Web/API/Fetch_API) standard.
   223‚Üí
   224‚Üí	Use-cases:
   225‚Üí	1. Use custom `fetch` implementations like [`isomorphic-unfetch`](https://www.npmjs.com/package/isomorphic-unfetch).
   226‚Üí	2. Use the `fetch` wrapper function provided by some frameworks that use server-side rendering (SSR).
   227‚Üí
   228‚Üí	@default fetch
   229‚Üí
   230‚Üí	@example
   231‚Üí	```
   232‚Üí	import ky from 'ky';
   233‚Üí	import fetch from 'isomorphic-unfetch';
   234‚Üí
   235‚Üí	const json = await ky('https://example.com', {fetch}).json();
   236‚Üí	```
   237‚Üí	*/
   238‚Üí	fetch?: (input: Input, init?: RequestInit) => Promise<Response>;
   239‚Üí
   240‚Üí	/**
   241‚Üí	User-defined data passed to hooks.
   242‚Üí
   243‚Üí	This option allows you to pass arbitrary contextual data to hooks without polluting the request itself. The context is available in all hooks and is **guaranteed to always be an object** (never `undefined`), so you can safely access properties without optional chaining.
   244‚Üí
   245‚Üí	Use cases:
   246‚Üí	- Pass authentication tokens or API keys to hooks
   247‚Üí	- Attach request metadata for logging or debugging
   248‚Üí	- Implement conditional logic in hooks based on the request context
   249‚Üí	- Pass serverless environment bindings (e.g., Cloudflare Workers)
   250‚Üí
   251‚Üí	**Note:** Context is shallow merged. Top-level properties are merged, but nested objects are replaced. Only enumerable properties are copied.
   252‚Üí
   253‚Üí	@example
   254‚Üí	```
   255‚Üí	import ky from 'ky';
   256‚Üí
   257‚Üí	// Pass data to hooks
   258‚Üí	const api = ky.create({
   259‚Üí		hooks: {
   260‚Üí			beforeRequest: [
   261‚Üí				(request, options) => {
   262‚Üí					const {token} = options.context;
   263‚Üí					if (token) {
   264‚Üí						request.headers.set('Authorization', `Bearer ${token}`);
   265‚Üí					}
   266‚Üí				}
   267‚Üí			]
   268‚Üí		}
   269‚Üí	});
   270‚Üí
   271‚Üí	await api('https://example.com', {
   272‚Üí		context: {
   273‚Üí			token: 'secret123'
   274‚Üí		}
   275‚Üí	}).json();
   276‚Üí
   277‚Üí	// Shallow merge: only top-level properties are merged
   278‚Üí	const instance = ky.create({
   279‚Üí		context: {
   280‚Üí			a: 1,
   281‚Üí			b: {
   282‚Üí				nested: true
   283‚Üí			}
   284‚Üí		}
   285‚Üí	});
   286‚Üí
   287‚Üí	const extended = instance.extend({
   288‚Üí		context: {
   289‚Üí			b: {
   290‚Üí				updated: true
   291‚Üí			},
   292‚Üí			c: 3
   293‚Üí		}
   294‚Üí	});
   295‚Üí	// Result: {a: 1, b: {updated: true}, c: 3}
   296‚Üí	// Note: The original `b.nested` is gone (shallow merge)
   297‚Üí	```
   298‚Üí	*/
   299‚Üí	context?: Record<string, unknown>;
   300‚Üí};
   302‚Üí/**
   303‚ÜíEach key from KyOptions is present and set to `true`.
   304‚Üí
   305‚ÜíThis type is used for identifying and working with the known keys in KyOptions.
   306‚Üí*/
   307‚Üíexport type KyOptionsRegistry = {[K in keyof KyOptions]-?: true};
   309‚Üí/**
   310‚ÜíOptions are the same as `window.fetch`, except for the KyOptions
   311‚Üí*/
   312‚Üíexport interface Options extends KyOptions, Omit<RequestInit, 'headers'> { // eslint-disable-line @typescript-eslint/consistent-type-definitions -- This must stay an interface so that it can be extended outside of Ky for use in `ky.create`.
   313‚Üí	/**
   314‚Üí	HTTP method used to make the request.
   315‚Üí
   316‚Üí	Internally, the standard methods (`GET`, `POST`, `PUT`, `PATCH`, `HEAD` and `DELETE`) are uppercased in order to avoid server errors due to case sensitivity.
   317‚Üí	*/
   318‚Üí	method?: LiteralUnion<HttpMethod, string>;
   319‚Üí
   320‚Üí	/**
   321‚Üí	HTTP headers used to make the request.
   322‚Üí
   323‚Üí	You can pass a `Headers` instance or a plain object.
   324‚Üí
   325‚Üí	You can remove a header with `.extend()` by passing the header with an `undefined` value.
   326‚Üí
   327‚Üí	@example
   328‚Üí	```
   329‚Üí	import ky from 'ky';
   330‚Üí
   331‚Üí	const url = 'https://sindresorhus.com';
   332‚Üí
   333‚Üí	const original = ky.create({
   334‚Üí		headers: {
   335‚Üí			rainbow: 'rainbow',
   336‚Üí			unicorn: 'unicorn'
   337‚Üí		}
   338‚Üí	});
   339‚Üí
   340‚Üí	const extended = original.extend({
   341‚Üí		headers: {
   342‚Üí			rainbow: undefined
   343‚Üí		}
   344‚Üí	});
   345‚Üí
   346‚Üí	const response = await extended(url).json();
   347‚Üí
   348‚Üí	console.log('rainbow' in response);
   349‚Üí	//=> false
   350‚Üí
   351‚Üí	console.log('unicorn' in response);
   352‚Üí	//=> true
   353‚Üí	```
   354‚Üí	*/
   355‚Üí	headers?: KyHeadersInit;
   356‚Üí}
   358‚Üíexport type InternalOptions = Required<
   359‚ÜíOmit<Options, 'hooks' | 'retry' | 'context' | 'throwHttpErrors'>,
   360‚Üí'fetch' | 'prefixUrl' | 'timeout'
   361‚Üí> & {
   362‚Üí	headers: Required<Headers>;
   363‚Üí	hooks: Required<Hooks>;
   364‚Üí	retry: Required<Omit<RetryOptions, 'shouldRetry'>> & Pick<RetryOptions, 'shouldRetry'>;
   365‚Üí	prefixUrl: string;
   366‚Üí	context: Record<string, unknown>;
   367‚Üí	throwHttpErrors: boolean | ((status: number) => boolean);
   368‚Üí};
   370‚Üí/**
   371‚ÜíNormalized options passed to the `fetch` call and the `beforeRequest` hooks.
   372‚Üí*/
   373‚Üíexport interface NormalizedOptions extends RequestInit { // eslint-disable-line @typescript-eslint/consistent-type-definitions -- This must stay an interface so that it can be extended outside of Ky for use in `ky.create`.
   374‚Üí	// Extended from `RequestInit`, but ensured to be set (not optional).
   375‚Üí	method: NonNullable<RequestInit['method']>;
   376‚Üí	credentials?: NonNullable<RequestInit['credentials']>;
   377‚Üí
   378‚Üí	// Extended from custom `KyOptions`, but ensured to be set (not optional).
   379‚Üí	retry: RetryOptions;
   380‚Üí	prefixUrl: string;
   381‚Üí	onDownloadProgress: Options['onDownloadProgress'];
   382‚Üí	onUploadProgress: Options['onUploadProgress'];
   383‚Üí	context: Record<string, unknown>;
   384‚Üí}
source/types/request.ts
     1‚Üíexport type KyRequest<T = unknown> = {
     2‚Üí	json: <J = T>() => Promise<J>;
     3‚Üí} & Request;
source/types/response.ts
     1‚Üíexport type KyResponse<T = unknown> = {
     2‚Üí	json: <J = T >() => Promise<J>;
     3‚Üí} & Response;
source/types/retry.ts
     3‚Üíexport type ShouldRetryState = {
     4‚Üí	/**
     5‚Üí	The error that caused the request to fail.
     6‚Üí	*/
     7‚Üí	error: Error;
     8‚Üí
     9‚Üí	/**
    10‚Üí	The number of retries attempted. Starts at 1 for the first retry.
    11‚Üí	*/
    12‚Üí	retryCount: number;
    13‚Üí};
    15‚Üíexport type RetryOptions = {
    16‚Üí	/**
    17‚Üí	The number of times to retry failed requests.
    18‚Üí
    19‚Üí	@default 2
    20‚Üí	*/
    21‚Üí	limit?: number;
    22‚Üí
    23‚Üí	/**
    24‚Üí	The HTTP methods allowed to retry.
    25‚Üí
    26‚Üí	@default ['get', 'put', 'head', 'delete', 'options', 'trace']
    27‚Üí	*/
    28‚Üí	methods?: HttpMethod[];
    29‚Üí
    30‚Üí	/**
    31‚Üí	The HTTP status codes allowed to retry.
    32‚Üí
    33‚Üí	@default [408, 413, 429, 500, 502, 503, 504]
    34‚Üí	*/
    35‚Üí	statusCodes?: number[];
    36‚Üí
    37‚Üí	/**
    38‚Üí	The HTTP status codes allowed to retry with a `Retry-After` header.
    39‚Üí
    40‚Üí	@default [413, 429, 503]
    41‚Üí	*/
    42‚Üí	afterStatusCodes?: number[];
    43‚Üí
    44‚Üí	/**
    45‚Üí	If the `Retry-After` header is greater than `maxRetryAfter`, the request will be canceled.
    46‚Üí
    47‚Üí	@default Infinity
    48‚Üí	*/
    49‚Üí	maxRetryAfter?: number;
    50‚Üí
    51‚Üí	/**
    52‚Üí	The upper limit of the delay per retry in milliseconds.
    53‚Üí	To clamp the delay, set `backoffLimit` to 1000, for example.
    54‚Üí
    55‚Üí	By default, the delay is calculated in the following way:
    56‚Üí
    57‚Üí	```
    58‚Üí	0.3 * (2 ** (attemptCount - 1)) * 1000
    59‚Üí	```
    60‚Üí
    61‚Üí	The delay increases exponentially.
    62‚Üí
    63‚Üí	@default Infinity
    64‚Üí	*/
    65‚Üí	backoffLimit?: number;
    66‚Üí
    67‚Üí	/**
    68‚Üí	A function to calculate the delay between retries given `attemptCount` (starts from 1).
    69‚Üí
    70‚Üí	@default attemptCount => 0.3 * (2 ** (attemptCount - 1)) * 1000
    71‚Üí	*/
    72‚Üí	delay?: (attemptCount: number) => number;
    73‚Üí
    74‚Üí	/**
    75‚Üí	Add random jitter to retry delays to prevent thundering herd problems.
    76‚Üí
    77‚Üí	When many clients retry simultaneously (e.g., after hitting a rate limit), they can overwhelm the server again. Jitter adds randomness to break this synchronization.
    78‚Üí
    79‚Üí	Set to `true` to use full jitter, which randomizes the delay between 0 and the computed delay.
    80‚Üí
    81‚Üí	Alternatively, pass a function to implement custom jitter strategies.
    82‚Üí
    83‚Üí	@default undefined (no jitter)
    84‚Üí
    85‚Üí	@example
    86‚Üí	```
    87‚Üí	import ky from 'ky';
    88‚Üí
    89‚Üí	const json = await ky('https://example.com', {
    90‚Üí		retry: {
    91‚Üí			limit: 5,
    92‚Üí
    93‚Üí			// Full jitter (randomizes delay between 0 and computed value)
    94‚Üí			jitter: true
    95‚Üí
    96‚Üí			// Percentage jitter (80-120% of delay)
    97‚Üí			// jitter: delay => delay * (0.8 + Math.random() * 0.4)
    98‚Üí
    99‚Üí			// Absolute jitter (¬±100ms)
   100‚Üí			// jitter: delay => delay + (Math.random() * 200 - 100)
   101‚Üí		}
   102‚Üí	}).json();
   103‚Üí	```
   104‚Üí	*/
   105‚Üí	jitter?: boolean | ((delay: number) => number) | undefined;
   106‚Üí
   107‚Üí	/**
   108‚Üí	Whether to retry when the request times out.
   109‚Üí
   110‚Üí	@default false
   111‚Üí
   112‚Üí	@example
   113‚Üí	```
   114‚Üí	import ky from 'ky';
   115‚Üí
   116‚Üí	const json = await ky('https://example.com', {
   117‚Üí		retry: {
   118‚Üí			limit: 3,
   119‚Üí			retryOnTimeout: true
   120‚Üí		}
   121‚Üí	}).json();
   122‚Üí	```
   123‚Üí	*/
   124‚Üí	retryOnTimeout?: boolean;
   125‚Üí
   126‚Üí	/**
   127‚Üí	A function to determine whether a retry should be attempted.
   128‚Üí
   129‚Üí	This function takes precedence over all other retry checks and is called first, before any other retry validation.
   130‚Üí
   131‚Üí	**Note:** This is different from the `beforeRetry` hook:
   132‚Üí	- `shouldRetry`: Controls WHETHER to retry (called before the retry decision is made)
   133‚Üí	- `beforeRetry`: Called AFTER retry is confirmed, allowing you to modify the request
   134‚Üí
   135‚Üí	Should return:
   136‚Üí	- `true` to force a retry (bypasses `retryOnTimeout`, status code checks, and other validations)
   137‚Üí	- `false` to prevent a retry (no retry will occur)
   138‚Üí	- `undefined` to use the default retry logic (`retryOnTimeout`, status codes, etc.)
   139‚Üí
   140‚Üí	@example
   141‚Üí	```

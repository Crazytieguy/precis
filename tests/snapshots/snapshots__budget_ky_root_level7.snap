   456‚Üí				}
   457‚Üí			}
   458‚Üí
   459‚Üí			return this.#retry(function_);
   460‚Üí		}
   461‚Üí	}
   462‚Üí
   463‚Üí	async #fetch(): Promise<Response> {
   464‚Üí		// Reset abortController if it was aborted (happens on timeout retry)
   465‚Üí		if (this.#abortController?.signal.aborted) {
   466‚Üí			this.#abortController = new globalThis.AbortController();
   467‚Üí			this.#options.signal = this.#userProvidedAbortSignal ? AbortSignal.any([this.#userProvidedAbortSignal, this.#abortController.signal]) : this.#abortController.signal;
   468‚Üí			// Recreate request with new signal
   469‚Üí			this.request = new globalThis.Request(this.request, {signal: this.#options.signal});
   470‚Üí		}
   471‚Üí
   472‚Üí		for (const hook of this.#options.hooks.beforeRequest) {
   473‚Üí			// eslint-disable-next-line no-await-in-loop
   474‚Üí			const result = await hook(
   475‚Üí				this.request,
   476‚Üí				this.#getNormalizedOptions(),
   477‚Üí				{retryCount: this.#retryCount},
   478‚Üí			);
   479‚Üí
   480‚Üí			if (result instanceof Response) {
   481‚Üí				return result;
   482‚Üí			}
   483‚Üí
   484‚Üí			if (result instanceof globalThis.Request) {
   485‚Üí				this.#assignRequest(result);
   486‚Üí				break;
   487‚Üí			}
   488‚Üí		}
   489‚Üí
   490‚Üí		const nonRequestOptions = findUnknownOptions(this.request, this.#options);
   491‚Üí
   492‚Üí		// Cloning is done here to prepare in advance for retries
   493‚Üí		this.#originalRequest = this.request;
   494‚Üí		this.request = this.#originalRequest.clone();
   495‚Üí
   496‚Üí		if (this.#options.timeout === false) {
   497‚Üí			return this.#options.fetch(this.#originalRequest, nonRequestOptions);
   498‚Üí		}
   499‚Üí
   500‚Üí		return timeout(this.#originalRequest, nonRequestOptions, this.#abortController, this.#options as TimeoutOptions);
   501‚Üí	}
   502‚Üí
   503‚Üí	#getNormalizedOptions(): NormalizedOptions {
   504‚Üí		if (!this.#cachedNormalizedOptions) {
   505‚Üí			const {hooks, ...normalizedOptions} = this.#options;
   506‚Üí			this.#cachedNormalizedOptions = Object.freeze(normalizedOptions) as NormalizedOptions;
   507‚Üí		}
   508‚Üí
   509‚Üí		return this.#cachedNormalizedOptions;
   510‚Üí	}
   511‚Üí
   512‚Üí	#assignRequest(request: Request): void {
   513‚Üí		this.#cachedNormalizedOptions = undefined;
   514‚Üí		this.request = this.#wrapRequestWithUploadProgress(request);
   515‚Üí	}
   516‚Üí
   517‚Üí	#wrapRequestWithUploadProgress(request: Request, originalBody?: BodyInit): Request {
   518‚Üí		if (!this.#options.onUploadProgress || !request.body) {
   519‚Üí			return request;
   520‚Üí		}
   521‚Üí
   522‚Üí		return streamRequest(request, this.#options.onUploadProgress, originalBody ?? this.#options.body ?? undefined);
   523‚Üí	}
   524‚Üí}

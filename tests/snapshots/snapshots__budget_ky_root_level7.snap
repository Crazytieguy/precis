   129‚Üí	// Retry with refreshed authentication token
   130‚Üí	const data = await response.clone().json();
   131‚Üí	return ky.retry({
   132‚Üí		request: new Request(request, {
   133‚Üí			headers: {
   134‚Üí				...Object.fromEntries(request.headers),
   135‚Üí				'Authorization': `Bearer ${data.newToken}`
   136‚Üí			}
   137‚Üí		}),
   138‚Üí		code: 'TOKEN_REFRESHED'
   139‚Üí	});
   140‚Üí	```
   141‚Üí	*/

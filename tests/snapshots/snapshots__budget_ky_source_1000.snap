   332ÔåÆ
   333ÔåÆ	const original = ky.create({
   334ÔåÆ		headers: {
   335ÔåÆ			rainbow: 'rainbow',
   336ÔåÆ			unicorn: 'unicorn'
   337ÔåÆ		}
   338ÔåÆ	});
   339ÔåÆ
   340ÔåÆ	const extended = original.extend({
   341ÔåÆ		headers: {
   342ÔåÆ			rainbow: undefined
   343ÔåÆ		}
   344ÔåÆ	});
   345ÔåÆ

errors/ForceRetryError.ts
     4вҶ’/**
     5вҶ’Internal error used to signal a forced retry from afterResponse hooks.
     6вҶ’This is thrown when a user returns ky.retry() from an afterResponse hook.
     7вҶ’*/
     8вҶ’export class ForceRetryError extends Error {
     9вҶ’	override name = 'ForceRetryError' as const;
    10вҶ’	customDelay: number | undefined;
    11вҶ’	code: string | undefined;
    12вҶ’	customRequest: Request | undefined;
    13вҶ’
    14вҶ’	constructor(options?: ForceRetryOptions) {
    15вҶ’		// Runtime protection: wrap non-Error causes in NonError
    16вҶ’		// TypeScript type is Error for guidance, but JS users can pass anything
    17вҶ’		const cause = options?.cause
    18вҶ’			? (options.cause instanceof Error ? options.cause : new NonError(options.cause))
    19вҶ’			: undefined;
    20вҶ’
    21вҶ’		super(
    22вҶ’			options?.code ? `Forced retry: ${options.code}` : 'Forced retry',
    23вҶ’			cause ? {cause} : undefined,
    24вҶ’		);
    25вҶ’
    26вҶ’		this.customDelay = options?.delay;
    27вҶ’		this.code = options?.code;
    28вҶ’		this.customRequest = options?.request;
    29вҶ’	}
    30вҶ’}

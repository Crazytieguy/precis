   319вҶ’
   320вҶ’	/**
   321вҶ’	HTTP headers used to make the request.
   322вҶ’
   323вҶ’	You can pass a `Headers` instance or a plain object.
   324вҶ’
   325вҶ’	You can remove a header with `.extend()` by passing the header with an `undefined` value.
   326вҶ’
   327вҶ’	@example
   328вҶ’	```
   329вҶ’	import ky from 'ky';
   330вҶ’
   331вҶ’	const url = 'https://sindresorhus.com';
   332вҶ’
   333вҶ’	const original = ky.create({
   334вҶ’		headers: {
   335вҶ’			rainbow: 'rainbow',
   336вҶ’			unicorn: 'unicorn'
   337вҶ’		}
   338вҶ’	});
   339вҶ’
   340вҶ’	const extended = original.extend({
   341вҶ’		headers: {
   342вҶ’			rainbow: undefined
   343вҶ’		}
   344вҶ’	});
   345вҶ’
   346вҶ’	const response = await extended(url).json();
   347вҶ’
   348вҶ’	console.log('rainbow' in response);
   349вҶ’	//=> false
   350вҶ’
   351вҶ’	console.log('unicorn' in response);
   352вҶ’	//=> true
   353вҶ’	```
   354вҶ’	*/
   355вҶ’	headers?: KyHeadersInit;
   356вҶ’}

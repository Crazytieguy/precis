    65→/**
    66→Options for forcing a retry via `ky.retry()`.
    67→*/
    68→export type ForceRetryOptions = {
    69→	/**
    70→	Custom delay in milliseconds before retrying.
    71→
    72→	If not provided, uses the default retry delay calculation based on `retry.delay` configuration.
    73→
    74→	**Note:** Custom delays bypass jitter and `backoffLimit`. This is intentional, as custom delays often come from server responses (e.g., `Retry-After` headers) and should be respected exactly as specified.
    75→	*/
    76→	delay?: number;
    77→
    78→	/**
    79→	Error code for the retry.
    80→
    81→	This machine-readable identifier will be included in the error message passed to `beforeRetry` hooks, allowing you to distinguish between different types of forced retries.
    82→
    83→	@example
    84→	```
    85→	return ky.retry({code: 'RATE_LIMIT'});
    86→	// Resulting error message: 'Forced retry: RATE_LIMIT'
    87→	```
    88→	*/
    89→	code?: string;
    90→
    91→	/**
    92→	Original error that caused the retry.
    93→
    94→	This allows you to preserve the error chain when forcing a retry based on caught exceptions. The error will be set as the `cause` of the `ForceRetryError`, enabling proper error chain traversal.
    95→
    96→	@example
    97→	```
    98→	try {
    99→		const data = await response.clone().json();
   100→		validateBusinessLogic(data);
   101→	} catch (error) {
   102→		return ky.retry({
   103→			code: 'VALIDATION_FAILED',
   104→			cause: error  // Preserves original error in chain
   105→		});
   106→	}
   107→	```
   108→	*/
   109→	cause?: Error;
   110→
   111→	/**
   112→	Custom request to use for the retry.
   113→
   114→	This allows you to modify or completely replace the request during a forced retry. The custom request becomes the starting point for the retry - `beforeRetry` hooks can still further modify it if needed.
   115→
   116→	**Note:** The custom request's `signal` will be replaced with Ky's managed signal to handle timeouts and user-provided abort signals correctly. If the original request body has been consumed, you must provide a new body or clone the request before consuming.
   117→
   118→	@example
   119→	```
   120→	// Fallback to a different endpoint
   121→	return ky.retry({
   122→		request: new Request('https://backup-api.com/endpoint', {
   123→			method: request.method,
   124→			headers: request.headers,
   125→		}),
   126→		code: 'BACKUP_ENDPOINT'
   127→	});
   128→
   129→	// Retry with refreshed authentication token
   130→	const data = await response.clone().json();
   131→	return ky.retry({
   132→		request: new Request(request, {
   133→			headers: {
   134→				...Object.fromEntries(request.headers),
   135→				'Authorization': `Bearer ${data.newToken}`
   136→			}
   137→		}),
   138→		code: 'TOKEN_REFRESHED'
   139→	});
   140→	```
   141→	*/
   142→	request?: Request;
   143→};

errors/ForceRetryError.ts
     4в†’/**
     5в†’Internal error used to signal a forced retry from afterResponse hooks.
     6в†’This is thrown when a user returns ky.retry() from an afterResponse hook.
     7в†’*/
     8в†’export class ForceRetryError extends Error {
     9в†’	override name = 'ForceRetryError' as const;
    10в†’	customDelay: number | undefined;
    11в†’	code: string | undefined;
    12в†’	customRequest: Request | undefined;
    13в†’
    14в†’	constructor(options?: ForceRetryOptions) {
    15в†’		// Runtime protection: wrap non-Error causes in NonError
    16в†’		// TypeScript type is Error for guidance, but JS users can pass anything
    17в†’		const cause = options?.cause
    18в†’			? (options.cause instanceof Error ? options.cause : new NonError(options.cause))
    19в†’			: undefined;
    20в†’
    21в†’		super(
    22в†’			options?.code ? `Forced retry: ${options.code}` : 'Forced retry',
    23в†’			cause ? {cause} : undefined,
    24в†’		);
    25в†’
    26в†’		this.customDelay = options?.delay;
    27в†’		this.code = options?.code;
    28в†’		this.customRequest = options?.request;
    29в†’	}
    30в†’}
errors/HTTPError.ts
     5в†’export class HTTPError<T = unknown> extends Error {
     6в†’	public response: KyResponse<T>;
     7в†’	public request: KyRequest;
     8в†’	public options: NormalizedOptions;
     9в†’
    10в†’	constructor(response: Response, request: Request, options: NormalizedOptions) {
    11в†’		const code = (response.status || response.status === 0) ? response.status : '';
    12в†’		const title = response.statusText ?? '';
    13в†’		const status = `${code} ${title}`.trim();
    14в†’		const reason = status ? `status code ${status}` : 'an unknown error';
    15в†’
    16в†’		super(`Request failed with ${reason}: ${request.method} ${request.url}`);
    17в†’
    18в†’		this.name = 'HTTPError';
    19в†’		this.response = response;
    20в†’		this.request = request;
    21в†’		this.options = options;
    22в†’	}
    23в†’}
errors/NonError.ts
     1в†’/**
     2в†’Wrapper for non-Error values that were thrown.
     3в†’
     4в†’In JavaScript, any value can be thrown (not just Error instances). This class wraps such values to ensure consistent error handling.
     5в†’*/
     6в†’export class NonError extends Error {
     7в†’	override name = 'NonError';
     8в†’	readonly value: unknown;
     9в†’
    10в†’	constructor(value: unknown) {
    11в†’		let message = 'Non-error value was thrown';
    12в†’
    13в†’		// Intentionally minimal as this error is just an edge-case.
    14в†’		try {
    15в†’			if (typeof value === 'string') {
    16в†’				message = value;
    17в†’			} else if (value && typeof value === 'object' && 'message' in value && typeof value.message === 'string') {
    18в†’				message = value.message;
    19в†’			}
    20в†’		} catch {
    21в†’			// Use default message if accessing properties throws
    22в†’		}
    23в†’
    24в†’		super(message);
    25в†’
    26в†’		this.value = value;
    27в†’	}
    28в†’}

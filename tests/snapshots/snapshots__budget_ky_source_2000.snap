   313в†’	/**
   314в†’	HTTP method used to make the request.
   315в†’
   316в†’	Internally, the standard methods (`GET`, `POST`, `PUT`, `PATCH`, `HEAD` and `DELETE`) are uppercased in order to avoid server errors due to case sensitivity.
   317в†’	*/
   318в†’	method?: LiteralUnion<HttpMethod, string>;
   319в†’
   320в†’	/**
   321в†’	HTTP headers used to make the request.
   322в†’
   323в†’	You can pass a `Headers` instance or a plain object.
   324в†’
   325в†’	You can remove a header with `.extend()` by passing the header with an `undefined` value.
   326в†’
   327в†’	@example
   328в†’	```
   329в†’	import ky from 'ky';
   330в†’
   331в†’	const url = 'https://sindresorhus.com';
   332в†’
   333в†’	const original = ky.create({
   334в†’		headers: {
   335в†’			rainbow: 'rainbow',
   336в†’			unicorn: 'unicorn'
   337в†’		}
   338в†’	});
   339в†’
   340в†’	const extended = original.extend({
   341в†’		headers: {
   342в†’			rainbow: undefined
   343в†’		}
   344в†’	});
   345в†’
   346в†’	const response = await extended(url).json();
   347в†’
   348в†’	console.log('rainbow' in response);
   349в†’	//=> false
   350в†’
   351в†’	console.log('unicorn' in response);
   352в†’	//=> true
   353в†’	```
   354в†’	*/
   355в†’	headers?: KyHeadersInit;
   356в†’}

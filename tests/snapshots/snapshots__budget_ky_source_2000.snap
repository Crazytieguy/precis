    65вҶ’/**
    66вҶ’Options for forcing a retry via `ky.retry()`.
    67вҶ’*/
    68вҶ’export type ForceRetryOptions = {
    69вҶ’	/**
    70вҶ’	Custom delay in milliseconds before retrying.
    71вҶ’
    72вҶ’	If not provided, uses the default retry delay calculation based on `retry.delay` configuration.
    73вҶ’
    74вҶ’	**Note:** Custom delays bypass jitter and `backoffLimit`. This is intentional, as custom delays often come from server responses (e.g., `Retry-After` headers) and should be respected exactly as specified.
    75вҶ’	*/
    76вҶ’	delay?: number;
    77вҶ’
    78вҶ’	/**
    79вҶ’	Error code for the retry.
    80вҶ’
    81вҶ’	This machine-readable identifier will be included in the error message passed to `beforeRetry` hooks, allowing you to distinguish between different types of forced retries.
    82вҶ’
    83вҶ’	@example
    84вҶ’	```
    85вҶ’	return ky.retry({code: 'RATE_LIMIT'});
    86вҶ’	// Resulting error message: 'Forced retry: RATE_LIMIT'
    87вҶ’	```
    88вҶ’	*/
    89вҶ’	code?: string;
    90вҶ’
    91вҶ’	/**
    92вҶ’	Original error that caused the retry.
    93вҶ’
    94вҶ’	This allows you to preserve the error chain when forcing a retry based on caught exceptions. The error will be set as the `cause` of the `ForceRetryError`, enabling proper error chain traversal.
    95вҶ’
    96вҶ’	@example
    97вҶ’	```
    98вҶ’	try {
    99вҶ’		const data = await response.clone().json();
   100вҶ’		validateBusinessLogic(data);
   101вҶ’	} catch (error) {
   102вҶ’		return ky.retry({
   103вҶ’			code: 'VALIDATION_FAILED',
   104вҶ’			cause: error  // Preserves original error in chain
   105вҶ’		});
   106вҶ’	}
   107вҶ’	```
   108вҶ’	*/
   109вҶ’	cause?: Error;
   110вҶ’
   111вҶ’	/**
   112вҶ’	Custom request to use for the retry.
   113вҶ’
   114вҶ’	This allows you to modify or completely replace the request during a forced retry. The custom request becomes the starting point for the retry - `beforeRetry` hooks can still further modify it if needed.
   115вҶ’
   116вҶ’	**Note:** The custom request's `signal` will be replaced with Ky's managed signal to handle timeouts and user-provided abort signals correctly. If the original request body has been consumed, you must provide a new body or clone the request before consuming.
   117вҶ’
   118вҶ’	@example
   119вҶ’	```
   120вҶ’	// Fallback to a different endpoint
   121вҶ’	return ky.retry({
   122вҶ’		request: new Request('https://backup-api.com/endpoint', {
   123вҶ’			method: request.method,
   124вҶ’			headers: request.headers,
   125вҶ’		}),
   126вҶ’		code: 'BACKUP_ENDPOINT'
   127вҶ’	});
   128вҶ’
   129вҶ’	// Retry with refreshed authentication token
   130вҶ’	const data = await response.clone().json();
   131вҶ’	return ky.retry({
   132вҶ’		request: new Request(request, {
   133вҶ’			headers: {
   134вҶ’				...Object.fromEntries(request.headers),
   135вҶ’				'Authorization': `Bearer ${data.newToken}`
   136вҶ’			}
   137вҶ’		}),
   138вҶ’		code: 'TOKEN_REFRESHED'
   139вҶ’	});
   140вҶ’	```
   141вҶ’	*/
   142вҶ’	request?: Request;
   143вҶ’};
   145вҶ’/**
   146вҶ’Marker returned by ky.retry() to signal a forced retry from afterResponse hooks.

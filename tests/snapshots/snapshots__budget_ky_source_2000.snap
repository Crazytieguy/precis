     4‚Üí/**
     5‚ÜíInternal error used to signal a forced retry from afterResponse hooks.
     6‚ÜíThis is thrown when a user returns ky.retry() from an afterResponse hook.
     7‚Üí*/
     8‚Üíexport class ForceRetryError extends Error {
     9‚Üí	override name = 'ForceRetryError' as const;
    10‚Üí	customDelay: number | undefined;
    11‚Üí	code: string | undefined;
    12‚Üí	customRequest: Request | undefined;
    13‚Üí
    14‚Üí	constructor(options?: ForceRetryOptions) {
    15‚Üí		// Runtime protection: wrap non-Error causes in NonError
    16‚Üí		// TypeScript type is Error for guidance, but JS users can pass anything
    17‚Üí		const cause = options?.cause
    18‚Üí			? (options.cause instanceof Error ? options.cause : new NonError(options.cause))
    19‚Üí			: undefined;
    20‚Üí
    21‚Üí		super(
    22‚Üí			options?.code ? `Forced retry: ${options.code}` : 'Forced retry',
    23‚Üí			cause ? {cause} : undefined,
    24‚Üí		);
    25‚Üí
    26‚Üí		this.customDelay = options?.delay;
    27‚Üí		this.code = options?.code;
    28‚Üí		this.customRequest = options?.request;
    29‚Üí	}
    30‚Üí}

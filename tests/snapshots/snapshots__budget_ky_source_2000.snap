     5вҶ’export class HTTPError<T = unknown> extends Error {
     6вҶ’	public response: KyResponse<T>;
     7вҶ’	public request: KyRequest;
     8вҶ’	public options: NormalizedOptions;
     9вҶ’
    10вҶ’	constructor(response: Response, request: Request, options: NormalizedOptions) {
    11вҶ’		const code = (response.status || response.status === 0) ? response.status : '';
    12вҶ’		const title = response.statusText ?? '';
    13вҶ’		const status = `${code} ${title}`.trim();
    14вҶ’		const reason = status ? `status code ${status}` : 'an unknown error';
    15вҶ’
    16вҶ’		super(`Request failed with ${reason}: ${request.method} ${request.url}`);
    17вҶ’
    18вҶ’		this.name = 'HTTPError';
    19вҶ’		this.response = response;
    20вҶ’		this.request = request;
    21вҶ’		this.options = options;
    22вҶ’	}
    23вҶ’}
errors/NonError.ts
     1вҶ’/**
     2вҶ’Wrapper for non-Error values that were thrown.
     3вҶ’
     4вҶ’In JavaScript, any value can be thrown (not just Error instances). This class wraps such values to ensure consistent error handling.
     5вҶ’*/
     6вҶ’export class NonError extends Error {
     7вҶ’	override name = 'NonError';
     8вҶ’	readonly value: unknown;
     9вҶ’
    10вҶ’	constructor(value: unknown) {
    11вҶ’		let message = 'Non-error value was thrown';
    12вҶ’
    13вҶ’		// Intentionally minimal as this error is just an edge-case.
    14вҶ’		try {
    15вҶ’			if (typeof value === 'string') {
    16вҶ’				message = value;
    17вҶ’			} else if (value && typeof value === 'object' && 'message' in value && typeof value.message === 'string') {
    18вҶ’				message = value.message;
    19вҶ’			}
    20вҶ’		} catch {
    21вҶ’			// Use default message if accessing properties throws
    22вҶ’		}
    23вҶ’
    24вҶ’		super(message);
    25вҶ’
    26вҶ’		this.value = value;
    27вҶ’	}
    28вҶ’}

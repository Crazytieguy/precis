core/constants.ts
     4→export const supportsRequestStreams = (() => {
     5→	let duplexAccessed = false;
     6→	let hasContentType = false;
     7→	const supportsReadableStream = typeof globalThis.ReadableStream === 'function';
     8→	const supportsRequest = typeof globalThis.Request === 'function';
     9→
    10→	if (supportsReadableStream && supportsRequest) {
    11→		try {
    12→			hasContentType = new globalThis.Request('https://empty.invalid', {
    13→				body: new globalThis.ReadableStream(),
    14→				method: 'POST',
    15→				// @ts-expect-error - Types are outdated.
    16→				get duplex() {
    17→					duplexAccessed = true;
    18→					return 'half';
    19→				},
    20→			}).headers.has('Content-Type');
    21→		} catch (error) {
    22→			// QQBrowser on iOS throws "unsupported BodyInit type" error (see issue #581)
    23→			if (error instanceof Error && error.message === 'unsupported BodyInit type') {
    24→				return false;
    25→			}
    26→
    27→			throw error;
    28→		}
    29→	}
    30→
    31→	return duplexAccessed && !hasContentType;
    32→})();

utils/type-guards.ts
     5в†’/**
     6в†’Type guard to check if an error is a Ky error.
     7в†’
     8в†’@param error - The error to check
     9в†’@returns `true` if the error is a Ky error, `false` otherwise
    10в†’
    11в†’@example
    12в†’```
    13в†’import ky, {isKyError} from 'ky';
    14в†’try {
    15в†’	const response = await ky.get('/api/data');
    16в†’} catch (error) {
    17в†’	if (isKyError(error)) {
    18в†’		// Handle Ky-specific errors
    19в†’		console.log('Ky error occurred:', error.message);
    20в†’	} else {
    21в†’		// Handle other errors
    22в†’		console.log('Unknown error:', error);
    23в†’	}
    24в†’}
    25в†’```
    26в†’*/
    27в†’export function isKyError(error: unknown): error is HTTPError | TimeoutError | ForceRetryError {
    28в†’	return isHTTPError(error) || isTimeoutError(error) || isForceRetryError(error);
    29в†’}
    31в†’/**
    32в†’Type guard to check if an error is an HTTPError.
    33в†’
    34в†’@param error - The error to check
    35в†’@returns `true` if the error is an HTTPError, `false` otherwise
    36в†’
    37в†’@example
    38в†’```
    39в†’import ky, {isHTTPError} from 'ky';
    40в†’try {
    41в†’	const response = await ky.get('/api/data');
    42в†’} catch (error) {
    43в†’	if (isHTTPError(error)) {
    44в†’		console.log('HTTP error status:', error.response.status);
    45в†’	}
    46в†’}
    47в†’```
    48в†’*/
    49в†’export function isHTTPError<T = unknown>(error: unknown): error is HTTPError<T> {
    50в†’	return error instanceof HTTPError || ((error as any)?.name === HTTPError.name);
    51в†’}
    53в†’/**
    54в†’Type guard to check if an error is a TimeoutError.
    55в†’
    56в†’@param error - The error to check
    57в†’@returns `true` if the error is a TimeoutError, `false` otherwise
    58в†’
    59в†’@example
    60в†’```
    61в†’import ky, {isTimeoutError} from 'ky';
    62в†’try {
    63в†’	const response = await ky.get('/api/data', { timeout: 1000 });
    64в†’} catch (error) {
    65в†’	if (isTimeoutError(error)) {
    66в†’		console.log('Request timed out:', error.request.url);
    67в†’	}
    68в†’}
    69в†’```
    70в†’*/
    71в†’export function isTimeoutError(error: unknown): error is TimeoutError {
    72в†’	return error instanceof TimeoutError || ((error as any)?.name === TimeoutError.name);
    73в†’}
    75в†’/**
    76в†’Type guard to check if an error is a ForceRetryError.
    77в†’
    78в†’@param error - The error to check
    79в†’@returns `true` if the error is a ForceRetryError, `false` otherwise
    80в†’
    81в†’@example
    82в†’```
    83в†’import ky, {isForceRetryError} from 'ky';
    84в†’
    85в†’const api = ky.extend({
    86в†’	hooks: {
    87в†’		beforeRetry: [
    88в†’			({error, retryCount}) => {
    89в†’				if (isForceRetryError(error)) {
    90в†’					console.log(`Forced retry #${retryCount}: ${error.code}`);
    91в†’				}
    92в†’			}
    93в†’		]
    94в†’	}
    95в†’});
    96в†’```
    97в†’*/
    98в†’export function isForceRetryError(error: unknown): error is ForceRetryError {
    99в†’	return error instanceof ForceRetryError || ((error as any)?.name === ForceRetryError.name);
   100в†’}

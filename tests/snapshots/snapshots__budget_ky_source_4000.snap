   148вҶ’export class RetryMarker {
   149вҶ’	constructor(public options?: ForceRetryOptions) {}
   153вҶ’Force a retry from an `afterResponse` hook.
   154вҶ’
   155вҶ’This allows you to retry a request based on the response content, even if the response has a successful status code. The retry will respect the `retry.limit` option and skip the `shouldRetry` check. The forced retry is observable in `beforeRetry` hooks, where the error will be a `ForceRetryError`.
   156вҶ’
   157вҶ’@param options - Optional configuration for the retry.
   158вҶ’
   159вҶ’@example
   160вҶ’```
   161вҶ’import ky, {isForceRetryError} from 'ky';
   162вҶ’
   163вҶ’const api = ky.extend({
   164вҶ’	hooks: {
   165вҶ’		afterResponse: [
   166вҶ’			async (request, options, response) => {
   167вҶ’				// Retry based on response body content
   168вҶ’				if (response.status === 200) {
   169вҶ’					const data = await response.clone().json();
   170вҶ’
   171вҶ’					// Simple retry with default delay
   172вҶ’					if (data.error?.code === 'TEMPORARY_ERROR') {
   173вҶ’						return ky.retry();
   174вҶ’					}
   175вҶ’
   176вҶ’					// Retry with custom delay from API response
   177вҶ’					if (data.error?.code === 'RATE_LIMIT') {
   178вҶ’						return ky.retry({
   179вҶ’							delay: data.error.retryAfter * 1000,
   180вҶ’							code: 'RATE_LIMIT'
   181вҶ’						});
   182вҶ’					}
   183вҶ’
      вҶ’вҖҰ

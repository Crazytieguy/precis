     6вҶ’Type guard to check if an error is a Ky error.
     7вҶ’
     8вҶ’@param error - The error to check
     9вҶ’@returns `true` if the error is a Ky error, `false` otherwise
    10вҶ’
    11вҶ’@example
    12вҶ’```
    13вҶ’import ky, {isKyError} from 'ky';
    14вҶ’try {
    15вҶ’	const response = await ky.get('/api/data');
    16вҶ’} catch (error) {
    17вҶ’	if (isKyError(error)) {
    18вҶ’		// Handle Ky-specific errors
    19вҶ’		console.log('Ky error occurred:', error.message);
    20вҶ’	} else {
    21вҶ’		// Handle other errors
    22вҶ’		console.log('Unknown error:', error);
    23вҶ’	}
    24вҶ’}
    25вҶ’```
    27вҶ’export function isKyError(error: unknown): error is HTTPError | TimeoutError | ForceRetryError {
    28вҶ’	return isHTTPError(error) || isTimeoutError(error) || isForceRetryError(error);
    29вҶ’}
    32вҶ’Type guard to check if an error is an HTTPError.
    33вҶ’
    34вҶ’@param error - The error to check
    35вҶ’@returns `true` if the error is an HTTPError, `false` otherwise
    36вҶ’
    37вҶ’@example
    38вҶ’```
    39вҶ’import ky, {isHTTPError} from 'ky';
    40вҶ’try {
    41вҶ’	const response = await ky.get('/api/data');
    42вҶ’} catch (error) {
    43вҶ’	if (isHTTPError(error)) {
    44вҶ’		console.log('HTTP error status:', error.response.status);
    45вҶ’	}

     4в†’export const supportsRequestStreams = (() => {
     5в†’	let duplexAccessed = false;
     6в†’	let hasContentType = false;
     7в†’	const supportsReadableStream = typeof globalThis.ReadableStream === 'function';
     8в†’	const supportsRequest = typeof globalThis.Request === 'function';
     9в†’
    10в†’	if (supportsReadableStream && supportsRequest) {
    11в†’		try {
    12в†’			hasContentType = new globalThis.Request('https://empty.invalid', {
    13в†’				body: new globalThis.ReadableStream(),
    14в†’				method: 'POST',
    15в†’				// @ts-expect-error - Types are outdated.
    16в†’				get duplex() {
    17в†’					duplexAccessed = true;
    18в†’					return 'half';
    19в†’				},
    20в†’			}).headers.has('Content-Type');
    21в†’		} catch (error) {
    22в†’			// QQBrowser on iOS throws "unsupported BodyInit type" error (see issue #581)
    23в†’			if (error instanceof Error && error.message === 'unsupported BodyInit type') {
    24в†’				return false;
    25в†’			}
    26в†’
    27в†’			throw error;
    28в†’		}
    29в†’	}
    30в†’
    31в†’	return duplexAccessed && !hasContentType;
    32в†’})();

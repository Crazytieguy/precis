     3‚Üíimport {ForceRetryError} from '../errors/ForceRetryError.js';
     5‚Üí/**
     6‚ÜíType guard to check if an error is a Ky error.
     7‚Üí
     8‚Üí@param error - The error to check
     9‚Üí@returns `true` if the error is a Ky error, `false` otherwise
    10‚Üí
    11‚Üí@example
    12‚Üí```
    13‚Üíimport ky, {isKyError} from 'ky';
    14‚Üítry {
    15‚Üí	const response = await ky.get('/api/data');
    16‚Üí} catch (error) {
    17‚Üí	if (isKyError(error)) {
    18‚Üí		// Handle Ky-specific errors
    19‚Üí		console.log('Ky error occurred:', error.message);
    20‚Üí	} else {
    21‚Üí		// Handle other errors
    22‚Üí		console.log('Unknown error:', error);
    23‚Üí	}
    24‚Üí}
    25‚Üí```
    26‚Üí*/
    27‚Üíexport function isKyError(error: unknown): error is HTTPError | TimeoutError | ForceRetryError {
    28‚Üí	return isHTTPError(error) || isTimeoutError(error) || isForceRetryError(error);
    29‚Üí}
    31‚Üí/**
    32‚ÜíType guard to check if an error is an HTTPError.
    33‚Üí
    34‚Üí@param error - The error to check
    35‚Üí@returns `true` if the error is an HTTPError, `false` otherwise
    36‚Üí
    37‚Üí@example
    38‚Üí```
    39‚Üíimport ky, {isHTTPError} from 'ky';
    40‚Üítry {
    41‚Üí	const response = await ky.get('/api/data');
    42‚Üí} catch (error) {
    43‚Üí	if (isHTTPError(error)) {
    44‚Üí		console.log('HTTP error status:', error.response.status);
    45‚Üí	}
    46‚Üí}
    47‚Üí```
    48‚Üí*/
    49‚Üíexport function isHTTPError<T = unknown>(error: unknown): error is HTTPError<T> {
    50‚Üí	return error instanceof HTTPError || ((error as any)?.name === HTTPError.name);
    51‚Üí}
    53‚Üí/**
    54‚ÜíType guard to check if an error is a TimeoutError.
    55‚Üí
    56‚Üí@param error - The error to check
    57‚Üí@returns `true` if the error is a TimeoutError, `false` otherwise
    58‚Üí
    59‚Üí@example
    60‚Üí```
    61‚Üíimport ky, {isTimeoutError} from 'ky';
    62‚Üítry {
    63‚Üí	const response = await ky.get('/api/data', { timeout: 1000 });
    64‚Üí} catch (error) {
    65‚Üí	if (isTimeoutError(error)) {
    66‚Üí		console.log('Request timed out:', error.request.url);
    67‚Üí	}
    68‚Üí}
    69‚Üí```
    70‚Üí*/
    71‚Üíexport function isTimeoutError(error: unknown): error is TimeoutError {
    72‚Üí	return error instanceof TimeoutError || ((error as any)?.name === TimeoutError.name);
    73‚Üí}
    75‚Üí/**
    76‚ÜíType guard to check if an error is a ForceRetryError.
    77‚Üí
    78‚Üí@param error - The error to check
    79‚Üí@returns `true` if the error is a ForceRetryError, `false` otherwise
    80‚Üí
    81‚Üí@example
    82‚Üí```
    83‚Üíimport ky, {isForceRetryError} from 'ky';
    84‚Üí
    85‚Üíconst api = ky.extend({
    86‚Üí	hooks: {
    87‚Üí		beforeRetry: [
    88‚Üí			({error, retryCount}) => {
    89‚Üí				if (isForceRetryError(error)) {
    90‚Üí					console.log(`Forced retry #${retryCount}: ${error.code}`);
    91‚Üí				}
    92‚Üí			}
    93‚Üí		]
    94‚Üí	}
    95‚Üí});
    96‚Üí```
    97‚Üí*/
    98‚Üíexport function isForceRetryError(error: unknown): error is ForceRetryError {
    99‚Üí	return error instanceof ForceRetryError || ((error as any)?.name === ForceRetryError.name);
   100‚Üí}

    49вҶ’export function isHTTPError<T = unknown>(error: unknown): error is HTTPError<T> {
    50вҶ’	return error instanceof HTTPError || ((error as any)?.name === HTTPError.name);
    51вҶ’}
    54вҶ’Type guard to check if an error is a TimeoutError.
    55вҶ’
    56вҶ’@param error - The error to check
    57вҶ’@returns `true` if the error is a TimeoutError, `false` otherwise
    58вҶ’
    59вҶ’@example
    60вҶ’```
    61вҶ’import ky, {isTimeoutError} from 'ky';
    62вҶ’try {
    63вҶ’	const response = await ky.get('/api/data', { timeout: 1000 });

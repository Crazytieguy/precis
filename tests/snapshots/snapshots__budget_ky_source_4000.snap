    62→					// Cancel both responses to prevent memory leaks when hook throws
    63→					ky.#cancelResponseBody(clonedResponse);
    64→					ky.#cancelResponseBody(response);
    65→					throw error;
    66→				}
    67→
    68→				if (modifiedResponse instanceof RetryMarker) {
    69→					// Cancel both the cloned response passed to the hook and the current response to prevent resource leaks (especially important in Deno/Bun).
    70→					// Do not await cancellation since hooks can clone the response, leaving extra tee branches that keep cancel promises pending per the Streams spec.
    71→					ky.#cancelResponseBody(clonedResponse);
    72→					ky.#cancelResponseBody(response);
    73→					throw new ForceRetryError(modifiedResponse.options);
    74→				}
    75→
    76→				// Determine which response to use going forward
    77→				const nextResponse = modifiedResponse instanceof globalThis.Response ? modifiedResponse : response;

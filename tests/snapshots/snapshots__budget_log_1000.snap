    27→### In libraries
    29→Libraries should link only to the `log` crate, and use the provided macros to
    30→log whatever information will be useful to downstream consumers:
    31→
    32→```toml
    33→[dependencies]
    34→log = "0.4"
    35→```
    36→
    37→```rust
    38→use log::{info, trace, warn};
    39→
    40→pub fn shave_the_yak(yak: &mut Yak) {
    41→    trace!("Commencing yak shaving");
    42→
    43→    loop {
    44→        match find_a_razor() {
    45→            Ok(razor) => {
    46→                info!("Razor located: {razor}");
    47→                yak.shave(razor);
    48→                break;
    49→            }
    50→            Err(err) => {
    51→                warn!("Unable to locate a razor: {err}, retrying");
    52→            }
    53→        }
    54→    }
    55→}
    56→```

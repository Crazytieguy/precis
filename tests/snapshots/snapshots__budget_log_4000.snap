     9‚Üí/// A source of key-values.
    10‚Üí///
    11‚Üí/// The source may be a single pair, a set of pairs, or a filter over a set of pairs.
    12‚Üí/// Use the [`VisitSource`](trait.VisitSource.html) trait to inspect the structured data
    13‚Üí/// in a source.
    14‚Üí///
      ‚Üí‚Ä¶
    51‚Üípub trait Source {
    52‚Üí    /// Visit key-values.
    53‚Üí    ///
    54‚Üí    /// A source doesn't have to guarantee any ordering or uniqueness of key-values.
    55‚Üí    /// If the given visitor returns an error then the source may early-return with it,
    56‚Üí    /// even if there are more key-values.
    57‚Üí    ///
    58‚Üí    /// # Implementation notes
    59‚Üí    ///
    60‚Üí    /// A source should yield the same key-values to a subsequent visitor unless
    61‚Üí    /// that visitor itself fails.
    62‚Üí    fn visit<'kvs>(&'kvs self, visitor: &mut dyn VisitSource<'kvs>) -> Result<(), Error>;
    63‚Üí
    64‚Üí    /// Get the value for a given key.
    65‚Üí    ///
    66‚Üí    /// If the key appears multiple times in the source then which key is returned
    67‚Üí    /// is implementation specific.
    68‚Üí    ///
    69‚Üí    /// # Implementation notes
    70‚Üí    ///
    71‚Üí    /// A source that can provide a more efficient implementation of this method
    72‚Üí    /// should override it.
    73‚Üí    fn get(&self, key: Key) -> Option<Value<'_>> {
    74‚Üí        get_default(self, key)
    75‚Üí    }
    76‚Üí
    77‚Üí    /// Count the number of key-values that can be visited.
    78‚Üí    ///
    79‚Üí    /// # Implementation notes
    80‚Üí    ///
    81‚Üí    /// A source that knows the number of key-values upfront may provide a more
    82‚Üí    /// efficient implementation.
    83‚Üí    ///
    84‚Üí    /// A subsequent call to `visit` should yield the same number of key-values.
    85‚Üí    fn count(&self) -> usize {
    86‚Üí        count_default(self)
    87‚Üí    }
    88‚Üí}

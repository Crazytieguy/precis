  1261‚Üí    /// `log` method implementation to guarantee that filtering is applied.
  1262‚Üí    fn enabled(&self, metadata: &Metadata) -> bool;
  1263‚Üí
  1264‚Üí    /// Logs the `Record`.
  1265‚Üí    ///
  1266‚Üí    /// # For implementors
  1267‚Üí    ///

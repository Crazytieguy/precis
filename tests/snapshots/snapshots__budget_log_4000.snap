  1275Ôćĺ    /// # For implementors
  1276Ôćĺ    ///
  1277Ôćĺ    /// This method isn't called automatically by the `log!` macros.
  1278Ôćĺ    /// It can be called manually on shut-down to ensure any in-flight records are flushed.
  1279Ôćĺ    fn flush(&self);
  1280Ôćĺ}

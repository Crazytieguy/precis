  1248‚Üí/// A trait encapsulating the operations required of a logger.
  1249‚Üípub trait Log: Sync + Send {
  1250‚Üí    /// Determines if a log message with the specified metadata would be
  1251‚Üí    /// logged.
  1252‚Üí    ///
  1253‚Üí    /// This is used by the `log_enabled!` macro to allow callers to avoid
  1254‚Üí    /// expensive computation of log message arguments if the message would be
  1255‚Üí    /// discarded anyway.
  1256‚Üí    ///
  1257‚Üí    /// # For implementors
  1258‚Üí    ///
  1259‚Üí    /// This method isn't called automatically by the `log!` macros.
  1260‚Üí    /// It's up to an implementation of the `Log` trait to call `enabled` in its own
  1261‚Üí    /// `log` method implementation to guarantee that filtering is applied.
  1262‚Üí    fn enabled(&self, metadata: &Metadata) -> bool;
  1263‚Üí
  1264‚Üí    /// Logs the `Record`.
  1265‚Üí    ///
  1266‚Üí    /// # For implementors
  1267‚Üí    ///
  1268‚Üí    /// Note that `enabled` is *not* necessarily called before this method.
  1269‚Üí    /// Implementations of `log` should perform all necessary filtering
  1270‚Üí    /// internally.
  1271‚Üí    fn log(&self, record: &Record);
  1272‚Üí
  1273‚Üí    /// Flushes any buffered records.
  1274‚Üí    ///
  1275‚Üí    /// # For implementors
  1276‚Üí    ///
  1277‚Üí    /// This method isn't called automatically by the `log!` macros.
  1278‚Üí    /// It can be called manually on shut-down to ensure any in-flight records are flushed.
  1279‚Üí    fn flush(&self);
  1280‚Üí}

  1261Ôćĺ    /// `log` method implementation to guarantee that filtering is applied.
  1262Ôćĺ    fn enabled(&self, metadata: &Metadata) -> bool;
  1263Ôćĺ
  1264Ôćĺ    /// Logs the `Record`.
  1265Ôćĺ    ///
  1266Ôćĺ    /// # For implementors
  1267Ôćĺ    ///
  1268Ôćĺ    /// Note that `enabled` is *not* necessarily called before this method.
  1269Ôćĺ    /// Implementations of `log` should perform all necessary filtering
  1270Ôćĺ    /// internally.
  1271Ôćĺ    fn log(&self, record: &Record);
  1272Ôćĺ
  1273Ôćĺ    /// Flushes any buffered records.

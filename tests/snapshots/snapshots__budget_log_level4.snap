   359тЖТ/// Determines if a message logged at the specified level in that module will
   360тЖТ/// be logged.
   361тЖТ///
   362тЖТ/// This can be used to avoid expensive computation of log message arguments if
   363тЖТ/// the message would be ignored anyway.
   364тЖТ///
   365тЖТ/// # Examples
   366тЖТ///
   367тЖТ/// ```
   368тЖТ/// use log::{debug, log_enabled, Level};
   369тЖТ///
   370тЖТ/// # struct Data { x: u32, y: u32 }
   371тЖТ/// # fn expensive_call() -> Data { Data { x: 0, y: 0 } }
   372тЖТ/// # let my_logger = log::__private_api::GlobalLogger;
   373тЖТ/// if log_enabled!(Level::Debug) {
   374тЖТ///     let data = expensive_call();
   375тЖТ///     debug!("expensive debug data: {} {}", data.x, data.y);
   376тЖТ/// }
   377тЖТ///
   378тЖТ/// if log_enabled!(target: "Global", Level::Debug) {
   379тЖТ///    let data = expensive_call();
   380тЖТ///    debug!(target: "Global", "expensive debug data: {} {}", data.x, data.y);
   381тЖТ/// }
   382тЖТ///
   383тЖТ/// if log_enabled!(logger: my_logger, Level::Debug) {
   384тЖТ///    let data = expensive_call();
   385тЖТ///    debug!(target: "Global", "expensive debug data: {} {}", data.x, data.y);
   386тЖТ/// }
   387тЖТ/// ```
   388тЖТ///
   389тЖТ/// This macro accepts the same `target` and `logger` arguments as [`macro@log`].
   390тЖТ#[macro_export]
   391тЖТmacro_rules! log_enabled {

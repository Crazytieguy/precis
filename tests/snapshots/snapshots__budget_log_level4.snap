kv/mod.rs
     1тЖТ//! Structured logging.
     2тЖТ//!
     3тЖТ//! Add the `kv` feature to your `Cargo.toml` to enable
     4тЖТ//! this module:
     5тЖТ//!
     6тЖТ//! ```toml
     7тЖТ//! [dependencies.log]
     8тЖТ//! features = ["kv"]
     9тЖТ//! ```
    10тЖТ//!
    11тЖТ//! # Structured logging in `log`
    12тЖТ//!
    13тЖТ//! Structured logging enhances traditional text-based log records with user-defined
    14тЖТ//! attributes. Structured logs can be analyzed using a variety of data processing
    15тЖТ//! techniques, without needing to find and parse attributes from unstructured text first.
    16тЖТ//!
    17тЖТ//! In `log`, user-defined attributes are part of a [`Source`] on the log record.
    18тЖТ//! Each attribute is a key-value; a pair of [`Key`] and [`Value`]. Keys are strings
    19тЖТ//! and values are a datum of any type that can be formatted or serialized. Simple types
    20тЖТ//! like strings, booleans, and numbers are supported, as well as arbitrarily complex
    21тЖТ//! structures involving nested objects and sequences.
    22тЖТ//!
    23тЖТ//! ## Adding key-values to log records
    24тЖТ//!
    25тЖТ//! Key-values appear before the message format in the `log!` macros:
    26тЖТ//!
    27тЖТ//! ```
    28тЖТ//! # use log::info;
    29тЖТ//! info!(a = 1; "Something of interest");
    30тЖТ//! ```
    31тЖТ//!
    32тЖТ//! Key-values support the same shorthand identifier syntax as `format_args`:
    33тЖТ//!
    34тЖТ//! ```
    35тЖТ//! # use log::info;
    36тЖТ//! let a = 1;
    37тЖТ//!
    38тЖТ//! info!(a; "Something of interest");
    39тЖТ//! ```
    40тЖТ//!
    41тЖТ//! Values are capturing using the [`ToValue`] trait by default. To capture a value
    42тЖТ//! using a different trait implementation, use a modifier after its key. Here's how
    43тЖТ//! the same example can capture `a` using its `Debug` implementation instead:
    44тЖТ//!
    45тЖТ//! ```
    46тЖТ//! # use log::info;
    47тЖТ//! info!(a:? = 1; "Something of interest");
    48тЖТ//! ```
    49тЖТ//!
    50тЖТ//! The following capturing modifiers are supported:
    51тЖТ//!
    52тЖТ//! - `:?` will capture the value using `Debug`.
    53тЖТ//! - `:debug` will capture the value using `Debug`.
    54тЖТ//! - `:%` will capture the value using `Display`.
    55тЖТ//! - `:display` will capture the value using `Display`.
    56тЖТ//! - `:err` will capture the value using `std::error::Error` (requires the `kv_std` feature).
    57тЖТ//! - `:sval` will capture the value using `sval::Value` (requires the `kv_sval` feature).
    58тЖТ//! - `:serde` will capture the value using `serde::Serialize` (requires the `kv_serde` feature).
    59тЖТ//!
    60тЖТ//! ## Working with key-values on log records
    61тЖТ//!
    62тЖТ//! Use the [`Record::key_values`](../struct.Record.html#method.key_values) method to access key-values.
    63тЖТ//!
    64тЖТ//! Individual values can be pulled from the source by their key:
    65тЖТ//!
    66тЖТ//! ```
    67тЖТ//! # fn main() -> Result<(), log::kv::Error> {
    68тЖТ//! use log::kv::{Source, Key, Value};
    69тЖТ//! # let record = log::Record::builder().key_values(&[("a", 1)]).build();
    70тЖТ//!
    71тЖТ//! // info!(a = 1; "Something of interest");
    72тЖТ//!
    73тЖТ//! let a: Value = record.key_values().get(Key::from("a")).unwrap();
    74тЖТ//! assert_eq!(1, a.to_i64().unwrap());
    75тЖТ//! # Ok(())
    76тЖТ//! # }
    77тЖТ//! ```
    78тЖТ//!
    79тЖТ//! All key-values can also be enumerated using a [`VisitSource`]:
    80тЖТ//!
    81тЖТ//! ```
    82тЖТ//! # fn main() -> Result<(), log::kv::Error> {
    83тЖТ//! use std::collections::BTreeMap;
    84тЖТ//!
    85тЖТ//! use log::kv::{self, Source, Key, Value, VisitSource};
    86тЖТ//!
    87тЖТ//! struct Collect<'kvs>(BTreeMap<Key<'kvs>, Value<'kvs>>);
    88тЖТ//!
    89тЖТ//! impl<'kvs> VisitSource<'kvs> for Collect<'kvs> {
    90тЖТ//!     fn visit_pair(&mut self, key: Key<'kvs>, value: Value<'kvs>) -> Result<(), kv::Error> {
    91тЖТ//!         self.0.insert(key, value);
    92тЖТ//!
    93тЖТ//!         Ok(())
    94тЖТ//!     }
    95тЖТ//! }
    96тЖТ//!
    97тЖТ//! let mut visitor = Collect(BTreeMap::new());
    98тЖТ//!
    99тЖТ//! # let record = log::Record::builder().key_values(&[("a", 1), ("b", 2), ("c", 3)]).build();
   100тЖТ//! // info!(a = 1, b = 2, c = 3; "Something of interest");
   101тЖТ//!
   102тЖТ//! record.key_values().visit(&mut visitor)?;
   103тЖТ//!
   104тЖТ//! let collected = visitor.0;
   105тЖТ//!
   106тЖТ//! assert_eq!(
   107тЖТ//!     vec!["a", "b", "c"],
   108тЖТ//!     collected
   109тЖТ//!         .keys()
   110тЖТ//!         .map(|k| k.as_str())
   111тЖТ//!         .collect::<Vec<_>>(),
   112тЖТ//! );
   113тЖТ//! # Ok(())
   114тЖТ//! # }
   115тЖТ//! ```
   116тЖТ//!
   117тЖТ//! [`Value`]s have methods for conversions to common types:
   118тЖТ//!
   119тЖТ//! ```
   120тЖТ//! # fn main() -> Result<(), log::kv::Error> {
   121тЖТ//! use log::kv::{Source, Key};
   122тЖТ//! # let record = log::Record::builder().key_values(&[("a", 1)]).build();
   123тЖТ//!
   124тЖТ//! // info!(a = 1; "Something of interest");
   125тЖТ//!
   126тЖТ//! let a = record.key_values().get(Key::from("a")).unwrap();
   127тЖТ//!
   128тЖТ//! assert_eq!(1, a.to_i64().unwrap());
   129тЖТ//! # Ok(())
   130тЖТ//! # }
   131тЖТ//! ```
   132тЖТ//!
   133тЖТ//! Values also have their own [`VisitValue`] type. Value visitors are a lightweight
   134тЖТ//! API for working with primitives types:
   135тЖТ//!
   136тЖТ//! ```
   137тЖТ//! # fn main() -> Result<(), log::kv::Error> {
   138тЖТ//! use log::kv::{self, Source, Key, VisitValue};
   139тЖТ//! # let record = log::Record::builder().key_values(&[("a", 1)]).build();
   140тЖТ//!
   141тЖТ//! struct IsNumeric(bool);
   142тЖТ//!
   143тЖТ//! impl<'kvs> VisitValue<'kvs> for IsNumeric {
   144тЖТ//!     fn visit_any(&mut self, _value: kv::Value) -> Result<(), kv::Error> {
   145тЖТ//!         self.0 = false;
   146тЖТ//!         Ok(())
   147тЖТ//!     }
   148тЖТ//!
   149тЖТ//!     fn visit_u64(&mut self, _value: u64) -> Result<(), kv::Error> {
   150тЖТ//!         self.0 = true;
   151тЖТ//!         Ok(())
   152тЖТ//!     }
   153тЖТ//!
   154тЖТ//!     fn visit_i64(&mut self, _value: i64) -> Result<(), kv::Error> {
   155тЖТ//!         self.0 = true;
   156тЖТ//!         Ok(())
   157тЖТ//!     }
   158тЖТ//!
   159тЖТ//!     fn visit_u128(&mut self, _value: u128) -> Result<(), kv::Error> {
   160тЖТ//!         self.0 = true;
   161тЖТ//!         Ok(())
   162тЖТ//!     }
   163тЖТ//!
   164тЖТ//!     fn visit_i128(&mut self, _value: i128) -> Result<(), kv::Error> {
   165тЖТ//!         self.0 = true;
   166тЖТ//!         Ok(())
   167тЖТ//!     }
   168тЖТ//!
   169тЖТ//!     fn visit_f64(&mut self, _value: f64) -> Result<(), kv::Error> {
   170тЖТ//!         self.0 = true;
   171тЖТ//!         Ok(())
   172тЖТ//!     }
   173тЖТ//! }
   174тЖТ//!
   175тЖТ//! // info!(a = 1; "Something of interest");
   176тЖТ//!
   177тЖТ//! let a = record.key_values().get(Key::from("a")).unwrap();
   178тЖТ//!
   179тЖТ//! let mut visitor = IsNumeric(false);
   180тЖТ//!
   181тЖТ//! a.visit(&mut visitor)?;
   182тЖТ//!
   183тЖТ//! let is_numeric = visitor.0;
   184тЖТ//!
   185тЖТ//! assert!(is_numeric);
   186тЖТ//! # Ok(())
   187тЖТ//! # }
   188тЖТ//! ```
   189тЖТ//!
   190тЖТ//! To serialize a value to a format like JSON, you can also use either `serde` or `sval`:
   191тЖТ//!
   192тЖТ//! ```
   193тЖТ//! # fn main() -> Result<(), Box<dyn std::error::Error>> {
   194тЖТ//! # #[cfg(feature = "kv_serde")]
   195тЖТ//! # {
   196тЖТ//! # use log::kv::Key;
   197тЖТ//! #[derive(serde::Serialize)]
   198тЖТ//! struct Data {
   199тЖТ//!     a: i32, b: bool,
   200тЖТ//!     c: &'static str,
   201тЖТ//! }
   202тЖТ//!
   203тЖТ//! let data = Data { a: 1, b: true, c: "Some data" };
   204тЖТ//!
   205тЖТ//! # let source = [("a", log::kv::Value::from_serde(&data))];
   206тЖТ//! # let record = log::Record::builder().key_values(&source).build();
   207тЖТ//! // info!(a = data; "Something of interest");
   208тЖТ//!
   209тЖТ//! let a = record.key_values().get(Key::from("a")).unwrap();
   210тЖТ//!
   211тЖТ//! assert_eq!("{\"a\":1,\"b\":true,\"c\":\"Some data\"}", serde_json::to_string(&a)?);
   212тЖТ//! # }
   213тЖТ//! # Ok(())
   214тЖТ//! # }
   215тЖТ//! ```
   216тЖТ//!
   217тЖТ//! The choice of serialization framework depends on the needs of the consumer.
   218тЖТ//! If you're in a no-std environment, you can use `sval`. In other cases, you can use `serde`.
   219тЖТ//! Log producers and log consumers don't need to agree on the serialization framework.
   220тЖТ//! A value can be captured using its `serde::Serialize` implementation and still be serialized
   221тЖТ//! through `sval` without losing any structure or data.
   222тЖТ//!
   223тЖТ//! Values can also always be formatted using the standard `Debug` and `Display`
   224тЖТ//! traits:
   225тЖТ//!
   226тЖТ//! ```
   227тЖТ//! # use log::kv::Key;
   228тЖТ//! #[derive(Debug)]
   229тЖТ//! struct Data {
   230тЖТ//!     a: i32,
   231тЖТ//!     b: bool,
   232тЖТ//!     c: &'static str,
   233тЖТ//! }
   234тЖТ//!
   235тЖТ//! let data = Data { a: 1, b: true, c: "Some data" };
   236тЖТ//!
   237тЖТ//! # let source = [("a", log::kv::Value::from_debug(&data))];
   238тЖТ//! # let record = log::Record::builder().key_values(&source).build();
   239тЖТ//! // info!(a = data; "Something of interest");
   240тЖТ//!
   241тЖТ//! let a = record.key_values().get(Key::from("a")).unwrap();
   242тЖТ//!
   243тЖТ//! assert_eq!("Data { a: 1, b: true, c: \"Some data\" }", format!("{a:?}"));
   244тЖТ//! ```
   245тЖТ
   246тЖТmod error;
   247тЖТmod key;
   249тЖТ#[cfg(not(feature = "kv_unstable"))]
   250тЖТmod source;
   251тЖТ#[cfg(not(feature = "kv_unstable"))]
   252тЖТmod value;
   259тЖТ#[cfg(feature = "kv_unstable")]
   260тЖТpub mod source;
   261тЖТ#[cfg(feature = "kv_unstable")]
   262тЖТpub mod value;
kv/source.rs
     9тЖТ/// A source of key-values.
    10тЖТ///
    11тЖТ/// The source may be a single pair, a set of pairs, or a filter over a set of pairs.
    12тЖТ/// Use the [`VisitSource`](trait.VisitSource.html) trait to inspect the structured data
    13тЖТ/// in a source.
    14тЖТ///
    15тЖТ/// A source is like an iterator over its key-values, except with a push-based API
    16тЖТ/// instead of a pull-based one.
    17тЖТ///
    18тЖТ/// # Examples
    19тЖТ///
    20тЖТ/// Enumerating the key-values in a source:
    21тЖТ///
    22тЖТ/// ```
    23тЖТ/// # fn main() -> Result<(), log::kv::Error> {
    24тЖТ/// use log::kv::{self, Source, Key, Value, VisitSource};
    25тЖТ///
    26тЖТ/// // A `VisitSource` that prints all key-values
    27тЖТ/// // VisitSources are fed the key-value pairs of each key-values
    28тЖТ/// struct Printer;
    29тЖТ///
    30тЖТ/// impl<'kvs> VisitSource<'kvs> for Printer {
    31тЖТ///     fn visit_pair(&mut self, key: Key<'kvs>, value: Value<'kvs>) -> Result<(), kv::Error> {
    32тЖТ///         println!("{key}: {value}");
    33тЖТ///
    34тЖТ///         Ok(())
    35тЖТ///     }
    36тЖТ/// }
    37тЖТ///
    38тЖТ/// // A source with 3 key-values
    39тЖТ/// // Common collection types implement the `Source` trait
    40тЖТ/// let source = &[
    41тЖТ///     ("a", 1),
    42тЖТ///     ("b", 2),
    43тЖТ///     ("c", 3),
    44тЖТ/// ];
    45тЖТ///
    46тЖТ/// // Pass an instance of the `VisitSource` to a `Source` to visit it
    47тЖТ/// source.visit(&mut Printer)?;
    48тЖТ/// # Ok(())
    49тЖТ/// # }
    50тЖТ/// ```
    51тЖТpub trait Source {
    52тЖТ    /// Visit key-values.
    53тЖТ    ///
    54тЖТ    /// A source doesn't have to guarantee any ordering or uniqueness of key-values.
    55тЖТ    /// If the given visitor returns an error then the source may early-return with it,
    56тЖТ    /// even if there are more key-values.
    57тЖТ    ///
    58тЖТ    /// # Implementation notes
    59тЖТ    ///
    60тЖТ    /// A source should yield the same key-values to a subsequent visitor unless
    61тЖТ    /// that visitor itself fails.
    62тЖТ    fn visit<'kvs>(&'kvs self, visitor: &mut dyn VisitSource<'kvs>) -> Result<(), Error>;
    64тЖТ    /// Get the value for a given key.

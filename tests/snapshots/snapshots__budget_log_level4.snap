macros.rs
    11тЖТ/// The standard logging macro.
    12тЖТ///
    13тЖТ/// This macro will generically log with the specified `Level` and `format!`
    14тЖТ/// based argument list.
    15тЖТ///
    16тЖТ/// ```
    17тЖТ/// use log::{log, Level};
    18тЖТ///
    19тЖТ/// let data = (42, "Forty-two");
    20тЖТ/// let private_data = "private";
    21тЖТ///
    22тЖТ/// log!(Level::Error, "Received errors: {}, {}", data.0, data.1);
    23тЖТ/// ```
    24тЖТ///
    25тЖТ/// Optionally, you can specify a `target` argument to attach a specific target
    26тЖТ/// to the log record. By default, the target is the module path of the caller.
    27тЖТ///
    28тЖТ/// ```
    29тЖТ/// use log::{log, Level};
    30тЖТ///
    31тЖТ/// let data = (42, "Forty-two");
    32тЖТ/// let private_data = "private";
    33тЖТ///
    34тЖТ/// log!(
    35тЖТ///     target: "app_events",
    36тЖТ///     Level::Error,
    37тЖТ///     "Received errors: {}, {}",
    38тЖТ///     data.0, data.1
    39тЖТ/// );
    40тЖТ/// ```
    41тЖТ///
    42тЖТ/// And optionally, you can specify a `logger` argument to use a specific logger
    43тЖТ/// instead of the default global logger.
    44тЖТ///
    45тЖТ/// ```
    46тЖТ/// # struct MyLogger {}
    47тЖТ/// # impl Log for MyLogger {
    48тЖТ/// #     fn enabled(&self, _metadata: &log::Metadata) -> bool {
    49тЖТ/// #         false
    50тЖТ/// #     }
    51тЖТ/// #     fn log(&self, _record: &log::Record) {}
    52тЖТ/// #     fn flush(&self) {}
    53тЖТ/// # }
    54тЖТ/// use log::{log, Level, Log};
    55тЖТ///
    56тЖТ/// let data = (42, "Forty-two");
    57тЖТ/// let private_data = "private";
    58тЖТ///
    59тЖТ/// let my_logger = MyLogger {};
    60тЖТ/// log!(
    61тЖТ///     logger: my_logger,
    62тЖТ///     Level::Error,
    63тЖТ///     "Received errors: {}, {}",
    64тЖТ///     data.0, data.1
    65тЖТ/// );
    66тЖТ/// ```
    67тЖТ///
    68тЖТ/// The `logger` argument accepts a value that implements the `Log` trait. The value
    69тЖТ/// will be borrowed within the macro.
    70тЖТ///
    71тЖТ/// Note that the global level set via Cargo features, or through `set_max_level` will

   491тЖТ    /// Visit a big signed integer.
   492тЖТ    fn visit_i128(&mut self, value: i128) -> Result<(), Error> {
   496тЖТ    /// Visit a floating point.
   497тЖТ    fn visit_f64(&mut self, value: f64) -> Result<(), Error> {
   501тЖТ    /// Visit a boolean.

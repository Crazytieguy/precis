src/macros.rs
    11‚Üí/// The standard logging macro.
    12‚Üí///
    13‚Üí/// This macro will generically log with the specified `Level` and `format!`
    14‚Üí/// based argument list.
    15‚Üí///
    16‚Üí/// ```
    17‚Üí/// use log::{log, Level};
    18‚Üí///
    19‚Üí/// let data = (42, "Forty-two");
    20‚Üí/// let private_data = "private";
    21‚Üí///
    22‚Üí/// log!(Level::Error, "Received errors: {}, {}", data.0, data.1);
    23‚Üí/// ```
    24‚Üí///
    25‚Üí/// Optionally, you can specify a `target` argument to attach a specific target
    26‚Üí/// to the log record. By default, the target is the module path of the caller.
    27‚Üí///
    28‚Üí/// ```
    29‚Üí/// use log::{log, Level};
    30‚Üí///
    31‚Üí/// let data = (42, "Forty-two");
    32‚Üí/// let private_data = "private";
    33‚Üí///
    34‚Üí/// log!(
    35‚Üí///     target: "app_events",
    36‚Üí///     Level::Error,
    37‚Üí///     "Received errors: {}, {}",
    38‚Üí///     data.0, data.1
    39‚Üí/// );
    40‚Üí/// ```
    41‚Üí///
    42‚Üí/// And optionally, you can specify a `logger` argument to use a specific logger
    43‚Üí/// instead of the default global logger.
    44‚Üí///
    45‚Üí/// ```
    46‚Üí/// # struct MyLogger {}
    47‚Üí/// # impl Log for MyLogger {
    48‚Üí/// #     fn enabled(&self, _metadata: &log::Metadata) -> bool {
    49‚Üí/// #         false
    50‚Üí/// #     }
    51‚Üí/// #     fn log(&self, _record: &log::Record) {}
    52‚Üí/// #     fn flush(&self) {}
    53‚Üí/// # }
    54‚Üí/// use log::{log, Level, Log};
    55‚Üí///
    56‚Üí/// let data = (42, "Forty-two");
    57‚Üí/// let private_data = "private";
    58‚Üí///
    59‚Üí/// let my_logger = MyLogger {};
    60‚Üí/// log!(
    61‚Üí///     logger: my_logger,
    62‚Üí///     Level::Error,
    63‚Üí///     "Received errors: {}, {}",
    64‚Üí///     data.0, data.1
    65‚Üí/// );
    66‚Üí/// ```
    67‚Üí///
    68‚Üí/// The `logger` argument accepts a value that implements the `Log` trait. The value
    69‚Üí/// will be borrowed within the macro.
    70‚Üí///
    71‚Üí/// Note that the global level set via Cargo features, or through `set_max_level` will
    72‚Üí/// still apply, even when a custom logger is supplied with the `logger` argument.
    73‚Üí#[macro_export]
    74‚Üí#[clippy::format_args]
    75‚Üímacro_rules! log {

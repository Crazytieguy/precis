   359â†’/// Determines if a message logged at the specified level in that module will
   360â†’/// be logged.
   361â†’///
   362â†’/// This can be used to avoid expensive computation of log message arguments if
   363â†’/// the message would be ignored anyway.
   364â†’///
   365â†’/// # Examples
   366â†’///
   367â†’/// ```
   368â†’/// use log::{debug, log_enabled, Level};
   369â†’///
   370â†’/// # struct Data { x: u32, y: u32 }
   371â†’/// # fn expensive_call() -> Data { Data { x: 0, y: 0 } }
   372â†’/// # let my_logger = log::__private_api::GlobalLogger;
   373â†’/// if log_enabled!(Level::Debug) {
   374â†’///     let data = expensive_call();
   375â†’///     debug!("expensive debug data: {} {}", data.x, data.y);
   376â†’/// }
   377â†’///
   378â†’/// if log_enabled!(target: "Global", Level::Debug) {
   379â†’///    let data = expensive_call();
   380â†’///    debug!(target: "Global", "expensive debug data: {} {}", data.x, data.y);
   381â†’/// }
   382â†’///
   383â†’/// if log_enabled!(logger: my_logger, Level::Debug) {
   384â†’///    let data = expensive_call();
   385â†’///    debug!(target: "Global", "expensive debug data: {} {}", data.x, data.y);
   386â†’/// }
   387â†’/// ```
   388â†’///
   389â†’/// This macro accepts the same `target` and `logger` arguments as [`macro@log`].
   390â†’#[macro_export]
   391â†’macro_rules! log_enabled {

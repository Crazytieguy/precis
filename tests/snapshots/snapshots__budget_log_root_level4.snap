src/kv/mod.rs
     1â†’//! Structured logging.
     2â†’//!
     3â†’//! Add the `kv` feature to your `Cargo.toml` to enable
     4â†’//! this module:
     5â†’//!
     6â†’//! ```toml
     7â†’//! [dependencies.log]
     8â†’//! features = ["kv"]
     9â†’//! ```
    10â†’//!
    11â†’//! # Structured logging in `log`
    12â†’//!
    13â†’//! Structured logging enhances traditional text-based log records with user-defined
    14â†’//! attributes. Structured logs can be analyzed using a variety of data processing
    15â†’//! techniques, without needing to find and parse attributes from unstructured text first.
    16â†’//!
    17â†’//! In `log`, user-defined attributes are part of a [`Source`] on the log record.
    18â†’//! Each attribute is a key-value; a pair of [`Key`] and [`Value`]. Keys are strings
    19â†’//! and values are a datum of any type that can be formatted or serialized. Simple types
    20â†’//! like strings, booleans, and numbers are supported, as well as arbitrarily complex
    21â†’//! structures involving nested objects and sequences.
    22â†’//!
    23â†’//! ## Adding key-values to log records
    24â†’//!
    25â†’//! Key-values appear before the message format in the `log!` macros:
    26â†’//!
    27â†’//! ```
    28â†’//! # use log::info;
    29â†’//! info!(a = 1; "Something of interest");
    30â†’//! ```
    31â†’//!
    32â†’//! Key-values support the same shorthand identifier syntax as `format_args`:
    33â†’//!
    34â†’//! ```
    35â†’//! # use log::info;
    36â†’//! let a = 1;
    37â†’//!
    38â†’//! info!(a; "Something of interest");
    39â†’//! ```
    40â†’//!
    41â†’//! Values are capturing using the [`ToValue`] trait by default. To capture a value
    42â†’//! using a different trait implementation, use a modifier after its key. Here's how
    43â†’//! the same example can capture `a` using its `Debug` implementation instead:
    44â†’//!
    45â†’//! ```
    46â†’//! # use log::info;
    47â†’//! info!(a:? = 1; "Something of interest");
    48â†’//! ```
    49â†’//!
    50â†’//! The following capturing modifiers are supported:
    51â†’//!
    52â†’//! - `:?` will capture the value using `Debug`.
    53â†’//! - `:debug` will capture the value using `Debug`.
    54â†’//! - `:%` will capture the value using `Display`.
    55â†’//! - `:display` will capture the value using `Display`.
    56â†’//! - `:err` will capture the value using `std::error::Error` (requires the `kv_std` feature).
    57â†’//! - `:sval` will capture the value using `sval::Value` (requires the `kv_sval` feature).
    58â†’//! - `:serde` will capture the value using `serde::Serialize` (requires the `kv_serde` feature).
    59â†’//!
    60â†’//! ## Working with key-values on log records
    61â†’//!
    62â†’//! Use the [`Record::key_values`](../struct.Record.html#method.key_values) method to access key-values.
    63â†’//!
    64â†’//! Individual values can be pulled from the source by their key:
    65â†’//!
    66â†’//! ```
    67â†’//! # fn main() -> Result<(), log::kv::Error> {
    68â†’//! use log::kv::{Source, Key, Value};
    69â†’//! # let record = log::Record::builder().key_values(&[("a", 1)]).build();
    70â†’//!
    71â†’//! // info!(a = 1; "Something of interest");
    72â†’//!
    73â†’//! let a: Value = record.key_values().get(Key::from("a")).unwrap();
    74â†’//! assert_eq!(1, a.to_i64().unwrap());
    75â†’//! # Ok(())
    76â†’//! # }
    77â†’//! ```
    78â†’//!
    79â†’//! All key-values can also be enumerated using a [`VisitSource`]:
    80â†’//!
    81â†’//! ```
    82â†’//! # fn main() -> Result<(), log::kv::Error> {
    83â†’//! use std::collections::BTreeMap;
    84â†’//!
    85â†’//! use log::kv::{self, Source, Key, Value, VisitSource};
    86â†’//!
    87â†’//! struct Collect<'kvs>(BTreeMap<Key<'kvs>, Value<'kvs>>);
    88â†’//!
    89â†’//! impl<'kvs> VisitSource<'kvs> for Collect<'kvs> {
    90â†’//!     fn visit_pair(&mut self, key: Key<'kvs>, value: Value<'kvs>) -> Result<(), kv::Error> {
    91â†’//!         self.0.insert(key, value);
    92â†’//!
    93â†’//!         Ok(())
    94â†’//!     }
    95â†’//! }
    96â†’//!
    97â†’//! let mut visitor = Collect(BTreeMap::new());
    98â†’//!
    99â†’//! # let record = log::Record::builder().key_values(&[("a", 1), ("b", 2), ("c", 3)]).build();
   100â†’//! // info!(a = 1, b = 2, c = 3; "Something of interest");
   101â†’//!
   102â†’//! record.key_values().visit(&mut visitor)?;
   103â†’//!
   104â†’//! let collected = visitor.0;
   105â†’//!
   106â†’//! assert_eq!(
   107â†’//!     vec!["a", "b", "c"],
   108â†’//!     collected
   109â†’//!         .keys()
   110â†’//!         .map(|k| k.as_str())
   111â†’//!         .collect::<Vec<_>>(),
   112â†’//! );
   113â†’//! # Ok(())
   114â†’//! # }
   115â†’//! ```
   116â†’//!
   117â†’//! [`Value`]s have methods for conversions to common types:
   118â†’//!
   119â†’//! ```
   120â†’//! # fn main() -> Result<(), log::kv::Error> {
   121â†’//! use log::kv::{Source, Key};
   122â†’//! # let record = log::Record::builder().key_values(&[("a", 1)]).build();
   123â†’//!
   124â†’//! // info!(a = 1; "Something of interest");
   125â†’//!
   126â†’//! let a = record.key_values().get(Key::from("a")).unwrap();
   127â†’//!
   128â†’//! assert_eq!(1, a.to_i64().unwrap());
   129â†’//! # Ok(())
   130â†’//! # }
   131â†’//! ```
   132â†’//!
   133â†’//! Values also have their own [`VisitValue`] type. Value visitors are a lightweight
   134â†’//! API for working with primitives types:
   135â†’//!
   136â†’//! ```
   137â†’//! # fn main() -> Result<(), log::kv::Error> {
   138â†’//! use log::kv::{self, Source, Key, VisitValue};
   139â†’//! # let record = log::Record::builder().key_values(&[("a", 1)]).build();
   140â†’//!
   141â†’//! struct IsNumeric(bool);
   142â†’//!
   143â†’//! impl<'kvs> VisitValue<'kvs> for IsNumeric {
   144â†’//!     fn visit_any(&mut self, _value: kv::Value) -> Result<(), kv::Error> {
   145â†’//!         self.0 = false;
   146â†’//!         Ok(())
   147â†’//!     }
   148â†’//!
   149â†’//!     fn visit_u64(&mut self, _value: u64) -> Result<(), kv::Error> {
   150â†’//!         self.0 = true;
   151â†’//!         Ok(())
   152â†’//!     }
   153â†’//!
   154â†’//!     fn visit_i64(&mut self, _value: i64) -> Result<(), kv::Error> {
   155â†’//!         self.0 = true;
   156â†’//!         Ok(())
   157â†’//!     }
   158â†’//!
   159â†’//!     fn visit_u128(&mut self, _value: u128) -> Result<(), kv::Error> {
   160â†’//!         self.0 = true;
   161â†’//!         Ok(())
   162â†’//!     }
   163â†’//!
   164â†’//!     fn visit_i128(&mut self, _value: i128) -> Result<(), kv::Error> {
   165â†’//!         self.0 = true;
   166â†’//!         Ok(())
   167â†’//!     }
   168â†’//!
   169â†’//!     fn visit_f64(&mut self, _value: f64) -> Result<(), kv::Error> {
   170â†’//!         self.0 = true;
   171â†’//!         Ok(())
   172â†’//!     }
   173â†’//! }
   174â†’//!
   175â†’//! // info!(a = 1; "Something of interest");
   176â†’//!
   177â†’//! let a = record.key_values().get(Key::from("a")).unwrap();
   178â†’//!
   179â†’//! let mut visitor = IsNumeric(false);
   180â†’//!
   181â†’//! a.visit(&mut visitor)?;
   182â†’//!
   183â†’//! let is_numeric = visitor.0;
   184â†’//!
   185â†’//! assert!(is_numeric);
   186â†’//! # Ok(())
   187â†’//! # }
   188â†’//! ```
   189â†’//!
   190â†’//! To serialize a value to a format like JSON, you can also use either `serde` or `sval`:
   191â†’//!
   192â†’//! ```
   193â†’//! # fn main() -> Result<(), Box<dyn std::error::Error>> {
   194â†’//! # #[cfg(feature = "kv_serde")]
   195â†’//! # {
   196â†’//! # use log::kv::Key;
   197â†’//! #[derive(serde::Serialize)]
   198â†’//! struct Data {
   199â†’//!     a: i32, b: bool,
   200â†’//!     c: &'static str,
   201â†’//! }
   202â†’//!
   203â†’//! let data = Data { a: 1, b: true, c: "Some data" };
   204â†’//!
   205â†’//! # let source = [("a", log::kv::Value::from_serde(&data))];
   206â†’//! # let record = log::Record::builder().key_values(&source).build();
   207â†’//! // info!(a = data; "Something of interest");
   208â†’//!
   209â†’//! let a = record.key_values().get(Key::from("a")).unwrap();
   210â†’//!
   211â†’//! assert_eq!("{\"a\":1,\"b\":true,\"c\":\"Some data\"}", serde_json::to_string(&a)?);
   212â†’//! # }
   213â†’//! # Ok(())
   214â†’//! # }
   215â†’//! ```
   216â†’//!
   217â†’//! The choice of serialization framework depends on the needs of the consumer.
   218â†’//! If you're in a no-std environment, you can use `sval`. In other cases, you can use `serde`.
   219â†’//! Log producers and log consumers don't need to agree on the serialization framework.
   220â†’//! A value can be captured using its `serde::Serialize` implementation and still be serialized
   221â†’//! through `sval` without losing any structure or data.
   222â†’//!
   223â†’//! Values can also always be formatted using the standard `Debug` and `Display`
   224â†’//! traits:
   225â†’//!
   226â†’//! ```
   227â†’//! # use log::kv::Key;
   228â†’//! #[derive(Debug)]
   229â†’//! struct Data {
   230â†’//!     a: i32,
   231â†’//!     b: bool,
   232â†’//!     c: &'static str,
   233â†’//! }
   234â†’//!
   235â†’//! let data = Data { a: 1, b: true, c: "Some data" };
   236â†’//!
   237â†’//! # let source = [("a", log::kv::Value::from_debug(&data))];
   238â†’//! # let record = log::Record::builder().key_values(&source).build();
   239â†’//! // info!(a = data; "Something of interest");
   240â†’//!
   241â†’//! let a = record.key_values().get(Key::from("a")).unwrap();
   242â†’//!
   243â†’//! assert_eq!("Data { a: 1, b: true, c: \"Some data\" }", format!("{a:?}"));
   244â†’//! ```
   245â†’

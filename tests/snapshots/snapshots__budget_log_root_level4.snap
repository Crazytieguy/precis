src/macros.rs
    11â†’/// The standard logging macro.
    12â†’///
    13â†’/// This macro will generically log with the specified `Level` and `format!`
    14â†’/// based argument list.
    15â†’///
    16â†’/// ```
    17â†’/// use log::{log, Level};
    18â†’///
    19â†’/// let data = (42, "Forty-two");
    20â†’/// let private_data = "private";
    21â†’///
    22â†’/// log!(Level::Error, "Received errors: {}, {}", data.0, data.1);
    23â†’/// ```
    24â†’///
    25â†’/// Optionally, you can specify a `target` argument to attach a specific target
    26â†’/// to the log record. By default, the target is the module path of the caller.
    27â†’///
    28â†’/// ```
    29â†’/// use log::{log, Level};
    30â†’///
    31â†’/// let data = (42, "Forty-two");
    32â†’/// let private_data = "private";
    33â†’///
    34â†’/// log!(
    35â†’///     target: "app_events",
    36â†’///     Level::Error,
    37â†’///     "Received errors: {}, {}",
    38â†’///     data.0, data.1
    39â†’/// );
    40â†’/// ```
    41â†’///
    42â†’/// And optionally, you can specify a `logger` argument to use a specific logger
    43â†’/// instead of the default global logger.
    44â†’///
    45â†’/// ```
    46â†’/// # struct MyLogger {}
    47â†’/// # impl Log for MyLogger {
    48â†’/// #     fn enabled(&self, _metadata: &log::Metadata) -> bool {
    49â†’/// #         false
    50â†’/// #     }
    51â†’/// #     fn log(&self, _record: &log::Record) {}
    52â†’/// #     fn flush(&self) {}
    53â†’/// # }
    54â†’/// use log::{log, Level, Log};
    55â†’///
    56â†’/// let data = (42, "Forty-two");
    57â†’/// let private_data = "private";
    58â†’///
    59â†’/// let my_logger = MyLogger {};
    60â†’/// log!(
    61â†’///     logger: my_logger,
    62â†’///     Level::Error,
    63â†’///     "Received errors: {}, {}",
    64â†’///     data.0, data.1
    65â†’/// );
    66â†’/// ```
    67â†’///
    68â†’/// The `logger` argument accepts a value that implements the `Log` trait. The value
    69â†’/// will be borrowed within the macro.
    70â†’///
    71â†’/// Note that the global level set via Cargo features, or through `set_max_level` will
    72â†’/// still apply, even when a custom logger is supplied with the `logger` argument.
    73â†’#[macro_export]
    74â†’#[clippy::format_args]
    75â†’macro_rules! log {

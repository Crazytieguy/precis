   450‚Üí/// A visitor for a [`Value`].
   451‚Üí///
   452‚Üí/// Also see [`Value`'s documentation on serialization]. Value visitors are a simple alternative
   453‚Üí/// to a more fully-featured serialization framework like `serde` or `sval`. A value visitor
   454‚Üí/// can differentiate primitive types through methods like [`VisitValue::visit_bool`] and
   455‚Üí/// [`VisitValue::visit_str`], but more complex types like maps and sequences
   456‚Üí/// will fallthrough to [`VisitValue::visit_any`].
   457‚Üí///
   458‚Üí/// If you're trying to serialize a value to a format like JSON, you can use either `serde`
   459‚Üí/// or `sval` directly with the value. You don't need a visitor.
   460‚Üí///
   461‚Üí/// [`Value`'s documentation on serialization]: Value#serialization
   462‚Üípub trait VisitValue<'v> {
   463‚Üí    /// Visit a `Value`.
   464‚Üí    ///
   465‚Üí    /// This is the only required method on `VisitValue` and acts as a fallback for any
   466‚Üí    /// more specific methods that aren't overridden.
   467‚Üí    /// The `Value` may be formatted using its `fmt::Debug` or `fmt::Display` implementation,
   468‚Üí    /// or serialized using its `sval::Value` or `serde::Serialize` implementation.
   469‚Üí    fn visit_any(&mut self, value: Value) -> Result<(), Error>;
   470‚Üí
   471‚Üí    /// Visit an empty value.
   472‚Üí    fn visit_null(&mut self) -> Result<(), Error> {
   473‚Üí        self.visit_any(Value::null())
   474‚Üí    }
   475‚Üí
   476‚Üí    /// Visit an unsigned integer.
   477‚Üí    fn visit_u64(&mut self, value: u64) -> Result<(), Error> {
   478‚Üí        self.visit_any(value.into())
   479‚Üí    }
   480‚Üí
   481‚Üí    /// Visit a signed integer.
   482‚Üí    fn visit_i64(&mut self, value: i64) -> Result<(), Error> {
   483‚Üí        self.visit_any(value.into())
   484‚Üí    }
   485‚Üí
   486‚Üí    /// Visit a big unsigned integer.
   487‚Üí    fn visit_u128(&mut self, value: u128) -> Result<(), Error> {
   488‚Üí        self.visit_any((value).into())
   489‚Üí    }
   490‚Üí
   491‚Üí    /// Visit a big signed integer.
   492‚Üí    fn visit_i128(&mut self, value: i128) -> Result<(), Error> {
   493‚Üí        self.visit_any((value).into())
   494‚Üí    }
   495‚Üí
   496‚Üí    /// Visit a floating point.
   497‚Üí    fn visit_f64(&mut self, value: f64) -> Result<(), Error> {
   498‚Üí        self.visit_any(value.into())
   499‚Üí    }
   500‚Üí
   501‚Üí    /// Visit a boolean.
   502‚Üí    fn visit_bool(&mut self, value: bool) -> Result<(), Error> {
   503‚Üí        self.visit_any(value.into())
   504‚Üí    }
   505‚Üí
   506‚Üí    /// Visit a string.
   507‚Üí    fn visit_str(&mut self, value: &str) -> Result<(), Error> {
   508‚Üí        self.visit_any(value.into())
   509‚Üí    }
   510‚Üí
   511‚Üí    /// Visit a string.
   512‚Üí    fn visit_borrowed_str(&mut self, value: &'v str) -> Result<(), Error> {
   513‚Üí        self.visit_str(value)
   514‚Üí    }
   515‚Üí
   516‚Üí    /// Visit a Unicode character.
   517‚Üí    fn visit_char(&mut self, value: char) -> Result<(), Error> {
   518‚Üí        let mut b = [0; 4];
   519‚Üí        self.visit_str(&*value.encode_utf8(&mut b))
   520‚Üí    }
   521‚Üí
   522‚Üí    /// Visit an error.
   523‚Üí    #[cfg(feature = "kv_std")]
   524‚Üí    fn visit_error(&mut self, err: &(dyn std::error::Error + 'static)) -> Result<(), Error> {
   525‚Üí        self.visit_any(Value::from_dyn_error(err))
   526‚Üí    }
   527‚Üí
   528‚Üí    /// Visit an error.
   529‚Üí    #[cfg(feature = "kv_std")]
   530‚Üí    fn visit_borrowed_error(

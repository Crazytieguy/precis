  1602‚Üí/// The statically resolved maximum log level.
  1603‚Üí///
  1604‚Üí/// See the crate level documentation for information on how to configure this.
  1605‚Üí///
  1606‚Üí/// This value is checked by the log macros, but not by the `Log`ger returned by
  1607‚Üí/// the [`logger`] function. Code that manually calls functions on that value
  1608‚Üí/// should compare the level against this value.
  1609‚Üí///
  1610‚Üí/// [`logger`]: fn.logger.html
  1611‚Üípub const STATIC_MAX_LEVEL: LevelFilter = match cfg!(debug_assertions) {
  1612‚Üí    false if cfg!(feature = "release_max_level_off") => LevelFilter::Off,
  1613‚Üí    false if cfg!(feature = "release_max_level_error") => LevelFilter::Error,
  1614‚Üí    false if cfg!(feature = "release_max_level_warn") => LevelFilter::Warn,
  1615‚Üí    false if cfg!(feature = "release_max_level_info") => LevelFilter::Info,
  1616‚Üí    false if cfg!(feature = "release_max_level_debug") => LevelFilter::Debug,
  1617‚Üí    false if cfg!(feature = "release_max_level_trace") => LevelFilter::Trace,
  1618‚Üí    _ if cfg!(feature = "max_level_off") => LevelFilter::Off,
  1619‚Üí    _ if cfg!(feature = "max_level_error") => LevelFilter::Error,
  1620‚Üí    _ if cfg!(feature = "max_level_warn") => LevelFilter::Warn,
  1621‚Üí    _ if cfg!(feature = "max_level_info") => LevelFilter::Info,
  1622‚Üí    _ if cfg!(feature = "max_level_debug") => LevelFilter::Debug,
  1623‚Üí    _ => LevelFilter::Trace,
  1624‚Üí};

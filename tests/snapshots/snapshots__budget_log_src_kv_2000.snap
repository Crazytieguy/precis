    12‚Üí/// Use the [`VisitSource`](trait.VisitSource.html) trait to inspect the structured data
    13‚Üí/// in a source.
    14‚Üí///
    15‚Üí/// A source is like an iterator over its key-values, except with a push-based API
    16‚Üí/// instead of a pull-based one.
    17‚Üí///
    18‚Üí/// # Examples
    19‚Üí///
    20‚Üí/// Enumerating the key-values in a source:
    21‚Üí///
    22‚Üí/// ```
    23‚Üí/// # fn main() -> Result<(), log::kv::Error> {
    24‚Üí/// use log::kv::{self, Source, Key, Value, VisitSource};
    25‚Üí///
    26‚Üí/// // A `VisitSource` that prints all key-values
    27‚Üí/// // VisitSources are fed the key-value pairs of each key-values
    28‚Üí/// struct Printer;

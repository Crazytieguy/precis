     9â†’/// A source of key-values.
    10â†’///
    11â†’/// The source may be a single pair, a set of pairs, or a filter over a set of pairs.
    12â†’/// Use the [`VisitSource`](trait.VisitSource.html) trait to inspect the structured data
    13â†’/// in a source.
    14â†’///
    15â†’/// A source is like an iterator over its key-values, except with a push-based API
    16â†’/// instead of a pull-based one.
    17â†’///
    18â†’/// # Examples
    19â†’///
    20â†’/// Enumerating the key-values in a source:
    21â†’///
    22â†’/// ```
    23â†’/// # fn main() -> Result<(), log::kv::Error> {
    24â†’/// use log::kv::{self, Source, Key, Value, VisitSource};
    25â†’///
    26â†’/// // A `VisitSource` that prints all key-values
    27â†’/// // VisitSources are fed the key-value pairs of each key-values
    28â†’/// struct Printer;
    29â†’///
    30â†’/// impl<'kvs> VisitSource<'kvs> for Printer {
    31â†’///     fn visit_pair(&mut self, key: Key<'kvs>, value: Value<'kvs>) -> Result<(), kv::Error> {
    32â†’///         println!("{key}: {value}");
    33â†’///
    34â†’///         Ok(())
    35â†’///     }
    36â†’/// }
    37â†’///
    38â†’/// // A source with 3 key-values
    39â†’/// // Common collection types implement the `Source` trait
    40â†’/// let source = &[
    41â†’///     ("a", 1),
    42â†’///     ("b", 2),
    43â†’///     ("c", 3),
    44â†’/// ];
    45â†’///
    46â†’/// // Pass an instance of the `VisitSource` to a `Source` to visit it
    47â†’/// source.visit(&mut Printer)?;
    48â†’/// # Ok(())
    49â†’/// # }
    50â†’/// ```
    51â†’pub trait Source {
    52â†’    /// Visit key-values.
    53â†’    ///
    54â†’    /// A source doesn't have to guarantee any ordering or uniqueness of key-values.
    55â†’    /// If the given visitor returns an error then the source may early-return with it,
    56â†’    /// even if there are more key-values.
    57â†’    ///
    58â†’    /// # Implementation notes
    59â†’    ///
    60â†’    /// A source should yield the same key-values to a subsequent visitor unless
    61â†’    /// that visitor itself fails.
    62â†’    fn visit<'kvs>(&'kvs self, visitor: &mut dyn VisitSource<'kvs>) -> Result<(), Error>;
    63â†’
    64â†’    /// Get the value for a given key.
    65â†’    ///
    66â†’    /// If the key appears multiple times in the source then which key is returned
    67â†’    /// is implementation specific.
    68â†’    ///
    69â†’    /// # Implementation notes
    70â†’    ///
    71â†’    /// A source that can provide a more efficient implementation of this method
    72â†’    /// should override it.
    73â†’    fn get(&self, key: Key) -> Option<Value<'_>> {
    74â†’        get_default(self, key)
    75â†’    }
    76â†’
    77â†’    /// Count the number of key-values that can be visited.
    78â†’    ///
    79â†’    /// # Implementation notes
    80â†’    ///
    81â†’    /// A source that knows the number of key-values upfront may provide a more
    82â†’    /// efficient implementation.
    83â†’    ///
    84â†’    /// A subsequent call to `visit` should yield the same number of key-values.
    85â†’    fn count(&self) -> usize {
    86â†’        count_default(self)
    87â†’    }
    88â†’}

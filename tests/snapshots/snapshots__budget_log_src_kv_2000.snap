    33â†’/// A value in a key-value.
    34â†’///
    35â†’/// Values are an anonymous bag containing some structured datum.
    36â†’///
    37â†’/// # Capturing values
    38â†’///
    39â†’/// There are a few ways to capture a value:
    40â†’///
    41â†’/// - Using the `Value::from_*` methods.
    42â†’/// - Using the `ToValue` trait.
    43â†’/// - Using the standard `From` trait.
    44â†’///
    45â†’/// ## Using the `Value::from_*` methods
    46â†’///
    47â†’/// `Value` offers a few constructor methods that capture values of different kinds.
    48â†’///
    49â†’/// ```
    50â†’/// use log::kv::Value;
    51â†’///
    52â†’/// let value = Value::from_debug(&42i32);
    53â†’///
    54â†’/// assert_eq!(None, value.to_i64());
    55â†’/// ```
    56â†’///
    57â†’/// ## Using the `ToValue` trait
    58â†’///
    59â†’/// The `ToValue` trait can be used to capture values generically.
    60â†’/// It's the bound used by `Source`.
    61â†’///
    62â†’/// ```
    63â†’/// # use log::kv::ToValue;
    64â†’/// let value = 42i32.to_value();
    65â†’///
    66â†’/// assert_eq!(Some(42), value.to_i64());
    67â†’/// ```
    68â†’///
    69â†’/// ## Using the standard `From` trait
    70â†’///
    71â†’/// Standard types that implement `ToValue` also implement `From`.
    72â†’///
    73â†’/// ```
    74â†’/// use log::kv::Value;
    75â†’///
    76â†’/// let value = Value::from(42i32);
    77â†’///
    78â†’/// assert_eq!(Some(42), value.to_i64());
    79â†’/// ```
    80â†’///
    81â†’/// # Data model
    82â†’///

   450â†’/// A visitor for a [`Value`].
   451â†’///
   452â†’/// Also see [`Value`'s documentation on serialization]. Value visitors are a simple alternative
   453â†’/// to a more fully-featured serialization framework like `serde` or `sval`. A value visitor
   454â†’/// can differentiate primitive types through methods like [`VisitValue::visit_bool`] and
   455â†’/// [`VisitValue::visit_str`], but more complex types like maps and sequences
   456â†’/// will fallthrough to [`VisitValue::visit_any`].
   457â†’///
   458â†’/// If you're trying to serialize a value to a format like JSON, you can use either `serde`
   459â†’/// or `sval` directly with the value. You don't need a visitor.
   460â†’///
   461â†’/// [`Value`'s documentation on serialization]: Value#serialization
   462â†’pub trait VisitValue<'v> {
   463â†’    /// Visit a `Value`.
   464â†’    ///
   465â†’    /// This is the only required method on `VisitValue` and acts as a fallback for any
   466â†’    /// more specific methods that aren't overridden.
   467â†’    /// The `Value` may be formatted using its `fmt::Debug` or `fmt::Display` implementation,
   468â†’    /// or serialized using its `sval::Value` or `serde::Serialize` implementation.
   469â†’    fn visit_any(&mut self, value: Value) -> Result<(), Error>;
   470â†’
   471â†’    /// Visit an empty value.
   472â†’    fn visit_null(&mut self) -> Result<(), Error> {
   473â†’        self.visit_any(Value::null())
   474â†’    }
   475â†’
   476â†’    /// Visit an unsigned integer.
   477â†’    fn visit_u64(&mut self, value: u64) -> Result<(), Error> {
   478â†’        self.visit_any(value.into())
   479â†’    }
   480â†’
   481â†’    /// Visit a signed integer.
   482â†’    fn visit_i64(&mut self, value: i64) -> Result<(), Error> {
   483â†’        self.visit_any(value.into())
   484â†’    }
   485â†’
   486â†’    /// Visit a big unsigned integer.
   487â†’    fn visit_u128(&mut self, value: u128) -> Result<(), Error> {
   488â†’        self.visit_any((value).into())
   489â†’    }
   490â†’
   491â†’    /// Visit a big signed integer.
   492â†’    fn visit_i128(&mut self, value: i128) -> Result<(), Error> {
   493â†’        self.visit_any((value).into())
   494â†’    }
   495â†’
   496â†’    /// Visit a floating point.
   497â†’    fn visit_f64(&mut self, value: f64) -> Result<(), Error> {
   498â†’        self.visit_any(value.into())
   499â†’    }
   500â†’
   501â†’    /// Visit a boolean.
   502â†’    fn visit_bool(&mut self, value: bool) -> Result<(), Error> {
   503â†’        self.visit_any(value.into())
   504â†’    }
   505â†’
   506â†’    /// Visit a string.
   507â†’    fn visit_str(&mut self, value: &str) -> Result<(), Error> {
   508â†’        self.visit_any(value.into())
   509â†’    }
   510â†’
   511â†’    /// Visit a string.
   512â†’    fn visit_borrowed_str(&mut self, value: &'v str) -> Result<(), Error> {
   513â†’        self.visit_str(value)
   514â†’    }
   515â†’
   516â†’    /// Visit a Unicode character.
   517â†’    fn visit_char(&mut self, value: char) -> Result<(), Error> {
   518â†’        let mut b = [0; 4];
   519â†’        self.visit_str(&*value.encode_utf8(&mut b))
   520â†’    }
   521â†’
   522â†’    /// Visit an error.
   523â†’    #[cfg(feature = "kv_std")]
   524â†’    fn visit_error(&mut self, err: &(dyn std::error::Error + 'static)) -> Result<(), Error> {
   525â†’        self.visit_any(Value::from_dyn_error(err))
   526â†’    }
   527â†’
   528â†’    /// Visit an error.
   529â†’    #[cfg(feature = "kv_std")]
   530â†’    fn visit_borrowed_error(
   531â†’        &mut self,
   532â†’        err: &'v (dyn std::error::Error + 'static),
   533â†’    ) -> Result<(), Error> {
   534â†’        self.visit_any(Value::from_dyn_error(err))
   535â†’    }
   536â†’}

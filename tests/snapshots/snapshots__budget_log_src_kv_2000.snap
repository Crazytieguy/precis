    30‚Üí/// impl<'kvs> VisitSource<'kvs> for Printer {
    31‚Üí///     fn visit_pair(&mut self, key: Key<'kvs>, value: Value<'kvs>) -> Result<(), kv::Error> {
    32‚Üí///         println!("{key}: {value}");
    33‚Üí///
    34‚Üí///         Ok(())
    35‚Üí///     }
    36‚Üí/// }
    37‚Üí///

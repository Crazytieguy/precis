source.rs
     9‚Üí/// A source of key-values.
    10‚Üí///
    11‚Üí/// The source may be a single pair, a set of pairs, or a filter over a set of pairs.
    12‚Üí/// Use the [`VisitSource`](trait.VisitSource.html) trait to inspect the structured data
    13‚Üí/// in a source.
    14‚Üí///
    15‚Üí/// A source is like an iterator over its key-values, except with a push-based API
    16‚Üí/// instead of a pull-based one.
    17‚Üí///
    18‚Üí/// # Examples
    19‚Üí///
    20‚Üí/// Enumerating the key-values in a source:
    21‚Üí///
    22‚Üí/// ```
    23‚Üí/// # fn main() -> Result<(), log::kv::Error> {
    24‚Üí/// use log::kv::{self, Source, Key, Value, VisitSource};
    25‚Üí///
    26‚Üí/// // A `VisitSource` that prints all key-values
    27‚Üí/// // VisitSources are fed the key-value pairs of each key-values
    28‚Üí/// struct Printer;
    29‚Üí///
    30‚Üí/// impl<'kvs> VisitSource<'kvs> for Printer {
    31‚Üí///     fn visit_pair(&mut self, key: Key<'kvs>, value: Value<'kvs>) -> Result<(), kv::Error> {
    32‚Üí///         println!("{key}: {value}");
    33‚Üí///
    34‚Üí///         Ok(())
    35‚Üí///     }
    36‚Üí/// }
    37‚Üí///
    38‚Üí/// // A source with 3 key-values
    39‚Üí/// // Common collection types implement the `Source` trait
    40‚Üí/// let source = &[
    41‚Üí///     ("a", 1),
    42‚Üí///     ("b", 2),
    43‚Üí///     ("c", 3),
    44‚Üí/// ];
    45‚Üí///
    46‚Üí/// // Pass an instance of the `VisitSource` to a `Source` to visit it
    47‚Üí/// source.visit(&mut Printer)?;
    48‚Üí/// # Ok(())
    49‚Üí/// # }
    50‚Üí/// ```
    51‚Üípub trait Source {
    52‚Üí    /// Visit key-values.
    53‚Üí    ///
    54‚Üí    /// A source doesn't have to guarantee any ordering or uniqueness of key-values.
    55‚Üí    /// If the given visitor returns an error then the source may early-return with it,
    56‚Üí    /// even if there are more key-values.
    57‚Üí    ///
    58‚Üí    /// # Implementation notes
    59‚Üí    ///
    60‚Üí    /// A source should yield the same key-values to a subsequent visitor unless
    61‚Üí    /// that visitor itself fails.
    62‚Üí    fn visit<'kvs>(&'kvs self, visitor: &mut dyn VisitSource<'kvs>) -> Result<(), Error>;
    63‚Üí
    64‚Üí    /// Get the value for a given key.
    65‚Üí    ///
    66‚Üí    /// If the key appears multiple times in the source then which key is returned
    67‚Üí    /// is implementation specific.
    68‚Üí    ///
    69‚Üí    /// # Implementation notes
    70‚Üí    ///
    71‚Üí    /// A source that can provide a more efficient implementation of this method
    72‚Üí    /// should override it.
    73‚Üí    fn get(&self, key: Key) -> Option<Value<'_>> {
    74‚Üí        get_default(self, key)
    75‚Üí    }
    76‚Üí
    77‚Üí    /// Count the number of key-values that can be visited.
    78‚Üí    ///
    79‚Üí    /// # Implementation notes
    80‚Üí    ///
    81‚Üí    /// A source that knows the number of key-values upfront may provide a more
    82‚Üí    /// efficient implementation.
    83‚Üí    ///
    84‚Üí    /// A subsequent call to `visit` should yield the same number of key-values.
    85‚Üí    fn count(&self) -> usize {
    86‚Üí        count_default(self)
    87‚Üí    }
    88‚Üí}
    90‚Üí/// The default implementation of `Source::get`
    91‚Üífn get_default<'v>(source: &'v (impl Source + ?Sized), key: Key) -> Option<Value<'v>> {
    92‚Üí    struct Get<'k, 'v> {
    93‚Üí        key: Key<'k>,
    94‚Üí        found: Option<Value<'v>>,
    95‚Üí    }
    96‚Üí
    97‚Üí    impl<'k, 'kvs> VisitSource<'kvs> for Get<'k, 'kvs> {
    98‚Üí        fn visit_pair(&mut self, key: Key<'kvs>, value: Value<'kvs>) -> Result<(), Error> {
    99‚Üí            if self.key == key {
   100‚Üí                self.found = Some(value);
   101‚Üí            }
   102‚Üí
   103‚Üí            Ok(())
   104‚Üí        }
   105‚Üí    }
   106‚Üí
   113‚Üí/// The default implementation of `Source::count`.
   114‚Üífn count_default(source: impl Source) -> usize {
   115‚Üí    struct Count(usize);
   116‚Üí
   117‚Üí    impl<'kvs> VisitSource<'kvs> for Count {
   118‚Üí        fn visit_pair(&mut self, _: Key<'kvs>, _: Value<'kvs>) -> Result<(), Error> {
   119‚Üí            self.0 += 1;
   120‚Üí
   121‚Üí            Ok(())
   122‚Üí        }
   123‚Üí    }
   124‚Üí
   125‚Üí    let mut count = Count(0);
   126‚Üí    let _ = source.visit(&mut count);
   127‚Üí    count.0
   128‚Üí}
   234‚Üí/// A visitor for the key-value pairs in a [`Source`](trait.Source.html).
   235‚Üípub trait VisitSource<'kvs> {
   236‚Üí    /// Visit a key-value pair.
   237‚Üí    fn visit_pair(&mut self, key: Key<'kvs>, value: Value<'kvs>) -> Result<(), Error>;
   238‚Üí}
   240‚Üí#[allow(clippy::needless_lifetimes)] // Not needless.
   241‚Üíimpl<'a, 'kvs, T> VisitSource<'kvs> for &'a mut T
   242‚Üíwhere
   243‚Üí    T: VisitSource<'kvs> + ?Sized,
   244‚Üí{
   245‚Üí    fn visit_pair(&mut self, key: Key<'kvs>, value: Value<'kvs>) -> Result<(), Error> {
   246‚Üí        (**self).visit_pair(key, value)
   247‚Üí    }
   248‚Üí}

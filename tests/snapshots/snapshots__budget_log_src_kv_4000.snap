   444вҶ’        fn from вҖҰ
   450вҶ’/// A visitor for a [`Value`].
   451вҶ’///
   452вҶ’/// Also see [`Value`'s documentation on serialization]. Value visitors are a simple alternative
   453вҶ’/// to a more fully-featured serialization framework like `serde` or `sval`. A value visitor
   454вҶ’/// can differentiate primitive types through methods like [`VisitValue::visit_bool`] and
   455вҶ’/// [`VisitValue::visit_str`], but more complex types like maps and sequences
   456вҶ’/// will fallthrough to [`VisitValue::visit_any`].
   457вҶ’///
   458вҶ’/// If you're trying to serialize a value to a format like JSON, you can use either `serde`
   459вҶ’/// or `sval` directly with the value. You don't need a visitor.
   460вҶ’///
   461вҶ’/// [`Value`'s documentation on serialization]: Value#serialization
   462вҶ’pub trait VisitValue<'v> {
   463вҶ’    /// Visit a `Value`.
   464вҶ’    ///
   465вҶ’    /// This is the only required method on `VisitValue` and acts as a fallback for any
   466вҶ’    /// more specific methods that aren't overridden.
   467вҶ’    /// The `Value` may be formatted using its `fmt::Debug` or `fmt::Display` implementation,
   468вҶ’    /// or serialized using its `sval::Value` or `serde::Serialize` implementation.
   469вҶ’    fn visit_any(&mut self, value: Value) -> Result<(), Error>;
   471вҶ’    /// Visit an empty value.
   472вҶ’    fn visit_null(&mut self) -> Result<(), Error> {
   473вҶ’        self.visit_any(Value::null())
   474вҶ’    }
   476вҶ’    /// Visit an unsigned integer.
   477вҶ’    fn visit_u64(&mut self, value: u64) -> Result<(), Error> {
   478вҶ’        self.visit_any(value.into())
   479вҶ’    }
   481вҶ’    /// Visit a signed integer.
   482вҶ’    fn visit_i64(&mut self, value: i64) -> Result<(), Error> {
   483вҶ’        self.visit_any(value.into())
   484вҶ’    }
   486вҶ’    /// Visit a big unsigned integer.
   487вҶ’    fn visit_u128(&mut self, value: u128) -> Result<(), Error> {
   488вҶ’        self.visit_any((value).into())
   489вҶ’    }
   491вҶ’    /// Visit a big signed integer.
   492вҶ’    fn visit_i128(&mut self, value: i128) -> Result<(), Error> {
   493вҶ’        self.visit_any((value).into())
   494вҶ’    }
   496вҶ’    /// Visit a floating point.
   497вҶ’    fn visit_f64(&mut self, value: f64) -> Result<(), Error> {
   498вҶ’        self.visit_any(value.into())
   499вҶ’    }
   501вҶ’    /// Visit a boolean.
   502вҶ’    fn visit_bool(&mut self, value: bool) -> Result<(), Error> {
   503вҶ’        self.visit_any(value.into())
   504вҶ’    }
   506вҶ’    /// Visit a string.
   507вҶ’    fn visit_str(&mut self, value: &str) -> Result<(), Error> {
   508вҶ’        self.visit_any(value.into())
   509вҶ’    }
   511вҶ’    /// Visit a string.
   512вҶ’    fn visit_borrowed_str(&mut self, value: &'v str) -> Result<(), Error> {
   513вҶ’        self.visit_str(value)
   514вҶ’    }
   516вҶ’    /// Visit a Unicode character.
   517вҶ’    fn visit_char(&mut self, value: char) -> Result<(), Error> {
   518вҶ’        let mut b = [0; 4];
   519вҶ’        self.visit_str(&*value.encode_utf8(&mut b))
   520вҶ’    }
   522вҶ’    /// Visit an error.
   523вҶ’    #[cfg(feature = "kv_std")]
   524вҶ’    fn visit_error(&mut self, err: &(dyn std::error::Error + 'static)) -> Result<(), Error> {
   525вҶ’        self.visit_any(Value::from_dyn_error(err))
   526вҶ’    }
   528вҶ’    /// Visit an error.
   529вҶ’    #[cfg(feature = "kv_std")]
   530вҶ’    fn visit_borrowed_error(
   531вҶ’        &mut self,
   532вҶ’        err: &'v (dyn std::error::Error + 'static),
   533вҶ’    ) -> Result<(), Error> {
   534вҶ’        self.visit_any(Value::from_dyn_error(err))
   535вҶ’    }
   538вҶ’#[allow(clippy::needless_lifetimes)] // Not needless.
   539вҶ’impl<'a, 'v, T: ?Sized> VisitValue<'v> for &'a mut T
   540вҶ’where
   541вҶ’    T: VisitValue<'v>,
   542вҶ’{
   543вҶ’    fn visit_any вҖҰ
   547вҶ’    fn visit_null вҖҰ
   551вҶ’    fn visit_u64 вҖҰ
   555вҶ’    fn visit_i64 вҖҰ
   559вҶ’    fn visit_u128 вҖҰ
   563вҶ’    fn visit_i128 вҖҰ
   567вҶ’    fn visit_f64 вҖҰ
   571вҶ’    fn visit_bool вҖҰ
   575вҶ’    fn visit_str вҖҰ
   579вҶ’    fn visit_borrowed_str вҖҰ
   583вҶ’    fn visit_char вҖҰ
   587вҶ’    #[cfg(feature = "kv_std")]
   588вҶ’    fn visit_error(&mut self, err: &(dyn std::error::Error + 'static)) -> Result<(), Error> {
   589вҶ’        (**self).visit_error(err)
   590вҶ’    }
   592вҶ’    #[cfg(feature = "kv_std")]
   593вҶ’    fn visit_borrowed_error(
   594вҶ’        &mut self,
   595вҶ’        err: &'v (dyn std::error::Error + 'static),
   596вҶ’    ) -> Result<(), Error> {
   597вҶ’        (**self).visit_borrowed_error(err)
   598вҶ’    }

   451‚Üí///
   452‚Üí/// Also see [`Value`'s documentation on serialization]. Value visitors are a simple alternative
   453‚Üí/// to a more fully-featured serialization framework like `serde` or `sval`. A value visitor
   454‚Üí/// can differentiate primitive types through methods like [`VisitValue::visit_bool`] and
   455‚Üí/// [`VisitValue::visit_str`], but more complex types like maps and sequences
   456‚Üí/// will fallthrough to [`VisitValue::visit_any`].
   457‚Üí///
   458‚Üí/// If you're trying to serialize a value to a format like JSON, you can use either `serde`
   459‚Üí/// or `sval` directly with the value. You don't need a visitor.
   460‚Üí///
   461‚Üí/// [`Value`'s documentation on serialization]: Value#serialization
   462‚Üípub trait VisitValue<'v> {
   463‚Üí    /// Visit a `Value`.
   464‚Üí    ///
   465‚Üí    /// This is the only required method on `VisitValue` and acts as a fallback for any
   466‚Üí    /// more specific methods that aren't overridden.
   467‚Üí    /// The `Value` may be formatted using its `fmt::Debug` or `fmt::Display` implementation,
   468‚Üí    /// or serialized using its `sval::Value` or `serde::Serialize` implementation.
   469‚Üí    fn visit_any(&mut self, value: Value) -> Result<(), Error>;
   470‚Üí
   471‚Üí    /// Visit an empty value.
   472‚Üí    fn visit_null(&mut self) -> Result<(), Error> {
   473‚Üí        self.visit_any(Value::null())
   474‚Üí    }
   475‚Üí
   476‚Üí    /// Visit an unsigned integer.
   477‚Üí    fn visit_u64(&mut self, value: u64) -> Result<(), Error> {
   478‚Üí        self.visit_any(value.into())
   479‚Üí    }
   480‚Üí
   481‚Üí    /// Visit a signed integer.
   482‚Üí    fn visit_i64(&mut self, value: i64) -> Result<(), Error> {
   483‚Üí        self.visit_any(value.into())
   484‚Üí    }
   485‚Üí
   486‚Üí    /// Visit a big unsigned integer.
   487‚Üí    fn visit_u128(&mut self, value: u128) -> Result<(), Error> {
   488‚Üí        self.visit_any((value).into())
   489‚Üí    }
   490‚Üí
   491‚Üí    /// Visit a big signed integer.
   492‚Üí    fn visit_i128(&mut self, value: i128) -> Result<(), Error> {
   493‚Üí        self.visit_any((value).into())
   494‚Üí    }
   495‚Üí
   496‚Üí    /// Visit a floating point.
   497‚Üí    fn visit_f64(&mut self, value: f64) -> Result<(), Error> {
   498‚Üí        self.visit_any(value.into())
   499‚Üí    }
   500‚Üí
   501‚Üí    /// Visit a boolean.
   502‚Üí    fn visit_bool(&mut self, value: bool) -> Result<(), Error> {
   503‚Üí        self.visit_any(value.into())
   504‚Üí    }
   505‚Üí
   506‚Üí    /// Visit a string.
   507‚Üí    fn visit_str(&mut self, value: &str) -> Result<(), Error> {
   508‚Üí        self.visit_any(value.into())
   509‚Üí    }
   510‚Üí
   511‚Üí    /// Visit a string.
   512‚Üí    fn visit_borrowed_str(&mut self, value: &'v str) -> Result<(), Error> {
   513‚Üí        self.visit_str(value)
   514‚Üí    }
   515‚Üí
   516‚Üí    /// Visit a Unicode character.
   517‚Üí    fn visit_char(&mut self, value: char) -> Result<(), Error> {
   518‚Üí        let mut b = [0; 4];
   519‚Üí        self.visit_str(&*value.encode_utf8(&mut b))
   520‚Üí    }
   521‚Üí
   522‚Üí    /// Visit an error.
   523‚Üí    #[cfg(feature = "kv_std")]
   524‚Üí    fn visit_error(&mut self, err: &(dyn std::error::Error + 'static)) -> Result<(), Error> {
   525‚Üí        self.visit_any(Value::from_dyn_error(err))
   526‚Üí    }
   527‚Üí
   528‚Üí    /// Visit an error.
   529‚Üí    #[cfg(feature = "kv_std")]
   530‚Üí    fn visit_borrowed_error(
   531‚Üí        &mut self,
   532‚Üí        err: &'v (dyn std::error::Error + 'static),
   533‚Üí    ) -> Result<(), Error> {
   534‚Üí        self.visit_any(Value::from_dyn_error(err))
   535‚Üí    }
   536‚Üí}
   538‚Üí#[allow(clippy::needless_lifetimes)] // Not needless.
   539‚Üíimpl<'a, 'v, T: ?Sized> VisitValue<'v> for &'a mut T
   540‚Üíwhere
   541‚Üí    T: VisitValue<'v>,
   542‚Üí{
   543‚Üí    fn visit_any(&mut self, value: Value) -> Result<(), Error> {
   544‚Üí        (**self).visit_any(value)
   545‚Üí    }
   546‚Üí
   547‚Üí    fn visit_null(&mut self) -> Result<(), Error> {
   548‚Üí        (**self).visit_null()
   549‚Üí    }
   550‚Üí
   551‚Üí    fn visit_u64(&mut self, value: u64) -> Result<(), Error> {
   552‚Üí        (**self).visit_u64(value)
   553‚Üí    }
   554‚Üí
   555‚Üí    fn visit_i64(&mut self, value: i64) -> Result<(), Error> {
   556‚Üí        (**self).visit_i64(value)
   557‚Üí    }
   558‚Üí
   587‚Üí    #[cfg(feature = "kv_std")]
   588‚Üí    fn visit_error(&mut self, err: &(dyn std::error::Error + 'static)) -> Result<(), Error> {
   589‚Üí        (**self).visit_error(err)
   590‚Üí    }
   592‚Üí    #[cfg(feature = "kv_std")]
   593‚Üí    fn visit_borrowed_error(
   594‚Üí        &mut self,
   595‚Üí        err: &'v (dyn std::error::Error + 'static),
   596‚Üí    ) -> Result<(), Error> {
   597‚Üí        (**self).visit_borrowed_error(err)
   598‚Üí    }
   601‚Üí#[cfg(feature = "value-bag")]
   602‚Üípub(in crate::kv) mod inner {
   603‚Üí    /**
   604‚Üí    An implementation of `Value` based on a library called `value_bag`.
   605‚Üí
   606‚Üí    `value_bag` was written specifically for use in `log`'s value, but was split out when it outgrew
   607‚Üí    the codebase here. It's a general-purpose type-erasure library that handles mapping between
   608‚Üí    more fully-featured serialization frameworks.
   609‚Üí    */
   610‚Üí    use super::*;
   611‚Üí
   612‚Üí    pub use value_bag::ValueBag as Inner;
   613‚Üí
   614‚Üí    pub use value_bag::Error;
   615‚Üí
   616‚Üí    #[cfg(test)]
   617‚Üí    pub use value_bag::test::TestToken as Token;
   618‚Üí
   619‚Üí    pub fn visit<'v>(
   620‚Üí        inner: &Inner<'v>,
   621‚Üí        visitor: impl VisitValue<'v>,
   622‚Üí    ) -> Result<(), crate::kv::Error> {
   623‚Üí        struct InnerVisitValue<V>(V);
   624‚Üí
   625‚Üí        impl<'v, V> value_bag::visit::Visit<'v> for InnerVisitValue<V>
   626‚Üí        where
   627‚Üí            V: VisitValue<'v>,
   628‚Üí        {
   629‚Üí            fn visit_any(&mut self, value: value_bag::ValueBag) -> Result<(), Error> {
   630‚Üí                self.0
   631‚Üí                    .visit_any(Value { inner: value })
   632‚Üí                    .map_err(crate::kv::Error::into_value)
   633‚Üí            }
   634‚Üí
   635‚Üí            fn visit_empty(&mut self) -> Result<(), Error> {
   636‚Üí                self.0.visit_null().map_err(crate::kv::Error::into_value)
   637‚Üí            }
   638‚Üí
   720‚Üí#[cfg(not(feature = "value-bag"))]
   721‚Üípub(in crate::kv) mod inner {
   722‚Üí    /**
   723‚Üí    This is a dependency-free implementation of `Value` when there's no serialization frameworks involved.
   724‚Üí    In these simple cases a more fully featured solution like `value_bag` isn't needed, so we avoid pulling it in.
   725‚Üí
   726‚Üí    There are a few things here that need to remain consistent with the `value_bag`-based implementation:
   727‚Üí
   728‚Üí    1. Conversions should always produce the same results. If a conversion here returns `Some`, then
   729‚Üí       the same `value_bag`-based conversion must also. Of particular note here are floats to ints; they're
   730‚Üí       based on the standard library's `TryInto` conversions, which need to be converted to `i32` or `u32`,
   731‚Üí       and then to `f64`.
   732‚Üí    2. VisitValues should always be called in the same way. If a particular type of value calls `visit_i64`,
   733‚Üí       then the same `value_bag`-based visitor must also.
   734‚Üí    */
   735‚Üí    use super::*;
   736‚Üí
   737‚Üí    #[derive(Clone)]
   738‚Üí    pub enum Inner<'v> {
   739‚Üí        None,
   740‚Üí        Bool(bool),
   741‚Üí        Str(&'v str),
   742‚Üí        Char(char),
   743‚Üí        I64(i64),
   744‚Üí        U64(u64),
   745‚Üí        F64(f64),
   746‚Üí        I128(i128),
   747‚Üí        U128(u128),
   748‚Üí        Debug(&'v dyn fmt::Debug),
   749‚Üí        Display(&'v dyn fmt::Display),
   750‚Üí    }
   751‚Üí
   752‚Üí    impl<'v> From<()> for Inner<'v> {
   753‚Üí        fn from(_: ()) -> Self {
   754‚Üí            Inner::None
   755‚Üí        }
   756‚Üí    }
   757‚Üí
  1052‚Üí    /// Get a value from a type implementing `std::fmt::Debug`.
  1053‚Üí    #[cfg(feature = "kv_unstable")]
  1054‚Üí    #[deprecated(note = "use `from_debug` instead")]
  1055‚Üí    pub fn capture_debug<T>(value: &'v T) -> Self
  1056‚Üí    where
  1057‚Üí        T: fmt::Debug + 'static,
  1058‚Üí    {
  1059‚Üí        Value::from_debug(value)
  1060‚Üí    }
  1062‚Üí    /// Get a value from a type implementing `std::fmt::Display`.
  1063‚Üí    #[cfg(feature = "kv_unstable")]
  1064‚Üí    #[deprecated(note = "use `from_display` instead")]
  1065‚Üí    pub fn capture_display<T>(value: &'v T) -> Self
  1066‚Üí    where
  1067‚Üí        T: fmt::Display + 'static,
  1068‚Üí    {
  1069‚Üí        Value::from_display(value)
  1070‚Üí    }
  1072‚Üí    /// Get a value from an error.
  1073‚Üí    #[cfg(feature = "kv_unstable_std")]
  1074‚Üí    #[deprecated(note = "use `from_dyn_error` instead")]
  1075‚Üí    pub fn capture_error<T>(err: &'v T) -> Self
  1076‚Üí    where
  1077‚Üí        T: std::error::Error + 'static,
  1078‚Üí    {
  1079‚Üí        Value::from_dyn_error(err)
  1080‚Üí    }
  1082‚Üí    /// Get a value from a type implementing `serde::Serialize`.
  1083‚Üí    #[cfg(feature = "kv_unstable_serde")]
  1084‚Üí    #[deprecated(note = "use `from_serde` instead")]
  1085‚Üí    pub fn capture_serde<T>(value: &'v T) -> Self
  1086‚Üí    where
  1087‚Üí        T: serde_core::Serialize + 'static,
  1088‚Üí    {
  1089‚Üí        Value::from_serde(value)
  1090‚Üí    }
  1092‚Üí    /// Get a value from a type implementing `sval::Value`.
  1093‚Üí    #[cfg(feature = "kv_unstable_sval")]
  1094‚Üí    #[deprecated(note = "use `from_sval` instead")]
  1095‚Üí    pub fn capture_sval<T>(value: &'v T) -> Self
  1096‚Üí    where
  1097‚Üí        T: sval::Value + 'static,
  1098‚Üí    {
  1099‚Üí        Value::from_sval(value)
  1100‚Üí    }
  1125‚Üí/// Get a value from a type implementing `std::fmt::Debug`.
  1126‚Üí#[cfg(feature = "kv_unstable")]
  1127‚Üí#[deprecated(note = "use the `key:? = value` macro syntax instead")]
  1128‚Üí#[macro_export]
  1129‚Üímacro_rules! as_debug {
  1130‚Üí    ($capture:expr) => {
  1131‚Üí        $crate::kv::Value::from_debug(&$capture)
  1132‚Üí    };
  1133‚Üí}
  1135‚Üí/// Get a value from a type implementing `std::fmt::Display`.
  1136‚Üí#[cfg(feature = "kv_unstable")]
  1137‚Üí#[deprecated(note = "use the `key:% = value` macro syntax instead")]
  1138‚Üí#[macro_export]
  1139‚Üímacro_rules! as_display {
  1140‚Üí    ($capture:expr) => {
  1141‚Üí        $crate::kv::Value::from_display(&$capture)

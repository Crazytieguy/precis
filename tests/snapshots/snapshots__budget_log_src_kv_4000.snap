   450Ôćĺ/// A visitor for a [`Value`].
   451Ôćĺ///
   452Ôćĺ/// Also see [`Value`'s documentation on serialization]. Value visitors are a simple alternative
   453Ôćĺ/// to a more fully-featured serialization framework like `serde` or `sval`. A value visitor
   454Ôćĺ/// can differentiate primitive types through methods like [`VisitValue::visit_bool`] and
   455Ôćĺ/// [`VisitValue::visit_str`], but more complex types like maps and sequences
   456Ôćĺ/// will fallthrough to [`VisitValue::visit_any`].
   457Ôćĺ///
   458Ôćĺ/// If you're trying to serialize a value to a format like JSON, you can use either `serde`
   459Ôćĺ/// or `sval` directly with the value. You don't need a visitor.
   460Ôćĺ///
   461Ôćĺ/// [`Value`'s documentation on serialization]: Value#serialization
   462Ôćĺpub trait VisitValue<'v> {
   463Ôćĺ    /// Visit a `Value`.
   464Ôćĺ    ///
   465Ôćĺ    /// This is the only required method on `VisitValue` and acts as a fallback for any
   466Ôćĺ    /// more specific methods that aren't overridden.
   467Ôćĺ    /// The `Value` may be formatted using its `fmt::Debug` or `fmt::Display` implementation,
   468Ôćĺ    /// or serialized using its `sval::Value` or `serde::Serialize` implementation.
   469Ôćĺ    fn visit_any(&mut self, value: Value) -> Result<(), Error>;
   470Ôćĺ
   471Ôćĺ    /// Visit an empty value.
   472Ôćĺ    fn visit_null(&mut self) -> Result<(), Error> {
   473Ôćĺ        self.visit_any(Value::null())
   474Ôćĺ    }
   475Ôćĺ
   476Ôćĺ    /// Visit an unsigned integer.
   477Ôćĺ    fn visit_u64(&mut self, value: u64) -> Result<(), Error> {
   478Ôćĺ        self.visit_any(value.into())
   479Ôćĺ    }
   480Ôćĺ
   481Ôćĺ    /// Visit a signed integer.
   482Ôćĺ    fn visit_i64(&mut self, value: i64) -> Result<(), Error> {
   483Ôćĺ        self.visit_any(value.into())
   484Ôćĺ    }
   485Ôćĺ
   486Ôćĺ    /// Visit a big unsigned integer.
   487Ôćĺ    fn visit_u128(&mut self, value: u128) -> Result<(), Error> {
   488Ôćĺ        self.visit_any((value).into())
   489Ôćĺ    }
   490Ôćĺ
   491Ôćĺ    /// Visit a big signed integer.
   492Ôćĺ    fn visit_i128(&mut self, value: i128) -> Result<(), Error> {
   493Ôćĺ        self.visit_any((value).into())
   494Ôćĺ    }
   495Ôćĺ
   496Ôćĺ    /// Visit a floating point.
   497Ôćĺ    fn visit_f64(&mut self, value: f64) -> Result<(), Error> {
   498Ôćĺ        self.visit_any(value.into())
   499Ôćĺ    }
   500Ôćĺ
   501Ôćĺ    /// Visit a boolean.
   502Ôćĺ    fn visit_bool(&mut self, value: bool) -> Result<(), Error> {
   503Ôćĺ        self.visit_any(value.into())
   504Ôćĺ    }
   505Ôćĺ
   506Ôćĺ    /// Visit a string.
   507Ôćĺ    fn visit_str(&mut self, value: &str) -> Result<(), Error> {
   508Ôćĺ        self.visit_any(value.into())
   509Ôćĺ    }
   510Ôćĺ
   511Ôćĺ    /// Visit a string.
   512Ôćĺ    fn visit_borrowed_str(&mut self, value: &'v str) -> Result<(), Error> {
   513Ôćĺ        self.visit_str(value)
   514Ôćĺ    }
   515Ôćĺ
   516Ôćĺ    /// Visit a Unicode character.
   517Ôćĺ    fn visit_char(&mut self, value: char) -> Result<(), Error> {
   518Ôćĺ        let mut b = [0; 4];
   519Ôćĺ        self.visit_str(&*value.encode_utf8(&mut b))
   520Ôćĺ    }
   521Ôćĺ
   522Ôćĺ    /// Visit an error.
   523Ôćĺ    #[cfg(feature = "kv_std")]
   524Ôćĺ    fn visit_error(&mut self, err: &(dyn std::error::Error + 'static)) -> Result<(), Error> {
   525Ôćĺ        self.visit_any(Value::from_dyn_error(err))
   526Ôćĺ    }
   527Ôćĺ
   528Ôćĺ    /// Visit an error.
   529Ôćĺ    #[cfg(feature = "kv_std")]
   530Ôćĺ    fn visit_borrowed_error(
   531Ôćĺ        &mut self,
   532Ôćĺ        err: &'v (dyn std::error::Error + 'static),
   533Ôćĺ    ) -> Result<(), Error> {
   534Ôćĺ        self.visit_any(Value::from_dyn_error(err))
   535Ôćĺ    }
   536Ôćĺ}
   538Ôćĺ#[allow(clippy::needless_lifetimes)] // Not needless.
   539Ôćĺimpl<'a, 'v, T: ?Sized> VisitValue<'v> for &'a mut T
   540Ôćĺwhere
   541Ôćĺ    T: VisitValue<'v>,
   542Ôćĺ{
   543Ôćĺ    fn visit_any(&mut self, value: Value) -> Result<(), Error> {
   544Ôćĺ        (**self).visit_any(value)
   545Ôćĺ    }
   546Ôćĺ
   547Ôćĺ    fn visit_null(&mut self) -> Result<(), Error> {
   548Ôćĺ        (**self).visit_null()
   549Ôćĺ    }
   550Ôćĺ
   551Ôćĺ    fn visit_u64(&mut self, value: u64) -> Result<(), Error> {
   552Ôćĺ        (**self).visit_u64(value)
   553Ôćĺ    }
   554Ôćĺ
   555Ôćĺ    fn visit_i64(&mut self, value: i64) -> Result<(), Error> {
   556Ôćĺ        (**self).visit_i64(value)
   557Ôćĺ    }
   558Ôćĺ
   587Ôćĺ    #[cfg(feature = "kv_std")]
   588Ôćĺ    fn visit_error(&mut self, err: &(dyn std::error::Error + 'static)) -> Result<(), Error> {
   589Ôćĺ        (**self).visit_error(err)
   590Ôćĺ    }
   592Ôćĺ    #[cfg(feature = "kv_std")]
   593Ôćĺ    fn visit_borrowed_error(
   594Ôćĺ        &mut self,
   595Ôćĺ        err: &'v (dyn std::error::Error + 'static),
   596Ôćĺ    ) -> Result<(), Error> {
   597Ôćĺ        (**self).visit_borrowed_error(err)
   598Ôćĺ    }

mod.rs
     1‚Üí//! Structured logging.
     2‚Üí//!
     3‚Üí//! Add the `kv` feature to your `Cargo.toml` to enable
     4‚Üí//! this module:
     5‚Üí//!
     6‚Üí//! ```toml
     7‚Üí//! [dependencies.log]
     8‚Üí//! features = ["kv"]
     9‚Üí//! ```
    10‚Üí//!
    11‚Üí//! # Structured logging in `log`
    12‚Üí//!
    13‚Üí//! Structured logging enhances traditional text-based log records with user-defined
    14‚Üí//! attributes. Structured logs can be analyzed using a variety of data processing
    15‚Üí//! techniques, without needing to find and parse attributes from unstructured text first.
    16‚Üí//!
    17‚Üí//! In `log`, user-defined attributes are part of a [`Source`] on the log record.
    18‚Üí//! Each attribute is a key-value; a pair of [`Key`] and [`Value`]. Keys are strings
    19‚Üí//! and values are a datum of any type that can be formatted or serialized. Simple types
    20‚Üí//! like strings, booleans, and numbers are supported, as well as arbitrarily complex
    21‚Üí//! structures involving nested objects and sequences.
    22‚Üí//!
    23‚Üí//! ## Adding key-values to log records
    24‚Üí//!
    25‚Üí//! Key-values appear before the message format in the `log!` macros:
    26‚Üí//!
    27‚Üí//! ```
    28‚Üí//! # use log::info;
    29‚Üí//! info!(a = 1; "Something of interest");
    30‚Üí//! ```
    31‚Üí//!
    32‚Üí//! Key-values support the same shorthand identifier syntax as `format_args`:
    33‚Üí//!
    34‚Üí//! ```
    35‚Üí//! # use log::info;
    36‚Üí//! let a = 1;
    37‚Üí//!
    38‚Üí//! info!(a; "Something of interest");
    39‚Üí//! ```
    40‚Üí//!
    41‚Üí//! Values are capturing using the [`ToValue`] trait by default. To capture a value
    42‚Üí//! using a different trait implementation, use a modifier after its key. Here's how
    43‚Üí//! the same example can capture `a` using its `Debug` implementation instead:
    44‚Üí//!
    45‚Üí//! ```
    46‚Üí//! # use log::info;
    47‚Üí//! info!(a:? = 1; "Something of interest");
    48‚Üí//! ```
    49‚Üí//!
    50‚Üí//! The following capturing modifiers are supported:
    51‚Üí//!
    52‚Üí//! - `:?` will capture the value using `Debug`.
    53‚Üí//! - `:debug` will capture the value using `Debug`.
    54‚Üí//! - `:%` will capture the value using `Display`.
    55‚Üí//! - `:display` will capture the value using `Display`.
    56‚Üí//! - `:err` will capture the value using `std::error::Error` (requires the `kv_std` feature).
    57‚Üí//! - `:sval` will capture the value using `sval::Value` (requires the `kv_sval` feature).
    58‚Üí//! - `:serde` will capture the value using `serde::Serialize` (requires the `kv_serde` feature).
    59‚Üí//!
    60‚Üí//! ## Working with key-values on log records
    61‚Üí//!
    62‚Üí//! Use the [`Record::key_values`](../struct.Record.html#method.key_values) method to access key-values.
    63‚Üí//!
    64‚Üí//! Individual values can be pulled from the source by their key:
    65‚Üí//!
    66‚Üí//! ```
    67‚Üí//! # fn main() -> Result<(), log::kv::Error> {
    68‚Üí//! use log::kv::{Source, Key, Value};
    69‚Üí//! # let record = log::Record::builder().key_values(&[("a", 1)]).build();
    70‚Üí//!
    71‚Üí//! // info!(a = 1; "Something of interest");
    72‚Üí//!
    73‚Üí//! let a: Value = record.key_values().get(Key::from("a")).unwrap();
    74‚Üí//! assert_eq!(1, a.to_i64().unwrap());
    75‚Üí//! # Ok(())
    76‚Üí//! # }
    77‚Üí//! ```
    78‚Üí//!
    79‚Üí//! All key-values can also be enumerated using a [`VisitSource`]:
    80‚Üí//!
    81‚Üí//! ```
    82‚Üí//! # fn main() -> Result<(), log::kv::Error> {
    83‚Üí//! use std::collections::BTreeMap;
    84‚Üí//!
    85‚Üí//! use log::kv::{self, Source, Key, Value, VisitSource};
    86‚Üí//!
    87‚Üí//! struct Collect<'kvs>(BTreeMap<Key<'kvs>, Value<'kvs>>);
    88‚Üí//!
    89‚Üí//! impl<'kvs> VisitSource<'kvs> for Collect<'kvs> {
    90‚Üí//!     fn visit_pair(&mut self, key: Key<'kvs>, value: Value<'kvs>) -> Result<(), kv::Error> {
    91‚Üí//!         self.0.insert(key, value);
    92‚Üí//!
    93‚Üí//!         Ok(())
    94‚Üí//!     }
    95‚Üí//! }
    96‚Üí//!
    97‚Üí//! let mut visitor = Collect(BTreeMap::new());
    98‚Üí//!
    99‚Üí//! # let record = log::Record::builder().key_values(&[("a", 1), ("b", 2), ("c", 3)]).build();
   100‚Üí//! // info!(a = 1, b = 2, c = 3; "Something of interest");
   101‚Üí//!
   102‚Üí//! record.key_values().visit(&mut visitor)?;
   103‚Üí//!
   104‚Üí//! let collected = visitor.0;
   105‚Üí//!
   106‚Üí//! assert_eq!(
   107‚Üí//!     vec!["a", "b", "c"],
   108‚Üí//!     collected
   109‚Üí//!         .keys()
   110‚Üí//!         .map(|k| k.as_str())
   111‚Üí//!         .collect::<Vec<_>>(),
   112‚Üí//! );
   113‚Üí//! # Ok(())
   114‚Üí//! # }
   115‚Üí//! ```
   116‚Üí//!
   117‚Üí//! [`Value`]s have methods for conversions to common types:
   118‚Üí//!
   119‚Üí//! ```
   120‚Üí//! # fn main() -> Result<(), log::kv::Error> {
   121‚Üí//! use log::kv::{Source, Key};
   122‚Üí//! # let record = log::Record::builder().key_values(&[("a", 1)]).build();
   123‚Üí//!
   124‚Üí//! // info!(a = 1; "Something of interest");
   125‚Üí//!
   126‚Üí//! let a = record.key_values().get(Key::from("a")).unwrap();
   127‚Üí//!
   128‚Üí//! assert_eq!(1, a.to_i64().unwrap());
   129‚Üí//! # Ok(())
   130‚Üí//! # }
   131‚Üí//! ```
   132‚Üí//!
   133‚Üí//! Values also have their own [`VisitValue`] type. Value visitors are a lightweight
   134‚Üí//! API for working with primitives types:
   135‚Üí//!
   136‚Üí//! ```
   137‚Üí//! # fn main() -> Result<(), log::kv::Error> {
   138‚Üí//! use log::kv::{self, Source, Key, VisitValue};
   139‚Üí//! # let record = log::Record::builder().key_values(&[("a", 1)]).build();
   140‚Üí//!
   141‚Üí//! struct IsNumeric(bool);
   142‚Üí//!
   143‚Üí//! impl<'kvs> VisitValue<'kvs> for IsNumeric {
   144‚Üí//!     fn visit_any(&mut self, _value: kv::Value) -> Result<(), kv::Error> {
   145‚Üí//!         self.0 = false;
   146‚Üí//!         Ok(())
   147‚Üí//!     }
   148‚Üí//!
   149‚Üí//!     fn visit_u64(&mut self, _value: u64) -> Result<(), kv::Error> {
   150‚Üí//!         self.0 = true;
   151‚Üí//!         Ok(())
   152‚Üí//!     }
   153‚Üí//!
   154‚Üí//!     fn visit_i64(&mut self, _value: i64) -> Result<(), kv::Error> {
   155‚Üí//!         self.0 = true;
   156‚Üí//!         Ok(())
   157‚Üí//!     }
   158‚Üí//!
   159‚Üí//!     fn visit_u128(&mut self, _value: u128) -> Result<(), kv::Error> {
   160‚Üí//!         self.0 = true;
   161‚Üí//!         Ok(())
   162‚Üí//!     }
   163‚Üí//!
   164‚Üí//!     fn visit_i128(&mut self, _value: i128) -> Result<(), kv::Error> {
   165‚Üí//!         self.0 = true;
   166‚Üí//!         Ok(())
   167‚Üí//!     }
   168‚Üí//!
   169‚Üí//!     fn visit_f64(&mut self, _value: f64) -> Result<(), kv::Error> {
   170‚Üí//!         self.0 = true;
   171‚Üí//!         Ok(())
   172‚Üí//!     }
   173‚Üí//! }
   174‚Üí//!
   175‚Üí//! // info!(a = 1; "Something of interest");
   176‚Üí//!
   177‚Üí//! let a = record.key_values().get(Key::from("a")).unwrap();
   178‚Üí//!
   179‚Üí//! let mut visitor = IsNumeric(false);
   180‚Üí//!
   181‚Üí//! a.visit(&mut visitor)?;
   182‚Üí//!
   183‚Üí//! let is_numeric = visitor.0;
   184‚Üí//!
   185‚Üí//! assert!(is_numeric);
   186‚Üí//! # Ok(())
   187‚Üí//! # }
   188‚Üí//! ```
   189‚Üí//!
   190‚Üí//! To serialize a value to a format like JSON, you can also use either `serde` or `sval`:
   191‚Üí//!
   192‚Üí//! ```
   193‚Üí//! # fn main() -> Result<(), Box<dyn std::error::Error>> {
   194‚Üí//! # #[cfg(feature = "kv_serde")]
   195‚Üí//! # {
   196‚Üí//! # use log::kv::Key;
   197‚Üí//! #[derive(serde::Serialize)]
   198‚Üí//! struct Data {
   199‚Üí//!     a: i32, b: bool,
   200‚Üí//!     c: &'static str,
   201‚Üí//! }
   202‚Üí//!
   203‚Üí//! let data = Data { a: 1, b: true, c: "Some data" };
   204‚Üí//!
   205‚Üí//! # let source = [("a", log::kv::Value::from_serde(&data))];
   206‚Üí//! # let record = log::Record::builder().key_values(&source).build();
   207‚Üí//! // info!(a = data; "Something of interest");
   208‚Üí//!
   209‚Üí//! let a = record.key_values().get(Key::from("a")).unwrap();
   210‚Üí//!
   211‚Üí//! assert_eq!("{\"a\":1,\"b\":true,\"c\":\"Some data\"}", serde_json::to_string(&a)?);
   212‚Üí//! # }
   213‚Üí//! # Ok(())
   214‚Üí//! # }
   215‚Üí//! ```
   216‚Üí//!
   217‚Üí//! The choice of serialization framework depends on the needs of the consumer.
   218‚Üí//! If you're in a no-std environment, you can use `sval`. In other cases, you can use `serde`.
   219‚Üí//! Log producers and log consumers don't need to agree on the serialization framework.
   220‚Üí//! A value can be captured using its `serde::Serialize` implementation and still be serialized
   221‚Üí//! through `sval` without losing any structure or data.
   222‚Üí//!
   223‚Üí//! Values can also always be formatted using the standard `Debug` and `Display`
   224‚Üí//! traits:
   225‚Üí//!
   226‚Üí//! ```
   227‚Üí//! # use log::kv::Key;
   228‚Üí//! #[derive(Debug)]
   229‚Üí//! struct Data {
   230‚Üí//!     a: i32,
   231‚Üí//!     b: bool,
   232‚Üí//!     c: &'static str,
   233‚Üí//! }
   234‚Üí//!
   235‚Üí//! let data = Data { a: 1, b: true, c: "Some data" };
   236‚Üí//!
   237‚Üí//! # let source = [("a", log::kv::Value::from_debug(&data))];
   238‚Üí//! # let record = log::Record::builder().key_values(&source).build();
   239‚Üí//! // info!(a = data; "Something of interest");
   240‚Üí//!
   241‚Üí//! let a = record.key_values().get(Key::from("a")).unwrap();
   242‚Üí//!
   243‚Üí//! assert_eq!("Data { a: 1, b: true, c: \"Some data\" }", format!("{a:?}"));
   244‚Üí//! ```
   245‚Üí

   720Ôćĺ#[cfg(not(feature = "value-bag"))]
   721Ôćĺpub(in crate::kv) mod inner {
   722Ôćĺ    /**
   723Ôćĺ    This is a dependency-free implementation of `Value` when there's no serialization frameworks involved.
   724Ôćĺ    In these simple cases a more fully featured solution like `value_bag` isn't needed, so we avoid pulling it in.
   725Ôćĺ
   726Ôćĺ    There are a few things here that need to remain consistent with the `value_bag`-based implementation:
   727Ôćĺ
   728Ôćĺ    1. Conversions should always produce the same results. If a conversion here returns `Some`, then
   729Ôćĺ       the same `value_bag`-based conversion must also. Of particular note here are floats to ints; they're
   730Ôćĺ       based on the standard library's `TryInto` conversions, which need to be converted to `i32` or `u32`,
   731Ôćĺ       and then to `f64`.
   732Ôćĺ    2. VisitValues should always be called in the same way. If a particular type of value calls `visit_i64`,
   733Ôćĺ       then the same `value_bag`-based visitor must also.
   734Ôćĺ    */
   735Ôćĺ    use super::*;
   736Ôćĺ
   737Ôćĺ    #[derive(Clone)]
   738Ôćĺ    pub enum Inner<'v> {
   739Ôćĺ        None,
   740Ôćĺ        Bool(bool),
   741Ôćĺ        Str(&'v str),
   742Ôćĺ        Char(char),
   743Ôćĺ        I64(i64),
   744Ôćĺ        U64(u64),
   745Ôćĺ        F64(f64),
   746Ôćĺ        I128(i128),
   747Ôćĺ        U128(u128),
   748Ôćĺ        Debug(&'v dyn fmt::Debug),
   749Ôćĺ        Display(&'v dyn fmt::Display),
   750Ôćĺ    }
   751Ôćĺ
   752Ôćĺ    impl<'v> From<()> for Inner<'v> {
   753Ôćĺ        fn from(_: ()) -> Self {
   754Ôćĺ            Inner::None
   755Ôćĺ        }
   756Ôćĺ    }
   757Ôćĺ

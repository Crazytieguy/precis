     9Ôćĺ/// A source of key-values.
    10Ôćĺ///
    11Ôćĺ/// The source may be a single pair, a set of pairs, or a filter over a set of pairs.
    12Ôćĺ/// Use the [`VisitSource`](trait.VisitSource.html) trait to inspect the structured data
    13Ôćĺ/// in a source.
    14Ôćĺ///
    15Ôćĺ/// A source is like an iterator over its key-values, except with a push-based API
    16Ôćĺ/// instead of a pull-based one.
    17Ôćĺ///
    18Ôćĺ/// # Examples
    19Ôćĺ///
    20Ôćĺ/// Enumerating the key-values in a source:
    21Ôćĺ///
    22Ôćĺ/// ```
    23Ôćĺ/// # fn main() -> Result<(), log::kv::Error> {
    24Ôćĺ/// use log::kv::{self, Source, Key, Value, VisitSource};
    25Ôćĺ///
    26Ôćĺ/// // A `VisitSource` that prints all key-values
    27Ôćĺ/// // VisitSources are fed the key-value pairs of each key-values
    28Ôćĺ/// struct Printer;
    29Ôćĺ///
    30Ôćĺ/// impl<'kvs> VisitSource<'kvs> for Printer {
    31Ôćĺ///     fn visit_pair(&mut self, key: Key<'kvs>, value: Value<'kvs>) -> Result<(), kv::Error> {
    32Ôćĺ///         println!("{key}: {value}");
    33Ôćĺ///
    34Ôćĺ///         Ok(())
    35Ôćĺ///     }
    36Ôćĺ/// }
    37Ôćĺ///
    38Ôćĺ/// // A source with 3 key-values
    39Ôćĺ/// // Common collection types implement the `Source` trait
    40Ôćĺ/// let source = &[
    41Ôćĺ///     ("a", 1),
    42Ôćĺ///     ("b", 2),
    43Ôćĺ///     ("c", 3),
    44Ôćĺ/// ];
    45Ôćĺ///
    46Ôćĺ/// // Pass an instance of the `VisitSource` to a `Source` to visit it
    47Ôćĺ/// source.visit(&mut Printer)?;
    48Ôćĺ/// # Ok(())
    49Ôćĺ/// # }
    50Ôćĺ/// ```
    51Ôćĺpub trait Source {
    52Ôćĺ    /// Visit key-values.
    53Ôćĺ    ///
    54Ôćĺ    /// A source doesn't have to guarantee any ordering or uniqueness of key-values.
    55Ôćĺ    /// If the given visitor returns an error then the source may early-return with it,
    56Ôćĺ    /// even if there are more key-values.
    57Ôćĺ    ///
    58Ôćĺ    /// # Implementation notes
    59Ôćĺ    ///
    60Ôćĺ    /// A source should yield the same key-values to a subsequent visitor unless
    61Ôćĺ    /// that visitor itself fails.
    62Ôćĺ    fn visit<'kvs>(&'kvs self, visitor: &mut dyn VisitSource<'kvs>) -> Result<(), Error>;
    63Ôćĺ
    64Ôćĺ    /// Get the value for a given key.
    65Ôćĺ    ///
    66Ôćĺ    /// If the key appears multiple times in the source then which key is returned
    67Ôćĺ    /// is implementation specific.
    68Ôćĺ    ///
    69Ôćĺ    /// # Implementation notes
    70Ôćĺ    ///
    71Ôćĺ    /// A source that can provide a more efficient implementation of this method
    72Ôćĺ    /// should override it.
    73Ôćĺ    fn get(&self, key: Key) -> Option<Value<'_>> {
    74Ôćĺ        get_default(self, key)
    75Ôćĺ    }
    76Ôćĺ
    77Ôćĺ    /// Count the number of key-values that can be visited.
    78Ôćĺ    ///
    79Ôćĺ    /// # Implementation notes
    80Ôćĺ    ///
    81Ôćĺ    /// A source that knows the number of key-values upfront may provide a more
    82Ôćĺ    /// efficient implementation.
    83Ôćĺ    ///
    84Ôćĺ    /// A subsequent call to `visit` should yield the same number of key-values.
    85Ôćĺ    fn count(&self) -> usize {
    86Ôćĺ        count_default(self)
    87Ôćĺ    }
    88Ôćĺ}
    90Ôćĺ/// The default implementation of `Source::get`

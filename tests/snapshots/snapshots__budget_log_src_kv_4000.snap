     6вҶ’use crate::kv::{Error, Key, ToKey, ToValue, Value};
     7вҶ’use std::fmt;
     9вҶ’/// A source of key-values.
    10вҶ’///
    11вҶ’/// The source may be a single pair, a set of pairs, or a filter over a set of pairs.
    12вҶ’/// Use the [`VisitSource`](trait.VisitSource.html) trait to inspect the structured data
    13вҶ’/// in a source.
    14вҶ’///
    15вҶ’/// A source is like an iterator over its key-values, except with a push-based API
    16вҶ’/// instead of a pull-based one.
    17вҶ’///
    18вҶ’/// # Examples
    19вҶ’///
    20вҶ’/// Enumerating the key-values in a source:
    21вҶ’///
    22вҶ’/// ```
    23вҶ’/// # fn main() -> Result<(), log::kv::Error> {
    24вҶ’/// use log::kv::{self, Source, Key, Value, VisitSource};
    25вҶ’///
    26вҶ’/// // A `VisitSource` that prints all key-values
    27вҶ’/// // VisitSources are fed the key-value pairs of each key-values
    28вҶ’/// struct Printer;
    29вҶ’///
    30вҶ’/// impl<'kvs> VisitSource<'kvs> for Printer {
    31вҶ’///     fn visit_pair(&mut self, key: Key<'kvs>, value: Value<'kvs>) -> Result<(), kv::Error> {
    32вҶ’///         println!("{key}: {value}");
    33вҶ’///
    34вҶ’///         Ok(())
    35вҶ’///     }
    36вҶ’/// }
    37вҶ’///
    38вҶ’/// // A source with 3 key-values
    39вҶ’/// // Common collection types implement the `Source` trait
    40вҶ’/// let source = &[
    41вҶ’///     ("a", 1),
    42вҶ’///     ("b", 2),
    43вҶ’///     ("c", 3),
    44вҶ’/// ];
    45вҶ’///
    46вҶ’/// // Pass an instance of the `VisitSource` to a `Source` to visit it
    47вҶ’/// source.visit(&mut Printer)?;
    48вҶ’/// # Ok(())
    49вҶ’/// # }
    50вҶ’/// ```
    51вҶ’pub trait Source {
    52вҶ’    /// Visit key-values.
    53вҶ’    ///
    54вҶ’    /// A source doesn't have to guarantee any ordering or uniqueness of key-values.
    55вҶ’    /// If the given visitor returns an error then the source may early-return with it,
    56вҶ’    /// even if there are more key-values.
    57вҶ’    ///
    58вҶ’    /// # Implementation notes
    59вҶ’    ///
    60вҶ’    /// A source should yield the same key-values to a subsequent visitor unless
    61вҶ’    /// that visitor itself fails.
    62вҶ’    fn visit<'kvs>(&'kvs self, visitor: &mut dyn VisitSource<'kvs>) -> Result<(), Error>;
    64вҶ’    /// Get the value for a given key.
    65вҶ’    ///
    66вҶ’    /// If the key appears multiple times in the source then which key is returned
    67вҶ’    /// is implementation specific.
    68вҶ’    ///
    69вҶ’    /// # Implementation notes
    70вҶ’    ///
    71вҶ’    /// A source that can provide a more efficient implementation of this method
    72вҶ’    /// should override it.
    73вҶ’    fn get(&self, key: Key) -> Option<Value<'_>> {
    74вҶ’        get_default(self, key)
    75вҶ’    }
    77вҶ’    /// Count the number of key-values that can be visited.
    78вҶ’    ///
    79вҶ’    /// # Implementation notes
    80вҶ’    ///
    81вҶ’    /// A source that knows the number of key-values upfront may provide a more
    82вҶ’    /// efficient implementation.
    83вҶ’    ///
    84вҶ’    /// A subsequent call to `visit` should yield the same number of key-values.
    85вҶ’    fn count(&self) -> usize {
    86вҶ’        count_default(self)
    87вҶ’    }
    90вҶ’/// The default implementation of `Source::get`
    91вҶ’fn get_default<'v>(source: &'v (impl Source + ?Sized), key: Key) -> Option<Value<'v>> {
    92вҶ’    struct Get<'k, 'v> {
    93вҶ’        key: Key<'k>,
    94вҶ’        found: Option<Value<'v>>,
    95вҶ’    }
    96вҶ’
    97вҶ’    impl<'k, 'kvs> VisitSource<'kvs> for Get<'k, 'kvs> {
    98вҶ’        fn visit_pair(&mut self, key: Key<'kvs>, value: Value<'kvs>) -> Result<(), Error> {
    99вҶ’            if self.key == key {
   100вҶ’                self.found = Some(value);
   101вҶ’            }
   102вҶ’
   103вҶ’            Ok(())
   104вҶ’        }
   105вҶ’    }
   106вҶ’
   107вҶ’    let mut get = Get { key, found: None };
   108вҶ’
   109вҶ’    let _ = source.visit(&mut get);
   110вҶ’    get.found
   111вҶ’}
   113вҶ’/// The default implementation of `Source::count`.
   114вҶ’fn count_default(source: impl Source) -> usize {
   115вҶ’    struct Count(usize);
   116вҶ’
   117вҶ’    impl<'kvs> VisitSource<'kvs> for Count {
   118вҶ’        fn visit_pair(&mut self, _: Key<'kvs>, _: Value<'kvs>) -> Result<(), Error> {
   119вҶ’            self.0 += 1;
   120вҶ’
   121вҶ’            Ok(())
   122вҶ’        }
   123вҶ’    }
   124вҶ’
   125вҶ’    let mut count = Count(0);
   126вҶ’    let _ = source.visit(&mut count);
   127вҶ’    count.0
   128вҶ’}

    10вҶ’/// A type that can be converted into a [`Value`](struct.Value.html).
    11вҶ’pub trait ToValue {
    12вҶ’    /// Perform the conversion.
    13вҶ’    fn to_value(&self) -> Value<'_>;
    20вҶ’    fn to_value вҖҰ
    26вҶ’    fn to_value вҖҰ
    33вҶ’/// A value in a key-value.
    34вҶ’///
    35вҶ’/// Values are an anonymous bag containing some structured datum.
    36вҶ’///
    37вҶ’/// # Capturing values
    38вҶ’///
    39вҶ’/// There are a few ways to capture a value:
    40вҶ’///
    41вҶ’/// - Using the `Value::from_*` methods.
    42вҶ’/// - Using the `ToValue` trait.
    43вҶ’/// - Using the standard `From` trait.
    44вҶ’///
    45вҶ’/// ## Using the `Value::from_*` methods
    46вҶ’///
    47вҶ’/// `Value` offers a few constructor methods that capture values of different kinds.
    48вҶ’///
    49вҶ’/// ```
    50вҶ’/// use log::kv::Value;
    51вҶ’///
    52вҶ’/// let value = Value::from_debug(&42i32);
    53вҶ’///
    54вҶ’/// assert_eq!(None, value.to_i64());
    55вҶ’/// ```
    56вҶ’///
    57вҶ’/// ## Using the `ToValue` trait
    58вҶ’///
    59вҶ’/// The `ToValue` trait can be used to capture values generically.
    60вҶ’/// It's the bound used by `Source`.
    61вҶ’///
    62вҶ’/// ```
    63вҶ’/// # use log::kv::ToValue;
    64вҶ’/// let value = 42i32.to_value();
    65вҶ’///
    66вҶ’/// assert_eq!(Some(42), value.to_i64());
    67вҶ’/// ```
    68вҶ’///
    69вҶ’/// ## Using the standard `From` trait
    70вҶ’///
    71вҶ’/// Standard types that implement `ToValue` also implement `From`.
    72вҶ’///
    73вҶ’/// ```
    74вҶ’/// use log::kv::Value;
    75вҶ’///
    76вҶ’/// let value = Value::from(42i32);
    77вҶ’///
    78вҶ’/// assert_eq!(Some(42), value.to_i64());
    79вҶ’/// ```
    80вҶ’///
    81вҶ’/// # Data model
    82вҶ’///
    83вҶ’/// Values can hold one of a number of types:
    84вҶ’///
    85вҶ’/// - **Null:** The absence of any other meaningful value. Note that
    86вҶ’///   `Some(Value::null())` is not the same as `None`. The former is
    87вҶ’///   `null` while the latter is `undefined`. This is important to be
    88вҶ’///   able to tell the difference between a key-value that was logged,
    89вҶ’///   but its value was empty (`Some(Value::null())`) and a key-value
    90вҶ’///   that was never logged at all (`None`).
    91вҶ’/// - **Strings:** `str`, `char`.
    92вҶ’/// - **Booleans:** `bool`.
    93вҶ’/// - **Integers:** `u8`-`u128`, `i8`-`i128`, `NonZero*`.
    94вҶ’/// - **Floating point numbers:** `f32`-`f64`.
    95вҶ’/// - **Errors:** `dyn (Error + 'static)`.
    96вҶ’/// - **`serde`:** Any type in `serde`'s data model.
    97вҶ’/// - **`sval`:** Any type in `sval`'s data model.
    98вҶ’///
    99вҶ’/// # Serialization
   100вҶ’///
   101вҶ’/// Values provide a number of ways to be serialized.
   102вҶ’///
   103вҶ’/// For basic types the [`Value::visit`] method can be used to extract the
   104вҶ’/// underlying typed value. However, this is limited in the amount of types
   105вҶ’/// supported (see the [`VisitValue`] trait methods).
   106вҶ’///
   107вҶ’/// For more complex types one of the following traits can be used:
   108вҶ’///  * `sval::Value`, requires the `kv_sval` feature.
   109вҶ’///  * `serde::Serialize`, requires the `kv_serde` feature.
   110вҶ’///
   111вҶ’/// You don't need a visitor to serialize values through `serde` or `sval`.
   112вҶ’///
   113вҶ’/// A value can always be serialized using any supported framework, regardless
   114вҶ’/// of how it was captured. If, for example, a value was captured using its
   115вҶ’/// `Display` implementation, it will serialize through `serde` as a string. If it was
   116вҶ’/// captured as a struct using `serde`, it will also serialize as a struct
   117вҶ’/// through `sval`, or can be formatted using a `Debug`-compatible representation.
   118вҶ’#[derive(Clone)]
   119вҶ’pub struct Value<'v> {
   120вҶ’    inner: inner::Inner<'v>,
   121вҶ’}
   124вҶ’    /// Get a value from a type implementing `ToValue`.
   125вҶ’    pub fn from_any<T>(value: &'v T) -> Self
   126вҶ’    where
   127вҶ’        T: ToValue,
   128вҶ’    {
   129вҶ’        value.to_value()
   130вҶ’    }
   132вҶ’    /// Get a value from a type implementing `std::fmt::Debug`.
   133вҶ’    pub fn from_debug<T>(value: &'v T) -> Self
   134вҶ’    where
   135вҶ’        T: fmt::Debug,
   136вҶ’    {
   137вҶ’        Value {
   138вҶ’            inner: inner::Inner::from_debug(value),
   139вҶ’        }
   140вҶ’    }
   142вҶ’    /// Get a value from a type implementing `std::fmt::Display`.
   143вҶ’    pub fn from_display<T>(value: &'v T) -> Self
   144вҶ’    where
   145вҶ’        T: fmt::Display,
   146вҶ’    {
   147вҶ’        Value {
   148вҶ’            inner: inner::Inner::from_display(value),
   149вҶ’        }
   150вҶ’    }
   152вҶ’    /// Get a value from a type implementing `serde::Serialize`.
   153вҶ’    #[cfg(feature = "kv_serde")]
   154вҶ’    pub fn from_serde<T>(value: &'v T) -> Self
   155вҶ’    where
   156вҶ’        T: serde_core::Serialize,
   157вҶ’    {
   158вҶ’        Value {
   159вҶ’            inner: inner::Inner::from_serde1(value),
   160вҶ’        }
   161вҶ’    }
   163вҶ’    /// Get a value from a type implementing `sval::Value`.

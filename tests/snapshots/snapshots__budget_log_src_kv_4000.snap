   216‚Üí    /// serialize a value using its `Serialize` or `Value` implementation.
   217‚Üí    pub fn visit(&self, visitor: impl VisitValue<'v>) -> Result<(), Error> {
   218‚Üí        inner::visit(&self.inner, visitor)
   219‚Üí    }

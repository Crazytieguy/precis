   288‚Üímacro_rules! impl_to_value_primitive {
   289‚Üí    ($($into_ty:ty,)*) => {
   290‚Üí        $(
   291‚Üí            impl ToValue for $into_ty {
   292‚Üí                fn to_value(&self) -> Value<'_> {
   293‚Üí                    Value::from(*self)
   294‚Üí                }
   295‚Üí            }
   296‚Üí
   297‚Üí            impl<'v> From<$into_ty> for Value<'v> {
   298‚Üí                fn from(value: $into_ty) -> Self {
   299‚Üí                    Value::from_inner(value)
   300‚Üí                }
   301‚Üí            }
   302‚Üí
   303‚Üí            impl<'v> From<&'v $into_ty> for Value<'v> {
   304‚Üí                fn from(value: &'v $into_ty) -> Self {
   305‚Üí                    Value::from_inner(*value)
   306‚Üí                }
   307‚Üí            }
   308‚Üí        )*
   309‚Üí    };
   310‚Üí}
   312‚Üímacro_rules! impl_to_value_nonzero_primitive {
   313‚Üí    ($($into_ty:ident,)*) => {
   314‚Üí        $(
   315‚Üí            impl ToValue for std::num::$into_ty {
   316‚Üí                fn to_value(&self) -> Value<'_> {
   317‚Üí                    Value::from(self.get())
   318‚Üí                }
   319‚Üí            }
   320‚Üí
   321‚Üí            impl<'v> From<std::num::$into_ty> for Value<'v> {
   322‚Üí                fn from(value: std::num::$into_ty) -> Self {
   323‚Üí                    Value::from(value.get())
   324‚Üí                }
   325‚Üí            }
   326‚Üí
   327‚Üí            impl<'v> From<&'v std::num::$into_ty> for Value<'v> {
   328‚Üí                fn from(value: &'v std::num::$into_ty) -> Self {
   329‚Üí                    Value::from(value.get())
   330‚Üí                }
   331‚Üí            }
   332‚Üí        )*
   333‚Üí    };
   334‚Üí}
   336‚Üímacro_rules! impl_value_to_primitive {
   337‚Üí    ($(#[doc = $doc:tt] $into_name:ident -> $into_ty:ty,)*) => {
   338‚Üí        impl<'v> Value<'v> {
   339‚Üí            $(
   340‚Üí                #[doc = $doc]
   341‚Üí                pub fn $into_name(&self) -> Option<$into_ty> {
   342‚Üí                    self.inner.$into_name()
   343‚Üí                }
   344‚Üí            )*
   345‚Üí        }
   346‚Üí    }
   347‚Üí}

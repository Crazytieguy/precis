    37Ôćĺ/// # Capturing values
    38Ôćĺ///
    39Ôćĺ/// There are a few ways to capture a value:
    40Ôćĺ///
    41Ôćĺ/// - Using the `Value::from_*` methods.
    42Ôćĺ/// - Using the `ToValue` trait.
    43Ôćĺ/// - Using the standard `From` trait.
    44Ôćĺ///
    45Ôćĺ/// ## Using the `Value::from_*` methods
    46Ôćĺ///
    47Ôćĺ/// `Value` offers a few constructor methods that capture values of different kinds.
    48Ôćĺ///
    49Ôćĺ/// ```
    50Ôćĺ/// use log::kv::Value;
    51Ôćĺ///
    52Ôćĺ/// let value = Value::from_debug(&42i32);
    53Ôćĺ///
    54Ôćĺ/// assert_eq!(None, value.to_i64());
    55Ôćĺ/// ```
    56Ôćĺ///
    57Ôćĺ/// ## Using the `ToValue` trait
    58Ôćĺ///
    59Ôćĺ/// The `ToValue` trait can be used to capture values generically.
    60Ôćĺ/// It's the bound used by `Source`.
    61Ôćĺ///
    62Ôćĺ/// ```
    63Ôćĺ/// # use log::kv::ToValue;
    64Ôćĺ/// let value = 42i32.to_value();
    65Ôćĺ///
    66Ôćĺ/// assert_eq!(Some(42), value.to_i64());
    67Ôćĺ/// ```
    68Ôćĺ///
    69Ôćĺ/// ## Using the standard `From` trait
    70Ôćĺ///
    71Ôćĺ/// Standard types that implement `ToValue` also implement `From`.
    72Ôćĺ///
    73Ôćĺ/// ```
    74Ôćĺ/// use log::kv::Value;
    75Ôćĺ///
    76Ôćĺ/// let value = Value::from(42i32);
    77Ôćĺ///
    78Ôćĺ/// assert_eq!(Some(42), value.to_i64());
    79Ôćĺ/// ```
    80Ôćĺ///
    81Ôćĺ/// # Data model
    82Ôćĺ///
    83Ôćĺ/// Values can hold one of a number of types:
    84Ôćĺ///

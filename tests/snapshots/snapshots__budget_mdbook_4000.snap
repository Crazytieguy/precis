   713‚Üí/// Allows you to "update" any arbitrary field in a struct by round-tripping via
   714‚Üí/// a `toml::Value`.
   715‚Üí///
      ‚Üí‚Ä¶
   718‚Üítrait Updateable<'de>: Serialize + Deserialize<'de> {
   719‚Üí    fn update_value<S: Serialize>(&mut self, key: &str, value: S) -> Result<()> {
   720‚Üí        let mut raw = Value::try_from(&self).expect("unreachable");
   721‚Üí        let value = Value::try_from(value)?;
   722‚Üí        raw.insert(key, value);
   723‚Üí        let updated = raw.try_into()?;
   724‚Üí        *self = updated;
   725‚Üí        Ok(())
   726‚Üí    }
   727‚Üí}

    35‚Üí}
    37‚Üí/// The context provided to all renderers.
    38‚Üí#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]
    39‚Üí#[non_exhaustive]
    40‚Üípub struct RenderContext {
    41‚Üí    /// Which version of `mdbook` did this come from (as written in `mdbook`'s
    42‚Üí    /// `Cargo.toml`). Useful if you know the renderer is only compatible with
    43‚Üí    /// certain versions of `mdbook`.
    44‚Üí    pub version: String,
    45‚Üí    /// The book's root directory.
    46‚Üí    pub root: PathBuf,
    47‚Üí    /// A loaded representation of the book itself.
    48‚Üí    pub book: Book,
    49‚Üí    /// The loaded configuration file.
    50‚Üí    pub config: Config,
    51‚Üí    /// Where the renderer *must* put any build artefacts generated. To allow

    36‚Üí/// Formats a number of bytes into a human readable SI-prefixed size.
    37‚Üí/// Returns a tuple of `(quantity, units)`.
    38‚Üípub fn human_readable_bytes(bytes: u64) -> (f32, &'static str) {
    39‚Üí    static UNITS: [&str; 7] = ["B", "KiB", "MiB", "GiB", "TiB", "PiB", "EiB"];
    40‚Üí    let bytes = bytes as f32;
    41‚Üí    let i = ((bytes.log2() / 10.0) as usize).min(UNITS.len() - 1);
    42‚Üí    (bytes / 1024_f32.powi(i as i32), UNITS[i])
    43‚Üí}

    23‚Üí/// An operation which is run immediately after loading a book into memory and
    24‚Üí/// before it gets rendered.
    25‚Üí///
    26‚Üí/// Types that implement the `Preprocessor` trait can be used with
    27‚Üí/// [`MDBook::with_preprocessor`] to programmatically add preprocessors.
    28‚Üí///
    29‚Üí/// [`MDBook::with_preprocessor`]: https://docs.rs/mdbook-driver/latest/mdbook_driver/struct.MDBook.html#method.with_preprocessor
    30‚Üípub trait Preprocessor {
    31‚Üí    /// Get the `Preprocessor`'s name.
    32‚Üí    fn name(&self) -> &str;
    34‚Üí    /// Run this `Preprocessor`, allowing it to update the book before it is
    35‚Üí    /// given to a renderer.
    36‚Üí    fn run(&self, ctx: &PreprocessorContext, book: Book) -> Result<Book>;
    38‚Üí    /// A hint to `MDBook` whether this preprocessor is compatible with a
    39‚Üí    /// particular renderer.
    40‚Üí    ///
    41‚Üí    /// By default, always returns `true`.
    42‚Üí    fn supports_renderer(&self, _renderer: &str) -> Result<bool> {
    43‚Üí        Ok(true)
    44‚Üí    }
    47‚Üí/// Extra information for a `Preprocessor` to give them more context when
    48‚Üí/// processing a book.
    49‚Üí#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]
    50‚Üí#[non_exhaustive]
    51‚Üípub struct PreprocessorContext {
    52‚Üí    /// The location of the book directory on disk.
    53‚Üí    pub root: PathBuf,
    54‚Üí    /// The book configuration (`book.toml`).
    55‚Üí    pub config: Config,
    56‚Üí    /// The `Renderer` this preprocessor is being used with.
    57‚Üí    pub renderer: String,
    58‚Üí    /// The calling `mdbook` version.
    59‚Üí    pub mdbook_version: String,
    60‚Üí    /// Internal mapping of chapter titles.
    61‚Üí    ///
    62‚Üí    /// This is used internally by mdbook to compute custom chapter titles.
    63‚Üí    /// This should not be used outside of mdbook's internals.
    64‚Üí    #[serde(skip)]
    65‚Üí    pub chapter_titles: RefCell<HashMap<PathBuf, String>>,
    66‚Üí}
    68‚Üíimpl PreprocessorContext {
    69‚Üí    /// Create a new `PreprocessorContext`.
    70‚Üí    pub fn new(root: PathBuf, config: Config, renderer: String) -> Self {
    71‚Üí        PreprocessorContext {
    72‚Üí            root,
    73‚Üí            config,
    74‚Üí            renderer,
    75‚Üí            mdbook_version: crate::MDBOOK_VERSION.to_string(),
    76‚Üí            chapter_titles: RefCell::new(HashMap::new()),
    77‚Üí        }
    78‚Üí    }
    81‚Üí/// Parses the input given to a preprocessor.
    82‚Üípub fn parse_input<R: Read>(reader: R) -> Result<(PreprocessorContext, Book)> {
    83‚Üí    serde_json::from_reader(reader).with_context(|| "Unable to parse the input")
    84‚Üí}

    43‚Üí/// Creates a new pulldown-cmark parser of the given text.
    44‚Üípub fn new_cmark_parser<'text>(text: &'text str, options: &MarkdownOptions) -> Parser<'text> {
    45‚Üí    let mut opts = Options::empty();
    46‚Üí    opts.insert(Options::ENABLE_TABLES);
    47‚Üí    opts.insert(Options::ENABLE_FOOTNOTES);
    48‚Üí    opts.insert(Options::ENABLE_STRIKETHROUGH);
    49‚Üí    opts.insert(Options::ENABLE_TASKLISTS);
    50‚Üí    opts.insert(Options::ENABLE_HEADING_ATTRIBUTES);

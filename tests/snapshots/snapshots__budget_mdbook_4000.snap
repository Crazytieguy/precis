    27‚Üí/// [`MDBook::with_renderer`]: https://docs.rs/mdbook-driver/latest/mdbook_driver/struct.MDBook.html#method.with_renderer
    28‚Üípub trait Renderer {
    29‚Üí    /// The `Renderer`'s name.

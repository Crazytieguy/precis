    12вҶ’fn main() {
    13вҶ’    let mut stdin = io::stdin();
    14вҶ’    let ctx = RenderContext::from_json(&mut stdin).unwrap();
    15вҶ’    let cfg: WordcountConfig = ctx.config
    16вҶ’        .get_deserialized("output.wordcount")
    17вҶ’        .unwrap_or_default();
    18вҶ’
    19вҶ’    let _ = fs::create_dir_all(&ctx.destination);
    20вҶ’    let mut f = File::create(ctx.destination.join("wordcounts.txt")).unwrap();
    21вҶ’
    22вҶ’    for item in ctx.book.iter() {
    23вҶ’        if let BookItem::Chapter(ref ch) = *item {
    24вҶ’            if cfg.ignores.contains(&ch.name) {
    25вҶ’                continue;
    26вҶ’            }
    27вҶ’

     1Ôćĺexport type EventType = string | symbol;
     5Ôćĺexport type Handler<T = unknown> = (event: T) => void;
     6Ôćĺexport type WildcardHandler<T = Record<string, unknown>> = (
     7Ôćĺ	type: keyof T,
     8Ôćĺ	event: T[keyof T]
     9Ôćĺ) => void;
    12Ôćĺexport type EventHandlerList<T = unknown> = Array<Handler<T>>;
    13Ôćĺexport type WildCardEventHandlerList<T = Record<string, unknown>> = Array<
    14Ôćĺ	WildcardHandler<T>
    15Ôćĺ>;
    18Ôćĺexport type EventHandlerMap<Events extends Record<EventType, unknown>> = Map<
    19Ôćĺ	keyof Events | '*',
    20Ôćĺ	EventHandlerList<Events[keyof Events]> | WildCardEventHandlerList<Events>
    21Ôćĺ>;
    23Ôćĺexport interface Emitter<Events extends Record<EventType, unknown>> {
    24Ôćĺ	all: EventHandlerMap<Events>;
    25Ôćĺ
    26Ôćĺ	on<Key extends keyof Events>(type: Key, handler: Handler<Events[Key]>): void;
    27Ôćĺ	on(type: '*', handler: WildcardHandler<Events>): void;
    28Ôćĺ
    29Ôćĺ	off<Key extends keyof Events>(
    30Ôćĺ		type: Key,
    31Ôćĺ		handler?: Handler<Events[Key]>
    32Ôćĺ	): void;
    33Ôćĺ	off(type: '*', handler: WildcardHandler<Events>): void;
    34Ôćĺ
    35Ôćĺ	emit<Key extends keyof Events>(type: Key, event: Events[Key]): void;
    36Ôćĺ	emit<Key extends keyof Events>(
    37Ôćĺ		type: undefined extends Events[Key] ? Key : never
    38Ôćĺ	): void;
    39Ôćĺ}
    41Ôćĺ/**
    42Ôćĺ * Mitt: Tiny (~200b) functional event emitter / pubsub.
    43Ôćĺ * @name mitt
    44Ôćĺ * @returns {Mitt}
    45Ôćĺ */
    46Ôćĺexport default function mitt<Events extends Record<EventType, unknown>>(
    47Ôćĺ	all?: EventHandlerMap<Events>
    48Ôćĺ): Emitter<Events> {
    49Ôćĺ	type GenericEventHandler =
    50Ôćĺ		| Handler<Events[keyof Events]>
    51Ôćĺ		| WildcardHandler<Events>;
    52Ôćĺ	all = all || new Map();
    53Ôćĺ
    54Ôćĺ	return {
    55Ôćĺ		/**
    56Ôćĺ		 * A Map of event names to registered handler functions.
    57Ôćĺ		 */
    58Ôćĺ		all,
    59Ôćĺ
    60Ôćĺ		/**
    61Ôćĺ		 * Register an event handler for the given type.
    62Ôćĺ		 * @param {string|symbol} type Type of event to listen for, or `'*'` for all events
    63Ôćĺ		 * @param {Function} handler Function to call in response to given event
    64Ôćĺ		 * @memberOf mitt
    65Ôćĺ		 */
    66Ôćĺ		on<Key extends keyof Events>(type: Key, handler: GenericEventHandler) {
    67Ôćĺ			const handlers: Array<GenericEventHandler> | undefined = all!.get(type);
    68Ôćĺ			if (handlers) {
    69Ôćĺ				handlers.push(handler);
    70Ôćĺ			} else {
    71Ôćĺ				all!.set(type, [handler] as EventHandlerList<Events[keyof Events]>);
    72Ôćĺ			}
    73Ôćĺ		},
    74Ôćĺ
    75Ôćĺ		/**
    76Ôćĺ		 * Remove an event handler for the given type.
      ÔćĺÔÇŽ

src/index.ts
     1вҶ’export type EventType = string | symbol;
     5вҶ’export type Handler<T = unknown> = (event: T) => void;
     6вҶ’export type WildcardHandler<T = Record<string, unknown>> = (
     7вҶ’	type: keyof T,
     8вҶ’	event: T[keyof T]
     9вҶ’) => void;
    12вҶ’export type EventHandlerList<T = unknown> = Array<Handler<T>>;
    13вҶ’export type WildCardEventHandlerList<T = Record<string, unknown>> = Array<
    14вҶ’	WildcardHandler<T>
    15вҶ’>;
    18вҶ’export type EventHandlerMap<Events extends Record<EventType, unknown>> = Map<
    19вҶ’	keyof Events | '*',
    20вҶ’	EventHandlerList<Events[keyof Events]> | WildCardEventHandlerList<Events>
    21вҶ’>;
    23вҶ’export interface Emitter<Events extends Record<EventType, unknown>> {
    24вҶ’	all: EventHandlerMap<Events>;
    25вҶ’
    26вҶ’	on<Key extends keyof Events>(type: Key, handler: Handler<Events[Key]>): void;
    27вҶ’	on(type: '*', handler: WildcardHandler<Events>): void;
    28вҶ’
    29вҶ’	off<Key extends keyof Events>(
    30вҶ’		type: Key,
    31вҶ’		handler?: Handler<Events[Key]>
    32вҶ’	): void;
    33вҶ’	off(type: '*', handler: WildcardHandler<Events>): void;
    34вҶ’
    35вҶ’	emit<Key extends keyof Events>(type: Key, event: Events[Key]): void;
    36вҶ’	emit<Key extends keyof Events>(
    37вҶ’		type: undefined extends Events[Key] ? Key : never
    38вҶ’	): void;
    39вҶ’}
    41вҶ’/**
    42вҶ’ * Mitt: Tiny (~200b) functional event emitter / pubsub.
    43вҶ’ * @name mitt
    44вҶ’ * @returns {Mitt}
    45вҶ’ */
    46вҶ’export default function mitt<Events extends Record<EventType, unknown>>(
    47вҶ’	all?: EventHandlerMap<Events>
    48вҶ’): Emitter<Events> {
    49вҶ’	type GenericEventHandler =
    50вҶ’		| Handler<Events[keyof Events]>
    51вҶ’		| WildcardHandler<Events>;
    52вҶ’	all = all || new Map();
    53вҶ’
    54вҶ’	return {
    55вҶ’		/**
    56вҶ’		 * A Map of event names to registered handler functions.
    57вҶ’		 */
    58вҶ’		all,
    59вҶ’
    60вҶ’		/**
    61вҶ’		 * Register an event handler for the given type.
    62вҶ’		 * @param {string|symbol} type Type of event to listen for, or `'*'` for all events
    63вҶ’		 * @param {Function} handler Function to call in response to given event
    64вҶ’		 * @memberOf mitt
    65вҶ’		 */
    66вҶ’		on<Key extends keyof Events>(type: Key, handler: GenericEventHandler) {
    67вҶ’			const handlers: Array<GenericEventHandler> | undefined = all!.get(type);
    68вҶ’			if (handlers) {
    69вҶ’				handlers.push(handler);
    70вҶ’			} else {
    71вҶ’				all!.set(type, [handler] as EventHandlerList<Events[keyof Events]>);
    72вҶ’			}
    73вҶ’		},
    74вҶ’
    75вҶ’		/**

src/index.ts
     1в†’export type EventType = string | symbol;
     5в†’export type Handler<T = unknown> = (event: T) => void;
     6в†’export type WildcardHandler<T = Record<string, unknown>> = (
     7в†’	type: keyof T,
     8в†’	event: T[keyof T]
     9в†’) => void;
    12в†’export type EventHandlerList<T = unknown> = Array<Handler<T>>;
    13в†’export type WildCardEventHandlerList<T = Record<string, unknown>> = Array<
    14в†’	WildcardHandler<T>
    15в†’>;
    18в†’export type EventHandlerMap<Events extends Record<EventType, unknown>> = Map<
    19в†’	keyof Events | '*',
    20в†’	EventHandlerList<Events[keyof Events]> | WildCardEventHandlerList<Events>
    21в†’>;
    23в†’export interface Emitter<Events extends Record<EventType, unknown>> {
    24в†’	all: EventHandlerMap<Events>;
    25в†’
    26в†’	on<Key extends keyof Events>(type: Key, handler: Handler<Events[Key]>): void;
    27в†’	on(type: '*', handler: WildcardHandler<Events>): void;
    33в†’	off(type: '*', handler: WildcardHandler<Events>): void;
    36в†’	emit<Key extends keyof Events>(
    37в†’		type: undefined extends Events[Key] ? Key : never
    38в†’	): void;
    42в†’ * Mitt: Tiny (~200b) functional event emitter / pubsub.
    43в†’ * @name mitt
    44в†’ * @returns {Mitt}
    46в†’export default function mitt<Events extends Record<EventType, unknown>>(
    47в†’	all?: EventHandlerMap<Events>
    48в†’): Emitter<Events> {
    49в†’	type GenericEventHandler =
    50в†’		| Handler<Events[keyof Events]>
    51в†’		| WildcardHandler<Events>;
    52в†’	all = all || new Map();
    53в†’
    54в†’	return {
    55в†’		/**
    56в†’		 * A Map of event names to registered handler functions.
    57в†’		 */
    58в†’		all,
    59в†’
    60в†’		/**
    61в†’		 * Register an event handler for the given type.
    62в†’		 * @param {string|symbol} type Type of event to listen for, or `'*'` for all events
    63в†’		 * @param {Function} handler Function to call in response to given event
    64в†’		 * @memberOf mitt
    65в†’		 */
    66в†’		on<Key extends keyof Events>(type: Key, handler: GenericEventHandler) {
    67в†’			const handlers: Array<GenericEventHandler> | undefined = all!.get(type);
    68в†’			if (handlers) {
    69в†’				handlers.push(handler);
    70в†’			} else {
    71в†’				all!.set(type, [handler] as EventHandlerList<Events[keyof Events]>);
    72в†’			}
    73в†’		},
    74в†’
    75в†’		/**

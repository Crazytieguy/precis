src/index.ts
     1‚Üíexport type EventType = string | symbol;
     5‚Üíexport type Handler<T = unknown> = (event: T) => void;
     6‚Üíexport type WildcardHandler<T = Record<string, unknown>> = (
     7‚Üí	type: keyof T,
     8‚Üí	event: T[keyof T]
     9‚Üí) => void;
    12‚Üíexport type EventHandlerList<T = unknown> = Array<Handler<T>>;
    13‚Üíexport type WildCardEventHandlerList<T = Record<string, unknown>> = Array<
    14‚Üí	WildcardHandler<T>
    15‚Üí>;
    18‚Üíexport type EventHandlerMap<Events extends Record<EventType, unknown>> = Map<
    19‚Üí	keyof Events | '*',
    20‚Üí	EventHandlerList<Events[keyof Events]> | WildCardEventHandlerList<Events>
    21‚Üí>;
    23‚Üíexport interface Emitter<Events extends Record<EventType, unknown>> {
    24‚Üí	all: EventHandlerMap<Events>;
    25‚Üí
    26‚Üí	on<Key extends keyof Events>(type: Key, handler: Handler<Events[Key]>): void;
    27‚Üí	on(type: '*', handler: WildcardHandler<Events>): void;
    33‚Üí	off(type: '*', handler: WildcardHandler<Events>): void;
    36‚Üí	emit<Key extends keyof Events>(
    37‚Üí		type: undefined extends Events[Key] ? Key : never
    38‚Üí	): void;
    41‚Üí/**
    42‚Üí * Mitt: Tiny (~200b) functional event emitter / pubsub.
    43‚Üí * @name mitt
    44‚Üí * @returns {Mitt}
    45‚Üí */
    46‚Üíexport default function mitt<Events extends Record<EventType, unknown>>(
    47‚Üí	all?: EventHandlerMap<Events>
    48‚Üí): Emitter<Events> {
    49‚Üí	type GenericEventHandler =
    50‚Üí		| Handler<Events[keyof Events]>
    51‚Üí		| WildcardHandler<Events>;
    52‚Üí	all = all || new Map();
    53‚Üí
    54‚Üí	return {
    55‚Üí		/**
    56‚Üí		 * A Map of event names to registered handler functions.
    57‚Üí		 */
    58‚Üí		all,
    59‚Üí
    60‚Üí		/**
    61‚Üí		 * Register an event handler for the given type.
    62‚Üí		 * @param {string|symbol} type Type of event to listen for, or `'*'` for all events
    63‚Üí		 * @param {Function} handler Function to call in response to given event
    64‚Üí		 * @memberOf mitt
    65‚Üí		 */
    66‚Üí		on<Key extends keyof Events>(type: Key, handler: GenericEventHandler) {
    67‚Üí			const handlers: Array<GenericEventHandler> | undefined = all!.get(type);
    68‚Üí			if (handlers) {
    69‚Üí				handlers.push(handler);
    70‚Üí			} else {
    71‚Üí				all!.set(type, [handler] as EventHandlerList<Events[keyof Events]>);
    72‚Üí			}
    73‚Üí		},
    74‚Üí
    75‚Üí		/**
    76‚Üí		 * Remove an event handler for the given type.
    77‚Üí		 * If `handler` is omitted, all handlers of the given type are removed.
    78‚Üí		 * @param {string|symbol} type Type of event to unregister `handler` from (`'*'` to remove a wildcard handler)
    79‚Üí		 * @param {Function} [handler] Handler function to remove
    80‚Üí		 * @memberOf mitt
    81‚Üí		 */
    82‚Üí		off<Key extends keyof Events>(type: Key, handler?: GenericEventHandler) {
    83‚Üí			const handlers: Array<GenericEventHandler> | undefined = all!.get(type);
    84‚Üí			if (handlers) {
    85‚Üí				if (handler) {
    86‚Üí					handlers.splice(handlers.indexOf(handler) >>> 0, 1);
    87‚Üí				} else {
    88‚Üí					all!.set(type, []);
    89‚Üí				}
    90‚Üí			}
    91‚Üí		},
    92‚Üí
    93‚Üí		/**
    94‚Üí		 * Invoke all handlers for the given type.
    95‚Üí		 * If present, `'*'` handlers are invoked after type-matched handlers.
    96‚Üí		 *
    97‚Üí		 * Note: Manually firing '*' handlers is not supported.
    98‚Üí		 *
    99‚Üí		 * @param {string|symbol} type The event type to invoke
   100‚Üí		 * @param {Any} [evt] Any value (object is recommended and powerful), passed to each handler
   101‚Üí		 * @memberOf mitt
   102‚Üí		 */
   103‚Üí		emit<Key extends keyof Events>(type: Key, evt?: Events[Key]) {
   104‚Üí			let handlers = all!.get(type);
   105‚Üí			if (handlers) {
   106‚Üí				(handlers as EventHandlerList<Events[keyof Events]>)
   107‚Üí					.slice()
   108‚Üí					.map((handler) => {
   109‚Üí						handler(evt!);
   110‚Üí					});
   111‚Üí			}
   112‚Üí
   113‚Üí			handlers = all!.get('*');
   114‚Üí			if (handlers) {
   115‚Üí				(handlers as WildCardEventHandlerList<Events>)
   116‚Üí					.slice()
   117‚Üí					.map((handler) => {
   118‚Üí						handler(type, evt!);
   119‚Üí					});
   120‚Üí			}
   121‚Üí		}
   122‚Üí	};
   123‚Üí}


src/index.ts
     1ŌåÆexport type EventType = string | symbol;
     5ŌåÆexport type Handler<T = unknown> = (event: T) => void;
     6ŌåÆexport type WildcardHandler<T = Record<string, unknown>> = (
     7ŌåÆ	type: keyof T,
     8ŌåÆ	event: T[keyof T]
     9ŌåÆ) => void;
    12ŌåÆexport type EventHandlerList<T = unknown> = Array<Handler<T>>;
    13ŌåÆexport type WildCardEventHandlerList<T = Record<string, unknown>> = Array<
    14ŌåÆ	WildcardHandler<T>
    15ŌåÆ>;
    18ŌåÆexport type EventHandlerMap<Events extends Record<EventType, unknown>> = Map<
    19ŌåÆ	keyof Events | '*',
    20ŌåÆ	EventHandlerList<Events[keyof Events]> | WildCardEventHandlerList<Events>
    21ŌåÆ>;
    23ŌåÆexport interface Emitter<Events extends Record<EventType, unknown>> {
    24ŌåÆ	all: EventHandlerMap<Events>;
    25ŌåÆ
    26ŌåÆ	on<Key extends keyof Events>(type: Key, handler: Handler<Events[Key]>): void;
    27ŌåÆ	on(type: '*', handler: WildcardHandler<Events>): void;
    33ŌåÆ	off(type: '*', handler: WildcardHandler<Events>): void;
    36ŌåÆ	emit<Key extends keyof Events>(
    37ŌåÆ		type: undefined extends Events[Key] ? Key : never
    38ŌåÆ	): void;
    41ŌåÆ/**
    42ŌåÆ * Mitt: Tiny (~200b) functional event emitter / pubsub.
    43ŌåÆ * @name mitt
    44ŌåÆ * @returns {Mitt}
    45ŌåÆ */
    46ŌåÆexport default function mitt<Events extends Record<EventType, unknown>>(
    47ŌåÆ	all?: EventHandlerMap<Events>
    48ŌåÆ): Emitter<Events> {
    49ŌåÆ	type GenericEventHandler =
    50ŌåÆ		| Handler<Events[keyof Events]>
    51ŌåÆ		| WildcardHandler<Events>;
    52ŌåÆ	all = all || new Map();
    53ŌåÆ
    54ŌåÆ	return {
    55ŌåÆ		/**
    56ŌåÆ		 * A Map of event names to registered handler functions.
    57ŌåÆ		 */
    58ŌåÆ		all,
    59ŌåÆ
    60ŌåÆ		/**
    61ŌåÆ		 * Register an event handler for the given type.
    62ŌåÆ		 * @param {string|symbol} type Type of event to listen for, or `'*'` for all events
    63ŌåÆ		 * @param {Function} handler Function to call in response to given event
    64ŌåÆ		 * @memberOf mitt
    65ŌåÆ		 */
    66ŌåÆ		on<Key extends keyof Events>(type: Key, handler: GenericEventHandler) {
    67ŌåÆ			const handlers: Array<GenericEventHandler> | undefined = all!.get(type);
    68ŌåÆ			if (handlers) {
    69ŌåÆ				handlers.push(handler);
    70ŌåÆ			} else {
    71ŌåÆ				all!.set(type, [handler] as EventHandlerList<Events[keyof Events]>);
    72ŌåÆ			}
    73ŌåÆ		},
    74ŌåÆ
    75ŌåÆ		/**
    76ŌåÆ		 * Remove an event handler for the given type.
    77ŌåÆ		 * If `handler` is omitted, all handlers of the given type are removed.
    78ŌåÆ		 * @param {string|symbol} type Type of event to unregister `handler` from (`'*'` to remove a wildcard handler)
    79ŌåÆ		 * @param {Function} [handler] Handler function to remove
    80ŌåÆ		 * @memberOf mitt
    81ŌåÆ		 */
    82ŌåÆ		off<Key extends keyof Events>(type: Key, handler?: GenericEventHandler) {
    83ŌåÆ			const handlers: Array<GenericEventHandler> | undefined = all!.get(type);
    84ŌåÆ			if (handlers) {
    85ŌåÆ				if (handler) {
    86ŌåÆ					handlers.splice(handlers.indexOf(handler) >>> 0, 1);
    87ŌåÆ				} else {
    88ŌåÆ					all!.set(type, []);
    89ŌåÆ				}
    90ŌåÆ			}
    91ŌåÆ		},
    92ŌåÆ
    93ŌåÆ		/**
    94ŌåÆ		 * Invoke all handlers for the given type.
    95ŌåÆ		 * If present, `'*'` handlers are invoked after type-matched handlers.
    96ŌåÆ		 *
    97ŌåÆ		 * Note: Manually firing '*' handlers is not supported.
    98ŌåÆ		 *
    99ŌåÆ		 * @param {string|symbol} type The event type to invoke
   100ŌåÆ		 * @param {Any} [evt] Any value (object is recommended and powerful), passed to each handler
   101ŌåÆ		 * @memberOf mitt
   102ŌåÆ		 */
   103ŌåÆ		emit<Key extends keyof Events>(type: Key, evt?: Events[Key]) {
   104ŌåÆ			let handlers = all!.get(type);
   105ŌåÆ			if (handlers) {
   106ŌåÆ				(handlers as EventHandlerList<Events[keyof Events]>)
   107ŌåÆ					.slice()
   108ŌåÆ					.map((handler) => {
   109ŌåÆ						handler(evt!);
   110ŌåÆ					});
   111ŌåÆ			}
   112ŌåÆ
   113ŌåÆ			handlers = all!.get('*');
   114ŌåÆ			if (handlers) {
   115ŌåÆ				(handlers as WildCardEventHandlerList<Events>)
   116ŌåÆ					.slice()
   117ŌåÆ					.map((handler) => {
   118ŌåÆ						handler(type, evt!);
   119ŌåÆ					});
   120ŌåÆ			}
   121ŌåÆ		}
   122ŌåÆ	};
   123ŌåÆ}


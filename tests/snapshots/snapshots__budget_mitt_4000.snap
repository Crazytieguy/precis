src/index.ts
     1â†’export type EventType = string | symbol;
     5â†’export type Handler<T = unknown> = (event: T) => void;
     6â†’export type WildcardHandler<T = Record<string, unknown>> = (
     7â†’	type: keyof T,
     8â†’	event: T[keyof T]
     9â†’) => void;
    12â†’export type EventHandlerList<T = unknown> = Array<Handler<T>>;
    13â†’export type WildCardEventHandlerList<T = Record<string, unknown>> = Array<
    14â†’	WildcardHandler<T>
    15â†’>;
    18â†’export type EventHandlerMap<Events extends Record<EventType, unknown>> = Map<
    19â†’	keyof Events | '*',
    20â†’	EventHandlerList<Events[keyof Events]> | WildCardEventHandlerList<Events>
    21â†’>;
    23â†’export interface Emitter<Events extends Record<EventType, unknown>> {
    24â†’	all: EventHandlerMap<Events>;
    25â†’
    26â†’	on<Key extends keyof Events>(type: Key, handler: Handler<Events[Key]>): void;
    27â†’	on(type: '*', handler: WildcardHandler<Events>): void;
    33â†’	off(type: '*', handler: WildcardHandler<Events>): void;
    36â†’	emit<Key extends keyof Events>(
    37â†’		type: undefined extends Events[Key] ? Key : never
    38â†’	): void;
    41â†’/**
    42â†’ * Mitt: Tiny (~200b) functional event emitter / pubsub.
    43â†’ * @name mitt
    44â†’ * @returns {Mitt}
    45â†’ */
    46â†’export default function mitt<Events extends Record<EventType, unknown>>(
    47â†’	all?: EventHandlerMap<Events>
    48â†’): Emitter<Events> {
    49â†’	type GenericEventHandler =
    50â†’		| Handler<Events[keyof Events]>
    51â†’		| WildcardHandler<Events>;
    52â†’	all = all || new Map();
    53â†’
    54â†’	return {
    55â†’		/**
    56â†’		 * A Map of event names to registered handler functions.
    57â†’		 */
    58â†’		all,
    59â†’
    60â†’		/**
    61â†’		 * Register an event handler for the given type.
    62â†’		 * @param {string|symbol} type Type of event to listen for, or `'*'` for all events
    63â†’		 * @param {Function} handler Function to call in response to given event
    64â†’		 * @memberOf mitt
    65â†’		 */
    66â†’		on<Key extends keyof Events>(type: Key, handler: GenericEventHandler) {
    67â†’			const handlers: Array<GenericEventHandler> | undefined = all!.get(type);
    68â†’			if (handlers) {
    69â†’				handlers.push(handler);
    70â†’			} else {
    71â†’				all!.set(type, [handler] as EventHandlerList<Events[keyof Events]>);
    72â†’			}
    73â†’		},
    74â†’
    75â†’		/**
    76â†’		 * Remove an event handler for the given type.
    77â†’		 * If `handler` is omitted, all handlers of the given type are removed.
    78â†’		 * @param {string|symbol} type Type of event to unregister `handler` from (`'*'` to remove a wildcard handler)
    79â†’		 * @param {Function} [handler] Handler function to remove
    80â†’		 * @memberOf mitt
    81â†’		 */
    82â†’		off<Key extends keyof Events>(type: Key, handler?: GenericEventHandler) {
    83â†’			const handlers: Array<GenericEventHandler> | undefined = all!.get(type);
    84â†’			if (handlers) {
    85â†’				if (handler) {
    86â†’					handlers.splice(handlers.indexOf(handler) >>> 0, 1);
    87â†’				} else {
    88â†’					all!.set(type, []);
    89â†’				}
    90â†’			}
    91â†’		},
    92â†’
    93â†’		/**
    94â†’		 * Invoke all handlers for the given type.
    95â†’		 * If present, `'*'` handlers are invoked after type-matched handlers.
    96â†’		 *
    97â†’		 * Note: Manually firing '*' handlers is not supported.
    98â†’		 *
    99â†’		 * @param {string|symbol} type The event type to invoke
   100â†’		 * @param {Any} [evt] Any value (object is recommended and powerful), passed to each handler
   101â†’		 * @memberOf mitt
   102â†’		 */
   103â†’		emit<Key extends keyof Events>(type: Key, evt?: Events[Key]) {
   104â†’			let handlers = all!.get(type);
   105â†’			if (handlers) {
   106â†’				(handlers as EventHandlerList<Events[keyof Events]>)
   107â†’					.slice()
   108â†’					.map((handler) => {
   109â†’						handler(evt!);
   110â†’					});
   111â†’			}
   112â†’
   113â†’			handlers = all!.get('*');
   114â†’			if (handlers) {
   115â†’				(handlers as WildCardEventHandlerList<Events>)
   116â†’					.slice()
   117â†’					.map((handler) => {
   118â†’						handler(type, evt!);
   119â†’					});
   120â†’			}
   121â†’		}
   122â†’	};
   123â†’}


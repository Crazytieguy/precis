     1‚Üíexport type EventType = string | symbol;
     5‚Üíexport type Handler<T = unknown> = (event: T) => void;
     6‚Üíexport type WildcardHandler<T = Record<string, unknown>> = (
     7‚Üí	type: keyof T,
     8‚Üí	event: T[keyof T]
     9‚Üí) => void;
    12‚Üíexport type EventHandlerList<T = unknown> = Array<Handler<T>>;
    13‚Üíexport type WildCardEventHandlerList<T = Record<string, unknown>> = Array<
    14‚Üí	WildcardHandler<T>
    15‚Üí>;
    18‚Üíexport type EventHandlerMap<Events extends Record<EventType, unknown>> = Map<
    19‚Üí	keyof Events | '*',
    20‚Üí	EventHandlerList<Events[keyof Events]> | WildCardEventHandlerList<Events>
    21‚Üí>;
    23‚Üíexport interface Emitter<Events extends Record<EventType, unknown>> {
    24‚Üí	all: EventHandlerMap<Events>;
    25‚Üí
    26‚Üí	on<Key extends keyof Events>(type: Key, handler: Handler<Events[Key]>): void;
    27‚Üí	on(type: '*', handler: WildcardHandler<Events>): void;
    28‚Üí
    29‚Üí	off<Key extends keyof Events>(
    30‚Üí		type: Key,
    31‚Üí		handler?: Handler<Events[Key]>
    32‚Üí	): void;
    33‚Üí	off(type: '*', handler: WildcardHandler<Events>): void;
    34‚Üí
    35‚Üí	emit<Key extends keyof Events>(type: Key, event: Events[Key]): void;
    36‚Üí	emit<Key extends keyof Events>(
    37‚Üí		type: undefined extends Events[Key] ? Key : never
    38‚Üí	): void;
    39‚Üí}
    41‚Üí/**
    42‚Üí * Mitt: Tiny (~200b) functional event emitter / pubsub.
    43‚Üí * @name mitt
    44‚Üí * @returns {Mitt}
    45‚Üí */
    46‚Üíexport default function mitt<Events extends Record<EventType, unknown>>(
    47‚Üí	all?: EventHandlerMap<Events>
    48‚Üí): Emitter<Events> {

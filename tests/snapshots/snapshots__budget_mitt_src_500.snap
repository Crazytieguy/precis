    41в†’/**
    42в†’ * Mitt: Tiny (~200b) functional event emitter / pubsub.
    43в†’ * @name mitt
    44в†’ * @returns {Mitt}
    45в†’ */
    46в†’export default function mitt<Events extends Record<EventType, unknown>>(
    47в†’	all?: EventHandlerMap<Events>
    48в†’): Emitter<Events> {
    49в†’	type GenericEventHandler =
    50в†’		| Handler<Events[keyof Events]>
    51в†’		| WildcardHandler<Events>;
    52в†’	all = all || new Map();
    53в†’

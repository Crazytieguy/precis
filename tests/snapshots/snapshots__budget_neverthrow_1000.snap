   312→export class Ok<T, E> implements IResult<T, E> {
   313→  constructor(readonly value: T) {}
   314→
   315→  isOk(): this is Ok<T, E> {
   316→    return true
   317→  }
   318→
   319→  isErr(): this is Err<T, E> {
   320→    return !this.isOk()
   321→  }

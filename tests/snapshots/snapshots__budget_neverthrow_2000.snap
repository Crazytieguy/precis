    11Рєњinterface NeverThrowError<T, E> {
    12Рєњ  data:
    13Рєњ    | {
    14Рєњ        type: string
    15Рєњ        value: T
    16Рєњ      }
    17Рєњ    | {
    18Рєњ        type: string
    19Рєњ        value: E
    20Рєњ      }
    21Рєњ  message: string
    22Рєњ  stack: string | undefined
    23Рєњ}
    27Рєњexport const createNeverThrowError = <T, E>(
    28Рєњ  message: string,
    29Рєњ  result: Result<T, E>,
    30Рєњ  config: ErrorConfig = defaultErrorConfig,
    31Рєњ): NeverThrowError<T, E> => {
    32Рєњ  const data = result.isOk()
    33Рєњ    ? { type: 'Ok', value: result.value }
    34Рєњ    : { type: 'Err', value: result.error }
    35Рєњ
    36Рєњ  const maybeStack = config.withStackTrace ? new Error().stack : undefined
    37Рєњ
    38Рєњ  return {
    39Рєњ    data,
    40Рєњ    message,
    41Рєњ    stack: maybeStack,
    42Рєњ  }
    43Рєњ}

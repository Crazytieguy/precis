    14‚Üíexport namespace Result {
    15‚Üí  /**
    16‚Üí   * Wraps a function with a try catch, creating a new function with the same
    17‚Üí   * arguments but returning `Ok` if successful, `Err` if the function throws
    18‚Üí   *
    19‚Üí   * @param fn function to wrap with ok on success or err on failure
    20‚Üí   * @param errorFn when an error is thrown, this will wrap the error result if provided
    21‚Üí   */
    22‚Üí  // eslint-disable-next-line @typescript-eslint/no-explicit-any
    23‚Üí  export function fromThrowable<Fn extends (...args: readonly any[]) => any, E>(
    24‚Üí    fn: Fn,
    25‚Üí    errorFn?: (e: unknown) => E,
    26‚Üí  ): (...args: Parameters<Fn>) => Result<ReturnType<Fn>, E> {
    27‚Üí    return (...args) => {
    28‚Üí      try {
    29‚Üí        const result = fn(...args)
    30‚Üí        return ok(result)
    31‚Üí      } catch (e) {
    32‚Üí        return err(errorFn ? errorFn(e) : e)
    33‚Üí      }
    34‚Üí    }
    35‚Üí  }
    36‚Üí
    37‚Üí  export function combine<
    43‚Üí  export function combine
    55‚Üí  export function combineWithAllErrors

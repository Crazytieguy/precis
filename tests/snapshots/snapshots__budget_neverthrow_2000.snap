   427‚Üí    return !this.isOk()
   428‚Üí  }
   429‚Üí
   430‚Üí  // eslint-disable-next-line @typescript-eslint/no-unused-vars
   431‚Üí  map<A>(_f: (t: T) => A): Result<A, E> {
   432‚Üí    return err(this.error)
   433‚Üí  }
   434‚Üí
   435‚Üí  mapErr<U>(f: (e: E) => U): Result<T, U> {
   436‚Üí    return err(f(this.error))
   437‚Üí  }

   312‚Üíexport class Ok<T, E> implements IResult<T, E> {
   313‚Üí  constructor(readonly value: T) {}
   314‚Üí
   315‚Üí  isOk(): this is Ok<T, E> {
   316‚Üí    return true
   317‚Üí  }
   318‚Üí
   319‚Üí  isErr(): this is Err<T, E> {
   320‚Üí    return !this.isOk()
   321‚Üí  }
   322‚Üí
   323‚Üí  map<A>(f: (t: T) => A): Result<A, E> {
   324‚Üí    return ok(f(this.value))
   325‚Üí  }
   326‚Üí
   327‚Üí  // eslint-disable-next-line @typescript-eslint/no-unused-vars
   328‚Üí  mapErr<U>(_f: (e: E) => U): Result<T, U> {
   329‚Üí    return ok(this.value)
   330‚Üí  }
   331‚Üí

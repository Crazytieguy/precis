    14Рєњexport namespace Result {
    15Рєњ  /**
    16Рєњ   * Wraps a function with a try catch, creating a new function with the same
    17Рєњ   * arguments but returning `Ok` if successful, `Err` if the function throws
    18Рєњ   *
    19Рєњ   * @param fn function to wrap with ok on success or err on failure
    20Рєњ   * @param errorFn when an error is thrown, this will wrap the error result if provided
    21Рєњ   */
    22Рєњ  // eslint-disable-next-line @typescript-eslint/no-explicit-any
    23Рєњ  export function fromThrowable<Fn extends (...args: readonly any[]) => any, E>(
    24Рєњ    fn: Fn,
    25Рєњ    errorFn?: (e: unknown) => E,
    26Рєњ  ): (...args: Parameters<Fn>) => Result<ReturnType<Fn>, E> {
    27Рєњ    return (...args) => {
    28Рєњ      try {
    29Рєњ        const result = fn(...args)
    30Рєњ        return ok(result)
    31Рєњ      } catch (e) {
    32Рєњ        return err(errorFn ? errorFn(e) : e)
    33Рєњ      }
    34Рєњ    }
    35Рєњ  }
    36Рєњ
    37Рєњ  export function combine<
    38Рєњ    T extends readonly [Result<unknown, unknown>, ...Result<unknown, unknown>[]]
    39Рєњ  >(resultList: T): CombineResults<T>
    43Рєњ  export function combine Рђд

    30Рєњ/**
    31Рєњ * Short circuits on the FIRST Err value that we find
    32Рєњ */
    33Рєњexport const combineResultList = <T, E>(
    34Рєњ  resultList: readonly Result<T, E>[],
    35Рєњ): Result<readonly T[], E> => {
    36Рєњ  let acc = ok([]) as Result<T[], E>
    37Рєњ
    38Рєњ  for (const result of resultList) {
    39Рєњ    if (result.isErr()) {
    40Рєњ      acc = err(result.error)
    41Рєњ      break
    42Рєњ    } else {
    43Рєњ      acc.map((list) => list.push(result.value))
    44Рєњ    }
    45Рєњ  }
    46Рєњ  return acc
    47Рєњ}
    54Рєњexport const combineResultAsyncList = <T, E>(
    55Рєњ  asyncResultList: readonly ResultAsync<T, E>[],
    56Рєњ): ResultAsync<readonly T[], E> =>
    57Рєњ  ResultAsync.fromSafePromise(Promise.all(asyncResultList)).andThen(
    58Рєњ    combineResultList,
    59Рєњ  ) as ResultAsync<T[], E>
    61Рєњ/**
    62Рєњ * Give a list of all the errors we find
    63Рєњ */
    64Рєњexport const combineResultListWithAllErrors = <T, E>(
    65Рєњ  resultList: readonly Result<T, E>[],
    66Рєњ): Result<readonly T[], E[]> => {
    67Рєњ  let acc = ok([]) as Result<T[], E[]>
    68Рєњ
    69Рєњ  for (const result of resultList) {
    70Рєњ    if (result.isErr() && acc.isErr()) {
    71Рєњ      acc.error.push(result.error)
    72Рєњ    } else if (result.isErr() && acc.isOk()) {
    73Рєњ      acc = err([result.error])
    74Рєњ    } else if (result.isOk() && acc.isOk()) {
    75Рєњ      acc.value.push(result.value)
    76Рєњ    }
    77Рєњ    // do nothing when result.isOk() && acc.isErr()
    78Рєњ  }
    79Рєњ  return acc
    80Рєњ}
    82Рєњexport const combineResultAsyncListWithAllErrors = <T, E>(
    83Рєњ  asyncResultList: readonly ResultAsync<T, E>[],
    84Рєњ): ResultAsync<readonly T[], E[]> =>
    85Рєњ  ResultAsync.fromSafePromise(Promise.all(asyncResultList)).andThen(
    86Рєњ    combineResultListWithAllErrors,
    87Рєњ  ) as ResultAsync<T[], E[]>

     1Ôćĺimport { Result, ok, err } from '../result'
     2Ôćĺimport { ResultAsync } from '../result-async'
     5Ôćĺexport type ExtractOkTypes<T extends readonly Result<unknown, unknown>[]> = {
     6Ôćĺ  [idx in keyof T]: T[idx] extends Result<infer U, unknown> ? U : never
     7Ôćĺ}
    10Ôćĺexport type ExtractOkAsyncTypes<T extends readonly ResultAsync<unknown, unknown>[]> = {
    11Ôćĺ  [idx in keyof T]: T[idx] extends ResultAsync<infer U, unknown> ? U : never
    12Ôćĺ}
    15Ôćĺexport type ExtractErrTypes<T extends readonly Result<unknown, unknown>[]> = {
    16Ôćĺ  [idx in keyof T]: T[idx] extends Result<unknown, infer E> ? E : never
    17Ôćĺ}
    20Ôćĺexport type ExtractErrAsyncTypes<T extends readonly ResultAsync<unknown, unknown>[]> = {
    21Ôćĺ  [idx in keyof T]: T[idx] extends ResultAsync<unknown, infer E> ? E : never
    22Ôćĺ}
    24Ôćĺexport type InferOkTypes<R> = R extends Result<infer T, unknown> ? T : never
    25Ôćĺexport type InferErrTypes<R> = R extends Result<unknown, infer E> ? E : never
    27Ôćĺexport type InferAsyncOkTypes<R> = R extends ResultAsync<infer T, unknown> ? T : never
    28Ôćĺexport type InferAsyncErrTypes<R> = R extends ResultAsync<unknown, infer E> ? E : never
    30Ôćĺ/**
    31Ôćĺ * Short circuits on the FIRST Err value that we find
    32Ôćĺ */
    33Ôćĺexport const combineResultList = <T, E>(
    34Ôćĺ  resultList: readonly Result<T, E>[],
    35Ôćĺ): Result<readonly T[], E> => {
    36Ôćĺ  let acc = ok([]) as Result<T[], E>
    37Ôćĺ
    38Ôćĺ  for (const result of resultList) {
    39Ôćĺ    if (result.isErr()) {
    40Ôćĺ      acc = err(result.error)
    41Ôćĺ      break
    42Ôćĺ    } else {
    43Ôćĺ      acc.map((list) => list.push(result.value))
    44Ôćĺ    }
    45Ôćĺ  }
    46Ôćĺ  return acc
    47Ôćĺ}
    54Ôćĺexport const combineResultAsyncList = <T, E>(
    55Ôćĺ  asyncResultList: readonly ResultAsync<T, E>[],
    56Ôćĺ): ResultAsync<readonly T[], E> =>
    57Ôćĺ  ResultAsync.fromSafePromise(Promise.all(asyncResultList)).andThen(
    58Ôćĺ    combineResultList,
    59Ôćĺ  ) as ResultAsync<T[], E>
    61Ôćĺ/**
    62Ôćĺ * Give a list of all the errors we find
    63Ôćĺ */
    64Ôćĺexport const combineResultListWithAllErrors = <T, E>(
    65Ôćĺ  resultList: readonly Result<T, E>[],
    66Ôćĺ): Result<readonly T[], E[]> => {
    67Ôćĺ  let acc = ok([]) as Result<T[], E[]>
    68Ôćĺ
    69Ôćĺ  for (const result of resultList) {
    70Ôćĺ    if (result.isErr() && acc.isErr()) {
    71Ôćĺ      acc.error.push(result.error)
    72Ôćĺ    } else if (result.isErr() && acc.isOk()) {
    73Ôćĺ      acc = err([result.error])
    74Ôćĺ    } else if (result.isOk() && acc.isOk()) {
    75Ôćĺ      acc.value.push(result.value)
    76Ôćĺ    }
    77Ôćĺ    // do nothing when result.isOk() && acc.isErr()
    78Ôćĺ  }

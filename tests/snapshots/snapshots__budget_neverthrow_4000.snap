    10→import { Err, Ok, Result } from './ …
    11→./_internals/utils …
    22→export class ResultAsync<T, E> implements PromiseLike<Result<T, E>> {
    23→  private _promise: Promise<Result<T, E>>
    24→
    25→  constructor(res: Promise<Result<T, E>>) {
    26→    this._promise = res
    27→  }
    28→
    29→  static fromSafePromise<T, E = never>(promise: PromiseLike<T>): ResultAsync<T, E>
    30→  static fromSafePromise<T, E = never>(promise: Promise<T>): ResultAsync<T, E> {
    31→    const newPromise = promise.then((value: T) => new Ok<T, E>(value))
    32→
    33→    return new ResultAsync(newPromise)
    34→  }
    35→
    36→  static fromPromise<T, E>(promise: PromiseLike<T>, errorFn: (e: unknown) => E): ResultAsync<T, E>
    37→  static fromPromise<T, E>(promise: Promise<T>, errorFn: (e: unknown) => E): ResultAsync<T, E> {
    38→    const newPromise = promise
    39→      .then((value: T) => new Ok<T, E>(value))
    40→      .catch((e) => new Err<T, E>(errorFn(e)))
    41→
    42→    return new ResultAsync(newPromise)
    43→  }

     3‚Üíexport interface ErrorConfig {
     4‚Üí  withStackTrace: boolean
     5‚Üí}
     7‚Üíconst defaultErrorConfig: ErrorConfig = {
     8‚Üí  withStackTrace: false,
     9‚Üí}
    11‚Üíinterface NeverThrowError<T, E> {
    12‚Üí  data:
    13‚Üí    | {
    14‚Üí        type: string
    15‚Üí        value: T
    16‚Üí      }
    17‚Üí    | {
    18‚Üí        type: string
    19‚Üí        value: E
    20‚Üí      }
    21‚Üí  message: string
    22‚Üí  stack: string | undefined
    23‚Üí}
    27‚Üíexport const createNeverThrowError = <T, E>(
    28‚Üí  message: string,
    29‚Üí  result: Result<T, E>,
    30‚Üí  config: ErrorConfig = defaultErrorConfig,
    31‚Üí): NeverThrowError<T, E> => {
    32‚Üí  const data = result.isOk()
    33‚Üí    ? { type: 'Ok', value: result.value }
    34‚Üí    : { type: 'Err', value: result.error }
    35‚Üí
    36‚Üí  const maybeStack = config.withStackTrace ? new Error().stack : undefined
    37‚Üí
    38‚Üí  return {
    39‚Üí    data,
    40‚Üí    message,
    41‚Üí    stack: maybeStack,
    42‚Üí  }
    43‚Üí}
src/_internals/utils.ts
     5‚Üíexport type ExtractOkTypes<T extends readonly Result<unknown, unknown>[]> = {
     6‚Üí  [idx in keyof T]: T[idx] extends Result<infer U, unknown> ? U : never
     7‚Üí}
    10‚Üíexport type ExtractOkAsyncTypes<T extends readonly ResultAsync<unknown, unknown>[]> = {
    11‚Üí  [idx in keyof T]: T[idx] extends ResultAsync<infer U, unknown> ? U : never
    12‚Üí}
    15‚Üíexport type ExtractErrTypes<T extends readonly Result<unknown, unknown>[]> = {
    16‚Üí  [idx in keyof T]: T[idx] extends Result<unknown, infer E> ? E : never
    17‚Üí}
    20‚Üíexport type ExtractErrAsyncTypes<T extends readonly ResultAsync<unknown, unknown>[]> = {
    21‚Üí  [idx in keyof T]: T[idx] extends ResultAsync<unknown, infer E> ? E : never
    22‚Üí}
    24‚Üíexport type InferOkTypes<R> = R extends Result<infer T, unknown> ? T : never
    25‚Üíexport type InferErrTypes<R> = R extends Result<unknown, infer E> ? E : never
    27‚Üíexport type InferAsyncOkTypes<R> = R extends ResultAsync<infer T, unknown> ? T : never
    28‚Üíexport type InferAsyncErrTypes<R> = R extends ResultAsync<unknown, infer E> ? E : never
    30‚Üí/**
    31‚Üí * Short circuits on the FIRST Err value that we find
    32‚Üí */
    33‚Üíexport const combineResultList = <T, E>(
    34‚Üí  resultList: readonly Result<T, E>[],
    35‚Üí): Result<readonly T[], E> => {
    36‚Üí  let acc = ok([]) as Result<T[], E>
    37‚Üí
    38‚Üí  for (const result of resultList) {
    39‚Üí    if (result.isErr()) {
    40‚Üí      acc = err(result.error)
    41‚Üí      break
    42‚Üí    } else {
    43‚Üí      acc.map((list) => list.push(result.value))
    44‚Üí    }
    45‚Üí  }
    46‚Üí  return acc
    47‚Üí}
    54‚Üíexport const combineResultAsyncList = <T, E>(
    55‚Üí  asyncResultList: readonly ResultAsync<T, E>[],
    56‚Üí): ResultAsync<readonly T[], E> =>
    57‚Üí  ResultAsync.fromSafePromise(Promise.all(asyncResultList)).andThen(
    58‚Üí    combineResultList,
    59‚Üí  ) as ResultAsync<T[], E>
    61‚Üí/**
    62‚Üí * Give a list of all the errors we find
    63‚Üí */
    64‚Üíexport const combineResultListWithAllErrors = <T, E>(
    65‚Üí  resultList: readonly Result<T, E>[],
    66‚Üí): Result<readonly T[], E[]> => {
    67‚Üí  let acc = ok([]) as Result<T[], E[]>
    68‚Üí
    69‚Üí  for (const result of resultList) {
    70‚Üí    if (result.isErr() && acc.isErr()) {
    71‚Üí      acc.error.push(result.error)
    72‚Üí    } else if (result.isErr() && acc.isOk()) {
    73‚Üí      acc = err([result.error])
    74‚Üí    } else if (result.isOk() && acc.isOk()) {
    75‚Üí      acc.value.push(result.value)
    76‚Üí    }
    77‚Üí    // do nothing when result.isOk() && acc.isErr()
    78‚Üí  }
    79‚Üí  return acc
    80‚Üí}
    82‚Üíexport const combineResultAsyncListWithAllErrors = <T, E>(
    83‚Üí  asyncResultList: readonly ResultAsync<T, E>[],
    84‚Üí): ResultAsync<readonly T[], E[]> =>
    85‚Üí  ResultAsync.fromSafePromise(Promise.all(asyncResultList)).andThen(
    86‚Üí    combineResultListWithAllErrors,
    87‚Üí  ) as ResultAsync<T[], E[]>
src/result-async.ts
    22‚Üíexport class ResultAsync<T, E> implements PromiseLike<Result<T, E>> {
    23‚Üí  private _promise: Promise<Result<T, E>>
    24‚Üí
    25‚Üí  constructor(res: Promise<Result<T, E>>) {
    26‚Üí    this._promise = res
    27‚Üí  }
    28‚Üí
    29‚Üí  static fromSafePromise<T, E = never>(promise: PromiseLike<T>): ResultAsync<T, E>
    30‚Üí  static fromSafePromise<T, E = never>(promise: Promise<T>): ResultAsync<T, E> {
    31‚Üí    const newPromise = promise.then((value: T) => new Ok<T, E>(value))
    32‚Üí
    33‚Üí    return new ResultAsync(newPromise)
    34‚Üí  }
    35‚Üí
    36‚Üí  static fromPromise<T, E>(promise: PromiseLike<T>, errorFn: (e: unknown) => E): ResultAsync<T, E>
    37‚Üí  static fromPromise<T, E>(promise: Promise<T>, errorFn: (e: unknown) => E): ResultAsync<T, E> {
    38‚Üí    const newPromise = promise
    39‚Üí      .then((value: T) => new Ok<T, E>(value))
    40‚Üí      .catch((e) => new Err<T, E>(errorFn(e)))
    41‚Üí
    42‚Üí    return new ResultAsync(newPromise)
    43‚Üí  }
    44‚Üí
    45‚Üí  // eslint-disable-next-line @typescript-eslint/no-explicit-any
    46‚Üí  static fromThrowable<A extends readonly any[], R, E>(
    47‚Üí    fn: (...args: A) => Promise<R>,
    48‚Üí    errorFn?: (err: unknown) => E,
    49‚Üí  ): (...args: A) => ResultAsync<R, E> {
    50‚Üí    return (...args) => {
    51‚Üí      return new ResultAsync(
    52‚Üí        (async () => {
    53‚Üí          try {
    54‚Üí            return new Ok(await fn(...args))
    55‚Üí          } catch (error) {
    56‚Üí            return new Err(errorFn ? errorFn(error) : error)
    57‚Üí          }
    58‚Üí        })(),
    59‚Üí      )

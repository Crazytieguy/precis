    22Ôćĺexport class ResultAsync<T, E> implements PromiseLike<Result<T, E>> {
    23Ôćĺ  private _promise: Promise<Result<T, E>>
    24Ôćĺ
    25Ôćĺ  constructor(res: Promise<Result<T, E>>) {
    26Ôćĺ    this._promise = res
    27Ôćĺ  }
    28Ôćĺ
    29Ôćĺ  static fromSafePromise<T, E = never>(promise: PromiseLike<T>): ResultAsync<T, E>
    30Ôćĺ  static fromSafePromise<T, E = never>(promise: Promise<T>): ResultAsync<T, E> {
    31Ôćĺ    const newPromise = promise.then((value: T) => new Ok<T, E>(value))
    32Ôćĺ
    33Ôćĺ    return new ResultAsync(newPromise)
    34Ôćĺ  }
    35Ôćĺ
    36Ôćĺ  static fromPromise<T, E>(promise: PromiseLike<T>, errorFn: (e: unknown) => E): ResultAsync<T, E>
    37Ôćĺ  static fromPromise<T, E>(promise: Promise<T>, errorFn: (e: unknown) => E): ResultAsync<T, E> {
    38Ôćĺ    const newPromise = promise
    39Ôćĺ      .then((value: T) => new Ok<T, E>(value))
    40Ôćĺ      .catch((e) => new Err<T, E>(errorFn(e)))
    41Ôćĺ
    42Ôćĺ    return new ResultAsync(newPromise)
    43Ôćĺ  }
    44Ôćĺ
    45Ôćĺ  // eslint-disable-next-line @typescript-eslint/no-explicit-any
    46Ôćĺ  static fromThrowable<A extends readonly any[], R, E>(
    47Ôćĺ    fn: (...args: A) => Promise<R>,
    48Ôćĺ    errorFn?: (err: unknown) => E,
    49Ôćĺ  ): (...args: A) => ResultAsync<R, E> {
    50Ôćĺ    return (...args) => {
    51Ôćĺ      return new ResultAsync(
    52Ôćĺ        (async () => {
    53Ôćĺ          try {
    54Ôćĺ            return new Ok(await fn(...args))
    55Ôćĺ          } catch (error) {
    56Ôćĺ            return new Err(errorFn ? errorFn(error) : error)
    57Ôćĺ          }
    58Ôćĺ        })(),
    59Ôćĺ      )
    60Ôćĺ    }
    61Ôćĺ  }
    62Ôćĺ
    63Ôćĺ  static combine<
    64Ôćĺ    T extends readonly [ResultAsync<unknown, unknown>, ...ResultAsync<unknown, unknown>[]]
    65Ôćĺ  >(asyncResultList: T): CombineResultAsyncs<T>
    66Ôćĺ  static combine<T extends readonly ResultAsync<unknown, unknown>[]>(
    67Ôćĺ    asyncResultList: T,
    68Ôćĺ  ): CombineResultAsyncs<T>
    69Ôćĺ  static combine<T extends readonly ResultAsync<unknown, unknown>[]>(
    70Ôćĺ    asyncResultList: T,
    71Ôćĺ  ): CombineResultAsyncs<T> {
    72Ôćĺ    return (combineResultAsyncList(asyncResultList) as unknown) as CombineResultAsyncs<T>
    73Ôćĺ  }
    74Ôćĺ
    75Ôćĺ  static combineWithAllErrors<
    76Ôćĺ    T extends readonly [ResultAsync<unknown, unknown>, ...ResultAsync<unknown, unknown>[]]
    77Ôćĺ  >(asyncResultList: T): CombineResultsWithAllErrorsArrayAsync<T>
    78Ôćĺ  static combineWithAllErrors<T extends readonly ResultAsync<unknown, unknown>[]>(
    79Ôćĺ    asyncResultList: T,
    81Ôćĺ  static combineWithAllErrors

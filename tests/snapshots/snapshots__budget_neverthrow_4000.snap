     1Ôćĺimport { Result } from '../result'
     3Ôćĺexport interface ErrorConfig {
     4Ôćĺ  withStackTrace: boolean
     5Ôćĺ}
     7Ôćĺconst defaultErrorConfig: ErrorConfig = {
     8Ôćĺ  withStackTrace: false,
     9Ôćĺ}
    11Ôćĺinterface NeverThrowError<T, E> {
    12Ôćĺ  data:
    13Ôćĺ    | {
    14Ôćĺ        type: string
    15Ôćĺ        value: T
    16Ôćĺ      }
    17Ôćĺ    | {
    18Ôćĺ        type: string
    19Ôćĺ        value: E
    20Ôćĺ      }
    21Ôćĺ  message: string
    22Ôćĺ  stack: string | undefined
    23Ôćĺ}
    27Ôćĺexport const createNeverThrowError = <T, E>(
    28Ôćĺ  message: string,
    29Ôćĺ  result: Result<T, E>,
    30Ôćĺ  config: ErrorConfig = defaultErrorConfig,
    31Ôćĺ): NeverThrowError<T, E> => {
    32Ôćĺ  const data = result.isOk()
    33Ôćĺ    ? { type: 'Ok', value: result.value }
    34Ôćĺ    : { type: 'Err', value: result.error }
    35Ôćĺ
    36Ôćĺ  const maybeStack = config.withStackTrace ? new Error().stack : undefined
    37Ôćĺ
    38Ôćĺ  return {
    39Ôćĺ    data,
    40Ôćĺ    message,
    41Ôćĺ    stack: maybeStack,
    42Ôćĺ  }
    43Ôćĺ}

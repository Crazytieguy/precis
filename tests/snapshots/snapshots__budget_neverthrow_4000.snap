   134‚Üíinterface IResult<T, E> {
   135‚Üí  /**
   136‚Üí   * Used to check if a `Result` is an `OK`
   137‚Üí   *
   138‚Üí   * @returns `true` if the result is an `OK` variant of Result
   139‚Üí   */
   140‚Üí  isOk(): this is Ok<T, E>
   142‚Üí  /**
   143‚Üí   * Used to check if a `Result` is an `Err`
   144‚Üí   *
   145‚Üí   * @returns `true` if the result is an `Err` variant of Result
   146‚Üí   */
   147‚Üí  isErr(): this is Err<T, E>
   149‚Üí  /**
   150‚Üí   * Maps a `Result<T, E>` to `Result<U, E>`
   151‚Üí   * by applying a function to a contained `Ok` value, leaving an `Err` value
   152‚Üí   * untouched.
   153‚Üí   *
   154‚Üí   * @param f The function to apply an `OK` value
   155‚Üí   * @returns the result of applying `f` or an `Err` untouched
   156‚Üí   */
   157‚Üí  map<A>(f: (t: T) => A): Result<A, E>
   159‚Üí  /**
   160‚Üí   * Maps a `Result<T, E>` to `Result<T, F>` by applying a function to a
   161‚Üí   * contained `Err` value, leaving an `Ok` value untouched.
   162‚Üí   *
   163‚Üí   * This function can be used to pass through a successful result while
   164‚Üí   * handling an error.
   165‚Üí   *
   166‚Üí   * @param f a function to apply to the error `Err` value
   167‚Üí   */
   168‚Üí  mapErr<U>(f: (e: E) => U): Result<T, U>
   183‚Üí  andThen ‚Ä¶
   185‚Üí  /**
   186‚Üí   * This "tee"s the current value to an passed-in computation such as side
   187‚Üí   * effect functions but still returns the same current value as the result.
   188‚Üí   *
   189‚Üí   * This is useful when you want to pass the current result to your side-track
   190‚Üí   * work such as logging but want to continue main-track work after that.
   191‚Üí   * This method does not care about the result of the passed in computation.
   192‚Üí   *
   193‚Üí   * @param f The function to apply to the current value
   194‚Üí   */
   195‚Üí  andTee(f: (t: T) => unknown): Result<T, E>
   197‚Üí  /**
   198‚Üí   * This "tee"s the current `Err` value to an passed-in computation such as side
   199‚Üí   * effect functions but still returns the same `Err` value as the result.
   200‚Üí   *
   201‚Üí   * This is useful when you want to pass the current `Err` value to your side-track
   202‚Üí   * work such as logging but want to continue error-track work after that.
   203‚Üí   * This method does not care about the result of the passed in computation.
   204‚Üí   *
   205‚Üí   * @param f The function to apply to the current `Err` value
   206‚Üí   */
   207‚Üí  orTee(f: (t: E) => unknown): Result<T, E>
   219‚Üí  andThrough ‚Ä¶
   233‚Üí  orElse ‚Ä¶
   235‚Üí  /**
   236‚Üí   * Similar to `map` Except you must return a new `Result`.
   237‚Üí   *
   238‚Üí   * This is useful for when you need to do a subsequent async computation using
   239‚Üí   * the inner `T` value, but that computation might fail. Must return a ResultAsync
   240‚Üí   *
   241‚Üí   * @param f The function that returns a `ResultAsync` to apply to the current
   242‚Üí   * value
   243‚Üí   */
   244‚Üí  asyncAndThen<U, F>(f: (t: T) => ResultAsync<U, F>): ResultAsync<U, E | F>
   246‚Üí  /**
   247‚Üí   * Maps a `Result<T, E>` to `ResultAsync<U, E>`
   248‚Üí   * by applying an async function to a contained `Ok` value, leaving an `Err`
   249‚Üí   * value untouched.
   250‚Üí   *
   251‚Üí   * @param f An async function to apply an `OK` value
   252‚Üí   */
   253‚Üí  asyncMap<U>(f: (t: T) => Promise<U>): ResultAsync<U, E>
   255‚Üí  /**
   256‚Üí   * Unwrap the `Ok` value, or return the default if there is an `Err`
   257‚Üí   *
   258‚Üí   * @param v the default value to return if there is an `Err`
   259‚Üí   */
   260‚Üí  unwrapOr<A>(v: A): T | A
   262‚Üí  /**
   263‚Üí   *
   264‚Üí   * Given 2 functions (one for the `Ok` variant and one for the `Err` variant)
   265‚Üí   * execute the function that matches the `Result` variant.
   266‚Üí   *
   267‚Üí   * Match callbacks do not necessitate to return a `Result`, however you can
   268‚Üí   * return a `Result` if you want to.
   269‚Üí   *
   270‚Üí   * `match` is like chaining `map` and `mapErr`, with the distinction that
   271‚Üí   * with `match` both functions must have the same return type.
   272‚Üí   *
   273‚Üí   * @param ok
   274‚Üí   * @param err
   275‚Üí   */
   276‚Üí  match<A, B = A>(ok: (t: T) => A, err: (e: E) => B): A | B
   278‚Üí  /**
   279‚Üí   * @deprecated will be removed in 9.0.0.
   280‚Üí   *
   281‚Üí   * You can use `safeTry` without this method.
   282‚Üí   * @example
   283‚Üí   * ```typescript
   284‚Üí   * safeTry(function* () {
   285‚Üí   *   const okValue = yield* yourResult
   286‚Üí   * })
   287‚Üí   * ```
   288‚Üí   * Emulates Rust's `?` operator in `safeTry`'s body. See also `safeTry`.
   289‚Üí   */
   290‚Üí  safeUnwrap(): Generator<Err<never, E>, T>
   292‚Üí  /**
   293‚Üí   * **This method is unsafe, and should only be used in a test environments**
   294‚Üí   *
   295‚Üí   * Takes a `Result<T, E>` and returns a `T` when the result is an `Ok`, otherwise it throws a custom object.
   296‚Üí   *
   297‚Üí   * @param config
   298‚Üí   */
   299‚Üí  _unsafeUnwrap(config?: ErrorConfig): T
   301‚Üí  /**
   302‚Üí   * **This method is unsafe, and should only be used in a test environments**
   303‚Üí   *
   304‚Üí   * takes a `Result<T, E>` and returns a `E` when the result is an `Err`,
   305‚Üí   * otherwise it throws a custom object.
   306‚Üí   *
   307‚Üí   * @param config
   308‚Üí   */
   309‚Üí  _unsafeUnwrapErr(config?: ErrorConfig): E

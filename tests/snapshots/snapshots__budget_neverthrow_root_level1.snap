   649→  : T
   652→export type MemberListOf<T> = (
   653→  (T extends unknown ? (t: T) => T : never) extends infer U
   654→    ? (U extends unknown ? (u: U) => unknown : never) extends (v: infer V) => unknown
   655→      ? V
   656→      : never
   657→    : never
   658→) extends (_: unknown) => infer W
   659→  ? [...MemberListOf<Exclude<T, W>>, W]
   660→  : []
   669→export type EmptyArrayToNever<T, NeverArrayToNever extends number = 0> = T extends []
   670→  ? never
   671→  : NeverArrayToNever extends 1
   672→  ? T extends [never, ...infer Rest]
   673→    ? [EmptyArrayToNever<Rest>] extends [never]
   674→      ? never
   675→      : T
   676→    : T
   677→  : T
   680→type UnknownMembersToNever
   685→export type MembersToUnion<T> = T extends unknown[] ? T[number] : never
   688→export type IsLiteralArray<T> = T extends { length: infer L }
   689→  ? L extends number
   690→    ? number extends L
   691→      ? 0
   692→      : 1
   693→    : 0
   694→  : 0

   289â†’  // itself is a union therefore it would be enough to cast it to Ok.
   290â†’  T extends Array<infer A>
   291â†’  ? A extends PromiseLike<infer HI>
   292â†’    ? HI extends Result<infer L, infer R>
   293â†’      ? Ok<L, R>[]
   294â†’      : never
   295â†’    : never
   296â†’  : never
   300â†’type TraverseAsync<T, Depth extends number = 5> = IsLiteralArray<T> extends 1
   301â†’  ? Combine<T, Depth> extends [infer Oks, infer Errs]
   302â†’    ? ResultAsync<EmptyArrayToNever<Oks>, MembersToUnion<Errs>>
   303â†’    : never
   304â†’  : // The following check is important if we somehow reach to the point of
   305â†’  // checking something similar to ResultAsync<X, Y>[]. In this case we don't
   306â†’  // know the length of the elements, therefore we need to traverse the X and Y
   307â†’  // in a way that the result should contain X[] and Y[].
   308â†’  T extends Array<infer I>
   309â†’  ? // The MemberListOf<I> here is to include all possible types. Therefore
   310â†’    // if we face (ResultAsync<X, Y> | ResultAsync<A, B>)[] this type should
   311â†’    // handle the case.
   312â†’    Combine<MemberListOf<I>, Depth> extends [infer Oks, infer Errs]
   313â†’    ? // The following `extends unknown[]` checks are just to satisfy the TS.
   314â†’      // we already expect them to be an array.
   315â†’      Oks extends unknown[]
   316â†’      ? Errs extends unknown[]
   317â†’        ? ResultAsync<EmptyArrayToNever<Oks[number][]>, MembersToUnion<Errs[number][]>>
   318â†’        : ResultAsync<EmptyArrayToNever<Oks[number][]>, Errs>
   319â†’      : // The rest of the conditions are to satisfy the TS and support
   320â†’      // the edge cases which are not really expected to happen.
   321â†’      Errs extends unknown[]
   322â†’      ? ResultAsync<Oks, MembersToUnion<Errs[number][]>>
   323â†’      : ResultAsync<Oks, Errs>
   324â†’    : never
   325â†’  : never
   330â†’type TraverseWithAllErrorsAsync<T, Depth extends number = 5> = TraverseAsync<
   331â†’  T,
   332â†’  Depth
   333â†’> extends ResultAsync<infer Oks, infer Errs>
   334â†’  ? ResultAsync<Oks, Errs[]>
   335â†’  : never
   338â†’type Writable<T> = T extends ReadonlyArray<unknown> ? [...T] : T

    14â†’export namespace Result {
    23â†’  export function fromThrowable<Fn extends (...args: readonly any[]) => any, E>(
    24â†’    fn: Fn,
    25â†’    errorFn?: (e: unknown) => E,
    26â†’  ): (...args: Parameters<Fn>) => Result<ReturnType<Fn>, E> {
    43â†’  export function combine<
    44â†’    T extends readonly [Result<unknown, unknown>, ...Result<unknown, unknown>[]]
    45â†’  >(resultList: T): CombineResults<T> {
    55â†’  export function combineWithAllErrors<T extends readonly Result<unknown, unknown>[]>(
    56â†’    resultList: T,
    57â†’  ): CombineResultsWithAllErrorsArray<T> {
    62â†’export type Result<T, E> = Ok<T, E> | Err<T, E>
    66â†’export function ok<T, E = never>(value: T): Ok<T, E> {
    73â†’export function err<T = never, E = unknown>(err: E): Err<T, E> {
   122â†’export function safeTry<T, E>(
   123â†’  body:
   124â†’    | (() => Generator<Err<never, E>, Result<T, E>>)
   125â†’    | (() => AsyncGenerator<Err<never, E>, Result<T, E>>),
   126â†’): Result<T, E> | ResultAsync<T, E> {
   134â†’interface IResult<T, E> {
   136â†’   * Used to check if a `Result` is an `OK`
   140â†’  isOk(): this is Ok<T, E>
   143â†’   * Used to check if a `Result` is an `Err`
   147â†’  isErr(): this is Err<T, E>
   150â†’   * Maps a `Result<T, E>` to `Result<U, E>`
   157â†’  map<A>(f: (t: T) => A): Result<A, E>
   160â†’   * Maps a `Result<T, E>` to `Result<T, F>` by applying a function to a
   168â†’  mapErr<U>(f: (e: E) => U): Result<T, U>
   183â†’  andThen<U, F>(f: (t: T) => Result<U, F>): Result<U, E | F>
   186â†’   * This "tee"s the current value to an passed-in computation such as side
   195â†’  andTee(f: (t: T) => unknown): Result<T, E>
   198â†’   * This "tee"s the current `Err` value to an passed-in computation such as side
   207â†’  orTee(f: (t: E) => unknown): Result<T, E>
   219â†’  andThrough<F>(f: (t: T) => Result<unknown, F>): Result<T, E | F>
   233â†’  orElse<U, A>(f: (e: E) => Result<U, A>): Result<U | T, A>
   236â†’   * Similar to `map` Except you must return a new `Result`.
   244â†’  asyncAndThen<U, F>(f: (t: T) => ResultAsync<U, F>): ResultAsync<U, E | F>
   247â†’   * Maps a `Result<T, E>` to `ResultAsync<U, E>`
   253â†’  asyncMap<U>(f: (t: T) => Promise<U>): ResultAsync<U, E>
   256â†’   * Unwrap the `Ok` value, or return the default if there is an `Err`
   260â†’  unwrapOr<A>(v: A): T | A
   264â†’   * Given 2 functions (one for the `Ok` variant and one for the `Err` variant)
   276â†’  match<A, B = A>(ok: (t: T) => A, err: (e: E) => B): A | B
   279â†’   * @deprecated will be removed in 9.0.0.
   290â†’  safeUnwrap(): Generator<Err<never, E>, T>
   293â†’   * **This method is unsafe, and should only be used in a test environments**
   299â†’  _unsafeUnwrap(config?: ErrorConfig): T
   302â†’   * **This method is unsafe, and should only be used in a test environments**
   309â†’  _unsafeUnwrapErr(config?: ErrorConfig): E
   312â†’export class Ok<T, E> implements IResult<T, E> {
   313â†’  constructor(readonly value: T) {}
   315â†’  isOk(): this is Ok<T, E> {
   319â†’  isErr(): this is Err<T, E> {
   323â†’  map<A>(f: (t: T) => A): Result<A, E> {
   328â†’  mapErr<U>(_f: (e: E) => U): Result<T, U> {
   337â†’  andThen(f: any): any {
   344â†’  andThrough(f: any): any {
   348â†’  andTee(f: (t: T) => unknown): Result<T, E> {
   357â†’  orTee(_f: (t: E) => unknown): Result<T, E> {
   366â†’  orElse(_f: any): any {
   370â†’  asyncAndThen<U, F>(f: (t: T) => ResultAsync<U, F>): ResultAsync<U, E | F> {
   379â†’  asyncAndThrough(f: (t: T) => ResultAsync<unknown, unknown>): any {
   383â†’  asyncMap<U>(f: (t: T) => Promise<U>): ResultAsync<U, E> {
   388â†’  unwrapOr<A>(_v: A): T | A {
   393â†’  match<A, B = A>(ok: (t: T) => A, _err: (e: E) => B): A | B {
   397â†’  safeUnwrap(): Generator<Err<never, E>, T> {
   405â†’  _unsafeUnwrap(_?: ErrorConfig): T {
   409â†’  _unsafeUnwrapErr(config?: ErrorConfig): E {
   419â†’export class Err<T, E> implements IResult<T, E> {
   420â†’  constructor(readonly error: E) {}
   422â†’  isOk(): this is Ok<T, E> {
   426â†’  isErr(): this is Err<T, E> {
   431â†’  map<A>(_f: (t: T) => A): Result<A, E> {
   435â†’  mapErr<U>(f: (e: E) => U): Result<T, U> {
   439â†’  andThrough<F>(_f: (t: T) => Result<unknown, F>): Result<T, E | F> {
   443â†’  andTee(_f: (t: T) => unknown): Result<T, E> {
   447â†’  orTee(f: (t: E) => unknown): Result<T, E> {
   461â†’  andThen(_f: any): any {
   470â†’  orElse(f: any): any {
   475â†’  asyncAndThen<U, F>(_f: (t: T) => ResultAsync<U, F>): ResultAsync<U, E | F> {
   479â†’  asyncAndThrough<F>(_f: (t: T) => ResultAsync<unknown, F>): ResultAsync<T, E | F> {
   484â†’  asyncMap<U>(_f: (t: T) => Promise<U>): ResultAsync<U, E> {
   488â†’  unwrapOr<A>(v: A): T | A {
   492â†’  match<A, B = A>(_ok: (t: T) => A, err: (e: E) => B): A | B {
   496â†’  safeUnwrap(): Generator<Err<never, E>, T> {
   505â†’  _unsafeUnwrap(config?: ErrorConfig): T {
   509â†’  _unsafeUnwrapErr(_?: ErrorConfig): E {

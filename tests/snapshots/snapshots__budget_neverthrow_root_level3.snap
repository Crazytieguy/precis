   590â†’type CollectResults<T, Collected extends unknown[] = [], Depth extends number = 50> = [
   591â†’  Depth,
   592â†’] extends [never]
   593â†’  ? []
   594â†’  : T extends [infer H, ...infer Rest]
   595â†’  ? // And test whether the head of the list is a result
   596â†’    H extends Result<infer L, infer R>
   597â†’    ? // Continue collecting...
   598â†’      CollectResults<
   599â†’        // the rest of the elements
   600â†’        Rest,
   601â†’        // The collected
   602â†’        [...Collected, [L, R]],
   603â†’        // and one less of the current depth
   604â†’        Prev[Depth]
   605â†’      >
   606â†’    : never // Impossible
   607â†’  : Collected
   614â†’export type Transpose<
   615â†’  A,
   616â†’  Transposed extends unknown[][] = [],
   617â†’  Depth extends number = 10
   618â†’> = A extends [infer T, ...infer Rest]
   619â†’  ? T extends [infer L, infer R]
   620â†’    ? Transposed extends [infer PL, infer PR]
   621â†’      ? PL extends unknown[]
   622â†’        ? PR extends unknown[]
   623â†’          ? Transpose<Rest, [[...PL, L], [...PR, R]], Prev[Depth]>
   624â†’          : never
   625â†’        : never
   626â†’      : Transpose<Rest, [[L], [R]], Prev[Depth]>
   627â†’    : Transposed
   628â†’  : Transposed
   635â†’export type Combine<T, Depth extends number = 5> = Transpose<CollectResults<T>, [], Depth> extends [
   636â†’  infer L,
   637â†’  infer R,
   638â†’]
   639â†’  ? [UnknownMembersToNever<L>, UnknownMembersToNever<R>]
   640â†’  : Transpose<CollectResults<T>, [], Depth> extends []
   641â†’  ? [[], []]
   642â†’  : never
   645â†’export type Dedup<T> = T extends Result<infer RL, infer RR>
   646â†’  ? [unknown] extends [RL]
   647â†’    ? Err<RL, RR>
   648â†’    : Ok<RL, RR>
   649â†’  : T
   652â†’export type MemberListOf<T> = (
   653â†’  (T extends unknown ? (t: T) => T : never) extends infer U
   654â†’    ? (U extends unknown ? (u: U) => unknown : never) extends (v: infer V) => unknown
   655â†’      ? V
   656â†’      : never
   657â†’    : never
   658â†’) extends (_: unknown) => infer W
   659â†’  ? [...MemberListOf<Exclude<T, W>>, W]
   660â†’  : []
   669â†’export type EmptyArrayToNever<T, NeverArrayToNever extends number = 0> = T extends []
   670â†’  ? never
   671â†’  : NeverArrayToNever extends 1
   672â†’  ? T extends [never, ...infer Rest]
   673â†’    ? [EmptyArrayToNever<Rest>] extends [never]
   674â†’      ? never
   675â†’      : T
   676â†’    : T
   677â†’  : T
   680â†’type UnknownMembersToNever<T> = T extends [infer H, ...infer R]
   681â†’  ? [[unknown] extends [H] ? never : H, ...UnknownMembersToNever<R>]
   682â†’  : T
   685â†’export type MembersToUnion<T> = T extends unknown[] ? T[number] : never
   688â†’export type IsLiteralArray<T> = T extends { length: infer L }
   689â†’  ? L extends number
   690â†’    ? number extends L
   691â†’      ? 0
   692â†’      : 1
   693â†’    : 0
   694â†’  : 0
   698â†’type Traverse<T, Depth extends number = 5> = Combine<T, Depth> extends [infer Oks, infer Errs]
   699â†’  ? Result<EmptyArrayToNever<Oks, 1>, MembersToUnion<Errs>>
   700â†’  : never
   704â†’type TraverseWithAllErrors<T, Depth extends number = 5> = Traverse<T, Depth> extends Result<
   705â†’  infer Oks,
   706â†’  infer Errs
   707â†’>
   708â†’  ? Result<Oks, Errs[]>
   709â†’  : never
   712â†’export type CombineResults<
   713â†’  T extends readonly Result<unknown, unknown>[]
   714â†’> = IsLiteralArray<T> extends 1
   715â†’  ? Traverse<T>
   716â†’  : Result<ExtractOkTypes<T>, ExtractErrTypes<T>[number]>
   719â†’export type CombineResultsWithAllErrorsArray<
   720â†’  T extends readonly Result<unknown, unknown>[]
   721â†’> = IsLiteralArray<T> extends 1
   722â†’  ? TraverseWithAllErrors<T>
   723â†’  : Result<ExtractOkTypes<T>, ExtractErrTypes<T>[number][]>

   259‚Üíexport const fromPromise = ResultAsync.fromPromise
   260‚Üíexport const fromSafePromise = ResultAsync.fromSafePromise
   262‚Üíexport const fromAsyncThrowable = ResultAsync.fromThrowable
   265‚Üíexport type CombineResultAsyncs<
   266‚Üí  T extends readonly ResultAsync<unknown, unknown>[]
   267‚Üí> = IsLiteralArray<T> extends 1
   268‚Üí  ? TraverseAsync<UnwrapAsync<T>>
   269‚Üí  : ResultAsync<ExtractOkAsyncTypes<T>, ExtractErrAsyncTypes<T>[number]>
   272‚Üíexport type CombineResultsWithAllErrorsArrayAsync<
   273‚Üí  T extends readonly ResultAsync<unknown, unknown>[]
   274‚Üí> = IsLiteralArray<T> extends 1
   275‚Üí  ? TraverseWithAllErrorsAsync<UnwrapAsync<T>>
   276‚Üí  : ResultAsync<ExtractOkAsyncTypes<T>, ExtractErrAsyncTypes<T>[number][]>
   279‚Üítype UnwrapAsync<T> = IsLiteralArray<T> extends 1
   280‚Üí  ? Writable<T> extends [infer H, ...infer Rest]
   281‚Üí    ? H extends PromiseLike<infer HI>
   282‚Üí      ? HI extends Result<unknown, unknown>
   283‚Üí        ? [Dedup<HI>, ...UnwrapAsync<Rest>]
   284‚Üí        : never
   285‚Üí      : never
   286‚Üí    : []
   287‚Üí  : // If we got something too general such as ResultAsync<X, Y>[] then we
   288‚Üí  // simply need to map it to ResultAsync<X[], Y[]>. Yet `ResultAsync`
   289‚Üí  // itself is a union therefore it would be enough to cast it to Ok.
   290‚Üí  T extends Array<infer A>
   291‚Üí  ? A extends PromiseLike<infer HI>
   292‚Üí    ? HI extends Result<infer L, infer R>
   293‚Üí      ? Ok<L, R>[]
   294‚Üí      : never
   295‚Üí    : never
   296‚Üí  : never
   300‚Üítype TraverseAsync<T, Depth extends number = 5> = IsLiteralArray<T> extends 1
   301‚Üí  ? Combine<T, Depth> extends [infer Oks, infer Errs]
   302‚Üí    ? ResultAsync<EmptyArrayToNever<Oks>, MembersToUnion<Errs>>
   303‚Üí    : never
   304‚Üí  : // The following check is important if we somehow reach to the point of
   305‚Üí  // checking something similar to ResultAsync<X, Y>[]. In this case we don't
   306‚Üí  // know the length of the elements, therefore we need to traverse the X and Y
   307‚Üí  // in a way that the result should contain X[] and Y[].
   308‚Üí  T extends Array<infer I>
   309‚Üí  ? // The MemberListOf<I> here is to include all possible types. Therefore
   310‚Üí    // if we face (ResultAsync<X, Y> | ResultAsync<A, B>)[] this type should
   311‚Üí    // handle the case.
   312‚Üí    Combine<MemberListOf<I>, Depth> extends [infer Oks, infer Errs]
   313‚Üí    ? // The following `extends unknown[]` checks are just to satisfy the TS.
   314‚Üí      // we already expect them to be an array.
   315‚Üí      Oks extends unknown[]
   316‚Üí      ? Errs extends unknown[]
   317‚Üí        ? ResultAsync<EmptyArrayToNever<Oks[number][]>, MembersToUnion<Errs[number][]>>
   318‚Üí        : ResultAsync<EmptyArrayToNever<Oks[number][]>, Errs>
   319‚Üí      : // The rest of the conditions are to satisfy the TS and support
   320‚Üí      // the edge cases which are not really expected to happen.
   321‚Üí      Errs extends unknown[]
   322‚Üí      ? ResultAsync<Oks, MembersToUnion<Errs[number][]>>
   323‚Üí      : ResultAsync<Oks, Errs>
   324‚Üí    : never
   325‚Üí  : never
   330‚Üítype TraverseWithAllErrorsAsync<T, Depth extends number = 5> = TraverseAsync<
   331‚Üí  T,
   332‚Üí  Depth
   333‚Üí> extends ResultAsync<infer Oks, infer Errs>
   334‚Üí  ? ResultAsync<Oks, Errs[]>
   335‚Üí  : never
   338‚Üítype Writable<T> = T extends ReadonlyArray<unknown> ? [...T] : T

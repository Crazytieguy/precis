    62→export type Result<T, E> = Ok<T, E> | Err<T, E>
    66→export function ok<T, E = never>(value: T): Ok<T, E> {
    73→export function err<T = never, E = unknown>(err: E): Err<T, E> {
   122→export function safeTry<T, E>(
   123→  body:
   124→    | (() => Generator<Err<never, E>, Result<T, E>>)
   125→    | (() => AsyncGenerator<Err<never, E>, Result<T, E>>),
   126→): Result<T, E> | ResultAsync<T, E> {
   134→interface IResult<T, E> {
   136→   * Used to check if a `Result` is an `OK`
   140→  isOk(): this is Ok<T, E>
   143→   * Used to check if a `Result` is an `Err`
   147→  isErr(): this is Err<T, E>
   150→   * Maps a `Result<T, E>` to `Result<U, E>`
   157→  map<A>(f: (t: T) => A): Result<A, E>
   160→   * Maps a `Result<T, E>` to `Result<T, F>` by applying a function to a
   168→  mapErr<U>(f: (e: E) => U): Result<T, U>
   183→  andThen<U, F>(f: (t: T) => Result<U, F>): Result<U, E | F>
   186→   * This "tee"s the current value to an passed-in computation such as side
   195→  andTee(f: (t: T) => unknown): Result<T, E>
   198→   * This "tee"s the current `Err` value to an passed-in computation such as side
   207→  orTee(f: (t: E) => unknown): Result<T, E>
   219→  andThrough<F>(f: (t: T) => Result<unknown, F>): Result<T, E | F>
   233→  orElse<U, A>(f: (e: E) => Result<U, A>): Result<U | T, A>
   236→   * Similar to `map` Except you must return a new `Result`.
   244→  asyncAndThen<U, F>(f: (t: T) => ResultAsync<U, F>): ResultAsync<U, E | F>
   247→   * Maps a `Result<T, E>` to `ResultAsync<U, E>`
   253→  asyncMap<U>(f: (t: T) => Promise<U>): ResultAsync<U, E>
   256→   * Unwrap the `Ok` value, or return the default if there is an `Err`
   260→  unwrapOr<A>(v: A): T | A
   264→   * Given 2 functions (one for the `Ok` variant and one for the `Err` variant)
   276→  match<A, B = A>(ok: (t: T) => A, err: (e: E) => B): A | B
   279→   * @deprecated will be removed in 9.0.0.
   290→  safeUnwrap(): Generator<Err<never, E>, T>
   293→   * **This method is unsafe, and should only be used in a test environments**
   299→  _unsafeUnwrap(config?: ErrorConfig): T
   302→   * **This method is unsafe, and should only be used in a test environments**
   309→  _unsafeUnwrapErr(config?: ErrorConfig): E
   312→export class Ok<T, E> implements IResult<T, E> {
   313→  constructor(readonly value: T) {}
   315→  isOk(): this is Ok<T, E> {
   319→  isErr(): this is Err<T, E> {
   323→  map<A>(f: (t: T) => A): Result<A, E> {
   328→  mapErr<U>(_f: (e: E) => U): Result<T, U> {
   337→  andThen(f: any): any {
   344→  andThrough(f: any): any {
   348→  andTee(f: (t: T) => unknown): Result<T, E> {
   357→  orTee(_f: (t: E) => unknown): Result<T, E> {
   366→  orElse(_f: any): any {
   370→  asyncAndThen<U, F>(f: (t: T) => ResultAsync<U, F>): ResultAsync<U, E | F> {
   379→  asyncAndThrough(f: (t: T) => ResultAsync<unknown, unknown>): any {
   383→  asyncMap<U>(f: (t: T) => Promise<U>): ResultAsync<U, E> {
   388→  unwrapOr<A>(_v: A): T | A {
   393→  match<A, B = A>(ok: (t: T) => A, _err: (e: E) => B): A | B {
   397→  safeUnwrap(): Generator<Err<never, E>, T> {
   405→  _unsafeUnwrap(_?: ErrorConfig): T {
   409→  _unsafeUnwrapErr(config?: ErrorConfig): E {
   419→export class Err<T, E> implements IResult<T, E> {
   420→  constructor(readonly error: E) {}
   422→  isOk(): this is Ok<T, E> {
   426→  isErr(): this is Err<T, E> {
   431→  map<A>(_f: (t: T) => A): Result<A, E> {
   435→  mapErr<U>(f: (e: E) => U): Result<T, U> {
   439→  andThrough<F>(_f: (t: T) => Result<unknown, F>): Result<T, E | F> {
   443→  andTee(_f: (t: T) => unknown): Result<T, E> {
   447→  orTee(f: (t: E) => unknown): Result<T, E> {
   461→  andThen(_f: any): any {
   470→  orElse(f: any): any {
   475→  asyncAndThen<U, F>(_f: (t: T) => ResultAsync<U, F>): ResultAsync<U, E | F> {
   479→  asyncAndThrough<F>(_f: (t: T) => ResultAsync<unknown, F>): ResultAsync<T, E | F> {
   484→  asyncMap<U>(_f: (t: T) => Promise<U>): ResultAsync<U, E> {
   488→  unwrapOr<A>(v: A): T | A {
   492→  match<A, B = A>(_ok: (t: T) => A, err: (e: E) => B): A | B {
   496→  safeUnwrap(): Generator<Err<never, E>, T> {
   505→  _unsafeUnwrap(config?: ErrorConfig): T {
   509→  _unsafeUnwrapErr(_?: ErrorConfig): E {
   523→export const fromThrowable = Result.fromThrowable
   530→type Prev = [
   531→  never,
   532→  0,
   533→  1,
   534→  2,
   535→  3,
   536→  4,
   537→  5,
   538→  6,
   539→  7,
   540→  8,
   541→  9,
   542→  10,
   543→  11,
   544→  12,
   545→  13,
   546→  14,
   547→  15,
   548→  16,
   549→  17,
   550→  18,
   551→  19,
   552→  20,
   553→  21,
   554→  22,
   555→  23,
   556→  24,
   557→  25,
   558→  26,
   559→  27,
   560→  28,
   561→  29,
   562→  30,
   563→  31,
   564→  32,
   565→  33,
   566→  34,
   567→  35,
   568→  36,
   569→  37,
   570→  38,
   571→  39,
   572→  40,
   573→  41,
   574→  42,
   575→  43,
   576→  44,
   577→  45,
   578→  46,
   579→  47,
   580→  48,
   581→  49,
   582→  ...0[]
   583→]
   590→type CollectResults<T, Collected extends unknown[] = [], Depth extends number = 50> = [
   591→  Depth,
   592→] extends [never]
   593→  ? []
   594→  : T extends [infer H, ...infer Rest]
   595→  ? // And test whether the head of the list is a result
   596→    H extends Result<infer L, infer R>
   597→    ? // Continue collecting...
   598→      CollectResults<
   599→        // the rest of the elements
   600→        Rest,
   601→        // The collected
   602→        [...Collected, [L, R]],
   603→        // and one less of the current depth
   604→        Prev[Depth]
   605→      >
   606→    : never // Impossible
   607→  : Collected
   614→export type Transpose<
   615→  A,
   616→  Transposed extends unknown[][] = [],
   617→  Depth extends number = 10
   618→> = A extends [infer T, ...infer Rest]
   619→  ? T extends [infer L, infer R]
   620→    ? Transposed extends [infer PL, infer PR]
   621→      ? PL extends unknown[]
   622→        ? PR extends unknown[]
   623→          ? Transpose<Rest, [[...PL, L], [...PR, R]], Prev[Depth]>
   624→          : never
   625→        : never
   626→      : Transpose<Rest, [[L], [R]], Prev[Depth]>
   627→    : Transposed
   628→  : Transposed
   635→export type Combine<T, Depth extends number = 5> = Transpose<CollectResults<T>, [], Depth> extends [
   636→  infer L,
   637→  infer R,
   638→]
   639→  ? [UnknownMembersToNever<L>, UnknownMembersToNever<R>]
   640→  : Transpose<CollectResults<T>, [], Depth> extends []
   641→  ? [[], []]
   642→  : never
   645→export type Dedup<T> = T extends Result<infer RL, infer RR>
   646→  ? [unknown] extends [RL]
   647→    ? Err<RL, RR>
   648→    : Ok<RL, RR>
   649→  : T
   652→export type MemberListOf<T> = (
   653→  (T extends unknown ? (t: T) => T : never) extends infer U
   654→    ? (U extends unknown ? (u: U) => unknown : never) extends (v: infer V) => unknown
   655→      ? V
   656→      : never
   657→    : never
   658→) extends (_: unknown) => infer W
   659→  ? [...MemberListOf<Exclude<T, W>>, W]
   660→  : []
   669→export type EmptyArrayToNever<T, NeverArrayToNever extends number = 0> = T extends []
   670→  ? never
   671→  : NeverArrayToNever extends 1
   672→  ? T extends [never, ...infer Rest]
   673→    ? [EmptyArrayToNever<Rest>] extends [never]
   674→      ? never
   675→      : T
   676→    : T
   677→  : T
   680→type UnknownMembersToNever<T> = T extends [infer H, ...infer R]
   681→  ? [[unknown] extends [H] ? never : H, ...UnknownMembersToNever<R>]
   682→  : T
   685→export type MembersToUnion<T> = T extends unknown[] ? T[number] : never
   688→export type IsLiteralArray<T> = T extends { length: infer L }
   689→  ? L extends number
   690→    ? number extends L
   691→      ? 0
   692→      : 1
   693→    : 0
   694→  : 0
   698→type Traverse<T, Depth extends number = 5> = Combine<T, Depth> extends [infer Oks, infer Errs]
   699→  ? Result<EmptyArrayToNever<Oks, 1>, MembersToUnion<Errs>>
   700→  : never
   704→type TraverseWithAllErrors<T, Depth extends number = 5> = Traverse<T, Depth> extends Result<
   705→  infer Oks,
   706→  infer Errs
   707→>
   708→  ? Result<Oks, Errs[]>
   709→  : never
   712→export type CombineResults<
   713→  T extends readonly Result<unknown, unknown>[]
   714→> = IsLiteralArray<T> extends 1
   715→  ? Traverse<T>
   716→  : Result<ExtractOkTypes<T>, ExtractErrTypes<T>[number]>
   719→export type CombineResultsWithAllErrorsArray<
   720→  T extends readonly Result<unknown, unknown>[]
   721→> = IsLiteralArray<T> extends 1
   722→  ? TraverseWithAllErrors<T>
   723→  : Result<ExtractOkTypes<T>, ExtractErrTypes<T>[number][]>

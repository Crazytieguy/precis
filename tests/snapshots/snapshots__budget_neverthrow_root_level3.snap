   523‚Üíexport const fromThrowable = Result.fromThrowable
   530‚Üítype Prev = [
   531‚Üí  never,
   532‚Üí  0,
   533‚Üí  1,
   534‚Üí  2,
   535‚Üí  3,
   536‚Üí  4,
   537‚Üí  5,
   538‚Üí  6,
   539‚Üí  7,
   540‚Üí  8,
   541‚Üí  9,
   542‚Üí  10,
   543‚Üí  11,
   544‚Üí  12,
   545‚Üí  13,
   546‚Üí  14,
   547‚Üí  15,
   548‚Üí  16,
   549‚Üí  17,
   550‚Üí  18,
   551‚Üí  19,
   552‚Üí  20,
   553‚Üí  21,
   554‚Üí  22,
   555‚Üí  23,
   556‚Üí  24,
   557‚Üí  25,
   558‚Üí  26,
   559‚Üí  27,
   560‚Üí  28,
   561‚Üí  29,
   562‚Üí  30,
   563‚Üí  31,
   564‚Üí  32,
   565‚Üí  33,
   566‚Üí  34,
   567‚Üí  35,
   568‚Üí  36,
   569‚Üí  37,
   570‚Üí  38,
   571‚Üí  39,
   572‚Üí  40,
   573‚Üí  41,
   574‚Üí  42,
   575‚Üí  43,
   576‚Üí  44,
   577‚Üí  45,
   578‚Üí  46,
   579‚Üí  47,
   580‚Üí  48,
   581‚Üí  49,
   582‚Üí  ...0[]
   583‚Üí]
   590‚Üítype CollectResults<T, Collected extends unknown[] = [], Depth extends number = 50> = [
   591‚Üí  Depth,
   592‚Üí] extends [never]
   593‚Üí  ? []
   594‚Üí  : T extends [infer H, ...infer Rest]
   595‚Üí  ? // And test whether the head of the list is a result
   596‚Üí    H extends Result<infer L, infer R>
   597‚Üí    ? // Continue collecting...
   598‚Üí      CollectResults<
   599‚Üí        // the rest of the elements
   600‚Üí        Rest,
   601‚Üí        // The collected
   602‚Üí        [...Collected, [L, R]],
   603‚Üí        // and one less of the current depth
   604‚Üí        Prev[Depth]
   605‚Üí      >
   606‚Üí    : never // Impossible
   607‚Üí  : Collected
   614‚Üíexport type Transpose<
   615‚Üí  A,
   616‚Üí  Transposed extends unknown[][] = [],
   617‚Üí  Depth extends number = 10
   618‚Üí> = A extends [infer T, ...infer Rest]
   619‚Üí  ? T extends [infer L, infer R]
   620‚Üí    ? Transposed extends [infer PL, infer PR]
   621‚Üí      ? PL extends unknown[]
   622‚Üí        ? PR extends unknown[]
   623‚Üí          ? Transpose<Rest, [[...PL, L], [...PR, R]], Prev[Depth]>
   624‚Üí          : never
   625‚Üí        : never
   626‚Üí      : Transpose<Rest, [[L], [R]], Prev[Depth]>
   627‚Üí    : Transposed
   628‚Üí  : Transposed
   635‚Üíexport type Combine<T, Depth extends number = 5> = Transpose<CollectResults<T>, [], Depth> extends [
   636‚Üí  infer L,
   637‚Üí  infer R,
   638‚Üí]
   639‚Üí  ? [UnknownMembersToNever<L>, UnknownMembersToNever<R>]
   640‚Üí  : Transpose<CollectResults<T>, [], Depth> extends []
   641‚Üí  ? [[], []]
   642‚Üí  : never
   645‚Üíexport type Dedup<T> = T extends Result<infer RL, infer RR>
   646‚Üí  ? [unknown] extends [RL]
   647‚Üí    ? Err<RL, RR>
   648‚Üí    : Ok<RL, RR>
   649‚Üí  : T
   652‚Üíexport type MemberListOf<T> = (
   653‚Üí  (T extends unknown ? (t: T) => T : never) extends infer U
   654‚Üí    ? (U extends unknown ? (u: U) => unknown : never) extends (v: infer V) => unknown
   655‚Üí      ? V
   656‚Üí      : never
   657‚Üí    : never
   658‚Üí) extends (_: unknown) => infer W
   659‚Üí  ? [...MemberListOf<Exclude<T, W>>, W]
   660‚Üí  : []
   669‚Üíexport type EmptyArrayToNever<T, NeverArrayToNever extends number = 0> = T extends []
   670‚Üí  ? never
   671‚Üí  : NeverArrayToNever extends 1
   672‚Üí  ? T extends [never, ...infer Rest]
   673‚Üí    ? [EmptyArrayToNever<Rest>] extends [never]
   674‚Üí      ? never
   675‚Üí      : T
   676‚Üí    : T
   677‚Üí  : T
   680‚Üítype UnknownMembersToNever<T> = T extends [infer H, ...infer R]
   681‚Üí  ? [[unknown] extends [H] ? never : H, ...UnknownMembersToNever<R>]
   682‚Üí  : T
   685‚Üíexport type MembersToUnion<T> = T extends unknown[] ? T[number] : never
   688‚Üíexport type IsLiteralArray<T> = T extends { length: infer L }
   689‚Üí  ? L extends number
   690‚Üí    ? number extends L
   691‚Üí      ? 0
   692‚Üí      : 1
   693‚Üí    : 0
   694‚Üí  : 0
   698‚Üítype Traverse<T, Depth extends number = 5> = Combine<T, Depth> extends [infer Oks, infer Errs]
   699‚Üí  ? Result<EmptyArrayToNever<Oks, 1>, MembersToUnion<Errs>>
   700‚Üí  : never
   704‚Üítype TraverseWithAllErrors<T, Depth extends number = 5> = Traverse<T, Depth> extends Result<
   705‚Üí  infer Oks,
   706‚Üí  infer Errs
   707‚Üí>
   708‚Üí  ? Result<Oks, Errs[]>
   709‚Üí  : never
   712‚Üíexport type CombineResults<
   713‚Üí  T extends readonly Result<unknown, unknown>[]
   714‚Üí> = IsLiteralArray<T> extends 1
   715‚Üí  ? Traverse<T>
   716‚Üí  : Result<ExtractOkTypes<T>, ExtractErrTypes<T>[number]>
   719‚Üíexport type CombineResultsWithAllErrorsArray<
   720‚Üí  T extends readonly Result<unknown, unknown>[]
   721‚Üí> = IsLiteralArray<T> extends 1
   722‚Üí  ? TraverseWithAllErrors<T>
   723‚Üí  : Result<ExtractOkTypes<T>, ExtractErrTypes<T>[number][]>

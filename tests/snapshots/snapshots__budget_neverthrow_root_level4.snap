   130→    )
   131→  }
   132→
   133→  orTee(f: (t: E) => unknown): ResultAsync<T, E> {
   134→    return new ResultAsync(
   135→      this._promise.then(async (res: Result<T, E>) => {
   136→        if (res.isOk()) {
   137→          return new Ok<T, E>(res.value)
   138→        }
   139→        try {
   140→          await f(res.error)
   141→        } catch (e) {
   142→          // Tee does not care about the error
   143→        }
   144→        return new Err<T, E>(res.error)
   145→      }),
   146→    )
   147→  }
   148→
   149→  mapErr<U>(f: (e: E) => U | Promise<U>): ResultAsync<T, U> {
   150→    return new ResultAsync(
   151→      this._promise.then(async (res: Result<T, E>) => {
   152→        if (res.isOk()) {
   153→          return new Ok<T, U>(res.value)
   154→        }
   155→
   156→        return new Err<T, U>(await f(res.error))
   157→      }),
   158→    )
   159→  }

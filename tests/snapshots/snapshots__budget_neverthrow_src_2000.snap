     1тЖТimport { Result } from '../result'
     3тЖТexport interface ErrorConfig {
     4тЖТ  withStackTrace: boolean
     5тЖТ}
     7тЖТconst defaultErrorConfig: ErrorConfig = {
     8тЖТ  withStackTrace: false,
     9тЖТ}
    11тЖТinterface NeverThrowError<T, E> {
    12тЖТ  data:
    13тЖТ    | {
    14тЖТ        type: string
    15тЖТ        value: T
    16тЖТ      }
    17тЖТ    | {
    18тЖТ        type: string
    19тЖТ        value: E
    20тЖТ      }
    21тЖТ  message: string
    22тЖТ  stack: string | undefined
    23тЖТ}
    27тЖТexport const createNeverThrowError = <T, E>(
    28тЖТ  message: string,
    29тЖТ  result: Result<T, E>,
    30тЖТ  config: ErrorConfig = defaultErrorConfig,
    31тЖТ): NeverThrowError<T, E> => {
    32тЖТ  const data = result.isOk()
    33тЖТ    ? { type: 'Ok', value: result.value }
    34тЖТ    : { type: 'Err', value: result.error }
    35тЖТ
    36тЖТ  const maybeStack = config.withStackTrace ? new Error().stack : undefined
    37тЖТ
    38тЖТ  return {
    39тЖТ    data,
    40тЖТ    message,
    41тЖТ    stack: maybeStack,
    42тЖТ  }
    43тЖТ}

    14тЖТexport namespace Result {
    15тЖТ  /**
    16тЖТ   * Wraps a function with a try catch, creating a new function with the same
    17тЖТ   * arguments but returning `Ok` if successful, `Err` if the function throws
    18тЖТ   *
    19тЖТ   * @param fn function to wrap with ok on success or err on failure
    20тЖТ   * @param errorFn when an error is thrown, this will wrap the error result if provided
    21тЖТ   */
    22тЖТ  // eslint-disable-next-line @typescript-eslint/no-explicit-any
    23тЖТ  export function fromThrowable<Fn extends (...args: readonly any[]) => any, E>(
    24тЖТ    fn: Fn,
    25тЖТ    errorFn?: (e: unknown) => E,
    26тЖТ  ): (...args: Parameters<Fn>) => Result<ReturnType<Fn>, E> {
    27тЖТ    return (...args) => {
    28тЖТ      try {
    29тЖТ        const result = fn(...args)
    30тЖТ        return ok(result)
    31тЖТ      } catch (e) {
    32тЖТ        return err(errorFn ? errorFn(e) : e)
    33тЖТ      }
    34тЖТ    }
    35тЖТ  }
    36тЖТ
    37тЖТ  export function combine<
    38тЖТ    T extends readonly [Result<unknown, unknown>, ...Result<unknown, unknown>[]]
    39тЖТ  >(resultList: T): CombineResults<T>
    40тЖТ  export function combine<T extends readonly Result<unknown, unknown>[]>(
    41тЖТ    resultList: T,
    42тЖТ  ): CombineResults<T>
    43тЖТ  export function combine<
    44тЖТ    T extends readonly [Result<unknown, unknown>, ...Result<unknown, unknown>[]]
    45тЖТ  >(resultList: T): CombineResults<T> {
    46тЖТ    return combineResultList(resultList) as CombineResults<T>
    47тЖТ  }

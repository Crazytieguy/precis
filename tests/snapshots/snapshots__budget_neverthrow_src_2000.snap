    30тЖТ  static fromSafePromise<T, E = never>(promise: Promise<T>): ResultAsync<T, E> {
    31тЖТ    const newPromise = promise.then((value: T) => new Ok<T, E>(value))
    32тЖТ
    33тЖТ    return new ResultAsync(newPromise)
    34тЖТ  }

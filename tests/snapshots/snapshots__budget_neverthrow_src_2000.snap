     1тЖТimport { Result, ok, err } from '../result'
     2тЖТimport { ResultAsync } from '../result-async'
     5тЖТexport type ExtractOkTypes<T extends readonly Result<unknown, unknown>[]> = {
     6тЖТ  [idx in keyof T]: T[idx] extends Result<infer U, unknown> ? U : never
     7тЖТ}
    10тЖТexport type ExtractOkAsyncTypes<T extends readonly ResultAsync<unknown, unknown>[]> = {
    11тЖТ  [idx in keyof T]: T[idx] extends ResultAsync<infer U, unknown> ? U : never
    12тЖТ}
    15тЖТexport type ExtractErrTypes<T extends readonly Result<unknown, unknown>[]> = {
    16тЖТ  [idx in keyof T]: T[idx] extends Result<unknown, infer E> ? E : never
    17тЖТ}
    20тЖТexport type ExtractErrAsyncTypes<T extends readonly ResultAsync<unknown, unknown>[]> = {
    21тЖТ  [idx in keyof T]: T[idx] extends ResultAsync<unknown, infer E> ? E : never
    22тЖТ}
    24тЖТexport type InferOkTypes<R> = R extends Result<infer T, unknown> ? T : never
    25тЖТexport type InferErrTypes<R> = R extends Result<unknown, infer E> ? E : never
    27тЖТexport type InferAsyncOkTypes<R> = R extends ResultAsync<infer T, unknown> ? T : never
    28тЖТexport type InferAsyncErrTypes<R> = R extends ResultAsync<unknown, infer E> ? E : never
    30тЖТ/**
    31тЖТ * Short circuits on the FIRST Err value that we find
    32тЖТ */
    33тЖТexport const combineResultList = <T, E>(
    34тЖТ  resultList: readonly Result<T, E>[],
    35тЖТ): Result<readonly T[], E> => {
    36тЖТ  let acc = ok([]) as Result<T[], E>
    37тЖТ
    38тЖТ  for (const result of resultList) {
    39тЖТ    if (result.isErr()) {
    40тЖТ      acc = err(result.error)
    41тЖТ      break
    42тЖТ    } else {
    43тЖТ      acc.map((list) => list.push(result.value))
    44тЖТ    }
    45тЖТ  }
    46тЖТ  return acc
    47тЖТ}
    54тЖТexport const combineResultAsyncList = <T, E>(
    55тЖТ  asyncResultList: readonly ResultAsync<T, E>[],
    56тЖТ): ResultAsync<readonly T[], E> =>
    57тЖТ  ResultAsync.fromSafePromise(Promise.all(asyncResultList)).andThen(
    58тЖТ    combineResultList,
    59тЖТ  ) as ResultAsync<T[], E>
    61тЖТ/**
    62тЖТ * Give a list of all the errors we find
    63тЖТ */
    64тЖТexport const combineResultListWithAllErrors = <T, E>(
    65тЖТ  resultList: readonly Result<T, E>[],
    66тЖТ): Result<readonly T[], E[]> => {
    67тЖТ  let acc = ok([]) as Result<T[], E[]>
    68тЖТ
    69тЖТ  for (const result of resultList) {
    70тЖТ    if (result.isErr() && acc.isErr()) {
    71тЖТ      acc.error.push(result.error)
    72тЖТ    } else if (result.isErr() && acc.isOk()) {
    73тЖТ      acc = err([result.error])
    74тЖТ    } else if (result.isOk() && acc.isOk()) {
    75тЖТ      acc.value.push(result.value)
    76тЖТ    }
    77тЖТ    // do nothing when result.isOk() && acc.isErr()
    78тЖТ  }
    79тЖТ  return acc
    80тЖТ}
    82тЖТexport const combineResultAsyncListWithAllErrors = <T, E>(
    83тЖТ  asyncResultList: readonly ResultAsync<T, E>[],
    84тЖТ): ResultAsync<readonly T[], E[]> =>
    85тЖТ  ResultAsync.fromSafePromise(Promise.all(asyncResultList)).andThen(
    86тЖТ    combineResultListWithAllErrors,
    87тЖТ  ) as ResultAsync<T[], E[]>

   315тЖТ      Oks extends unknown[]
   316тЖТ      ? Errs extends unknown[]
   317тЖТ        ? ResultAsync<EmptyArrayToNever<Oks[number][]>, MembersToUnion<Errs[number][]>>
   318тЖТ        : ResultAsync<EmptyArrayToNever<Oks[number][]>, Errs>
   319тЖТ      : // The rest of the conditions are to satisfy the TS and support
   320тЖТ      // the edge cases which are not really expected to happen.
   321тЖТ      Errs extends unknown[]
   322тЖТ      ? ResultAsync<Oks, MembersToUnion<Errs[number][]>>
   323тЖТ      : ResultAsync<Oks, Errs>
   324тЖТ    : never
   325тЖТ  : never
   330тЖТtype TraverseWithAllErrorsAsync<T, Depth extends number = 5> = TraverseAsync<
   331тЖТ  T,
   332тЖТ  Depth
   333тЖТ> extends ResultAsync<infer Oks, infer Errs>

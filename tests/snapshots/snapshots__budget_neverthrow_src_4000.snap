   598тЖТ      CollectResults<
   599тЖТ        // the rest of the elements
   600тЖТ        Rest,
   601тЖТ        // The collected
   602тЖТ        [...Collected, [L, R]],
   603тЖТ        // and one less of the current depth
   604тЖТ        Prev[Depth]

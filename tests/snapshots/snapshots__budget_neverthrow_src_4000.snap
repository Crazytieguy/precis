   276тЖТ  : ResultAsync<ExtractOkAsyncTypes<T>, ExtractErrAsyncTypes<T>[number][]>
   279тЖТtype UnwrapAsync<T> = IsLiteralArray<T> extends 1
   280тЖТ  ? Writable<T> extends [infer H, ...infer Rest]
   281тЖТ    ? H extends PromiseLike<infer HI>
   282тЖТ      ? HI extends Result<unknown, unknown>
   283тЖТ        ? [Dedup<HI>, ...UnwrapAsync<Rest>]
   284тЖТ        : never
   285тЖТ      : never
   286тЖТ    : []
   287тЖТ  : // If we got something too general such as ResultAsync<X, Y>[] then we

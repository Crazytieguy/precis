   628тЖТ  : Transposed
   635тЖТexport type Combine<T, Depth extends number = 5> = Transpose<CollectResults<T>, [], Depth> extends [
   636тЖТ  infer L,
   637тЖТ  infer R,
   638тЖТ]
   639тЖТ  ? [UnknownMembersToNever<L>, UnknownMembersToNever<R>]
   640тЖТ  : Transpose<CollectResults<T>, [], Depth> extends []
   641тЖТ  ? [[], []]
   642тЖТ  : never
   645тЖТexport type Dedup<T> = T extends Result<infer RL, infer RR>
   646тЖТ  ? [unknown] extends [RL]
   647тЖТ    ? Err<RL, RR>
   648тЖТ    : Ok<RL, RR>
   649тЖТ  : T
   652тЖТexport type MemberListOf<T> = (
   653тЖТ  (T extends unknown ? (t: T) => T : never) extends infer U
   654тЖТ    ? (U extends unknown ? (u: U) => unknown : never) extends (v: infer V) => unknown
   655тЖТ      ? V
   656тЖТ      : never
   657тЖТ    : never
   658тЖТ) extends (_: unknown) => infer W
   659тЖТ  ? [...MemberListOf<Exclude<T, W>>, W]
   660тЖТ  : []
   669тЖТexport type EmptyArrayToNever<T, NeverArrayToNever extends number = 0> = T extends []
   670тЖТ  ? never
   671тЖТ  : NeverArrayToNever extends 1
   672тЖТ  ? T extends [never, ...infer Rest]
   673тЖТ    ? [EmptyArrayToNever<Rest>] extends [never]
   674тЖТ      ? never
   675тЖТ      : T
   676тЖТ    : T
   677тЖТ  : T
   680тЖТtype UnknownMembersToNever<T> = T extends [infer H, ...infer R]
   681тЖТ  ? [[unknown] extends [H] ? never : H, ...UnknownMembersToNever<R>]
   682тЖТ  : T
   685тЖТexport type MembersToUnion<T> = T extends unknown[] ? T[number] : never
   688тЖТexport type IsLiteralArray<T> = T extends { length: infer L }
   689тЖТ  ? L extends number
   690тЖТ    ? number extends L
   691тЖТ      ? 0
   692тЖТ      : 1
   693тЖТ    : 0
   694тЖТ  : 0
   698тЖТtype Traverse<T, Depth extends number = 5> = Combine<T, Depth> extends [infer Oks, infer Errs]
   699тЖТ  ? Result<EmptyArrayToNever<Oks, 1>, MembersToUnion<Errs>>
   700тЖТ  : never
   704тЖТtype TraverseWithAllErrors<T, Depth extends number = 5> = Traverse<T, Depth> extends Result<
   705тЖТ  infer Oks,
   706тЖТ  infer Errs
   707тЖТ>
   708тЖТ  ? Result<Oks, Errs[]>
   709тЖТ  : never
   712тЖТexport type CombineResults<
   713тЖТ  T extends readonly Result<unknown, unknown>[]
   714тЖТ> = IsLiteralArray<T> extends 1
   715тЖТ  ? Traverse<T>
   716тЖТ  : Result<ExtractOkTypes<T>, ExtractErrTypes<T>[number]>
   719тЖТexport type CombineResultsWithAllErrorsArray<
   720тЖТ  T extends readonly Result<unknown, unknown>[]
   721тЖТ> = IsLiteralArray<T> extends 1
   722тЖТ  ? TraverseWithAllErrors<T>
   723тЖТ  : Result<ExtractOkTypes<T>, ExtractErrTypes<T>[number][]>

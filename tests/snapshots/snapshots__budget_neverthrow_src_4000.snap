   291тЖТ  ? A extends PromiseLike<infer HI>
   292тЖТ    ? HI extends Result<infer L, infer R>
   293тЖТ      ? Ok<L, R>[]
   294тЖТ      : never
   295тЖТ    : never
   296тЖТ  : never
   300тЖТtype TraverseAsync<T, Depth extends number = 5> = IsLiteralArray<T> extends 1
   301тЖТ  ? Combine<T, Depth> extends [infer Oks, infer Errs]
   302тЖТ    ? ResultAsync<EmptyArrayToNever<Oks>, MembersToUnion<Errs>>
   303тЖТ    : never
   304тЖТ  : // The following check is important if we somehow reach to the point of
   305тЖТ  // checking something similar to ResultAsync<X, Y>[]. In this case we don't
   306тЖТ  // know the length of the elements, therefore we need to traverse the X and Y
   307тЖТ  // in a way that the result should contain X[] and Y[].

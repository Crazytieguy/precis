    13‚Üí#[derive(Debug)]
    14‚Üípub(crate) struct OnceCell<T> {
    15‚Üí    // This `queue` field is the core of the implementation. It encodes two
    16‚Üí    // pieces of information:
    17‚Üí    //
    18‚Üí    // * The current state of the cell (`INCOMPLETE`, `RUNNING`, `COMPLETE`)
    19‚Üí    // * Linked list of threads waiting for the current cell.
    20‚Üí    //
    21‚Üí    // State is encoded in two low bits. Only `INCOMPLETE` and `RUNNING` states
    22‚Üí    // allow waiters.
    23‚Üí    queue: AtomicPtr<Waiter>,
    24‚Üí    value: UnsafeCell<Option<T>>,
    25‚Üí}

    13Рєњ#[derive(Debug)]
    14Рєњpub(crate) struct OnceCell<T> {
    15Рєњ    // This `queue` field is the core of the implementation. It encodes two
    16Рєњ    // pieces of information:
    17Рєњ    //
    18Рєњ    // * The current state of the cell (`INCOMPLETE`, `RUNNING`, `COMPLETE`)
    19Рєњ    // * Linked list of threads waiting for the current cell.
    20Рєњ    //
    21Рєњ    // State is encoded in two low bits. Only `INCOMPLETE` and `RUNNING` states
    22Рєњ    // allow waiters.
    23Рєњ    queue: AtomicPtr<Waiter>,
    24Рєњ    value: UnsafeCell<Option<T>>,
    25Рєњ}

   872‚Üí
   873‚Üí    /// A thread-safe cell which can be written to only once.
   874‚Üí    ///
   875‚Üí    /// `OnceCell` provides `&` references to the contents without RAII guards.
   876‚Üí    ///
   877‚Üí    /// Reading a non-`None` value out of `OnceCell` establishes a
   878‚Üí    /// happens-before relationship with a corresponding write. For example, if
   879‚Üí    /// thread A initializes the cell with `get_or_init(f)`, and thread B
   880‚Üí    /// subsequently reads the result of this call, B also observes all the side
   881‚Üí    /// effects of `f`.
   882‚Üí    ///
   883‚Üí    /// # Example
   884‚Üí    /// ```
   885‚Üí    /// use once_cell::sync::OnceCell;
   886‚Üí    ///
   887‚Üí    /// static CELL: OnceCell<String> = OnceCell::new();
   888‚Üí    /// assert!(CELL.get().is_none());
   889‚Üí    ///
   890‚Üí    /// std::thread::spawn(|| {
   891‚Üí    ///     let value: &String = CELL.get_or_init(|| {
   892‚Üí    ///         "Hello, World!".to_string()
   893‚Üí    ///     });
   894‚Üí    ///     assert_eq!(value, "Hello, World!");
   895‚Üí    /// }).join().unwrap();
   896‚Üí    ///
   897‚Üí    /// let value: Option<&String> = CELL.get();
   898‚Üí    /// assert!(value.is_some());
   899‚Üí    /// assert_eq!(value.unwrap().as_str(), "Hello, World!");
   900‚Üí    /// ```
   901‚Üí    pub struct OnceCell<T>(Imp<T>);

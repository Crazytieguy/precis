   210‚Üífn wait(queue: &AtomicPtr<Waiter>, mut curr_queue: *mut Waiter) {
   211‚Üí    let curr_state = strict::addr(curr_queue) & STATE_MASK;
   212‚Üí    loop {
   213‚Üí        let node = Waiter {
   214‚Üí            thread: Cell::new(Some(thread::current())),
   215‚Üí            signaled: AtomicBool::new(false),
   216‚Üí            next: strict::map_addr(curr_queue, |q| q & !STATE_MASK),
   217‚Üí        };
   218‚Üí        let me = &node as *const Waiter as *mut Waiter;
   219‚Üí
   220‚Üí        let exchange = queue.compare_exchange(
   221‚Üí            curr_queue,
   222‚Üí            strict::map_addr(me, |q| q | curr_state),
   223‚Üí            Ordering::Release,
   224‚Üí            Ordering::Relaxed,
   225‚Üí        );
   226‚Üí        if let Err(new_queue) = exchange {
   227‚Üí            if strict::addr(new_queue) & STATE_MASK != curr_state {
   228‚Üí                return;
   229‚Üí            }
   230‚Üí            curr_queue = new_queue;
   231‚Üí            continue;
   232‚Üí        }
   233‚Üí
   234‚Üí        while !node.signaled.load(Ordering::Acquire) {
   235‚Üí            thread::park();
   236‚Üí        }
   237‚Üí        break;
   238‚Üí    }
   239‚Üí}

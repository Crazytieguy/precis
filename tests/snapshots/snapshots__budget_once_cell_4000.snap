   390‚Üí
   391‚Üí    /// A cell which can be written to only once. It is not thread safe.
   392‚Üí    ///
   393‚Üí    /// Unlike [`std::cell::RefCell`], a `OnceCell` provides simple `&`
   394‚Üí    /// references to the contents.
   395‚Üí    ///
   396‚Üí    /// [`std::cell::RefCell`]: https://doc.rust-lang.org/std/cell/struct.RefCell.html
   397‚Üí    ///
   398‚Üí    /// # Example
   399‚Üí    /// ```
   400‚Üí    /// use once_cell::unsync::OnceCell;
   401‚Üí    ///
   402‚Üí    /// let cell = OnceCell::new();
   403‚Üí    /// assert!(cell.get().is_none());
   404‚Üí    ///
   405‚Üí    /// let value: &String = cell.get_or_init(|| {
   406‚Üí    ///     "Hello, World!".to_string()
   407‚Üí    /// });
   408‚Üí    /// assert_eq!(value, "Hello, World!");
   409‚Üí    /// assert!(cell.get().is_some());
   410‚Üí    /// ```
   411‚Üí    pub struct OnceCell<T> {
   412‚Üí        // Invariant: written to at most once.
   413‚Üí        inner: UnsafeCell<Option<T>>,
   414‚Üí    }
   415‚Üí
   424‚Üí        fn default() -> Self {
   425‚Üí            Self::new()
   426‚Üí        }
   430‚Üí        fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
   431‚Üí            match self.get() {
   432‚Üí                Some(v) => f.debug_tuple("OnceCell").field(v).finish(),
   433‚Üí                None => f.write_str("OnceCell(Uninit)"),
   434‚Üí            }
   435‚Üí        }
   439‚Üí        fn clone(&self) -> OnceCell<T> {
   440‚Üí            match self.get() {
   441‚Üí                Some(value) => OnceCell::with_value(value.clone()),
   442‚Üí                None => OnceCell::new(),
   443‚Üí            }
   444‚Üí        }
   446‚Üí        fn clone_from(&mut self, source: &Self) {
   447‚Üí            match (self.get_mut(), source.get()) {
   448‚Üí                (Some(this), Some(source)) => this.clone_from(source),
   449‚Üí                _ => *self = source.clone(),
   450‚Üí            }
   451‚Üí        }
   455‚Üí        fn eq(&self, other: &Self) -> bool {
   456‚Üí            self.get() == other.get()
   457‚Üí        }
   463‚Üí        fn from(value: T) -> Self {
   464‚Üí            OnceCell::with_value(value)
   465‚Üí        }

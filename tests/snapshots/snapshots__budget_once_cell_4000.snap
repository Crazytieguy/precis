   125‚Üíconst INCOMPLETE: usize = 0x0;
   126‚Üíconst RUNNING: usize = 0x1;
   127‚Üíconst COMPLETE: usize = 0x2;
   128‚Üíconst INCOMPLETE_PTR: *mut Waiter = INCOMPLETE as *mut Waiter;
   129‚Üíconst COMPLETE_PTR: *mut Waiter = COMPLETE as *mut Waiter;
   133‚Üíconst STATE_MASK: usize = 0x3;
   135‚Üí/// Representation of a node in the linked list of waiters in the RUNNING state.
   136‚Üí/// A waiters is stored on the stack of the waiting threads.
   137‚Üí#[repr(align(4))] // Ensure the two lower bits are free to use as state bits.
   138‚Üístruct Waiter {
   139‚Üí    thread: Cell<Option<Thread>>,
   140‚Üí    signaled: AtomicBool,
   141‚Üí    next: *mut Waiter,
   142‚Üí}
   144‚Üí/// Drains and notifies the queue of waiters on drop.
   145‚Üístruct Guard<'a> {
   146‚Üí    queue: &'a AtomicPtr<Waiter>,
   147‚Üí    new_queue: *mut Waiter,
   148‚Üí}
   151‚Üí    fn drop(&mut self) {
   152‚Üí        let queue = self.queue.swap(self.new_queue, Ordering::AcqRel);
   153‚Üí
   154‚Üí        let state = strict::addr(queue) & STATE_MASK;
   155‚Üí        assert_eq!(state, RUNNING);
   156‚Üí
   157‚Üí        unsafe {
   158‚Üí            let mut waiter = strict::map_addr(queue, |q| q & !STATE_MASK);
   159‚Üí            while !waiter.is_null() {
   160‚Üí                let next = (*waiter).next;
   161‚Üí                let thread = (*waiter).thread.take().unwrap();
   162‚Üí                (*waiter).signaled.store(true, Ordering::Release);
   163‚Üí                waiter = next;
   164‚Üí                thread.unpark();
   165‚Üí            }
   166‚Üí        }
   167‚Üí    }

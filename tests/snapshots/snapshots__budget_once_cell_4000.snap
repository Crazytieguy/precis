  1234‚Üí    ///     println!("initializing");
  1235‚Üí    ///     let mut m = HashMap::new();
  1236‚Üí    ///     m.insert(13, "Spica".to_string());
  1237‚Üí    ///     m.insert(74, "Hoyten".to_string());

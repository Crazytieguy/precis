   861‚Üí/// Thread-safe, blocking version of `OnceCell`.
   862‚Üí#[cfg(any(feature = "std", feature = "critical-section"))]
   863‚Üípub mod sync {
   864‚Üí    use core::{
   865‚Üí        cell::Cell,
   866‚Üí        fmt, mem,
   867‚Üí        ops::{Deref, DerefMut},
   868‚Üí        panic::RefUnwindSafe,
   869‚Üí    };
   870‚Üí
   871‚Üí    use super::imp::OnceCell as Imp;
   872‚Üí
   873‚Üí    /// A thread-safe cell which can be written to only once.
   874‚Üí    ///
   875‚Üí    /// `OnceCell` provides `&` references to the contents without RAII guards.
   876‚Üí    ///
   877‚Üí    /// Reading a non-`None` value out of `OnceCell` establishes a
   878‚Üí    /// happens-before relationship with a corresponding write. For example, if
   879‚Üí    /// thread A initializes the cell with `get_or_init(f)`, and thread B
   880‚Üí    /// subsequently reads the result of this call, B also observes all the side
   881‚Üí    /// effects of `f`.
   882‚Üí    ///
   883‚Üí    /// # Example
   884‚Üí    /// ```
   885‚Üí    /// use once_cell::sync::OnceCell;

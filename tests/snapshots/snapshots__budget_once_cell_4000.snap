  1223‚Üí    ///
  1224‚Üí    /// This type is thread-safe and can be used in statics.
  1225‚Üí    ///
  1226‚Üí    /// # Example
  1227‚Üí    ///
  1228‚Üí    /// ```
  1229‚Üí    /// use std::collections::HashMap;
  1230‚Üí    ///
  1231‚Üí    /// use once_cell::sync::Lazy;
  1232‚Üí    ///
  1233‚Üí    /// static HASHMAP: Lazy<HashMap<i32, String>> = Lazy::new(|| {
  1234‚Üí    ///     println!("initializing");
  1235‚Üí    ///     let mut m = HashMap::new();
  1236‚Üí    ///     m.insert(13, "Spica".to_string());
  1237‚Üí    ///     m.insert(74, "Hoyten".to_string());
  1238‚Üí    ///     m
  1239‚Üí    /// });
  1240‚Üí    ///
  1241‚Üí    /// fn main() {
  1242‚Üí    ///     println!("ready");
  1243‚Üí    ///     std::thread::spawn(|| {
  1244‚Üí    ///         println!("{:?}", HASHMAP.get(&13));
  1245‚Üí    ///     }).join().unwrap();
  1246‚Üí    ///     println!("{:?}", HASHMAP.get(&74));
  1247‚Üí    ///
  1248‚Üí    ///     // Prints:
  1249‚Üí    ///     //   ready
  1250‚Üí    ///     //   initializing
  1251‚Üí    ///     //   Some("Spica")
  1252‚Üí    ///     //   Some("Hoyten")
  1253‚Üí    /// }
  1254‚Üí    /// ```
  1255‚Üí    pub struct Lazy<T, F = fn() -> T> {
  1256‚Üí        cell: OnceCell<T>,
  1257‚Üí        init: Cell<Option<F>>,
  1258‚Üí    }
  1261‚Üí        fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
  1262‚Üí            f.debug_struct("Lazy").field("cell", &self.cell).field("init", &"..").finish()
  1263‚Üí        }

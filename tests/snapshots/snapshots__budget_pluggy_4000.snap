   199Ôćĺ        wrapper: bool = ...,
   200Ôćĺ    ) -> Callable[[_F], _F]: ...
   201Ôćĺ
   202Ôćĺ    def __call__(  # noqa: F811
   203Ôćĺ        self,
   204Ôćĺ        function: _F | None = None,
   205Ôćĺ        hookwrapper: bool = False,
   206Ôćĺ        optionalhook: bool = False,
   207Ôćĺ        tryfirst: bool = False,
   208Ôćĺ        trylast: bool = False,
   209Ôćĺ        specname: str | None = None,
   210Ôćĺ        wrapper: bool = False,
   211Ôćĺ    ) -> _F | Callable[[_F], _F]:
   212Ôćĺ        """If passed a function, directly sets attributes on the function
   213Ôćĺ        which will make it discoverable to :meth:`PluginManager.register`.
   214Ôćĺ
   215Ôćĺ        If passed no function, returns a decorator which can be applied to a
   216Ôćĺ        function later using the attributes supplied.
   217Ôćĺ
   218Ôćĺ        :param optionalhook:
   219Ôćĺ            If ``True``, a missing matching hook specification will not result
   220Ôćĺ            in an error (by default it is an error if no matching spec is
   221Ôćĺ            found). See :ref:`optionalhook`.
   222Ôćĺ
   223Ôćĺ        :param tryfirst:
   224Ôćĺ            If ``True``, this hook implementation will run as early as possible
   225Ôćĺ            in the chain of N hook implementations for a specification. See
   226Ôćĺ            :ref:`callorder`.
   227Ôćĺ
   228Ôćĺ        :param trylast:
   229Ôćĺ            If ``True``, this hook implementation will run as late as possible
   230Ôćĺ            in the chain of N hook implementations for a specification. See
   231Ôćĺ            :ref:`callorder`.
   232Ôćĺ
   233Ôćĺ        :param wrapper:
   234Ôćĺ            If ``True`` ("new-style hook wrapper"), the hook implementation
   235Ôćĺ            needs to execute exactly one ``yield``. The code before the
   236Ôćĺ            ``yield`` is run early before any non-hook-wrapper function is run.
   237Ôćĺ            The code after the ``yield`` is run after all non-hook-wrapper
   238Ôćĺ            functions have run. The ``yield`` receives the result value of the
   239Ôćĺ            inner calls, or raises the exception of inner calls (including
   240Ôćĺ            earlier hook wrapper calls). The return value of the function
   241Ôćĺ            becomes the return value of the hook, and a raised exception becomes
   242Ôćĺ            the exception of the hook. See :ref:`hookwrapper`.
   243Ôćĺ
   244Ôćĺ        :param hookwrapper:
   245Ôćĺ            If ``True`` ("old-style hook wrapper"), the hook implementation
   246Ôćĺ            needs to execute exactly one ``yield``. The code before the
   247Ôćĺ            ``yield`` is run early before any non-hook-wrapper function is run.
   248Ôćĺ            The code after the ``yield`` is run after all non-hook-wrapper
   249Ôćĺ            function have run  The ``yield`` receives a :class:`Result` object
   250Ôćĺ            representing the exception or result outcome of the inner calls
   251Ôćĺ            (including earlier hook wrapper calls). This option is mutually
   252Ôćĺ            exclusive with ``wrapper``. See :ref:`old_style_hookwrapper`.
   253Ôćĺ
   254Ôćĺ        :param specname:
   255Ôćĺ            If provided, the given name will be used instead of the function
   256Ôćĺ            name when matching this hook implementation to a hook specification
   257Ôćĺ            during registration. See :ref:`specname`.
   258Ôćĺ
   259Ôćĺ        .. versionadded:: 1.2.0
   260Ôćĺ            The ``wrapper`` parameter.
   261Ôćĺ        """
   262Ôćĺ
   263Ôćĺ        def setattr_hookimpl_opts(func: _F) -> _F:
   264Ôćĺ            opts: HookimplOpts = {
   265Ôćĺ                "wrapper": wrapper,
   266Ôćĺ                "hookwrapper": hookwrapper,
   267Ôćĺ                "optionalhook": optionalhook,
   268Ôćĺ                "tryfirst": tryfirst,
   269Ôćĺ                "trylast": trylast,
   270Ôćĺ                "specname": specname,
   271Ôćĺ            }
   272Ôćĺ            setattr(func, self.project_name + "_impl", opts)
   273Ôćĺ            return func
   274Ôćĺ
   275Ôćĺ        if function is None:
   276Ôćĺ            return setattr_hookimpl_opts
   277Ôćĺ        else:
   278Ôćĺ            return setattr_hookimpl_opts(function)

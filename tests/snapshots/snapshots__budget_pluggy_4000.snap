   165Ôćĺclass HookimplMarker:
   166Ôćĺ    """Decorator for marking functions as hook implementations.
   167Ôćĺ
   168Ôćĺ    Instantiate it with a ``project_name`` to get a decorator.
   169Ôćĺ    Calling :meth:`PluginManager.register` later will discover all marked
   170Ôćĺ    functions if the :class:`PluginManager` uses the same project name.
   171Ôćĺ    """
   172Ôćĺ
   173Ôćĺ    __slots__ = ("project_name",)
   174Ôćĺ
   175Ôćĺ    def __init__(self, project_name: str) -> None:
   176Ôćĺ        self.project_name: Final = project_name
   177Ôćĺ
   178Ôćĺ    @overload
   179Ôćĺ    def __call__(
   180Ôćĺ        self,
   181Ôćĺ        function: _F,
   182Ôćĺ        hookwrapper: bool = ...,
   183Ôćĺ        optionalhook: bool = ...,
   184Ôćĺ        tryfirst: bool = ...,
   185Ôćĺ        trylast: bool = ...,
   186Ôćĺ        specname: str | None = ...,
   187Ôćĺ        wrapper: bool = ...,

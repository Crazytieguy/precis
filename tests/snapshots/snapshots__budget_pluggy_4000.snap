    90Ôćĺ
    91Ôćĺ    @overload
    92Ôćĺ    def __call__(
    93Ôćĺ        self,
    94Ôćĺ        function: _F,
    95Ôćĺ        firstresult: bool = False,
    96Ôćĺ        historic: bool = False,
    97Ôćĺ        warn_on_impl: Warning | None = None,
    98Ôćĺ        warn_on_impl_args: Mapping[str, Warning] | None = None,
    99Ôćĺ    ) -> _F: ...
   100Ôćĺ
   101Ôćĺ    @overload  # noqa: F811
   102Ôćĺ    def __call__(  # noqa: F811
   103Ôćĺ        self,
   104Ôćĺ        function: None = ...,
   105Ôćĺ        firstresult: bool = ...,
   106Ôćĺ        historic: bool = ...,
   107Ôćĺ        warn_on_impl: Warning | None = ...,
   108Ôćĺ        warn_on_impl_args: Mapping[str, Warning] | None = ...,
   109Ôćĺ    ) -> Callable[[_F], _F]: ...
   110Ôćĺ
   111Ôćĺ    def __call__(  # noqa: F811
   112Ôćĺ        self,
   113Ôćĺ        function: _F | None = None,
   114Ôćĺ        firstresult: bool = False,
   115Ôćĺ        historic: bool = False,
   116Ôćĺ        warn_on_impl: Warning | None = None,
   117Ôćĺ        warn_on_impl_args: Mapping[str, Warning] | None = None,
   118Ôćĺ    ) -> _F | Callable[[_F], _F]:
   119Ôćĺ        """If passed a function, directly sets attributes on the function
   120Ôćĺ        which will make it discoverable to :meth:`PluginManager.add_hookspecs`.
   121Ôćĺ
   122Ôćĺ        If passed no function, returns a decorator which can be applied to a
   123Ôćĺ        function later using the attributes supplied.
   124Ôćĺ
   125Ôćĺ        :param firstresult:
   126Ôćĺ            If ``True``, the 1:N hook call (N being the number of registered
   127Ôćĺ            hook implementation functions) will stop at I<=N when the I'th
   128Ôćĺ            function returns a non-``None`` result. See :ref:`firstresult`.
   129Ôćĺ
   130Ôćĺ        :param historic:
   131Ôćĺ            If ``True``, every call to the hook will be memorized and replayed
   132Ôćĺ            on plugins registered after the call was made. See :ref:`historic`.
   133Ôćĺ
   134Ôćĺ        :param warn_on_impl:
   135Ôćĺ            If given, every implementation of this hook will trigger the given
   136Ôćĺ            warning. See :ref:`warn_on_impl`.
   137Ôćĺ
   138Ôćĺ        :param warn_on_impl_args:
   139Ôćĺ            If given, every implementation of this hook which requests one of
   140Ôćĺ            the arguments in the dict will trigger the corresponding warning.
   141Ôćĺ            See :ref:`warn_on_impl`.
   142Ôćĺ
   143Ôćĺ            .. versionadded:: 1.5
   144Ôćĺ        """
   145Ôćĺ
   146Ôćĺ        def setattr_hookspec_opts(func: _F) -> _F:
   147Ôćĺ            if historic and firstresult:
   148Ôćĺ                raise ValueError("cannot have a historic firstresult hook")
   149Ôćĺ            opts: HookspecOpts = {
   150Ôćĺ                "firstresult": firstresult,
   151Ôćĺ                "historic": historic,
   152Ôćĺ                "warn_on_impl": warn_on_impl,
   153Ôćĺ                "warn_on_impl_args": warn_on_impl_args,
   154Ôćĺ            }
   155Ôćĺ            setattr(func, self.project_name + "_spec", opts)
   156Ôćĺ            return func
   157Ôćĺ
   158Ôćĺ        if function is not None:
   159Ôćĺ            return setattr_hookspec_opts(function)
   160Ôćĺ        else:
   161Ôćĺ            return setattr_hookspec_opts

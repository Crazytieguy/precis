    16Ôćĺclass TagTracer:
    17Ôćĺ    def __init__(self) -> None:
    18Ôćĺ        self._tags2proc: dict[tuple[str, ...], _Processor] = {}
    19Ôćĺ        self._writer: _Writer | None = None
    20Ôćĺ        self.indent = 0
    21Ôćĺ
    22Ôćĺ    def get(self, name: str) -> TagTracerSub:
    23Ôćĺ        return TagTracerSub(self, (name,))
    24Ôćĺ
    25Ôćĺ    def _format_message(self, tags: Sequence[str], args: Sequence[object]) -> str:
    26Ôćĺ        if isinstance(args[-1], dict):
    27Ôćĺ            extra = args[-1]
    28Ôćĺ            args = args[:-1]
    29Ôćĺ        else:
    30Ôćĺ            extra = {}
    31Ôćĺ
    32Ôćĺ        content = " ".join(map(str, args))
    33Ôćĺ        indent = "  " * self.indent
    34Ôćĺ
    35Ôćĺ        lines = [f"{indent}{content} [{':'.join(tags)}]\n"]
    36Ôćĺ
    37Ôćĺ        for name, value in extra.items():
    38Ôćĺ            lines.append(f"{indent}    {name}: {value}\n")
    39Ôćĺ
    40Ôćĺ        return "".join(lines)
    41Ôćĺ
    42Ôćĺ    def _processmessage(self, tags: tuple[str, ...], args: tuple[object, ...]) -> None:
    43Ôćĺ        if self._writer is not None and args:
    44Ôćĺ            self._writer(self._format_message(tags, args))
    45Ôćĺ        if processor := self._tags2proc.get(tags):
    46Ôćĺ            processor(tags, args)
    48Ôćĺ    def setwriter ÔÇŽ
    51Ôćĺ    def setprocessor ÔÇŽ
    59Ôćĺclass TagTracerSub:
    60Ôćĺ    def __init__(self, root: TagTracer, tags: tuple[str, ...]) -> None:
    61Ôćĺ        self.root = root
    62Ôćĺ        self.tags = tags
    63Ôćĺ
    64Ôćĺ    def __call__(self, *args: object) -> None:
    65Ôćĺ        self.root._processmessage(self.tags, args)
    66Ôćĺ
    67Ôćĺ    def get(self, name: str) -> TagTracerSub:
    68Ôćĺ        return self.__class__(self.root, self.tags + (name,))

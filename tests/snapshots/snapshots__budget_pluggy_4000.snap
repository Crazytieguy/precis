    47Ôćĺ            return None
    48Ôćĺ        else:
    49Ôćĺ            return (type(exc), exc, self._traceback)
    50Ôćĺ
    51Ôćĺ    @property
    52Ôćĺ    def exception(self) -> BaseException | None:
    53Ôćĺ        """:meta private:"""
    54Ôćĺ        return self._exception
    55Ôćĺ
    56Ôćĺ    @classmethod
    57Ôćĺ    def from_call(cls, func: Callable[[], ResultType]) -> Result[ResultType]:
    58Ôćĺ        """:meta private:"""
    59Ôćĺ        __tracebackhide__ = True
    60Ôćĺ        result = exception = None
    61Ôćĺ        try:
    62Ôćĺ            result = func()
    63Ôćĺ        except BaseException as exc:
    64Ôćĺ            exception = exc
    65Ôćĺ        return cls(result, exception)
    66Ôćĺ
    67Ôćĺ    def force_result(self, result: ResultType) -> None:
    68Ôćĺ        """Force the result(s) to ``result``.
    69Ôćĺ
    70Ôćĺ        If the hook was marked as a ``firstresult`` a single value should
    71Ôćĺ        be set, otherwise set a (modified) list of results. Any exceptions
    72Ôćĺ        found during invocation will be deleted.
    73Ôćĺ
    74Ôćĺ        This overrides any previous result or exception.
    75Ôćĺ        """
    76Ôćĺ        self._result = result
    77Ôćĺ        self._exception = None
    78Ôćĺ        self._traceback = None
    79Ôćĺ
    80Ôćĺ    def force_exception(self, exception: BaseException) -> None:
    81Ôćĺ        """Force the result to fail with ``exception``.
    82Ôćĺ
    83Ôćĺ        This overrides any previous result or exception.
    84Ôćĺ
    85Ôćĺ        .. versionadded:: 1.1.0
    86Ôćĺ        """
    87Ôćĺ        self._result = None
    88Ôćĺ        self._exception = exception
    89Ôćĺ        self._traceback = exception.__traceback__ if exception is not None else None
    90Ôćĺ
    91Ôćĺ    def get_result(self) -> ResultType:
    92Ôćĺ        """Get the result(s) for this hook call.
    93Ôćĺ
    94Ôćĺ        If the hook was marked as a ``firstresult`` only a single value
    95Ôćĺ        will be returned, otherwise a list of results.
    96Ôćĺ        """
    97Ôćĺ        __tracebackhide__ = True
    98Ôćĺ        exc = self._exception
    99Ôćĺ        tb = self._traceback
   100Ôćĺ        if exc is None:
   101Ôćĺ            return cast(ResultType, self._result)
   102Ôćĺ        else:
   103Ôćĺ            raise exc.with_traceback(tb)

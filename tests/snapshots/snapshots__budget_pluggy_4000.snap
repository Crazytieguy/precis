   425→        self,
   426→        specmodule_or_class: _Namespace,
   427→        spec_opts: HookspecOpts,
   428→    ) -> None:
   429→        if self.spec is not None:
   430→            raise ValueError(
   431→                f"Hook {self.spec.name!r} is already registered "
   432→                f"within namespace {self.spec.namespace}"

scripts/towncrier-draft-to-file.py
     1→from subprocess import call
     2→import sys
     5→def main() -> int:
     6→    """
     7→    Platform agnostic wrapper script for towncrier.
     8→    Fixes the issue (pytest#7251) where windows users are unable to natively
     9→    run tox -e docs to build pytest docs.
    10→    """
    11→    with open("docs/_changelog_towncrier_draft.rst", "w") as draft_file:
    12→        return call(("towncrier", "--draft"), stdout=draft_file)


   608Ôćĺ        "_orig",
   609Ôćĺ        "_remove_plugins",
   610Ôćĺ    )
   611Ôćĺ
   612Ôćĺ    def __init__(self, orig: HookCaller, remove_plugins: Set[_Plugin]) -> None:
   613Ôćĺ        self._orig = orig

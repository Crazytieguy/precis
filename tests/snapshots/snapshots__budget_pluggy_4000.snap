    25Ôćĺclass Result(Generic[ResultType]):
    26Ôćĺ    """An object used to inspect and set the result in a :ref:`hook wrapper
    27Ôćĺ    <hookwrappers>`."""
    28Ôćĺ
    29Ôćĺ    __slots__ = ("_result", "_exception", "_traceback")
    30Ôćĺ
    31Ôćĺ    def __init__(
    32Ôćĺ        self,
    33Ôćĺ        result: ResultType | None,
    34Ôćĺ        exception: BaseException | None,
    35Ôćĺ    ) -> None:
    36Ôćĺ        """:meta private:"""
    37Ôćĺ        self._result = result
    38Ôćĺ        self._exception = exception
    39Ôćĺ        # Exception __traceback__ is mutable, this keeps the original.
    40Ôćĺ        self._traceback = exception.__traceback__ if exception is not None else None
    41Ôćĺ
    42Ôćĺ    @property
    43Ôćĺ    def excinfo(self) -> _ExcInfo | None:
    44Ôćĺ        """:meta private:"""
    45Ôćĺ        exc = self._exception

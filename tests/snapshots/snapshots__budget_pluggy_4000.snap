   593Ôćĺclass _SubsetHookCaller(HookCaller):
   594Ôćĺ    """A proxy to another HookCaller which manages calls to all registered
   595Ôćĺ    plugins except the ones from remove_plugins."""
   596Ôćĺ
   597Ôćĺ    # This class is unusual: in inhertits from `HookCaller` so all of
   598Ôćĺ    # the *code* runs in the class, but it delegates all underlying *data*
   599Ôćĺ    # to the original HookCaller.
   600Ôćĺ    # `subset_hook_caller` used to be implemented by creating a full-fledged
   601Ôćĺ    # HookCaller, copying all hookimpls from the original. This had problems
   602Ôćĺ    # with memory leaks (#346) and historic calls (#347), which make a proxy
   603Ôćĺ    # approach better.

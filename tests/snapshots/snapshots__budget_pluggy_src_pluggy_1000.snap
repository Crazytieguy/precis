    28→
    29→    __slots__ = ("_result", "_exception", "_traceback")
    30→
    31→    def __init__(
    32→        self,
    33→        result: ResultType | None,
    34→        exception: BaseException | None,
    35→    ) -> None:
    36→        """:meta private:"""
    37→        self._result = result

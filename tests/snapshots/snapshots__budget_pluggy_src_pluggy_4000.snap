   593→class _SubsetHookCaller(HookCaller):
   594→    """A proxy to another HookCaller which manages calls to all registered
   595→    plugins except the ones from remove_plugins."""
   596→
   597→    # This class is unusual: in inhertits from `HookCaller` so all of
   598→    # the *code* runs in the class, but it delegates all underlying *data*
   599→    # to the original HookCaller.
   600→    # `subset_hook_caller` used to be implemented by creating a full-fledged
   601→    # HookCaller, copying all hookimpls from the original. This had problems
   602→    # with memory leaks (#346) and historic calls (#347), which make a proxy
   603→    # approach better.
   604→    # An alternative implementation is to use a `_getattr__`/`__getattribute__`
   605→    # proxy, however that adds more overhead and is more tricky to implement.
   606→
   607→    __slots__ = (
   608→        "_orig",
   609→        "_remove_plugins",
   610→    )
   611→
   612→    def __init__(self, orig: HookCaller, remove_plugins: Set[_Plugin]) -> None:
   613→        self._orig = orig
   614→        self._remove_plugins = remove_plugins
   615→        self.name = orig.name  # type: ignore[misc]
   616→        self._hookexec = orig._hookexec  # type: ignore[misc]
   617→
   618→    @property  # type: ignore[misc]
   619→    def _hookimpls(self) -> list[HookImpl]:
   620→        return [
   621→            impl
   622→            for impl in self._orig._hookimpls
   623→            if impl.plugin not in self._remove_plugins
   624→        ]
   625→
   626→    @property
   627→    def spec(self) -> HookSpec | None:  # type: ignore[override]
   628→        return self._orig.spec
   629→
   630→    @property
   631→    def _call_history(self) -> _CallHistory | None:  # type: ignore[override]
   632→        return self._orig._call_history
   633→
   634→    def __repr__(self) -> str:
   635→        return f"<_SubsetHookCaller {self.name!r}>"
   638→@final
   639→class HookImpl:
   640→    """A hook implementation in a :class:`HookCaller`."""
   641→
   642→    __slots__ = (
   643→        "function",
   644→        "argnames",
   645→        "kwargnames",
   646→        "plugin",
   647→        "opts",
   648→        "plugin_name",
   649→        "wrapper",
   650→        "hookwrapper",
   651→        "optionalhook",
   652→        "tryfirst",
   653→        "trylast",

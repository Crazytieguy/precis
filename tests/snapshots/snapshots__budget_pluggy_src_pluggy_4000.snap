   673→        #: The :class:`HookimplOpts` used to configure this hook implementation.
   674→        self.opts: Final = hook_impl_opts
   675→        #: The name of the plugin which defined this hook implementation.
   676→        self.plugin_name: Final = plugin_name
   677→        #: Whether the hook implementation is a :ref:`wrapper <hookwrapper>`.
   678→        self.wrapper: Final = hook_impl_opts["wrapper"]
   679→        #: Whether the hook implementation is an :ref:`old-style wrapper
   680→        #: <old_style_hookwrappers>`.
   681→        self.hookwrapper: Final = hook_impl_opts["hookwrapper"]
   682→        #: Whether validation against a hook specification is :ref:`optional
   683→        #: <optionalhook>`.
   684→        self.optionalhook: Final = hook_impl_opts["optionalhook"]
   685→        #: Whether to try to order this hook implementation :ref:`first
   686→        #: <callorder>`.
   687→        self.tryfirst: Final = hook_impl_opts["tryfirst"]
   688→        #: Whether to try to order this hook implementation :ref:`last
   689→        #: <callorder>`.
   690→        self.trylast: Final = hook_impl_opts["trylast"]
   691→
   692→    def __repr__(self) -> str:
   693→        return f"<HookImpl plugin_name={self.plugin_name!r}, plugin={self.plugin!r}>"
   696→@final
   697→class HookSpec:
   698→    __slots__ = (
   699→        "namespace",
   700→        "function",
   701→        "name",
   702→        "argnames",
   703→        "kwargnames",
   704→        "opts",
   705→        "warn_on_impl",
   706→        "warn_on_impl_args",
   707→    )
   708→
   709→    def __init__(self, namespace: _Namespace, name: str, opts: HookspecOpts) -> None:
   710→        self.namespace = namespace
   711→        self.function: Callable[..., object] = getattr(namespace, name)
   712→        self.name = name
   713→        self.argnames, self.kwargnames = varnames(self.function)
   714→        self.opts = opts
   715→        self.warn_on_impl = opts.get("warn_on_impl")
   716→        self.warn_on_impl_args = opts.get("warn_on_impl_args")

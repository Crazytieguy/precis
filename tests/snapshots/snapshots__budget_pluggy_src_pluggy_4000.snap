    30→    """
    31→    backward compatibility wrapper to run a old style hookwrapper as a wrapper
    32→    """
    33→    if TYPE_CHECKING:
    34→        teardown = cast(Teardown, hook_impl.function(*args))
    35→    else:
    36→        teardown = hook_impl.function(*args)
    37→    try:

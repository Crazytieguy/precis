    24‚Üí@final
    25‚Üíclass Result(Generic[ResultType]):
    26‚Üí    """An object used to inspect and set the result in a :ref:`hook wrapper
    27‚Üí    <hookwrappers>`."""
    28‚Üí
    29‚Üí    __slots__ = ("_result", "_exception", "_traceback")
    30‚Üí
    31‚Üí    def __init__(
    32‚Üí        self,
    33‚Üí        result: ResultType | None,
    34‚Üí        exception: BaseException | None,
    35‚Üí    ) -> None:
    36‚Üí        """:meta private:"""
    37‚Üí        self._result = result
    38‚Üí        self._exception = exception
    39‚Üí        # Exception __traceback__ is mutable, this keeps the original.
    40‚Üí        self._traceback = exception.__traceback__ if exception is not None else None
    41‚Üí
    42‚Üí    @property
    43‚Üí    def excinfo(self) -> _ExcInfo | None:
    44‚Üí        """:meta private:"""
    45‚Üí        exc = self._exception
    46‚Üí        if exc is None:
    47‚Üí            return None
    48‚Üí        else:
    49‚Üí            return (type(exc), exc, self._traceback)
    50‚Üí
    51‚Üí    @property
    52‚Üí    def exception(self) -> BaseException | None:
    53‚Üí        """:meta private:"""
    54‚Üí        return self._exception
    55‚Üí
    56‚Üí    @classmethod
    57‚Üí    def from_call(cls, func: Callable[[], ResultType]) -> Result[ResultType]:
    58‚Üí        """:meta private:"""
    59‚Üí        __tracebackhide__ = True
    60‚Üí        result = exception = None
    61‚Üí        try:
    62‚Üí            result = func()
    63‚Üí        except BaseException as exc:
    64‚Üí            exception = exc
    65‚Üí        return cls(result, exception)
    66‚Üí
    67‚Üí    def force_result(self, result: ResultType) -> None:
    68‚Üí        """Force the result(s) to ``result``.
    69‚Üí
    70‚Üí        If the hook was marked as a ``firstresult`` a single value should
    71‚Üí        be set, otherwise set a (modified) list of results. Any exceptions
    72‚Üí        found during invocation will be deleted.
    73‚Üí
    74‚Üí        This overrides any previous result or exception.
    75‚Üí        """
    76‚Üí        self._result = result
    77‚Üí        self._exception = None
    78‚Üí        self._traceback = None
    79‚Üí
    80‚Üí    def force_exception(self, exception: BaseException) -> None:
    81‚Üí        """Force the result to fail with ``exception``.
    82‚Üí
    83‚Üí        This overrides any previous result or exception.
    84‚Üí
    85‚Üí        .. versionadded:: 1.1.0
    86‚Üí        """
    87‚Üí        self._result = None
    88‚Üí        self._exception = exception
    89‚Üí        self._traceback = exception.__traceback__ if exception is not None else None
    90‚Üí
    91‚Üí    def get_result(self) -> ResultType:
    92‚Üí        """Get the result(s) for this hook call.
    93‚Üí
    94‚Üí        If the hook was marked as a ``firstresult`` only a single value
    95‚Üí        will be returned, otherwise a list of results.
    96‚Üí        """
    97‚Üí        __tracebackhide__ = True
    98‚Üí        exc = self._exception
    99‚Üí        tb = self._traceback
   100‚Üí        if exc is None:
   101‚Üí            return cast(ResultType, self._result)
   102‚Üí        else:
   103‚Üí            raise exc.with_traceback(tb)
_tracing.py
    16‚Üíclass TagTracer:
    17‚Üí    def __init__(self) -> None:
    18‚Üí        self._tags2proc: dict[tuple[str, ...], _Processor] = {}
    19‚Üí        self._writer: _Writer | None = None
    20‚Üí        self.indent = 0
    21‚Üí
    22‚Üí    def get(self, name: str) -> TagTracerSub:
    23‚Üí        return TagTracerSub(self, (name,))
    24‚Üí
    25‚Üí    def _format_message(self, tags: Sequence[str], args: Sequence[object]) -> str:
    26‚Üí        if isinstance(args[-1], dict):
    27‚Üí            extra = args[-1]
    28‚Üí            args = args[:-1]
    29‚Üí        else:
    30‚Üí            extra = {}
    31‚Üí
    32‚Üí        content = " ".join(map(str, args))
    33‚Üí        indent = "  " * self.indent
    34‚Üí
    35‚Üí        lines = [f"{indent}{content} [{':'.join(tags)}]\n"]
    36‚Üí
    37‚Üí        for name, value in extra.items():
    38‚Üí            lines.append(f"{indent}    {name}: {value}\n")
    39‚Üí
    40‚Üí        return "".join(lines)
    41‚Üí
    42‚Üí    def _processmessage(self, tags: tuple[str, ...], args: tuple[object, ...]) -> None:
    48‚Üí    def setwriter(self, writer: _Writer | None) -> None:
    51‚Üí    def setprocessor(self, tags: str | tuple[str, ...], processor: _Processor) -> None:
    59‚Üíclass TagTracerSub:
    60‚Üí    def __init__(self, root: TagTracer, tags: tuple[str, ...]) -> None:
    61‚Üí        self.root = root
    62‚Üí        self.tags = tags
    63‚Üí
    64‚Üí    def __call__(self, *args: object) -> None:
    65‚Üí        self.root._processmessage(self.tags, args)
    66‚Üí
    67‚Üí    def get(self, name: str) -> TagTracerSub:
    68‚Üí        return self.__class__(self.root, self.tags + (name,))

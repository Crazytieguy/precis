    83→class PluginManager:
    99→
   100→    def __init__(self, project_name: str) -> None:
   101→        #: The project name.
   102→        self.project_name: Final = project_name
   103→        self._name2plugin: Final[dict[str, _Plugin]] = {}
   104→        self._plugin_distinfo: Final[list[tuple[_Plugin, DistFacade]]] = []
   105→        #: The "hook relay", used to call a hook on all registered plugins.
   106→        #: See :ref:`calling`.
   107→        self.hook: Final = HookRelay()
   108→        #: The tracing entry point. See :ref:`tracing`.
   109→        self.trace: Final[_tracing.TagTracerSub] = _tracing.TagTracer().get(
   110→            "pluginmanage"
   111→        )
   112→        self._inner_hookexec = _multicall
   113→
   114→    def _hookexec(
   115→        self,
   116→        hook_name: str,
   117→        methods: Sequence[HookImpl],
   118→        kwargs: Mapping[str, object],
   119→        firstresult: bool,
   120→    ) -> object | list[object]:
   121→        # called from all hookcaller instances.
   122→        # enable_tracing will set its own wrapping function at self._inner_hookexec
   123→        return self._inner_hookexec(hook_name, methods, kwargs, firstresult)
   124→
   125→    def register(self, plugin: _Plugin, name: str | None = None) -> str | None:
   126→        """Register a plugin and return its name.
   127→
   128→        :param name:
   129→            The name under which to register the plugin. If not specified, a
   130→            name is generated using :func:`get_canonical_name`.
   131→
   132→        :returns:
   133→            The plugin name. If the name is blocked from registering, returns
   134→            ``None``.
   135→
   136→        If the plugin is already registered, raises a :exc:`ValueError`.
   137→        """
   138→        plugin_name = name or self.get_canonical_name(plugin)
   139→
   140→        if plugin_name in self._name2plugin:
   141→            if self._name2plugin.get(plugin_name, -1) is None:
   142→                return None  # blocked plugin, return None to indicate no registration
   143→            raise ValueError(
   144→                "Plugin name already registered: "
   145→                f"{plugin_name}={plugin}\n{self._name2plugin}"
   146→            )
   147→
   148→        if plugin in self._name2plugin.values():
   149→            raise ValueError(
   150→                "Plugin already registered under a different name: "
   151→                f"{plugin_name}={plugin}\n{self._name2plugin}"
   152→            )
   153→
   154→        # XXX if an error happens we should make sure no state has been
   155→        # changed at point of return
   156→        self._name2plugin[plugin_name] = plugin
   157→
   158→        # register matching hook implementations of the plugin
   159→        for name in dir(plugin):
   160→            hookimpl_opts = self.parse_hookimpl_opts(plugin, name)
   161→            if hookimpl_opts is not None:
   162→                normalize_hookimpl_opts(hookimpl_opts)
   163→                method: _HookImplFunction[object] = getattr(plugin, name)
   164→                hookimpl = HookImpl(plugin, plugin_name, method, hookimpl_opts)
   165→                name = hookimpl_opts.get("specname") or name
   166→                hook: HookCaller | None = getattr(self.hook, name, None)

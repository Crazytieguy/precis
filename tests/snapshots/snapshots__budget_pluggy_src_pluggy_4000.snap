   119‚Üí        """If passed a function, directly sets attributes on the function
   120‚Üí        which will make it discoverable to :meth:`PluginManager.add_hookspecs`.
   121‚Üí
   122‚Üí        If passed no function, returns a decorator which can be applied to a
   123‚Üí        function later using the attributes supplied.
   124‚Üí
   125‚Üí        :param firstresult:
   126‚Üí            If ``True``, the 1:N hook call (N being the number of registered
   127‚Üí            hook implementation functions) will stop at I<=N when the I'th
   128‚Üí            function returns a non-``None`` result. See :ref:`firstresult`.
   129‚Üí
   130‚Üí        :param historic:
   131‚Üí            If ``True``, every call to the hook will be memorized and replayed
   132‚Üí            on plugins registered after the call was made. See :ref:`historic`.
   133‚Üí
   134‚Üí        :param warn_on_impl:
   135‚Üí            If given, every implementation of this hook will trigger the given
   136‚Üí            warning. See :ref:`warn_on_impl`.
   137‚Üí
   138‚Üí        :param warn_on_impl_args:
   139‚Üí            If given, every implementation of this hook which requests one of
   140‚Üí            the arguments in the dict will trigger the corresponding warning.
   141‚Üí            See :ref:`warn_on_impl`.
   142‚Üí
   143‚Üí            .. versionadded:: 1.5
   144‚Üí        """
   145‚Üí
   146‚Üí        def setattr_hookspec_opts(func: _F) -> _F:
   147‚Üí            if historic and firstresult:
   148‚Üí                raise ValueError("cannot have a historic firstresult hook")
   149‚Üí            opts: HookspecOpts = {
   150‚Üí                "firstresult": firstresult,
   151‚Üí                "historic": historic,
   152‚Üí                "warn_on_impl": warn_on_impl,
   153‚Üí                "warn_on_impl_args": warn_on_impl_args,
   154‚Üí            }
   155‚Üí            setattr(func, self.project_name + "_spec", opts)
   156‚Üí            return func
   157‚Üí
   158‚Üí        if function is not None:
   159‚Üí            return setattr_hookspec_opts(function)
   160‚Üí        else:
   161‚Üí            return setattr_hookspec_opts

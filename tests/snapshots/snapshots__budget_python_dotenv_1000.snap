    18â†’class Atom(metaclass=ABCMeta):
    19â†’    def __ne__(self, other: object) -> bool:
    20â†’        result = self.__eq__(other)
    21â†’        if result is NotImplemented:
    22â†’            return NotImplemented
    23â†’        return not result
    25â†’    @abstractmethod
    26â†’    def resolve(self, env: Mapping[str, Optional[str]]) -> str: ...
    29â†’class Literal(Atom):
    30â†’    def __init__(self, value: str) -> None:
    31â†’        self.value = value
    32â†’
    33â†’    def __repr__(self) -> str:
    34â†’        return f"Literal(value={self.value})"
    48â†’class Variable(Atom):

    18тЖТclass Atom(metaclass=ABCMeta):
    19тЖТ    def __ne__(self, other: object) -> bool:
    20тЖТ        result = self.__eq__(other)
    21тЖТ        if result is NotImplemented:
    22тЖТ            return NotImplemented
    23тЖТ        return not result
    25тЖТ    @abstractmethod
    26тЖТ    def resolve(self, env: Mapping[str, Optional[str]]) -> str: ...
    29тЖТclass Literal(Atom):
    30тЖТ    def __init__(self, value: str) -> None:
    31тЖТ        self.value = value
    32тЖТ
    33тЖТ    def __repr__(self) -> str:
    34тЖТ        return f"Literal(value={self.value})"

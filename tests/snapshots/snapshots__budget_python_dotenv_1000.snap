    12тЖТclass IPythonDotEnv(Magics):
    13тЖТ    @magic_arguments()
    14тЖТ    @argument(
    15тЖТ        "-o",
    16тЖТ        "--override",
    17тЖТ        action="store_true",
    18тЖТ        help="Indicate to override existing variables",
    19тЖТ    )
    20тЖТ    @argument(
    21тЖТ        "-v",
    22тЖТ        "--verbose",
    23тЖТ        action="store_true",
    24тЖТ        help="Indicate function calls to be verbose",
    25тЖТ    )
    26тЖТ    @argument(
    27тЖТ        "dotenv_path",
    28тЖТ        nargs="?",
    29тЖТ        type=str,
    30тЖТ        default=".env",
    31тЖТ        help="Search in increasingly higher folders for the `dotenv_path`",
    32тЖТ    )
    33тЖТ    @line_magic
    34тЖТ    def dotenv(self, line):
    35тЖТ        args = parse_argstring(self.dotenv, line)
    36тЖТ        # Locate the .env file
    37тЖТ        dotenv_path = args.dotenv_path
    38тЖТ        try:
    39тЖТ            dotenv_path = find_dotenv(dotenv_path, True, True)
    40тЖТ        except IOError:
    41тЖТ            print("cannot find .env file")
    42тЖТ            return
    43тЖТ
    44тЖТ        # Load the .env file
    45тЖТ        load_dotenv(dotenv_path, verbose=args.verbose, override=args.override)

    25‚Üídef _load_dotenv_disabled() -> bool:
    26‚Üí    """
    27‚Üí    Determine if dotenv loading has been disabled.
    28‚Üí    """
    29‚Üí    if "PYTHON_DOTENV_DISABLED" not in os.environ:
    30‚Üí        return False
    31‚Üí    value = os.environ["PYTHON_DOTENV_DISABLED"].casefold()
    32‚Üí    return value in {"1", "true", "t", "yes", "y"}

    18вҶ’class Atom(metaclass=ABCMeta):
    19вҶ’    def __ne__(self, other: object) -> bool:
    20вҶ’        result = self.__eq__(other)
    21вҶ’        if result is NotImplemented:
    22вҶ’            return NotImplemented
    23вҶ’        return not result

    60вҶ’@click.version_option(version=__version__)
    61вҶ’@click.pass_context
    62вҶ’def cli(ctx: click.Context, file: Any, quote: Any, export: Any) -> None:
    63вҶ’    """This script is used to set, get or unset values from a .env file."""
    64вҶ’    ctx.obj = {"QUOTE": quote, "EXPORT": export, "FILE": file}
    67вҶ’@contextmanager
    68вҶ’def stream_file(path: os.PathLike) -> Iterator[IO[str]]:
    69вҶ’    """
    70вҶ’    Open a file and yield the corresponding (decoded) stream.
    71вҶ’
    72вҶ’    Exits with error code 2 if the file cannot be opened.
    73вҶ’    """
    74вҶ’
    75вҶ’    try:
    76вҶ’        with open(path) as stream:
    77вҶ’            yield stream
    78вҶ’    except OSError as exc:
    79вҶ’        print(f"Error opening env file: {exc}", file=sys.stderr)
    80вҶ’        sys.exit(2)
    93вҶ’def list_values вҖҰ
   112вҶ’@cli.command(name="set")
   113вҶ’@click.pass_context
   114вҶ’@click.argument("key", required=True)
   115вҶ’@click.argument("value", required=True)
   116вҶ’def set_value(ctx: click.Context, key: Any, value: Any) -> None:
   117вҶ’    """Store the given key/value."""
   118вҶ’    file = ctx.obj["FILE"]
   119вҶ’    quote = ctx.obj["QUOTE"]
   120вҶ’    export = ctx.obj["EXPORT"]
   121вҶ’    success, key, value = set_key(file, key, value, quote, export)
   122вҶ’    if success:
   123вҶ’        click.echo(f"{key}={value}")
   124вҶ’    else:
   125вҶ’        sys.exit(1)
   128вҶ’@cli.command()
   129вҶ’@click.pass_context
   130вҶ’@click.argument("key", required=True)
   131вҶ’def get(ctx: click.Context, key: Any) -> None:
   132вҶ’    """Retrieve the value for the given key."""
   133вҶ’    file = ctx.obj["FILE"]
   134вҶ’
   135вҶ’    with stream_file(file) as stream:
   136вҶ’        values = dotenv_values(stream=stream)
   137вҶ’
   138вҶ’    stored_value = values.get(key)
   139вҶ’    if stored_value:
   140вҶ’        click.echo(stored_value)
   141вҶ’    else:
   142вҶ’        sys.exit(1)
   145вҶ’@cli.command()
   146вҶ’@click.pass_context
   147вҶ’@click.argument("key", required=True)
   148вҶ’def unset(ctx: click.Context, key: Any) -> None:
   149вҶ’    """Removes the given key."""
   150вҶ’    file = ctx.obj["FILE"]
   151вҶ’    quote = ctx.obj["QUOTE"]
   152вҶ’    success, key = unset_key(file, key, quote)
   153вҶ’    if success:
   154вҶ’        click.echo(f"Successfully removed {key}")
   155вҶ’    else:
   156вҶ’        sys.exit(1)
   172вҶ’@click.argument("commandline", nargs=-1, type=click.UNPROCESSED)
   173вҶ’def run(ctx: click.Context, override: bool, commandline: tuple[str, ...]) -> None:
   174вҶ’    """Run command with environment variables present."""
   175вҶ’    file = ctx.obj["FILE"]
   176вҶ’    if not os.path.isfile(file):
   177вҶ’        raise click.BadParameter(
   178вҶ’            f"Invalid value for '-f' \"{file}\" does not exist.", ctx=ctx
   179вҶ’        )
   180вҶ’    dotenv_as_dict = {
   181вҶ’        k: v
   182вҶ’        for (k, v) in dotenv_values(file).items()
   183вҶ’        if v is not None and (override or k not in os.environ)
   184вҶ’    }
   185вҶ’
   186вҶ’    if not commandline:
   187вҶ’        click.echo("No command given.")
   188вҶ’        sys.exit(1)
   189вҶ’
   190вҶ’    run_command([*commandline, *ctx.args], dotenv_as_dict)

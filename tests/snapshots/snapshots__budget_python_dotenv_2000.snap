    11вҶ’@magics_class
    12вҶ’class IPythonDotEnv(Magics):
    13вҶ’    @magic_arguments()
    14вҶ’    @argument(
    15вҶ’        "-o",
    16вҶ’        "--override",
    17вҶ’        action="store_true",
    18вҶ’        help="Indicate to override existing variables",
    19вҶ’    )
    20вҶ’    @argument(
    21вҶ’        "-v",
    22вҶ’        "--verbose",
    23вҶ’        action="store_true",
    24вҶ’        help="Indicate function calls to be verbose",
    25вҶ’    )
    26вҶ’    @argument(
    27вҶ’        "dotenv_path",
    28вҶ’        nargs="?",
    29вҶ’        type=str,
    30вҶ’        default=".env",
    31вҶ’        help="Search in increasingly higher folders for the `dotenv_path`",
    32вҶ’    )
    33вҶ’    @line_magic
    34вҶ’    def dotenv(self, line):
    35вҶ’        args = parse_argstring(self.dotenv, line)
    36вҶ’        # Locate the .env file
    37вҶ’        dotenv_path = args.dotenv_path
    38вҶ’        try:
    39вҶ’            dotenv_path = find_dotenv(dotenv_path, True, True)
    40вҶ’        except IOError:
    41вҶ’            print("cannot find .env file")
    42вҶ’            return
    43вҶ’
    44вҶ’        # Load the .env file
    45вҶ’        load_dotenv(dotenv_path, verbose=args.verbose, override=args.override)

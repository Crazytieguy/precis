   141вҶ’@contextmanager
   142вҶ’def rewrite(
   143вҶ’    path: StrPath,
   144вҶ’    encoding: Optional[str],
   145вҶ’) -> Iterator[Tuple[IO[str], IO[str]]]:
   146вҶ’    pathlib.Path(path).touch()
   147вҶ’
   148вҶ’    with tempfile.NamedTemporaryFile(mode="w", encoding=encoding, delete=False) as dest:
   149вҶ’        error = None
   150вҶ’        try:
   151вҶ’            with open(path, encoding=encoding) as source:
   152вҶ’                yield (source, dest)
   153вҶ’        except BaseException as err:
   154вҶ’            error = err
   155вҶ’
   156вҶ’    if error is None:
   157вҶ’        shutil.move(dest.name, path)
   158вҶ’    else:
   159вҶ’        os.unlink(dest.name)
   160вҶ’        raise error from None

    47в†’class Position:
    48в†’    def __init__(self, chars: int, line: int) -> None:
    49в†’        self.chars = chars
    50в†’        self.line = line
    51в†’
    52в†’    @classmethod
    53в†’    def start(cls) -> "Position":
    54в†’        return cls(chars=0, line=1)
    55в†’
    56в†’    def set(self, other: "Position") -> None:
    57в†’        self.chars = other.chars
    58в†’        self.line = other.line
    59в†’
    60в†’    def advance(self, string: str) -> None:
    61в†’        self.chars += len(string)
    62в†’        self.line += len(re.findall(_newline, string))
    65в†’class Error(Exception):
    66в†’    pass
    69в†’class Reader:
    70в†’    def __init__(self, stream: IO[str]) -> None:
    71в†’        self.string = stream.read()
    72в†’        self.position = Position.start()
    73в†’        self.mark = Position.start()
    74в†’
    75в†’    def has_next(self) -> bool:
    76в†’        return self.position.chars < len(self.string)
    77в†’
    78в†’    def set_mark(self) -> None:
    79в†’        self.mark.set(self.position)
    80в†’
    81в†’    def get_marked(self) -> Original:
    82в†’        return Original(
    83в†’            string=self.string[self.mark.chars : self.position.chars],
    84в†’            line=self.mark.line,
    85в†’        )
    86в†’
    87в†’    def peek(self, count: int) -> str:
    88в†’        return self.string[self.position.chars : self.position.chars + count]
    89в†’
    90в†’    def read(self, count: int) -> str:
    91в†’        result = self.string[self.position.chars : self.position.chars + count]
    92в†’        if len(result) < count:
    93в†’            raise Error("read: End of string")
    94в†’        self.position.advance(result)
    95в†’        return result
    96в†’
    97в†’    def read_regex(self, regex: Pattern[str]) -> Sequence[str]:
    98в†’        match = regex.match(self.string, self.position.chars)
    99в†’        if match is None:
   100в†’            raise Error("read_regex: Pattern not found")
   101в†’        self.position.advance(self.string[match.start() : match.end()])
   102в†’        return match.groups()

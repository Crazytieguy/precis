   269в†’def _walk_to_root(path: str) -> Iterator[str]:
   270в†’    """
   271в†’    Yield directories starting from the given directory up to the root
   272в†’    """
   273в†’    if not os.path.exists(path):
   274в†’        raise IOError("Starting path not found")
   275в†’
   276в†’    if os.path.isfile(path):
   277в†’        path = os.path.dirname(path)
   278в†’
   279в†’    last_dir = None
   280в†’    current_dir = os.path.abspath(path)
   281в†’    while last_dir != current_dir:
   282в†’        yield current_dir
   283в†’        parent_dir = os.path.abspath(os.path.join(current_dir, os.path.pardir))
   284в†’        last_dir, current_dir = current_dir, parent_dir
   287в†’def find_dotenv(
   288в†’    filename: str = ".env",
   289в†’    raise_error_if_not_found: bool = False,
   290в†’    usecwd: bool = False,
   291в†’) -> str:
   292в†’    """
   293в†’    Search in increasingly higher folders for the given file
   294в†’
   295в†’    Returns path to the file if found, or an empty string otherwise
   296в†’    """
   338в†’def load_dotenv(
   339в†’    dotenv_path: Optional[StrPath] = None,
   340в†’    stream: Optional[IO[str]] = None,
   341в†’    verbose: bool = False,
   342в†’    override: bool = False,
   343в†’    interpolate: bool = True,
   344в†’    encoding: Optional[str] = "utf-8",
   345в†’) -> bool:
   346в†’    """Parse a .env file and then load all the variables found as environment variables.
   347в†’
   348в†’    Parameters:
   349в†’        dotenv_path: Absolute or relative path to .env file.
   350в†’        stream: Text stream (such as `io.StringIO`) with .env content, used if
   351в†’            `dotenv_path` is `None`.
   352в†’        verbose: Whether to output a warning the .env file is missing.
   353в†’        override: Whether to override the system environment variables with the variables
   354в†’            from the `.env` file.
   355в†’        encoding: Encoding to be used to read the file.
   356в†’    Returns:
   357в†’        Bool: True if at least one environment variable is set else False
   358в†’
   359в†’    If both `dotenv_path` and `stream` are `None`, `find_dotenv()` is used to find the
   360в†’    .env file with it's default parameters. If you need to change the default parameters
   361в†’    of `find_dotenv()`, you can explicitly call `find_dotenv()` and pass the result
   362в†’    to this function as `dotenv_path`.
   363в†’
   364в†’    If the environment variable `PYTHON_DOTENV_DISABLED` is set to a truthy value,
   365в†’    .env loading is disabled.
   366в†’    """
   387в†’def dotenv_values(
   388в†’    dotenv_path: Optional[StrPath] = None,
   389в†’    stream: Optional[IO[str]] = None,
   390в†’    verbose: bool = False,
   391в†’    interpolate: bool = True,
   392в†’    encoding: Optional[str] = "utf-8",
   393в†’) -> Dict[str, Optional[str]]:
   394в†’    """
   395в†’    Parse a .env file and return its content as a dict.
   396в†’
   397в†’    The returned dict will have `None` values for keys without values in the .env file.
   398в†’    For example, `foo=bar` results in `{"foo": "bar"}` whereas `foo` alone results in
   399в†’    `{"foo": None}`
   400в†’
   401в†’    Parameters:
   402в†’        dotenv_path: Absolute or relative path to the .env file.
   403в†’        stream: `StringIO` object with .env content, used if `dotenv_path` is `None`.
   404в†’        verbose: Whether to output a warning if the .env file is missing.
   405в†’        encoding: Encoding to be used to read the file.
   406в†’
   407в†’    If both `dotenv_path` and `stream` are `None`, `find_dotenv()` is used to find the
   408в†’    .env file.
   409в†’    """
   423в†’def _is_file_or_fifo(path: StrPath) -> bool:
   424в†’    """
   425в†’    Return True if `path` exists and is either a regular file or a FIFO.
   426в†’    """
   427в†’    if os.path.isfile(path):
   428в†’        return True
   429в†’
   430в†’    try:
   431в†’        st = os.stat(path)
   432в†’    except (FileNotFoundError, OSError):
   433в†’        return False
   434в†’
   435в†’    return stat.S_ISFIFO(st.st_mode)

    33â†’    @line_magic
    34â†’    def dotenv(self, line):
    35â†’        args = parse_argstring(self.dotenv, line)
    36â†’        # Locate the .env file
    37â†’        dotenv_path = args.dotenv_path
    38â†’        try:

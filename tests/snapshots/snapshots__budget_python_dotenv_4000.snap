    11‚Üí@magics_class
    12‚Üíclass IPythonDotEnv(Magics):
    13‚Üí    @magic_arguments()
    14‚Üí    @argument(
    15‚Üí        "-o",
    16‚Üí        "--override",
    17‚Üí        action="store_true",
    18‚Üí        help="Indicate to override existing variables",
    19‚Üí    )
    20‚Üí    @argument(
    21‚Üí        "-v",
    22‚Üí        "--verbose",
    23‚Üí        action="store_true",
    24‚Üí        help="Indicate function calls to be verbose",
    25‚Üí    )
    26‚Üí    @argument(
    27‚Üí        "dotenv_path",
    28‚Üí        nargs="?",
    29‚Üí        type=str,
    30‚Üí        default=".env",
    31‚Üí        help="Search in increasingly higher folders for the `dotenv_path`",
    32‚Üí    )
    33‚Üí    @line_magic
    34‚Üí    def dotenv(self, line):
    35‚Üí        args = parse_argstring(self.dotenv, line)
    36‚Üí        # Locate the .env file
    37‚Üí        dotenv_path = args.dotenv_path
    38‚Üí        try:
    39‚Üí            dotenv_path = find_dotenv(dotenv_path, True, True)
    40‚Üí        except IOError:
    41‚Üí            print("cannot find .env file")
    42‚Üí            return
    43‚Üí
    44‚Üí        # Load the .env file
    45‚Üí        load_dotenv(dotenv_path, verbose=args.verbose, override=args.override)
    48‚Üídef load_ipython_extension(ipython):
    49‚Üí    """Register the %dotenv magic."""

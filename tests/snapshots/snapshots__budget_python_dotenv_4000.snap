    45‚Üíclass DotEnv:
    46‚Üí    def __init__(
    47‚Üí        self,
    48‚Üí        dotenv_path: Optional[StrPath],
    49‚Üí        stream: Optional[IO[str]] = None,
    50‚Üí        verbose: bool = False,
    51‚Üí        encoding: Optional[str] = None,
    52‚Üí        interpolate: bool = True,
    53‚Üí        override: bool = True,
    54‚Üí    ) -> None:
    55‚Üí        self.dotenv_path: Optional[StrPath] = dotenv_path
    56‚Üí        self.stream: Optional[IO[str]] = stream
    57‚Üí        self._dict: Optional[Dict[str, Optional[str]]] = None
    58‚Üí        self.verbose: bool = verbose
    59‚Üí        self.encoding: Optional[str] = encoding
    60‚Üí        self.interpolate: bool = interpolate
    61‚Üí        self.override: bool = override
    62‚Üí
    63‚Üí    @contextmanager
    64‚Üí    def _get_stream(self) -> Iterator[IO[str]]:
    65‚Üí        if self.dotenv_path and _is_file_or_fifo(self.dotenv_path):
    66‚Üí            with open(self.dotenv_path, encoding=self.encoding) as stream:
    67‚Üí                yield stream
    68‚Üí        elif self.stream is not None:
    69‚Üí            yield self.stream
    70‚Üí        else:
    71‚Üí            if self.verbose:
    72‚Üí                logger.info(
    73‚Üí                    "python-dotenv could not find configuration file %s.",
    74‚Üí                    self.dotenv_path or ".env",
    75‚Üí                )
    76‚Üí            yield io.StringIO("")
    77‚Üí
    78‚Üí    def dict(self) -> Dict[str, Optional[str]]:
    79‚Üí        """Return dotenv as dict"""
    80‚Üí        if self._dict:
    81‚Üí            return self._dict
    82‚Üí
    83‚Üí        raw_values = self.parse()
    84‚Üí
    85‚Üí        if self.interpolate:
    86‚Üí            self._dict = OrderedDict(
    87‚Üí                resolve_variables(raw_values, override=self.override)
    88‚Üí            )
    89‚Üí        else:
    90‚Üí            self._dict = OrderedDict(raw_values)
    91‚Üí
    92‚Üí        return self._dict
    93‚Üí
    94‚Üí    def parse(self) -> Iterator[Tuple[str, Optional[str]]]:
    95‚Üí        with self._get_stream() as stream:
    96‚Üí            for mapping in with_warn_for_invalid_lines(parse_stream(stream)):
    97‚Üí                if mapping.key is not None:
    98‚Üí                    yield mapping.key, mapping.value
    99‚Üí
   100‚Üí    def set_as_environment_variables(self) -> bool:
   101‚Üí        """
   102‚Üí        Load the current dotenv as system environment variable.
   103‚Üí        """
   104‚Üí        if not self.dict():
   105‚Üí            return False
   106‚Üí
   107‚Üí        for k, v in self.dict().items():
   108‚Üí            if k in os.environ and not self.override:
   109‚Üí                continue
   110‚Üí            if v is not None:
   111‚Üí                os.environ[k] = v
   112‚Üí
   113‚Üí        return True
   114‚Üí
   115‚Üí    def get(self, key: str) -> Optional[str]:
   116‚Üí        """ """
   117‚Üí        data = self.dict()
   118‚Üí
   119‚Üí        if key in data:
   120‚Üí            return data[key]
   121‚Üí
   122‚Üí        if self.verbose:
   123‚Üí            logger.warning("Key %s not found in %s.", key, self.dotenv_path)
   124‚Üí
   125‚Üí        return None
   128‚Üídef get_key(
   129‚Üí    dotenv_path: StrPath,

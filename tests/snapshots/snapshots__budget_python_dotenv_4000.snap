    11в†’@magics_class
    12в†’class IPythonDotEnv(Magics):
    13в†’    @magic_arguments()
    14в†’    @argument(
    15в†’        "-o",
    16в†’        "--override",
    17в†’        action="store_true",
    18в†’        help="Indicate to override existing variables",
    19в†’    )
    20в†’    @argument(
    21в†’        "-v",
    22в†’        "--verbose",
    23в†’        action="store_true",
    24в†’        help="Indicate function calls to be verbose",
    25в†’    )
    26в†’    @argument(
    27в†’        "dotenv_path",
    28в†’        nargs="?",
    29в†’        type=str,
    30в†’        default=".env",
    31в†’        help="Search in increasingly higher folders for the `dotenv_path`",
    32в†’    )
    33в†’    @line_magic
    34в†’    def dotenv(self, line):
    35в†’        args = parse_argstring(self.dotenv, line)
    36в†’        # Locate the .env file
    37в†’        dotenv_path = args.dotenv_path
    38в†’        try:
    39в†’            dotenv_path = find_dotenv(dotenv_path, True, True)
    40в†’        except IOError:
    41в†’            print("cannot find .env file")
    42в†’            return
    43в†’
    44в†’        # Load the .env file
    45в†’        load_dotenv(dotenv_path, verbose=args.verbose, override=args.override)
    48в†’def load_ipython_extension(ipython):

     1→import json
     2→import os
     3→import shlex
     4→import sys
     5→from contextlib import contextmanager
     6→from typing import IO, Any, Dict, Iterator, List, Optional
     9→    from subprocess import Popen
    12→    import click
    20→from .main import dotenv_values, set_key, unset_key
    21→from .version import __version__
    24→def enumerate_env() -> Optional[str]:
    25→    """
    26→    Return a path for the ${pwd}/.env file.
    27→
    28→    If pwd does not exist, return None.
    29→    """
    60→@click.version_option(version=__version__)
    61→@click.pass_context
    62→def cli(ctx: click.Context, file: Any, quote: Any, export: Any) -> None:
    63→    """This script is used to set, get or unset values from a .env file."""
    64→    ctx.obj = {"QUOTE": quote, "EXPORT": export, "FILE": file}
    67→@contextmanager
    68→def stream_file(path: os.PathLike) -> Iterator[IO[str]]:
    69→    """
    70→    Open a file and yield the corresponding (decoded) stream.
    71→
    72→    Exits with error code 2 if the file cannot be opened.
    73→    """
    74→
    75→    try:
    76→        with open(path) as stream:
    77→            yield stream
    78→    except OSError as exc:
    79→        print(f"Error opening env file: {exc}", file=sys.stderr)
    80→        sys.exit(2)
    93→def list_values(ctx: click.Context, output_format: str) -> None:
    94→    """Display all the stored key/value."""
   112→@cli.command(name="set")
   113→@click.pass_context
   114→@click.argument("key", required=True)
   115→@click.argument("value", required=True)
   116→def set_value(ctx: click.Context, key: Any, value: Any) -> None:
   117→    """Store the given key/value."""
   118→    file = ctx.obj["FILE"]
   119→    quote = ctx.obj["QUOTE"]
   120→    export = ctx.obj["EXPORT"]
   121→    success, key, value = set_key(file, key, value, quote, export)
   122→    if success:
   123→        click.echo(f"{key}={value}")
   124→    else:
   125→        sys.exit(1)
   128→@cli.command()
   129→@click.pass_context
   130→@click.argument("key", required=True)
   131→def get(ctx: click.Context, key: Any) -> None:
   132→    """Retrieve the value for the given key."""
   133→    file = ctx.obj["FILE"]
   134→
   135→    with stream_file(file) as stream:
   136→        values = dotenv_values(stream=stream)
   137→
   138→    stored_value = values.get(key)
   139→    if stored_value:
   140→        click.echo(stored_value)
   141→    else:
   142→        sys.exit(1)
   145→@cli.command()
   146→@click.pass_context
   147→@click.argument("key", required=True)
   148→def unset(ctx: click.Context, key: Any) -> None:
   149→    """Removes the given key."""
   150→    file = ctx.obj["FILE"]
   151→    quote = ctx.obj["QUOTE"]
   152→    success, key = unset_key(file, key, quote)
   153→    if success:
   154→        click.echo(f"Successfully removed {key}")
   155→    else:
   156→        sys.exit(1)
   172→@click.argument("commandline", nargs=-1, type=click.UNPROCESSED)
   173→def run(ctx: click.Context, override: bool, commandline: tuple[str, ...]) -> None:
   174→    """Run command with environment variables present."""
   175→    file = ctx.obj["FILE"]
   176→    if not os.path.isfile(file):
   177→        raise click.BadParameter(
   178→            f"Invalid value for '-f' \"{file}\" does not exist.", ctx=ctx
   179→        )
   180→    dotenv_as_dict = {
   181→        k: v
   182→        for (k, v) in dotenv_values(file).items()
   183→        if v is not None and (override or k not in os.environ)
   184→    }
   185→
   186→    if not commandline:
   187→        click.echo("No command given.")
   188→        sys.exit(1)
   189→
   190→    run_command([*commandline, *ctx.args], dotenv_as_dict)
   193→def run_command(command: List[str], env: Dict[str, str]) -> None:
   194→    """Replace the current process with the specified command.
   195→
   196→    Replaces the current process with the specified command and the variables from `env`
   197→    added in the current environment variables.
   198→
   199→    Parameters
   200→    ----------
   201→    command: List[str]
   202→        The command and it's parameters
   203→    env: Dict
   204→        The additional environment variables
   205→
   206→    Returns
   207→    -------
   208→    None
   209→        This function does not return any value. It replaces the current process with the new one.
   210→
   211→    """

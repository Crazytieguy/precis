src/dotenv/cli.py
    24‚Üídef enumerate_env() -> Optional[str]:
    25‚Üí    """
    26‚Üí    Return a path for the ${pwd}/.env file.
    27‚Üí
    28‚Üí    If pwd does not exist, return None.
    29‚Üí    """
    60‚Üí@click.version_option(version=__version__)
    61‚Üí@click.pass_context
    62‚Üídef cli(ctx: click.Context, file: Any, quote: Any, export: Any) -> None:
    63‚Üí    """This script is used to set, get or unset values from a .env file."""
    64‚Üí    ctx.obj = {"QUOTE": quote, "EXPORT": export, "FILE": file}
    67‚Üí@contextmanager
    68‚Üídef stream_file(path: os.PathLike) -> Iterator[IO[str]]:
    69‚Üí    """
    70‚Üí    Open a file and yield the corresponding (decoded) stream.
    71‚Üí
    72‚Üí    Exits with error code 2 if the file cannot be opened.
    73‚Üí    """
    74‚Üí
    75‚Üí    try:
    76‚Üí        with open(path) as stream:
    77‚Üí            yield stream
    78‚Üí    except OSError as exc:
    79‚Üí        print(f"Error opening env file: {exc}", file=sys.stderr)
    80‚Üí        sys.exit(2)
    93‚Üídef list_values(ctx: click.Context, output_format: str) -> None:
    94‚Üí    """Display all the stored key/value."""
   112‚Üí@cli.command(name="set")
   113‚Üí@click.pass_context
   114‚Üí@click.argument("key", required=True)
   115‚Üí@click.argument("value", required=True)
   116‚Üídef set_value(ctx: click.Context, key: Any, value: Any) -> None:
   117‚Üí    """Store the given key/value."""
   118‚Üí    file = ctx.obj["FILE"]
   119‚Üí    quote = ctx.obj["QUOTE"]
   120‚Üí    export = ctx.obj["EXPORT"]
   121‚Üí    success, key, value = set_key(file, key, value, quote, export)
   122‚Üí    if success:
   123‚Üí        click.echo(f"{key}={value}")
   124‚Üí    else:
   125‚Üí        sys.exit(1)
   128‚Üí@cli.command()
   129‚Üí@click.pass_context
   130‚Üí@click.argument("key", required=True)
   131‚Üídef get(ctx: click.Context, key: Any) -> None:
   132‚Üí    """Retrieve the value for the given key."""
   133‚Üí    file = ctx.obj["FILE"]
   134‚Üí
   135‚Üí    with stream_file(file) as stream:
   136‚Üí        values = dotenv_values(stream=stream)
   137‚Üí
   138‚Üí    stored_value = values.get(key)
   139‚Üí    if stored_value:
   140‚Üí        click.echo(stored_value)
   141‚Üí    else:
   142‚Üí        sys.exit(1)
   145‚Üí@cli.command()
   146‚Üí@click.pass_context
   147‚Üí@click.argument("key", required=True)
   148‚Üídef unset(ctx: click.Context, key: Any) -> None:
   149‚Üí    """Removes the given key."""
   150‚Üí    file = ctx.obj["FILE"]
   151‚Üí    quote = ctx.obj["QUOTE"]
   152‚Üí    success, key = unset_key(file, key, quote)
   153‚Üí    if success:
   154‚Üí        click.echo(f"Successfully removed {key}")
   155‚Üí    else:
   156‚Üí        sys.exit(1)
   172‚Üí@click.argument("commandline", nargs=-1, type=click.UNPROCESSED)
   173‚Üídef run(ctx: click.Context, override: bool, commandline: tuple[str, ...]) -> None:
   174‚Üí    """Run command with environment variables present."""
   175‚Üí    file = ctx.obj["FILE"]
   176‚Üí    if not os.path.isfile(file):
   177‚Üí        raise click.BadParameter(
   178‚Üí            f"Invalid value for '-f' \"{file}\" does not exist.", ctx=ctx
   179‚Üí        )
   180‚Üí    dotenv_as_dict = {
   181‚Üí        k: v
   182‚Üí        for (k, v) in dotenv_values(file).items()
   183‚Üí        if v is not None and (override or k not in os.environ)
   184‚Üí    }
   185‚Üí
   186‚Üí    if not commandline:
   187‚Üí        click.echo("No command given.")
   188‚Üí        sys.exit(1)
   189‚Üí
   190‚Üí    run_command([*commandline, *ctx.args], dotenv_as_dict)
   193‚Üídef run_command(command: List[str], env: Dict[str, str]) -> None:
   194‚Üí    """Replace the current process with the specified command.
   195‚Üí
   196‚Üí    Replaces the current process with the specified command and the variables from `env`
   197‚Üí    added in the current environment variables.
   198‚Üí
   199‚Üí    Parameters

    24в†’def enumerate_env() -> Optional[str]:
    25в†’    """
    26в†’    Return a path for the ${pwd}/.env file.
    27в†’
    28в†’    If pwd does not exist, return None.
    29в†’    """
    60в†’@click.version_option(version=__version__)
    61в†’@click.pass_context
    62в†’def cli(ctx: click.Context, file: Any, quote: Any, export: Any) -> None:
    63в†’    """This script is used to set, get or unset values from a .env file."""
    64в†’    ctx.obj = {"QUOTE": quote, "EXPORT": export, "FILE": file}
    67в†’@contextmanager
    68в†’def stream_file(path: os.PathLike) -> Iterator[IO[str]]:
    69в†’    """
    70в†’    Open a file and yield the corresponding (decoded) stream.
    71в†’
    72в†’    Exits with error code 2 if the file cannot be opened.
    73в†’    """
    74в†’
    75в†’    try:
    76в†’        with open(path) as stream:
    77в†’            yield stream
    78в†’    except OSError as exc:
    79в†’        print(f"Error opening env file: {exc}", file=sys.stderr)
    80в†’        sys.exit(2)
    93в†’def list_values(ctx: click.Context, output_format: str) -> None:
    94в†’    """Display all the stored key/value."""
   112в†’@cli.command(name="set")
   113в†’@click.pass_context
   114в†’@click.argument("key", required=True)
   115в†’@click.argument("value", required=True)
   116в†’def set_value(ctx: click.Context, key: Any, value: Any) -> None:
   117в†’    """Store the given key/value."""
   118в†’    file = ctx.obj["FILE"]
   119в†’    quote = ctx.obj["QUOTE"]
   120в†’    export = ctx.obj["EXPORT"]
   121в†’    success, key, value = set_key(file, key, value, quote, export)
   122в†’    if success:
   123в†’        click.echo(f"{key}={value}")
   124в†’    else:
   125в†’        sys.exit(1)
   128в†’@cli.command()
   129в†’@click.pass_context
   130в†’@click.argument("key", required=True)
   131в†’def get(ctx: click.Context, key: Any) -> None:
   132в†’    """Retrieve the value for the given key."""
   133в†’    file = ctx.obj["FILE"]
   134в†’
   135в†’    with stream_file(file) as stream:
   136в†’        values = dotenv_values(stream=stream)
   137в†’
   138в†’    stored_value = values.get(key)
   139в†’    if stored_value:
   140в†’        click.echo(stored_value)
   141в†’    else:
   142в†’        sys.exit(1)
   145в†’@cli.command()
   146в†’@click.pass_context
   147в†’@click.argument("key", required=True)
   148в†’def unset(ctx: click.Context, key: Any) -> None:
   149в†’    """Removes the given key."""
   150в†’    file = ctx.obj["FILE"]
   151в†’    quote = ctx.obj["QUOTE"]
   152в†’    success, key = unset_key(file, key, quote)
   153в†’    if success:
   154в†’        click.echo(f"Successfully removed {key}")
   155в†’    else:
   156в†’        sys.exit(1)
   172в†’@click.argument("commandline", nargs=-1, type=click.UNPROCESSED)
   173в†’def run(ctx: click.Context, override: bool, commandline: tuple[str, ...]) -> None:
   174в†’    """Run command with environment variables present."""
   175в†’    file = ctx.obj["FILE"]
   176в†’    if not os.path.isfile(file):
   177в†’        raise click.BadParameter(
   178в†’            f"Invalid value for '-f' \"{file}\" does not exist.", ctx=ctx
   179в†’        )
   180в†’    dotenv_as_dict = {
   181в†’        k: v
   182в†’        for (k, v) in dotenv_values(file).items()
   183в†’        if v is not None and (override or k not in os.environ)
   184в†’    }
   185в†’
   186в†’    if not commandline:
   187в†’        click.echo("No command given.")
   188в†’        sys.exit(1)
   189в†’
   190в†’    run_command([*commandline, *ctx.args], dotenv_as_dict)
   193в†’def run_command(command: List[str], env: Dict[str, str]) -> None:
   194в†’    """Replace the current process with the specified command.
   195в†’
   196в†’    Replaces the current process with the specified command and the variables from `env`
   197в†’    added in the current environment variables.
   198в†’
   199в†’    Parameters
   200в†’    ----------
   201в†’    command: List[str]
   202в†’        The command and it's parameters
   203в†’    env: Dict
   204в†’        The additional environment variables
   205в†’
   206в†’    Returns
   207в†’    -------
   208в†’    None
   209в†’        This function does not return any value. It replaces the current process with the new one.
   210в†’
   211в†’    """

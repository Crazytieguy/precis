    69â†’class Reader:
    70â†’    def __init__(self, stream: IO[str]) -> None:
    71â†’        self.string = stream.read()
    72â†’        self.position = Position.start()
    73â†’        self.mark = Position.start()
    74â†’
    75â†’    def has_next(self) -> bool:
    76â†’        return self.position.chars < len(self.string)
    77â†’
    78â†’    def set_mark(self) -> None:
    79â†’        self.mark.set(self.position)
    80â†’
    81â†’    def get_marked(self) -> Original:
    82â†’        return Original(
    83â†’            string=self.string[self.mark.chars : self.position.chars],
    84â†’            line=self.mark.line,
    85â†’        )
    86â†’
    87â†’    def peek(self, count: int) -> str:
    88â†’        return self.string[self.position.chars : self.position.chars + count]
    89â†’
    90â†’    def read(self, count: int) -> str:
    91â†’        result = self.string[self.position.chars : self.position.chars + count]
    92â†’        if len(result) < count:
    93â†’            raise Error("read: End of string")
    94â†’        self.position.advance(result)
    95â†’        return result
    96â†’
    97â†’    def read_regex(self, regex: Pattern[str]) -> Sequence[str]:
    98â†’        match = regex.match(self.string, self.position.chars)
    99â†’        if match is None:
   100â†’            raise Error("read_regex: Pattern not found")
   101â†’        self.position.advance(self.string[match.start() : match.end()])
   102â†’        return match.groups()

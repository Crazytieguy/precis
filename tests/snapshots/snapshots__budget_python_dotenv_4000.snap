   269â†’def _walk_to_root(path: str) -> Iterator[str]:
   270â†’    """
   271â†’    Yield directories starting from the given directory up to the root
   272â†’    """
   273â†’    if not os.path.exists(path):
   274â†’        raise IOError("Starting path not found")
   275â†’
   276â†’    if os.path.isfile(path):
   277â†’        path = os.path.dirname(path)
   278â†’
   279â†’    last_dir = None
   280â†’    current_dir = os.path.abspath(path)
   281â†’    while last_dir != current_dir:
   282â†’        yield current_dir
   283â†’        parent_dir = os.path.abspath(os.path.join(current_dir, os.path.pardir))
   284â†’        last_dir, current_dir = current_dir, parent_dir
   287â†’def find_dotenv(
   288â†’    filename: str = ".env",
   289â†’    raise_error_if_not_found: bool = False,
   290â†’    usecwd: bool = False,
   291â†’) -> str:
   292â†’    """
   293â†’    Search in increasingly higher folders for the given file
   294â†’
   295â†’    Returns path to the file if found, or an empty string otherwise
   296â†’    """
   338â†’def load_dotenv(
   339â†’    dotenv_path: Optional[StrPath] = None,
   340â†’    stream: Optional[IO[str]] = None,
   341â†’    verbose: bool = False,
   342â†’    override: bool = False,
   343â†’    interpolate: bool = True,
   344â†’    encoding: Optional[str] = "utf-8",
   345â†’) -> bool:
   346â†’    """Parse a .env file and then load all the variables found as environment variables.
   347â†’
   348â†’    Parameters:
   349â†’        dotenv_path: Absolute or relative path to .env file.
   350â†’        stream: Text stream (such as `io.StringIO`) with .env content, used if
   351â†’            `dotenv_path` is `None`.
   352â†’        verbose: Whether to output a warning the .env file is missing.
   353â†’        override: Whether to override the system environment variables with the variables
   354â†’            from the `.env` file.
   355â†’        encoding: Encoding to be used to read the file.
   356â†’    Returns:
   357â†’        Bool: True if at least one environment variable is set else False
   358â†’
   359â†’    If both `dotenv_path` and `stream` are `None`, `find_dotenv()` is used to find the
   360â†’    .env file with it's default parameters. If you need to change the default parameters
   361â†’    of `find_dotenv()`, you can explicitly call `find_dotenv()` and pass the result
   362â†’    to this function as `dotenv_path`.
   363â†’
   364â†’    If the environment variable `PYTHON_DOTENV_DISABLED` is set to a truthy value,
   365â†’    .env loading is disabled.
   366â†’    """
   387â†’def dotenv_values(
   388â†’    dotenv_path: Optional[StrPath] = None,
   389â†’    stream: Optional[IO[str]] = None,
   390â†’    verbose: bool = False,
   391â†’    interpolate: bool = True,
   392â†’    encoding: Optional[str] = "utf-8",
   393â†’) -> Dict[str, Optional[str]]:
   394â†’    """
   395â†’    Parse a .env file and return its content as a dict.
   396â†’
   397â†’    The returned dict will have `None` values for keys without values in the .env file.
   398â†’    For example, `foo=bar` results in `{"foo": "bar"}` whereas `foo` alone results in
   399â†’    `{"foo": None}`
   400â†’
   401â†’    Parameters:
   402â†’        dotenv_path: Absolute or relative path to the .env file.
   403â†’        stream: `StringIO` object with .env content, used if `dotenv_path` is `None`.
   404â†’        verbose: Whether to output a warning if the .env file is missing.
   405â†’        encoding: Encoding to be used to read the file.
   406â†’
   407â†’    If both `dotenv_path` and `stream` are `None`, `find_dotenv()` is used to find the
   408â†’    .env file.
   409â†’    """
   423â†’def _is_file_or_fifo(path: StrPath) -> bool:
   424â†’    """
   425â†’    Return True if `path` exists and is either a regular file or a FIFO.
   426â†’    """
   427â†’    if os.path.isfile(path):
   428â†’        return True
   429â†’
   430â†’    try:
   431â†’        st = os.stat(path)
   432â†’    except (FileNotFoundError, OSError):
   433â†’        return False
   434â†’
   435â†’    return stat.S_ISFIFO(st.st_mode)

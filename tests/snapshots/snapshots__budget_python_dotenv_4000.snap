   141‚Üí@contextmanager
   142‚Üídef rewrite(
   143‚Üí    path: StrPath,
   144‚Üí    encoding: Optional[str],
   145‚Üí) -> Iterator[Tuple[IO[str], IO[str]]]:
   146‚Üí    pathlib.Path(path).touch()
   147‚Üí
   148‚Üí    with tempfile.NamedTemporaryFile(mode="w", encoding=encoding, delete=False) as dest:
   149‚Üí        error = None
   150‚Üí        try:
   151‚Üí            with open(path, encoding=encoding) as source:
   152‚Üí                yield (source, dest)
   153‚Üí        except BaseException as err:
   154‚Üí            error = err
   155‚Üí
   156‚Üí    if error is None:
   157‚Üí        shutil.move(dest.name, path)
   158‚Üí    else:
   159‚Üí        os.unlink(dest.name)
   160‚Üí        raise error from None

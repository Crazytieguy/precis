src/dotenv/main.py
    25в†’def _load_dotenv_disabled() -> bool:
    26в†’    """
    27в†’    Determine if dotenv loading has been disabled.
    28в†’    """
    29в†’    if "PYTHON_DOTENV_DISABLED" not in os.environ:
    30в†’        return False
    31в†’    value = os.environ["PYTHON_DOTENV_DISABLED"].casefold()
    32в†’    return value in {"1", "true", "t", "yes", "y"}
    35в†’def with_warn_for_invalid_lines(mappings: Iterator[Binding]) -> Iterator[Binding]:
    45в†’class DotEnv:
    46в†’    def __init__(
    47в†’        self,
    48в†’        dotenv_path: Optional[StrPath],
    49в†’        stream: Optional[IO[str]] = None,
    50в†’        verbose: bool = False,
    51в†’        encoding: Optional[str] = None,
    52в†’        interpolate: bool = True,
    53в†’        override: bool = True,
    54в†’    ) -> None:
    55в†’        self.dotenv_path: Optional[StrPath] = dotenv_path
    56в†’        self.stream: Optional[IO[str]] = stream
    57в†’        self._dict: Optional[Dict[str, Optional[str]]] = None
    58в†’        self.verbose: bool = verbose
    59в†’        self.encoding: Optional[str] = encoding
    60в†’        self.interpolate: bool = interpolate
    61в†’        self.override: bool = override
    62в†’
    63в†’    @contextmanager
    64в†’    def _get_stream(self) -> Iterator[IO[str]]:
    65в†’        if self.dotenv_path and _is_file_or_fifo(self.dotenv_path):
    66в†’            with open(self.dotenv_path, encoding=self.encoding) as stream:
    67в†’                yield stream
    68в†’        elif self.stream is not None:
    69в†’            yield self.stream
    70в†’        else:
    71в†’            if self.verbose:
    72в†’                logger.info(
    73в†’                    "python-dotenv could not find configuration file %s.",
    74в†’                    self.dotenv_path or ".env",
    75в†’                )
    76в†’            yield io.StringIO("")
    77в†’
    78в†’    def dict(self) -> Dict[str, Optional[str]]:
    79в†’        """Return dotenv as dict"""
    80в†’        if self._dict:
    81в†’            return self._dict
    82в†’
    83в†’        raw_values = self.parse()
    84в†’
    85в†’        if self.interpolate:
    86в†’            self._dict = OrderedDict(
    87в†’                resolve_variables(raw_values, override=self.override)
    88в†’            )
    89в†’        else:
    90в†’            self._dict = OrderedDict(raw_values)
    91в†’
    92в†’        return self._dict
    93в†’
    94в†’    def parse(self) -> Iterator[Tuple[str, Optional[str]]]:
    95в†’        with self._get_stream() as stream:
    96в†’            for mapping in with_warn_for_invalid_lines(parse_stream(stream)):
    97в†’                if mapping.key is not None:
    98в†’                    yield mapping.key, mapping.value
    99в†’
   100в†’    def set_as_environment_variables(self) -> bool:
   101в†’        """
   102в†’        Load the current dotenv as system environment variable.
   103в†’        """
   104в†’        if not self.dict():
   105в†’            return False
   106в†’
   107в†’        for k, v in self.dict().items():
   108в†’            if k in os.environ and not self.override:
   109в†’                continue
   110в†’            if v is not None:
   111в†’                os.environ[k] = v
   112в†’
   113в†’        return True
   114в†’
   115в†’    def get(self, key: str) -> Optional[str]:
   116в†’        """ """
   117в†’        data = self.dict()
   118в†’
   119в†’        if key in data:
   120в†’            return data[key]
   121в†’
   122в†’        if self.verbose:
   123в†’            logger.warning("Key %s not found in %s.", key, self.dotenv_path)
   124в†’
   125в†’        return None
   128в†’def get_key(
   129в†’    dotenv_path: StrPath,
   130в†’    key_to_get: str,
   131в†’    encoding: Optional[str] = "utf-8",
   132в†’) -> Optional[str]:
   133в†’    """
   134в†’    Get the value of a given key from the given .env.
   135в†’
   136в†’    Returns `None` if the key isn't found or doesn't have a value.
   137в†’    """
   141в†’@contextmanager
   142в†’def rewrite(
   143в†’    path: StrPath,
   144в†’    encoding: Optional[str],
   145в†’) -> Iterator[Tuple[IO[str], IO[str]]]:
   146в†’    pathlib.Path(path).touch()
   147в†’
   148в†’    with tempfile.NamedTemporaryFile(mode="w", encoding=encoding, delete=False) as dest:
   149в†’        error = None
   150в†’        try:
   151в†’            with open(path, encoding=encoding) as source:
   152в†’                yield (source, dest)
   153в†’        except BaseException as err:
   154в†’            error = err
   155в†’
   156в†’    if error is None:
   157в†’        shutil.move(dest.name, path)
   158в†’    else:
   159в†’        os.unlink(dest.name)
   160в†’        raise error from None
   163в†’def set_key(

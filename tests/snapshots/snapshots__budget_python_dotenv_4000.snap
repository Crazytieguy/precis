    29в†’class Literal(Atom):
    30в†’    def __init__(self, value: str) -> None:
    31в†’        self.value = value
    32в†’
    33в†’    def __repr__(self) -> str:
    34в†’        return f"Literal(value={self.value})"
    35в†’
    36в†’    def __eq__(self, other: object) -> bool:
    37в†’        if not isinstance(other, self.__class__):
    38в†’            return NotImplemented
    39в†’        return self.value == other.value
    40в†’
    41в†’    def __hash__(self) -> int:
    42в†’        return hash((self.__class__, self.value))
    43в†’
    44в†’    def resolve(self, env: Mapping[str, Optional[str]]) -> str:
    45в†’        return self.value
    48в†’class Variable(Atom):
    49в†’    def __init__(self, name: str, default: Optional[str]) -> None:
    50в†’        self.name = name
    51в†’        self.default = default
    52в†’
    53в†’    def __repr__(self) -> str:
    54в†’        return f"Variable(name={self.name}, default={self.default})"
    55в†’
    56в†’    def __eq__(self, other: object) -> bool:
    57в†’        if not isinstance(other, self.__class__):
    58в†’            return NotImplemented
    59в†’        return (self.name, self.default) == (other.name, other.default)
    60в†’
    61в†’    def __hash__(self) -> int:
    62в†’        return hash((self.__class__, self.name, self.default))
    63в†’
    64в†’    def resolve(self, env: Mapping[str, Optional[str]]) -> str:
    65в†’        default = self.default if self.default is not None else ""
    66в†’        result = env.get(self.name, default)
    67в†’        return result if result is not None else ""

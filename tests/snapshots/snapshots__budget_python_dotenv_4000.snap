   141â†’@contextmanager
   142â†’def rewrite(
   143â†’    path: StrPath,
   144â†’    encoding: Optional[str],
   145â†’) -> Iterator[Tuple[IO[str], IO[str]]]:
   146â†’    pathlib.Path(path).touch()
   147â†’
   148â†’    with tempfile.NamedTemporaryFile(mode="w", encoding=encoding, delete=False) as dest:
   149â†’        error = None
   150â†’        try:
   151â†’            with open(path, encoding=encoding) as source:
   152â†’                yield (source, dest)
   153â†’        except BaseException as err:
   154â†’            error = err
   155â†’
   156â†’    if error is None:
   157â†’        shutil.move(dest.name, path)
   158â†’    else:
   159â†’        os.unlink(dest.name)
   160â†’        raise error from None

    47â†’class Position:
    48â†’    def __init__(self, chars: int, line: int) -> None:
    49â†’        self.chars = chars
    50â†’        self.line = line
    51â†’
    52â†’    @classmethod
    53â†’    def start(cls) -> "Position":
    54â†’        return cls(chars=0, line=1)
    55â†’
    56â†’    def set(self, other: "Position") -> None:
    57â†’        self.chars = other.chars
    58â†’        self.line = other.line
    59â†’
    60â†’    def advance(self, string: str) -> None:

    47‚Üíclass Position:
    48‚Üí    def __init__(self, chars: int, line: int) -> None:
    49‚Üí        self.chars = chars
    50‚Üí        self.line = line
    51‚Üí
    52‚Üí    @classmethod
    53‚Üí    def start(cls) -> "Position":
    54‚Üí        return cls(chars=0, line=1)
    55‚Üí
    56‚Üí    def set(self, other: "Position") -> None:
    57‚Üí        self.chars = other.chars
    58‚Üí        self.line = other.line
    59‚Üí
    60‚Üí    def advance(self, string: str) -> None:
    61‚Üí        self.chars += len(string)
    62‚Üí        self.line += len(re.findall(_newline, string))
    65‚Üíclass Error(Exception):
    66‚Üí    pass
    69‚Üíclass Reader:
    70‚Üí    def __init__(self, stream: IO[str]) -> None:
    71‚Üí        self.string = stream.read()
    72‚Üí        self.position = Position.start()
    73‚Üí        self.mark = Position.start()
    74‚Üí
    75‚Üí    def has_next(self) -> bool:
    76‚Üí        return self.position.chars < len(self.string)
    77‚Üí
    78‚Üí    def set_mark(self) -> None:
    79‚Üí        self.mark.set(self.position)
    80‚Üí
    81‚Üí    def get_marked(self) -> Original:
    82‚Üí        return Original(
    83‚Üí            string=self.string[self.mark.chars : self.position.chars],
    84‚Üí            line=self.mark.line,
    85‚Üí        )
    86‚Üí
    87‚Üí    def peek(self, count: int) -> str:
    88‚Üí        return self.string[self.position.chars : self.position.chars + count]
    89‚Üí
    90‚Üí    def read(self, count: int) -> str:
    91‚Üí        result = self.string[self.position.chars : self.position.chars + count]
    92‚Üí        if len(result) < count:
    93‚Üí            raise Error("read: End of string")
    94‚Üí        self.position.advance(result)
    95‚Üí        return result
    96‚Üí
    97‚Üí    def read_regex(self, regex: Pattern[str]) -> Sequence[str]:
    98‚Üí        match = regex.match(self.string, self.position.chars)
    99‚Üí        if match is None:
   100‚Üí            raise Error("read_regex: Pattern not found")
   101‚Üí        self.position.advance(self.string[match.start() : match.end()])
   102‚Üí        return match.groups()

src/dotenv/cli.py
    24â†’def enumerate_env() -> Optional[str]:
    25â†’    """
    26â†’    Return a path for the ${pwd}/.env file.
    27â†’
    28â†’    If pwd does not exist, return None.
    29â†’    """
    60â†’@click.version_option(version=__version__)
    61â†’@click.pass_context
    62â†’def cli(ctx: click.Context, file: Any, quote: Any, export: Any) -> None:
    63â†’    """This script is used to set, get or unset values from a .env file."""
    64â†’    ctx.obj = {"QUOTE": quote, "EXPORT": export, "FILE": file}
    67â†’@contextmanager
    68â†’def stream_file(path: os.PathLike) -> Iterator[IO[str]]:
    69â†’    """
    70â†’    Open a file and yield the corresponding (decoded) stream.
    71â†’
    72â†’    Exits with error code 2 if the file cannot be opened.
    73â†’    """
    74â†’
    75â†’    try:
    76â†’        with open(path) as stream:
    77â†’            yield stream
    78â†’    except OSError as exc:
    79â†’        print(f"Error opening env file: {exc}", file=sys.stderr)
    80â†’        sys.exit(2)
    93â†’def list_values(ctx: click.Context, output_format: str) -> None:
    94â†’    """Display all the stored key/value."""
   112â†’@cli.command(name="set")
   113â†’@click.pass_context
   114â†’@click.argument("key", required=True)
   115â†’@click.argument("value", required=True)
   116â†’def set_value(ctx: click.Context, key: Any, value: Any) -> None:
   117â†’    """Store the given key/value."""
   118â†’    file = ctx.obj["FILE"]
   119â†’    quote = ctx.obj["QUOTE"]
   120â†’    export = ctx.obj["EXPORT"]
   121â†’    success, key, value = set_key(file, key, value, quote, export)
   122â†’    if success:
   123â†’        click.echo(f"{key}={value}")
   124â†’    else:
   125â†’        sys.exit(1)
   128â†’@cli.command()
   129â†’@click.pass_context
   130â†’@click.argument("key", required=True)
   131â†’def get(ctx: click.Context, key: Any) -> None:
   132â†’    """Retrieve the value for the given key."""
   133â†’    file = ctx.obj["FILE"]
   134â†’
   135â†’    with stream_file(file) as stream:
   136â†’        values = dotenv_values(stream=stream)
   137â†’
   138â†’    stored_value = values.get(key)
   139â†’    if stored_value:
   140â†’        click.echo(stored_value)
   141â†’    else:
   142â†’        sys.exit(1)
   145â†’@cli.command()
   146â†’@click.pass_context
   147â†’@click.argument("key", required=True)
   148â†’def unset(ctx: click.Context, key: Any) -> None:
   149â†’    """Removes the given key."""
   150â†’    file = ctx.obj["FILE"]
   151â†’    quote = ctx.obj["QUOTE"]
   152â†’    success, key = unset_key(file, key, quote)
   153â†’    if success:
   154â†’        click.echo(f"Successfully removed {key}")
   155â†’    else:
   156â†’        sys.exit(1)
   172â†’@click.argument("commandline", nargs=-1, type=click.UNPROCESSED)
   173â†’def run(ctx: click.Context, override: bool, commandline: tuple[str, ...]) -> None:
   174â†’    """Run command with environment variables present."""
   175â†’    file = ctx.obj["FILE"]
   176â†’    if not os.path.isfile(file):
   177â†’        raise click.BadParameter(
   178â†’            f"Invalid value for '-f' \"{file}\" does not exist.", ctx=ctx
   179â†’        )
   180â†’    dotenv_as_dict = {
   181â†’        k: v
   182â†’        for (k, v) in dotenv_values(file).items()
   183â†’        if v is not None and (override or k not in os.environ)
   184â†’    }
   185â†’
   186â†’    if not commandline:
   187â†’        click.echo("No command given.")
   188â†’        sys.exit(1)
   189â†’
   190â†’    run_command([*commandline, *ctx.args], dotenv_as_dict)
   193â†’def run_command(command: List[str], env: Dict[str, str]) -> None:
   194â†’    """Replace the current process with the specified command.
   195â†’
   196â†’    Replaces the current process with the specified command and the variables from `env`
   197â†’    added in the current environment variables.
   198â†’
   199â†’    Parameters
   200â†’    ----------
   201â†’    command: List[str]
   202â†’        The command and it's parameters
   203â†’    env: Dict
   204â†’        The additional environment variables
   205â†’
   206â†’    Returns
   207â†’    -------
   208â†’    None
   209â†’        This function does not return any value. It replaces the current process with the new one.
   210â†’
   211â†’    """
src/dotenv/ipython.py
    11â†’@magics_class
    12â†’class IPythonDotEnv(Magics):
    13â†’    @magic_arguments()
    14â†’    @argument(
    15â†’        "-o",
    16â†’        "--override",
    17â†’        action="store_true",
    18â†’        help="Indicate to override existing variables",
    19â†’    )
    20â†’    @argument(

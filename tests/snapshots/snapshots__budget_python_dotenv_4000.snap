    45â†’class DotEnv:
    46â†’    def __init__(
    47â†’        self,
    48â†’        dotenv_path: Optional[StrPath],
    49â†’        stream: Optional[IO[str]] = None,
    50â†’        verbose: bool = False,
    51â†’        encoding: Optional[str] = None,
    52â†’        interpolate: bool = True,
    53â†’        override: bool = True,
    54â†’    ) -> None:
    55â†’        self.dotenv_path: Optional[StrPath] = dotenv_path
    56â†’        self.stream: Optional[IO[str]] = stream
    57â†’        self._dict: Optional[Dict[str, Optional[str]]] = None
    58â†’        self.verbose: bool = verbose
    59â†’        self.encoding: Optional[str] = encoding
    60â†’        self.interpolate: bool = interpolate
    61â†’        self.override: bool = override
    62â†’
    63â†’    @contextmanager
    64â†’    def _get_stream(self) -> Iterator[IO[str]]:
    65â†’        if self.dotenv_path and _is_file_or_fifo(self.dotenv_path):
    66â†’            with open(self.dotenv_path, encoding=self.encoding) as stream:
    67â†’                yield stream
    68â†’        elif self.stream is not None:
    69â†’            yield self.stream
    70â†’        else:
    71â†’            if self.verbose:
    72â†’                logger.info(
    73â†’                    "python-dotenv could not find configuration file %s.",
    74â†’                    self.dotenv_path or ".env",
    75â†’                )
    76â†’            yield io.StringIO("")
    77â†’
    78â†’    def dict(self) -> Dict[str, Optional[str]]:
    79â†’        """Return dotenv as dict"""
    80â†’        if self._dict:
    81â†’            return self._dict
    82â†’
    83â†’        raw_values = self.parse()
    84â†’
    85â†’        if self.interpolate:
    86â†’            self._dict = OrderedDict(
    87â†’                resolve_variables(raw_values, override=self.override)
    88â†’            )
    89â†’        else:
    90â†’            self._dict = OrderedDict(raw_values)
    91â†’
    92â†’        return self._dict
    93â†’
    94â†’    def parse(self) -> Iterator[Tuple[str, Optional[str]]]:
    95â†’        with self._get_stream() as stream:
    96â†’            for mapping in with_warn_for_invalid_lines(parse_stream(stream)):
    97â†’                if mapping.key is not None:
    98â†’                    yield mapping.key, mapping.value
    99â†’
   100â†’    def set_as_environment_variables(self) -> bool:
   101â†’        """
   102â†’        Load the current dotenv as system environment variable.
   103â†’        """
   104â†’        if not self.dict():
   105â†’            return False
   106â†’
   107â†’        for k, v in self.dict().items():
   108â†’            if k in os.environ and not self.override:
   109â†’                continue
   110â†’            if v is not None:
   111â†’                os.environ[k] = v
   112â†’
   113â†’        return True
   114â†’
   115â†’    def get(self, key: str) -> Optional[str]:
   116â†’        """ """
   117â†’        data = self.dict()
   118â†’
   119â†’        if key in data:
   120â†’            return data[key]
   121â†’
   122â†’        if self.verbose:
   123â†’            logger.warning("Key %s not found in %s.", key, self.dotenv_path)
   124â†’
   125â†’        return None

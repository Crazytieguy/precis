    18в†’class Atom(metaclass=ABCMeta):
    19в†’    def __ne__(self, other: object) -> bool:
    20в†’        result = self.__eq__(other)
    21в†’        if result is NotImplemented:
    22в†’            return NotImplemented
    23в†’        return not result
    24в†’

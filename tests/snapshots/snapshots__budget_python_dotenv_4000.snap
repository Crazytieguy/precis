    18‚Üíclass Atom(metaclass=ABCMeta):
    19‚Üí    def __ne__(self, other: object) -> bool:
    20‚Üí        result = self.__eq__(other)
    21‚Üí        if result is NotImplemented:
    22‚Üí            return NotImplemented
    23‚Üí        return not result
    24‚Üí
    25‚Üí    @abstractmethod
    26‚Üí    def resolve(self, env: Mapping[str, Optional[str]]) -> str: ...
    29‚Üíclass Literal(Atom):
    30‚Üí    def __init__(self, value: str) -> None:
    31‚Üí        self.value = value
    32‚Üí
    33‚Üí    def __repr__(self) -> str:
    34‚Üí        return f"Literal(value={self.value})"
    35‚Üí
    36‚Üí    def __eq__(self, other: object) -> bool:
    37‚Üí        if not isinstance(other, self.__class__):
    38‚Üí            return NotImplemented
    39‚Üí        return self.value == other.value
    40‚Üí
    41‚Üí    def __hash__(self) -> int:
    42‚Üí        return hash((self.__class__, self.value))
    43‚Üí
    44‚Üí    def resolve(self, env: Mapping[str, Optional[str]]) -> str:
    45‚Üí        return self.value
    48‚Üíclass Variable(Atom):
    49‚Üí    def __init__(self, name: str, default: Optional[str]) -> None:
    50‚Üí        self.name = name
    51‚Üí        self.default = default
    52‚Üí
    53‚Üí    def __repr__(self) -> str:
    54‚Üí        return f"Variable(name={self.name}, default={self.default})"
    55‚Üí
    56‚Üí    def __eq__(self, other: object) -> bool:
    57‚Üí        if not isinstance(other, self.__class__):
    58‚Üí            return NotImplemented
    59‚Üí        return (self.name, self.default) == (other.name, other.default)
    60‚Üí
    61‚Üí    def __hash__(self) -> int:
    62‚Üí        return hash((self.__class__, self.name, self.default))
    63‚Üí
    64‚Üí    def resolve(self, env: Mapping[str, Optional[str]]) -> str:
    65‚Üí        default = self.default if self.default is not None else ""
    66‚Üí        result = env.get(self.name, default)
    67‚Üí        return result if result is not None else ""

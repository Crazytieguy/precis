    29â†’class Literal(Atom):
    30â†’    def __init__(self, value: str) -> None:
    31â†’        self.value = value
    32â†’
    33â†’    def __repr__(self) -> str:
    34â†’        return f"Literal(value={self.value})"
    35â†’
    36â†’    def __eq__(self, other: object) -> bool:
    37â†’        if not isinstance(other, self.__class__):
    38â†’            return NotImplemented
    39â†’        return self.value == other.value
    40â†’
    41â†’    def __hash__(self) -> int:
    42â†’        return hash((self.__class__, self.value))
    43â†’
    44â†’    def resolve(self, env: Mapping[str, Optional[str]]) -> str:
    45â†’        return self.value
    48â†’class Variable(Atom):
    49â†’    def __init__(self, name: str, default: Optional[str]) -> None:
    50â†’        self.name = name
    51â†’        self.default = default
    52â†’
    53â†’    def __repr__(self) -> str:
    54â†’        return f"Variable(name={self.name}, default={self.default})"
    55â†’
    56â†’    def __eq__(self, other: object) -> bool:
    57â†’        if not isinstance(other, self.__class__):
    58â†’            return NotImplemented
    59â†’        return (self.name, self.default) == (other.name, other.default)
    60â†’
    61â†’    def __hash__(self) -> int:
    62â†’        return hash((self.__class__, self.name, self.default))
    63â†’
    64â†’    def resolve(self, env: Mapping[str, Optional[str]]) -> str:
    65â†’        default = self.default if self.default is not None else ""
    66â†’        result = env.get(self.name, default)
    67â†’        return result if result is not None else ""

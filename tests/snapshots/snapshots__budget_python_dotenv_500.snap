    26‚Üí    @argument(
    27‚Üí        "dotenv_path",
    28‚Üí        nargs="?",
    29‚Üí        type=str,
    30‚Üí        default=".env",
    31‚Üí        help="Search in increasingly higher folders for the `dotenv_path`",

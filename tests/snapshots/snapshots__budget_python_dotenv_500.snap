    33‚Üí    @line_magic
    34‚Üí    def dotenv(self, line):
    35‚Üí        args = parse_argstring(self.dotenv, line)
    36‚Üí        # Locate the .env file
    37‚Üí        dotenv_path = args.dotenv_path
    38‚Üí        try:
    39‚Üí            dotenv_path = find_dotenv(dotenv_path, True, True)
    40‚Üí        except IOError:
    41‚Üí            print("cannot find .env file")
    42‚Üí            return
    43‚Üí
    44‚Üí        # Load the .env file
    45‚Üí        load_dotenv(dotenv_path, verbose=args.verbose, override=args.override)

    18→class Atom(metaclass=ABCMeta):
    19→    def __ne__(self, other: object) -> bool:
    20→        result = self.__eq__(other)
    21→        if result is NotImplemented:
    22→            return NotImplemented
    23→        return not result
    24→
    25→    @abstractmethod

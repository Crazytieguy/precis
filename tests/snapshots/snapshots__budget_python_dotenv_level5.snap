    47→class Position:
    48→    def __init__(self, chars: int, line: int) -> None:
    49→        self.chars = chars
    50→        self.line = line
    51→
    52→    @classmethod
    53→    def start(cls) -> "Position":
    54→        return cls(chars=0, line=1)
    55→
    56→    def set(self, other: "Position") -> None:
    57→        self.chars = other.chars
    58→        self.line = other.line
    59→
    60→    def advance(self, string: str) -> None:
    61→        self.chars += len(string)
    62→        self.line += len(re.findall(_newline, string))
    65→class Error(Exception):

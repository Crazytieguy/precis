   269‚Üídef _walk_to_root(path: str) -> Iterator[str]:
   270‚Üí    """
   271‚Üí    Yield directories starting from the given directory up to the root
   272‚Üí    """
   273‚Üí    if not os.path.exists(path):
   274‚Üí        raise IOError("Starting path not found")
   275‚Üí
   276‚Üí    if os.path.isfile(path):
   277‚Üí        path = os.path.dirname(path)
   278‚Üí
   279‚Üí    last_dir = None
   280‚Üí    current_dir = os.path.abspath(path)
   281‚Üí    while last_dir != current_dir:
   282‚Üí        yield current_dir
   283‚Üí        parent_dir = os.path.abspath(os.path.join(current_dir, os.path.pardir))

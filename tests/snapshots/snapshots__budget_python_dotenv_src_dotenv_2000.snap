   345‚Üí) -> bool:
   346‚Üí    """Parse a .env file and then load all the variables found as environment variables.
   347‚Üí
   348‚Üí    Parameters:
   349‚Üí        dotenv_path: Absolute or relative path to .env file.
   350‚Üí        stream: Text stream (such as `io.StringIO`) with .env content, used if
   351‚Üí            `dotenv_path` is `None`.
   352‚Üí        verbose: Whether to output a warning the .env file is missing.
   353‚Üí        override: Whether to override the system environment variables with the variables
   354‚Üí            from the `.env` file.
   355‚Üí        encoding: Encoding to be used to read the file.
   356‚Üí    Returns:
   357‚Üí        Bool: True if at least one environment variable is set else False
   358‚Üí
   359‚Üí    If both `dotenv_path` and `stream` are `None`, `find_dotenv()` is used to find the
   360‚Üí    .env file with it's default parameters. If you need to change the default parameters
   361‚Üí    of `find_dotenv()`, you can explicitly call `find_dotenv()` and pass the result
   362‚Üí    to this function as `dotenv_path`.
   363‚Üí
   364‚Üí    If the environment variable `PYTHON_DOTENV_DISABLED` is set to a truthy value,
   365‚Üí    .env loading is disabled.
   366‚Üí    """
   387‚Üídef dotenv_values(
   388‚Üí    dotenv_path: Optional[StrPath] = None,
   389‚Üí    stream: Optional[IO[str]] = None,
   390‚Üí    verbose: bool = False,
   391‚Üí    interpolate: bool = True,
   392‚Üí    encoding: Optional[str] = "utf-8",
   393‚Üí) -> Dict[str, Optional[str]]:
   394‚Üí    """
   395‚Üí    Parse a .env file and return its content as a dict.
   396‚Üí
   397‚Üí    The returned dict will have `None` values for keys without values in the .env file.
   398‚Üí    For example, `foo=bar` results in `{"foo": "bar"}` whereas `foo` alone results in
   399‚Üí    `{"foo": None}`
   400‚Üí
   401‚Üí    Parameters:
   402‚Üí        dotenv_path: Absolute or relative path to the .env file.
   403‚Üí        stream: `StringIO` object with .env content, used if `dotenv_path` is `None`.
   404‚Üí        verbose: Whether to output a warning if the .env file is missing.
   405‚Üí        encoding: Encoding to be used to read the file.
   406‚Üí
   407‚Üí    If both `dotenv_path` and `stream` are `None`, `find_dotenv()` is used to find the
   408‚Üí    .env file.
   409‚Üí    """
   423‚Üídef _is_file_or_fifo(path: StrPath) -> bool:
   424‚Üí    """
   425‚Üí    Return True if `path` exists and is either a regular file or a FIFO.
   426‚Üí    """
   427‚Üí    if os.path.isfile(path):
   428‚Üí        return True
   429‚Üí
   430‚Üí    try:
   431‚Üí        st = os.stat(path)
   432‚Üí    except (FileNotFoundError, OSError):
   433‚Üí        return False
   434‚Üí
   435‚Üí    return stat.S_ISFIFO(st.st_mode)


   172→@click.argument("commandline", nargs=-1, type=click.UNPROCESSED)
   173→def run(ctx: click.Context, override: bool, commandline: tuple[str, ...]) -> None:
   174→    """Run command with environment variables present."""
   175→    file = ctx.obj["FILE"]
   176→    if not os.path.isfile(file):
   177→        raise click.BadParameter(
   178→            f"Invalid value for '-f' \"{file}\" does not exist.", ctx=ctx
   179→        )
   180→    dotenv_as_dict = {
   181→        k: v
   182→        for (k, v) in dotenv_values(file).items()
   183→        if v is not None and (override or k not in os.environ)
   184→    }
   185→
   186→    if not commandline:
   187→        click.echo("No command given.")
   188→        sys.exit(1)
   189→
   190→    run_command([*commandline, *ctx.args], dotenv_as_dict)
   193→def run_command(command: List[str], env: Dict[str, str]) -> None:
   194→    """Replace the current process with the specified command.
   195→
   196→    Replaces the current process with the specified command and the variables from `env`
   197→    added in the current environment variables.
   198→
   199→    Parameters
   200→    ----------
   201→    command: List[str]
   202→        The command and it's parameters
   203→    env: Dict
   204→        The additional environment variables
   205→
   206→    Returns
   207→    -------
   208→    None
   209→        This function does not return any value. It replaces the current process with the new one.
   210→
   211→    """
   212→    # copy the current environment variables and add the vales from
   213→    # `env`
   214→    cmd_env = os.environ.copy()
   215→    cmd_env.update(env)
   216→
   217→    if sys.platform == "win32":
   218→        # execvpe on Windows returns control immediately
   219→        # rather than once the command has finished.
   220→        p = Popen(command, universal_newlines=True, bufsize=0, shell=False, env=cmd_env)
   221→        _, _ = p.communicate()
   222→
   223→        sys.exit(p.returncode)
   224→    else:
   225→        os.execvpe(command[0], args=command, env=cmd_env)

   120→          className={clsx(
   121→            props.className,
   122→            className,
   123→            'h-full w-full rounded-lg p-4 overflow-x-auto flex flex-col items justify-center'
   124→          )}
   125→          style={style}
   126→        >
   127→          {tokens.map((line, i) => {
   128→            if (tokens.length - 1 === i && line[0].empty) {
   129→              return null;
   130→            }
   131→
   132→            return (
   133→              <div {...getLineProps({ line, key: i })} key={i}>

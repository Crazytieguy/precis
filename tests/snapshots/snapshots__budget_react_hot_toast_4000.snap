   149→export const dispatch = (action: Action, toasterId = DEFAULT_TOASTER_ID) => {
   150→  memoryState[toasterId] = reducer(
   151→    memoryState[toasterId] || defaultToasterState,
   152→    action
   153→  );
   154→  listeners.forEach(([id, listener]) => {
   155→    if (id === toasterId) {
   156→      listener(memoryState[toasterId]);
   157→    }
   158→  });
   159→};
   161→export const dispatchAll = (action: Action) =>
   162→  Object.keys(memoryState).forEach((toasterId) => dispatch(action, toasterId));
   164→export const getToasterIdFromToastId = (toastId: string) =>
   165→  Object.keys(memoryState).find((toasterId) =>
   166→    memoryState[toasterId].toasts.some((t) => t.id === toastId)
   167→  );
   169→export const createDispatch =
   170→  (toasterId = DEFAULT_TOASTER_ID) =>
   171→  (action: Action) => {
   172→    dispatch(action, toasterId);

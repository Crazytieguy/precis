     1→import { css, setup } from 'goober';
     2→import * as React from 'react';
     3→import {
     4→  resolveValue,
     5→  ToasterProps,
     6→  ToastPosition,
     7→  ToastWrapperProps,
     8→} from '../core/types';
     9→import { useToaster } from '../core/use-toaster';
    10→import { prefersReducedMotion } from '../core/utils';
    11→import { ToastBar } from './toast-bar';
    15→const ToastWrapper = ({
    16→  id,
    17→  className,
    18→  style,
    19→  onHeightUpdate,
    20→  children,
    21→}: ToastWrapperProps) => {
    22→  const ref = React.useCallback(
    23→    (el: HTMLElement | null) => {
    24→      if (el) {
    25→        const updateHeight = () => {
    26→          const height = el.getBoundingClientRect().height;
    27→          onHeightUpdate(id, height);
    28→        };
    29→        updateHeight();
    30→        new MutationObserver(updateHeight).observe(el, {
    31→          subtree: true,
    32→          childList: true,
    33→          characterData: true,
    34→        });
    35→      }
    36→    },
    37→    [id, onHeightUpdate]
    38→  );
    39→
    40→  return (
    41→    <div ref={ref} className={className} style={style}>
    42→      {children}
    43→    </div>
    44→  );
    45→};
    47→const getPositionStyle = (
    48→  position: ToastPosition,
    49→  offset: number
    50→): React.CSSProperties => {
    51→  const top = position.includes('top');
    52→  const verticalStyle: React.CSSProperties = top ? { top: 0 } : { bottom: 0 };
    53→  const horizontalStyle: React.CSSProperties = position.includes('center')
    54→    ? {
    55→        justifyContent: 'center',
    56→      }
    57→    : position.includes('right')
    58→    ? {
    59→        justifyContent: 'flex-end',
    60→      }
    61→    : {};
    62→  return {
    63→    left: 0,
    64→    right: 0,
    65→    display: 'flex',
    66→    position: 'absolute',
    67→    transition: prefersReducedMotion()
    68→      ? undefined
    69→      : `all 230ms cubic-bezier(.21,1.02,.73,1)`,
    70→    transform: `translateY(${offset * (top ? 1 : -1)}px)`,
    71→    ...verticalStyle,
    72→    ...horizontalStyle,
    73→  };
    74→};
    76→const activeClass = css`
    83→const DEFAULT_OFFSET = 16;
    85→export const Toaster: React.FC<ToasterProps> = ({
    86→  reverseOrder,
    87→  position = 'top-center',
    88→  toastOptions,
    89→  gutter,
    90→  children,
    91→  toasterId,
    92→  containerStyle,
    93→  containerClassName,
    94→}) => {
    95→  const { toasts, handlers } = useToaster(toastOptions, toasterId);
    96→
    97→  return (
    98→    <div
    99→      data-rht-toaster={toasterId || ''}
   100→      style={{
   101→        position: 'fixed',
   102→        zIndex: 9999,
   103→        top: DEFAULT_OFFSET,
   104→        left: DEFAULT_OFFSET,
   105→        right: DEFAULT_OFFSET,
   106→        bottom: DEFAULT_OFFSET,
   107→        pointerEvents: 'none',
   108→        ...containerStyle,
   109→      }}
   110→      className={containerClassName}
   111→      onMouseEnter={handlers.startPause}
   112→      onMouseLeave={handlers.endPause}
   113→    >
   114→      {toasts.map((t) => {
   115→        const toastPosition = t.position || position;
   116→        const offset = handlers.calculateOffset(t, {
   117→          reverseOrder,
   118→          gutter,
   119→          defaultPosition: position,
   120→        });
   121→        const positionStyle = getPositionStyle(toastPosition, offset);
   122→
   123→        return (
   124→          <ToastWrapper
   125→            id={t.id}
   126→            key={t.id}
   127→            onHeightUpdate={handlers.updateHeight}
   128→            className={t.visible ? activeClass : ''}
   129→            style={positionStyle}
   130→          >
   131→            {t.type === 'custom' ? (
   132→              resolveValue(t.message, t)
   133→            ) : children ? (
   134→              children(t)
   135→            ) : (
   136→              <ToastBar toast={t} position={toastPosition} />
   137→            )}
   138→          </ToastWrapper>
   139→        );
   140→      })}
   141→    </div>
   142→  );
   143→};
src/core/store.ts
     1→import { useEffect, useState, useRef } from 'react';
     2→import { DefaultToastOptions, Toast, ToastType } from './types';
     4→export const TOAST_EXPIRE_DISMISS_DELAY = 1000;
     5→export const TOAST_LIMIT = 20;
     6→export const DEFAULT_TOASTER_ID = 'default';
     8→interface ToasterSettings {
     9→  toastLimit: number;
    10→}
    12→export enum ActionType {
    13→  ADD_TOAST,
    14→  UPDATE_TOAST,
    15→  UPSERT_TOAST,
    16→  DISMISS_TOAST,
    17→  REMOVE_TOAST,
    18→  START_PAUSE,
    19→  END_PAUSE,
    20→}
    22→export type Action =
    23→  | {
    24→      type: ActionType.ADD_TOAST;
    25→      toast: Toast;
    26→    }
    27→  | {
    28→      type: ActionType.UPSERT_TOAST;
    29→      toast: Toast;
    30→    }
    31→  | {
    32→      type: ActionType.UPDATE_TOAST;
    33→      toast: Partial<Toast>;
    34→    }
    35→  | {
    36→      type: ActionType.DISMISS_TOAST;
    37→      toastId?: string;
    38→    }
    39→  | {
    40→      type: ActionType.REMOVE_TOAST;
    41→      toastId?: string;
    42→    }
    43→  | {
    44→      type: ActionType.START_PAUSE;
    45→      time: number;
    46→    }
    47→  | {
    48→      type: ActionType.END_PAUSE;
    49→      time: number;
    50→    };
    52→interface ToasterState {
    53→  toasts: Toast[];
    54→  settings: ToasterSettings;
    55→  pausedAt: number | undefined;
    56→}
    58→interface State {
    59→  [toasterId: string]: ToasterState;
    60→}
    62→export const reducer = (state: ToasterState, action: Action): ToasterState => {
    63→  const { toastLimit } = state.settings;
    64→
    65→  switch (action.type) {
    66→    case ActionType.ADD_TOAST:
    67→      return {
    68→        ...state,
    69→        toasts: [action.toast, ...state.toasts].slice(0, toastLimit),
    70→      };
    71→
    72→    case ActionType.UPDATE_TOAST:
    73→      return {
    74→        ...state,
    75→        toasts: state.toasts.map((t) =>
    76→          t.id === action.toast.id ? { ...t, ...action.toast } : t
    77→        ),
    78→      };
    79→
    80→    case ActionType.UPSERT_TOAST:
    81→      const { toast } = action;
    82→      return reducer(state, {
    83→        type: state.toasts.find((t) => t.id === toast.id)
    84→          ? ActionType.UPDATE_TOAST
    85→          : ActionType.ADD_TOAST,
    86→        toast,
    87→      });
    88→
    89→    case ActionType.DISMISS_TOAST:
    90→      const { toastId } = action;
    91→
    92→      return {
    93→        ...state,
    94→        toasts: state.toasts.map((t) =>
    95→          t.id === toastId || toastId === undefined
    96→            ? {
    97→                ...t,
    98→                dismissed: true,
    99→                visible: false,
   100→              }
   101→            : t
   102→        ),
   103→      };
   104→    case ActionType.REMOVE_TOAST:
   105→      if (action.toastId === undefined) {
   106→        return {
   107→          ...state,
   108→          toasts: [],
   109→        };
   110→      }
   111→      return {
   112→        ...state,
   113→        toasts: state.toasts.filter((t) => t.id !== action.toastId),
   114→      };
   115→
   116→    case ActionType.START_PAUSE:
   117→      return {
   118→        ...state,
   119→        pausedAt: action.time,
   120→      };
   121→
   122→    case ActionType.END_PAUSE:
   123→      const diff = action.time - (state.pausedAt || 0);
   124→
   125→      return {
   126→        ...state,
   127→        pausedAt: undefined,
   128→        toasts: state.toasts.map((t) => ({
   129→          ...t,
   130→          pauseDuration: t.pauseDuration + diff,
   131→        })),
   132→      };
   133→  }
   134→};
   136→const listeners: Array<
   137→  [toasterId: string, reducer: (state: ToasterState) => void]
   138→> = [];
   140→const defaultToasterState: ToasterState = {
   141→  toasts: [],
   142→  pausedAt: undefined,
   143→  settings: {
   144→    toastLimit: TOAST_LIMIT,
   145→  },
   146→};
   149→export const dispatch = (action: Action, toasterId = DEFAULT_TOASTER_ID) => {
   150→  memoryState[toasterId] = reducer(
   151→    memoryState[toasterId] || defaultToasterState,
   152→    action
   153→  );
   154→  listeners.forEach(([id, listener]) => {
   155→    if (id === toasterId) {
   156→      listener(memoryState[toasterId]);
   157→    }
   158→  });
   159→};
   161→export const dispatchAll = (action: Action) =>
   162→  Object.keys(memoryState).forEach((toasterId) => dispatch(action, toasterId));
   164→export const getToasterIdFromToastId = (toastId: string) =>
   165→  Object.keys(memoryState).find((toasterId) =>
   166→    memoryState[toasterId].toasts.some((t) => t.id === toastId)
   167→  );
   169→export const createDispatch =
   170→  (toasterId = DEFAULT_TOASTER_ID) =>
   171→  (action: Action) => {
   172→    dispatch(action, toasterId);
   173→  };
   175→export const defaultTimeouts: {
   176→  [key in ToastType]: number;
   177→} = {
   178→  blank: 4000,
   179→  error: 4000,
   180→  success: 2000,
   181→  loading: Infinity,
   182→  custom: 4000,
   183→};
   185→export const useStore = (
   186→  toastOptions: DefaultToastOptions = {},
   187→  toasterId: string = DEFAULT_TOASTER_ID
   188→): ToasterState => {
   189→  const [state, setState] = useState<ToasterState>(
   190→    memoryState[toasterId] || defaultToasterState
   191→  );
   192→  const initial = useRef(memoryState[toasterId]);
   193→
   194→  // TODO: Switch to useSyncExternalStore when targeting React 18+
   195→  useEffect(() => {
   196→    if (initial.current !== memoryState[toasterId]) {
   197→      setState(memoryState[toasterId]);
   198→    }
   199→    listeners.push([toasterId, setState]);
   200→    return () => {
   201→      const index = listeners.findIndex(([id]) => id === toasterId);
   202→      if (index > -1) {
   203→        listeners.splice(index, 1);
   204→      }
   205→    };
   206→  }, [toasterId]);
   207→
   208→  const mergedToasts = state.toasts.map((t) => ({
   209→    ...toastOptions,
   210→    ...toastOptions[t.type],
   211→    ...t,
   212→    removeDelay:
   213→      t.removeDelay ||
   214→      toastOptions[t.type]?.removeDelay ||
   215→      toastOptions?.removeDelay,
   216→    duration:
   217→      t.duration ||
   218→      toastOptions[t.type]?.duration ||
   219→      toastOptions?.duration ||
   220→      defaultTimeouts[t.type],
   221→    style: {
   222→      ...toastOptions.style,
   223→      ...toastOptions[t.type]?.style,
   224→      ...t.style,
   225→    },
   226→  }));
   227→
   228→  return {
   229→    ...state,
   230→    toasts: mergedToasts,
   231→  };
   232→};
src/core/toast.ts
     1→import {
     2→  Renderable,
     3→  Toast,
     4→  ToastOptions,
     5→  ToastType,
     6→  DefaultToastOptions,
     7→  ValueOrFunction,
     8→  resolveValue,
     9→} from './types';
    10→import { genId } from './utils';
    11→import {
    12→  createDispatch,
    13→  Action,
    14→  ActionType,
    15→  dispatchAll,
    16→  getToasterIdFromToastId,
    17→} from './store';
    19→type Message = ValueOrFunction<Renderable, Toast>;
    21→type ToastHandler = (message: Message, options?: ToastOptions) => string;
    23→const createToast = (
    24→  message: Message,
    25→  type: ToastType = 'blank',
    26→  opts?: ToastOptions
    27→): Toast => ({
    28→  createdAt: Date.now(),
    29→  visible: true,
    30→  dismissed: false,
    31→  type,
    32→  ariaProps: {
    33→    role: 'status',
    34→    'aria-live': 'polite',
    35→  },
    36→  message,
    37→  pauseDuration: 0,
    38→  ...opts,
    39→  id: opts?.id || genId(),
    40→});
    42→const createHandler =
    43→  (type?: ToastType): ToastHandler =>
    44→  (message, options) => {
    45→    const toast = createToast(message, type, options);
    46→
    47→    const dispatch = createDispatch(
    48→      toast.toasterId || getToasterIdFromToastId(toast.id)
    49→    );
    50→
    51→    dispatch({ type: ActionType.UPSERT_TOAST, toast });
    52→    return toast.id;
    53→  };
    55→const toast = (message: Message, opts?: ToastOptions) =>
    56→  createHandler('blank')(message, opts);
src/core/types.ts
     1→import { CSSProperties } from 'react';
     3→export type ToastType = 'success' | 'error' | 'loading' | 'blank' | 'custom';
     4→export type ToastPosition =
     5→  | 'top-left'
     6→  | 'top-center'
     7→  | 'top-right'
     8→  | 'bottom-left'
     9→  | 'bottom-center'
    10→  | 'bottom-right';
    12→export type Renderable = React.ReactElement | string | null;
    14→export interface IconTheme {
    15→  primary: string;
    16→  secondary: string;
    17→}
    19→export type ValueFunction<TValue, TArg> = (arg: TArg) => TValue;
    20→export type ValueOrFunction<TValue, TArg> =
    21→  | TValue
    22→  | ValueFunction<TValue, TArg>;
    24→const isFunction = <TValue, TArg>(
    25→  valOrFunction: ValueOrFunction<TValue, TArg>
    26→): valOrFunction is ValueFunction<TValue, TArg> =>
    27→  typeof valOrFunction === 'function';
    29→export const resolveValue = <TValue, TArg>(
    30→  valOrFunction: ValueOrFunction<TValue, TArg>,
    31→  arg: TArg
    32→): TValue => (isFunction(valOrFunction) ? valOrFunction(arg) : valOrFunction);
    34→export interface Toast {
    35→  type: ToastType;
    36→  id: string;
    37→  toasterId?: string;
    38→  message: ValueOrFunction<Renderable, Toast>;
    39→  icon?: Renderable;
    40→  duration?: number;
    41→  pauseDuration: number;
    42→  position?: ToastPosition;
    43→  removeDelay?: number;
    44→
    45→  ariaProps: {
    46→    role: 'status' | 'alert';
    47→    'aria-live': 'assertive' | 'off' | 'polite';
    48→  };
    49→
    50→  style?: CSSProperties;
    51→  className?: string;
    52→  iconTheme?: IconTheme;
    53→
    54→  createdAt: number;
    55→  visible: boolean;
    56→  dismissed: boolean;
    57→  height?: number;
    58→}
    60→export type ToastOptions = Partial<
    61→  Pick<
    62→    Toast,
    63→    | 'id'
    64→    | 'icon'
    65→    | 'duration'
    66→    | 'ariaProps'
    67→    | 'className'
    68→    | 'style'
    69→    | 'position'
    70→    | 'iconTheme'
    71→    | 'toasterId'
    72→    | 'removeDelay'
    73→  >
    74→>;
    76→export type DefaultToastOptions = ToastOptions & {
    77→  [key in ToastType]?: ToastOptions;
    78→};
    80→export interface ToasterProps {
    81→  position?: ToastPosition;
    82→  toastOptions?: DefaultToastOptions;
    83→  reverseOrder?: boolean;
    84→  gutter?: number;
    85→  containerStyle?: React.CSSProperties;
    86→  containerClassName?: string;
    87→  toasterId?: string;
    88→  children?: (toast: Toast) => React.ReactElement;
    89→}
    91→export interface ToastWrapperProps {
    92→  id: string;
    93→  className?: string;
    94→  style?: React.CSSProperties;
    95→  onHeightUpdate: (id: string, height: number) => void;
    96→  children?: React.ReactNode;

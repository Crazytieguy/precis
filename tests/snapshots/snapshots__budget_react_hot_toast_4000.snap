src/core/use-toaster.ts
     1→import { useEffect, useCallback, useRef } from 'react';
     2→import { createDispatch, ActionType, useStore, dispatch } from './store';
     3→import { toast } from './toast';
     4→import { DefaultToastOptions, Toast, ToastPosition } from './types';
     6→export const REMOVE_DELAY = 1000;
     8→export const useToaster = (
     9→  toastOptions?: DefaultToastOptions,
    10→  toasterId: string = 'default'
    11→) => {
    12→  const { toasts, pausedAt } = useStore(toastOptions, toasterId);
    13→  const toastTimeouts = useRef(
    14→    new Map<Toast['id'], ReturnType<typeof setTimeout>>()
    15→  ).current;
    16→
    17→  const addToRemoveQueue = useCallback(
    18→    (toastId: string, removeDelay = REMOVE_DELAY) => {
    19→      if (toastTimeouts.has(toastId)) {
    20→        return;
    21→      }
    22→
    23→      const timeout = setTimeout(() => {
    24→        toastTimeouts.delete(toastId);
    25→        dispatch({
    26→          type: ActionType.REMOVE_TOAST,
    27→          toastId: toastId,
    28→        });
    29→      }, removeDelay);
    30→
    31→      toastTimeouts.set(toastId, timeout);
    32→    },
    33→    []
    34→  );
    35→
    36→  useEffect(() => {
    37→    if (pausedAt) {
    38→      return;
    39→    }
    40→
    41→    const now = Date.now();
    42→    const timeouts = toasts.map((t) => {
    43→      if (t.duration === Infinity) {
    44→        return;
    45→      }
    46→
    47→      const durationLeft =
    48→        (t.duration || 0) + t.pauseDuration - (now - t.createdAt);
    49→
    50→      if (durationLeft < 0) {
    51→        if (t.visible) {
    52→          toast.dismiss(t.id);
    53→        }
    54→        return;
    55→      }
    56→      return setTimeout(() => toast.dismiss(t.id, toasterId), durationLeft);
    57→    });
    58→
    59→    return () => {
    60→      timeouts.forEach((timeout) => timeout && clearTimeout(timeout));
    61→    };
    62→  }, [toasts, pausedAt, toasterId]);
    63→
    64→  const dispatch = useCallback(createDispatch(toasterId), [toasterId]);
    65→
    66→  const startPause = useCallback(() => {
    67→    dispatch({
    68→      type: ActionType.START_PAUSE,
    69→      time: Date.now(),
    70→    });
    71→  }, [dispatch]);
    72→
    73→  const updateHeight = useCallback(
    74→    (toastId: string, height: number) => {
    75→      dispatch({
    76→        type: ActionType.UPDATE_TOAST,
    77→        toast: { id: toastId, height },
    78→      });
    79→    },
    80→    [dispatch]
    81→  );
    82→
    83→  const endPause = useCallback(() => {
    84→    if (pausedAt) {
    85→      dispatch({ type: ActionType.END_PAUSE, time: Date.now() });
    86→    }
    87→  }, [pausedAt, dispatch]);
    88→
    89→  const calculateOffset = useCallback(
    90→    (
    91→      toast: Toast,
    92→      opts?: {
    93→        reverseOrder?: boolean;
    94→        gutter?: number;
    95→        defaultPosition?: ToastPosition;
    96→      }
    97→    ) => {
    98→      const { reverseOrder = false, gutter = 8, defaultPosition } = opts || {};
    99→
   100→      const relevantToasts = toasts.filter(
   101→        (t) =>
   102→          (t.position || defaultPosition) ===
   103→            (toast.position || defaultPosition) && t.height
   104→      );
   105→      const toastIndex = relevantToasts.findIndex((t) => t.id === toast.id);
   106→      const toastsBefore = relevantToasts.filter(
   107→        (toast, i) => i < toastIndex && toast.visible
   108→      ).length;
   109→
   110→      const offset = relevantToasts
   111→        .filter((t) => t.visible)
   112→        .slice(...(reverseOrder ? [toastsBefore + 1] : [0, toastsBefore]))
   113→        .reduce((acc, t) => acc + (t.height || 0) + gutter, 0);
   114→
   115→      return offset;
   116→    },
   117→    [toasts]
   118→  );
   119→
   120→  // Keep track of dismissed toasts and remove them after the delay
   121→  useEffect(() => {
   122→    toasts.forEach((toast) => {
   123→      if (toast.dismissed) {
   124→        addToRemoveQueue(toast.id, toast.removeDelay);
   125→      } else {
   126→        // If toast becomes visible again, remove it from the queue
   127→        const timeout = toastTimeouts.get(toast.id);
   128→        if (timeout) {
   129→          clearTimeout(timeout);
   130→          toastTimeouts.delete(toast.id);
   131→        }
   132→      }
   133→    });
   134→  }, [toasts, addToRemoveQueue]);
   135→
   136→  return {
   137→    toasts,
   138→    handlers: {
   139→      updateHeight,
   140→      startPause,
   141→      endPause,
   142→      calculateOffset,
   143→    },
   144→  };
   145→};
src/core/utils.ts
     1→export const genId = (() => {
     2→  let count = 0;
     3→  return () => {
     4→    return (++count).toString();
     5→  };
     6→})();
     8→export const prefersReducedMotion = (() => {
     9→  // Cache result
    10→  let shouldReduceMotion: boolean | undefined = undefined;
    11→
    12→  return () => {
    13→    if (shouldReduceMotion === undefined && typeof window !== 'undefined') {
    14→      const mediaQuery = matchMedia('(prefers-reduced-motion: reduce)');
    15→      shouldReduceMotion = !mediaQuery || mediaQuery.matches;
    16→    }
    17→    return shouldReduceMotion;
    18→  };
    19→})();

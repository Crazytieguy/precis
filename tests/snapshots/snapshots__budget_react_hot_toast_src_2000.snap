   149‚Üíexport const dispatch = (action: Action, toasterId = DEFAULT_TOASTER_ID) => {
   150‚Üí  memoryState[toasterId] = reducer(
   151‚Üí    memoryState[toasterId] || defaultToasterState,
   152‚Üí    action
   153‚Üí  );
   154‚Üí  listeners.forEach(([id, listener]) => {
   155‚Üí    if (id === toasterId) {
   156‚Üí      listener(memoryState[toasterId]);

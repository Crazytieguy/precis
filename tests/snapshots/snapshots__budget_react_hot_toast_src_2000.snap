    83‚Üíconst DEFAULT_OFFSET = 16;
    85‚Üíexport const Toaster: React.FC<ToasterProps> = ({
    86‚Üí  reverseOrder,
    87‚Üí  position = 'top-center',
    88‚Üí  toastOptions,
    89‚Üí  gutter,
    90‚Üí  children,
    91‚Üí  toasterId,
    92‚Üí  containerStyle,
    93‚Üí  containerClassName,
    94‚Üí}) => {
    95‚Üí  const { toasts, handlers } = useToaster(toastOptions, toasterId);
    96‚Üí
    97‚Üí  return (
    98‚Üí    <div
    99‚Üí      data-rht-toaster={toasterId || ''}
   100‚Üí      style={{
   101‚Üí        position: 'fixed',
   102‚Üí        zIndex: 9999,
   103‚Üí        top: DEFAULT_OFFSET,
   104‚Üí        left: DEFAULT_OFFSET,
   105‚Üí        right: DEFAULT_OFFSET,
   106‚Üí        bottom: DEFAULT_OFFSET,
   107‚Üí        pointerEvents: 'none',
   108‚Üí        ...containerStyle,
   109‚Üí      }}
   110‚Üí      className={containerClassName}
   111‚Üí      onMouseEnter={handlers.startPause}
   112‚Üí      onMouseLeave={handlers.endPause}
   113‚Üí    >
   114‚Üí      {toasts.map((t) => {
   115‚Üí        const toastPosition = t.position || position;
   116‚Üí        const offset = handlers.calculateOffset(t, {
   117‚Üí          reverseOrder,
   118‚Üí          gutter,
   119‚Üí          defaultPosition: position,
   120‚Üí        });
   121‚Üí        const positionStyle = getPositionStyle(toastPosition, offset);
   122‚Üí
   123‚Üí        return (
   124‚Üí          <ToastWrapper
   125‚Üí            id={t.id}
   126‚Üí            key={t.id}
   127‚Üí            onHeightUpdate={handlers.updateHeight}
   128‚Üí            className={t.visible ? activeClass : ''}
   129‚Üí            style={positionStyle}
   130‚Üí          >
   131‚Üí            {t.type === 'custom' ? (
   132‚Üí              resolveValue(t.message, t)
   133‚Üí            ) : children ? (
   134‚Üí              children(t)
   135‚Üí            ) : (
   136‚Üí              <ToastBar toast={t} position={toastPosition} />
   137‚Üí            )}
   138‚Üí          </ToastWrapper>
   139‚Üí        );
   140‚Üí      })}
   141‚Üí    </div>
   142‚Üí  );
   143‚Üí};

     8‚Üíexport const prefersReducedMotion = (() => {
     9‚Üí  // Cache result
    10‚Üí  let shouldReduceMotion: boolean | undefined = undefined;
    11‚Üí
    12‚Üí  return () => {
    13‚Üí    if (shouldReduceMotion === undefined && typeof window !== 'undefined') {
    14‚Üí      const mediaQuery = matchMedia('(prefers-reduced-motion: reduce)');
    15‚Üí      shouldReduceMotion = !mediaQuery || mediaQuery.matches;
    16‚Üí    }
    17‚Üí    return shouldReduceMotion;
    18‚Üí  };
    19‚Üí})();

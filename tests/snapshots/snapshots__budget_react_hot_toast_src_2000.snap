     6‚Üíexport const REMOVE_DELAY = 1000;
     8‚Üíexport const useToaster = (
     9‚Üí  toastOptions?: DefaultToastOptions,
    10‚Üí  toasterId: string = 'default'
    11‚Üí) => {
    12‚Üí  const { toasts, pausedAt } = useStore(toastOptions, toasterId);
    13‚Üí  const toastTimeouts = useRef(
    14‚Üí    new Map<Toast['id'], ReturnType<typeof setTimeout>>()
    15‚Üí  ).current;
    16‚Üí
    17‚Üí  const addToRemoveQueue = useCallback(
    18‚Üí    (toastId: string, removeDelay = REMOVE_DELAY) => {
    19‚Üí      if (toastTimeouts.has(toastId)) {
    20‚Üí        return;
    21‚Üí      }

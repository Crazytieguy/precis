     1‚Üíimport { useEffect, useState, useRef } from 'react';
     2‚Üíimport { DefaultToastOptions, Toast, ToastType } from './types';
     4‚Üíexport const TOAST_EXPIRE_DISMISS_DELAY = 1000;
     5‚Üíexport const TOAST_LIMIT = 20;
     6‚Üíexport const DEFAULT_TOASTER_ID = 'default';
     8‚Üíinterface ToasterSettings {
     9‚Üí  toastLimit: number;
    10‚Üí}
    12‚Üíexport enum ActionType {
    13‚Üí  ADD_TOAST,

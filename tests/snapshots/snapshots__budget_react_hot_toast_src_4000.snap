     1→import * as React from 'react';
     2→import { styled, keyframes } from 'goober';
     3→
     4→import { Toast } from '../core/types';
     5→import { ErrorIcon, ErrorTheme } from './error';
     6→import { LoaderIcon, LoaderTheme } from './loader';
     7→import { CheckmarkIcon, CheckmarkTheme } from './checkmark';
     8→
     9→const StatusWrapper = styled('div')`
    10→  position: absolute;
    11→`;
    12→
    13→const IndicatorWrapper = styled('div')`
    14→  position: relative;
    15→  display: flex;
    16→  justify-content: center;
    17→  align-items: center;
    18→  min-width: 20px;
    19→  min-height: 20px;
    20→`;
    21→
    22→const enter = keyframes`
    23→from {
    24→  transform: scale(0.6);
    25→  opacity: 0.4;
    26→}
    27→to {
    28→  transform: scale(1);
    29→  opacity: 1;
    30→}`;
    31→
    32→export const AnimatedIconWrapper = styled('div')`
    33→  position: relative;
    34→  transform: scale(0.6);
    35→  opacity: 0.4;
    36→  min-width: 20px;
    37→  animation: ${enter} 0.3s 0.12s cubic-bezier(0.175, 0.885, 0.32, 1.275)
    38→    forwards;
    39→`;
    40→
    41→export type IconThemes = Partial<{
    42→  success: CheckmarkTheme;
    43→  error: ErrorTheme;
    44→  loading: LoaderTheme;
    45→}>;
    46→
    47→export const ToastIcon: React.FC<{
    48→  toast: Toast;
    49→}> = ({ toast }) => {
    50→  const { icon, type, iconTheme } = toast;
    51→  if (icon !== undefined) {
    52→    if (typeof icon === 'string') {
    53→      return <AnimatedIconWrapper>{icon}</AnimatedIconWrapper>;
    54→    } else {
    55→      return icon;
    56→    }
    57→  }
    58→
    59→  if (type === 'blank') {
    60→    return null;
    61→  }
    62→
    63→  return (
    64→    <IndicatorWrapper>
    65→      <LoaderIcon {...iconTheme} />
    66→      {type !== 'loading' && (
    67→        <StatusWrapper>
    68→          {type === 'error' ? (
    69→            <ErrorIcon {...iconTheme} />
    70→          ) : (
    71→            <CheckmarkIcon {...iconTheme} />
    72→          )}
    73→        </StatusWrapper>
    74→      )}
    75→    </IndicatorWrapper>
    76→  );
    77→};
components/toaster.tsx
     1→import { css, setup } from 'goober';
     2→import * as React from 'react';
     3→import {
     4→  resolveValue,
     5→  ToasterProps,
     6→  ToastPosition,
     7→  ToastWrapperProps,
     8→} from '../core/types';
     9→import { useToaster } from '../core/use-toaster';
    10→import { prefersReducedMotion } from '../core/utils';
    11→import { ToastBar } from './toast-bar';
    12→
    13→setup(React.createElement);
    14→
    15→const ToastWrapper = ({
    16→  id,
    17→  className,
    18→  style,
    19→  onHeightUpdate,
    20→  children,
    21→}: ToastWrapperProps) => {
    22→  const ref = React.useCallback(
    23→    (el: HTMLElement | null) => {
    24→      if (el) {
    25→        const updateHeight = () => {
    26→          const height = el.getBoundingClientRect().height;
    27→          onHeightUpdate(id, height);
    28→        };
    29→        updateHeight();
    30→        new MutationObserver(updateHeight).observe(el, {
    31→          subtree: true,
    32→          childList: true,
    33→          characterData: true,
    34→        });
    35→      }
    36→    },
    37→    [id, onHeightUpdate]
    38→  );
    39→
    40→  return (
    41→    <div ref={ref} className={className} style={style}>
    42→      {children}
    43→    </div>
    44→  );
    45→};
    46→
    47→const getPositionStyle = (
    48→  position: ToastPosition,
    49→  offset: number
    50→): React.CSSProperties => {
    51→  const top = position.includes('top');
    52→  const verticalStyle: React.CSSProperties = top ? { top: 0 } : { bottom: 0 };
    53→  const horizontalStyle: React.CSSProperties = position.includes('center')
    54→    ? {
    55→        justifyContent: 'center',
    56→      }
    57→    : position.includes('right')
    58→    ? {
    59→        justifyContent: 'flex-end',
    60→      }
    61→    : {};
    62→  return {
    63→    left: 0,
    64→    right: 0,
    65→    display: 'flex',
    66→    position: 'absolute',
    67→    transition: prefersReducedMotion()
    68→      ? undefined
    69→      : `all 230ms cubic-bezier(.21,1.02,.73,1)`,
    70→    transform: `translateY(${offset * (top ? 1 : -1)}px)`,
    71→    ...verticalStyle,
    72→    ...horizontalStyle,
    73→  };
    74→};
    75→
    76→const activeClass = css`
    77→  z-index: 9999;
    78→  > * {
    79→    pointer-events: auto;
    80→  }
    81→`;
    82→
    83→const DEFAULT_OFFSET = 16;
    84→
    85→export const Toaster: React.FC<ToasterProps> = ({
    86→  reverseOrder,
    87→  position = 'top-center',
    88→  toastOptions,
    89→  gutter,
    90→  children,
    91→  toasterId,
    92→  containerStyle,
    93→  containerClassName,
    94→}) => {
    95→  const { toasts, handlers } = useToaster(toastOptions, toasterId);
    96→
    97→  return (
    98→    <div
    99→      data-rht-toaster={toasterId || ''}
   100→      style={{
   101→        position: 'fixed',
   102→        zIndex: 9999,
   103→        top: DEFAULT_OFFSET,
   104→        left: DEFAULT_OFFSET,
   105→        right: DEFAULT_OFFSET,
   106→        bottom: DEFAULT_OFFSET,
   107→        pointerEvents: 'none',
   108→        ...containerStyle,
   109→      }}
   110→      className={containerClassName}
   111→      onMouseEnter={handlers.startPause}
   112→      onMouseLeave={handlers.endPause}
   113→    >
   114→      {toasts.map((t) => {
   115→        const toastPosition = t.position || position;
   116→        const offset = handlers.calculateOffset(t, {
   117→          reverseOrder,
   118→          gutter,
   119→          defaultPosition: position,
   120→        });
   121→        const positionStyle = getPositionStyle(toastPosition, offset);
   122→
   123→        return (
   124→          <ToastWrapper
   125→            id={t.id}
   126→            key={t.id}
   127→            onHeightUpdate={handlers.updateHeight}
   128→            className={t.visible ? activeClass : ''}
   129→            style={positionStyle}
   130→          >
   131→            {t.type === 'custom' ? (
   132→              resolveValue(t.message, t)
   133→            ) : children ? (
   134→              children(t)
   135→            ) : (
   136→              <ToastBar toast={t} position={toastPosition} />
   137→            )}
   138→          </ToastWrapper>
   139→        );
   140→      })}
   141→    </div>
   142→  );
   143→};
core/store.ts
     1→import { useEffect, useState, useRef } from 'react';
     2→import { DefaultToastOptions, Toast, ToastType } from './types';
     3→
     4→export const TOAST_EXPIRE_DISMISS_DELAY = 1000;
     5→export const TOAST_LIMIT = 20;
     6→export const DEFAULT_TOASTER_ID = 'default';
     7→
     8→interface ToasterSettings {
     9→  toastLimit: number;
    10→}
    11→
    12→export enum ActionType {
    13→  ADD_TOAST,
    14→  UPDATE_TOAST,
    15→  UPSERT_TOAST,
    16→  DISMISS_TOAST,
    17→  REMOVE_TOAST,
    18→  START_PAUSE,
    19→  END_PAUSE,
    20→}
    21→
    22→export type Action =
    23→  | {
    24→      type: ActionType.ADD_TOAST;
    25→      toast: Toast;
    26→    }
    27→  | {
    28→      type: ActionType.UPSERT_TOAST;
    29→      toast: Toast;
    30→    }
    31→  | {
    32→      type: ActionType.UPDATE_TOAST;
    33→      toast: Partial<Toast>;
    34→    }
    35→  | {
    36→      type: ActionType.DISMISS_TOAST;
    37→      toastId?: string;
    38→    }
    39→  | {
    40→      type: ActionType.REMOVE_TOAST;
    41→      toastId?: string;
    42→    }
    43→  | {
    44→      type: ActionType.START_PAUSE;
    45→      time: number;
    46→    }
    47→  | {
    48→      type: ActionType.END_PAUSE;
    49→      time: number;
    50→    };
    51→
    52→interface ToasterState {
    53→  toasts: Toast[];
    54→  settings: ToasterSettings;
    55→  pausedAt: number | undefined;
    56→}
    57→
    58→interface State {
    59→  [toasterId: string]: ToasterState;
    60→}
    61→
    62→export const reducer = (state: ToasterState, action: Action): ToasterState => {
    63→  const { toastLimit } = state.settings;
    64→
    65→  switch (action.type) {
    66→    case ActionType.ADD_TOAST:
    67→      return {
    68→        ...state,
    69→        toasts: [action.toast, ...state.toasts].slice(0, toastLimit),
    70→      };
    71→
    72→    case ActionType.UPDATE_TOAST:
    73→      return {
    74→        ...state,
    75→        toasts: state.toasts.map((t) =>
    76→          t.id === action.toast.id ? { ...t, ...action.toast } : t
    77→        ),
    78→      };
    79→
    80→    case ActionType.UPSERT_TOAST:
    81→      const { toast } = action;
    82→      return reducer(state, {
    83→        type: state.toasts.find((t) => t.id === toast.id)
    84→          ? ActionType.UPDATE_TOAST
    85→          : ActionType.ADD_TOAST,
    86→        toast,
    87→      });
    88→
    89→    case ActionType.DISMISS_TOAST:
    90→      const { toastId } = action;
    91→
    92→      return {
    93→        ...state,
    94→        toasts: state.toasts.map((t) =>
    95→          t.id === toastId || toastId === undefined
    96→            ? {
    97→                ...t,
    98→                dismissed: true,
    99→                visible: false,
   100→              }
   101→            : t
   102→        ),
   103→      };
   104→    case ActionType.REMOVE_TOAST:
   105→      if (action.toastId === undefined) {
   106→        return {
   107→          ...state,
   108→          toasts: [],
   109→        };
   110→      }
   111→      return {
   112→        ...state,
   113→        toasts: state.toasts.filter((t) => t.id !== action.toastId),
   114→      };
   115→
   116→    case ActionType.START_PAUSE:
   117→      return {
   118→        ...state,
   119→        pausedAt: action.time,
   120→      };
   121→
   122→    case ActionType.END_PAUSE:
   123→      const diff = action.time - (state.pausedAt || 0);
   124→
   125→      return {
   126→        ...state,
   127→        pausedAt: undefined,
   128→        toasts: state.toasts.map((t) => ({
   129→          ...t,
   130→          pauseDuration: t.pauseDuration + diff,
   131→        })),
   132→      };
   133→  }
   134→};
   135→
   136→const listeners: Array<
   137→  [toasterId: string, reducer: (state: ToasterState) => void]
   138→> = [];
   139→
   140→const defaultToasterState: ToasterState = {
   141→  toasts: [],
   142→  pausedAt: undefined,
   143→  settings: {
   144→    toastLimit: TOAST_LIMIT,
   145→  },
   146→};
   147→let memoryState: State = {};
   148→
   149→export const dispatch = (action: Action, toasterId = DEFAULT_TOASTER_ID) => {
   150→  memoryState[toasterId] = reducer(
   151→    memoryState[toasterId] || defaultToasterState,
   152→    action
   153→  );
   154→  listeners.forEach(([id, listener]) => {
   155→    if (id === toasterId) {
   156→      listener(memoryState[toasterId]);
   157→    }
   158→  });
   159→};
   160→
   161→export const dispatchAll = (action: Action) =>
   162→  Object.keys(memoryState).forEach((toasterId) => dispatch(action, toasterId));
   163→
   164→export const getToasterIdFromToastId = (toastId: string) =>
   165→  Object.keys(memoryState).find((toasterId) =>
   166→    memoryState[toasterId].toasts.some((t) => t.id === toastId)
   167→  );
   168→
   169→export const createDispatch =
   170→  (toasterId = DEFAULT_TOASTER_ID) =>
   171→  (action: Action) => {
   172→    dispatch(action, toasterId);
   173→  };
   174→
   175→export const defaultTimeouts: {
   176→  [key in ToastType]: number;
   177→} = {
   178→  blank: 4000,
   179→  error: 4000,
   180→  success: 2000,
   181→  loading: Infinity,
   182→  custom: 4000,
   183→};
   184→
   185→export const useStore = (
   186→  toastOptions: DefaultToastOptions = {},
   187→  toasterId: string = DEFAULT_TOASTER_ID
   188→): ToasterState => {
   189→  const [state, setState] = useState<ToasterState>(
   190→    memoryState[toasterId] || defaultToasterState
   191→  );
   192→  const initial = useRef(memoryState[toasterId]);
   193→
   194→  // TODO: Switch to useSyncExternalStore when targeting React 18+
   195→  useEffect(() => {
   196→    if (initial.current !== memoryState[toasterId]) {
   197→      setState(memoryState[toasterId]);
   198→    }
   199→    listeners.push([toasterId, setState]);
   200→    return () => {
   201→      const index = listeners.findIndex(([id]) => id === toasterId);
   202→      if (index > -1) {
   203→        listeners.splice(index, 1);
   204→      }
   205→    };
   206→  }, [toasterId]);
   207→
   208→  const mergedToasts = state.toasts.map((t) => ({
   209→    ...toastOptions,
   210→    ...toastOptions[t.type],
   211→    ...t,
   212→    removeDelay:
   213→      t.removeDelay ||
   214→      toastOptions[t.type]?.removeDelay ||
   215→      toastOptions?.removeDelay,
   216→    duration:
   217→      t.duration ||
   218→      toastOptions[t.type]?.duration ||
   219→      toastOptions?.duration ||
   220→      defaultTimeouts[t.type],
   221→    style: {
   222→      ...toastOptions.style,
   223→      ...toastOptions[t.type]?.style,
   224→      ...t.style,
   225→    },
   226→  }));
   227→
   228→  return {
   229→    ...state,
   230→    toasts: mergedToasts,
   231→  };
   232→};
core/toast.ts
     1→import {
     2→  Renderable,
     3→  Toast,
     4→  ToastOptions,
     5→  ToastType,
     6→  DefaultToastOptions,
     7→  ValueOrFunction,
     8→  resolveValue,
     9→} from './types';
    10→import { genId } from './utils';
    11→import {
    12→  createDispatch,
    13→  Action,
    14→  ActionType,
    15→  dispatchAll,
    16→  getToasterIdFromToastId,
    17→} from './store';
    18→
    19→type Message = ValueOrFunction<Renderable, Toast>;
    20→
    21→type ToastHandler = (message: Message, options?: ToastOptions) => string;
    22→
    23→const createToast = (
    24→  message: Message,
    25→  type: ToastType = 'blank',
    26→  opts?: ToastOptions
    27→): Toast => ({
    28→  createdAt: Date.now(),
    29→  visible: true,
    30→  dismissed: false,
    31→  type,
    32→  ariaProps: {
    33→    role: 'status',
    34→    'aria-live': 'polite',
    35→  },
    36→  message,
    37→  pauseDuration: 0,
    38→  ...opts,
    39→  id: opts?.id || genId(),
    40→});
    41→
    42→const createHandler =
    43→  (type?: ToastType): ToastHandler =>
    44→  (message, options) => {
    45→    const toast = createToast(message, type, options);
    46→
    47→    const dispatch = createDispatch(
    48→      toast.toasterId || getToasterIdFromToastId(toast.id)
    49→    );
    50→
    51→    dispatch({ type: ActionType.UPSERT_TOAST, toast });
    52→    return toast.id;
    53→  };
    54→
    55→const toast = (message: Message, opts?: ToastOptions) =>
    56→  createHandler('blank')(message, opts);
    57→
    58→toast.error = createHandler('error');
    59→toast.success = createHandler('success');
    60→toast.loading = createHandler('loading');
    61→toast.custom = createHandler('custom');
    62→
    63→/**
    64→ * Dismisses the toast with the given id. If no id is given, dismisses all toasts.
    65→ * The toast will transition out and then be removed from the DOM.
    66→ * Applies to all toasters, except when a `toasterId` is given.
    67→ */
    68→toast.dismiss = (toastId?: string, toasterId?: string) => {
    69→  const action: Action = {
    70→    type: ActionType.DISMISS_TOAST,
    71→    toastId,
    72→  };
    73→
    74→  if (toasterId) {
    75→    createDispatch(toasterId)(action);
    76→  } else {
    77→    dispatchAll(action);
    78→  }
    79→};
    80→
    81→/**
    82→ * Dismisses all toasts.
    83→ */
    84→toast.dismissAll = (toasterId?: string) => toast.dismiss(undefined, toasterId);
    85→
    86→/**
    87→ * Removes the toast with the given id.
    88→ * The toast will be removed from the DOM without any transition.
    89→ */
    90→toast.remove = (toastId?: string, toasterId?: string) => {
    91→  const action: Action = {
    92→    type: ActionType.REMOVE_TOAST,
    93→    toastId,
    94→  };
    95→  if (toasterId) {
    96→    createDispatch(toasterId)(action);
    97→  } else {
    98→    dispatchAll(action);
    99→  }
   100→};
   101→
   102→/**
   103→ * Removes all toasts.
   104→ */
   105→toast.removeAll = (toasterId?: string) => toast.remove(undefined, toasterId);
   106→
   107→/**
   108→ * Create a loading toast that will automatically updates with the promise.
   109→ */
   110→toast.promise = <T>(
   111→  promise: Promise<T> | (() => Promise<T>),
   112→  msgs: {
   113→    loading: Renderable;
   114→    success?: ValueOrFunction<Renderable, T>;
   115→    error?: ValueOrFunction<Renderable, any>;
   116→  },
   117→  opts?: DefaultToastOptions
   118→) => {
   119→  const id = toast.loading(msgs.loading, { ...opts, ...opts?.loading });
   120→
   121→  if (typeof promise === 'function') {
   122→    promise = promise();
   123→  }
   124→
   125→  promise
   126→    .then((p) => {
   127→      const successMessage = msgs.success
   128→        ? resolveValue(msgs.success, p)
   129→        : undefined;
   130→
   131→      if (successMessage) {
   132→        toast.success(successMessage, {
   133→          id,
   134→          ...opts,
   135→          ...opts?.success,
   136→        });
   137→      } else {
   138→        toast.dismiss(id);
   139→      }
   140→      return p;
   141→    })
   142→    .catch((e) => {
   143→      const errorMessage = msgs.error ? resolveValue(msgs.error, e) : undefined;
   144→
   145→      if (errorMessage) {
   146→        toast.error(errorMessage, {
   147→          id,
   148→          ...opts,
   149→          ...opts?.error,
   150→        });
   151→      } else {
   152→        toast.dismiss(id);
   153→      }
   154→    });
   155→
   156→  return promise;
   157→};
   158→
   159→export { toast };
core/types.ts
     1→import { CSSProperties } from 'react';
     2→
     3→export type ToastType = 'success' | 'error' | 'loading' | 'blank' | 'custom';
     4→export type ToastPosition =
     5→  | 'top-left'
     6→  | 'top-center'
     7→  | 'top-right'
     8→  | 'bottom-left'
     9→  | 'bottom-center'
    10→  | 'bottom-right';
    11→
    12→export type Renderable = React.ReactElement | string | null;
    13→
    14→export interface IconTheme {
    15→  primary: string;
    16→  secondary: string;
    17→}
    18→
    19→export type ValueFunction<TValue, TArg> = (arg: TArg) => TValue;
    20→export type ValueOrFunction<TValue, TArg> =
    21→  | TValue
    22→  | ValueFunction<TValue, TArg>;
    23→
    24→const isFunction = <TValue, TArg>(
    25→  valOrFunction: ValueOrFunction<TValue, TArg>
    26→): valOrFunction is ValueFunction<TValue, TArg> =>
    27→  typeof valOrFunction === 'function';
    28→
    29→export const resolveValue = <TValue, TArg>(
    30→  valOrFunction: ValueOrFunction<TValue, TArg>,
    31→  arg: TArg
    32→): TValue => (isFunction(valOrFunction) ? valOrFunction(arg) : valOrFunction);
    33→
    34→export interface Toast {
    35→  type: ToastType;
    36→  id: string;
    37→  toasterId?: string;
    38→  message: ValueOrFunction<Renderable, Toast>;
    39→  icon?: Renderable;
    40→  duration?: number;
    41→  pauseDuration: number;
    42→  position?: ToastPosition;
    43→  removeDelay?: number;
    44→
    45→  ariaProps: {
    46→    role: 'status' | 'alert';
    47→    'aria-live': 'assertive' | 'off' | 'polite';
    48→  };
    49→
    50→  style?: CSSProperties;
    51→  className?: string;
    52→  iconTheme?: IconTheme;
    53→
    54→  createdAt: number;
    55→  visible: boolean;
    56→  dismissed: boolean;
    57→  height?: number;
    58→}
    59→
    60→export type ToastOptions = Partial<
    61→  Pick<
    62→    Toast,
    63→    | 'id'
    64→    | 'icon'
    65→    | 'duration'
    66→    | 'ariaProps'
    67→    | 'className'
    68→    | 'style'
    69→    | 'position'
    70→    | 'iconTheme'
    71→    | 'toasterId'
    72→    | 'removeDelay'
    73→  >
    74→>;
    75→
    76→export type DefaultToastOptions = ToastOptions & {
    77→  [key in ToastType]?: ToastOptions;
    78→};
    79→
    80→export interface ToasterProps {
    81→  position?: ToastPosition;
    82→  toastOptions?: DefaultToastOptions;
    83→  reverseOrder?: boolean;
    84→  gutter?: number;
    85→  containerStyle?: React.CSSProperties;
    86→  containerClassName?: string;
    87→  toasterId?: string;
    88→  children?: (toast: Toast) => React.ReactElement;
    89→}
    90→
    91→export interface ToastWrapperProps {
    92→  id: string;
    93→  className?: string;
    94→  style?: React.CSSProperties;
    95→  onHeightUpdate: (id: string, height: number) => void;
    96→  children?: React.ReactNode;
    97→}
core/use-toaster.ts
     1→import { useEffect, useCallback, useRef } from 'react';
     2→import { createDispatch, ActionType, useStore, dispatch } from './store';
     3→import { toast } from './toast';
     4→import { DefaultToastOptions, Toast, ToastPosition } from './types';
     5→
     6→export const REMOVE_DELAY = 1000;
     7→
     8→export const useToaster = (
     9→  toastOptions?: DefaultToastOptions,
    10→  toasterId: string = 'default'
    11→) => {
    12→  const { toasts, pausedAt } = useStore(toastOptions, toasterId);
    13→  const toastTimeouts = useRef(
    14→    new Map<Toast['id'], ReturnType<typeof setTimeout>>()
    15→  ).current;
    16→
    17→  const addToRemoveQueue = useCallback(
    18→    (toastId: string, removeDelay = REMOVE_DELAY) => {
    19→      if (toastTimeouts.has(toastId)) {
    20→        return;
    21→      }
    22→
    23→      const timeout = setTimeout(() => {
    24→        toastTimeouts.delete(toastId);
    25→        dispatch({
    26→          type: ActionType.REMOVE_TOAST,
    27→          toastId: toastId,
    28→        });
    29→      }, removeDelay);
    30→
    31→      toastTimeouts.set(toastId, timeout);
    32→    },
    33→    []
    34→  );
    35→
    36→  useEffect(() => {
    37→    if (pausedAt) {
    38→      return;
    39→    }
    40→
    41→    const now = Date.now();
    42→    const timeouts = toasts.map((t) => {
    43→      if (t.duration === Infinity) {
    44→        return;
    45→      }
    46→
    47→      const durationLeft =
    48→        (t.duration || 0) + t.pauseDuration - (now - t.createdAt);
    49→
    50→      if (durationLeft < 0) {
    51→        if (t.visible) {
    52→          toast.dismiss(t.id);
    53→        }
    54→        return;
    55→      }
    56→      return setTimeout(() => toast.dismiss(t.id, toasterId), durationLeft);
    57→    });
    58→
    59→    return () => {
    60→      timeouts.forEach((timeout) => timeout && clearTimeout(timeout));
    61→    };
    62→  }, [toasts, pausedAt, toasterId]);
    63→
    64→  const dispatch = useCallback(createDispatch(toasterId), [toasterId]);
    65→
    66→  const startPause = useCallback(() => {
    67→    dispatch({
    68→      type: ActionType.START_PAUSE,
    69→      time: Date.now(),
    70→    });
    71→  }, [dispatch]);
    72→
    73→  const updateHeight = useCallback(
    74→    (toastId: string, height: number) => {
    75→      dispatch({
    76→        type: ActionType.UPDATE_TOAST,
    77→        toast: { id: toastId, height },
    78→      });
    79→    },
    80→    [dispatch]
    81→  );
    82→
    83→  const endPause = useCallback(() => {
    84→    if (pausedAt) {
    85→      dispatch({ type: ActionType.END_PAUSE, time: Date.now() });
    86→    }
    87→  }, [pausedAt, dispatch]);
    88→
    89→  const calculateOffset = useCallback(
    90→    (
    91→      toast: Toast,
    92→      opts?: {
    93→        reverseOrder?: boolean;
    94→        gutter?: number;
    95→        defaultPosition?: ToastPosition;
    96→      }
    97→    ) => {
    98→      const { reverseOrder = false, gutter = 8, defaultPosition } = opts || {};
    99→
   100→      const relevantToasts = toasts.filter(
   101→        (t) =>
   102→          (t.position || defaultPosition) ===
   103→            (toast.position || defaultPosition) && t.height
   104→      );
   105→      const toastIndex = relevantToasts.findIndex((t) => t.id === toast.id);
   106→      const toastsBefore = relevantToasts.filter(
   107→        (toast, i) => i < toastIndex && toast.visible
   108→      ).length;
   109→
   110→      const offset = relevantToasts
   111→        .filter((t) => t.visible)
   112→        .slice(...(reverseOrder ? [toastsBefore + 1] : [0, toastsBefore]))
   113→        .reduce((acc, t) => acc + (t.height || 0) + gutter, 0);
   114→
   115→      return offset;
   116→    },
   117→    [toasts]
   118→  );
   119→
   120→  // Keep track of dismissed toasts and remove them after the delay
   121→  useEffect(() => {
   122→    toasts.forEach((toast) => {
   123→      if (toast.dismissed) {
   124→        addToRemoveQueue(toast.id, toast.removeDelay);
   125→      } else {
   126→        // If toast becomes visible again, remove it from the queue
   127→        const timeout = toastTimeouts.get(toast.id);
   128→        if (timeout) {
   129→          clearTimeout(timeout);
   130→          toastTimeouts.delete(toast.id);
   131→        }
   132→      }
   133→    });
   134→  }, [toasts, addToRemoveQueue]);
   135→
   136→  return {
   137→    toasts,
   138→    handlers: {
   139→      updateHeight,
   140→      startPause,
   141→      endPause,
   142→      calculateOffset,
   143→    },
   144→  };
   145→};
core/utils.ts
     1→export const genId = (() => {
     2→  let count = 0;
     3→  return () => {
     4→    return (++count).toString();
     5→  };
     6→})();
     7→
     8→export const prefersReducedMotion = (() => {
     9→  // Cache result
    10→  let shouldReduceMotion: boolean | undefined = undefined;
    11→
    12→  return () => {
    13→    if (shouldReduceMotion === undefined && typeof window !== 'undefined') {
    14→      const mediaQuery = matchMedia('(prefers-reduced-motion: reduce)');
    15→      shouldReduceMotion = !mediaQuery || mediaQuery.matches;
    16→    }
    17→    return shouldReduceMotion;
    18→  };
    19→})();

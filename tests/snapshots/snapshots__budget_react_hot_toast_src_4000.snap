    58‚Üíinterface State {
    59‚Üí  [toasterId: string]: ToasterState;
    60‚Üí}
    62‚Üíexport const reducer = (state: ToasterState, action: Action): ToasterState => {
    63‚Üí  const { toastLimit } = state.settings;
    64‚Üí
    65‚Üí  switch (action.type) {
    66‚Üí    case ActionType.ADD_TOAST:
    67‚Üí      return {
    68‚Üí        ...state,
    69‚Üí        toasts: [action.toast, ...state.toasts].slice(0, toastLimit),
    70‚Üí      };
    71‚Üí
    72‚Üí    case ActionType.UPDATE_TOAST:
    73‚Üí      return {
    74‚Üí        ...state,
    75‚Üí        toasts: state.toasts.map((t) =>
    76‚Üí          t.id === action.toast.id ? { ...t, ...action.toast } : t
    77‚Üí        ),
    78‚Üí      };
    79‚Üí
    80‚Üí    case ActionType.UPSERT_TOAST:
    81‚Üí      const { toast } = action;
    82‚Üí      return reducer(state, {
    83‚Üí        type: state.toasts.find((t) => t.id === toast.id)
    84‚Üí          ? ActionType.UPDATE_TOAST
    85‚Üí          : ActionType.ADD_TOAST,
    86‚Üí        toast,
    87‚Üí      });
    88‚Üí
    89‚Üí    case ActionType.DISMISS_TOAST:
    90‚Üí      const { toastId } = action;
    91‚Üí
    92‚Üí      return {
    93‚Üí        ...state,
    94‚Üí        toasts: state.toasts.map((t) =>
    95‚Üí          t.id === toastId || toastId === undefined
    96‚Üí            ? {
    97‚Üí                ...t,
    98‚Üí                dismissed: true,
    99‚Üí                visible: false,
   100‚Üí              }
   101‚Üí            : t
   102‚Üí        ),
   103‚Üí      };
   104‚Üí    case ActionType.REMOVE_TOAST:
   105‚Üí      if (action.toastId === undefined) {
   106‚Üí        return {
   107‚Üí          ...state,
   108‚Üí          toasts: [],
   109‚Üí        };
   110‚Üí      }
   111‚Üí      return {
   112‚Üí        ...state,
   113‚Üí        toasts: state.toasts.filter((t) => t.id !== action.toastId),
   114‚Üí      };
   115‚Üí
   116‚Üí    case ActionType.START_PAUSE:
   117‚Üí      return {
   118‚Üí        ...state,
   119‚Üí        pausedAt: action.time,
   120‚Üí      };
   121‚Üí
   122‚Üí    case ActionType.END_PAUSE:
   123‚Üí      const diff = action.time - (state.pausedAt || 0);
   124‚Üí
   125‚Üí      return {
   126‚Üí        ...state,
   127‚Üí        pausedAt: undefined,
   128‚Üí        toasts: state.toasts.map((t) => ({
   129‚Üí          ...t,
   130‚Üí          pauseDuration: t.pauseDuration + diff,
   131‚Üí        })),
   132‚Üí      };
   133‚Üí  }
   134‚Üí};
   136‚Üíconst listeners: Array<
   137‚Üí  [toasterId: string, reducer: (state: ToasterState) => void]
   138‚Üí> = [];
   140‚Üíconst defaultToasterState: ToasterState = {
   141‚Üí  toasts: [],
   142‚Üí  pausedAt: undefined,
   143‚Üí  settings: {
   144‚Üí    toastLimit: TOAST_LIMIT,
   145‚Üí  },
   146‚Üí};
   149‚Üíexport const dispatch = (action: Action, toasterId = DEFAULT_TOASTER_ID) => {
   150‚Üí  memoryState[toasterId] = reducer(
   151‚Üí    memoryState[toasterId] || defaultToasterState,
   152‚Üí    action
   153‚Üí  );
   154‚Üí  listeners.forEach(([id, listener]) => {
   155‚Üí    if (id === toasterId) {
   156‚Üí      listener(memoryState[toasterId]);
   157‚Üí    }
   158‚Üí  });
   159‚Üí};
   161‚Üíexport const dispatchAll = (action: Action) =>
   162‚Üí  Object.keys(memoryState).forEach((toasterId) => dispatch(action, toasterId));
   164‚Üíexport const getToasterIdFromToastId = (toastId: string) =>
   165‚Üí  Object.keys(memoryState).find((toasterId) =>
   166‚Üí    memoryState[toasterId].toasts.some((t) => t.id === toastId)
   167‚Üí  );
   169‚Üíexport const createDispatch =
   170‚Üí  (toasterId = DEFAULT_TOASTER_ID) =>
   171‚Üí  (action: Action) => {
   172‚Üí    dispatch(action, toasterId);
   173‚Üí  };
   175‚Üíexport const defaultTimeouts: {
   176‚Üí  [key in ToastType]: number;
   177‚Üí} = {
   178‚Üí  blank: 4000,
   179‚Üí  error: 4000,
   180‚Üí  success: 2000,
   181‚Üí  loading: Infinity,
   182‚Üí  custom: 4000,
   183‚Üí};
   185‚Üíexport const useStore = (
   186‚Üí  toastOptions: DefaultToastOptions = {},
   187‚Üí  toasterId: string = DEFAULT_TOASTER_ID
   188‚Üí): ToasterState => {
   189‚Üí  const [state, setState] = useState<ToasterState>(
   190‚Üí    memoryState[toasterId] || defaultToasterState
   191‚Üí  );
   192‚Üí  const initial = useRef(memoryState[toasterId]);
   193‚Üí
   194‚Üí  // TODO: Switch to useSyncExternalStore when targeting React 18+
   195‚Üí  useEffect(() => {
   196‚Üí    if (initial.current !== memoryState[toasterId]) {
   197‚Üí      setState(memoryState[toasterId]);
   198‚Üí    }
   199‚Üí    listeners.push([toasterId, setState]);
   200‚Üí    return () => {
   201‚Üí      const index = listeners.findIndex(([id]) => id === toasterId);
   202‚Üí      if (index > -1) {
   203‚Üí        listeners.splice(index, 1);
   204‚Üí      }
   205‚Üí    };
   206‚Üí  }, [toasterId]);
   207‚Üí
   208‚Üí  const mergedToasts = state.toasts.map((t) => ({
   209‚Üí    ...toastOptions,
   210‚Üí    ...toastOptions[t.type],
   211‚Üí    ...t,
   212‚Üí    removeDelay:
   213‚Üí      t.removeDelay ||
   214‚Üí      toastOptions[t.type]?.removeDelay ||
   215‚Üí      toastOptions?.removeDelay,
   216‚Üí    duration:
   217‚Üí      t.duration ||
   218‚Üí      toastOptions[t.type]?.duration ||
   219‚Üí      toastOptions?.duration ||
   220‚Üí      defaultTimeouts[t.type],
   221‚Üí    style: {
   222‚Üí      ...toastOptions.style,
   223‚Üí      ...toastOptions[t.type]?.style,
   224‚Üí      ...t.style,
   225‚Üí    },
   226‚Üí  }));
   227‚Üí
   228‚Üí  return {
   229‚Üí    ...state,
   230‚Üí    toasts: mergedToasts,
   231‚Üí  };
   232‚Üí};

core/toast.ts
     1‚Üíimport {
     2‚Üí  Renderable,
     3‚Üí  Toast,
     4‚Üí  ToastOptions,
     5‚Üí  ToastType,
     6‚Üí  DefaultToastOptions,
     7‚Üí  ValueOrFunction,
     8‚Üí  resolveValue,
     9‚Üí} from './types';
    10‚Üíimport { genId } from './utils';
    11‚Üíimport {
    12‚Üí  createDispatch,
    13‚Üí  Action,
    14‚Üí  ActionType,
    15‚Üí  dispatchAll,
    16‚Üí  getToasterIdFromToastId,
    17‚Üí} from './store';
    19‚Üítype Message = ValueOrFunction<Renderable, Toast>;
    21‚Üítype ToastHandler = (message: Message, options?: ToastOptions) => string;
    23‚Üíconst createToast = (
    24‚Üí  message: Message,
    25‚Üí  type: ToastType = 'blank',
    26‚Üí  opts?: ToastOptions
    27‚Üí): Toast => ({
    28‚Üí  createdAt: Date.now(),
    29‚Üí  visible: true,
    30‚Üí  dismissed: false,
    31‚Üí  type,
    32‚Üí  ariaProps: {
    33‚Üí    role: 'status',
    34‚Üí    'aria-live': 'polite',
    35‚Üí  },
    36‚Üí  message,
    37‚Üí  pauseDuration: 0,
    38‚Üí  ...opts,
    39‚Üí  id: opts?.id || genId(),
    40‚Üí});
    42‚Üíconst createHandler =
    43‚Üí  (type?: ToastType): ToastHandler =>
    44‚Üí  (message, options) => {
    45‚Üí    const toast = createToast(message, type, options);
    46‚Üí
    47‚Üí    const dispatch = createDispatch(
    48‚Üí      toast.toasterId || getToasterIdFromToastId(toast.id)
    49‚Üí    );
    50‚Üí
    51‚Üí    dispatch({ type: ActionType.UPSERT_TOAST, toast });
    52‚Üí    return toast.id;
    53‚Üí  };
    55‚Üíconst toast = (message: Message, opts?: ToastOptions) =>
    56‚Üí  createHandler('blank')(message, opts);

core/types.ts
     1‚Üíimport { CSSProperties } from 'react';
     3‚Üíexport type ToastType = 'success' | 'error' | 'loading' | 'blank' | 'custom';
     4‚Üíexport type ToastPosition =
     5‚Üí  | 'top-left'
     6‚Üí  | 'top-center'
     7‚Üí  | 'top-right'
     8‚Üí  | 'bottom-left'
     9‚Üí  | 'bottom-center'
    10‚Üí  | 'bottom-right';
    12‚Üíexport type Renderable = React.ReactElement | string | null;
    14‚Üíexport interface IconTheme {
    15‚Üí  primary: string;
    16‚Üí  secondary: string;
    17‚Üí}
    19‚Üíexport type ValueFunction<TValue, TArg> = (arg: TArg) => TValue;
    20‚Üíexport type ValueOrFunction<TValue, TArg> =
    21‚Üí  | TValue
    22‚Üí  | ValueFunction<TValue, TArg>;
    24‚Üíconst isFunction = <TValue, TArg>(
    25‚Üí  valOrFunction: ValueOrFunction<TValue, TArg>
    26‚Üí): valOrFunction is ValueFunction<TValue, TArg> =>
    27‚Üí  typeof valOrFunction === 'function';
    29‚Üíexport const resolveValue = <TValue, TArg>(
    30‚Üí  valOrFunction: ValueOrFunction<TValue, TArg>,
    31‚Üí  arg: TArg
    32‚Üí): TValue => (isFunction(valOrFunction) ? valOrFunction(arg) : valOrFunction);
    34‚Üíexport interface Toast {
    35‚Üí  type: ToastType;
    36‚Üí  id: string;
    37‚Üí  toasterId?: string;
    38‚Üí  message: ValueOrFunction<Renderable, Toast>;
    39‚Üí  icon?: Renderable;
    40‚Üí  duration?: number;
    41‚Üí  pauseDuration: number;
    42‚Üí  position?: ToastPosition;
    43‚Üí  removeDelay?: number;
    44‚Üí
    45‚Üí  ariaProps: {
    46‚Üí    role: 'status' | 'alert';
    47‚Üí    'aria-live': 'assertive' | 'off' | 'polite';
    48‚Üí  };
    49‚Üí
    50‚Üí  style?: CSSProperties;
    51‚Üí  className?: string;
    52‚Üí  iconTheme?: IconTheme;
    53‚Üí
    54‚Üí  createdAt: number;
    55‚Üí  visible: boolean;
    56‚Üí  dismissed: boolean;
    57‚Üí  height?: number;
    58‚Üí}
    60‚Üíexport type ToastOptions = Partial<
    61‚Üí  Pick<
    62‚Üí    Toast,
    63‚Üí    | 'id'
    64‚Üí    | 'icon'
    65‚Üí    | 'duration'
    66‚Üí    | 'ariaProps'
    67‚Üí    | 'className'
    68‚Üí    | 'style'
    69‚Üí    | 'position'
    70‚Üí    | 'iconTheme'
    71‚Üí    | 'toasterId'
    72‚Üí    | 'removeDelay'
    73‚Üí  >
    74‚Üí>;
    76‚Üíexport type DefaultToastOptions = ToastOptions & {
    77‚Üí  [key in ToastType]?: ToastOptions;
    78‚Üí};
    80‚Üíexport interface ToasterProps {
    81‚Üí  position?: ToastPosition;
    82‚Üí  toastOptions?: DefaultToastOptions;
    83‚Üí  reverseOrder?: boolean;
    84‚Üí  gutter?: number;
    85‚Üí  containerStyle?: React.CSSProperties;
    86‚Üí  containerClassName?: string;
    87‚Üí  toasterId?: string;
    88‚Üí  children?: (toast: Toast) => React.ReactElement;
    89‚Üí}
    91‚Üíexport interface ToastWrapperProps {
    92‚Üí  id: string;
    93‚Üí  className?: string;
    94‚Üí  style?: React.CSSProperties;
    95‚Üí  onHeightUpdate: (id: string, height: number) => void;
    96‚Üí  children?: React.ReactNode;
    97‚Üí}

core/use-toaster.ts
     1‚Üíimport { useEffect, useCallback, useRef } from 'react';
     2‚Üíimport { createDispatch, ActionType, useStore, dispatch } from './store';
     3‚Üíimport { toast } from './toast';
     4‚Üíimport { DefaultToastOptions, Toast, ToastPosition } from './types';
     6‚Üíexport const REMOVE_DELAY = 1000;
     8‚Üíexport const useToaster = (
     9‚Üí  toastOptions?: DefaultToastOptions,
    10‚Üí  toasterId: string = 'default'
    11‚Üí) => {
    12‚Üí  const { toasts, pausedAt } = useStore(toastOptions, toasterId);
    13‚Üí  const toastTimeouts = useRef(
    14‚Üí    new Map<Toast['id'], ReturnType<typeof setTimeout>>()
    15‚Üí  ).current;
    16‚Üí
    17‚Üí  const addToRemoveQueue = useCallback(
    18‚Üí    (toastId: string, removeDelay = REMOVE_DELAY) => {
    19‚Üí      if (toastTimeouts.has(toastId)) {
    20‚Üí        return;
    21‚Üí      }
    22‚Üí
    23‚Üí      const timeout = setTimeout(() => {
    24‚Üí        toastTimeouts.delete(toastId);
    25‚Üí        dispatch({
    26‚Üí          type: ActionType.REMOVE_TOAST,
    27‚Üí          toastId: toastId,
    28‚Üí        });
    29‚Üí      }, removeDelay);
    30‚Üí
    31‚Üí      toastTimeouts.set(toastId, timeout);
    32‚Üí    },
    33‚Üí    []
    34‚Üí  );
    35‚Üí
    36‚Üí  useEffect(() => {
    37‚Üí    if (pausedAt) {
    38‚Üí      return;
    39‚Üí    }
    40‚Üí
    41‚Üí    const now = Date.now();
    42‚Üí    const timeouts = toasts.map((t) => {
    43‚Üí      if (t.duration === Infinity) {
    44‚Üí        return;
    45‚Üí      }
    46‚Üí
    47‚Üí      const durationLeft =
    48‚Üí        (t.duration || 0) + t.pauseDuration - (now - t.createdAt);
    49‚Üí
    50‚Üí      if (durationLeft < 0) {
    51‚Üí        if (t.visible) {
    52‚Üí          toast.dismiss(t.id);
    53‚Üí        }
    54‚Üí        return;
    55‚Üí      }
    56‚Üí      return setTimeout(() => toast.dismiss(t.id, toasterId), durationLeft);
    57‚Üí    });
    58‚Üí
    59‚Üí    return () => {
    60‚Üí      timeouts.forEach((timeout) => timeout && clearTimeout(timeout));
    61‚Üí    };
    62‚Üí  }, [toasts, pausedAt, toasterId]);
    63‚Üí
    64‚Üí  const dispatch = useCallback(createDispatch(toasterId), [toasterId]);
    65‚Üí
    66‚Üí  const startPause = useCallback(() => {
    67‚Üí    dispatch({
    68‚Üí      type: ActionType.START_PAUSE,
    69‚Üí      time: Date.now(),
    70‚Üí    });
    71‚Üí  }, [dispatch]);
    72‚Üí
    73‚Üí  const updateHeight = useCallback(
    74‚Üí    (toastId: string, height: number) => {
    75‚Üí      dispatch({
    76‚Üí        type: ActionType.UPDATE_TOAST,
    77‚Üí        toast: { id: toastId, height },
    78‚Üí      });
    79‚Üí    },
    80‚Üí    [dispatch]
    81‚Üí  );
    82‚Üí
    83‚Üí  const endPause = useCallback(() => {
    84‚Üí    if (pausedAt) {
    85‚Üí      dispatch({ type: ActionType.END_PAUSE, time: Date.now() });
    86‚Üí    }
    87‚Üí  }, [pausedAt, dispatch]);
    88‚Üí
    89‚Üí  const calculateOffset = useCallback(
    90‚Üí    (
    91‚Üí      toast: Toast,
    92‚Üí      opts?: {
    93‚Üí        reverseOrder?: boolean;
    94‚Üí        gutter?: number;
    95‚Üí        defaultPosition?: ToastPosition;
    96‚Üí      }
    97‚Üí    ) => {
    98‚Üí      const { reverseOrder = false, gutter = 8, defaultPosition } = opts || {};
    99‚Üí
   100‚Üí      const relevantToasts = toasts.filter(
   101‚Üí        (t) =>
   102‚Üí          (t.position || defaultPosition) ===
   103‚Üí            (toast.position || defaultPosition) && t.height
   104‚Üí      );
   105‚Üí      const toastIndex = relevantToasts.findIndex((t) => t.id === toast.id);
   106‚Üí      const toastsBefore = relevantToasts.filter(
   107‚Üí        (toast, i) => i < toastIndex && toast.visible
   108‚Üí      ).length;
   109‚Üí
   110‚Üí      const offset = relevantToasts
   111‚Üí        .filter((t) => t.visible)
   112‚Üí        .slice(...(reverseOrder ? [toastsBefore + 1] : [0, toastsBefore]))
   113‚Üí        .reduce((acc, t) => acc + (t.height || 0) + gutter, 0);
   114‚Üí
   115‚Üí      return offset;
   116‚Üí    },
   117‚Üí    [toasts]
   118‚Üí  );
   119‚Üí
   120‚Üí  // Keep track of dismissed toasts and remove them after the delay
   121‚Üí  useEffect(() => {
   122‚Üí    toasts.forEach((toast) => {
   123‚Üí      if (toast.dismissed) {
   124‚Üí        addToRemoveQueue(toast.id, toast.removeDelay);
   125‚Üí      } else {
   126‚Üí        // If toast becomes visible again, remove it from the queue
   127‚Üí        const timeout = toastTimeouts.get(toast.id);
   128‚Üí        if (timeout) {
   129‚Üí          clearTimeout(timeout);
   130‚Üí          toastTimeouts.delete(toast.id);
   131‚Üí        }
   132‚Üí      }
   133‚Üí    });
   134‚Üí  }, [toasts, addToRemoveQueue]);
   135‚Üí
   136‚Üí  return {
   137‚Üí    toasts,
   138‚Üí    handlers: {
   139‚Üí      updateHeight,
   140‚Üí      startPause,
   141‚Üí      endPause,
   142‚Üí      calculateOffset,
   143‚Üí    },
   144‚Üí  };
   145‚Üí};

core/utils.ts
     1‚Üíexport const genId = (() => {
     2‚Üí  let count = 0;
     3‚Üí  return () => {
     4‚Üí    return (++count).toString();
     5‚Üí  };
     6‚Üí})();
     8‚Üíexport const prefersReducedMotion = (() => {
     9‚Üí  // Cache result
    10‚Üí  let shouldReduceMotion: boolean | undefined = undefined;
    11‚Üí
    12‚Üí  return () => {
    13‚Üí    if (shouldReduceMotion === undefined && typeof window !== 'undefined') {
    14‚Üí      const mediaQuery = matchMedia('(prefers-reduced-motion: reduce)');
    15‚Üí      shouldReduceMotion = !mediaQuery || mediaQuery.matches;
    16‚Üí    }
    17‚Üí    return shouldReduceMotion;
    18‚Üí  };
    19‚Üí})();


     1‚Üíimport * as React from 'react';
     2‚Üíimport { styled, keyframes } from 'goober';
     4‚Üíimport { Toast, ToastPosition, resolveValue, Renderable } from '../core/types';
     5‚Üíimport { ToastIcon } from './toast-icon';
     6‚Üíimport { prefersReducedMotion } from '../core/utils';
     8‚Üíconst enterAnimation = (factor: number) => `
     9‚Üí0% {transform: translate3d(0,${factor * -200}%,0) scale(.6); opacity:.5;}
    10‚Üí100% {transform: translate3d(0,0,0) scale(1); opacity:1;}
    11‚Üí`;
    13‚Üíconst exitAnimation = (factor: number) => `
    14‚Üí0% {transform: translate3d(0,0,-1px) scale(1); opacity:1;}
    15‚Üí100% {transform: translate3d(0,${factor * -150}%,-1px) scale(.6); opacity:0;}
    16‚Üí`;
    18‚Üíconst fadeInAnimation = `0%{opacity:0;} 100%{opacity:1;}`;
    19‚Üíconst fadeOutAnimation = `0%{opacity:1;} 100%{opacity:0;}`;
    22‚Üíconst ToastBarBase = styled('div')`
    23‚Üí  :where(&) {
    24‚Üí    display: flex;
    25‚Üí    align-items: center;
    26‚Üí    background: #fff;
    27‚Üí    color: #363636;
    28‚Üí    line-height: 1.3;
    29‚Üí    will-change: transform;
    30‚Üí    box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1), 0 3px 3px rgba(0, 0, 0, 0.05);
    31‚Üí    max-width: 350px;
    32‚Üí    pointer-events: auto;
    33‚Üí    padding: 8px 10px;
    34‚Üí    border-radius: 8px;
    35‚Üí  }
    36‚Üí`;
    38‚Üíconst Message = styled('div')`
    39‚Üí  display: flex;
    40‚Üí  justify-content: center;
    41‚Üí  margin: 4px 10px;
    42‚Üí  color: inherit;
    43‚Üí  flex: 1 1 auto;
    44‚Üí  white-space: pre-line;
    45‚Üí`;
    47‚Üíinterface ToastBarProps {
    48‚Üí  toast: Toast;
    49‚Üí  position?: ToastPosition;
    50‚Üí  style?: React.CSSProperties;
    51‚Üí  children?: (components: {
    52‚Üí    icon: Renderable;
    53‚Üí    message: Renderable;
    54‚Üí  }) => Renderable;
    55‚Üí}
    57‚Üíconst getAnimationStyle = (
    58‚Üí  position: ToastPosition,
    59‚Üí  visible: boolean
    60‚Üí): React.CSSProperties => {
    61‚Üí  const top = position.includes('top');
    62‚Üí  const factor = top ? 1 : -1;
    63‚Üí
    64‚Üí  const [enter, exit] = prefersReducedMotion()
    65‚Üí    ? [fadeInAnimation, fadeOutAnimation]
    66‚Üí    : [enterAnimation(factor), exitAnimation(factor)];
    67‚Üí
    68‚Üí  return {
    69‚Üí    animation: visible
    70‚Üí      ? `${keyframes(enter)} 0.35s cubic-bezier(.21,1.02,.73,1) forwards`
    71‚Üí      : `${keyframes(exit)} 0.4s forwards cubic-bezier(.06,.71,.55,1)`,
    72‚Üí  };
    73‚Üí};
    75‚Üíexport const ToastBar: React.FC<ToastBarProps> = React.memo(
    76‚Üí  ({ toast, position, style, children }) => {
    77‚Üí    const animationStyle: React.CSSProperties = toast.height
    78‚Üí      ? getAnimationStyle(
    79‚Üí          toast.position || position || 'top-center',
    80‚Üí          toast.visible
    81‚Üí        )
    82‚Üí      : { opacity: 0 };
    83‚Üí
    84‚Üí    const icon = <ToastIcon toast={toast} />;
    85‚Üí    const message = (
    86‚Üí      <Message {...toast.ariaProps}>
    87‚Üí        {resolveValue(toast.message, toast)}
    88‚Üí      </Message>
    89‚Üí    );
    90‚Üí
    91‚Üí    return (
    92‚Üí      <ToastBarBase
    93‚Üí        className={toast.className}
    94‚Üí        style={{
    95‚Üí          ...animationStyle,
    96‚Üí          ...style,
    97‚Üí          ...toast.style,
    98‚Üí        }}
    99‚Üí      >
   100‚Üí        {typeof children === 'function' ? (
   101‚Üí          children({
   102‚Üí            icon,
   103‚Üí            message,
   104‚Üí          })
   105‚Üí        ) : (
   106‚Üí          <>
   107‚Üí            {icon}
   108‚Üí            {message}
   109‚Üí          </>
   110‚Üí        )}
   111‚Üí      </ToastBarBase>
   112‚Üí    );
   113‚Üí  }
   114‚Üí);


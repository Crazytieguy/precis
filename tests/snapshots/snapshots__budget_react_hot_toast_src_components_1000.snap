    47‚Üíexport const ToastIcon: React.FC<{
    48‚Üí  toast: Toast;
    49‚Üí}> = ({ toast }) => {
    50‚Üí  const { icon, type, iconTheme } = toast;
    51‚Üí  if (icon !== undefined) {
    52‚Üí    if (typeof icon === 'string') {
    53‚Üí      return <AnimatedIconWrapper>{icon}</AnimatedIconWrapper>;
    54‚Üí    } else {
    55‚Üí      return icon;
    56‚Üí    }
    57‚Üí  }
    58‚Üí
    59‚Üí  if (type === 'blank') {
    60‚Üí    return null;
    61‚Üí  }
    62‚Üí
    63‚Üí  return (
    64‚Üí    <IndicatorWrapper>
    65‚Üí      <LoaderIcon {...iconTheme} />
    66‚Üí      {type !== 'loading' && (
    67‚Üí        <StatusWrapper>
    68‚Üí          {type === 'error' ? (
    69‚Üí            <ErrorIcon {...iconTheme} />
    70‚Üí          ) : (
    71‚Üí            <CheckmarkIcon {...iconTheme} />
    72‚Üí          )}
    73‚Üí        </StatusWrapper>
    74‚Üí      )}
    75‚Üí    </IndicatorWrapper>
    76‚Üí  );
    77‚Üí};

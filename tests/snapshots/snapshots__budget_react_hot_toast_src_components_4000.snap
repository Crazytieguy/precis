    70тЖТ    transform: `translateY(${offset * (top ? 1 : -1)}px)`,
    71тЖТ    ...verticalStyle,
    72тЖТ    ...horizontalStyle,
    73тЖТ  };
    74тЖТ};
    76тЖТconst activeClass = css`

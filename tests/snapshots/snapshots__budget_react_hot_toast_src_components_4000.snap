    15тЖТconst ToastWrapper = ({
    16тЖТ  id,
    17тЖТ  className,
    18тЖТ  style,
    19тЖТ  onHeightUpdate,
    20тЖТ  children,
    21тЖТ}: ToastWrapperProps) => {
    22тЖТ  const ref = React.useCallback(
    23тЖТ    (el: HTMLElement | null) => {
    24тЖТ      if (el) {
    25тЖТ        const updateHeight = () => {
    26тЖТ          const height = el.getBoundingClientRect().height;
    27тЖТ          onHeightUpdate(id, height);
    28тЖТ        };
    29тЖТ        updateHeight();
    30тЖТ        new MutationObserver(updateHeight).observe(el, {
    31тЖТ          subtree: true,
    32тЖТ          childList: true,
    33тЖТ          characterData: true,
    34тЖТ        });
    35тЖТ      }
    36тЖТ    },
    37тЖТ    [id, onHeightUpdate]
    38тЖТ  );
    39тЖТ
    40тЖТ  return (
    41тЖТ    <div ref={ref} className={className} style={style}>

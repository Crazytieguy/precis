    19→const LETTERDASHNUMBER = '[a-zA-Z0-9-]'
    27→const safeRegexReplacements = [
    28→  ['\\s', 1],
    29→  ['\\d', MAX_LENGTH],
    30→  [LETTERDASHNUMBER, MAX_SAFE_BUILD_LENGTH],

bin/semver.js
     8â†’const argv = process.argv.slice(2)
    12â†’const range = []
    37â†’const main = () => {
    38â†’  if (!argv.length) {
    39â†’    return help()
    40â†’  }
    41â†’  while (argv.length) {
    42â†’    let a = argv.shift()
    43â†’    const indexOfEqualSign = a.indexOf('=')
    44â†’    if (indexOfEqualSign !== -1) {
    45â†’      const value = a.slice(indexOfEqualSign + 1)
    46â†’      a = a.slice(0, indexOfEqualSign)
    47â†’      argv.unshift(value)
    48â†’    }
    49â†’    switch (a) {
    50â†’      case '-rv': case '-rev': case '--rev': case '--reverse':
    51â†’        reverse = true
    52â†’        break
    53â†’      case '-l': case '--loose':
    54â†’        loose = true
    55â†’        break
    56â†’      case '-p': case '--include-prerelease':
   132â†’const failInc = () => {
   133â†’  console.error('--inc can only be used on a single version with no range')
   134â†’  fail()
   135â†’}
   137â†’const fail = () => process.exit(1)
   139â†’const help = () => console.log(
   140â†’`SemVer ${version}
   141â†’
   142â†’A JavaScript implementation of the https://semver.org/ specification
   143â†’Copyright Isaac Z. Schlueter
   144â†’
   145â†’Usage: semver [options] <version> [<version> [...]]
   146â†’Prints valid versions sorted by SemVer precedence
   147â†’
   148â†’Options:
   149â†’-r --range <range>
   150â†’        Print versions that match the specified range.
   151â†’
   152â†’-i --increment [<level>]
   153â†’        Increment a version by the specified level.  Level can
   154â†’        be one of: major, minor, patch, premajor, preminor,
   155â†’        prepatch, prerelease, or release.  Default level is 'patch'.
   156â†’        Only one version may be specified.
   157â†’
   158â†’--preid <identifier>
classes/comparator.js
     3â†’const ANY = Symbol('SemVer ANY')
     5â†’class Comparator {
     6â†’  static get ANY () {
     7â†’    return ANY
     8â†’  }
     9â†’
    10â†’  constructor (comp, options) {
    11â†’    options = parseOptions(options)
    12â†’
    13â†’    if (comp instanceof Comparator) {
    14â†’      if (comp.loose === !!options.loose) {
    15â†’        return comp
    16â†’      } else {
    17â†’        comp = comp.value
    18â†’      }
    19â†’    }
    20â†’
    21â†’    comp = comp.trim().split(/\s+/).join(' ')
    22â†’    debug('comparator', comp, options)
    23â†’    this.options = options
    24â†’    this.loose = !!options.loose
    25â†’    this.parse(comp)
    26â†’
    27â†’    if (this.semver === ANY) {
    28â†’      this.value = ''
    29â†’    } else {
    30â†’      this.value = this.operator + this.semver.version
    31â†’    }
    32â†’
    33â†’    debug('comp', this)
    34â†’  }

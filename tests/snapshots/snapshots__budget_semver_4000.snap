     7â†’  }
     8â†’
     9â†’  get (key) {
    10â†’    const value = this.map.get(key)
    11â†’    if (value === undefined) {
    12â†’      return undefined
    13â†’    } else {
    14â†’      // Remove the key from the map and add it to the end
    15â†’      this.map.delete(key)
    16â†’      this.map.set(key, value)
    17â†’      return value
    18â†’    }
    19â†’  }
    20â†’
    21â†’  delete (key) {
    22â†’    return this.map.delete(key)
    23â†’  }
    24â†’
    25â†’  set (key, value) {
    26â†’    const deleted = this.delete(key)
    27â†’
    28â†’    if (!deleted && value !== undefined) {
    29â†’      // If cache is full, delete the least recently used item
    30â†’      if (this.map.size >= this.max) {
    31â†’        const firstKey = this.map.keys().next().value
    32â†’        this.delete(firstKey)
    33â†’      }
    34â†’
    35â†’      this.map.set(key, value)
    36â†’    }
    37â†’
    38â†’    return this
    39â†’  }
    40â†’}

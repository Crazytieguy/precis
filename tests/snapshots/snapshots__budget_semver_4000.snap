     3вҶ’class LRUCache {
     4вҶ’  constructor () {
     5вҶ’    this.max = 1000
     6вҶ’    this.map = new Map()
     7вҶ’  }
     9вҶ’  get (key) {
    10вҶ’    const value = this.map.get(key)
    11вҶ’    if (value === undefined) {
    12вҶ’      return undefined
    13вҶ’    } else {
    14вҶ’      // Remove the key from the map and add it to the end
    15вҶ’      this.map.delete(key)
    16вҶ’      this.map.set(key, value)
    17вҶ’      return value
    18вҶ’    }
    19вҶ’  }
    21вҶ’  delete (key) {
    22вҶ’    return this.map.delete(key)
    23вҶ’  }
    25вҶ’  set (key, value) {
    26вҶ’    const deleted = this.delete(key)
    27вҶ’
    28вҶ’    if (!deleted && value !== undefined) {
    29вҶ’      // If cache is full, delete the least recently used item
    30вҶ’      if (this.map.size >= this.max) {
    31вҶ’        const firstKey = this.map.keys().next().value
    32вҶ’        this.delete(firstKey)
    33вҶ’      }
    34вҶ’
    35вҶ’      this.map.set(key, value)
    36вҶ’    }
    37вҶ’
    38вҶ’    return this
    39вҶ’  }


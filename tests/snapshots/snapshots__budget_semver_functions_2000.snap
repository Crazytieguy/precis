compare-build.js
     4→const compareBuild = (a, b, loose) => {
     5→  const versionA = new SemVer(a, loose)
     6→  const versionB = new SemVer(b, loose)
     7→  return versionA.compare(versionB) || versionA.compareBuild(versionB)
     8→}

compare-loose.js

identifiers.js
     1‚Üí'use strict'
     2‚Üí
     3‚Üíconst numeric = /^[0-9]+$/
     4‚Üíconst compareIdentifiers = (a, b) => {
     5‚Üí  if (typeof a === 'number' && typeof b === 'number') {
     6‚Üí    return a === b ? 0 : a < b ? -1 : 1
     7‚Üí  }
     8‚Üí
     9‚Üí  const anum = numeric.test(a)
    10‚Üí  const bnum = numeric.test(b)
    11‚Üí
    12‚Üí  if (anum && bnum) {
    13‚Üí    a = +a
    14‚Üí    b = +b
    15‚Üí  }
    16‚Üí
    17‚Üí  return a === b ? 0
    18‚Üí    : (anum && !bnum) ? -1
    19‚Üí    : (bnum && !anum) ? 1
    20‚Üí    : a < b ? -1
    21‚Üí    : 1
    22‚Üí}
    23‚Üí
    24‚Üíconst rcompareIdentifiers = (a, b) => compareIdentifiers(b, a)
    25‚Üí
    26‚Üímodule.exports = {
    27‚Üí  compareIdentifiers,
    28‚Üí  rcompareIdentifiers,
    29‚Üí}
lrucache.js
     1‚Üí'use strict'
     2‚Üí
     3‚Üíclass LRUCache {
     4‚Üí  constructor () {
     5‚Üí    this.max = 1000
     6‚Üí    this.map = new Map()
     7‚Üí  }
     8‚Üí
     9‚Üí  get (key) {
    10‚Üí    const value = this.map.get(key)
    11‚Üí    if (value === undefined) {
    12‚Üí      return undefined
    13‚Üí    } else {
    14‚Üí      // Remove the key from the map and add it to the end
    15‚Üí      this.map.delete(key)
    16‚Üí      this.map.set(key, value)
    17‚Üí      return value
    18‚Üí    }
    19‚Üí  }
    20‚Üí
    21‚Üí  delete (key) {
    22‚Üí    return this.map.delete(key)
    23‚Üí  }
    24‚Üí
    25‚Üí  set (key, value) {
    26‚Üí    const deleted = this.delete(key)
    27‚Üí
    28‚Üí    if (!deleted && value !== undefined) {
    29‚Üí      // If cache is full, delete the least recently used item
    30‚Üí      if (this.map.size >= this.max) {
    31‚Üí        const firstKey = this.map.keys().next().value
    32‚Üí        this.delete(firstKey)
    33‚Üí      }
    34‚Üí
    35‚Üí      this.map.set(key, value)
    36‚Üí    }
    37‚Üí
    38‚Üí    return this
    39‚Üí  }
    40‚Üí}
    41‚Üí
    42‚Üímodule.exports = LRUCache
parse-options.js
     1‚Üí'use strict'
     2‚Üí
     3‚Üí// parse out just the options we care about
     4‚Üíconst looseOption = Object.freeze({ loose: true })
     5‚Üíconst emptyOpts = Object.freeze({ })
     6‚Üíconst parseOptions = options => {
     7‚Üí  if (!options) {
     8‚Üí    return emptyOpts
     9‚Üí  }
    10‚Üí
    11‚Üí  if (typeof options !== 'object') {
    12‚Üí    return looseOption
    13‚Üí  }
    14‚Üí
    15‚Üí  return options
    16‚Üí}
    17‚Üímodule.exports = parseOptions
re.js
     1‚Üí'use strict'
     2‚Üí
     3‚Üíconst {
     4‚Üí  MAX_SAFE_COMPONENT_LENGTH,
     5‚Üí  MAX_SAFE_BUILD_LENGTH,
     6‚Üí  MAX_LENGTH,
     7‚Üí} = require('./constants')
     8‚Üíconst debug = require('./debug')
     9‚Üíexports = module.exports = {}
    10‚Üí
    11‚Üí// The actual regexps go on exports.re
    12‚Üíconst re = exports.re = []
    13‚Üíconst safeRe = exports.safeRe = []
    14‚Üíconst src = exports.src = []
    15‚Üíconst safeSrc = exports.safeSrc = []
    16‚Üíconst t = exports.t = {}
    17‚Üílet R = 0
    18‚Üí
    19‚Üíconst LETTERDASHNUMBER = '[a-zA-Z0-9-]'
    20‚Üí
    21‚Üí// Replace some greedy regex tokens to prevent regex dos issues. These regex are
    22‚Üí// used internally via the safeRe object since all inputs in this library get
    23‚Üí// normalized first to trim and collapse all extra whitespace. The original
    24‚Üí// regexes are exported for userland consumption and lower level usage. A
    25‚Üí// future breaking change could export the safer regex only with a note that
    26‚Üí// all input should have extra whitespace removed.
    27‚Üíconst safeRegexReplacements = [
    28‚Üí  ['\\s', 1],
    29‚Üí  ['\\d', MAX_LENGTH],
    30‚Üí  [LETTERDASHNUMBER, MAX_SAFE_BUILD_LENGTH],
    31‚Üí]
    32‚Üí
    33‚Üíconst makeSafeRegex = (value) => {
    34‚Üí  for (const [token, max] of safeRegexReplacements) {
    35‚Üí    value = value
    36‚Üí      .split(`${token}*`).join(`${token}{0,${max}}`)
    37‚Üí      .split(`${token}+`).join(`${token}{1,${max}}`)
    38‚Üí  }
    39‚Üí  return value
    40‚Üí}
    41‚Üí
    42‚Üíconst createToken = (name, value, isGlobal) => {
    43‚Üí  const safe = makeSafeRegex(value)
    44‚Üí  const index = R++
    45‚Üí  debug(name, index, value)
    46‚Üí  t[name] = index
    47‚Üí  src[index] = value
    48‚Üí  safeSrc[index] = safe
    49‚Üí  re[index] = new RegExp(value, isGlobal ? 'g' : undefined)
    50‚Üí  safeRe[index] = new RegExp(safe, isGlobal ? 'g' : undefined)
    51‚Üí}
    52‚Üí
    53‚Üí// The following Regular Expressions can be used for tokenizing,
    54‚Üí// validating, and parsing SemVer version strings.
    55‚Üí
    56‚Üí// ## Numeric Identifier
    57‚Üí// A single `0`, or a non-zero digit followed by zero or more digits.
    58‚Üí
    59‚ÜícreateToken('NUMERICIDENTIFIER', '0|[1-9]\\d*')
    60‚ÜícreateToken('NUMERICIDENTIFIERLOOSE', '\\d+')
    61‚Üí
    62‚Üí// ## Non-numeric Identifier
    63‚Üí// Zero or more digits, followed by a letter or hyphen, and then zero or
    64‚Üí// more letters, digits, or hyphens.
    65‚Üí
    66‚ÜícreateToken('NONNUMERICIDENTIFIER', `\\d*[a-zA-Z-]${LETTERDASHNUMBER}*`)
    67‚Üí
    68‚Üí// ## Main Version
    69‚Üí// Three dot-separated numeric identifiers.
    70‚Üí
    71‚ÜícreateToken('MAINVERSION', `(${src[t.NUMERICIDENTIFIER]})\\.` +
    72‚Üí                   `(${src[t.NUMERICIDENTIFIER]})\\.` +
    73‚Üí                   `(${src[t.NUMERICIDENTIFIER]})`)
    74‚Üí
    75‚ÜícreateToken('MAINVERSIONLOOSE', `(${src[t.NUMERICIDENTIFIERLOOSE]})\\.` +
    76‚Üí                        `(${src[t.NUMERICIDENTIFIERLOOSE]})\\.` +
    77‚Üí                        `(${src[t.NUMERICIDENTIFIERLOOSE]})`)
    78‚Üí
    79‚Üí// ## Pre-release Version Identifier
    80‚Üí// A numeric identifier, or a non-numeric identifier.
    81‚Üí// Non-numeric identifiers include numeric identifiers but can be longer.
    82‚Üí// Therefore non-numeric identifiers must go first.
    83‚Üí
    84‚ÜícreateToken('PRERELEASEIDENTIFIER', `(?:${src[t.NONNUMERICIDENTIFIER]
    85‚Üí}|${src[t.NUMERICIDENTIFIER]})`)
    86‚Üí
    87‚ÜícreateToken('PRERELEASEIDENTIFIERLOOSE', `(?:${src[t.NONNUMERICIDENTIFIER]
    88‚Üí}|${src[t.NUMERICIDENTIFIERLOOSE]})`)
    89‚Üí
    90‚Üí// ## Pre-release Version
    91‚Üí// Hyphen, followed by one or more dot-separated pre-release version
    92‚Üí// identifiers.
    93‚Üí
    94‚ÜícreateToken('PRERELEASE', `(?:-(${src[t.PRERELEASEIDENTIFIER]
    95‚Üí}(?:\\.${src[t.PRERELEASEIDENTIFIER]})*))`)
    96‚Üí
    97‚ÜícreateToken('PRERELEASELOOSE', `(?:-?(${src[t.PRERELEASEIDENTIFIERLOOSE]
    98‚Üí}(?:\\.${src[t.PRERELEASEIDENTIFIERLOOSE]})*))`)
    99‚Üí
   100‚Üí// ## Build Metadata Identifier
   101‚Üí// Any combination of digits, letters, or hyphens.
   102‚Üí
   103‚ÜícreateToken('BUILDIDENTIFIER', `${LETTERDASHNUMBER}+`)
   104‚Üí
   105‚Üí// ## Build Metadata
   106‚Üí// Plus sign, followed by one or more period-separated build metadata
   107‚Üí// identifiers.
   108‚Üí
   109‚ÜícreateToken('BUILD', `(?:\\+(${src[t.BUILDIDENTIFIER]
   110‚Üí}(?:\\.${src[t.BUILDIDENTIFIER]})*))`)
   111‚Üí
   112‚Üí// ## Full Version String
   113‚Üí// A main version, followed optionally by a pre-release version and
   114‚Üí// build metadata.
   115‚Üí
   116‚Üí// Note that the only major, minor, patch, and pre-release sections of
   117‚Üí// the version string are capturing groups.  The build metadata is not a
   118‚Üí// capturing group, because it should not ever be used in version
   119‚Üí// comparison.
   120‚Üí
   121‚ÜícreateToken('FULLPLAIN', `v?${src[t.MAINVERSION]
   122‚Üí}${src[t.PRERELEASE]}?${
   123‚Üí  src[t.BUILD]}?`)
   124‚Üí
   125‚ÜícreateToken('FULL', `^${src[t.FULLPLAIN]}$`)
   126‚Üí
   127‚Üí// like full, but allows v1.2.3 and =1.2.3, which people do sometimes.
   128‚Üí// also, 1.0.0alpha1 (prerelease without the hyphen) which is pretty
   129‚Üí// common in the npm registry.
   130‚ÜícreateToken('LOOSEPLAIN', `[v=\\s]*${src[t.MAINVERSIONLOOSE]
   131‚Üí}${src[t.PRERELEASELOOSE]}?${
   132‚Üí  src[t.BUILD]}?`)
   133‚Üí
   134‚ÜícreateToken('LOOSE', `^${src[t.LOOSEPLAIN]}$`)
   135‚Üí
   136‚ÜícreateToken('GTLT', '((?:<|>)?=?)')
   137‚Üí
   138‚Üí// Something like "2.*" or "1.2.x".

   157‚Üí
   158‚ÜícreateToken('XRANGE', `^${src[t.GTLT]}\\s*${src[t.XRANGEPLAIN]}$`)
   159‚ÜícreateToken('XRANGELOOSE', `^${src[t.GTLT]}\\s*${src[t.XRANGEPLAINLOOSE]}$`)
   160‚Üí
   161‚Üí// Coercion.

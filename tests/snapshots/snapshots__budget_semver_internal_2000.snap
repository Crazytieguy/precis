   150‚Üí
   151‚ÜícreateToken('XRANGEPLAINLOOSE', `[v=\\s]*(${src[t.XRANGEIDENTIFIERLOOSE]})` +
   152‚Üí                        `(?:\\.(${src[t.XRANGEIDENTIFIERLOOSE]})` +

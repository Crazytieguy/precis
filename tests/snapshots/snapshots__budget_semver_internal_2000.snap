   142‚ÜícreateToken('XRANGEIDENTIFIER', `${src[t.NUMERICIDENTIFIER]}|x|X|\\*`)
   143‚Üí
   144‚ÜícreateToken('XRANGEPLAIN', `[v=\\s]*(${src[t.XRANGEIDENTIFIER]})` +
   145‚Üí                   `(?:\\.(${src[t.XRANGEIDENTIFIER]})` +
   146‚Üí                   `(?:\\.(${src[t.XRANGEIDENTIFIER]})` +
   147‚Üí                   `(?:${src[t.PRERELEASE]})?${

   190‚Üíexports.caretTrimReplace = '$1^'
   191‚Üí
   192‚ÜícreateToken('CARET', `^${src[t.LONECARET]}${src[t.XRANGEPLAIN]}$`)
   193‚ÜícreateToken('CARETLOOSE', `^${src[t.LONECARET]}${src[t.XRANGEPLAINLOOSE]}$`)

   398→    const xM = isX(M)
   399→    const xm = xM || isX(m)
   400→    const xp = xm || isX(p)
   401→    const anyX = xp
   402→
   403→    if (gtlt === '=' && anyX) {
   404→      gtlt = ''
   405→    }
   406→
   407→    // if we're including prereleases in the match, then we need
   408→    // to fix this to -0, the lowest possible prerelease value

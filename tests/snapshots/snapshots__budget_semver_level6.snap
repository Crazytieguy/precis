    85→          this.formatted += comps[k].toString().trim()
    86→        }
    87→      }
    88→    }
    89→    return this.formatted
    90→  }
    91→
    92→  format () {
    93→    return this.range
    94→  }
    95→
    96→  toString () {
    97→    return this.range
    98→  }

    27→    if (this.semver === ANY) {
    28→      this.value = ''
    29→    } else {
    30→      this.value = this.operator + this.semver.version
    31→    }
    32→
    33→    debug('comp', this)
    34→  }
    35→
    36→  parse (comp) {
    37→    const r = this.options.loose ? re[t.COMPARATORLOOSE] : re[t.COMPARATOR]

    14→      if (comp.loose === !!options.loose) {
    15→        return comp
    16→      } else {
    17→        comp = comp.value
    18→      }
    19→    }
    20→
    21→    comp = comp.trim().split(/\s+/).join(' ')
    22→    debug('comparator', comp, options)
    23→    this.options = options
    24→    this.loose = !!options.loose
    25→    this.parse(comp)

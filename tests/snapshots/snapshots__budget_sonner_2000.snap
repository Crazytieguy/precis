     3в†’export const useIsDocumentHidden = () => {
     4в†’  const [isDocumentHidden, setIsDocumentHidden] = React.useState(document.hidden);
     5в†’
     6в†’  React.useEffect(() => {
     7в†’    const callback = () => {
     8в†’      setIsDocumentHidden(document.hidden);
     9в†’    };
    10в†’    document.addEventListener('visibilitychange', callback);
    11в†’    return () => document.removeEventListener('visibilitychange', callback);
    12в†’  }, []);
    13в†’
    14в†’  return isDocumentHidden;
    15в†’};

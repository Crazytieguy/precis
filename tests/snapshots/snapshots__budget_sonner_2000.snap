     1â†’import React from 'react';
     3â†’export type ToastTypes = 'normal' | 'action' | 'success' | 'info' | 'warning' | 'error' | 'loading' | 'default';
     5â†’export type PromiseT<Data = any> = Promise<Data> | (() => Promise<Data>);
     7â†’export interface PromiseIExtendedResult extends ExternalToast {
     8â†’  message: React.ReactNode;
     9â†’}
    11â†’export type PromiseTExtendedResult<Data = any> =
    12â†’  | PromiseIExtendedResult
    13â†’  | ((data: Data) => PromiseIExtendedResult | Promise<PromiseIExtendedResult>);
    15â†’export type PromiseTResult<Data = any> =
    16â†’  | string
    17â†’  | React.ReactNode
    18â†’  | ((data: Data) => React.ReactNode | string | Promise<React.ReactNode | string>);
    20â†’export type PromiseExternalToast = Omit<ExternalToast, 'description'>;
    22â†’export type PromiseData<ToastData = any> = PromiseExternalToast & {
    23â†’  loading?: string | React.ReactNode;
    24â†’  success?: PromiseTResult<ToastData> | PromiseTExtendedResult<ToastData>;
    25â†’  error?: PromiseTResult | PromiseTExtendedResult;
    26â†’  description?: PromiseTResult;
    27â†’  finally?: () => void | Promise<void>;
    28â†’};

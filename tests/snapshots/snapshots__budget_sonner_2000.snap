     3в†’export type ToastTypes = 'normal' | 'action' | 'success' | 'info' | 'warning' | 'error' | 'loading' | 'default';
     5в†’export type PromiseT<Data = any> = Promise<Data> | (() => Promise<Data>);
     7в†’export interface PromiseIExtendedResult extends ExternalToast {
     8в†’  message: React.ReactNode;
     9в†’}
    11в†’export type PromiseTExtendedResult<Data = any> =
    12в†’  | PromiseIExtendedResult
    13в†’  | ((data: Data) => PromiseIExtendedResult | Promise<PromiseIExtendedResult>);
    15в†’export type PromiseTResult<Data = any> =
    16в†’  | string
    17в†’  | React.ReactNode
    18в†’  | ((data: Data) => React.ReactNode | string | Promise<React.ReactNode | string>);
    20в†’export type PromiseExternalToast = Omit<ExternalToast, 'description'>;
    22в†’export type PromiseData<ToastData = any> = PromiseExternalToast & {
    23в†’  loading?: string | React.ReactNode;
    24в†’  success?: PromiseTResult<ToastData> | PromiseTExtendedResult<ToastData>;
    25в†’  error?: PromiseTResult | PromiseTExtendedResult;

website/src/components/Position/index.tsx
     5→const positions = ['top-left', 'top-center', 'top-right', 'bottom-left', 'bottom-center', 'bottom-right'] as const;
     7→export type Position = (typeof positions)[number];
     9→export const Position = ({
    10→  position: activePosition,
    11→  setPosition,
    12→}: {
    13→  position: Position;
    14→  setPosition: React.Dispatch<React.SetStateAction<Position>>;
    15→}) => {
    16→  const { toasts } = useSonner();
    17→
    18→  function removeAllToasts() {
    19→    toasts.forEach((t) => toast.dismiss(t.id));
    20→  }
    21→
    22→  return (
    23→    <div>
    24→      <h2>Position</h2>
    25→      <p>Swipe direction changes depending on the position.</p>
    26→      <div className="buttons">
    27→        {positions.map((position) => (
    28→          <button
    29→            data-active={activePosition === position}
    30→            className="button"
    31→            onClick={() => {
    32→              if (activePosition !== position) {
    33→                setPosition(position);
    34→                removeAllToasts();
    35→              }
    36→
    37→              toast('Event has been created', {
    38→                description: 'Monday, January 3rd at 6:00pm',
    39→              });
    40→            }}
    41→            key={position}
    42→          >
    43→            {position}
    44→          </button>
    45→        ))}
    46→      </div>
    47→      <CodeBlock>{`<Toaster position="${activePosition}" />`}</CodeBlock>
    48→    </div>
    49→  );
    50→};

    48→export const CodeBlock = ({ children, initialHeight = 0 }: { children: string; initialHeight?: number }) => {
    49→  const [ref, bounds] = useMeasure();
    50→  const [copying, setCopying] = React.useState<number>(0);
    51→
    52→  const onCopy = React.useCallback(() => {
    53→    copy(children);
    54→    setCopying((c) => c + 1);
    55→    setTimeout(() => {
    56→      setCopying((c) => c - 1);
    57→    }, 2000);
    58→  }, [children]);
    59→
    60→  return (
    61→    <div className={styles.outerWrapper}>
    62→      <button className={styles.copyButton} onClick={onCopy} aria-label="Copy code">
    63→        <MotionConfig transition={{ duration: 0.15 }}>
    64→          <AnimatePresence initial={false} mode="wait">
    65→            {copying ? (
    66→              <motion.div animate="visible" exit="hidden" initial="hidden" key="check" variants={variants}>

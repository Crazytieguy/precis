   154→        } else if (isHttpResponse(response) && !response.ok) {
   155→          shouldDismiss = false;
   156→
   157→          const promiseData =
   158→            typeof data.error === 'function' ? await data.error(`HTTP error! status: ${response.status}`) : data.error;
   159→
   160→          const description =
   161→            typeof data.description === 'function'
   162→              ? await data.description(`HTTP error! status: ${response.status}`)
   163→              : data.description;

   254→export const ToastState = new Observer();
   257→const toastFunction = (message: titleT, data?: ExternalToast) => {
   258→  const id = data?.id || toastsCounter++;
   259→
   260→  ToastState.addToast({
   261→    title: message,
   262→    ...data,
   263→    id,
   264→  });
   265→  return id;
   266→};
   268→const isHttpResponse = (data: any): data is Response => {
   269→  return (
   270→    data &&
   271→    typeof data === 'object' &&
   272→    'ok' in data &&
   273→    typeof data.ok === 'boolean' &&
   274→    'status' in data &&
   275→    typeof data.status === 'number'
   276→  );
   277→};

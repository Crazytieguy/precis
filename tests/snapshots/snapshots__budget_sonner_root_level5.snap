   170‚Üí
   171‚Üí          this.create({ id, type: 'error', description, ...toastSettings });
   172‚Üí        } else if (response instanceof Error) {
   173‚Üí          shouldDismiss = false;
   174‚Üí
   175‚Üí          const promiseData = typeof data.error === 'function' ? await data.error(response) : data.error;
   176‚Üí
   177‚Üí          const description =
   178‚Üí            typeof data.description === 'function' ? await data.description(response) : data.description;
   179‚Üí
   180‚Üí          const isExtendedResult = typeof promiseData === 'object' && !React.isValidElement(promiseData);
   181‚Üí

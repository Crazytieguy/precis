   193‚Üí
   194‚Üí          const isExtendedResult = typeof promiseData === 'object' && !React.isValidElement(promiseData);
   195‚Üí
   196‚Üí          const toastSettings: PromiseIExtendedResult = isExtendedResult
   197‚Üí            ? (promiseData as PromiseIExtendedResult)
   198‚Üí            : { message: promiseData };
   199‚Üí
   200‚Üí          this.create({ id, type: 'success', description, ...toastSettings });
   201‚Üí        }

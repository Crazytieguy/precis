    15‚Üítype titleT = (() => React.ReactNode) | React.ReactNode;
    17‚Üíclass Observer {
    18‚Üí  subscribers: Array<(toast: ExternalToast | ToastToDismiss) => void>;
    19‚Üí  toasts: Array<ToastT | ToastToDismiss>;
    20‚Üí  dismissedToasts: Set<string | number>;
    21‚Üí
    22‚Üí  constructor() {
    23‚Üí    this.subscribers = [];
    24‚Üí    this.toasts = [];
    25‚Üí    this.dismissedToasts = new Set();
    26‚Üí  }
    27‚Üí
    28‚Üí  // We use arrow functions to maintain the correct `this` reference
    29‚Üí  subscribe = (subscriber: (toast: ToastT | ToastToDismiss) => void) => {
    30‚Üí    this.subscribers.push(subscriber);
    31‚Üí
    32‚Üí    return () => {
    33‚Üí      const index = this.subscribers.indexOf(subscriber);
    34‚Üí      this.subscribers.splice(index, 1);
    35‚Üí    };
    36‚Üí  };
    37‚Üí
    38‚Üí  publish = (data: ToastT) => {
    39‚Üí    this.subscribers.forEach((subscriber) => subscriber(data));
    40‚Üí  };
    41‚Üí
    42‚Üí  addToast = (data: ToastT) => {
    43‚Üí    this.publish(data);
    44‚Üí    this.toasts = [...this.toasts, data];
    45‚Üí  };
    46‚Üí
    47‚Üí  create = (
    48‚Üí    data: ExternalToast & {
    49‚Üí      message?: titleT;
    50‚Üí      type?: ToastTypes;
    51‚Üí      promise?: PromiseT;
    52‚Üí      jsx?: React.ReactElement;
    53‚Üí    },
    54‚Üí  ) => {
    55‚Üí    const { message, ...rest } = data;
    56‚Üí    const id = typeof data?.id === 'number' || data.id?.length > 0 ? data.id : toastsCounter++;
    57‚Üí    const alreadyExists = this.toasts.find((toast) => {
    58‚Üí      return toast.id === id;
    59‚Üí    });
    60‚Üí    const dismissible = data.dismissible === undefined ? true : data.dismissible;
    61‚Üí
    62‚Üí    if (this.dismissedToasts.has(id)) {
    63‚Üí      this.dismissedToasts.delete(id);
    64‚Üí    }
    65‚Üí
    66‚Üí    if (alreadyExists) {
    67‚Üí      this.toasts = this.toasts.map((toast) => {
    68‚Üí        if (toast.id === id) {
    69‚Üí          this.publish({ ...toast, ...data, id, title: message });
    70‚Üí          return {
    71‚Üí            ...toast,
    72‚Üí            ...data,
    73‚Üí            id,
    74‚Üí            dismissible,
    75‚Üí            title: message,
    76‚Üí          };
    77‚Üí        }
    78‚Üí
    79‚Üí        return toast;
    80‚Üí      });
    81‚Üí    } else {
    82‚Üí      this.addToast({ title: message, ...rest, dismissible, id });
    83‚Üí    }
    84‚Üí
    85‚Üí    return id;
    86‚Üí  };
    87‚Üí
    88‚Üí  dismiss = (id?: number | string) => {
    89‚Üí    if (id) {
    90‚Üí      this.dismissedToasts.add(id);
    91‚Üí      requestAnimationFrame(() => this.subscribers.forEach((subscriber) => subscriber({ id, dismiss: true })));

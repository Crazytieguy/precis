   507→function getDocumentDirection(): ToasterProps['dir'] {
   508→  if (typeof window === 'undefined') return 'ltr';
   509→  if (typeof document === 'undefined') return 'ltr'; // For Fresh purpose
   510→
   511→  const dirAttribute = document.documentElement.getAttribute('dir');
   512→
   513→  if (dirAttribute === 'auto' || !dirAttribute) {
   514→    return window.getComputedStyle(document.documentElement).direction as ToasterProps['dir'];
   515→  }
   516→
   517→  return dirAttribute as ToasterProps['dir'];
   518→}
   520→function assignOffset(defaultOffset: ToasterProps['offset'], mobileOffset: ToasterProps['mobileOffset']) {
   521→  const styles = {} as React.CSSProperties;
   522→
   523→  [defaultOffset, mobileOffset].forEach((offset, index) => {
   524→    const isMobile = index === 1;
   525→    const prefix = isMobile ? '--mobile-offset' : '--offset';
   526→    const defaultValue = isMobile ? MOBILE_VIEWPORT_OFFSET : VIEWPORT_OFFSET;
   527→
   528→    function assignAll(offset: string | number) {
   529→      ['top', 'right', 'bottom', 'left'].forEach((key) => {
   530→        styles[`${prefix}-${key}`] = typeof offset === 'number' ? `${offset}px` : offset;
   531→      });
   532→    }
   533→
   534→    if (typeof offset === 'number' || typeof offset === 'string') {
   535→      assignAll(offset);
   536→    } else if (typeof offset === 'object') {
   537→      ['top', 'right', 'bottom', 'left'].forEach((key) => {
   538→        if (offset[key] === undefined) {
   539→          styles[`${prefix}-${key}`] = defaultValue;
   540→        } else {
   541→          styles[`${prefix}-${key}`] = typeof offset[key] === 'number' ? `${offset[key]}px` : offset[key];
   542→        }
   543→      });
   544→    } else {
   545→      assignAll(defaultValue);
   546→    }
   547→  });
   548→
   549→  return styles;
   550→}
   552→function useSonner() {
   553→  const [activeToasts, setActiveToasts] = React.useState<ToastT[]>([]);
   554→
   555→  React.useEffect(() => {
   556→    return ToastState.subscribe((toast) => {
   557→      if ((toast as ToastToDismiss).dismiss) {
   558→        setTimeout(() => {
   559→          ReactDOM.flushSync(() => {
   560→            setActiveToasts((toasts) => toasts.filter((t) => t.id !== toast.id));
   561→          });

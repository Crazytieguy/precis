     1→import React from 'react';
     3→export const useIsDocumentHidden = () => {
     4→  const [isDocumentHidden, setIsDocumentHidden] = React.useState(document.hidden);
     5→
     6→  React.useEffect(() => {
     7→    const callback = () => {
     8→      setIsDocumentHidden(document.hidden);
     9→    };
    10→    document.addEventListener('visibilitychange', callback);
    11→    return () => document.removeEventListener('visibilitychange', callback);
    12→  }, []);
    13→
    14→  return isDocumentHidden;
    15→};


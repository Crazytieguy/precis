   258→			continue
   259→		}
   260→
   261→		f := &Field{
   262→			field: field,
   263→			value: v.FieldByName(field.Name),
   264→		}
   265→
   266→		fields = append(fields, f)
   267→
   268→	}
   269→
   270→	return fields
   271→}

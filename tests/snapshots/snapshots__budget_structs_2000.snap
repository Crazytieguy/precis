   245→func getFields(v reflect.Value, tagName string) []*Field {
   246→	if v.Kind() == reflect.Ptr {
   247→		v = v.Elem()
   248→	}
   249→
   250→	t := v.Type()
   251→
   252→	var fields []*Field
   253→
   254→	for i := 0; i < t.NumField(); i++ {
   255→		field := t.Field(i)
   256→

   245‚Üífunc getFields(v reflect.Value, tagName string) []*Field {
   246‚Üí	if v.Kind() == reflect.Ptr {
   247‚Üí		v = v.Elem()
   248‚Üí	}
   249‚Üí
   250‚Üí	t := v.Type()

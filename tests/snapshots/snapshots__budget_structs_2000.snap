   262‚Üí			field: field,
   263‚Üí			value: v.FieldByName(field.Name),
   264‚Üí		}
   265‚Üí
   266‚Üí		fields = append(fields, f)
   267‚Üí
   268‚Üí	}
   269‚Üí
   270‚Üí	return fields
   271‚Üí}

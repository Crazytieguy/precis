tags.go
     3‚Üíimport "strings"
     5‚Üí// tagOptions contains a slice of tag options
     6‚Üítype tagOptions []string
     8‚Üí// Has returns true if the given option is available in tagOptions
     9‚Üífunc (t tagOptions) Has(opt string) bool {
    19‚Üí// parseTag splits a struct field's tag into its name and a list of options
    20‚Üí// which comes after a name. A tag is in the form of: "name,option1,option2".
    21‚Üí// The name can be neglectected.
    22‚Üífunc parseTag(tag string) (string, tagOptions) {
    23‚Üí	// tag is one of followings:
    24‚Üí	// ""
    25‚Üí	// "name"
    26‚Üí	// "name,opt"
    27‚Üí	// "name,opt,opt2"
    28‚Üí	// ",opt"
    29‚Üí
    30‚Üí	res := strings.Split(tag, ",")
    31‚Üí	return res[0], res[1:]
    32‚Üí}

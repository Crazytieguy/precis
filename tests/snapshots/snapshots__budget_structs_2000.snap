tags.go
     5вҶ’// tagOptions contains a slice of tag options
     6вҶ’type tagOptions []string
     8вҶ’// Has returns true if the given option is available in tagOptions
     9вҶ’func (t tagOptions) Has(opt string) bool {
    19вҶ’// parseTag splits a struct field's tag into its name and a list of options
    20вҶ’// which comes after a name. A tag is in the form of: "name,option1,option2".
    21вҶ’// The name can be neglectected.
    22вҶ’func parseTag(tag string) (string, tagOptions) {
    23вҶ’	// tag is one of followings:
    24вҶ’	// ""
    25вҶ’	// "name"
    26вҶ’	// "name,opt"
    27вҶ’	// "name,opt,opt2"
    28вҶ’	// ",opt"
    29вҶ’
    30вҶ’	res := strings.Split(tag, ",")
    31вҶ’	return res[0], res[1:]
    32вҶ’}

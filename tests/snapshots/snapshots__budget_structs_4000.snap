tags.go
     3Ôćĺimport "strings"
     5Ôćĺ// tagOptions contains a slice of tag options
     6Ôćĺtype tagOptions []string
     8Ôćĺ// Has returns true if the given option is available in tagOptions
     9Ôćĺfunc (t tagOptions) Has(opt string) bool {
    10Ôćĺ	for _, tagOpt := range t {
    11Ôćĺ		if tagOpt == opt {
    12Ôćĺ			return true
    13Ôćĺ		}
    14Ôćĺ	}
    15Ôćĺ
    16Ôćĺ	return false
    17Ôćĺ}
    19Ôćĺ// parseTag splits a struct field's tag into its name and a list of options
    20Ôćĺ// which comes after a name. A tag is in the form of: "name,option1,option2".
    21Ôćĺ// The name can be neglectected.
    22Ôćĺfunc parseTag(tag string) (string, tagOptions) {
    23Ôćĺ	// tag is one of followings:
    24Ôćĺ	// ""
    25Ôćĺ	// "name"
    26Ôćĺ	// "name,opt"
    27Ôćĺ	// "name,opt,opt2"
    28Ôćĺ	// ",opt"
    29Ôćĺ
    30Ôćĺ	res := strings.Split(tag, ",")
    31Ôćĺ	return res[0], res[1:]
    32Ôćĺ}

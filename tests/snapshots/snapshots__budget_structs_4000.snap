   273ÔåÆ// Field returns a new Field struct that provides several high level functions
   274ÔåÆ// around a single struct field entity. It panics if the field is not found.
   275ÔåÆfunc (s *Struct) Field(name string) *Field {
   276ÔåÆ	f, ok := s.FieldOk(name)
   277ÔåÆ	if !ok {
   278ÔåÆ		panic("field not found")
   279ÔåÆ	}
   280ÔåÆ
   281ÔåÆ	return f
   282ÔåÆ}
   284ÔåÆ// FieldOk returns a new Field struct that provides several high level functions
   285ÔåÆ// around a single struct field entity. The boolean returns true if the field
   286ÔåÆ// was found.
   287ÔåÆfunc (s *Struct) FieldOk(name string) (*Field, bool) {
   288ÔåÆ	t := s.value.Type()
   289ÔåÆ
   290ÔåÆ	field, ok := t.FieldByName(name)
   291ÔåÆ	if !ok {
   292ÔåÆ		return nil, false
   293ÔåÆ	}
   294ÔåÆ
   295ÔåÆ	return &Field{
   296ÔåÆ		field:      field,
   297ÔåÆ		value:      s.value.FieldByName(name),
   298ÔåÆ		defaultTag: s.TagName,
   299ÔåÆ	}, true
   300ÔåÆ}
   302ÔåÆ// IsZero returns true if all fields in a struct is a zero value (not
   303ÔåÆ// initialized) A struct tag with the content of "-" ignores the checking of
   304ÔåÆ// that particular field. Example:
   305ÔåÆ//
   306ÔåÆ//   // Field is ignored by this package.
   307ÔåÆ//   Field bool `structs:"-"`
   308ÔåÆ//
   309ÔåÆ// A value with the option of "omitnested" stops iterating further if the type
   310ÔåÆ// is a struct. Example:
   311ÔåÆ//
   312ÔåÆ//   // Field is not processed further by this package.
   313ÔåÆ//   Field time.Time     `structs:"myName,omitnested"`
   314ÔåÆ//   Field *http.Request `structs:",omitnested"`
   315ÔåÆ//
   316ÔåÆ// Note that only exported fields of a struct can be accessed, non exported
   317ÔåÆ// fields  will be neglected. It panics if s's kind is not struct.
   318ÔåÆfunc (s *Struct) IsZero() bool {
   319ÔåÆ	fields := s.structFields()
   320ÔåÆ
   321ÔåÆ	for _, field := range fields {
   322ÔåÆ		val := s.value.FieldByName(field.Name)
   323ÔåÆ
   324ÔåÆ		_, tagOpts := parseTag(field.Tag.Get(s.TagName))
   325ÔåÆ
   326ÔåÆ		if IsStruct(val.Interface()) && !tagOpts.Has("omitnested") {
   327ÔåÆ			ok := IsZero(val.Interface())
   328ÔåÆ			if !ok {
   329ÔåÆ				return false
   330ÔåÆ			}
   331ÔåÆ
   332ÔåÆ			continue
   333ÔåÆ		}
   334ÔåÆ
   335ÔåÆ		// zero value of the given field, such as "" for string, 0 for int
   336ÔåÆ		zero := reflect.Zero(val.Type()).Interface()
   337ÔåÆ
   338ÔåÆ		//  current value of the given field
   339ÔåÆ		current := val.Interface()
   340ÔåÆ
   341ÔåÆ		if !reflect.DeepEqual(current, zero) {
   342ÔåÆ			return false
   343ÔåÆ		}
   344ÔåÆ	}
   345ÔåÆ
   346ÔåÆ	return true
   347ÔåÆ}
   349ÔåÆ// HasZero returns true if a field in a struct is not initialized (zero value).
   350ÔåÆ// A struct tag with the content of "-" ignores the checking of that particular
   351ÔåÆ// field. Example:
   352ÔåÆ//
   353ÔåÆ//   // Field is ignored by this package.
   354ÔåÆ//   Field bool `structs:"-"`
   355ÔåÆ//
   356ÔåÆ// A value with the option of "omitnested" stops iterating further if the type
   357ÔåÆ// is a struct. Example:
   358ÔåÆ//
   359ÔåÆ//   // Field is not processed further by this package.
   360ÔåÆ//   Field time.Time     `structs:"myName,omitnested"`
   361ÔåÆ//   Field *http.Request `structs:",omitnested"`
   362ÔåÆ//
   363ÔåÆ// Note that only exported fields of a struct can be accessed, non exported
   364ÔåÆ// fields  will be neglected. It panics if s's kind is not struct.
   365ÔåÆfunc (s *Struct) HasZero() bool {
   366ÔåÆ	fields := s.structFields()
   367ÔåÆ
   368ÔåÆ	for _, field := range fields {
   369ÔåÆ		val := s.value.FieldByName(field.Name)
   370ÔåÆ
   371ÔåÆ		_, tagOpts := parseTag(field.Tag.Get(s.TagName))
   372ÔåÆ
   373ÔåÆ		if IsStruct(val.Interface()) && !tagOpts.Has("omitnested") {
   374ÔåÆ			ok := HasZero(val.Interface())
   375ÔåÆ			if ok {
   376ÔåÆ				return true
   377ÔåÆ			}
   378ÔåÆ
   379ÔåÆ			continue
   380ÔåÆ		}
   381ÔåÆ
   382ÔåÆ		// zero value of the given field, such as "" for string, 0 for int
   383ÔåÆ		zero := reflect.Zero(val.Type()).Interface()
   384ÔåÆ
   385ÔåÆ		//  current value of the given field
   386ÔåÆ		current := val.Interface()
   387ÔåÆ
   388ÔåÆ		if reflect.DeepEqual(current, zero) {
   389ÔåÆ			return true
   390ÔåÆ		}
   391ÔåÆ	}
   392ÔåÆ
   393ÔåÆ	return false
   394ÔåÆ}
   396ÔåÆ// Name returns the structs's type name within its package. For more info refer
   397ÔåÆ// to Name() function.
   398ÔåÆfunc (s *Struct) Name() string {
   399ÔåÆ	return s.value.Type().Name()
   400ÔåÆ}
   402ÔåÆ// structFields returns the exported struct fields for a given s struct. This
   403ÔåÆ// is a convenient helper method to avoid duplicate code in some of the
   404ÔåÆ// functions.
   405ÔåÆfunc (s *Struct) structFields() []reflect.StructField {
   406ÔåÆ	t := s.value.Type()
   407ÔåÆ
   408ÔåÆ	var f []reflect.StructField
   409ÔåÆ
   410ÔåÆ	for i := 0; i < t.NumField(); i++ {
   411ÔåÆ		field := t.Field(i)
   412ÔåÆ		// we can't access the value of unexported fields
   413ÔåÆ		if field.PkgPath != "" {
   414ÔåÆ			continue
   415ÔåÆ		}
   416ÔåÆ

   354Ôćĺ//   Field bool `structs:"-"`
   355Ôćĺ//
   356Ôćĺ// A value with the option of "omitnested" stops iterating further if the type
   357Ôćĺ// is a struct. Example:
   358Ôćĺ//
   359Ôćĺ//   // Field is not processed further by this package.
   360Ôćĺ//   Field time.Time     `structs:"myName,omitnested"`
   361Ôćĺ//   Field *http.Request `structs:",omitnested"`
   362Ôćĺ//
   363Ôćĺ// Note that only exported fields of a struct can be accessed, non exported
   364Ôćĺ// fields  will be neglected. It panics if s's kind is not struct.
   365Ôćĺfunc (s *Struct) HasZero() bool {
   366Ôćĺ	fields := s.structFields()

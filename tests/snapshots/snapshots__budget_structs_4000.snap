     3вҶ’import (
     4вҶ’	"errors"
     5вҶ’	"fmt"
     6вҶ’	"reflect"
     7вҶ’)
     9вҶ’var (
    10вҶ’	errNotExported = errors.New("field is not exported")
    11вҶ’	errNotSettable = errors.New("field is not settable")
    14вҶ’// Field represents a single struct field that encapsulates high level
    15вҶ’// functions around the field.
    16вҶ’type Field struct {
    17вҶ’	value      reflect.Value
    18вҶ’	field      reflect.StructField
    19вҶ’	defaultTag string
    20вҶ’}
    22вҶ’// Tag returns the value associated with key in the tag string. If there is no
    23вҶ’// such key in the tag, Tag returns the empty string.
    24вҶ’func (f *Field) Tag(key string) string {
    25вҶ’	return f.field.Tag.Get(key)
    26вҶ’}
    28вҶ’// Value returns the underlying value of the field. It panics if the field
    29вҶ’// is not exported.
    30вҶ’func (f *Field) Value() interface{} {
    31вҶ’	return f.value.Interface()
    32вҶ’}
    34вҶ’// IsEmbedded returns true if the given field is an anonymous field (embedded)
    35вҶ’func (f *Field) IsEmbedded() bool {
    36вҶ’	return f.field.Anonymous
    37вҶ’}
    39вҶ’// IsExported returns true if the given field is exported.
    40вҶ’func (f *Field) IsExported() bool {
    41вҶ’	return f.field.PkgPath == ""
    42вҶ’}
    44вҶ’// IsZero returns true if the given field is not initialized (has a zero value).
    45вҶ’// It panics if the field is not exported.
    46вҶ’func (f *Field) IsZero() bool {
    47вҶ’	zero := reflect.Zero(f.value.Type()).Interface()
    48вҶ’	current := f.Value()
    49вҶ’
    50вҶ’	return reflect.DeepEqual(current, zero)
    51вҶ’}
    53вҶ’// Name returns the name of the given field
    54вҶ’func (f *Field) Name() string {
    55вҶ’	return f.field.Name
    56вҶ’}
    58вҶ’// Kind returns the fields kind, such as "string", "map", "bool", etc ..
    59вҶ’func (f *Field) Kind() reflect.Kind {
    60вҶ’	return f.value.Kind()
    61вҶ’}
    63вҶ’// Set sets the field to given value v. It returns an error if the field is not
    64вҶ’// settable (not addressable or not exported) or if the given value's type
    65вҶ’// doesn't match the fields type.
    66вҶ’func (f *Field) Set(val interface{}) error {
    67вҶ’	// we can't set unexported fields, so be sure this field is exported
    68вҶ’	if !f.IsExported() {
    69вҶ’		return errNotExported
    70вҶ’	}
    71вҶ’
    72вҶ’	// do we get here? not sure...
    73вҶ’	if !f.value.CanSet() {
    74вҶ’		return errNotSettable
    75вҶ’	}
    76вҶ’
    77вҶ’	given := reflect.ValueOf(val)
    78вҶ’
      вҶ’вҖҰ
    87вҶ’// Zero sets the field to its zero value. It returns an error if the field is not
    88вҶ’// settable (not addressable or not exported).
    89вҶ’func (f *Field) Zero() error {
    90вҶ’	zero := reflect.Zero(f.value.Type()).Interface()
    91вҶ’	return f.Set(zero)
    92вҶ’}
    94вҶ’// Fields returns a slice of Fields. This is particular handy to get the fields
    95вҶ’// of a nested struct . A struct tag with the content of "-" ignores the
    96вҶ’// checking of that particular field. Example:
    97вҶ’//
    98вҶ’//   // Field is ignored by this package.
    99вҶ’//   Field *http.Request `structs:"-"`
   100вҶ’//
   101вҶ’// It panics if field is not exported or if field's kind is not struct
   102вҶ’func (f *Field) Fields() []*Field {
   103вҶ’	return getFields(f.value, f.defaultTag)
   104вҶ’}
   106вҶ’// Field returns the field from a nested struct. It panics if the nested struct
   107вҶ’// is not exported or if the field was not found.
   108вҶ’func (f *Field) Field(name string) *Field {
   109вҶ’	field, ok := f.FieldOk(name)
   110вҶ’	if !ok {
   111вҶ’		panic("field not found")
   112вҶ’	}
   113вҶ’
   114вҶ’	return field
   115вҶ’}
   117вҶ’// FieldOk returns the field from a nested struct. The boolean returns whether
   118вҶ’// the field was found (true) or not (false).
   119вҶ’func (f *Field) FieldOk(name string) (*Field, bool) {
   120вҶ’	value := &f.value
   121вҶ’	// value must be settable so we need to make sure it holds the address of the
   122вҶ’	// variable and not a copy, so we can pass the pointer to strctVal instead of a
   123вҶ’	// copy (which is not assigned to any variable, hence not settable).
   124вҶ’	// see "https://blog.golang.org/laws-of-reflection#TOC_8."
   125вҶ’	if f.value.Kind() != reflect.Ptr {
   126вҶ’		a := f.value.Addr()
   127вҶ’		value = &a
   128вҶ’	}
   129вҶ’	v := strctVal(value.Interface())
   130вҶ’	t := v.Type()
   131вҶ’

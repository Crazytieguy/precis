   494Ôćĺ	if v.Kind() == reflect.Invalid {
   495Ôćĺ		return false
   496Ôćĺ	}
   497Ôćĺ
   498Ôćĺ	return v.Kind() == reflect.Struct
   499Ôćĺ}

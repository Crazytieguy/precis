structs.go
     4Ôćĺimport (
     5Ôćĺ	"fmt"
     6Ôćĺ
     7Ôćĺ	"reflect"
     8Ôćĺ)
    10Ôćĺvar (
    11Ôćĺ	// DefaultTagName is the default tag name for struct fields which provides
    12Ôćĺ	// a more granular to tweak certain structs. Lookup the necessary functions
    13Ôćĺ	// for more info.
    14Ôćĺ	DefaultTagName = "structs" // struct's field default tag name
    17Ôćĺ// Struct encapsulates a struct type to provide several high level functions
    18Ôćĺ// around the struct.
    19Ôćĺtype Struct struct {
    20Ôćĺ	raw     interface{}
    21Ôćĺ	value   reflect.Value
    22Ôćĺ	TagName string
    23Ôćĺ}
    25Ôćĺ// New returns a new *Struct with the struct s. It panics if the s's kind is
    26Ôćĺ// not struct.
    27Ôćĺfunc New(s interface{}) *Struct {
    28Ôćĺ	return &Struct{
    29Ôćĺ		raw:     s,
    30Ôćĺ		value:   strctVal(s),
    31Ôćĺ		TagName: DefaultTagName,
    32Ôćĺ	}
    33Ôćĺ}
    35Ôćĺ// Map converts the given struct to a map[string]interface{}, where the keys
    36Ôćĺ// of the map are the field names and the values of the map the associated
    37Ôćĺ// values of the fields. The default key string is the struct field name but
    38Ôćĺ// can be changed in the struct field's tag value. The "structs" key in the
    39Ôćĺ// struct's field tag value is the key name. Example:
    40Ôćĺ//
    41Ôćĺ//   // Field appears in map as key "myName".
    42Ôćĺ//   Name string `structs:"myName"`
    43Ôćĺ//
    44Ôćĺ// A tag value with the content of "-" ignores that particular field. Example:
    45Ôćĺ//
    46Ôćĺ//   // Field is ignored by this package.
    47Ôćĺ//   Field bool `structs:"-"`
    48Ôćĺ//
    49Ôćĺ// A tag value with the content of "string" uses the stringer to get the value. Example:
    50Ôćĺ//
    51Ôćĺ//   // The value will be output of Animal's String() func.
    52Ôćĺ//   // Map will panic if Animal does not implement String().
    53Ôćĺ//   Field *Animal `structs:"field,string"`
    54Ôćĺ//
    55Ôćĺ// A tag value with the option of "flatten" used in a struct field is to flatten its fields
    56Ôćĺ// in the output map. Example:
    57Ôćĺ//
    58Ôćĺ//   // The FieldStruct's fields will be flattened into the output map.
    59Ôćĺ//   FieldStruct time.Time `structs:",flatten"`
    60Ôćĺ//
    61Ôćĺ// A tag value with the option of "omitnested" stops iterating further if the type
    62Ôćĺ// is a struct. Example:
    63Ôćĺ//
    64Ôćĺ//   // Field is not processed further by this package.
    65Ôćĺ//   Field time.Time     `structs:"myName,omitnested"`
    66Ôćĺ//   Field *http.Request `structs:",omitnested"`
    67Ôćĺ//
    68Ôćĺ// A tag value with the option of "omitempty" ignores that particular field if
    69Ôćĺ// the field value is empty. Example:
    70Ôćĺ//
    71Ôćĺ//   // Field appears in map as key "myName", but the field is
    72Ôćĺ//   // skipped if empty.
    73Ôćĺ//   Field string `structs:"myName,omitempty"`
    74Ôćĺ//
    75Ôćĺ//   // Field appears in map as key "Field" (the default), but
    76Ôćĺ//   // the field is skipped if empty.
    77Ôćĺ//   Field string `structs:",omitempty"`
    78Ôćĺ//
    79Ôćĺ// Note that only exported fields of a struct can be accessed, non exported
    80Ôćĺ// fields will be neglected.
    81Ôćĺfunc (s *Struct) Map() map[string]interface{} {
    82Ôćĺ	out := make(map[string]interface{})
    83Ôćĺ	s.FillMap(out)
    84Ôćĺ	return out
    85Ôćĺ}
    87Ôćĺ// FillMap is the same as Map. Instead of returning the output, it fills the
    88Ôćĺ// given map.
    89Ôćĺfunc (s *Struct) FillMap(out map[string]interface{}) {
    90Ôćĺ	if out == nil {
    91Ôćĺ		return
    92Ôćĺ	}
    93Ôćĺ
    94Ôćĺ	fields := s.structFields()
    95Ôćĺ
    96Ôćĺ	for _, field := range fields {
    97Ôćĺ		name := field.Name
    98Ôćĺ		val := s.value.FieldByName(name)
    99Ôćĺ		isSubStruct := false
   100Ôćĺ		var finalVal interface{}
   101Ôćĺ
   102Ôćĺ		tagName, tagOpts := parseTag(field.Tag.Get(s.TagName))
   103Ôćĺ		if tagName != "" {
   104Ôćĺ			name = tagName
   105Ôćĺ		}
   106Ôćĺ
   107Ôćĺ		// if the value is a zero value and the field is marked as omitempty do
   108Ôćĺ		// not include
   109Ôćĺ		if tagOpts.Has("omitempty") {
   110Ôćĺ			zero := reflect.Zero(val.Type()).Interface()
   111Ôćĺ			current := val.Interface()
   112Ôćĺ
   113Ôćĺ			if reflect.DeepEqual(current, zero) {
   114Ôćĺ				continue
   115Ôćĺ			}
   116Ôćĺ		}
   117Ôćĺ
   118Ôćĺ		if !tagOpts.Has("omitnested") {
   119Ôćĺ			finalVal = s.nested(val)
   120Ôćĺ
   121Ôćĺ			v := reflect.ValueOf(val.Interface())
   122Ôćĺ			if v.Kind() == reflect.Ptr {
   123Ôćĺ				v = v.Elem()
   124Ôćĺ			}
   125Ôćĺ
   126Ôćĺ			switch v.Kind() {
   127Ôćĺ			case reflect.Map, reflect.Struct:
   128Ôćĺ				isSubStruct = true
   129Ôćĺ			}
   130Ôćĺ		} else {
   131Ôćĺ			finalVal = val.Interface()
   132Ôćĺ		}
   133Ôćĺ
   134Ôćĺ		if tagOpts.Has("string") {
   135Ôćĺ			s, ok := val.Interface().(fmt.Stringer)
   136Ôćĺ			if ok {
   137Ôćĺ				out[name] = s.String()
   138Ôćĺ			}
   139Ôćĺ			continue
   140Ôćĺ		}
   141Ôćĺ
   142Ôćĺ		if isSubStruct && (tagOpts.Has("flatten")) {
   143Ôćĺ			for k := range finalVal.(map[string]interface{}) {
   144Ôćĺ				out[k] = finalVal.(map[string]interface{})[k]
   145Ôćĺ			}
   146Ôćĺ		} else {
   147Ôćĺ			out[name] = finalVal
   148Ôćĺ		}
   149Ôćĺ	}
   150Ôćĺ}
   152Ôćĺ// Values converts the given s struct's field values to a []interface{}.  A
   153Ôćĺ// struct tag with the content of "-" ignores the that particular field.
   154Ôćĺ// Example:
   155Ôćĺ//
   156Ôćĺ//   // Field is ignored by this package.
   157Ôćĺ//   Field int `structs:"-"`
   158Ôćĺ//
   159Ôćĺ// A value with the option of "omitnested" stops iterating further if the type
   160Ôćĺ// is a struct. Example:
   161Ôćĺ//
   162Ôćĺ//   // Fields is not processed further by this package.
   163Ôćĺ//   Field time.Time     `structs:",omitnested"`
   164Ôćĺ//   Field *http.Request `structs:",omitnested"`
   165Ôćĺ//
   166Ôćĺ// A tag value with the option of "omitempty" ignores that particular field and
   167Ôćĺ// is not added to the values if the field value is empty. Example:
   168Ôćĺ//
   169Ôćĺ//   // Field is skipped if empty
   170Ôćĺ//   Field string `structs:",omitempty"`
   171Ôćĺ//
   172Ôćĺ// Note that only exported fields of a struct can be accessed, non exported
   173Ôćĺ// fields  will be neglected.
   174Ôćĺfunc (s *Struct) Values() []interface{} {
   175Ôćĺ	fields := s.structFields()
   176Ôćĺ
   177Ôćĺ	var t []interface{}
   178Ôćĺ
   179Ôćĺ	for _, field := range fields {
   180Ôćĺ		val := s.value.FieldByName(field.Name)
   181Ôćĺ
   182Ôćĺ		_, tagOpts := parseTag(field.Tag.Get(s.TagName))
   183Ôćĺ
   184Ôćĺ		// if the value is a zero value and the field is marked as omitempty do
   185Ôćĺ		// not include
   186Ôćĺ		if tagOpts.Has("omitempty") {
   187Ôćĺ			zero := reflect.Zero(val.Type()).Interface()
   188Ôćĺ			current := val.Interface()
   189Ôćĺ
   190Ôćĺ			if reflect.DeepEqual(current, zero) {
   191Ôćĺ				continue
   192Ôćĺ			}
   193Ôćĺ		}
   194Ôćĺ
   195Ôćĺ		if tagOpts.Has("string") {
   196Ôćĺ			s, ok := val.Interface().(fmt.Stringer)
   197Ôćĺ			if ok {
   198Ôćĺ				t = append(t, s.String())
   199Ôćĺ			}
   200Ôćĺ			continue
   201Ôćĺ		}
   202Ôćĺ
   203Ôćĺ		if IsStruct(val.Interface()) && !tagOpts.Has("omitnested") {
   204Ôćĺ			// look out for embedded structs, and convert them to a
   205Ôćĺ			// []interface{} to be added to the final values slice
   206Ôćĺ			t = append(t, Values(val.Interface())...)
   207Ôćĺ		} else {
   208Ôćĺ			t = append(t, val.Interface())
   209Ôćĺ		}
   210Ôćĺ	}
   211Ôćĺ
   212Ôćĺ	return t
   213Ôćĺ}
   215Ôćĺ// Fields returns a slice of Fields. A struct tag with the content of "-"
   216Ôćĺ// ignores the checking of that particular field. Example:
   217Ôćĺ//
   218Ôćĺ//   // Field is ignored by this package.
   219Ôćĺ//   Field bool `structs:"-"`
   220Ôćĺ//
   221Ôćĺ// It panics if s's kind is not struct.
   222Ôćĺfunc (s *Struct) Fields() []*Field {
   223Ôćĺ	return getFields(s.value, s.TagName)
   224Ôćĺ}
   226Ôćĺ// Names returns a slice of field names. A struct tag with the content of "-"
   227Ôćĺ// ignores the checking of that particular field. Example:
   228Ôćĺ//
   229Ôćĺ//   // Field is ignored by this package.
   230Ôćĺ//   Field bool `structs:"-"`
   231Ôćĺ//
   232Ôćĺ// It panics if s's kind is not struct.
   233Ôćĺfunc (s *Struct) Names() []string {
   234Ôćĺ	fields := getFields(s.value, s.TagName)
   235Ôćĺ
   236Ôćĺ	names := make([]string, len(fields))
   237Ôćĺ
   238Ôćĺ	for i, field := range fields {
   239Ôćĺ		names[i] = field.Name()
   240Ôćĺ	}
   241Ôćĺ
   242Ôćĺ	return names
   243Ôćĺ}
   245Ôćĺfunc getFields(v reflect.Value, tagName string) []*Field {
   246Ôćĺ	if v.Kind() == reflect.Ptr {
   247Ôćĺ		v = v.Elem()
   248Ôćĺ	}
   249Ôćĺ
   250Ôćĺ	t := v.Type()
   251Ôćĺ
   252Ôćĺ	var fields []*Field
   253Ôćĺ
   254Ôćĺ	for i := 0; i < t.NumField(); i++ {
   255Ôćĺ		field := t.Field(i)
   256Ôćĺ
   257Ôćĺ		if tag := field.Tag.Get(tagName); tag == "-" {
   258Ôćĺ			continue
   259Ôćĺ		}
   260Ôćĺ
   261Ôćĺ		f := &Field{
   262Ôćĺ			field: field,
   263Ôćĺ			value: v.FieldByName(field.Name),
   264Ôćĺ		}
   265Ôćĺ
   266Ôćĺ		fields = append(fields, f)
   267Ôćĺ
   268Ôćĺ	}
   269Ôćĺ
   270Ôćĺ	return fields
   271Ôćĺ}
   273Ôćĺ// Field returns a new Field struct that provides several high level functions
   274Ôćĺ// around a single struct field entity. It panics if the field is not found.
   275Ôćĺfunc (s *Struct) Field(name string) *Field {
   276Ôćĺ	f, ok := s.FieldOk(name)
   277Ôćĺ	if !ok {
   278Ôćĺ		panic("field not found")
   279Ôćĺ	}
   280Ôćĺ
   281Ôćĺ	return f
   282Ôćĺ}
   284Ôćĺ// FieldOk returns a new Field struct that provides several high level functions
   285Ôćĺ// around a single struct field entity. The boolean returns true if the field
   286Ôćĺ// was found.
   287Ôćĺfunc (s *Struct) FieldOk(name string) (*Field, bool) {
   288Ôćĺ	t := s.value.Type()
   289Ôćĺ
   290Ôćĺ	field, ok := t.FieldByName(name)
   291Ôćĺ	if !ok {
   292Ôćĺ		return nil, false
   293Ôćĺ	}
   294Ôćĺ
   295Ôćĺ	return &Field{
   296Ôćĺ		field:      field,
   297Ôćĺ		value:      s.value.FieldByName(name),
   298Ôćĺ		defaultTag: s.TagName,
   299Ôćĺ	}, true
   300Ôćĺ}
   302Ôćĺ// IsZero returns true if all fields in a struct is a zero value (not
   303Ôćĺ// initialized) A struct tag with the content of "-" ignores the checking of
   304Ôćĺ// that particular field. Example:
   305Ôćĺ//
   306Ôćĺ//   // Field is ignored by this package.
   307Ôćĺ//   Field bool `structs:"-"`
   308Ôćĺ//
   309Ôćĺ// A value with the option of "omitnested" stops iterating further if the type
   310Ôćĺ// is a struct. Example:
   311Ôćĺ//
   312Ôćĺ//   // Field is not processed further by this package.
   313Ôćĺ//   Field time.Time     `structs:"myName,omitnested"`
   314Ôćĺ//   Field *http.Request `structs:",omitnested"`
   315Ôćĺ//
   316Ôćĺ// Note that only exported fields of a struct can be accessed, non exported
   317Ôćĺ// fields  will be neglected. It panics if s's kind is not struct.
   318Ôćĺfunc (s *Struct) IsZero() bool {
   319Ôćĺ	fields := s.structFields()
   320Ôćĺ
   321Ôćĺ	for _, field := range fields {
   322Ôćĺ		val := s.value.FieldByName(field.Name)
   323Ôćĺ
   324Ôćĺ		_, tagOpts := parseTag(field.Tag.Get(s.TagName))
   325Ôćĺ
   326Ôćĺ		if IsStruct(val.Interface()) && !tagOpts.Has("omitnested") {
   327Ôćĺ			ok := IsZero(val.Interface())
   328Ôćĺ			if !ok {
   329Ôćĺ				return false
   330Ôćĺ			}
   331Ôćĺ
   332Ôćĺ			continue
   333Ôćĺ		}
   334Ôćĺ
   335Ôćĺ		// zero value of the given field, such as "" for string, 0 for int
   336Ôćĺ		zero := reflect.Zero(val.Type()).Interface()
   337Ôćĺ
   338Ôćĺ		//  current value of the given field
   339Ôćĺ		current := val.Interface()
   340Ôćĺ
   341Ôćĺ		if !reflect.DeepEqual(current, zero) {
   342Ôćĺ			return false
   343Ôćĺ		}
   344Ôćĺ	}
   345Ôćĺ
   346Ôćĺ	return true
   347Ôćĺ}
   349Ôćĺ// HasZero returns true if a field in a struct is not initialized (zero value).
   350Ôćĺ// A struct tag with the content of "-" ignores the checking of that particular
   351Ôćĺ// field. Example:

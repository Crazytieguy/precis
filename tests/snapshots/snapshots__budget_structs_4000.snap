   479ÔåÆ// HasZero returns true if any field is equal to a zero value. For more info
   480ÔåÆ// refer to Struct types HasZero() method.  It panics if s's kind is not struct.
   481ÔåÆfunc HasZero(s interface{}) bool {
   482ÔåÆ	return New(s).HasZero()
   483ÔåÆ}
   485ÔåÆ// IsStruct returns true if the given variable is a struct or a pointer to
   486ÔåÆ// struct.
   487ÔåÆfunc IsStruct(s interface{}) bool {
   488ÔåÆ	v := reflect.ValueOf(s)
   489ÔåÆ	if v.Kind() == reflect.Ptr {
   490ÔåÆ		v = v.Elem()
   491ÔåÆ	}
   492ÔåÆ
   493ÔåÆ	// uninitialized zero value of a struct
   494ÔåÆ	if v.Kind() == reflect.Invalid {
   495ÔåÆ		return false
   496ÔåÆ	}
   497ÔåÆ
   498ÔåÆ	return v.Kind() == reflect.Struct
   499ÔåÆ}
   501ÔåÆ// Name returns the structs's type name within its package. It returns an
   502ÔåÆ// empty string for unnamed types. It panics if s's kind is not struct.
   503ÔåÆfunc Name(s interface{}) string {
   504ÔåÆ	return New(s).Name()
   505ÔåÆ}
   507ÔåÆ// nested retrieves recursively all types for the given value and returns the
   508ÔåÆ// nested value.
   509ÔåÆfunc (s *Struct) nested(val reflect.Value) interface{} {
   510ÔåÆ	var finalVal interface{}
   511ÔåÆ
   512ÔåÆ	v := reflect.ValueOf(val.Interface())
   513ÔåÆ	if v.Kind() == reflect.Ptr {
   514ÔåÆ		v = v.Elem()
   515ÔåÆ	}
   516ÔåÆ
   517ÔåÆ	switch v.Kind() {
   518ÔåÆ	case reflect.Struct:
   519ÔåÆ		n := New(val.Interface())
   520ÔåÆ		n.TagName = s.TagName

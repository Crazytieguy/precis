field.go
     3‚Üíimport (
     4‚Üí	"errors"
     5‚Üí	"fmt"
     6‚Üí	"reflect"
     7‚Üí)
     9‚Üívar (
    10‚Üí	errNotExported = errors.New("field is not exported")
    11‚Üí	errNotSettable = errors.New("field is not settable")
    14‚Üí// Field represents a single struct field that encapsulates high level
    15‚Üí// functions around the field.
    16‚Üítype Field struct {
    17‚Üí	value      reflect.Value
    18‚Üí	field      reflect.StructField
    19‚Üí	defaultTag string
    20‚Üí}
    22‚Üí// Tag returns the value associated with key in the tag string. If there is no
    23‚Üí// such key in the tag, Tag returns the empty string.
    24‚Üífunc (f *Field) Tag(key string) string {
    25‚Üí	return f.field.Tag.Get(key)
    26‚Üí}
    28‚Üí// Value returns the underlying value of the field. It panics if the field
    29‚Üí// is not exported.
    30‚Üífunc (f *Field) Value() interface{} {
    31‚Üí	return f.value.Interface()
    32‚Üí}
    34‚Üí// IsEmbedded returns true if the given field is an anonymous field (embedded)
    35‚Üífunc (f *Field) IsEmbedded() bool {
    36‚Üí	return f.field.Anonymous
    37‚Üí}
    39‚Üí// IsExported returns true if the given field is exported.
    40‚Üífunc (f *Field) IsExported() bool {
    41‚Üí	return f.field.PkgPath == ""
    42‚Üí}
    44‚Üí// IsZero returns true if the given field is not initialized (has a zero value).
    45‚Üí// It panics if the field is not exported.
    46‚Üífunc (f *Field) IsZero() bool {
    47‚Üí	zero := reflect.Zero(f.value.Type()).Interface()
    48‚Üí	current := f.Value()
    49‚Üí
    50‚Üí	return reflect.DeepEqual(current, zero)
    51‚Üí}
    53‚Üí// Name returns the name of the given field
    54‚Üífunc (f *Field) Name() string {
    55‚Üí	return f.field.Name
    56‚Üí}
    58‚Üí// Kind returns the fields kind, such as "string", "map", "bool", etc ..
    59‚Üífunc (f *Field) Kind() reflect.Kind {
    60‚Üí	return f.value.Kind()
    61‚Üí}
    63‚Üí// Set sets the field to given value v. It returns an error if the field is not
    64‚Üí// settable (not addressable or not exported) or if the given value's type
    65‚Üí// doesn't match the fields type.
    66‚Üífunc (f *Field) Set(val interface{}) error {
    67‚Üí	// we can't set unexported fields, so be sure this field is exported
    68‚Üí	if !f.IsExported() {
    69‚Üí		return errNotExported
    70‚Üí	}
    71‚Üí
    72‚Üí	// do we get here? not sure...
    73‚Üí	if !f.value.CanSet() {
    74‚Üí		return errNotSettable
    75‚Üí	}
    76‚Üí
    77‚Üí	given := reflect.ValueOf(val)
    78‚Üí
    79‚Üí	if f.value.Kind() != given.Kind() {
    80‚Üí		return fmt.Errorf("wrong kind. got: %s want: %s", given.Kind(), f.value.Kind())
    81‚Üí	}
    82‚Üí
    83‚Üí	f.value.Set(given)
    84‚Üí	return nil
    85‚Üí}
    87‚Üí// Zero sets the field to its zero value. It returns an error if the field is not
    88‚Üí// settable (not addressable or not exported).
    89‚Üífunc (f *Field) Zero() error {
    90‚Üí	zero := reflect.Zero(f.value.Type()).Interface()
    91‚Üí	return f.Set(zero)
    92‚Üí}
    94‚Üí// Fields returns a slice of Fields. This is particular handy to get the fields
    95‚Üí// of a nested struct . A struct tag with the content of "-" ignores the
    96‚Üí// checking of that particular field. Example:
    97‚Üí//
    98‚Üí//   // Field is ignored by this package.
    99‚Üí//   Field *http.Request `structs:"-"`
   100‚Üí//
   101‚Üí// It panics if field is not exported or if field's kind is not struct
   102‚Üífunc (f *Field) Fields() []*Field {
   103‚Üí	return getFields(f.value, f.defaultTag)
   104‚Üí}
   106‚Üí// Field returns the field from a nested struct. It panics if the nested struct
   107‚Üí// is not exported or if the field was not found.
   108‚Üífunc (f *Field) Field(name string) *Field {
   109‚Üí	field, ok := f.FieldOk(name)
   110‚Üí	if !ok {
   111‚Üí		panic("field not found")
   112‚Üí	}
   113‚Üí
   114‚Üí	return field
   115‚Üí}
   117‚Üí// FieldOk returns the field from a nested struct. The boolean returns whether
   118‚Üí// the field was found (true) or not (false).
   119‚Üífunc (f *Field) FieldOk(name string) (*Field, bool) {
   120‚Üí	value := &f.value
   121‚Üí	// value must be settable so we need to make sure it holds the address of the
   122‚Üí	// variable and not a copy, so we can pass the pointer to strctVal instead of a
   123‚Üí	// copy (which is not assigned to any variable, hence not settable).
   124‚Üí	// see "https://blog.golang.org/laws-of-reflection#TOC_8."
   125‚Üí	if f.value.Kind() != reflect.Ptr {
   126‚Üí		a := f.value.Addr()
   127‚Üí		value = &a
   128‚Üí	}
   129‚Üí	v := strctVal(value.Interface())
   130‚Üí	t := v.Type()
   131‚Üí
   132‚Üí	field, ok := t.FieldByName(name)
   133‚Üí	if !ok {
   134‚Üí		return nil, false
   135‚Üí	}
   136‚Üí
   137‚Üí	return &Field{
   138‚Üí		field: field,
   139‚Üí		value: v.FieldByName(name),
   140‚Üí	}, true
   141‚Üí}


structs.go
     4‚Üíimport (
     5‚Üí	"fmt"
     6‚Üí
     7‚Üí	"reflect"
     8‚Üí)
    10‚Üívar (
    11‚Üí	// DefaultTagName is the default tag name for struct fields which provides
    12‚Üí	// a more granular to tweak certain structs. Lookup the necessary functions
    13‚Üí	// for more info.
    14‚Üí	DefaultTagName = "structs" // struct's field default tag name
    17‚Üí// Struct encapsulates a struct type to provide several high level functions
    18‚Üí// around the struct.
    19‚Üítype Struct struct {
    20‚Üí	raw     interface{}
    21‚Üí	value   reflect.Value
    22‚Üí	TagName string
    23‚Üí}
    25‚Üí// New returns a new *Struct with the struct s. It panics if the s's kind is
    26‚Üí// not struct.
    27‚Üífunc New(s interface{}) *Struct {
    28‚Üí	return &Struct{
    29‚Üí		raw:     s,
    30‚Üí		value:   strctVal(s),
    31‚Üí		TagName: DefaultTagName,
    32‚Üí	}
    33‚Üí}
    35‚Üí// Map converts the given struct to a map[string]interface{}, where the keys
    36‚Üí// of the map are the field names and the values of the map the associated
    37‚Üí// values of the fields. The default key string is the struct field name but
    38‚Üí// can be changed in the struct field's tag value. The "structs" key in the
    39‚Üí// struct's field tag value is the key name. Example:
    40‚Üí//
    41‚Üí//   // Field appears in map as key "myName".
    42‚Üí//   Name string `structs:"myName"`
    43‚Üí//
    44‚Üí// A tag value with the content of "-" ignores that particular field. Example:
    45‚Üí//
    46‚Üí//   // Field is ignored by this package.
    47‚Üí//   Field bool `structs:"-"`
    48‚Üí//
    49‚Üí// A tag value with the content of "string" uses the stringer to get the value. Example:
    50‚Üí//
    51‚Üí//   // The value will be output of Animal's String() func.
    52‚Üí//   // Map will panic if Animal does not implement String().
    53‚Üí//   Field *Animal `structs:"field,string"`
    54‚Üí//
    55‚Üí// A tag value with the option of "flatten" used in a struct field is to flatten its fields
    56‚Üí// in the output map. Example:
    57‚Üí//
    58‚Üí//   // The FieldStruct's fields will be flattened into the output map.
    59‚Üí//   FieldStruct time.Time `structs:",flatten"`
    60‚Üí//
    61‚Üí// A tag value with the option of "omitnested" stops iterating further if the type
    62‚Üí// is a struct. Example:
    63‚Üí//
    64‚Üí//   // Field is not processed further by this package.
    65‚Üí//   Field time.Time     `structs:"myName,omitnested"`
    66‚Üí//   Field *http.Request `structs:",omitnested"`
    67‚Üí//
    68‚Üí// A tag value with the option of "omitempty" ignores that particular field if
    69‚Üí// the field value is empty. Example:
    70‚Üí//
    71‚Üí//   // Field appears in map as key "myName", but the field is
    72‚Üí//   // skipped if empty.
    73‚Üí//   Field string `structs:"myName,omitempty"`
    74‚Üí//
    75‚Üí//   // Field appears in map as key "Field" (the default), but
    76‚Üí//   // the field is skipped if empty.
    77‚Üí//   Field string `structs:",omitempty"`
    78‚Üí//
    79‚Üí// Note that only exported fields of a struct can be accessed, non exported
    80‚Üí// fields will be neglected.
    81‚Üífunc (s *Struct) Map() map[string]interface{} {
    82‚Üí	out := make(map[string]interface{})
    83‚Üí	s.FillMap(out)
    84‚Üí	return out
    85‚Üí}
    87‚Üí// FillMap is the same as Map. Instead of returning the output, it fills the
    88‚Üí// given map.
    89‚Üífunc (s *Struct) FillMap(out map[string]interface{}) {
    90‚Üí	if out == nil {
    91‚Üí		return
    92‚Üí	}
    93‚Üí
    94‚Üí	fields := s.structFields()
    95‚Üí
    96‚Üí	for _, field := range fields {
    97‚Üí		name := field.Name
    98‚Üí		val := s.value.FieldByName(name)
    99‚Üí		isSubStruct := false
   100‚Üí		var finalVal interface{}
   101‚Üí
   102‚Üí		tagName, tagOpts := parseTag(field.Tag.Get(s.TagName))
   103‚Üí		if tagName != "" {
   104‚Üí			name = tagName
   105‚Üí		}
   106‚Üí
   107‚Üí		// if the value is a zero value and the field is marked as omitempty do
   108‚Üí		// not include
   109‚Üí		if tagOpts.Has("omitempty") {
   110‚Üí			zero := reflect.Zero(val.Type()).Interface()
   111‚Üí			current := val.Interface()
   112‚Üí
   113‚Üí			if reflect.DeepEqual(current, zero) {
   114‚Üí				continue
   115‚Üí			}
   116‚Üí		}
   117‚Üí
   118‚Üí		if !tagOpts.Has("omitnested") {
   119‚Üí			finalVal = s.nested(val)
   120‚Üí
   121‚Üí			v := reflect.ValueOf(val.Interface())
   122‚Üí			if v.Kind() == reflect.Ptr {
   123‚Üí				v = v.Elem()
   124‚Üí			}
   125‚Üí
   126‚Üí			switch v.Kind() {
   127‚Üí			case reflect.Map, reflect.Struct:
   128‚Üí				isSubStruct = true
   129‚Üí			}
   130‚Üí		} else {
   131‚Üí			finalVal = val.Interface()
   132‚Üí		}
   133‚Üí
   134‚Üí		if tagOpts.Has("string") {
   135‚Üí			s, ok := val.Interface().(fmt.Stringer)
   136‚Üí			if ok {
   137‚Üí				out[name] = s.String()
   138‚Üí			}
   139‚Üí			continue
   140‚Üí		}
   141‚Üí
   142‚Üí		if isSubStruct && (tagOpts.Has("flatten")) {
   143‚Üí			for k := range finalVal.(map[string]interface{}) {
   144‚Üí				out[k] = finalVal.(map[string]interface{})[k]
   145‚Üí			}
   146‚Üí		} else {
   147‚Üí			out[name] = finalVal
   148‚Üí		}
   149‚Üí	}
   150‚Üí}
   152‚Üí// Values converts the given s struct's field values to a []interface{}.  A
   153‚Üí// struct tag with the content of "-" ignores the that particular field.
   154‚Üí// Example:
   155‚Üí//
   156‚Üí//   // Field is ignored by this package.
   157‚Üí//   Field int `structs:"-"`
   158‚Üí//
   159‚Üí// A value with the option of "omitnested" stops iterating further if the type
   160‚Üí// is a struct. Example:
   161‚Üí//
   162‚Üí//   // Fields is not processed further by this package.
   163‚Üí//   Field time.Time     `structs:",omitnested"`
   164‚Üí//   Field *http.Request `structs:",omitnested"`
   165‚Üí//
   166‚Üí// A tag value with the option of "omitempty" ignores that particular field and
   167‚Üí// is not added to the values if the field value is empty. Example:
   168‚Üí//
   169‚Üí//   // Field is skipped if empty
   170‚Üí//   Field string `structs:",omitempty"`
   171‚Üí//
   172‚Üí// Note that only exported fields of a struct can be accessed, non exported
   173‚Üí// fields  will be neglected.
   174‚Üífunc (s *Struct) Values() []interface{} {
   175‚Üí	fields := s.structFields()
   176‚Üí
   177‚Üí	var t []interface{}
   178‚Üí
   179‚Üí	for _, field := range fields {
   180‚Üí		val := s.value.FieldByName(field.Name)
   181‚Üí
   182‚Üí		_, tagOpts := parseTag(field.Tag.Get(s.TagName))
   183‚Üí
   184‚Üí		// if the value is a zero value and the field is marked as omitempty do
   185‚Üí		// not include
   186‚Üí		if tagOpts.Has("omitempty") {
   187‚Üí			zero := reflect.Zero(val.Type()).Interface()
   188‚Üí			current := val.Interface()
   189‚Üí
   190‚Üí			if reflect.DeepEqual(current, zero) {
   191‚Üí				continue
   192‚Üí			}
   193‚Üí		}
   194‚Üí
   195‚Üí		if tagOpts.Has("string") {
   196‚Üí			s, ok := val.Interface().(fmt.Stringer)
   197‚Üí			if ok {
   198‚Üí				t = append(t, s.String())
   199‚Üí			}
   200‚Üí			continue
   201‚Üí		}
   202‚Üí
   203‚Üí		if IsStruct(val.Interface()) && !tagOpts.Has("omitnested") {
   204‚Üí			// look out for embedded structs, and convert them to a
   205‚Üí			// []interface{} to be added to the final values slice
   206‚Üí			t = append(t, Values(val.Interface())...)
   207‚Üí		} else {
   208‚Üí			t = append(t, val.Interface())
   209‚Üí		}
   210‚Üí	}
   211‚Üí
   212‚Üí	return t
   213‚Üí}
   215‚Üí// Fields returns a slice of Fields. A struct tag with the content of "-"
   216‚Üí// ignores the checking of that particular field. Example:
   217‚Üí//
   218‚Üí//   // Field is ignored by this package.
   219‚Üí//   Field bool `structs:"-"`
   220‚Üí//
   221‚Üí// It panics if s's kind is not struct.
   222‚Üífunc (s *Struct) Fields() []*Field {
   223‚Üí	return getFields(s.value, s.TagName)
   224‚Üí}
   226‚Üí// Names returns a slice of field names. A struct tag with the content of "-"
   227‚Üí// ignores the checking of that particular field. Example:
   228‚Üí//
   229‚Üí//   // Field is ignored by this package.
   230‚Üí//   Field bool `structs:"-"`
   231‚Üí//
   232‚Üí// It panics if s's kind is not struct.
   233‚Üífunc (s *Struct) Names() []string {
   234‚Üí	fields := getFields(s.value, s.TagName)
   235‚Üí
   236‚Üí	names := make([]string, len(fields))
   237‚Üí
   238‚Üí	for i, field := range fields {
   239‚Üí		names[i] = field.Name()
   240‚Üí	}
   241‚Üí
   242‚Üí	return names
   243‚Üí}
   245‚Üífunc getFields(v reflect.Value, tagName string) []*Field {
   246‚Üí	if v.Kind() == reflect.Ptr {
   247‚Üí		v = v.Elem()
   248‚Üí	}
   249‚Üí
   250‚Üí	t := v.Type()
   251‚Üí
   252‚Üí	var fields []*Field
   253‚Üí
   254‚Üí	for i := 0; i < t.NumField(); i++ {
   255‚Üí		field := t.Field(i)
   256‚Üí
   257‚Üí		if tag := field.Tag.Get(tagName); tag == "-" {
   258‚Üí			continue
   259‚Üí		}
   260‚Üí
   261‚Üí		f := &Field{
   262‚Üí			field: field,
   263‚Üí			value: v.FieldByName(field.Name),
   264‚Üí		}
   265‚Üí
      ‚Üí‚Ä¶
   273‚Üí// Field returns a new Field struct that provides several high level functions
   274‚Üí// around a single struct field entity. It panics if the field is not found.
   275‚Üífunc (s *Struct) Field(name string) *Field {
   276‚Üí	f, ok := s.FieldOk(name)
   277‚Üí	if !ok {
   278‚Üí		panic("field not found")
   279‚Üí	}
   280‚Üí
   281‚Üí	return f
   282‚Üí}
   284‚Üí// FieldOk returns a new Field struct that provides several high level functions
   285‚Üí// around a single struct field entity. The boolean returns true if the field
   286‚Üí// was found.
   287‚Üífunc (s *Struct) FieldOk(name string) (*Field, bool) {
   288‚Üí	t := s.value.Type()
   289‚Üí
   290‚Üí	field, ok := t.FieldByName(name)
   291‚Üí	if !ok {
   292‚Üí		return nil, false
   293‚Üí	}
   294‚Üí
   295‚Üí	return &Field{
   296‚Üí		field:      field,
   297‚Üí		value:      s.value.FieldByName(name),
   298‚Üí		defaultTag: s.TagName,
   299‚Üí	}, true
   300‚Üí}
   302‚Üí// IsZero returns true if all fields in a struct is a zero value (not
   303‚Üí// initialized) A struct tag with the content of "-" ignores the checking of
   304‚Üí// that particular field. Example:
   305‚Üí//
   306‚Üí//   // Field is ignored by this package.
   307‚Üí//   Field bool `structs:"-"`
   308‚Üí//
   309‚Üí// A value with the option of "omitnested" stops iterating further if the type
   310‚Üí// is a struct. Example:
   311‚Üí//
   312‚Üí//   // Field is not processed further by this package.
   313‚Üí//   Field time.Time     `structs:"myName,omitnested"`
   314‚Üí//   Field *http.Request `structs:",omitnested"`
   315‚Üí//
   316‚Üí// Note that only exported fields of a struct can be accessed, non exported
   317‚Üí// fields  will be neglected. It panics if s's kind is not struct.
   318‚Üífunc (s *Struct) IsZero() bool {
   319‚Üí	fields := s.structFields()
   320‚Üí
   321‚Üí	for _, field := range fields {
   322‚Üí		val := s.value.FieldByName(field.Name)
   323‚Üí
   324‚Üí		_, tagOpts := parseTag(field.Tag.Get(s.TagName))
   325‚Üí
   326‚Üí		if IsStruct(val.Interface()) && !tagOpts.Has("omitnested") {
   327‚Üí			ok := IsZero(val.Interface())
   328‚Üí			if !ok {
   329‚Üí				return false
   330‚Üí			}
   331‚Üí
   332‚Üí			continue
   333‚Üí		}
   334‚Üí
   335‚Üí		// zero value of the given field, such as "" for string, 0 for int
   336‚Üí		zero := reflect.Zero(val.Type()).Interface()
   337‚Üí
   338‚Üí		//  current value of the given field
   339‚Üí		current := val.Interface()
   340‚Üí
   341‚Üí		if !reflect.DeepEqual(current, zero) {
   342‚Üí			return false
   343‚Üí		}
   344‚Üí	}
   345‚Üí
   346‚Üí	return true
   347‚Üí}
   349‚Üí// HasZero returns true if a field in a struct is not initialized (zero value).
   350‚Üí// A struct tag with the content of "-" ignores the checking of that particular
   351‚Üí// field. Example:
   352‚Üí//
   353‚Üí//   // Field is ignored by this package.
   354‚Üí//   Field bool `structs:"-"`
   355‚Üí//
   356‚Üí// A value with the option of "omitnested" stops iterating further if the type
   357‚Üí// is a struct. Example:
   358‚Üí//
   359‚Üí//   // Field is not processed further by this package.
   360‚Üí//   Field time.Time     `structs:"myName,omitnested"`
   361‚Üí//   Field *http.Request `structs:",omitnested"`
   362‚Üí//
   363‚Üí// Note that only exported fields of a struct can be accessed, non exported
   364‚Üí// fields  will be neglected. It panics if s's kind is not struct.
   365‚Üífunc (s *Struct) HasZero() bool {
   366‚Üí	fields := s.structFields()
   367‚Üí
   368‚Üí	for _, field := range fields {
   369‚Üí		val := s.value.FieldByName(field.Name)
   370‚Üí
   371‚Üí		_, tagOpts := parseTag(field.Tag.Get(s.TagName))
   372‚Üí
   373‚Üí		if IsStruct(val.Interface()) && !tagOpts.Has("omitnested") {
   374‚Üí			ok := HasZero(val.Interface())
   375‚Üí			if ok {
   376‚Üí				return true
   377‚Üí			}
   378‚Üí
   379‚Üí			continue
   380‚Üí		}
   381‚Üí
   382‚Üí		// zero value of the given field, such as "" for string, 0 for int
   383‚Üí		zero := reflect.Zero(val.Type()).Interface()
   384‚Üí
   385‚Üí		//  current value of the given field
   386‚Üí		current := val.Interface()
   387‚Üí
   388‚Üí		if reflect.DeepEqual(current, zero) {
   389‚Üí			return true
   390‚Üí		}
   391‚Üí	}
   392‚Üí
   393‚Üí	return false
   394‚Üí}
   396‚Üí// Name returns the structs's type name within its package. For more info refer
   397‚Üí// to Name() function.
   398‚Üífunc (s *Struct) Name() string {
   399‚Üí	return s.value.Type().Name()
   400‚Üí}
   402‚Üí// structFields returns the exported struct fields for a given s struct. This
   403‚Üí// is a convenient helper method to avoid duplicate code in some of the
   404‚Üí// functions.
   405‚Üífunc (s *Struct) structFields() []reflect.StructField {
   406‚Üí	t := s.value.Type()
   407‚Üí
   408‚Üí	var f []reflect.StructField
   409‚Üí
   410‚Üí	for i := 0; i < t.NumField(); i++ {
   411‚Üí		field := t.Field(i)
   412‚Üí		// we can't access the value of unexported fields
   413‚Üí		if field.PkgPath != "" {
   414‚Üí			continue
   415‚Üí		}
   416‚Üí
      ‚Üí‚Ä¶
   428‚Üífunc strctVal(s interface{}) reflect.Value {
   429‚Üí	v := reflect.ValueOf(s)
   430‚Üí
   431‚Üí	// if pointer get the underlying element‚â§
   432‚Üí	for v.Kind() == reflect.Ptr {
   433‚Üí		v = v.Elem()
   434‚Üí	}
   435‚Üí
   436‚Üí	if v.Kind() != reflect.Struct {
   437‚Üí		panic("not struct")
   438‚Üí	}
   439‚Üí
   440‚Üí	return v
   441‚Üí}
   443‚Üí// Map converts the given struct to a map[string]interface{}. For more info
   444‚Üí// refer to Struct types Map() method. It panics if s's kind is not struct.
   445‚Üífunc Map(s interface{}) map[string]interface{} {
   446‚Üí	return New(s).Map()
   447‚Üí}
   449‚Üí// FillMap is the same as Map. Instead of returning the output, it fills the
   450‚Üí// given map.
   451‚Üífunc FillMap(s interface{}, out map[string]interface{}) {
   452‚Üí	New(s).FillMap(out)
   453‚Üí}
   455‚Üí// Values converts the given struct to a []interface{}. For more info refer to
   456‚Üí// Struct types Values() method.  It panics if s's kind is not struct.
   457‚Üífunc Values(s interface{}) []interface{} {
   458‚Üí	return New(s).Values()
   459‚Üí}
   461‚Üí// Fields returns a slice of *Field. For more info refer to Struct types
   462‚Üí// Fields() method.  It panics if s's kind is not struct.
   463‚Üífunc Fields(s interface{}) []*Field {
   464‚Üí	return New(s).Fields()
   465‚Üí}
   467‚Üí// Names returns a slice of field names. For more info refer to Struct types
   468‚Üí// Names() method.  It panics if s's kind is not struct.
   469‚Üífunc Names(s interface{}) []string {
   470‚Üí	return New(s).Names()
   471‚Üí}
   473‚Üí// IsZero returns true if all fields is equal to a zero value. For more info
   474‚Üí// refer to Struct types IsZero() method.  It panics if s's kind is not struct.
   475‚Üífunc IsZero(s interface{}) bool {
   476‚Üí	return New(s).IsZero()
   477‚Üí}
   479‚Üí// HasZero returns true if any field is equal to a zero value. For more info
   480‚Üí// refer to Struct types HasZero() method.  It panics if s's kind is not struct.
   481‚Üífunc HasZero(s interface{}) bool {
   482‚Üí	return New(s).HasZero()
   483‚Üí}
   485‚Üí// IsStruct returns true if the given variable is a struct or a pointer to
   486‚Üí// struct.
   487‚Üífunc IsStruct(s interface{}) bool {
   488‚Üí	v := reflect.ValueOf(s)
   489‚Üí	if v.Kind() == reflect.Ptr {
   490‚Üí		v = v.Elem()
   491‚Üí	}
   492‚Üí
   493‚Üí	// uninitialized zero value of a struct
   494‚Üí	if v.Kind() == reflect.Invalid {
   495‚Üí		return false
   496‚Üí	}
   497‚Üí
   498‚Üí	return v.Kind() == reflect.Struct
   499‚Üí}
   501‚Üí// Name returns the structs's type name within its package. It returns an
   502‚Üí// empty string for unnamed types. It panics if s's kind is not struct.
   503‚Üífunc Name(s interface{}) string {
   504‚Üí	return New(s).Name()
   505‚Üí}
   507‚Üí// nested retrieves recursively all types for the given value and returns the
   508‚Üí// nested value.
   509‚Üífunc (s *Struct) nested(val reflect.Value) interface{} {
   510‚Üí	var finalVal interface{}
   511‚Üí
   512‚Üí	v := reflect.ValueOf(val.Interface())
   513‚Üí	if v.Kind() == reflect.Ptr {
   514‚Üí		v = v.Elem()
   515‚Üí	}
   516‚Üí
   517‚Üí	switch v.Kind() {
   518‚Üí	case reflect.Struct:
   519‚Üí		n := New(val.Interface())
   520‚Üí		n.TagName = s.TagName
      ‚Üí‚Ä¶


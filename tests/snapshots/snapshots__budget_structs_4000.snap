   443ÔåÆ// Map converts the given struct to a map[string]interface{}. For more info
   444ÔåÆ// refer to Struct types Map() method. It panics if s's kind is not struct.
   445ÔåÆfunc Map(s interface{}) map[string]interface{} {
   446ÔåÆ	return New(s).Map()
   447ÔåÆ}
   449ÔåÆ// FillMap is the same as Map. Instead of returning the output, it fills the
   450ÔåÆ// given map.
   451ÔåÆfunc FillMap(s interface{}, out map[string]interface{}) {
   452ÔåÆ	New(s).FillMap(out)
   453ÔåÆ}
   455ÔåÆ// Values converts the given struct to a []interface{}. For more info refer to
   456ÔåÆ// Struct types Values() method.  It panics if s's kind is not struct.
   457ÔåÆfunc Values(s interface{}) []interface{} {
   458ÔåÆ	return New(s).Values()
   459ÔåÆ}
   461ÔåÆ// Fields returns a slice of *Field. For more info refer to Struct types
   462ÔåÆ// Fields() method.  It panics if s's kind is not struct.
   463ÔåÆfunc Fields(s interface{}) []*Field {
   464ÔåÆ	return New(s).Fields()
   465ÔåÆ}
   467ÔåÆ// Names returns a slice of field names. For more info refer to Struct types
   468ÔåÆ// Names() method.  It panics if s's kind is not struct.
   469ÔåÆfunc Names(s interface{}) []string {

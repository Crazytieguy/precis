tags.go
     3ÔåÆimport "strings"
     5ÔåÆ// tagOptions contains a slice of tag options
     6ÔåÆtype tagOptions []string
     8ÔåÆ// Has returns true if the given option is available in tagOptions
     9ÔåÆfunc (t tagOptions) Has(opt string) bool {
    10ÔåÆ	for _, tagOpt := range t {
    11ÔåÆ		if tagOpt == opt {
    12ÔåÆ			return true
    13ÔåÆ		}
    14ÔåÆ	}
    15ÔåÆ
    16ÔåÆ	return false
    17ÔåÆ}
    19ÔåÆ// parseTag splits a struct field's tag into its name and a list of options
    20ÔåÆ// which comes after a name. A tag is in the form of: "name,option1,option2".
    21ÔåÆ// The name can be neglectected.
    22ÔåÆfunc parseTag(tag string) (string, tagOptions) {
    23ÔåÆ	// tag is one of followings:
    24ÔåÆ	// ""
    25ÔåÆ	// "name"
    26ÔåÆ	// "name,opt"
    27ÔåÆ	// "name,opt,opt2"
    28ÔåÆ	// ",opt"
    29ÔåÆ
    30ÔåÆ	res := strings.Split(tag, ",")
    31ÔåÆ	return res[0], res[1:]
    32ÔåÆ}

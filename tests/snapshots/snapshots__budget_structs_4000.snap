     3ÔåÆimport (
     4ÔåÆ	"errors"
     5ÔåÆ	"fmt"
     6ÔåÆ	"reflect"
     7ÔåÆ)
     9ÔåÆvar (
    10ÔåÆ	errNotExported = errors.New("field is not exported")
    11ÔåÆ	errNotSettable = errors.New("field is not settable")
    14ÔåÆ// Field represents a single struct field that encapsulates high level
    15ÔåÆ// functions around the field.
    16ÔåÆtype Field struct {
    17ÔåÆ	value      reflect.Value
    18ÔåÆ	field      reflect.StructField
    19ÔåÆ	defaultTag string
    20ÔåÆ}
    22ÔåÆ// Tag returns the value associated with key in the tag string. If there is no
    23ÔåÆ// such key in the tag, Tag returns the empty string.
    24ÔåÆfunc (f *Field) Tag(key string) string {
    25ÔåÆ	return f.field.Tag.Get(key)
    26ÔåÆ}
    28ÔåÆ// Value returns the underlying value of the field. It panics if the field
    29ÔåÆ// is not exported.
    30ÔåÆfunc (f *Field) Value() interface{} {
    31ÔåÆ	return f.value.Interface()
    32ÔåÆ}
    34ÔåÆ// IsEmbedded returns true if the given field is an anonymous field (embedded)
    35ÔåÆfunc (f *Field) IsEmbedded() bool {
    36ÔåÆ	return f.field.Anonymous
    37ÔåÆ}
    39ÔåÆ// IsExported returns true if the given field is exported.
    40ÔåÆfunc (f *Field) IsExported() bool {
    41ÔåÆ	return f.field.PkgPath == ""
    42ÔåÆ}
    44ÔåÆ// IsZero returns true if the given field is not initialized (has a zero value).
    45ÔåÆ// It panics if the field is not exported.
    46ÔåÆfunc (f *Field) IsZero() bool {
    47ÔåÆ	zero := reflect.Zero(f.value.Type()).Interface()
    48ÔåÆ	current := f.Value()
    49ÔåÆ
    50ÔåÆ	return reflect.DeepEqual(current, zero)
    51ÔåÆ}
    53ÔåÆ// Name returns the name of the given field
    54ÔåÆfunc (f *Field) Name() string {
    55ÔåÆ	return f.field.Name
    56ÔåÆ}
    58ÔåÆ// Kind returns the fields kind, such as "string", "map", "bool", etc ..
    59ÔåÆfunc (f *Field) Kind() reflect.Kind {
    60ÔåÆ	return f.value.Kind()
    61ÔåÆ}
    63ÔåÆ// Set sets the field to given value v. It returns an error if the field is not
    64ÔåÆ// settable (not addressable or not exported) or if the given value's type
    65ÔåÆ// doesn't match the fields type.
    66ÔåÆfunc (f *Field) Set(val interface{}) error {
    67ÔåÆ	// we can't set unexported fields, so be sure this field is exported
    68ÔåÆ	if !f.IsExported() {
    69ÔåÆ		return errNotExported
    70ÔåÆ	}
    71ÔåÆ
    72ÔåÆ	// do we get here? not sure...
    73ÔåÆ	if !f.value.CanSet() {
    74ÔåÆ		return errNotSettable
    75ÔåÆ	}
    76ÔåÆ
    77ÔåÆ	given := reflect.ValueOf(val)
    78ÔåÆ
    79ÔåÆ	if f.value.Kind() != given.Kind() {
    80ÔåÆ		return fmt.Errorf("wrong kind. got: %s want: %s", given.Kind(), f.value.Kind())
    81ÔåÆ	}
    82ÔåÆ
    83ÔåÆ	f.value.Set(given)
    84ÔåÆ	return nil
    85ÔåÆ}
    87ÔåÆ// Zero sets the field to its zero value. It returns an error if the field is not
    88ÔåÆ// settable (not addressable or not exported).
    89ÔåÆfunc (f *Field) Zero() error {
    90ÔåÆ	zero := reflect.Zero(f.value.Type()).Interface()
    91ÔåÆ	return f.Set(zero)
    92ÔåÆ}
    94ÔåÆ// Fields returns a slice of Fields. This is particular handy to get the fields
    95ÔåÆ// of a nested struct . A struct tag with the content of "-" ignores the
    96ÔåÆ// checking of that particular field. Example:
    97ÔåÆ//
    98ÔåÆ//   // Field is ignored by this package.
    99ÔåÆ//   Field *http.Request `structs:"-"`
   100ÔåÆ//
   101ÔåÆ// It panics if field is not exported or if field's kind is not struct
   102ÔåÆfunc (f *Field) Fields() []*Field {
   103ÔåÆ	return getFields(f.value, f.defaultTag)
   104ÔåÆ}
   106ÔåÆ// Field returns the field from a nested struct. It panics if the nested struct
   107ÔåÆ// is not exported or if the field was not found.
   108ÔåÆfunc (f *Field) Field(name string) *Field {
   109ÔåÆ	field, ok := f.FieldOk(name)
   110ÔåÆ	if !ok {
   111ÔåÆ		panic("field not found")
   112ÔåÆ	}
   113ÔåÆ
   114ÔåÆ	return field
   115ÔåÆ}
   117ÔåÆ// FieldOk returns the field from a nested struct. The boolean returns whether
   118ÔåÆ// the field was found (true) or not (false).
   119ÔåÆfunc (f *Field) FieldOk(name string) (*Field, bool) {
   120ÔåÆ	value := &f.value
   121ÔåÆ	// value must be settable so we need to make sure it holds the address of the
   122ÔåÆ	// variable and not a copy, so we can pass the pointer to strctVal instead of a
   123ÔåÆ	// copy (which is not assigned to any variable, hence not settable).
   124ÔåÆ	// see "https://blog.golang.org/laws-of-reflection#TOC_8."
   125ÔåÆ	if f.value.Kind() != reflect.Ptr {
   126ÔåÆ		a := f.value.Addr()
   127ÔåÆ		value = &a
   128ÔåÆ	}
   129ÔåÆ	v := strctVal(value.Interface())
   130ÔåÆ	t := v.Type()
   131ÔåÆ
   132ÔåÆ	field, ok := t.FieldByName(name)
   133ÔåÆ	if !ok {
   134ÔåÆ		return nil, false
   135ÔåÆ	}
   136ÔåÆ
   137ÔåÆ	return &Field{
   138ÔåÆ		field: field,
   139ÔåÆ		value: v.FieldByName(name),
   140ÔåÆ	}, true
   141ÔåÆ}

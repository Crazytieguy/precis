   485Ôćĺ// IsStruct returns true if the given variable is a struct or a pointer to
   486Ôćĺ// struct.
   487Ôćĺfunc IsStruct(s interface{}) bool {
   488Ôćĺ	v := reflect.ValueOf(s)
   489Ôćĺ	if v.Kind() == reflect.Ptr {
   490Ôćĺ		v = v.Elem()

structs.go
     4ÔåÆimport (
     5ÔåÆ	"fmt"
     6ÔåÆ
     7ÔåÆ	"reflect"
     8ÔåÆ)
    10ÔåÆvar (
    11ÔåÆ	// DefaultTagName is the default tag name for struct fields which provides
    12ÔåÆ	// a more granular to tweak certain structs. Lookup the necessary functions
    13ÔåÆ	// for more info.
    14ÔåÆ	DefaultTagName = "structs" // struct's field default tag name
    17ÔåÆ// Struct encapsulates a struct type to provide several high level functions
    18ÔåÆ// around the struct.
    19ÔåÆtype Struct struct {
    20ÔåÆ	raw     interface{}
    21ÔåÆ	value   reflect.Value
    22ÔåÆ	TagName string
    23ÔåÆ}
    25ÔåÆ// New returns a new *Struct with the struct s. It panics if the s's kind is
    26ÔåÆ// not struct.
    27ÔåÆfunc New(s interface{}) *Struct {
    28ÔåÆ	return &Struct{
    29ÔåÆ		raw:     s,
    30ÔåÆ		value:   strctVal(s),
    31ÔåÆ		TagName: DefaultTagName,
    32ÔåÆ	}
    33ÔåÆ}
    35ÔåÆ// Map converts the given struct to a map[string]interface{}, where the keys
    36ÔåÆ// of the map are the field names and the values of the map the associated
    37ÔåÆ// values of the fields. The default key string is the struct field name but
    38ÔåÆ// can be changed in the struct field's tag value. The "structs" key in the
    39ÔåÆ// struct's field tag value is the key name. Example:
    40ÔåÆ//
    41ÔåÆ//   // Field appears in map as key "myName".
    42ÔåÆ//   Name string `structs:"myName"`
    43ÔåÆ//
    44ÔåÆ// A tag value with the content of "-" ignores that particular field. Example:
    45ÔåÆ//
    46ÔåÆ//   // Field is ignored by this package.
    47ÔåÆ//   Field bool `structs:"-"`
    48ÔåÆ//
    49ÔåÆ// A tag value with the content of "string" uses the stringer to get the value. Example:
    50ÔåÆ//
    51ÔåÆ//   // The value will be output of Animal's String() func.
    52ÔåÆ//   // Map will panic if Animal does not implement String().
    53ÔåÆ//   Field *Animal `structs:"field,string"`
    54ÔåÆ//
    55ÔåÆ// A tag value with the option of "flatten" used in a struct field is to flatten its fields
    56ÔåÆ// in the output map. Example:
    57ÔåÆ//
    58ÔåÆ//   // The FieldStruct's fields will be flattened into the output map.
    59ÔåÆ//   FieldStruct time.Time `structs:",flatten"`
    60ÔåÆ//
    61ÔåÆ// A tag value with the option of "omitnested" stops iterating further if the type
    62ÔåÆ// is a struct. Example:
    63ÔåÆ//
    64ÔåÆ//   // Field is not processed further by this package.
    65ÔåÆ//   Field time.Time     `structs:"myName,omitnested"`
    66ÔåÆ//   Field *http.Request `structs:",omitnested"`
    67ÔåÆ//
    68ÔåÆ// A tag value with the option of "omitempty" ignores that particular field if
    69ÔåÆ// the field value is empty. Example:
    70ÔåÆ//
    71ÔåÆ//   // Field appears in map as key "myName", but the field is
    72ÔåÆ//   // skipped if empty.
    73ÔåÆ//   Field string `structs:"myName,omitempty"`
    74ÔåÆ//
    75ÔåÆ//   // Field appears in map as key "Field" (the default), but
    76ÔåÆ//   // the field is skipped if empty.
    77ÔåÆ//   Field string `structs:",omitempty"`
    78ÔåÆ//
    79ÔåÆ// Note that only exported fields of a struct can be accessed, non exported
    80ÔåÆ// fields will be neglected.
    81ÔåÆfunc (s *Struct) Map() map[string]interface{} {
    82ÔåÆ	out := make(map[string]interface{})
    83ÔåÆ	s.FillMap(out)
    84ÔåÆ	return out
    85ÔåÆ}
    87ÔåÆ// FillMap is the same as Map. Instead of returning the output, it fills the
    88ÔåÆ// given map.
    89ÔåÆfunc (s *Struct) FillMap(out map[string]interface{}) {
    90ÔåÆ	if out == nil {
    91ÔåÆ		return
    92ÔåÆ	}
    93ÔåÆ
    94ÔåÆ	fields := s.structFields()
    95ÔåÆ
    96ÔåÆ	for _, field := range fields {
    97ÔåÆ		name := field.Name
    98ÔåÆ		val := s.value.FieldByName(name)
    99ÔåÆ		isSubStruct := false
   100ÔåÆ		var finalVal interface{}
   101ÔåÆ
   102ÔåÆ		tagName, tagOpts := parseTag(field.Tag.Get(s.TagName))
   103ÔåÆ		if tagName != "" {
   104ÔåÆ			name = tagName
   105ÔåÆ		}
   106ÔåÆ
   107ÔåÆ		// if the value is a zero value and the field is marked as omitempty do
   108ÔåÆ		// not include
   109ÔåÆ		if tagOpts.Has("omitempty") {
   110ÔåÆ			zero := reflect.Zero(val.Type()).Interface()
   111ÔåÆ			current := val.Interface()
   112ÔåÆ
   113ÔåÆ			if reflect.DeepEqual(current, zero) {
   114ÔåÆ				continue
   115ÔåÆ			}
   116ÔåÆ		}
   117ÔåÆ
   118ÔåÆ		if !tagOpts.Has("omitnested") {
   119ÔåÆ			finalVal = s.nested(val)
   120ÔåÆ
   121ÔåÆ			v := reflect.ValueOf(val.Interface())
   122ÔåÆ			if v.Kind() == reflect.Ptr {
   123ÔåÆ				v = v.Elem()
   124ÔåÆ			}
   125ÔåÆ
   126ÔåÆ			switch v.Kind() {
   127ÔåÆ			case reflect.Map, reflect.Struct:
   128ÔåÆ				isSubStruct = true
   129ÔåÆ			}
   130ÔåÆ		} else {
   131ÔåÆ			finalVal = val.Interface()
   132ÔåÆ		}
   133ÔåÆ
   134ÔåÆ		if tagOpts.Has("string") {
   135ÔåÆ			s, ok := val.Interface().(fmt.Stringer)
   136ÔåÆ			if ok {
   137ÔåÆ				out[name] = s.String()
   138ÔåÆ			}
   139ÔåÆ			continue
   140ÔåÆ		}
   141ÔåÆ
   142ÔåÆ		if isSubStruct && (tagOpts.Has("flatten")) {
   143ÔåÆ			for k := range finalVal.(map[string]interface{}) {
   144ÔåÆ				out[k] = finalVal.(map[string]interface{})[k]
   145ÔåÆ			}
   146ÔåÆ		} else {
   147ÔåÆ			out[name] = finalVal
   148ÔåÆ		}
   149ÔåÆ	}
   150ÔåÆ}
   152ÔåÆ// Values converts the given s struct's field values to a []interface{}.  A
   153ÔåÆ// struct tag with the content of "-" ignores the that particular field.
   154ÔåÆ// Example:
   155ÔåÆ//
   156ÔåÆ//   // Field is ignored by this package.
   157ÔåÆ//   Field int `structs:"-"`
   158ÔåÆ//
   159ÔåÆ// A value with the option of "omitnested" stops iterating further if the type
   160ÔåÆ// is a struct. Example:
   161ÔåÆ//
   162ÔåÆ//   // Fields is not processed further by this package.
   163ÔåÆ//   Field time.Time     `structs:",omitnested"`
   164ÔåÆ//   Field *http.Request `structs:",omitnested"`
   165ÔåÆ//
   166ÔåÆ// A tag value with the option of "omitempty" ignores that particular field and
   167ÔåÆ// is not added to the values if the field value is empty. Example:
   168ÔåÆ//
   169ÔåÆ//   // Field is skipped if empty
   170ÔåÆ//   Field string `structs:",omitempty"`
   171ÔåÆ//
   172ÔåÆ// Note that only exported fields of a struct can be accessed, non exported
   173ÔåÆ// fields  will be neglected.
   174ÔåÆfunc (s *Struct) Values() []interface{} {
   175ÔåÆ	fields := s.structFields()
   176ÔåÆ
   177ÔåÆ	var t []interface{}
   178ÔåÆ
   179ÔåÆ	for _, field := range fields {
   180ÔåÆ		val := s.value.FieldByName(field.Name)
   181ÔåÆ
   182ÔåÆ		_, tagOpts := parseTag(field.Tag.Get(s.TagName))
   183ÔåÆ
   184ÔåÆ		// if the value is a zero value and the field is marked as omitempty do
   185ÔåÆ		// not include
   186ÔåÆ		if tagOpts.Has("omitempty") {
   187ÔåÆ			zero := reflect.Zero(val.Type()).Interface()
   188ÔåÆ			current := val.Interface()
   189ÔåÆ
   190ÔåÆ			if reflect.DeepEqual(current, zero) {
   191ÔåÆ				continue
   192ÔåÆ			}
   193ÔåÆ		}
   194ÔåÆ
   195ÔåÆ		if tagOpts.Has("string") {
   196ÔåÆ			s, ok := val.Interface().(fmt.Stringer)
   197ÔåÆ			if ok {
   198ÔåÆ				t = append(t, s.String())
   199ÔåÆ			}
   200ÔåÆ			continue
   201ÔåÆ		}
   202ÔåÆ
   203ÔåÆ		if IsStruct(val.Interface()) && !tagOpts.Has("omitnested") {
   204ÔåÆ			// look out for embedded structs, and convert them to a
   205ÔåÆ			// []interface{} to be added to the final values slice
   206ÔåÆ			t = append(t, Values(val.Interface())...)
   207ÔåÆ		} else {
   208ÔåÆ			t = append(t, val.Interface())
   209ÔåÆ		}
   210ÔåÆ	}
   211ÔåÆ
   212ÔåÆ	return t
   213ÔåÆ}
   215ÔåÆ// Fields returns a slice of Fields. A struct tag with the content of "-"
   216ÔåÆ// ignores the checking of that particular field. Example:
   217ÔåÆ//
   218ÔåÆ//   // Field is ignored by this package.
   219ÔåÆ//   Field bool `structs:"-"`
   220ÔåÆ//
   221ÔåÆ// It panics if s's kind is not struct.
   222ÔåÆfunc (s *Struct) Fields() []*Field {
   223ÔåÆ	return getFields(s.value, s.TagName)
   224ÔåÆ}
   226ÔåÆ// Names returns a slice of field names. A struct tag with the content of "-"
   227ÔåÆ// ignores the checking of that particular field. Example:
   228ÔåÆ//
   229ÔåÆ//   // Field is ignored by this package.
   230ÔåÆ//   Field bool `structs:"-"`
   231ÔåÆ//
   232ÔåÆ// It panics if s's kind is not struct.
   233ÔåÆfunc (s *Struct) Names() []string {
   234ÔåÆ	fields := getFields(s.value, s.TagName)
   235ÔåÆ
   236ÔåÆ	names := make([]string, len(fields))
   237ÔåÆ
   238ÔåÆ	for i, field := range fields {
   239ÔåÆ		names[i] = field.Name()
   240ÔåÆ	}
   241ÔåÆ
   242ÔåÆ	return names
   243ÔåÆ}
   245ÔåÆfunc getFields(v reflect.Value, tagName string) []*Field {
   246ÔåÆ	if v.Kind() == reflect.Ptr {
   247ÔåÆ		v = v.Elem()
   248ÔåÆ	}
   249ÔåÆ
   250ÔåÆ	t := v.Type()
   251ÔåÆ
   252ÔåÆ	var fields []*Field

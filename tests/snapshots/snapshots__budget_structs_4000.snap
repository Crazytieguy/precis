   473ÔåÆ// IsZero returns true if all fields is equal to a zero value. For more info
   474ÔåÆ// refer to Struct types IsZero() method.  It panics if s's kind is not struct.
   475ÔåÆfunc IsZero(s interface{}) bool {
   476ÔåÆ	return New(s).IsZero()

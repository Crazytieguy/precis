     3Ôćĺimport (
     4Ôćĺ	"errors"
     5Ôćĺ	"fmt"
     6Ôćĺ	"reflect"
     7Ôćĺ)
     9Ôćĺvar (
    10Ôćĺ	errNotExported = errors.New("field is not exported")
    11Ôćĺ	errNotSettable = errors.New("field is not settable")
    14Ôćĺ// Field represents a single struct field that encapsulates high level
    15Ôćĺ// functions around the field.
    16Ôćĺtype Field struct {
    17Ôćĺ	value      reflect.Value
    18Ôćĺ	field      reflect.StructField
    19Ôćĺ	defaultTag string
    20Ôćĺ}
    22Ôćĺ// Tag returns the value associated with key in the tag string. If there is no
    23Ôćĺ// such key in the tag, Tag returns the empty string.
    24Ôćĺfunc (f *Field) Tag(key string) string {
    25Ôćĺ	return f.field.Tag.Get(key)
    26Ôćĺ}
    28Ôćĺ// Value returns the underlying value of the field. It panics if the field
    29Ôćĺ// is not exported.
    30Ôćĺfunc (f *Field) Value() interface{} {
    31Ôćĺ	return f.value.Interface()
    32Ôćĺ}
    34Ôćĺ// IsEmbedded returns true if the given field is an anonymous field (embedded)
    35Ôćĺfunc (f *Field) IsEmbedded() bool {
    36Ôćĺ	return f.field.Anonymous
    37Ôćĺ}
    39Ôćĺ// IsExported returns true if the given field is exported.
    40Ôćĺfunc (f *Field) IsExported() bool {
    41Ôćĺ	return f.field.PkgPath == ""
    42Ôćĺ}
    44Ôćĺ// IsZero returns true if the given field is not initialized (has a zero value).
    45Ôćĺ// It panics if the field is not exported.
    46Ôćĺfunc (f *Field) IsZero() bool {
    47Ôćĺ	zero := reflect.Zero(f.value.Type()).Interface()
    48Ôćĺ	current := f.Value()
    49Ôćĺ
    50Ôćĺ	return reflect.DeepEqual(current, zero)
    51Ôćĺ}
    53Ôćĺ// Name returns the name of the given field
    54Ôćĺfunc (f *Field) Name() string {
    55Ôćĺ	return f.field.Name
    56Ôćĺ}
    58Ôćĺ// Kind returns the fields kind, such as "string", "map", "bool", etc ..
    59Ôćĺfunc (f *Field) Kind() reflect.Kind {
    60Ôćĺ	return f.value.Kind()
    61Ôćĺ}
    63Ôćĺ// Set sets the field to given value v. It returns an error if the field is not
    64Ôćĺ// settable (not addressable or not exported) or if the given value's type
    65Ôćĺ// doesn't match the fields type.
    66Ôćĺfunc (f *Field) Set(val interface{}) error {
    67Ôćĺ	// we can't set unexported fields, so be sure this field is exported
    68Ôćĺ	if !f.IsExported() {
    69Ôćĺ		return errNotExported
    70Ôćĺ	}
    71Ôćĺ
    72Ôćĺ	// do we get here? not sure...
    73Ôćĺ	if !f.value.CanSet() {
    74Ôćĺ		return errNotSettable
    75Ôćĺ	}
    76Ôćĺ
    77Ôćĺ	given := reflect.ValueOf(val)
    78Ôćĺ
    79Ôćĺ	if f.value.Kind() != given.Kind() {
    80Ôćĺ		return fmt.Errorf("wrong kind. got: %s want: %s", given.Kind(), f.value.Kind())
    81Ôćĺ	}
    82Ôćĺ
    83Ôćĺ	f.value.Set(given)
    84Ôćĺ	return nil
    85Ôćĺ}
    87Ôćĺ// Zero sets the field to its zero value. It returns an error if the field is not
    88Ôćĺ// settable (not addressable or not exported).
    89Ôćĺfunc (f *Field) Zero() error {
    90Ôćĺ	zero := reflect.Zero(f.value.Type()).Interface()
    91Ôćĺ	return f.Set(zero)
    92Ôćĺ}
    94Ôćĺ// Fields returns a slice of Fields. This is particular handy to get the fields
    95Ôćĺ// of a nested struct . A struct tag with the content of "-" ignores the
    96Ôćĺ// checking of that particular field. Example:
    97Ôćĺ//
    98Ôćĺ//   // Field is ignored by this package.
    99Ôćĺ//   Field *http.Request `structs:"-"`
   100Ôćĺ//
   101Ôćĺ// It panics if field is not exported or if field's kind is not struct
   102Ôćĺfunc (f *Field) Fields() []*Field {
   103Ôćĺ	return getFields(f.value, f.defaultTag)
   104Ôćĺ}
   106Ôćĺ// Field returns the field from a nested struct. It panics if the nested struct
   107Ôćĺ// is not exported or if the field was not found.
   108Ôćĺfunc (f *Field) Field(name string) *Field {
   109Ôćĺ	field, ok := f.FieldOk(name)
   110Ôćĺ	if !ok {
   111Ôćĺ		panic("field not found")
   112Ôćĺ	}
   113Ôćĺ
   114Ôćĺ	return field
   115Ôćĺ}
   117Ôćĺ// FieldOk returns the field from a nested struct. The boolean returns whether
   118Ôćĺ// the field was found (true) or not (false).
   119Ôćĺfunc (f *Field) FieldOk(name string) (*Field, bool) {
   120Ôćĺ	value := &f.value
   121Ôćĺ	// value must be settable so we need to make sure it holds the address of the
   122Ôćĺ	// variable and not a copy, so we can pass the pointer to strctVal instead of a
   123Ôćĺ	// copy (which is not assigned to any variable, hence not settable).
   124Ôćĺ	// see "https://blog.golang.org/laws-of-reflection#TOC_8."
   125Ôćĺ	if f.value.Kind() != reflect.Ptr {
   126Ôćĺ		a := f.value.Addr()
   127Ôćĺ		value = &a
   128Ôćĺ	}
   129Ôćĺ	v := strctVal(value.Interface())
   130Ôćĺ	t := v.Type()
   131Ôćĺ
   132Ôćĺ	field, ok := t.FieldByName(name)
   133Ôćĺ	if !ok {
   134Ôćĺ		return nil, false
   135Ôćĺ	}
   136Ôćĺ
   137Ôćĺ	return &Field{
   138Ôćĺ		field: field,
   139Ôćĺ		value: v.FieldByName(name),
   140Ôćĺ	}, true
   141Ôćĺ}

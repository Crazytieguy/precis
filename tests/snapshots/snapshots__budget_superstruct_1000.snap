     7Ôćĺ### Usage
     9ÔćĺSuperstruct allows you to define the shape of data you want to validate:
    10Ôćĺ
    11Ôćĺ```js
    12Ôćĺimport { assert, object, number, string, array } from 'superstruct'
    13Ôćĺ
    14Ôćĺconst Article = object({
    15Ôćĺ  id: number(),
    16Ôćĺ  title: string(),
    17Ôćĺ  tags: array(string()),
    18Ôćĺ  author: object({
    19Ôćĺ    id: number(),
    20Ôćĺ  }),
    21Ôćĺ})
    22Ôćĺ
    23Ôćĺconst data = {
    24Ôćĺ  id: 34,
    25Ôćĺ  title: 'Hello World',
    26Ôćĺ  tags: ['news', 'features'],
    27Ôćĺ  author: {
    28Ôćĺ    id: 1,
    29Ôćĺ  },
    30Ôćĺ}
    31Ôćĺ
    32Ôćĺassert(data, Article)

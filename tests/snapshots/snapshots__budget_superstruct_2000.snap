docs/readme.md
     7тЖТ### Usage
     9тЖТSuperstruct allows you to define the shape of data you want to validate:
    10тЖТ
    11тЖТ```js
    12тЖТimport { assert, object, number, string, array } from 'superstruct'
    13тЖТ
    14тЖТconst Article = object({
    15тЖТ  id: number(),
    16тЖТ  title: string(),
    17тЖТ  tags: array(string()),
    18тЖТ  author: object({
    19тЖТ    id: number(),
    20тЖТ  }),
    21тЖТ})
    22тЖТ
    23тЖТconst data = {
    24тЖТ  id: 34,
    25тЖТ  title: 'Hello World',
    26тЖТ  tags: ['news', 'features'],
    27тЖТ  author: {
    28тЖТ    id: 1,
    29тЖТ  },
    30тЖТ}
    31тЖТ
    32тЖТassert(data, Article)
      тЖТтАж

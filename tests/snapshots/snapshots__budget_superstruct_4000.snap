   375‚Üí/**
      ‚Üí‚Ä¶
   379‚Üíexport type TupleSchema<T> = { [K in keyof T]: Struct<T[K]> }
   381‚Üí/**
      ‚Üí‚Ä¶
   385‚Üíexport type AnyStruct = Struct<any, any>
   387‚Üí/**
      ‚Üí‚Ä¶
   394‚Üíexport type InferStructTuple<
   395‚Üí  Tuple extends AnyStruct[],
   396‚Üí  Length extends number = Tuple['length'],
   397‚Üí> = Length extends Length
   398‚Üí  ? number extends Length
   399‚Üí    ? Tuple
   400‚Üí    : _InferTuple<Tuple, Length, []>
   401‚Üí  : never
   402‚Üítype _InferTuple<
   403‚Üí  Tuple extends AnyStruct[],
   404‚Üí  Length extends number,
   405‚Üí  Accumulated extends unknown[],
   406‚Üí  Index extends number = Accumulated['length'],
   407‚Üí> = Index extends Length
   408‚Üí  ? Accumulated
   409‚Üí  : _InferTuple<Tuple, Length, [...Accumulated, Infer<Tuple[Index]>]>

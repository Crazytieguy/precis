src/error.ts
     1‚Üí/**
      ‚Üí‚Ä¶
     5‚Üíexport type Failure = {
     6‚Üí  value: any
     7‚Üí  key: any
     8‚Üí  type: string
     9‚Üí  refinement: string | undefined
    10‚Üí  message: string
    11‚Üí  explanation?: string
    12‚Üí  branch: Array<any>
    13‚Üí  path: Array<any>
    14‚Üí}
    16‚Üí/**
    17‚Üí * `StructError` objects are thrown (or returned) when validation fails.
    18‚Üí *
    19‚Üí * Validation logic is design to exit early for maximum performance. The error
    20‚Üí * represents the first error encountered during validation. For more detail,
    21‚Üí * the `error.failures` property is a generator function that can be run to
    22‚Üí * continue validation and receive all the failures in the data.
    23‚Üí */
    24‚Üí
    25‚Üíexport class StructError extends TypeError {
    26‚Üí  value: any
    27‚Üí  key!: any
    28‚Üí  type!: string
    29‚Üí  refinement!: string | undefined
    30‚Üí  path!: Array<any>
    31‚Üí  branch!: Array<any>
    32‚Üí  failures: () => Array<Failure>;
    33‚Üí  [x: string]: any
    34‚Üí
    35‚Üí  constructor(failure: Failure, failures: () => Generator<Failure>) {
    36‚Üí    let cached: Array<Failure> | undefined
    37‚Üí    const { message, explanation, ...rest } = failure
    38‚Üí    const { path } = failure
    39‚Üí    const msg =
    40‚Üí      path.length === 0 ? message : `At path: ${path.join('.')} -- ${message}`
    41‚Üí    super(explanation ?? msg)
    42‚Üí    if (explanation != null) this.cause = msg
    43‚Üí    Object.assign(this, rest)
    44‚Üí    this.name = this.constructor.name
    45‚Üí    this.failures = () => {
    46‚Üí      return (cached ??= [failure, ...failures()])
    47‚Üí    }
    48‚Üí  }
    49‚Üí}
src/struct.ts
     4‚Üí/**
     5‚Üí * `Struct` objects encapsulate the validation logic for a specific type of
     6‚Üí * values. Once constructed, you use the `assert`, `is` or `validate` helpers to
     7‚Üí * validate unknown input data against the struct.
     8‚Üí */
     9‚Üí
    10‚Üíexport class Struct<T = unknown, S = unknown> {
    11‚Üí  readonly TYPE!: T
    12‚Üí  type: string
    13‚Üí  schema: S
    14‚Üí  coercer: (value: unknown, context: Context) => unknown
    15‚Üí  validator: (value: unknown, context: Context) => Iterable<Failure>
    16‚Üí  refiner: (value: T, context: Context) => Iterable<Failure>
    17‚Üí  entries: (
    18‚Üí    value: unknown,
    19‚Üí    context: Context
    20‚Üí  ) => Iterable<[string | number, unknown, Struct<any> | Struct<never>]>
    21‚Üí
    22‚Üí  constructor(props: {
    23‚Üí    type: string
    24‚Üí    schema: S
    25‚Üí    coercer?: Coercer
    26‚Üí    validator?: Validator
    27‚Üí    refiner?: Refiner<T>
    28‚Üí    entries?: Struct<T, S>['entries']
    29‚Üí  }) {
    30‚Üí    const {
    31‚Üí      type,
    32‚Üí      schema,
    33‚Üí      validator,
    34‚Üí      refiner,
    35‚Üí      coercer = (value: unknown) => value,
    36‚Üí      entries = function* () {},
    37‚Üí    } = props
    38‚Üí
    39‚Üí    this.type = type
    40‚Üí    this.schema = schema
    41‚Üí    this.entries = entries
    42‚Üí    this.coercer = coercer
    43‚Üí
    44‚Üí    if (validator) {
    45‚Üí      this.validator = (value, context) => {
    46‚Üí        const result = validator(value, context)
    47‚Üí        return toFailures(result, context, this, value)
    48‚Üí      }
    49‚Üí    } else {
    50‚Üí      this.validator = () => []
    51‚Üí    }
    52‚Üí
    53‚Üí    if (refiner) {
    54‚Üí      this.refiner = (value, context) => {
    55‚Üí        const result = refiner(value, context)
    56‚Üí        return toFailures(result, context, this, value)
    57‚Üí      }
    58‚Üí    } else {
    59‚Üí      this.refiner = () => []
    60‚Üí    }
    61‚Üí  }
    62‚Üí
    63‚Üí  /**
    64‚Üí   * Assert that a value passes the struct's validation, throwing if it doesn't.
    65‚Üí   */
    66‚Üí
    67‚Üí  assert(value: unknown, message?: string): asserts value is T {
    68‚Üí    return assert(value, this, message)
    69‚Üí  }
    70‚Üí
    71‚Üí  /**
    72‚Üí   * Create a value with the struct's coercion logic, then validate it.
    73‚Üí   */
    74‚Üí
    75‚Üí  create(value: unknown, message?: string): T {
    76‚Üí    return create(value, this, message)
    77‚Üí  }
    78‚Üí
    79‚Üí  /**
    80‚Üí   * Check if a value passes the struct's validation.
    81‚Üí   */
    82‚Üí
    83‚Üí  is(value: unknown): value is T {
    84‚Üí    return is(value, this)
    85‚Üí  }
    86‚Üí
    87‚Üí  /**
    88‚Üí   * Mask a value, coercing and validating it, but returning only the subset of
    89‚Üí   * properties defined by the struct's schema. Masking applies recursively to
    90‚Üí   * props of `object` structs only.
    91‚Üí   */
    92‚Üí
    93‚Üí  mask(value: unknown, message?: string): T {
    94‚Üí    return mask(value, this, message)
    95‚Üí  }
    96‚Üí
    97‚Üí  /**
    98‚Üí   * Validate a value with the struct's validation logic, returning a tuple
    99‚Üí   * representing the result.
   100‚Üí   *
   101‚Üí   * You may optionally pass `true` for the `coerce` argument to coerce
   102‚Üí   * the value before attempting to validate it. If you do, the result will
   103‚Üí   * contain the coerced result when successful. Also, `mask` will turn on
   104‚Üí   * masking of the unknown `object` props recursively if passed.
   105‚Üí   */
   106‚Üí
   107‚Üí  validate(
   108‚Üí    value: unknown,
   109‚Üí    options: {
   110‚Üí      coerce?: boolean
   111‚Üí      mask?: boolean
   112‚Üí      message?: string
   113‚Üí    } = {}
   114‚Üí  ): [StructError, undefined] | [undefined, T] {
   115‚Üí    return validate(value, this, options)
   116‚Üí  }
   117‚Üí}
   119‚Üí/**
   120‚Üí * Assert that a value passes a struct, throwing if it doesn't.
   121‚Üí */
   122‚Üí
   123‚Üíexport function assert<T, S>(
   124‚Üí  value: unknown,
   125‚Üí  struct: Struct<T, S>,
   126‚Üí  message?: string
   127‚Üí): asserts value is T {
   128‚Üí  const result = validate(value, struct, { message })
   129‚Üí
   130‚Üí  if (result[0]) {
   131‚Üí    throw result[0]
      ‚Üí‚Ä¶
   135‚Üí/**
   136‚Üí * Create a value with the coercion logic of struct and validate it.
   137‚Üí */
   138‚Üí
   139‚Üíexport function create<T, S>(
   140‚Üí  value: unknown,
   141‚Üí  struct: Struct<T, S>,
   142‚Üí  message?: string
   143‚Üí): T {
   144‚Üí  const result = validate(value, struct, { coerce: true, message })
   145‚Üí
   146‚Üí  if (result[0]) {
   147‚Üí    throw result[0]
      ‚Üí‚Ä¶
   153‚Üí/**
   154‚Üí * Mask a value, returning only the subset of properties defined by a struct.
   155‚Üí */
   156‚Üí
   157‚Üíexport function mask<T, S>(
   158‚Üí  value: unknown,
   159‚Üí  struct: Struct<T, S>,
   160‚Üí  message?: string
   161‚Üí): T {
   162‚Üí  const result = validate(value, struct, { coerce: true, mask: true, message })
   163‚Üí

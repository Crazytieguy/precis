   330‚Üí/**
      ‚Üí‚Ä¶
   334‚Üíexport type StructSchema<T> = [T] extends [string | undefined | null]
   335‚Üí  ? [T] extends [IsMatch<T, string | undefined | null>]
   336‚Üí    ? null
   337‚Üí    : [T] extends [IsUnion<T>]
   338‚Üí      ? EnumSchema<T>
   339‚Üí      : T
   340‚Üí  : [T] extends [number | undefined | null]
   341‚Üí    ? [T] extends [IsMatch<T, number | undefined | null>]
   342‚Üí      ? null
   343‚Üí      : [T] extends [IsUnion<T>]
   344‚Üí        ? EnumSchema<T>
   345‚Üí        : T
   346‚Üí    : [T] extends [boolean]
   347‚Üí      ? [T] extends [IsExactMatch<T, boolean>]
   348‚Üí        ? null
   349‚Üí        : T
   350‚Üí      : T extends
   351‚Üí            | bigint
   352‚Üí            | symbol
   353‚Üí            | undefined
   354‚Üí            | null
   355‚Üí            | Function
   356‚Üí            | Date
   357‚Üí            | Error
   358‚Üí            | RegExp
   359‚Üí            | Map<any, any>
   360‚Üí            | WeakMap<any, any>
   361‚Üí            | Set<any>
   362‚Üí            | WeakSet<any>
   363‚Üí            | Promise<any>
   364‚Üí        ? null
   365‚Üí        : T extends Array<infer E>
   366‚Üí          ? T extends IsTuple<T>
   367‚Üí            ? null
   368‚Üí            : Struct<E>
   369‚Üí          : T extends object
   370‚Üí            ? T extends IsRecord<T>
   371‚Üí              ? null

docs/readme.md
     7Ôćĺ### Usage
     8Ôćĺ
     9ÔćĺSuperstruct allows you to define the shape of data you want to validate:
    10Ôćĺ
    11Ôćĺ```js
    12Ôćĺimport { assert, object, number, string, array } from 'superstruct'
    13Ôćĺ
    14Ôćĺconst Article = object({
    15Ôćĺ  id: number(),
    16Ôćĺ  title: string(),
    17Ôćĺ  tags: array(string()),
    18Ôćĺ  author: object({
    19Ôćĺ    id: number(),
    20Ôćĺ  }),
    21Ôćĺ})
    22Ôćĺ
    23Ôćĺconst data = {
    24Ôćĺ  id: 34,
    25Ôćĺ  title: 'Hello World',
    26Ôćĺ  tags: ['news', 'features'],
    27Ôćĺ  author: {
    28Ôćĺ    id: 1,
    29Ôćĺ  },
    30Ôćĺ}
    31Ôćĺ
    32Ôćĺassert(data, Article)
    33Ôćĺ// This will throw an error when the data is invalid.
    34Ôćĺ// If you'd rather not throw, you can use `is()` or `validate()`.
    35Ôćĺ```
    36Ôćĺ
    37ÔćĺSuperstruct ships with validators for all the common JavaScript data types, and you can define custom ones too:
    38Ôćĺ
    39Ôćĺ```js
    40Ôćĺimport { is, define, object, string } from 'superstruct'
    41Ôćĺimport isUuid from 'is-uuid'
    42Ôćĺimport isEmail from 'is-email'
    43Ôćĺ
    44Ôćĺconst Email = define('Email', isEmail)
    45Ôćĺconst Uuid = define('Uuid', isUuid.v4)
    46Ôćĺ
    47Ôćĺconst User = object({
    48Ôćĺ  id: Uuid,
    49Ôćĺ  email: Email,
    50Ôćĺ  name: string(),
    51Ôćĺ})
    52Ôćĺ
    53Ôćĺconst data = {
    54Ôćĺ  id: 'c8d63140-a1f7-45e0-bfc6-df72973fea86',
    55Ôćĺ  email: 'jane@example.com',
    56Ôćĺ  name: 'Jane',
    57Ôćĺ}
    58Ôćĺ
    59Ôćĺif (is(data, User)) {
    60Ôćĺ  // Your data is guaranteed to be valid in this block.
    61Ôćĺ}
    62Ôćĺ```
    63Ôćĺ

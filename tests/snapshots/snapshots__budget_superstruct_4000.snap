src/error.ts
     1Ôćĺ/**
     5Ôćĺexport type Failure = {
     6Ôćĺ  value: any
     7Ôćĺ  key: any
     8Ôćĺ  type: string
     9Ôćĺ  refinement: string | undefined
    10Ôćĺ  message: string
    11Ôćĺ  explanation?: string
    12Ôćĺ  branch: Array<any>
    13Ôćĺ  path: Array<any>
    14Ôćĺ}
    16Ôćĺ/**
    17Ôćĺ * `StructError` objects are thrown (or returned) when validation fails.
    18Ôćĺ *
    19Ôćĺ * Validation logic is design to exit early for maximum performance. The error
    20Ôćĺ * represents the first error encountered during validation. For more detail,
    21Ôćĺ * the `error.failures` property is a generator function that can be run to
    22Ôćĺ * continue validation and receive all the failures in the data.
    23Ôćĺ */
    24Ôćĺ
    25Ôćĺexport class StructError extends TypeError {
    26Ôćĺ  value: any
    27Ôćĺ  key!: any
    28Ôćĺ  type!: string
    29Ôćĺ  refinement!: string | undefined
    30Ôćĺ  path!: Array<any>
    31Ôćĺ  branch!: Array<any>
    32Ôćĺ  failures: () => Array<Failure>;
    33Ôćĺ  [x: string]: any
    34Ôćĺ
    35Ôćĺ  constructor(failure: Failure, failures: () => Generator<Failure>) {
    36Ôćĺ    let cached: Array<Failure> | undefined
    37Ôćĺ    const { message, explanation, ...rest } = failure
    38Ôćĺ    const { path } = failure
    39Ôćĺ    const msg =
    40Ôćĺ      path.length === 0 ? message : `At path: ${path.join('.')} -- ${message}`
    41Ôćĺ    super(explanation ?? msg)
    42Ôćĺ    if (explanation != null) this.cause = msg
    43Ôćĺ    Object.assign(this, rest)
    44Ôćĺ    this.name = this.constructor.name
    45Ôćĺ    this.failures = () => {
    46Ôćĺ      return (cached ??= [failure, ...failures()])
    47Ôćĺ    }
    48Ôćĺ  }
    49Ôćĺ}
src/struct.ts
     4Ôćĺ/**
     5Ôćĺ * `Struct` objects encapsulate the validation logic for a specific type of
     6Ôćĺ * values. Once constructed, you use the `assert`, `is` or `validate` helpers to
     7Ôćĺ * validate unknown input data against the struct.
     8Ôćĺ */
     9Ôćĺ
    10Ôćĺexport class Struct<T = unknown, S = unknown> {
    11Ôćĺ  readonly TYPE!: T
    12Ôćĺ  type: string
    13Ôćĺ  schema: S
    14Ôćĺ  coercer: (value: unknown, context: Context) => unknown
    15Ôćĺ  validator: (value: unknown, context: Context) => Iterable<Failure>
    16Ôćĺ  refiner: (value: T, context: Context) => Iterable<Failure>
    17Ôćĺ  entries: (
    18Ôćĺ    value: unknown,
    19Ôćĺ    context: Context
    20Ôćĺ  ) => Iterable<[string | number, unknown, Struct<any> | Struct<never>]>
    21Ôćĺ
    22Ôćĺ  constructor(props: {
    23Ôćĺ    type: string
    24Ôćĺ    schema: S
    25Ôćĺ    coercer?: Coercer
    26Ôćĺ    validator?: Validator
    27Ôćĺ    refiner?: Refiner<T>
    28Ôćĺ    entries?: Struct<T, S>['entries']
    29Ôćĺ  }) {
    30Ôćĺ    const {
    31Ôćĺ      type,
    32Ôćĺ      schema,
    33Ôćĺ      validator,
    34Ôćĺ      refiner,
    35Ôćĺ      coercer = (value: unknown) => value,
    36Ôćĺ      entries = function* () {},
    37Ôćĺ    } = props
    38Ôćĺ
    39Ôćĺ    this.type = type
    40Ôćĺ    this.schema = schema
    41Ôćĺ    this.entries = entries
    42Ôćĺ    this.coercer = coercer
    43Ôćĺ
    44Ôćĺ    if (validator) {
    45Ôćĺ      this.validator = (value, context) => {
    46Ôćĺ        const result = validator(value, context)
    47Ôćĺ        return toFailures(result, context, this, value)
    48Ôćĺ      }
    49Ôćĺ    } else {
    50Ôćĺ      this.validator = () => []
    51Ôćĺ    }
    52Ôćĺ
    53Ôćĺ    if (refiner) {
    54Ôćĺ      this.refiner = (value, context) => {
    55Ôćĺ        const result = refiner(value, context)
    56Ôćĺ        return toFailures(result, context, this, value)
    57Ôćĺ      }
    58Ôćĺ    } else {
    59Ôćĺ      this.refiner = () => []
    60Ôćĺ    }
    61Ôćĺ  }
    62Ôćĺ
    63Ôćĺ  /**
    64Ôćĺ   * Assert that a value passes the struct's validation, throwing if it doesn't.
    65Ôćĺ   */
    66Ôćĺ
    67Ôćĺ  assert(value: unknown, message?: string): asserts value is T {
    68Ôćĺ    return assert(value, this, message)
    69Ôćĺ  }
    70Ôćĺ
    71Ôćĺ  /**
    72Ôćĺ   * Create a value with the struct's coercion logic, then validate it.
    73Ôćĺ   */
    74Ôćĺ
    75Ôćĺ  create(value: unknown, message?: string): T {
    76Ôćĺ    return create(value, this, message)
    77Ôćĺ  }
    78Ôćĺ
    79Ôćĺ  /**
    80Ôćĺ   * Check if a value passes the struct's validation.
    81Ôćĺ   */
    82Ôćĺ
    83Ôćĺ  is(value: unknown): value is T {
    84Ôćĺ    return is(value, this)
    85Ôćĺ  }
    86Ôćĺ
    87Ôćĺ  /**
    88Ôćĺ   * Mask a value, coercing and validating it, but returning only the subset of
    89Ôćĺ   * properties defined by the struct's schema. Masking applies recursively to
    90Ôćĺ   * props of `object` structs only.
    91Ôćĺ   */
    92Ôćĺ
    93Ôćĺ  mask(value: unknown, message?: string): T {
    94Ôćĺ    return mask(value, this, message)
    95Ôćĺ  }
    96Ôćĺ
    97Ôćĺ  /**
    98Ôćĺ   * Validate a value with the struct's validation logic, returning a tuple
    99Ôćĺ   * representing the result.
   100Ôćĺ   *

   199‚Üí * Convert a union of type to an intersection.
   202‚Üíexport type UnionToIntersection<U> = (
   203‚Üí  U extends any ? (arg: U) => any : never
   204‚Üí) extends (arg: infer I) => void
   205‚Üí  ? I
   206‚Üí  : never
   209‚Üí * Assign properties from one type to another, overwriting existing.
   212‚Üíexport type Assign<T, U> = Simplify<U & Omit<T, keyof U>>
   215‚Üí * A schema for enum structs.
   218‚Üíexport type EnumSchema<T extends string | number | undefined | null> = {
   219‚Üí  [K in NonNullable<T>]: K
   220‚Üí}
   223‚Üí * Check if a type is a match for another whilst treating overlapping
   227‚Üíexport type IsMatch<T, G> = T extends G ? (G extends T ? T : never) : never
   230‚Üí * Check if a type is an exact match.
   233‚Üíexport type IsExactMatch<T, U> =
   234‚Üí  (<G>() => G extends T ? 1 : 2) extends <G>() => G extends U ? 1 : 2
   235‚Üí    ? T
   236‚Üí    : never
   239‚Üí * Check if a type is a record type.
   242‚Üíexport type IsRecord<T> = T extends object
   243‚Üí  ? string extends keyof T
   244‚Üí    ? T
   245‚Üí    : never
   246‚Üí  : never
   248‚Üí * Check if a type is a tuple.
   251‚Üíexport type IsTuple<T> = T extends [any]
   252‚Üí  ? T
   253‚Üí  : T extends [any, any]
   254‚Üí    ? T
   255‚Üí    : T extends [any, any, any]
   256‚Üí      ? T
   257‚Üí      : T extends [any, any, any, any]
   258‚Üí        ? T
   259‚Üí        : T extends [any, any, any, any, any]
   260‚Üí          ? T
   261‚Üí          : never
   264‚Üí * Check if a type is a union.
   267‚Üíexport type IsUnion<T, U extends T = T> = (
   268‚Üí  T extends any ? (U extends T ? false : true) : false
   269‚Üí) extends false
   270‚Üí  ? never
   271‚Üí  : T
   274‚Üí * A schema for object structs.
   277‚Üíexport type ObjectSchema = Record<string, Struct<any, any>>
   280‚Üí * Infer a type from an object struct schema.
   283‚Üíexport type ObjectType<S extends ObjectSchema> = Simplify<
   284‚Üí  Optionalize<{ [K in keyof S]: Infer<S[K]> }>
   285‚Üí>
   288‚Üí * Omit properties from a type that extend from a specific type.
   291‚Üíexport type OmitBy<T, V> = Omit<
   292‚Üí  T,
   293‚Üí  { [K in keyof T]: V extends Extract<T[K], V> ? K : never }[keyof T]
   294‚Üí>
   297‚Üí * Normalize properties of a type that allow `undefined` to make them optional.
   300‚Üíexport type Optionalize<S extends object> = OmitBy<S, undefined> &
   301‚Üí  Partial<PickBy<S, undefined>>
   304‚Üí * Transform an object schema type to represent a partial.
   307‚Üíexport type PartialObjectSchema<S extends ObjectSchema> = {
   308‚Üí  [K in keyof S]: Struct<Infer<S[K]> | undefined>
   309‚Üí}
   312‚Üí * Pick properties from a type that extend from a specific type.
   315‚Üíexport type PickBy<T, V> = Pick<
   316‚Üí  T,
   317‚Üí  { [K in keyof T]: V extends Extract<T[K], V> ? K : never }[keyof T]
   318‚Üí>
   321‚Üí * Simplifies a type definition to its most basic representation.
   324‚Üíexport type Simplify<T> = T extends any[] | Date
   325‚Üí  ? T
   326‚Üí  : { [K in keyof T]: T[K] } & {}
   328‚Üíexport type If<B extends Boolean, Then, Else> = B extends true ? Then : Else
   331‚Üí * A schema for any type of struct.
   334‚Üíexport type StructSchema<T> = [T] extends [string | undefined | null]
   335‚Üí  ? [T] extends [IsMatch<T, string | undefined | null>]
   336‚Üí    ? null
   337‚Üí    : [T] extends [IsUnion<T>]
   338‚Üí      ? EnumSchema<T>
   339‚Üí      : T
   340‚Üí  : [T] extends [number | undefined | null]
   341‚Üí    ? [T] extends [IsMatch<T, number | undefined | null>]
   342‚Üí      ? null
   343‚Üí      : [T] extends [IsUnion<T>]
   344‚Üí        ? EnumSchema<T>
   345‚Üí        : T
   346‚Üí    : [T] extends [boolean]
   347‚Üí      ? [T] extends [IsExactMatch<T, boolean>]
   348‚Üí        ? null
   349‚Üí        : T
   350‚Üí      : T extends
   351‚Üí            | bigint
   352‚Üí            | symbol
   353‚Üí            | undefined
   354‚Üí            | null
   355‚Üí            | Function
   356‚Üí            | Date
   357‚Üí            | Error
   358‚Üí            | RegExp
   359‚Üí            | Map<any, any>
   360‚Üí            | WeakMap<any, any>
   361‚Üí            | Set<any>
   362‚Üí            | WeakSet<any>
   363‚Üí            | Promise<any>
   364‚Üí        ? null
   365‚Üí        : T extends Array<infer E>
   366‚Üí          ? T extends IsTuple<T>
   367‚Üí            ? null
   368‚Üí            : Struct<E>
   369‚Üí          : T extends object
   370‚Üí            ? T extends IsRecord<T>
   371‚Üí              ? null
   372‚Üí              : { [K in keyof T]: Describe<T[K]> }
   373‚Üí            : null
   376‚Üí * A schema for tuple structs.
   379‚Üíexport type TupleSchema<T> = { [K in keyof T]: Struct<T[K]> }
   382‚Üí * Shorthand type for matching any `Struct`.
   385‚Üíexport type AnyStruct = Struct<any, any>
   388‚Üí * Infer a tuple of types from a tuple of `Struct`s.
   394‚Üíexport type InferStructTuple<
   395‚Üí  Tuple extends AnyStruct[],
   396‚Üí  Length extends number = Tuple['length'],
   397‚Üí> = Length extends Length
   398‚Üí  ? number extends Length
   399‚Üí    ? Tuple
   400‚Üí    : _InferTuple<Tuple, Length, []>
   401‚Üí  : never
   402‚Üítype _InferTuple<
   403‚Üí  Tuple extends AnyStruct[],
   404‚Üí  Length extends number,
   405‚Üí  Accumulated extends unknown[],
   406‚Üí  Index extends number = Accumulated['length'],
   407‚Üí> = Index extends Length
   408‚Üí  ? Accumulated
   409‚Üí  : _InferTuple<Tuple, Length, [...Accumulated, Infer<Tuple[Index]>]>

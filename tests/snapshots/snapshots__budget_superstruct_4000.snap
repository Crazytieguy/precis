     4‚Üí/**
     5‚Üí * Check if a value is an iterator.
     6‚Üí */
     7‚Üí
     8‚Üífunction isIterable<T>(x: unknown): x is Iterable<T> {
     9‚Üí  return isObject(x) && typeof x[Symbol.iterator] === 'function'
    10‚Üí}
    12‚Üí/**
    13‚Üí * Check if a value is a plain object.
    14‚Üí */
    15‚Üí
    16‚Üíexport function isObject(x: unknown): x is object {
    17‚Üí  return typeof x === 'object' && x != null
    18‚Üí}
    20‚Üí/**
    21‚Üí * Check if a value is a non-array object.
    22‚Üí */
    23‚Üí
    24‚Üíexport function isNonArrayObject(x: unknown): x is object {
    25‚Üí  return isObject(x) && !Array.isArray(x)
    26‚Üí}
    28‚Üí/**
    29‚Üí * Check if a value is a plain object.
    30‚Üí */
    31‚Üí
    32‚Üíexport function isPlainObject(x: unknown): x is { [key: string]: any } {
    33‚Üí  if (Object.prototype.toString.call(x) !== '[object Object]') {
    34‚Üí    return false
    35‚Üí  }
    36‚Üí
    37‚Üí  const prototype = Object.getPrototypeOf(x)
    38‚Üí  return prototype === null || prototype === Object.prototype
    39‚Üí}
    41‚Üí/**
    42‚Üí * Return a value as a printable string.
    43‚Üí */
    44‚Üí
    45‚Üíexport function print(value: any): string {
    46‚Üí  if (typeof value === 'symbol') {
    47‚Üí    return value.toString()
    48‚Üí  }
    49‚Üí
    50‚Üí  return typeof value === 'string' ? JSON.stringify(value) : `${value}`
    51‚Üí}
    53‚Üí/**
    54‚Üí * Shifts (removes and returns) the first value from the `input` iterator.
    55‚Üí * Like `Array.prototype.shift()` but for an `Iterator`.
    56‚Üí */
    57‚Üí
    58‚Üíexport function shiftIterator<T>(input: Iterator<T>): T | undefined {
    59‚Üí  const { done, value } = input.next()
    60‚Üí  return done ? undefined : value
    61‚Üí}
    63‚Üí/**
    64‚Üí * Convert a single validation result to a failure.
    65‚Üí */
    66‚Üí
    67‚Üíexport function toFailure<T, S>(
    68‚Üí  result: string | boolean | Partial<Failure>,
    69‚Üí  context: Context,
    70‚Üí  struct: Struct<T, S>,
    71‚Üí  value: any
    72‚Üí): Failure | undefined {
    73‚Üí  if (result === true) {
    74‚Üí    return
    75‚Üí  } else if (result === false) {
    76‚Üí    result = {}
    77‚Üí  } else if (typeof result === 'string') {
    78‚Üí    result = { message: result }
    79‚Üí  }
    80‚Üí
    81‚Üí  const { path, branch } = context
    82‚Üí  const { type } = struct
    83‚Üí  const {
    84‚Üí    refinement,
    85‚Üí    message = `Expected a value of type \`${type}\`${
    86‚Üí      refinement ? ` with refinement \`${refinement}\`` : ''
    87‚Üí    }, but received: \`${print(value)}\``,
    88‚Üí  } = result
    89‚Üí
    90‚Üí  return {
    91‚Üí    value,
    92‚Üí    type,
    93‚Üí    refinement,
    94‚Üí    key: path[path.length - 1],
    95‚Üí    path,
    96‚Üí    branch,
    97‚Üí    ...result,
    98‚Üí    message,
    99‚Üí  }
   100‚Üí}

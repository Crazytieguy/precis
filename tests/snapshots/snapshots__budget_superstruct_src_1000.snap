    16тЖТ/**
    17тЖТ * `StructError` objects are thrown (or returned) when validation fails.
    18тЖТ *
    19тЖТ * Validation logic is design to exit early for maximum performance. The error
    20тЖТ * represents the first error encountered during validation. For more detail,
    21тЖТ * the `error.failures` property is a generator function that can be run to
    22тЖТ * continue validation and receive all the failures in the data.
    23тЖТ */
    24тЖТ
    25тЖТexport class StructError extends TypeError {
    26тЖТ  value: any
    27тЖТ  key!: any
    28тЖТ  type!: string
    29тЖТ  refinement!: string | undefined
    30тЖТ  path!: Array<any>
    31тЖТ  branch!: Array<any>
    32тЖТ  failures: () => Array<Failure>;
    33тЖТ  [x: string]: any
    34тЖТ
    35тЖТ  constructor(failure: Failure, failures: () => Generator<Failure>) {
    36тЖТ    let cached: Array<Failure> | undefined
    37тЖТ    const { message, explanation, ...rest } = failure
    38тЖТ    const { path } = failure
    39тЖТ    const msg =
    40тЖТ      path.length === 0 ? message : `At path: ${path.join('.')} -- ${message}`
    41тЖТ    super(explanation ?? msg)
    42тЖТ    if (explanation != null) this.cause = msg
    43тЖТ    Object.assign(this, rest)

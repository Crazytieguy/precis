     1тЖТimport { toFailures, shiftIterator, StructSchema, run } from './utils.js'
     2тЖТimport { StructError, Failure } from './error.js'
     4тЖТ/**
     5тЖТ * `Struct` objects encapsulate the validation logic for a specific type of
     6тЖТ * values. Once constructed, you use the `assert`, `is` or `validate` helpers to
     7тЖТ * validate unknown input data against the struct.
     8тЖТ */
     9тЖТ
    10тЖТexport class Struct<T = unknown, S = unknown> {
    11тЖТ  readonly TYPE!: T
    12тЖТ  type: string
    13тЖТ  schema: S
    14тЖТ  coercer: (value: unknown, context: Context) => unknown
    15тЖТ  validator: (value: unknown, context: Context) => Iterable<Failure>
    16тЖТ  refiner: (value: T, context: Context) => Iterable<Failure>
    17тЖТ  entries: (
    18тЖТ    value: unknown,
    19тЖТ    context: Context
    20тЖТ  ) => Iterable<[string | number, unknown, Struct<any> | Struct<never>]>
    21тЖТ
    22тЖТ  constructor(props: {
    23тЖТ    type: string
    24тЖТ    schema: S
    25тЖТ    coercer?: Coercer
    26тЖТ    validator?: Validator
    27тЖТ    refiner?: Refiner<T>
    28тЖТ    entries?: Struct<T, S>['entries']
    29тЖТ  }) {
    30тЖТ    const {
    31тЖТ      type,
    32тЖТ      schema,
    33тЖТ      validator,
    34тЖТ      refiner,
    35тЖТ      coercer = (value: unknown) => value,
    36тЖТ      entries = function* () {},
    37тЖТ    } = props
    38тЖТ
    39тЖТ    this.type = type
    40тЖТ    this.schema = schema
    41тЖТ    this.entries = entries
    42тЖТ    this.coercer = coercer
    43тЖТ
    44тЖТ    if (validator) {
    45тЖТ      this.validator = (value, context) => {
    46тЖТ        const result = validator(value, context)
    47тЖТ        return toFailures(result, context, this, value)
    48тЖТ      }
    49тЖТ    } else {
    50тЖТ      this.validator = () => []
    51тЖТ    }
    52тЖТ
    53тЖТ    if (refiner) {
    54тЖТ      this.refiner = (value, context) => {
    55тЖТ        const result = refiner(value, context)
    56тЖТ        return toFailures(result, context, this, value)
    57тЖТ      }
    58тЖТ    } else {
    59тЖТ      this.refiner = () => []
    60тЖТ    }
    61тЖТ  }
    63тЖТ  /**
    64тЖТ   * Assert that a value passes the struct's validation, throwing if it doesn't.
    65тЖТ   */
    66тЖТ
    67тЖТ  assert(value: unknown, message?: string): asserts value is T {
    68тЖТ    return assert(value, this, message)
    69тЖТ  }
    71тЖТ  /**
    72тЖТ   * Create a value with the struct's coercion logic, then validate it.
    73тЖТ   */
    74тЖТ
    75тЖТ  create(value: unknown, message?: string): T {
    76тЖТ    return create(value, this, message)
    77тЖТ  }
    79тЖТ  /**
    80тЖТ   * Check if a value passes the struct's validation.
    81тЖТ   */
    82тЖТ
    83тЖТ  is(value: unknown): value is T {
    84тЖТ    return is(value, this)
    85тЖТ  }
    87тЖТ  /**
    88тЖТ   * Mask a value, coercing and validating it, but returning only the subset of
    89тЖТ   * properties defined by the struct's schema. Masking applies recursively to
    90тЖТ   * props of `object` structs only.
    91тЖТ   */
    92тЖТ
    93тЖТ  mask(value: unknown, message?: string): T {
    94тЖТ    return mask(value, this, message)
    95тЖТ  }
    97тЖТ  /**
    98тЖТ   * Validate a value with the struct's validation logic, returning a tuple
    99тЖТ   * representing the result.
   100тЖТ   *
   101тЖТ   * You may optionally pass `true` for the `coerce` argument to coerce
   102тЖТ   * the value before attempting to validate it. If you do, the result will
   103тЖТ   * contain the coerced result when successful. Also, `mask` will turn on
   104тЖТ   * masking of the unknown `object` props recursively if passed.
   105тЖТ   */
   106тЖТ
   107тЖТ  validate(
   108тЖТ    value: unknown,
   109тЖТ    options: {
   110тЖТ      coerce?: boolean
   111тЖТ      mask?: boolean
   112тЖТ      message?: string
   113тЖТ    } = {}
   114тЖТ  ): [StructError, undefined] | [undefined, T] {
   115тЖТ    return validate(value, this, options)
   116тЖТ  }
   119тЖТ/**
   120тЖТ * Assert that a value passes a struct, throwing if it doesn't.
   121тЖТ */
   122тЖТ
   123тЖТexport function assert<T, S>(
   124тЖТ  value: unknown,
   125тЖТ  struct: Struct<T, S>,
   126тЖТ  message?: string
   127тЖТ): asserts value is T {
   128тЖТ  const result = validate(value, struct, { message })
   129тЖТ
   130тЖТ  if (result[0]) {
   131тЖТ    throw result[0]
   132тЖТ  }
   133тЖТ}
   135тЖТ/**
   136тЖТ * Create a value with the coercion logic of struct and validate it.
   137тЖТ */
   138тЖТ
   139тЖТexport function create<T, S>(
   140тЖТ  value: unknown,
   141тЖТ  struct: Struct<T, S>,
   142тЖТ  message?: string
   143тЖТ): T {
   144тЖТ  const result = validate(value, struct, { coerce: true, message })
   145тЖТ
   146тЖТ  if (result[0]) {
   147тЖТ    throw result[0]
   148тЖТ  } else {
   149тЖТ    return result[1]
   150тЖТ  }
   151тЖТ}
   153тЖТ/**
   154тЖТ * Mask a value, returning only the subset of properties defined by a struct.
   155тЖТ */
   156тЖТ
   157тЖТexport function mask<T, S>(
   158тЖТ  value: unknown,
   159тЖТ  struct: Struct<T, S>,
   160тЖТ  message?: string
   161тЖТ): T {
   162тЖТ  const result = validate(value, struct, { coerce: true, mask: true, message })
   163тЖТ
   164тЖТ  if (result[0]) {
   165тЖТ    throw result[0]
   166тЖТ  } else {
   167тЖТ    return result[1]
   168тЖТ  }
   169тЖТ}
   171тЖТ/**
   172тЖТ * Check if a value passes a struct.
   173тЖТ */
   174тЖТ
   175тЖТexport function is<T, S>(value: unknown, struct: Struct<T, S>): value is T {
   176тЖТ  const result = validate(value, struct)
   177тЖТ  return !result[0]
   178тЖТ}
   180тЖТ/**
   181тЖТ * Validate a value against a struct, returning an error if invalid, or the
   182тЖТ * value (with potential coercion) if valid.
   183тЖТ */
   184тЖТ
   185тЖТexport function validate<T, S>(
   186тЖТ  value: unknown,
   187тЖТ  struct: Struct<T, S>,
   188тЖТ  options: {
   189тЖТ    coerce?: boolean
   190тЖТ    mask?: boolean
   191тЖТ    message?: string
   192тЖТ  } = {}
   193тЖТ): [StructError, undefined] | [undefined, T] {
   194тЖТ  const tuples = run(value, struct, options)
   195тЖТ  const tuple = shiftIterator(tuples)!
   196тЖТ
   197тЖТ  if (tuple[0]) {
   198тЖТ    const error = new StructError(tuple[0], function* () {
   199тЖТ      for (const t of tuples) {
   200тЖТ        if (t[0]) {
   201тЖТ          yield t[0]
   202тЖТ        }
   203тЖТ      }
   204тЖТ    })
   205тЖТ
   206тЖТ    return [error, undefined]
   207тЖТ  } else {
   208тЖТ    const v = tuple[1]
   209тЖТ    return [undefined, v]
   210тЖТ  }
   211тЖТ}
   213тЖТ/**
   214тЖТ * A `Context` contains information about the current location of the
   215тЖТ * validation inside the initial input value. It also carries `mask`
   216тЖТ * since it's a run-time flag determining how the validation was invoked
   217тЖТ * (via `mask()` or via `validate()`), plus it applies recursively
   218тЖТ * to all of the nested structs.
   219тЖТ */
   220тЖТ
   221тЖТexport type Context = {
   222тЖТ  branch: Array<any>
   223тЖТ  path: Array<any>
   224тЖТ  mask?: boolean
   225тЖТ}
   227тЖТ/**
   228тЖТ * A type utility to extract the type from a `Struct` class.
   229тЖТ */
   230тЖТ
   231тЖТexport type Infer<T extends Struct<any, any>> = T['TYPE']
   233тЖТ/**
   234тЖТ * A type utility to describe that a struct represents a TypeScript type.
   235тЖТ */
   236тЖТ
   237тЖТexport type Describe<T> = Struct<T, StructSchema<T>>
   239тЖТ/**
   240тЖТ * A `Result` is returned from validation functions.
   241тЖТ */
   242тЖТ
   243тЖТexport type Result =
   244тЖТ  | boolean
   245тЖТ  | string
   246тЖТ  | Partial<Failure>
   247тЖТ  | Iterable<boolean | string | Partial<Failure>>
   249тЖТ/**
   250тЖТ * A `Coercer` takes an unknown value and optionally coerces it.
   251тЖТ */
   252тЖТ
   253тЖТexport type Coercer<T = unknown> = (value: T, context: Context) => unknown
   255тЖТ/**
   256тЖТ * A `Validator` takes an unknown value and validates it.
   257тЖТ */
   258тЖТ
   259тЖТexport type Validator = (value: unknown, context: Context) => Result
   261тЖТ/**
   262тЖТ * A `Refiner` takes a value of a known type and validates it against a further
   263тЖТ * constraint.
   264тЖТ */
   265тЖТ
   266тЖТexport type Refiner<T> = (value: T, context: Context) => Result

utils.ts
     1тЖТimport { Struct, Infer, Result, Context, Describe } from './struct.js'
     2тЖТimport { Failure } from './error.js'
     4тЖТ/**
     5тЖТ * Check if a value is an iterator.
     6тЖТ */
     7тЖТ
     8тЖТfunction isIterable<T>(x: unknown): x is Iterable<T> {
     9тЖТ  return isObject(x) && typeof x[Symbol.iterator] === 'function'
    10тЖТ}
    12тЖТ/**
    13тЖТ * Check if a value is a plain object.
    14тЖТ */
    15тЖТ
    16тЖТexport function isObject(x: unknown): x is object {
    17тЖТ  return typeof x === 'object' && x != null
    18тЖТ}
    20тЖТ/**
    21тЖТ * Check if a value is a non-array object.
    22тЖТ */
    23тЖТ
    24тЖТexport function isNonArrayObject(x: unknown): x is object {
    25тЖТ  return isObject(x) && !Array.isArray(x)
    26тЖТ}
    28тЖТ/**
    29тЖТ * Check if a value is a plain object.
    30тЖТ */
    31тЖТ
    32тЖТexport function isPlainObject(x: unknown): x is { [key: string]: any } {
    33тЖТ  if (Object.prototype.toString.call(x) !== '[object Object]') {
    34тЖТ    return false
    35тЖТ  }
    36тЖТ
    37тЖТ  const prototype = Object.getPrototypeOf(x)
    38тЖТ  return prototype === null || prototype === Object.prototype
    39тЖТ}
    41тЖТ/**
    42тЖТ * Return a value as a printable string.
    43тЖТ */
    44тЖТ
    45тЖТexport function print(value: any): string {
    46тЖТ  if (typeof value === 'symbol') {
    47тЖТ    return value.toString()
    48тЖТ  }
    49тЖТ
    50тЖТ  return typeof value === 'string' ? JSON.stringify(value) : `${value}`
    51тЖТ}
    53тЖТ/**
    54тЖТ * Shifts (removes and returns) the first value from the `input` iterator.
    55тЖТ * Like `Array.prototype.shift()` but for an `Iterator`.
    56тЖТ */
    57тЖТ
    58тЖТexport function shiftIterator<T>(input: Iterator<T>): T | undefined {
    59тЖТ  const { done, value } = input.next()
    60тЖТ  return done ? undefined : value
    61тЖТ}
    63тЖТ/**
    64тЖТ * Convert a single validation result to a failure.
    65тЖТ */
    66тЖТ
    67тЖТexport function toFailure<T, S>(
    68тЖТ  result: string | boolean | Partial<Failure>,
    69тЖТ  context: Context,
    70тЖТ  struct: Struct<T, S>,
    71тЖТ  value: any
    72тЖТ): Failure | undefined {
    73тЖТ  if (result === true) {
    74тЖТ    return
    75тЖТ  } else if (result === false) {
    76тЖТ    result = {}
    77тЖТ  } else if (typeof result === 'string') {
    78тЖТ    result = { message: result }
    79тЖТ  }
    80тЖТ
    81тЖТ  const { path, branch } = context
    82тЖТ  const { type } = struct
    83тЖТ  const {
    84тЖТ    refinement,
    85тЖТ    message = `Expected a value of type \`${type}\`${
    86тЖТ      refinement ? ` with refinement \`${refinement}\`` : ''
    87тЖТ    }, but received: \`${print(value)}\``,
    88тЖТ  } = result
    89тЖТ
    90тЖТ  return {
    91тЖТ    value,
    92тЖТ    type,
    93тЖТ    refinement,
    94тЖТ    key: path[path.length - 1],
    95тЖТ    path,
    96тЖТ    branch,
    97тЖТ    ...result,
    98тЖТ    message,
    99тЖТ  }
   100тЖТ}

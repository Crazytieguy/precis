   284→  Optionalize<{ [K in keyof S]: Infer<S[K]> }>
   285→>
   287→/**
   288→ * Omit properties from a type that extend from a specific type.
   289→ */
   290→
   291→export type OmitBy<T, V> = Omit<
   292→  T,
   293→  { [K in keyof T]: V extends Extract<T[K], V> ? K : never }[keyof T]
   294→>
   296→/**
   297→ * Normalize properties of a type that allow `undefined` to make them optional.
   298→ */
   299→
   300→export type Optionalize<S extends object> = OmitBy<S, undefined> &
   301→  Partial<PickBy<S, undefined>>
   303→/**
   304→ * Transform an object schema type to represent a partial.
   305→ */
   306→
   307→export type PartialObjectSchema<S extends ObjectSchema> = {
   308→  [K in keyof S]: Struct<Infer<S[K]> | undefined>
   309→}
   311→/**
   312→ * Pick properties from a type that extend from a specific type.
   313→ */
   314→
   315→export type PickBy<T, V> = Pick<
   316→  T,
   317→  { [K in keyof T]: V extends Extract<T[K], V> ? K : never }[keyof T]
   318→>
   320→/**
   321→ * Simplifies a type definition to its most basic representation.
   322→ */
   323→
   324→export type Simplify<T> = T extends any[] | Date
   325→  ? T
   326→  : { [K in keyof T]: T[K] } & {}
   328→export type If<B extends Boolean, Then, Else> = B extends true ? Then : Else
   330→/**
   331→ * A schema for any type of struct.
   332→ */
   333→
   334→export type StructSchema<T> = [T] extends [string | undefined | null]
   335→  ? [T] extends [IsMatch<T, string | undefined | null>]
   336→    ? null
   337→    : [T] extends [IsUnion<T>]
   338→      ? EnumSchema<T>
   339→      : T
   340→  : [T] extends [number | undefined | null]
   341→    ? [T] extends [IsMatch<T, number | undefined | null>]
   342→      ? null
   343→      : [T] extends [IsUnion<T>]
   344→        ? EnumSchema<T>
   345→        : T
   346→    : [T] extends [boolean]
   347→      ? [T] extends [IsExactMatch<T, boolean>]
   348→        ? null
   349→        : T
   350→      : T extends
   351→            | bigint
   352→            | symbol
   353→            | undefined
   354→            | null
   355→            | Function
   356→            | Date
   357→            | Error
   358→            | RegExp
   359→            | Map<any, any>
   360→            | WeakMap<any, any>
   361→            | Set<any>
   362→            | WeakSet<any>
   363→            | Promise<any>
   364→        ? null
   365→        : T extends Array<infer E>
   366→          ? T extends IsTuple<T>
   367→            ? null
   368→            : Struct<E>
   369→          : T extends object
   370→            ? T extends IsRecord<T>
   371→              ? null
   372→              : { [K in keyof T]: Describe<T[K]> }
   373→            : null
   375→/**
   376→ * A schema for tuple structs.
   377→ */
   378→
   379→export type TupleSchema<T> = { [K in keyof T]: Struct<T[K]> }
   381→/**
   382→ * Shorthand type for matching any `Struct`.
   383→ */
   384→
   385→export type AnyStruct = Struct<any, any>
   387→/**
   388→ * Infer a tuple of types from a tuple of `Struct`s.
   389→ *
   390→ * This is used to recursively retrieve the type from `union` `intersection` and
   391→ * `tuple` structs.
   392→ */
   393→
   394→export type InferStructTuple<
   395→  Tuple extends AnyStruct[],
   396→  Length extends number = Tuple['length'],
   397→> = Length extends Length
   398→  ? number extends Length
   399→    ? Tuple
   400→    : _InferTuple<Tuple, Length, []>
   401→  : never
   402→type _InferTuple<
   403→  Tuple extends AnyStruct[],
   404→  Length extends number,
   405→  Accumulated extends unknown[],
   406→  Index extends number = Accumulated['length'],
   407→> = Index extends Length
   408→  ? Accumulated
   409→  : _InferTuple<Tuple, Length, [...Accumulated, Infer<Tuple[Index]>]>

   113‚Üí    } = {}
   114‚Üí  ): [StructError, undefined] | [undefined, T] {
   115‚Üí    return validate(value, this, options)
   116‚Üí  }
   119‚Üí/**
   120‚Üí * Assert that a value passes a struct, throwing if it doesn't.
   121‚Üí */
   122‚Üí
   123‚Üíexport function assert<T, S>(
   124‚Üí  value: unknown,
   125‚Üí  struct: Struct<T, S>,
   126‚Üí  message?: string
   127‚Üí): asserts value is T {
   128‚Üí  const result = validate(value, struct, { message })
   129‚Üí
   130‚Üí  if (result[0]) {
   131‚Üí    throw result[0]
   132‚Üí  }
   133‚Üí}
   135‚Üí/**
   136‚Üí * Create a value with the coercion logic of struct and validate it.
   137‚Üí */
   138‚Üí
   139‚Üíexport function create<T, S>(
   140‚Üí  value: unknown,
   141‚Üí  struct: Struct<T, S>,
   142‚Üí  message?: string
   143‚Üí): T {
   144‚Üí  const result = validate(value, struct, { coerce: true, message })
   145‚Üí
   146‚Üí  if (result[0]) {
   147‚Üí    throw result[0]
   148‚Üí  } else {
   149‚Üí    return result[1]
   150‚Üí  }
   151‚Üí}
   153‚Üí/**
   154‚Üí * Mask a value, returning only the subset of properties defined by a struct.
   155‚Üí */
   156‚Üí
   157‚Üíexport function mask<T, S>(
   158‚Üí  value: unknown,
   159‚Üí  struct: Struct<T, S>,
   160‚Üí  message?: string
   161‚Üí): T {
   162‚Üí  const result = validate(value, struct, { coerce: true, mask: true, message })
   163‚Üí
   164‚Üí  if (result[0]) {
   165‚Üí    throw result[0]
   166‚Üí  } else {
   167‚Üí    return result[1]
   168‚Üí  }
   169‚Üí}
   171‚Üí/**
   172‚Üí * Check if a value passes a struct.
   173‚Üí */
   174‚Üí
   175‚Üíexport function is<T, S>(value: unknown, struct: Struct<T, S>): value is T {
   176‚Üí  const result = validate(value, struct)
   177‚Üí  return !result[0]
   178‚Üí}
   180‚Üí/**
   181‚Üí * Validate a value against a struct, returning an error if invalid, or the
   182‚Üí * value (with potential coercion) if valid.
   183‚Üí */
   184‚Üí
   185‚Üíexport function validate<T, S>(
   186‚Üí  value: unknown,
   187‚Üí  struct: Struct<T, S>,
   188‚Üí  options: {
   189‚Üí    coerce?: boolean
   190‚Üí    mask?: boolean
   191‚Üí    message?: string
   192‚Üí  } = {}
   193‚Üí): [StructError, undefined] | [undefined, T] {
   194‚Üí  const tuples = run(value, struct, options)
   195‚Üí  const tuple = shiftIterator(tuples)!
   196‚Üí
   197‚Üí  if (tuple[0]) {
   198‚Üí    const error = new StructError(tuple[0], function* () {
   199‚Üí      for (const t of tuples) {
   200‚Üí        if (t[0]) {
   201‚Üí          yield t[0]
   202‚Üí        }
   203‚Üí      }
   204‚Üí    })
   205‚Üí
   206‚Üí    return [error, undefined]
   207‚Üí  } else {
   208‚Üí    const v = tuple[1]
   209‚Üí    return [undefined, v]
   210‚Üí  }
   211‚Üí}
   213‚Üí/**
   214‚Üí * A `Context` contains information about the current location of the
   215‚Üí * validation inside the initial input value. It also carries `mask`
   216‚Üí * since it's a run-time flag determining how the validation was invoked
   217‚Üí * (via `mask()` or via `validate()`), plus it applies recursively
   218‚Üí * to all of the nested structs.
   219‚Üí */
   220‚Üí
   221‚Üíexport type Context = {
   222‚Üí  branch: Array<any>

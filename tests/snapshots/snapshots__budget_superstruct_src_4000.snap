    16‚Üí/**
    17‚Üí * `StructError` objects are thrown (or returned) when validation fails.
    18‚Üí *
    19‚Üí * Validation logic is design to exit early for maximum performance. The error
    20‚Üí * represents the first error encountered during validation. For more detail,
    21‚Üí * the `error.failures` property is a generator function that can be run to
    22‚Üí * continue validation and receive all the failures in the data.
    23‚Üí */
    24‚Üí
    25‚Üíexport class StructError extends TypeError {
    26‚Üí  value: any
    27‚Üí  key!: any
    28‚Üí  type!: string
    29‚Üí  refinement!: string | undefined
    30‚Üí  path!: Array<any>
    31‚Üí  branch!: Array<any>
    32‚Üí  failures: () => Array<Failure>;
    33‚Üí  [x: string]: any
    34‚Üí
    35‚Üí  constructor(failure: Failure, failures: () => Generator<Failure>) {
    36‚Üí    let cached: Array<Failure> | undefined
    37‚Üí    const { message, explanation, ...rest } = failure
    38‚Üí    const { path } = failure
    39‚Üí    const msg =
    40‚Üí      path.length === 0 ? message : `At path: ${path.join('.')} -- ${message}`
    41‚Üí    super(explanation ?? msg)
    42‚Üí    if (explanation != null) this.cause = msg
    43‚Üí    Object.assign(this, rest)
    44‚Üí    this.name = this.constructor.name
    45‚Üí    this.failures = () => {
    46‚Üí      return (cached ??= [failure, ...failures()])
    47‚Üí    }
    48‚Üí  }

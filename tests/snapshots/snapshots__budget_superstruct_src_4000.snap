   228‚Üí * A type utility to extract the type from a `Struct` class.
   231‚Üíexport type Infer<T extends Struct<any, any>> = T['TYPE']
   234‚Üí * A type utility to describe that a struct represents a TypeScript type.
   237‚Üíexport type Describe<T> = Struct<T, StructSchema<T>>
   240‚Üí * A `Result` is returned from validation functions.
   243‚Üíexport type Result =
   244‚Üí  | boolean
   245‚Üí  | string
   246‚Üí  | Partial<Failure>
   247‚Üí  | Iterable<boolean | string | Partial<Failure>>
   250‚Üí * A `Coercer` takes an unknown value and optionally coerces it.
   253‚Üíexport type Coercer<T = unknown> = (value: T, context: Context) => unknown
   256‚Üí * A `Validator` takes an unknown value and validates it.
   259‚Üíexport type Validator = (value: unknown, context: Context) => Result
   262‚Üí * A `Refiner` takes a value of a known type and validates it against a further
   263‚Üí * constraint.
   266‚Üíexport type Refiner<T> = (value: T, context: Context) => Result


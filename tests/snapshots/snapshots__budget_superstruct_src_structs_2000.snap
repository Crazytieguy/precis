     6→ * Augment a `Struct` to add an additional coercion step to its input.
     7→ *
     8→ * This allows you to transform input data before validating it, to increase the
     9→ * likelihood that it passes validation—for example for default values, parsing
    10→ * different formats, etc.
    11→ *
    12→ * Note: You must use `create(value, Struct)` on the value to have the coercion
    13→ * take effect! Using simply `assert()` or `is()` will not use coercion.
    16→export function coerce<T, S, C>(
    17→  struct: Struct<T, S>,
    18→  condition: Struct<C, any>,
    19→  coercer: Coercer<C>
    20→): Struct<T, S> {
    21→  return new Struct({
    22→    ...struct,
    23→    coercer: (value, ctx) => {
    24→      return is(value, condition)
    25→        ? struct.coercer(coercer(value, ctx), ctx)
    26→        : struct.coercer(value, ctx)
    27→    },
    28→  })
    29→}

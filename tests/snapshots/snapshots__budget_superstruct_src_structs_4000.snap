   138→/**
   139→ * Augment a `Struct` to add an additional refinement to the validation.
   140→ *
   141→ * The refiner function is guaranteed to receive a value of the struct's type,
   142→ * because the struct's existing validation will already have passed. This
   143→ * allows you to layer additional validation on top of existing structs.
   144→ */
   145→
   146→export function refine<T, S>(
   147→  struct: Struct<T, S>,
   148→  name: string,
   149→  refiner: Refiner<T>
   150→): Struct<T, S> {
   151→  return new Struct({
   152→    ...struct,
   153→    *refiner(value, ctx) {
   154→      yield* struct.refiner(value, ctx)
   155→      const result = refiner(value, ctx)
   156→      const failures = toFailures(result, ctx, struct, value)
   157→
   158→      for (const failure of failures) {
   159→        yield { ...failure, refinement: name }
   160→      }
   161→    },
   162→  })
   163→}

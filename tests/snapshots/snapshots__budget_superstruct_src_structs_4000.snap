utilities.ts
     1‚Üíimport { Context, Struct, Validator } from '../struct.js'
     2‚Üíimport {
     3‚Üí  Assign,
     4‚Üí  ObjectSchema,
     5‚Üí  ObjectType,
     6‚Üí  PartialObjectSchema,
     7‚Üí} from '../utils.js'
     8‚Üíimport { object, optional, type } from './types.js'
    60‚Üíexport function assign(...Structs: Struct<any>[]): any {
    61‚Üí  const isType = Structs[0].type === 'type'
    62‚Üí  const schemas = Structs.map((s) => s.schema)
    63‚Üí  const schema = Object.assign({}, ...schemas)
    64‚Üí  return isType ? type(schema) : object(schema)
    65‚Üí}
    67‚Üí/**
    68‚Üí * Define a new struct type with a custom validation function.
    69‚Üí */
    70‚Üí
    71‚Üíexport function define<T>(name: string, validator: Validator): Struct<T, null> {
    72‚Üí  return new Struct({ type: name, schema: null, validator })
    73‚Üí}
    75‚Üí/**
    76‚Üí * Create a new struct based on an existing struct, but the value is allowed to
    77‚Üí * be `undefined`. `log` will be called if the value is not `undefined`.
    78‚Üí */
    79‚Üí
    80‚Üíexport function deprecated<T>(
    81‚Üí  struct: Struct<T>,
    82‚Üí  log: (value: unknown, ctx: Context) => void
    83‚Üí): Struct<T> {
    84‚Üí  return new Struct({
    85‚Üí    ...struct,
    86‚Üí    refiner: (value, ctx) => value === undefined || struct.refiner(value, ctx),
    87‚Üí    validator(value, ctx) {
    88‚Üí      if (value === undefined) {
    89‚Üí        return true
    90‚Üí      } else {
    91‚Üí        log(value, ctx)
    92‚Üí        return struct.validator(value, ctx)
    93‚Üí      }
    94‚Üí    },
    95‚Üí  })
    96‚Üí}
    98‚Üí/**
    99‚Üí * Create a struct with dynamic validation logic.
   100‚Üí *
   101‚Üí * The callback will receive the value currently being validated, and must
   102‚Üí * return a struct object to validate it with. This can be useful to model
   103‚Üí * validation logic that changes based on its input.
   104‚Üí */
   105‚Üí
   106‚Üíexport function dynamic<T>(
   107‚Üí  fn: (value: unknown, ctx: Context) => Struct<T, any>
   108‚Üí): Struct<T, null> {
   109‚Üí  return new Struct({
   110‚Üí    type: 'dynamic',
   111‚Üí    schema: null,
   112‚Üí    *entries(value, ctx) {
   113‚Üí      const struct = fn(value, ctx)
   114‚Üí      yield* struct.entries(value, ctx)
   115‚Üí    },
   116‚Üí    validator(value, ctx) {
   117‚Üí      const struct = fn(value, ctx)
   118‚Üí      return struct.validator(value, ctx)
   119‚Üí    },
   120‚Üí    coercer(value, ctx) {
   121‚Üí      const struct = fn(value, ctx)
   122‚Üí      return struct.coercer(value, ctx)
   123‚Üí    },
   124‚Üí    refiner(value, ctx) {
   125‚Üí      const struct = fn(value, ctx)
   126‚Üí      return struct.refiner(value, ctx)
   127‚Üí    },
   128‚Üí  })
   129‚Üí}
   131‚Üí/**
   132‚Üí * Create a struct with lazily evaluated validation logic.
   133‚Üí *
   134‚Üí * The first time validation is run with the struct, the callback will be called
   135‚Üí * and must return a struct object to use. This is useful for cases where you
   136‚Üí * want to have self-referential structs for nested data structures to avoid a
   137‚Üí * circular definition problem.
   138‚Üí */
   139‚Üí
   140‚Üíexport function lazy<T>(fn: () => Struct<T, any>): Struct<T, null> {
   141‚Üí  let struct: Struct<T, any> | undefined
   142‚Üí  return new Struct({
   143‚Üí    type: 'lazy',
   144‚Üí    schema: null,
   145‚Üí    *entries(value, ctx) {
   146‚Üí      struct ??= fn()
   147‚Üí      yield* struct.entries(value, ctx)
   148‚Üí    },
   149‚Üí    validator(value, ctx) {
   150‚Üí      struct ??= fn()
   151‚Üí      return struct.validator(value, ctx)
   152‚Üí    },
   153‚Üí    coercer(value, ctx) {
   154‚Üí      struct ??= fn()
   155‚Üí      return struct.coercer(value, ctx)
   156‚Üí    },
   157‚Üí    refiner(value, ctx) {
   158‚Üí      struct ??= fn()
   159‚Üí      return struct.refiner(value, ctx)
   160‚Üí    },
   161‚Üí  })
   162‚Üí}
   164‚Üí/**
   165‚Üí * Create a new struct based on an existing object struct, but excluding
   166‚Üí * specific properties.
   167‚Üí *
   168‚Üí * Like TypeScript's `Omit` utility.
   169‚Üí */
   170‚Üí
   171‚Üíexport function omit<S extends ObjectSchema, K extends keyof S>(
   172‚Üí  struct: Struct<ObjectType<S>, S>,
   173‚Üí  keys: K[]
   174‚Üí): Struct<ObjectType<Omit<S, K>>, Omit<S, K>> {
   175‚Üí  const { schema } = struct
   176‚Üí  const subschema: any = { ...schema }
   177‚Üí
   178‚Üí  for (const key of keys) {
   179‚Üí    delete subschema[key]
   180‚Üí  }
   181‚Üí
   182‚Üí  switch (struct.type) {
   183‚Üí    case 'type':
   184‚Üí      return type(subschema as Omit<S, K>)
   185‚Üí    default:
   186‚Üí      return object(subschema as Omit<S, K>)
   187‚Üí  }
   188‚Üí}
   190‚Üí/**
   191‚Üí * Create a new struct based on an existing object struct, but with all of its
   192‚Üí * properties allowed to be `undefined`.
   193‚Üí *
   194‚Üí * Like TypeScript's `Partial` utility.
   195‚Üí */
   196‚Üí
   197‚Üíexport function partial<S extends ObjectSchema>(
   198‚Üí  struct: Struct<ObjectType<S>, S> | S
   199‚Üí): Struct<ObjectType<PartialObjectSchema<S>>, PartialObjectSchema<S>> {
   200‚Üí  const isStruct = struct instanceof Struct
   201‚Üí  const schema: any = isStruct ? { ...struct.schema } : { ...struct }
   202‚Üí
   203‚Üí  for (const key in schema) {
   204‚Üí    schema[key] = optional(schema[key])
   205‚Üí  }
   206‚Üí
   207‚Üí  if (isStruct && struct.type === 'type') {
   208‚Üí    return type(schema) as any
   209‚Üí  }
   210‚Üí
   211‚Üí  return object(schema) as any
   212‚Üí}
   214‚Üí/**
   215‚Üí * Create a new struct based on an existing object struct, but only including
   216‚Üí * specific properties.
   217‚Üí *
   218‚Üí * Like TypeScript's `Pick` utility.
   219‚Üí */
   220‚Üí
   221‚Üíexport function pick<S extends ObjectSchema, K extends keyof S>(
   222‚Üí  struct: Struct<ObjectType<S>, S>,
   223‚Üí  keys: K[]
   224‚Üí): Struct<ObjectType<Pick<S, K>>, Pick<S, K>> {
   225‚Üí  const { schema } = struct
   226‚Üí  const subschema: any = {}
   227‚Üí
   228‚Üí  for (const key of keys) {
   229‚Üí    subschema[key] = schema[key]
   230‚Üí  }
   231‚Üí
   232‚Üí  switch (struct.type) {
   233‚Üí    case 'type':
   234‚Üí      return type(subschema) as any
   235‚Üí
   236‚Üí    default:
   237‚Üí      return object(subschema) as any
   238‚Üí  }
   239‚Üí}
   241‚Üí/**
   242‚Üí * Define a new struct type with a custom validation function.
   243‚Üí *
   244‚Üí * @deprecated This function has been renamed to `define`.
   245‚Üí */
   246‚Üí
   247‚Üíexport function struct<T>(name: string, validator: Validator): Struct<T, null> {
   248‚Üí  console.warn(
   249‚Üí    'superstruct@0.11 - The `struct` helper has been renamed to `define`.'
   250‚Üí  )
   251‚Üí
   252‚Üí  return define(name, validator)
   253‚Üí}

     1‚Üíimport { Infer, Struct } from '../struct.js'
     2‚Üíimport { define } from './utilities.js'
     3‚Üíimport {
     4‚Üí  ObjectSchema,
     5‚Üí  ObjectType,
     6‚Üí  print,
     7‚Üí  run,
     8‚Üí  isObject,
     9‚Üí  isNonArrayObject,
    10‚Üí  AnyStruct,
    11‚Üí  InferStructTuple,
    12‚Üí  UnionToIntersection,
    13‚Üí} from '../utils.js'
    15‚Üí/**
    16‚Üí * Ensure that any value passes validation.
    17‚Üí */
    18‚Üí
    19‚Üíexport function any(): Struct<any, null> {
    20‚Üí  return define('any', () => true)
    21‚Üí}
    33‚Üíexport function array<T extends Struct<any>>(Element?: T): any {
    34‚Üí  return new Struct({
    35‚Üí    type: 'array',
    36‚Üí    schema: Element,
    37‚Üí    *entries(value) {
    38‚Üí      if (Element && Array.isArray(value)) {
    39‚Üí        for (const [i, v] of value.entries()) {
    40‚Üí          yield [i, v, Element]
    41‚Üí        }
    42‚Üí      }
    43‚Üí    },
    44‚Üí    coercer(value) {
    45‚Üí      return Array.isArray(value) ? value.slice() : value
    46‚Üí    },
    47‚Üí    validator(value) {
    48‚Üí      return (
    49‚Üí        Array.isArray(value) ||
    50‚Üí        `Expected an array value, but received: ${print(value)}`
    51‚Üí      )
    52‚Üí    },
    53‚Üí  })
    54‚Üí}
    56‚Üí/**
    57‚Üí * Ensure that a value is a bigint.
    58‚Üí */
    59‚Üí
    60‚Üíexport function bigint(): Struct<bigint, null> {
    61‚Üí  return define('bigint', (value) => {
    62‚Üí    return typeof value === 'bigint'
    63‚Üí  })
    64‚Üí}
    66‚Üí/**
    67‚Üí * Ensure that a value is a boolean.
    68‚Üí */
    69‚Üí
    70‚Üíexport function boolean(): Struct<boolean, null> {
    71‚Üí  return define('boolean', (value) => {
    72‚Üí    return typeof value === 'boolean'
    73‚Üí  })
    74‚Üí}
    76‚Üí/**
    77‚Üí * Ensure that a value is a valid `Date`.
    78‚Üí *
    79‚Üí * Note: this also ensures that the value is *not* an invalid `Date` object,
    80‚Üí * which can occur when parsing a date fails but still returns a `Date`.
    81‚Üí */
    82‚Üí
    83‚Üíexport function date(): Struct<Date, null> {
    84‚Üí  return define('date', (value) => {
    85‚Üí    return (
    86‚Üí      (value instanceof Date && !isNaN(value.getTime())) ||
    87‚Üí      `Expected a valid \`Date\` object, but received: ${print(value)}`
    88‚Üí    )
    89‚Üí  })
    90‚Üí}
   105‚Üíexport function enums<U extends string | number, T extends readonly U[]>(
   106‚Üí  values: T
   107‚Üí): any {
   108‚Üí  const schema: any = {}
   109‚Üí  const description = values.map((v) => print(v)).join()
   110‚Üí
   111‚Üí  for (const key of values) {
   112‚Üí    schema[key] = key
   113‚Üí  }
   114‚Üí
   115‚Üí  return new Struct({
   116‚Üí    type: 'enums',
   117‚Üí    schema,
   118‚Üí    validator(value) {
   119‚Üí      return (
   120‚Üí        values.includes(value as any) ||
   121‚Üí        `Expected one of \`${description}\`, but received: ${print(value)}`
   122‚Üí      )
   123‚Üí    },
   124‚Üí  })
   125‚Üí}
   127‚Üí/**
   128‚Üí * Ensure that a value is a function.
   129‚Üí */
   130‚Üí
   131‚Üíexport function func(): Struct<Function, null> {
   132‚Üí  return define('func', (value) => {
   133‚Üí    return (
   134‚Üí      typeof value === 'function' ||
   135‚Üí      `Expected a function, but received: ${print(value)}`
   136‚Üí    )
   137‚Üí  })
   138‚Üí}
   140‚Üí/**
   141‚Üí * Ensure that a value is an instance of a specific class.
   142‚Üí */
   143‚Üí
   144‚Üíexport function instance<T extends { new (...args: any): any }>(
   145‚Üí  Class: T
   146‚Üí): Struct<InstanceType<T>, null> {
   147‚Üí  return define('instance', (value) => {
   148‚Üí    return (
   149‚Üí      value instanceof Class ||
   150‚Üí      `Expected a \`${Class.name}\` instance, but received: ${print(value)}`
   151‚Üí    )
   152‚Üí  })
   153‚Üí}
   155‚Üí/**
   156‚Üí * Ensure that a value is an integer.
   157‚Üí */
   158‚Üí
   159‚Üíexport function integer(): Struct<number, null> {
   160‚Üí  return define('integer', (value) => {
   161‚Üí    return (
   162‚Üí      (typeof value === 'number' && !isNaN(value) && Number.isInteger(value)) ||
   163‚Üí      `Expected an integer, but received: ${print(value)}`
   164‚Üí    )
   165‚Üí  })
   166‚Üí}
   168‚Üí/**
   169‚Üí * Ensure that a value matches all of a set of types.
   170‚Üí */
   171‚Üí
   172‚Üíexport function intersection<A extends AnyStruct, B extends AnyStruct[]>(
   173‚Üí  Structs: [A, ...B]
   174‚Üí): Struct<Infer<A> & UnionToIntersection<InferStructTuple<B>[number]>, null> {
   175‚Üí  return new Struct({
   176‚Üí    type: 'intersection',
   177‚Üí    schema: null,
   178‚Üí    *entries(value, ctx) {
   179‚Üí      for (const S of Structs) {
   180‚Üí        yield* S.entries(value, ctx)
   181‚Üí      }
   182‚Üí    },
   183‚Üí    *validator(value, ctx) {
   184‚Üí      for (const S of Structs) {
   185‚Üí        yield* S.validator(value, ctx)
   186‚Üí      }
   187‚Üí    },
   188‚Üí    *refiner(value, ctx) {
   189‚Üí      for (const S of Structs) {
   190‚Üí        yield* S.refiner(value, ctx)
   191‚Üí      }
   192‚Üí    },
   193‚Üí  })
   194‚Üí}
   204‚Üíexport function literal<T>(constant: T): any {
   205‚Üí  const description = print(constant)
   206‚Üí  const t = typeof constant
   207‚Üí  return new Struct({
   208‚Üí    type: 'literal',
   209‚Üí    schema:
   210‚Üí      t === 'string' || t === 'number' || t === 'boolean' ? constant : null,
   211‚Üí    validator(value) {
   212‚Üí      return (
   213‚Üí        value === constant ||
   214‚Üí        `Expected the literal \`${description}\`, but received: ${print(value)}`
   215‚Üí      )
   216‚Üí    },
   217‚Üí  })
   218‚Üí}
   230‚Üíexport function map<K, V>(Key?: Struct<K>, Value?: Struct<V>): any {
   231‚Üí  return new Struct({
   232‚Üí    type: 'map',
   233‚Üí    schema: null,
   234‚Üí    *entries(value) {
   235‚Üí      if (Key && Value && value instanceof Map) {
   236‚Üí        for (const [k, v] of value.entries()) {
   237‚Üí          yield [k as string, k, Key]
   238‚Üí          yield [k as string, v, Value]
   239‚Üí        }
   240‚Üí      }
   241‚Üí    },
   242‚Üí    coercer(value) {
   243‚Üí      return value instanceof Map ? new Map(value) : value
   244‚Üí    },
   245‚Üí    validator(value) {
   246‚Üí      return (
   247‚Üí        value instanceof Map ||
   248‚Üí        `Expected a \`Map\` object, but received: ${print(value)}`
   249‚Üí      )
   250‚Üí    },
   251‚Üí  })
   252‚Üí}
   254‚Üí/**
   255‚Üí * Ensure that no value ever passes validation.
   256‚Üí */
   257‚Üí
   258‚Üíexport function never(): Struct<never, null> {
   259‚Üí  return define('never', () => false)
   260‚Üí}
   262‚Üí/**
   263‚Üí * Augment an existing struct to allow `null` values.
   264‚Üí */
   265‚Üí
   266‚Üíexport function nullable<T, S>(struct: Struct<T, S>): Struct<T | null, S> {
   267‚Üí  return new Struct({
   268‚Üí    ...struct,
   269‚Üí    validator: (value, ctx) => value === null || struct.validator(value, ctx),
   270‚Üí    refiner: (value, ctx) => value === null || struct.refiner(value, ctx),
   271‚Üí  })
   272‚Üí}
   274‚Üí/**
   275‚Üí * Ensure that a value is a number.
   276‚Üí */
   277‚Üí
   278‚Üíexport function number(): Struct<number, null> {
   279‚Üí  return define('number', (value) => {
   280‚Üí    return (
   281‚Üí      (typeof value === 'number' && !isNaN(value)) ||
   282‚Üí      `Expected a number, but received: ${print(value)}`
   283‚Üí    )
   284‚Üí  })
   285‚Üí}
   298‚Üíexport function object<S extends ObjectSchema>(schema?: S): any {
   299‚Üí  const knowns = schema ? Object.keys(schema) : []
   300‚Üí  const Never = never()
   301‚Üí  return new Struct({
   302‚Üí    type: 'object',
   303‚Üí    schema: schema ? schema : null,
   304‚Üí    *entries(value) {
   305‚Üí      if (schema && isObject(value)) {
   306‚Üí        const unknowns = new Set(Object.keys(value))
   307‚Üí
   308‚Üí        for (const key of knowns) {
   309‚Üí          unknowns.delete(key)
   310‚Üí          yield [key, value[key], schema[key]]
   311‚Üí        }
   312‚Üí
   313‚Üí        for (const key of unknowns) {
   314‚Üí          yield [key, value[key], Never]
   315‚Üí        }
   316‚Üí      }
   317‚Üí    },
   318‚Üí    validator(value) {
   319‚Üí      return (
   320‚Üí        isNonArrayObject(value) ||
   321‚Üí        `Expected an object, but received: ${print(value)}`
   322‚Üí      )
   323‚Üí    },
   324‚Üí    coercer(value, ctx) {
   325‚Üí      if (!isNonArrayObject(value)) {
   326‚Üí        return value
   327‚Üí      }
   328‚Üí
   329‚Üí      const coerced = { ...value }
   330‚Üí
   331‚Üí      // The `object` struct has special behaviour enabled by the mask flag.
   332‚Üí      // When masking, properties that are not in the schema are deleted from
   333‚Üí      // the coerced object instead of eventually failing validaiton.
   334‚Üí      if (ctx.mask && schema) {
   335‚Üí        for (const key in coerced) {
   336‚Üí          if (schema[key] === undefined) {
   337‚Üí            delete coerced[key]
   338‚Üí          }
   339‚Üí        }
   340‚Üí      }
   341‚Üí
   342‚Üí      return coerced
   343‚Üí    },
   344‚Üí  })
   345‚Üí}
   347‚Üí/**
   348‚Üí * Augment a struct to allow `undefined` values.
   349‚Üí */
   350‚Üí
   351‚Üíexport function optional<T, S>(struct: Struct<T, S>): Struct<T | undefined, S> {
   352‚Üí  return new Struct({
   353‚Üí    ...struct,
   354‚Üí    validator: (value, ctx) =>
   355‚Üí      value === undefined || struct.validator(value, ctx),
   356‚Üí    refiner: (value, ctx) => value === undefined || struct.refiner(value, ctx),
   357‚Üí  })
   358‚Üí}
   360‚Üí/**
   361‚Üí * Ensure that a value is an object with keys and values of specific types, but
   362‚Üí * without ensuring any specific shape of properties.
   363‚Üí *
   364‚Üí * Like TypeScript's `Record` utility.
   365‚Üí */
   366‚Üí
   367‚Üíexport function record<K extends string, V>(
   368‚Üí  Key: Struct<K>,
   369‚Üí  Value: Struct<V>
   370‚Üí): Struct<Record<K, V>, null> {
   371‚Üí  return new Struct({
   372‚Üí    type: 'record',
   373‚Üí    schema: null,
   374‚Üí    *entries(value) {
   375‚Üí      if (isObject(value)) {
   376‚Üí        for (const k in value) {
   377‚Üí          const v = value[k]
   378‚Üí          yield [k, k, Key]
   379‚Üí          yield [k, v, Value]
   380‚Üí        }
   381‚Üí      }
   382‚Üí    },
   383‚Üí    validator(value) {
   384‚Üí      return (
   385‚Üí        isNonArrayObject(value) ||
   386‚Üí        `Expected an object, but received: ${print(value)}`
   387‚Üí      )
   388‚Üí    },
   389‚Üí    coercer(value) {
   390‚Üí      return isNonArrayObject(value) ? { ...value } : value
   391‚Üí    },
   392‚Üí  })

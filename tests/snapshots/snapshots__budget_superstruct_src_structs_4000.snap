   518→/**
   519→ * Ensure that a value matches one of a set of types.
   520→ */
   521→
   522→export function union<A extends AnyStruct, B extends AnyStruct[]>(
   523→  Structs: [A, ...B]
   524→): Struct<Infer<A> | InferStructTuple<B>[number], null> {
   525→  const description = Structs.map((s) => s.type).join(' | ')
   526→  return new Struct({
   527→    type: 'union',
   528→    schema: null,
   529→    coercer(value, ctx) {
   530→      for (const S of Structs) {
   531→        const [error, coerced] = S.validate(value, {

     6‚Üí * Augment a `Struct` to add an additional coercion step to its input.
     7‚Üí *
     8‚Üí * This allows you to transform input data before validating it, to increase the
     9‚Üí * likelihood that it passes validation‚Äîfor example for default values, parsing
    10‚Üí * different formats, etc.
    11‚Üí *
    12‚Üí * Note: You must use `create(value, Struct)` on the value to have the coercion
    13‚Üí * take effect! Using simply `assert()` or `is()` will not use coercion.
    16‚Üíexport function coerce<T, S, C>(
    17‚Üí  struct: Struct<T, S>,
    18‚Üí  condition: Struct<C, any>,
    19‚Üí  coercer: Coercer<C>
    20‚Üí): Struct<T, S> {
    21‚Üí  return new Struct({
    22‚Üí    ...struct,
    23‚Üí    coercer: (value, ctx) => {
    24‚Üí      return is(value, condition)
    25‚Üí        ? struct.coercer(coercer(value, ctx), ctx)
    26‚Üí        : struct.coercer(value, ctx)
    27‚Üí    },
    28‚Üí  })
    29‚Üí}
    32‚Üí * Augment a struct to replace `undefined` values with a default.
    33‚Üí *
    34‚Üí * Note: You must use `create(value, Struct)` on the value to have the coercion
    35‚Üí * take effect! Using simply `assert()` or `is()` will not use coercion.
    38‚Üíexport function defaulted<T, S>(
    39‚Üí  struct: Struct<T, S>,
    40‚Üí  fallback: any,
    41‚Üí  options: {
    42‚Üí    strict?: boolean
    43‚Üí  } = {}
    44‚Üí): Struct<T, S> {
    45‚Üí  return coerce(struct, unknown(), (x) => {
    46‚Üí    const f = typeof fallback === 'function' ? fallback() : fallback
    47‚Üí
    48‚Üí    if (x === undefined) {
    49‚Üí      return f
    50‚Üí    }
    51‚Üí
    52‚Üí    if (!options.strict && isPlainObject(x) && isPlainObject(f)) {
    53‚Üí      const ret = { ...x }
    54‚Üí      let changed = false
    55‚Üí
    56‚Üí      for (const key in f) {
    57‚Üí        if (ret[key] === undefined) {
    58‚Üí          ret[key] = f[key]
    59‚Üí          changed = true
    60‚Üí        }
    61‚Üí      }
    62‚Üí
    63‚Üí      if (changed) {
    64‚Üí        return ret
    65‚Üí      }
    66‚Üí    }
    67‚Üí
    68‚Üí    return x
    69‚Üí  })
    70‚Üí}
    73‚Üí * Augment a struct to trim string inputs.
    74‚Üí *
    75‚Üí * Note: You must use `create(value, Struct)` on the value to have the coercion
    76‚Üí * take effect! Using simply `assert()` or `is()` will not use coercion.
    79‚Üíexport function trimmed<T, S>(struct: Struct<T, S>): Struct<T, S> {
    80‚Üí  return coerce(struct, string(), (x) => x.trim())
    81‚Üí}


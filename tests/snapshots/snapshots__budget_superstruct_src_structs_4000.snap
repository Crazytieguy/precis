   168→/**
   169→ * Ensure that a value matches all of a set of types.
   170→ */
   171→
   172→export function intersection<A extends AnyStruct, B extends AnyStruct[]>(
   173→  Structs: [A, ...B]
   174→): Struct<Infer<A> & UnionToIntersection<InferStructTuple<B>[number]>, null> {
   175→  return new Struct({
   176→    type: 'intersection',
   177→    schema: null,
   178→    *entries(value, ctx) {
   179→      for (const S of Structs) {
   180→        yield* S.entries(value, ctx)
   181→      }
   182→    },
   183→    *validator(value, ctx) {
   184→      for (const S of Structs) {
   185→        yield* S.validator(value, ctx)
   186→      }
   187→    },
   188→    *refiner(value, ctx) {
   189→      for (const S of Structs) {
   190→        yield* S.refiner(value, ctx)
   191→      }
   192→    },
   193→  })
   194→}
   204→export function literal<T>(constant: T): any {
   205→  const description = print(constant)
   206→  const t = typeof constant
   207→  return new Struct({
   208→    type: 'literal',
   209→    schema:
   210→      t === 'string' || t === 'number' || t === 'boolean' ? constant : null,
   211→    validator(value) {
   212→      return (
   213→        value === constant ||
   214→        `Expected the literal \`${description}\`, but received: ${print(value)}`
   215→      )
   216→    },
   217→  })
   218→}
   230→export function map<K, V>(Key?: Struct<K>, Value?: Struct<V>): any {
   231→  return new Struct({
   232→    type: 'map',
   233→    schema: null,
   234→    *entries(value) {
   235→      if (Key && Value && value instanceof Map) {
   236→        for (const [k, v] of value.entries()) {
   237→          yield [k as string, k, Key]
   238→          yield [k as string, v, Value]
   239→        }
   240→      }
   241→    },
   242→    coercer(value) {
   243→      return value instanceof Map ? new Map(value) : value
   244→    },
   245→    validator(value) {
   246→      return (
   247→        value instanceof Map ||
   248→        `Expected a \`Map\` object, but received: ${print(value)}`
   249→      )
   250→    },
   251→  })
   252→}

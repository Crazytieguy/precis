   266→export function nullable<T, S>(struct: Struct<T, S>): Struct<T | null, S> {
   267→  return new Struct({
   268→    ...struct,
   269→    validator: (value, ctx) => value === null || struct.validator(value, ctx),
   270→    refiner: (value, ctx) => value === null || struct.refiner(value, ctx),
   271→  })
   272→}

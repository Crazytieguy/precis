     1→import { Struct, Refiner } from '../struct.js'
     2→import { toFailures } from '../utils.js'
     4→/**
     5→ * Ensure that a string, array, map, or set is empty.
     6→ */
     7→
     8→export function empty<
     9→  T extends string | any[] | Map<any, any> | Set<any>,
    10→  S extends any,
    11→>(struct: Struct<T, S>): Struct<T, S> {
    12→  return refine(struct, 'empty', (value) => {
    13→    const size = getSize(value)
    14→    return (
    15→      size === 0 ||
    16→      `Expected an empty ${struct.type} but received one with a size of \`${size}\``
    17→    )
    18→  })
    19→}
    21→function getSize(value: string | any[] | Map<any, any> | Set<any>): number {
    22→  if (value instanceof Map || value instanceof Set) {
    23→    return value.size
    24→  } else {
    25→    return value.length
    26→  }
    27→}
    29→/**
    30→ * Ensure that a number or date is below a threshold.
    31→ */
    32→
    33→export function max<T extends number | Date, S extends any>(
    34→  struct: Struct<T, S>,
    35→  threshold: T,
    36→  options: {
    37→    exclusive?: boolean
    38→  } = {}
    39→): Struct<T, S> {
    40→  const { exclusive } = options
    41→  return refine(struct, 'max', (value) => {
    42→    return exclusive
    43→      ? value < threshold
    44→      : value <= threshold ||
    45→          `Expected a ${struct.type} less than ${
    46→            exclusive ? '' : 'or equal to '
    47→          }${threshold} but received \`${value}\``
    48→  })
    49→}
    51→/**
    52→ * Ensure that a number or date is above a threshold.
    53→ */
    54→
    55→export function min<T extends number | Date, S extends any>(
    56→  struct: Struct<T, S>,
    57→  threshold: T,
    58→  options: {
    59→    exclusive?: boolean
    60→  } = {}
    61→): Struct<T, S> {
    62→  const { exclusive } = options
    63→  return refine(struct, 'min', (value) => {
    64→    return exclusive
    65→      ? value > threshold
    66→      : value >= threshold ||
    67→          `Expected a ${struct.type} greater than ${
    68→            exclusive ? '' : 'or equal to '
    69→          }${threshold} but received \`${value}\``
    70→  })
    71→}
    73→/**
    74→ * Ensure that a string, array, map or set is not empty.
    75→ */
    76→
    77→export function nonempty<
    78→  T extends string | any[] | Map<any, any> | Set<any>,
    79→  S extends any,
    80→>(struct: Struct<T, S>): Struct<T, S> {
    81→  return refine(struct, 'nonempty', (value) => {
    82→    const size = getSize(value)
    83→    return (
    84→      size > 0 || `Expected a nonempty ${struct.type} but received an empty one`
    85→    )
    86→  })
    87→}
    89→/**
    90→ * Ensure that a string matches a regular expression.
    91→ */
    92→
    93→export function pattern<T extends string, S extends any>(
    94→  struct: Struct<T, S>,
    95→  regexp: RegExp
    96→): Struct<T, S> {
    97→  return refine(struct, 'pattern', (value) => {
    98→    return (
    99→      regexp.test(value) ||
   100→      `Expected a ${struct.type} matching \`/${regexp.source}/\` but received "${value}"`
   101→    )
   102→  })
   103→}
   105→/**
   106→ * Ensure that a string, array, number, date, map, or set has a size (or length, or time) between `min` and `max`.
   107→ */
   108→
   109→export function size<
   110→  T extends string | number | Date | any[] | Map<any, any> | Set<any>,
   111→  S extends any,
   112→>(struct: Struct<T, S>, min: number, max: number = min): Struct<T, S> {
   113→  const expected = `Expected a ${struct.type}`
   114→  const of = min === max ? `of \`${min}\`` : `between \`${min}\` and \`${max}\``
   115→
   116→  return refine(struct, 'size', (value) => {
   117→    if (typeof value === 'number' || value instanceof Date) {
   118→      return (
   119→        (min <= value && value <= max) ||
   120→        `${expected} ${of} but received \`${value}\``
   121→      )
   122→    } else if (value instanceof Map || value instanceof Set) {
   123→      const { size } = value
   124→      return (
   125→        (min <= size && size <= max) ||
   126→        `${expected} with a size ${of} but received one with a size of \`${size}\``
   127→      )
   128→    } else {
   129→      const { length } = value as string | any[]
   130→      return (
   131→        (min <= length && length <= max) ||
   132→        `${expected} with a length ${of} but received one with a length of \`${length}\``
   133→      )

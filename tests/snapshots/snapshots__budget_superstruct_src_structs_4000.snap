     1‚Üíimport { Struct, Refiner } from '../struct.js'
     2‚Üíimport { toFailures } from '../utils.js'
     4‚Üí/**
     5‚Üí * Ensure that a string, array, map, or set is empty.
     6‚Üí */
     7‚Üí
     8‚Üíexport function empty<
     9‚Üí  T extends string | any[] | Map<any, any> | Set<any>,
    10‚Üí  S extends any,
    11‚Üí>(struct: Struct<T, S>): Struct<T, S> {
    12‚Üí  return refine(struct, 'empty', (value) => {
    13‚Üí    const size = getSize(value)
    14‚Üí    return (
    15‚Üí      size === 0 ||
    16‚Üí      `Expected an empty ${struct.type} but received one with a size of \`${size}\``
    17‚Üí    )
    18‚Üí  })
    19‚Üí}
    21‚Üífunction getSize(value: string | any[] | Map<any, any> | Set<any>): number {
    22‚Üí  if (value instanceof Map || value instanceof Set) {
    23‚Üí    return value.size
    24‚Üí  } else {
    25‚Üí    return value.length
    26‚Üí  }
    27‚Üí}
    29‚Üí/**
    30‚Üí * Ensure that a number or date is below a threshold.
    31‚Üí */
    32‚Üí
    33‚Üíexport function max<T extends number | Date, S extends any>(
    34‚Üí  struct: Struct<T, S>,
    35‚Üí  threshold: T,
    36‚Üí  options: {
    37‚Üí    exclusive?: boolean
    38‚Üí  } = {}
    39‚Üí): Struct<T, S> {
    40‚Üí  const { exclusive } = options
    41‚Üí  return refine(struct, 'max', (value) => {
    42‚Üí    return exclusive
    43‚Üí      ? value < threshold
    44‚Üí      : value <= threshold ||
    45‚Üí          `Expected a ${struct.type} less than ${
    46‚Üí            exclusive ? '' : 'or equal to '
    47‚Üí          }${threshold} but received \`${value}\``
    48‚Üí  })
    49‚Üí}
    51‚Üí/**
    52‚Üí * Ensure that a number or date is above a threshold.
    53‚Üí */
    54‚Üí
    55‚Üíexport function min<T extends number | Date, S extends any>(
    56‚Üí  struct: Struct<T, S>,
    57‚Üí  threshold: T,
    58‚Üí  options: {
    59‚Üí    exclusive?: boolean
    60‚Üí  } = {}
    61‚Üí): Struct<T, S> {
    62‚Üí  const { exclusive } = options
    63‚Üí  return refine(struct, 'min', (value) => {
    64‚Üí    return exclusive
    65‚Üí      ? value > threshold
    66‚Üí      : value >= threshold ||
    67‚Üí          `Expected a ${struct.type} greater than ${
    68‚Üí            exclusive ? '' : 'or equal to '
    69‚Üí          }${threshold} but received \`${value}\``
    70‚Üí  })
    71‚Üí}
    73‚Üí/**
    74‚Üí * Ensure that a string, array, map or set is not empty.
    75‚Üí */
    76‚Üí
    77‚Üíexport function nonempty<
    78‚Üí  T extends string | any[] | Map<any, any> | Set<any>,
    79‚Üí  S extends any,
    80‚Üí>(struct: Struct<T, S>): Struct<T, S> {
    81‚Üí  return refine(struct, 'nonempty', (value) => {
    82‚Üí    const size = getSize(value)
    83‚Üí    return (
    84‚Üí      size > 0 || `Expected a nonempty ${struct.type} but received an empty one`
    85‚Üí    )
    86‚Üí  })
    87‚Üí}
    89‚Üí/**
    90‚Üí * Ensure that a string matches a regular expression.
    91‚Üí */
    92‚Üí
    93‚Üíexport function pattern<T extends string, S extends any>(
    94‚Üí  struct: Struct<T, S>,
    95‚Üí  regexp: RegExp
    96‚Üí): Struct<T, S> {
    97‚Üí  return refine(struct, 'pattern', (value) => {
    98‚Üí    return (
    99‚Üí      regexp.test(value) ||
   100‚Üí      `Expected a ${struct.type} matching \`/${regexp.source}/\` but received "${value}"`
   101‚Üí    )
   102‚Üí  })
   103‚Üí}
   105‚Üí/**
   106‚Üí * Ensure that a string, array, number, date, map, or set has a size (or length, or time) between `min` and `max`.
   107‚Üí */
   108‚Üí
   109‚Üíexport function size<
   110‚Üí  T extends string | number | Date | any[] | Map<any, any> | Set<any>,
   111‚Üí  S extends any,
   112‚Üí>(struct: Struct<T, S>, min: number, max: number = min): Struct<T, S> {
   113‚Üí  const expected = `Expected a ${struct.type}`
   114‚Üí  const of = min === max ? `of \`${min}\`` : `between \`${min}\` and \`${max}\``
   115‚Üí
   116‚Üí  return refine(struct, 'size', (value) => {
   117‚Üí    if (typeof value === 'number' || value instanceof Date) {
   118‚Üí      return (
   119‚Üí        (min <= value && value <= max) ||
   120‚Üí        `${expected} ${of} but received \`${value}\``
   121‚Üí      )
   122‚Üí    } else if (value instanceof Map || value instanceof Set) {
   123‚Üí      const { size } = value
   124‚Üí      return (
   125‚Üí        (min <= size && size <= max) ||
   126‚Üí        `${expected} with a size ${of} but received one with a size of \`${size}\``
   127‚Üí      )
   128‚Üí    } else {
   129‚Üí      const { length } = value as string | any[]
   130‚Üí      return (
   131‚Üí        (min <= length && length <= max) ||
   132‚Üí        `${expected} with a length ${of} but received one with a length of \`${length}\``
   133‚Üí      )
   134‚Üí    }

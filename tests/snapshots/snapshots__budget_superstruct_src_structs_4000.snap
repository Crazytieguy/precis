   164→/**
   165→ * Create a new struct based on an existing object struct, but excluding
   166→ * specific properties.
   167→ *
   168→ * Like TypeScript's `Omit` utility.
   169→ */
   170→
   171→export function omit<S extends ObjectSchema, K extends keyof S>(
   172→  struct: Struct<ObjectType<S>, S>,
   173→  keys: K[]
   174→): Struct<ObjectType<Omit<S, K>>, Omit<S, K>> {
   175→  const { schema } = struct
   176→  const subschema: any = { ...schema }
   177→
   178→  for (const key of keys) {
   179→    delete subschema[key]
   180→  }
   181→
   182→  switch (struct.type) {
   183→    case 'type':
   184→      return type(subschema as Omit<S, K>)
   185→    default:
   186→      return object(subschema as Omit<S, K>)
   187→  }
   188→}
   190→/**
   191→ * Create a new struct based on an existing object struct, but with all of its
   192→ * properties allowed to be `undefined`.
   193→ *
   194→ * Like TypeScript's `Partial` utility.
   195→ */
   196→
   197→export function partial<S extends ObjectSchema>(
   198→  struct: Struct<ObjectType<S>, S> | S
   199→): Struct<ObjectType<PartialObjectSchema<S>>, PartialObjectSchema<S>> {
   200→  const isStruct = struct instanceof Struct
   201→  const schema: any = isStruct ? { ...struct.schema } : { ...struct }
   202→
   203→  for (const key in schema) {
   204→    schema[key] = optional(schema[key])
   205→  }
   206→
   207→  if (isStruct && struct.type === 'type') {
   208→    return type(schema) as any
   209→  }
   210→
   211→  return object(schema) as any
   212→}
   214→/**
   215→ * Create a new struct based on an existing object struct, but only including
   216→ * specific properties.
   217→ *
   218→ * Like TypeScript's `Pick` utility.
   219→ */
   220→
   221→export function pick<S extends ObjectSchema, K extends keyof S>(
   222→  struct: Struct<ObjectType<S>, S>,
   223→  keys: K[]
   224→): Struct<ObjectType<Pick<S, K>>, Pick<S, K>> {
   225→  const { schema } = struct
   226→  const subschema: any = {}
   227→
   228→  for (const key of keys) {
   229→    subschema[key] = schema[key]
   230→  }
   231→
   232→  switch (struct.type) {
   233→    case 'type':
   234→      return type(subschema) as any
   235→
   236→    default:
   237→      return object(subschema) as any
   238→  }
   239→}
   241→/**
   242→ * Define a new struct type with a custom validation function.
   243→ *
   244→ * @deprecated This function has been renamed to `define`.
   245→ */
   246→
   247→export function struct<T>(name: string, validator: Validator): Struct<T, null> {
   248→  console.warn(
   249→    'superstruct@0.11 - The `struct` helper has been renamed to `define`.'
   250→  )
   251→
   252→  return define(name, validator)
   253→}

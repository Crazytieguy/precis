     1→import { Context, Struct, Validator } from '../struct.js'
     2→import {
     3→  Assign,
     4→  ObjectSchema,
     5→  ObjectType,
     6→  PartialObjectSchema,
     7→} from '../utils.js'
     8→import { object, optional, type } from './types.js'
    60→export function assign(...Structs: Struct<any>[]): any {
    61→  const isType = Structs[0].type === 'type'
    62→  const schemas = Structs.map((s) => s.schema)
    63→  const schema = Object.assign({}, ...schemas)
    64→  return isType ? type(schema) : object(schema)
    65→}
    67→/**
    68→ * Define a new struct type with a custom validation function.
    69→ */
    70→
    71→export function define<T>(name: string, validator: Validator): Struct<T, null> {
    72→  return new Struct({ type: name, schema: null, validator })
    73→}
    75→/**
    76→ * Create a new struct based on an existing struct, but the value is allowed to
    77→ * be `undefined`. `log` will be called if the value is not `undefined`.
    78→ */
    79→
    80→export function deprecated<T>(
    81→  struct: Struct<T>,
    82→  log: (value: unknown, ctx: Context) => void
    83→): Struct<T> {
    84→  return new Struct({
    85→    ...struct,
    86→    refiner: (value, ctx) => value === undefined || struct.refiner(value, ctx),
    87→    validator(value, ctx) {
    88→      if (value === undefined) {
    89→        return true
    90→      } else {
    91→        log(value, ctx)
    92→        return struct.validator(value, ctx)
    93→      }
    94→    },
    95→  })
    96→}
    98→/**
    99→ * Create a struct with dynamic validation logic.
   100→ *
   101→ * The callback will receive the value currently being validated, and must
   102→ * return a struct object to validate it with. This can be useful to model
   103→ * validation logic that changes based on its input.
   104→ */
   105→
   106→export function dynamic<T>(
   107→  fn: (value: unknown, ctx: Context) => Struct<T, any>
   108→): Struct<T, null> {
   109→  return new Struct({
   110→    type: 'dynamic',
   111→    schema: null,
   112→    *entries(value, ctx) {
   113→      const struct = fn(value, ctx)
   114→      yield* struct.entries(value, ctx)
   115→    },
   116→    validator(value, ctx) {
   117→      const struct = fn(value, ctx)
   118→      return struct.validator(value, ctx)
   119→    },
   120→    coercer(value, ctx) {
   121→      const struct = fn(value, ctx)
   122→      return struct.coercer(value, ctx)
   123→    },
   124→    refiner(value, ctx) {
   125→      const struct = fn(value, ctx)
   126→      return struct.refiner(value, ctx)
   127→    },
   128→  })
   129→}
   131→/**
   132→ * Create a struct with lazily evaluated validation logic.
   133→ *
   134→ * The first time validation is run with the struct, the callback will be called
   135→ * and must return a struct object to use. This is useful for cases where you
   136→ * want to have self-referential structs for nested data structures to avoid a
   137→ * circular definition problem.
   138→ */
   139→
   140→export function lazy<T>(fn: () => Struct<T, any>): Struct<T, null> {
   141→  let struct: Struct<T, any> | undefined
   142→  return new Struct({
   143→    type: 'lazy',
   144→    schema: null,
   145→    *entries(value, ctx) {
   146→      struct ??= fn()
   147→      yield* struct.entries(value, ctx)
   148→    },
   149→    validator(value, ctx) {
   150→      struct ??= fn()
   151→      return struct.validator(value, ctx)
   152→    },
   153→    coercer(value, ctx) {
   154→      struct ??= fn()
   155→      return struct.coercer(value, ctx)
   156→    },
   157→    refiner(value, ctx) {
   158→      struct ??= fn()
   159→      return struct.refiner(value, ctx)
   160→    },
   161→  })

   395‚Üí/**
   396‚Üí * Ensure that a value is a `RegExp`.
   397‚Üí *
   398‚Üí * Note: this does not test the value against the regular expression! For that
   399‚Üí * you need to use the `pattern()` refinement.
   400‚Üí */
   401‚Üí
   402‚Üíexport function regexp(): Struct<RegExp, null> {
   403‚Üí  return define('regexp', (value) => {
   404‚Üí    return value instanceof RegExp
   405‚Üí  })
   406‚Üí}
   415‚Üíexport function set<T>(Element?: Struct<T>): any {
   416‚Üí  return new Struct({
   417‚Üí    type: 'set',
   418‚Üí    schema: null,
   419‚Üí    *entries(value) {
   420‚Üí      if (Element && value instanceof Set) {
   421‚Üí        for (const v of value) {
   422‚Üí          yield [v as string, v, Element]
   423‚Üí        }
   424‚Üí      }
   425‚Üí    },
   426‚Üí    coercer(value) {
   427‚Üí      return value instanceof Set ? new Set(value) : value
   428‚Üí    },
   429‚Üí    validator(value) {
   430‚Üí      return (
   431‚Üí        value instanceof Set ||
   432‚Üí        `Expected a \`Set\` object, but received: ${print(value)}`
   433‚Üí      )
   434‚Üí    },
   435‚Üí  })
   436‚Üí}
   438‚Üí/**
   439‚Üí * Ensure that a value is a string.
   440‚Üí */
   441‚Üí
   442‚Üíexport function string(): Struct<string, null> {
   443‚Üí  return define('string', (value) => {
   444‚Üí    return (
   445‚Üí      typeof value === 'string' ||
   446‚Üí      `Expected a string, but received: ${print(value)}`
   447‚Üí    )
   448‚Üí  })
   449‚Üí}
   451‚Üí/**
   452‚Üí * Ensure that a value is a tuple of a specific length, and that each of its
   453‚Üí * elements is of a specific type.
   454‚Üí */

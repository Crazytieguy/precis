    15→/**
    16→ * Ensure that any value passes validation.
    17→ */
    18→
    19→export function any(): Struct<any, null> {
    20→  return define('any', () => true)
    21→}
    33→export function array<T extends Struct<any>>(Element?: T): any {
    34→  return new Struct({
    35→    type: 'array',
    36→    schema: Element,
    37→    *entries(value) {
    38→      if (Element && Array.isArray(value)) {
    39→        for (const [i, v] of value.entries()) {
    40→          yield [i, v, Element]
    41→        }
    42→      }
    43→    },
    44→    coercer(value) {
    45→      return Array.isArray(value) ? value.slice() : value
    46→    },
    47→    validator(value) {
    48→      return (
    49→        Array.isArray(value) ||
    50→        `Expected an array value, but received: ${print(value)}`
    51→      )
    52→    },
    53→  })
    54→}
    56→/**
    57→ * Ensure that a value is a bigint.
    58→ */
    59→
    60→export function bigint(): Struct<bigint, null> {
    61→  return define('bigint', (value) => {
    62→    return typeof value === 'bigint'
    63→  })
    64→}
    66→/**
    67→ * Ensure that a value is a boolean.
    68→ */
    69→
    70→export function boolean(): Struct<boolean, null> {
    71→  return define('boolean', (value) => {
    72→    return typeof value === 'boolean'
    73→  })
    74→}
    76→/**
    77→ * Ensure that a value is a valid `Date`.
    78→ *
    79→ * Note: this also ensures that the value is *not* an invalid `Date` object,
    80→ * which can occur when parsing a date fails but still returns a `Date`.
    81→ */
    82→
    83→export function date(): Struct<Date, null> {
    84→  return define('date', (value) => {
    85→    return (
    86→      (value instanceof Date && !isNaN(value.getTime())) ||
    87→      `Expected a valid \`Date\` object, but received: ${print(value)}`
    88→    )
    89→  })
    90→}

   509‚Üí        `Expected an object, but received: ${print(value)}`
   510‚Üí      )
   511‚Üí    },
   512‚Üí    coercer(value) {
   513‚Üí      return isNonArrayObject(value) ? { ...value } : value
   514‚Üí    },
   515‚Üí  })

     1→import { Struct, is, Coercer } from '../struct.js'
     2→import { isPlainObject } from '../utils.js'
     3→import { string, unknown } from './types.js'
     5→/**
     6→ * Augment a `Struct` to add an additional coercion step to its input.
     7→ *
     8→ * This allows you to transform input data before validating it, to increase the
     9→ * likelihood that it passes validation—for example for default values, parsing
    10→ * different formats, etc.
    11→ *
    12→ * Note: You must use `create(value, Struct)` on the value to have the coercion
    13→ * take effect! Using simply `assert()` or `is()` will not use coercion.
    14→ */
    15→
    16→export function coerce<T, S, C>(
    17→  struct: Struct<T, S>,
    18→  condition: Struct<C, any>,
    19→  coercer: Coercer<C>
    20→): Struct<T, S> {
    21→  return new Struct({
    22→    ...struct,
    23→    coercer: (value, ctx) => {
    24→      return is(value, condition)
    25→        ? struct.coercer(coercer(value, ctx), ctx)
    26→        : struct.coercer(value, ctx)
    27→    },
    28→  })
    29→}
    31→/**
    32→ * Augment a struct to replace `undefined` values with a default.
    33→ *
    34→ * Note: You must use `create(value, Struct)` on the value to have the coercion
    35→ * take effect! Using simply `assert()` or `is()` will not use coercion.
    36→ */
    37→
    38→export function defaulted<T, S>(
    39→  struct: Struct<T, S>,
    40→  fallback: any,
    41→  options: {
    42→    strict?: boolean
    43→  } = {}
    44→): Struct<T, S> {
    45→  return coerce(struct, unknown(), (x) => {
    46→    const f = typeof fallback === 'function' ? fallback() : fallback
    47→
    48→    if (x === undefined) {
    49→      return f
    50→    }
    51→
    52→    if (!options.strict && isPlainObject(x) && isPlainObject(f)) {
    53→      const ret = { ...x }
    54→      let changed = false
    55→
    56→      for (const key in f) {
    57→        if (ret[key] === undefined) {
    58→          ret[key] = f[key]
    59→          changed = true
    60→        }
    61→      }
    62→
    63→      if (changed) {
    64→        return ret
    65→      }
      →…
    72→/**
    73→ * Augment a struct to trim string inputs.
    74→ *
    75→ * Note: You must use `create(value, Struct)` on the value to have the coercion
    76→ * take effect! Using simply `assert()` or `is()` will not use coercion.
    77→ */
    78→
    79→export function trimmed<T, S>(struct: Struct<T, S>): Struct<T, S> {
    80→  return coerce(struct, string(), (x) => x.trim())
    81→}

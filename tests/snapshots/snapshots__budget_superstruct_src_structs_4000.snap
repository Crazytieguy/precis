   138‚Üí/**
   139‚Üí * Augment a `Struct` to add an additional refinement to the validation.
   140‚Üí *
   141‚Üí * The refiner function is guaranteed to receive a value of the struct's type,
   142‚Üí * because the struct's existing validation will already have passed. This
   143‚Üí * allows you to layer additional validation on top of existing structs.
   144‚Üí */
   145‚Üí
   146‚Üíexport function refine<T, S>(
   147‚Üí  struct: Struct<T, S>,
   148‚Üí  name: string,
   149‚Üí  refiner: Refiner<T>
   150‚Üí): Struct<T, S> {
   151‚Üí  return new Struct({
   152‚Üí    ...struct,
   153‚Üí    *refiner(value, ctx) {
   154‚Üí      yield* struct.refiner(value, ctx)
   155‚Üí      const result = refiner(value, ctx)
   156‚Üí      const failures = toFailures(result, ctx, struct, value)
   157‚Üí
   158‚Üí      for (const failure of failures) {
   159‚Üí        yield { ...failure, refinement: name }
   160‚Üí      }
   161‚Üí    },
   162‚Üí  })
   163‚Üí}

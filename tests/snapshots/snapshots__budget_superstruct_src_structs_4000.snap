   298→export function object<S extends ObjectSchema>(schema?: S): any {
   299→  const knowns = schema ? Object.keys(schema) : []
   300→  const Never = never()
   301→  return new Struct({
   302→    type: 'object',
   303→    schema: schema ? schema : null,
   304→    *entries(value) {
   305→      if (schema && isObject(value)) {
   306→        const unknowns = new Set(Object.keys(value))
   307→
   308→        for (const key of knowns) {
   309→          unknowns.delete(key)
   310→          yield [key, value[key], schema[key]]
   311→        }
   312→
   313→        for (const key of unknowns) {
   314→          yield [key, value[key], Never]
   315→        }
   316→      }
   317→    },
   318→    validator(value) {
   319→      return (
   320→        isNonArrayObject(value) ||
   321→        `Expected an object, but received: ${print(value)}`
   322→      )
   323→    },
   324→    coercer(value, ctx) {
   325→      if (!isNonArrayObject(value)) {
   326→        return value
   327→      }
   328→
   329→      const coerced = { ...value }
   330→
   331→      // The `object` struct has special behaviour enabled by the mask flag.
   332→      // When masking, properties that are not in the schema are deleted from
   333→      // the coerced object instead of eventually failing validaiton.
   334→      if (ctx.mask && schema) {
   335→        for (const key in coerced) {
   336→          if (schema[key] === undefined) {
   337→            delete coerced[key]
   338→          }
   339→        }
   340→      }
   341→
   342→      return coerced
   343→    },
   344→  })
   345→}

    22→        if syn::parse_str::<Ident>(&repr).is_err() {
    23→            if let "_" | "super" | "self" | "Self" | "crate" = repr.as_str() {
    24→                // Some identifiers are never allowed to appear as raw, like r#self and r#_.
    25→            } else {

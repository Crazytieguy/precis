    16вҶ’    pub fn expand_shorthand(&mut self, fields: &[Field], container: ContainerKind) -> Result<()> {
    17вҶ’        let raw_args = self.args.clone();
    18вҶ’        let FmtArguments {
    19вҶ’            named: user_named_args,
    20вҶ’            first_unnamed,
    21вҶ’        } = explicit_named_args.parse2(raw_args).unwrap();

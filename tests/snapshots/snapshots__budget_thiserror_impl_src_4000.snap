    91вҶ’                None => return Ok(()),
    92вҶ’            };
    93вҶ’            let mut bonus_display = false;
    94вҶ’            let bound = match read[..end_spec].chars().next_back() {
    95вҶ’                Some('?') => Trait::Debug,
    96вҶ’                Some('o') => Trait::Octal,
    97вҶ’                Some('x') => Trait::LowerHex,
    98вҶ’                Some('X') => Trait::UpperHex,
    99вҶ’                Some('p') => Trait::Pointer,
   100вҶ’                Some('b') => Trait::Binary,
   101вҶ’                Some('e') => Trait::LowerExp,
   102вҶ’                Some('E') => Trait::UpperExp,
   103вҶ’                Some(_) => Trait::Display,

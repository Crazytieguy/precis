    23вҶ’        let mut member_index = HashMap::new();
    24вҶ’        let mut extra_positional_arguments_allowed = true;
    25вҶ’        for (i, field) in fields.iter().enumerate() {
    26вҶ’            member_index.insert(&field.member, i);
    27вҶ’            extra_positional_arguments_allowed &= matches!(&field.member, MemberUnraw::Named(_));
    28вҶ’        }
    29вҶ’
    30вҶ’        let span = self.fmt.span();
    31вҶ’        let fmt = self.fmt.value();
    32вҶ’        let mut read = fmt.as_str();
    33вҶ’        let mut out = String::new();
    34вҶ’        let mut has_bonus_display = false;
    35вҶ’        let mut infinite_recursive = false;
    36вҶ’        let mut implied_bounds = BTreeSet::new();
    37вҶ’        let mut bindings = Vec::new();
    38вҶ’        let mut macro_named_args = BTreeSet::new();
    39вҶ’
    40вҶ’        self.requires_fmt_machinery = self.requires_fmt_machinery || fmt.contains('}');
    41вҶ’
    42вҶ’        while let Some(brace) = read.find('{') {
    43вҶ’            self.requires_fmt_machinery = true;
    44вҶ’            out += &read[..brace + 1];
    45вҶ’            read = &read[brace + 1..];
    46вҶ’            if read.starts_with('{') {
    47вҶ’                out.push('{');
    48вҶ’                read = &read[1..];
    49вҶ’                continue;
    50вҶ’            }
    51вҶ’            let next = match read.chars().next() {
    52вҶ’                Some(next) => next,
    53вҶ’                None => return Ok(()),
    54вҶ’            };
    55вҶ’            let member = match next {
    56вҶ’                '0'..='9' => {
    57вҶ’                    let int = take_int(&mut read);
    58вҶ’                    if !extra_positional_arguments_allowed {
    59вҶ’                        if let Some(first_unnamed) = &first_unnamed {
    60вҶ’                            let msg = format!("ambiguous reference to positional arguments by number in a {container}; change this to a named argument");
    61вҶ’                            return Err(Error::new_spanned(first_unnamed, msg));
    62вҶ’                        }
    63вҶ’                    }
    64вҶ’                    match int.parse::<u32>() {
    65вҶ’                        Ok(index) => MemberUnraw::Unnamed(Index { index, span }),
    66вҶ’                        Err(_) => return Ok(()),
    67вҶ’                    }
    68вҶ’                }
    69вҶ’                'a'..='z' | 'A'..='Z' | '_' => {
    70вҶ’                    if read.starts_with("r#") {
    71вҶ’                        continue;
    72вҶ’                    }
    73вҶ’                    let repr = take_ident(&mut read);
    74вҶ’                    if repr == "_" {
    75вҶ’                        // Invalid. Let rustc produce the diagnostic.
    76вҶ’                        out += repr;
    77вҶ’                        continue;
    78вҶ’                    }
    79вҶ’                    let ident = IdentUnraw::new(Ident::new(repr, span));
    80вҶ’                    if user_named_args.contains(&ident) {
    81вҶ’                        // Refers to a named argument written by the user, not to field.
    82вҶ’                        out += repr;
    83вҶ’                        continue;
    84вҶ’                    }
    85вҶ’                    MemberUnraw::Named(ident)
    86вҶ’                }
    87вҶ’                _ => continue,
    88вҶ’            };

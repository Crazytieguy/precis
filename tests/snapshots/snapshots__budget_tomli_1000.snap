    45вҶ’RE_LOCALTIME: Final = re.compile(_TIME_RE_STR, flags=re.VERBOSE)
    46вҶ’RE_DATETIME: Final = re.compile(
    47вҶ’    rf"""
    48вҶ’([0-9]{{4}})-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])  # date, e.g. 1988-10-27
    49вҶ’(?:
    50вҶ’    [Tt ]
    51вҶ’    {_TIME_RE_STR}

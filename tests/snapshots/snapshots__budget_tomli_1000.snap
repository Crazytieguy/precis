src/tomli/_parser.py
    19вҶ’TYPE_CHECKING = False
    26вҶ’# Inline tables/arrays are implemented using recursion. Pathologically
    27вҶ’# nested documents cause pure Python to raise RecursionError (which is OK),
    28вҶ’# but mypyc binary wheels will crash unrecoverably (not OK). According to
    29вҶ’# mypyc docs this will be fixed in the future:
    30вҶ’# https://mypyc.readthedocs.io/en/latest/differences_from_python.html#stack-overflows
    31вҶ’# Before mypyc's fix is in, recursion needs to be limited by this library.
    32вҶ’# Choosing `sys.getrecursionlimit()` as maximum inline table/array nesting
    33вҶ’# level, as it allows more nesting than pure Python, but still seems a far
    34вҶ’# lower number than where mypyc binaries crash.
    35вҶ’MAX_INLINE_NESTING: Final = sys.getrecursionlimit()
    37вҶ’ASCII_CTRL: Final = frozenset(chr(i) for i in range(32)) | frozenset(chr(127))
    39вҶ’# Neither of these sets include quotation mark or backslash. They are
    40вҶ’# currently handled as separate cases in the parser functions.
    41вҶ’ILLEGAL_BASIC_STR_CHARS: Final = ASCII_CTRL - frozenset("\t")
    42вҶ’ILLEGAL_MULTILINE_BASIC_STR_CHARS: Final = ASCII_CTRL - frozenset("\t\n")
    44вҶ’ILLEGAL_LITERAL_STR_CHARS: Final = ILLEGAL_BASIC_STR_CHARS
    45вҶ’ILLEGAL_MULTILINE_LITERAL_STR_CHARS: Final = ILLEGAL_MULTILINE_BASIC_STR_CHARS
    47вҶ’ILLEGAL_COMMENT_CHARS: Final = ILLEGAL_BASIC_STR_CHARS
    49вҶ’TOML_WS: Final = frozenset(" \t")
    50вҶ’TOML_WS_AND_NEWLINE: Final = TOML_WS | frozenset("\n")
    51вҶ’BARE_KEY_CHARS: Final = frozenset(
    54вҶ’KEY_INITIAL_CHARS: Final = BARE_KEY_CHARS | frozenset("\"'")
    55вҶ’HEXDIGIT_CHARS: Final = frozenset("abcdef" "ABCDEF" "0123456789")
    57вҶ’BASIC_STR_ESCAPE_REPLACEMENTS: Final = MappingProxyType(
    71вҶ’class DEPRECATED_DEFAULT:

    12→def use_setuptools() -> None:
    13→    pyproject_path = Path(__file__).parent.parent / "pyproject.toml"
    14→    data = tomllib.loads(pyproject_path.read_bytes().decode())
    15→    data["build-system"] = {
    16→        "requires": ["setuptools>=77.0.3", "mypy[mypyc]>=1.15"],
    17→        "build-backend": "setuptools.build_meta",
    18→    }
    19→    pyproject_path.write_bytes(tomli_w.dumps(data).encode())

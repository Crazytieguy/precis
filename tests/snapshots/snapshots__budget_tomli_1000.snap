    12‚Üídef use_setuptools() -> None:
    13‚Üí    pyproject_path = Path(__file__).parent.parent / "pyproject.toml"
    14‚Üí    data = tomllib.loads(pyproject_path.read_bytes().decode())
    15‚Üí    data["build-system"] = {
    16‚Üí        "requires": ["setuptools>=77.0.3", "mypy[mypyc]>=1.15"],
    17‚Üí        "build-backend": "setuptools.build_meta",
    18‚Üí    }
    19‚Üí    pyproject_path.write_bytes(tomli_w.dumps(data).encode())

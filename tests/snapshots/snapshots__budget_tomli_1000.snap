    95вҶ’# No need to limit cache size. This is only ever called on input
    96вҶ’# that matched RE_DATETIME, so there is an implicit bound of
    97вҶ’# 24 (hours) * 60 (minutes) * 2 (offset direction) = 2880.
    98вҶ’@lru_cache(maxsize=None)
    99вҶ’def cached_tz(hour_str: str, minute_str: str, sign_str: str) -> timezone:
   100вҶ’    sign = 1 if sign_str == "+" else -1
   101вҶ’    return timezone(
   102вҶ’        timedelta(
   103вҶ’            hours=sign * int(hour_str),
   104вҶ’            minutes=sign * int(minute_str),
   105вҶ’        )
   106вҶ’    )

    11‚ÜíTYPE_CHECKING = False
    17‚Üí_TIME_RE_STR: Final = r"""
    18‚Üí([01][0-9]|2[0-3])             # hours
    19‚Üí:([0-5][0-9])                  # minutes
    20‚Üí(?:
    21‚Üí    :([0-5][0-9])              # optional seconds
    22‚Üí    (?:\.([0-9]{1,6})[0-9]*)?  # optional fractions of a second
    23‚Üí)?
    24‚Üí"""
    26‚ÜíRE_NUMBER: Final = re.compile(
    27‚Üí    r"""
    28‚Üí0
    29‚Üí(?:
    30‚Üí    x[0-9A-Fa-f](?:_?[0-9A-Fa-f])*   # hex
    31‚Üí    |
    32‚Üí    b[01](?:_?[01])*                 # bin
    33‚Üí    |
    34‚Üí    o[0-7](?:_?[0-7])*               # oct
    35‚Üí)
    36‚Üí|
    37‚Üí[+-]?(?:0|[1-9](?:_?[0-9])*)         # dec, integer part
    38‚Üí(?P<floatpart>
    39‚Üí    (?:\.[0-9](?:_?[0-9])*)?         # optional fractional part
    40‚Üí    (?:[eE][+-]?[0-9](?:_?[0-9])*)?  # optional exponent part
    41‚Üí)
    42‚Üí""",
    43‚Üí    flags=re.VERBOSE,
    44‚Üí)

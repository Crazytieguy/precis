   220â†’class Flags:
   222â†’
   223â†’    # Marks an immutable namespace (inline array or inline table).
   224â†’    FROZEN: Final = 0
   225â†’    # Marks a nest that has been explicitly created and can no longer
   226â†’    # be opened using the "[table]" syntax.
   227â†’    EXPLICIT_NEST: Final = 1
   228â†’
   229â†’    def __init__(self) -> None:
   230â†’        self._flags: dict[str, dict[Any, Any]] = {}
   231â†’        self._pending_flags: set[tuple[Key, int]] = set()
   232â†’
   233â†’    def add_pending(self, key: Key, flag: int) -> None:
   234â†’        self._pending_flags.add((key, flag))
   235â†’
   236â†’    def finalize_pending(self) -> None:
   237â†’        for key, flag in self._pending_flags:
   238â†’            self.set(key, flag, recursive=False)
   239â†’        self._pending_flags.clear()
   240â†’
   241â†’    def unset_all(self, key: Key) -> None:
   242â†’        cont = self._flags
   243â†’        for k in key[:-1]:
   244â†’            if k not in cont:
   249â†’    def set(self, key: Key, flag: int, *, recursive: bool) -> None:  # noqa: A003
   260â†’    def is_(self, key: Key, flag: int) -> bool:
   278â†’class NestedDict:
   279â†’    def __init__(self) -> None:
   280â†’        # The parsed content of the TOML document
   281â†’        self.dict: dict[str, Any] = {}
   282â†’
   283â†’    def get_or_create_nest(
   284â†’        self,
   285â†’        key: Key,
   286â†’        *,
   287â†’        access_lists: bool = True,
   288â†’    ) -> dict[str, Any]:
   289â†’        cont: Any = self.dict
   290â†’        for k in key:
   291â†’            if k not in cont:
   292â†’                cont[k] = {}
   293â†’            cont = cont[k]
   294â†’            if access_lists and isinstance(cont, list):
   295â†’                cont = cont[-1]
   296â†’            if not isinstance(cont, dict):
   297â†’                raise KeyError("There is no nest behind this key")
   298â†’        return cont  # type: ignore[no-any-return]
   299â†’
   300â†’    def append_nest_to_list(self, key: Key) -> None:
   301â†’        cont = self.get_or_create_nest(key[:-1])
   312â†’class Output:
   313â†’    def __init__(self) -> None:
   314â†’        self.data = NestedDict()
   315â†’        self.flags = Flags()

    11â†’TYPE_CHECKING = False
    17â†’_TIME_RE_STR: Final = r"""
    18â†’([01][0-9]|2[0-3])             # hours
    19â†’:([0-5][0-9])                  # minutes
    20â†’(?:
    21â†’    :([0-5][0-9])              # optional seconds
    22â†’    (?:\.([0-9]{1,6})[0-9]*)?  # optional fractions of a second
    23â†’)?
    24â†’"""
    26â†’RE_NUMBER: Final = re.compile(
    27â†’    r"""
    28â†’0
    29â†’(?:
    30â†’    x[0-9A-Fa-f](?:_?[0-9A-Fa-f])*   # hex
    31â†’    |
    32â†’    b[01](?:_?[01])*                 # bin
    33â†’    |
    34â†’    o[0-7](?:_?[0-7])*               # oct
    35â†’)
    36â†’|
    37â†’[+-]?(?:0|[1-9](?:_?[0-9])*)         # dec, integer part
    38â†’(?P<floatpart>

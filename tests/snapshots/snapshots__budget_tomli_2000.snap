    95â†’# No need to limit cache size. This is only ever called on input
    96â†’# that matched RE_DATETIME, so there is an implicit bound of
    97â†’# 24 (hours) * 60 (minutes) * 2 (offset direction) = 2880.
    98â†’@lru_cache(maxsize=None)
    99â†’def cached_tz(hour_str: str, minute_str: str, sign_str: str) -> timezone:
   100â†’    sign = 1 if sign_str == "+" else -1
   101â†’    return timezone(
   102â†’        timedelta(
   103â†’            hours=sign * int(hour_str),
   104â†’            minutes=sign * int(minute_str),
   105â†’        )
   106â†’    )

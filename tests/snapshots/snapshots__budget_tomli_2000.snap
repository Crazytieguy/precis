src/tomli/_parser.py
    19â†’TYPE_CHECKING = False
    26â†’# Inline tables/arrays are implemented using recursion. Pathologically
    27â†’# nested documents cause pure Python to raise RecursionError (which is OK),
    28â†’# but mypyc binary wheels will crash unrecoverably (not OK). According to
    29â†’# mypyc docs this will be fixed in the future:
    30â†’# https://mypyc.readthedocs.io/en/latest/differences_from_python.html#stack-overflows
    31â†’# Before mypyc's fix is in, recursion needs to be limited by this library.
    32â†’# Choosing `sys.getrecursionlimit()` as maximum inline table/array nesting
    33â†’# level, as it allows more nesting than pure Python, but still seems a far
    34â†’# lower number than where mypyc binaries crash.
    35â†’MAX_INLINE_NESTING: Final = sys.getrecursionlimit()
    37â†’ASCII_CTRL: Final = frozenset(chr(i) for i in range(32)) | frozenset(chr(127))
    39â†’# Neither of these sets include quotation mark or backslash. They are
    40â†’# currently handled as separate cases in the parser functions.
    41â†’ILLEGAL_BASIC_STR_CHARS: Final = ASCII_CTRL - frozenset("\t")
    42â†’ILLEGAL_MULTILINE_BASIC_STR_CHARS: Final = ASCII_CTRL - frozenset("\t\n")
    44â†’ILLEGAL_LITERAL_STR_CHARS: Final = ILLEGAL_BASIC_STR_CHARS
    45â†’ILLEGAL_MULTILINE_LITERAL_STR_CHARS: Final = ILLEGAL_MULTILINE_BASIC_STR_CHARS
    47â†’ILLEGAL_COMMENT_CHARS: Final = ILLEGAL_BASIC_STR_CHARS
    49â†’TOML_WS: Final = frozenset(" \t")
    50â†’TOML_WS_AND_NEWLINE: Final = TOML_WS | frozenset("\n")
    51â†’BARE_KEY_CHARS: Final = frozenset(
    52â†’    "abcdefghijklmnopqrstuvwxyz" "ABCDEFGHIJKLMNOPQRSTUVWXYZ" "0123456789" "-_"
    53â†’)
    54â†’KEY_INITIAL_CHARS: Final = BARE_KEY_CHARS | frozenset("\"'")
    55â†’HEXDIGIT_CHARS: Final = frozenset("abcdef" "ABCDEF" "0123456789")
    57â†’BASIC_STR_ESCAPE_REPLACEMENTS: Final = MappingProxyType(
    58â†’    {
    59â†’        "\\b": "\u0008",  # backspace
    60â†’        "\\t": "\u0009",  # tab
    61â†’        "\\n": "\u000a",  # linefeed
    62â†’        "\\f": "\u000c",  # form feed
    63â†’        "\\r": "\u000d",  # carriage return
    64â†’        "\\e": "\u001b",  # escape
    65â†’        '\\"': "\u0022",  # quote
    66â†’        "\\\\": "\u005c",  # backslash
    67â†’    }
    68â†’)

fuzzer/fuzz.py
    20â†’def test_one_input(input_bytes: bytes) -> None:
    21â†’    # We need a Unicode string, not bytes
    22â†’    fdp = atheris.FuzzedDataProvider(input_bytes)
    23â†’    data = fdp.ConsumeUnicode(sys.maxsize)
    24â†’
    25â†’    try:
    26â†’        toml_obj = tomli.loads(data)
    27â†’    except (tomli.TOMLDecodeError, RecursionError):
    28â†’        return
    29â†’    except BaseException:
    30â†’        print_err(data)
    31â†’        raise
    32â†’
    33â†’    try:
    34â†’        recovered_data = tomli_w.dumps(toml_obj)
    35â†’    except RecursionError:
    36â†’        return
    37â†’    except BaseException:
    38â†’        print_err(data)
    39â†’        raise
    40â†’
    41â†’    roundtripped_obj = tomli.loads(recovered_data)
    42â†’    normalize_toml_obj(roundtripped_obj)
    43â†’    normalize_toml_obj(toml_obj)
    44â†’    if roundtripped_obj != toml_obj:
    45â†’        sys.stderr.write(
    46â†’            f"Original dict:\n{toml_obj}\nRoundtripped dict:\n{roundtripped_obj}\n"
    47â†’        )
    48â†’        sys.stderr.flush()
    49â†’        print_err(data)
    50â†’        raise Exception("Dicts not equal after roundtrip")
    53â†’def print_err(data):
    54â†’    codepoints = [hex(ord(x)) for x in data]
    55â†’    sys.stderr.write(f"Input was {type(data)}:\n{data}\nCodepoints:\n{codepoints}\n")
    56â†’    sys.stderr.flush()
    59â†’def normalize_toml_obj(toml_obj: dict) -> None:
    60â†’    """Make NaNs equal when compared (without using recursion)."""
    61â†’    to_process = [toml_obj]
    62â†’    while to_process:
    63â†’        cont = to_process.pop()
    64â†’        for k, v in cont.items() if isinstance(cont, dict) else enumerate(cont):
    65â†’            if isinstance(v, float) and isnan(v):
    66â†’                cont[k] = "nan"
    67â†’            elif isinstance(v, (dict, list)):
    68â†’                to_process.append(v)
    71â†’def main():
    72â†’    # For possible options, see https://llvm.org/docs/LibFuzzer.html#options
    73â†’    fuzzer_options = sys.argv
    74â†’    atheris.Setup(fuzzer_options, test_one_input)
    75â†’    atheris.Fuzz()
scripts/use_setuptools.py
    12â†’def use_setuptools() -> None:
    13â†’    pyproject_path = Path(__file__).parent.parent / "pyproject.toml"
    14â†’    data = tomllib.loads(pyproject_path.read_bytes().decode())
    15â†’    data["build-system"] = {
    16â†’        "requires": ["setuptools>=77.0.3", "mypy[mypyc]>=1.15"],
    17â†’        "build-backend": "setuptools.build_meta",
    18â†’    }
    19â†’    pyproject_path.write_bytes(tomli_w.dumps(data).encode())

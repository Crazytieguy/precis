    28→        return
    29→    except BaseException:
    30→        print_err(data)
    31→        raise
    32→
    33→    try:
    34→        recovered_data = tomli_w.dumps(toml_obj)
    35→    except RecursionError:
    36→        return
    37→    except BaseException:
    38→        print_err(data)
    39→        raise
    40→
    41→    roundtripped_obj = tomli.loads(recovered_data)
    42→    normalize_toml_obj(roundtripped_obj)
    43→    normalize_toml_obj(toml_obj)
    44→    if roundtripped_obj != toml_obj:
    45→        sys.stderr.write(
    46→            f"Original dict:\n{toml_obj}\nRoundtripped dict:\n{roundtripped_obj}\n"
      →…
    53→def print_err(data):
    54→    codepoints = [hex(ord(x)) for x in data]
    55→    sys.stderr.write(f"Input was {type(data)}:\n{data}\nCodepoints:\n{codepoints}\n")
    56→    sys.stderr.flush()
    59→def normalize_toml_obj(toml_obj: dict) -> None:
    60→    """Make NaNs equal when compared (without using recursion)."""
    61→    to_process = [toml_obj]
    62→    while to_process:
    63→        cont = to_process.pop()
    64→        for k, v in cont.items() if isinstance(cont, dict) else enumerate(cont):
    65→            if isinstance(v, float) and isnan(v):
    66→                cont[k] = "nan"
    67→            elif isinstance(v, (dict, list)):
    68→                to_process.append(v)
    71→def main():
    72→    # For possible options, see https://llvm.org/docs/LibFuzzer.html#options
    73→    fuzzer_options = sys.argv
    74→    atheris.Setup(fuzzer_options, test_one_input)
    75→    atheris.Fuzz()

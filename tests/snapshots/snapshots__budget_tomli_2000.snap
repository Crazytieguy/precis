    20‚Üídef test_one_input(input_bytes: bytes) -> None:
    21‚Üí    # We need a Unicode string, not bytes
    22‚Üí    fdp = atheris.FuzzedDataProvider(input_bytes)
    23‚Üí    data = fdp.ConsumeUnicode(sys.maxsize)
    24‚Üí
    25‚Üí    try:
    26‚Üí        toml_obj = tomli.loads(data)
    27‚Üí    except (tomli.TOMLDecodeError, RecursionError):
    28‚Üí        return
    29‚Üí    except BaseException:
    30‚Üí        print_err(data)
    31‚Üí        raise
    32‚Üí
    33‚Üí    try:
    34‚Üí        recovered_data = tomli_w.dumps(toml_obj)
    35‚Üí    except RecursionError:
    36‚Üí        return
    37‚Üí    except BaseException:
    38‚Üí        print_err(data)
    39‚Üí        raise
    40‚Üí
    41‚Üí    roundtripped_obj = tomli.loads(recovered_data)
    42‚Üí    normalize_toml_obj(roundtripped_obj)
    43‚Üí    normalize_toml_obj(toml_obj)
    44‚Üí    if roundtripped_obj != toml_obj:
    45‚Üí        sys.stderr.write(
    46‚Üí            f"Original dict:\n{toml_obj}\nRoundtripped dict:\n{roundtripped_obj}\n"
    47‚Üí        )
    48‚Üí        sys.stderr.flush()
    49‚Üí        print_err(data)
      ‚Üí‚Ä¶
    53‚Üídef print_err(data):
    54‚Üí    codepoints = [hex(ord(x)) for x in data]
    55‚Üí    sys.stderr.write(f"Input was {type(data)}:\n{data}\nCodepoints:\n{codepoints}\n")
    56‚Üí    sys.stderr.flush()
    59‚Üídef normalize_toml_obj(toml_obj: dict) -> None:
    60‚Üí    """Make NaNs equal when compared (without using recursion)."""
    61‚Üí    to_process = [toml_obj]
    62‚Üí    while to_process:
    63‚Üí        cont = to_process.pop()
    64‚Üí        for k, v in cont.items() if isinstance(cont, dict) else enumerate(cont):
    65‚Üí            if isinstance(v, float) and isnan(v):
    66‚Üí                cont[k] = "nan"
    67‚Üí            elif isinstance(v, (dict, list)):
    68‚Üí                to_process.append(v)
    71‚Üídef main():
    72‚Üí    # For possible options, see https://llvm.org/docs/LibFuzzer.html#options
    73‚Üí    fuzzer_options = sys.argv
    74‚Üí    atheris.Setup(fuzzer_options, test_one_input)
    75‚Üí    atheris.Fuzz()
scripts/use_setuptools.py
    12‚Üídef use_setuptools() -> None:
    13‚Üí    pyproject_path = Path(__file__).parent.parent / "pyproject.toml"
    14‚Üí    data = tomllib.loads(pyproject_path.read_bytes().decode())
    15‚Üí    data["build-system"] = {
    16‚Üí        "requires": ["setuptools>=77.0.3", "mypy[mypyc]>=1.15"],
    17‚Üí        "build-backend": "setuptools.build_meta",
    18‚Üí    }
    19‚Üí    pyproject_path.write_bytes(tomli_w.dumps(data).encode())

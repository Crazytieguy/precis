    71тЖТclass DEPRECATED_DEFAULT:
    72тЖТ    """Sentinel to be used as default arg during deprecation
    73тЖТ    period of TOMLDecodeError's free-form arguments."""
    76тЖТclass TOMLDecodeError(ValueError):
    77тЖТ    """An error raised if a document is not valid TOML.
    78тЖТ
    79тЖТ    Adds the following attributes to ValueError:
    80тЖТ    msg: The unformatted error message
    81тЖТ    doc: The TOML document being parsed
    82тЖТ    pos: The index of doc where parsing failed
    83тЖТ    lineno: The line corresponding to pos
    84тЖТ    colno: The column corresponding to pos
    85тЖТ    """
    86тЖТ
    87тЖТ    def __init__(
    88тЖТ        self,
    89тЖТ        msg: str | type[DEPRECATED_DEFAULT] = DEPRECATED_DEFAULT,
    90тЖТ        doc: str | type[DEPRECATED_DEFAULT] = DEPRECATED_DEFAULT,
    91тЖТ        pos: Pos | type[DEPRECATED_DEFAULT] = DEPRECATED_DEFAULT,
    92тЖТ        *args: Any,
    93тЖТ    ):
    94тЖТ        if (
    95тЖТ            args
    96тЖТ            or not isinstance(msg, str)
    97тЖТ            or not isinstance(doc, str)
    98тЖТ            or not isinstance(pos, int)
    99тЖТ        ):
   100тЖТ            import warnings
   101тЖТ
   102тЖТ            warnings.warn(
   103тЖТ                "Free-form arguments for TOMLDecodeError are deprecated. "
   104тЖТ                "Please set 'msg' (str), 'doc' (str) and 'pos' (int) arguments only.",
   105тЖТ                DeprecationWarning,
   106тЖТ                stacklevel=2,
   107тЖТ            )
   108тЖТ            if pos is not DEPRECATED_DEFAULT:
   109тЖТ                args = pos, *args
   110тЖТ            if doc is not DEPRECATED_DEFAULT:
   111тЖТ                args = doc, *args
   112тЖТ            if msg is not DEPRECATED_DEFAULT:
   113тЖТ                args = msg, *args
   114тЖТ            ValueError.__init__(self, *args)
   115тЖТ            return
   116тЖТ
   117тЖТ        lineno = doc.count("\n", 0, pos) + 1
   118тЖТ        if lineno == 1:
   119тЖТ            colno = pos + 1
   120тЖТ        else:
   121тЖТ            colno = pos - doc.rindex("\n", 0, pos)
   122тЖТ
   123тЖТ        if pos >= len(doc):
   124тЖТ            coord_repr = "end of document"
   125тЖТ        else:
   126тЖТ            coord_repr = f"line {lineno}, column {colno}"
   127тЖТ        errmsg = f"{msg} (at {coord_repr})"
   128тЖТ        ValueError.__init__(self, errmsg)
   129тЖТ
   130тЖТ        self.msg = msg
   131тЖТ        self.doc = doc
   132тЖТ        self.pos = pos
   133тЖТ        self.lineno = lineno
   134тЖТ        self.colno = colno

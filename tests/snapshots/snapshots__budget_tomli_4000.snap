src/tomli/_parser.py
     7тЖТimport sys
     8тЖТfrom types import MappingProxyType
    10тЖТfrom ._re import (
    11тЖТ    RE_DATETIME,
    12тЖТ    RE_LOCALTIME,
    13тЖТ    RE_NUMBER,
    14тЖТ    match_to_datetime,
    15тЖТ    match_to_localtime,
    16тЖТ    match_to_number,
    17тЖТ)
    19тЖТTYPE_CHECKING = False
    21тЖТ    from collections.abc import Iterable
    22тЖТ    from typing import IO, Any, Final
    24тЖТ    from ._types import Key, ParseFloat, Pos
    26тЖТ# Inline tables/arrays are implemented using recursion. Pathologically
    27тЖТ# nested documents cause pure Python to raise RecursionError (which is OK),
    28тЖТ# but mypyc binary wheels will crash unrecoverably (not OK). According to
    29тЖТ# mypyc docs this will be fixed in the future:
    30тЖТ# https://mypyc.readthedocs.io/en/latest/differences_from_python.html#stack-overflows
    31тЖТ# Before mypyc's fix is in, recursion needs to be limited by this library.
    32тЖТ# Choosing `sys.getrecursionlimit()` as maximum inline table/array nesting
    33тЖТ# level, as it allows more nesting than pure Python, but still seems a far
    34тЖТ# lower number than where mypyc binaries crash.
    35тЖТMAX_INLINE_NESTING: Final = sys.getrecursionlimit()
    37тЖТASCII_CTRL: Final = frozenset(chr(i) for i in range(32)) | frozenset(chr(127))
    39тЖТ# Neither of these sets include quotation mark or backslash. They are
    40тЖТ# currently handled as separate cases in the parser functions.
    41тЖТILLEGAL_BASIC_STR_CHARS: Final = ASCII_CTRL - frozenset("\t")
    42тЖТILLEGAL_MULTILINE_BASIC_STR_CHARS: Final = ASCII_CTRL - frozenset("\t\n")
    44тЖТILLEGAL_LITERAL_STR_CHARS: Final = ILLEGAL_BASIC_STR_CHARS
    45тЖТILLEGAL_MULTILINE_LITERAL_STR_CHARS: Final = ILLEGAL_MULTILINE_BASIC_STR_CHARS
    47тЖТILLEGAL_COMMENT_CHARS: Final = ILLEGAL_BASIC_STR_CHARS
    49тЖТTOML_WS: Final = frozenset(" \t")
    50тЖТTOML_WS_AND_NEWLINE: Final = TOML_WS | frozenset("\n")
    51тЖТBARE_KEY_CHARS: Final = frozenset(
    52тЖТ    "abcdefghijklmnopqrstuvwxyz" "ABCDEFGHIJKLMNOPQRSTUVWXYZ" "0123456789" "-_"
    53тЖТ)
    54тЖТKEY_INITIAL_CHARS: Final = BARE_KEY_CHARS | frozenset("\"'")
    55тЖТHEXDIGIT_CHARS: Final = frozenset("abcdef" "ABCDEF" "0123456789")
    57тЖТBASIC_STR_ESCAPE_REPLACEMENTS: Final = MappingProxyType(
    58тЖТ    {
    59тЖТ        "\\b": "\u0008",  # backspace
    60тЖТ        "\\t": "\u0009",  # tab
    61тЖТ        "\\n": "\u000a",  # linefeed
    62тЖТ        "\\f": "\u000c",  # form feed
    63тЖТ        "\\r": "\u000d",  # carriage return
    64тЖТ        "\\e": "\u001b",  # escape
    65тЖТ        '\\"': "\u0022",  # quote
    66тЖТ        "\\\\": "\u005c",  # backslash
    67тЖТ    }
    68тЖТ)
    71тЖТclass DEPRECATED_DEFAULT:
    72тЖТ    """Sentinel to be used as default arg during deprecation
    73тЖТ    period of TOMLDecodeError's free-form arguments."""
    76тЖТclass TOMLDecodeError(ValueError):
    77тЖТ    """An error raised if a document is not valid TOML.
    78тЖТ
    79тЖТ    Adds the following attributes to ValueError:
    80тЖТ    msg: The unformatted error message
    81тЖТ    doc: The TOML document being parsed
    82тЖТ    pos: The index of doc where parsing failed
    83тЖТ    lineno: The line corresponding to pos
    84тЖТ    colno: The column corresponding to pos
    85тЖТ    """
    86тЖТ
    87тЖТ    def __init__(
    88тЖТ        self,
    89тЖТ        msg: str | type[DEPRECATED_DEFAULT] = DEPRECATED_DEFAULT,
    90тЖТ        doc: str | type[DEPRECATED_DEFAULT] = DEPRECATED_DEFAULT,
    91тЖТ        pos: Pos | type[DEPRECATED_DEFAULT] = DEPRECATED_DEFAULT,
    92тЖТ        *args: Any,
    93тЖТ    ):
    94тЖТ        if (
    95тЖТ            args
    96тЖТ            or not isinstance(msg, str)
    97тЖТ            or not isinstance(doc, str)
    98тЖТ            or not isinstance(pos, int)
    99тЖТ        ):
   100тЖТ            import warnings
   101тЖТ
   102тЖТ            warnings.warn(
   103тЖТ                "Free-form arguments for TOMLDecodeError are deprecated. "
   104тЖТ                "Please set 'msg' (str), 'doc' (str) and 'pos' (int) arguments only.",
   105тЖТ                DeprecationWarning,
   106тЖТ                stacklevel=2,
   107тЖТ            )
   108тЖТ            if pos is not DEPRECATED_DEFAULT:
   109тЖТ                args = pos, *args
   110тЖТ            if doc is not DEPRECATED_DEFAULT:
   111тЖТ                args = doc, *args
   112тЖТ            if msg is not DEPRECATED_DEFAULT:
   113тЖТ                args = msg, *args
   114тЖТ            ValueError.__init__(self, *args)
   115тЖТ            return
   116тЖТ
   117тЖТ        lineno = doc.count("\n", 0, pos) + 1
   118тЖТ        if lineno == 1:
   119тЖТ            colno = pos + 1
   120тЖТ        else:
   121тЖТ            colno = pos - doc.rindex("\n", 0, pos)
   122тЖТ
   123тЖТ        if pos >= len(doc):
   124тЖТ            coord_repr = "end of document"
   125тЖТ        else:
   126тЖТ            coord_repr = f"line {lineno}, column {colno}"
   127тЖТ        errmsg = f"{msg} (at {coord_repr})"
   128тЖТ        ValueError.__init__(self, errmsg)
   129тЖТ
   130тЖТ        self.msg = msg
   131тЖТ        self.doc = doc
   132тЖТ        self.pos = pos
   133тЖТ        self.lineno = lineno
   134тЖТ        self.colno = colno
   137тЖТdef load(__fp: IO[bytes], *, parse_float: ParseFloat = float) -> dict[str, Any]:
   138тЖТ    """Parse TOML from a binary file object."""
   149тЖТdef loads(__s: str, *, parse_float: ParseFloat = float) -> dict[str, Any]:
   150тЖТ    """Parse TOML from a string."""
   220тЖТclass Flags:
   221тЖТ    """Flags that map to parsed keys/namespaces."""
   222тЖТ
   223тЖТ    # Marks an immutable namespace (inline array or inline table).
   224тЖТ    FROZEN: Final = 0
   225тЖТ    # Marks a nest that has been explicitly created and can no longer
   226тЖТ    # be opened using the "[table]" syntax.
   227тЖТ    EXPLICIT_NEST: Final = 1
   228тЖТ
   229тЖТ    def __init__(self) -> None:
   230тЖТ        self._flags: dict[str, dict[Any, Any]] = {}
   231тЖТ        self._pending_flags: set[tuple[Key, int]] = set()
   232тЖТ
   233тЖТ    def add_pending(self, key: Key, flag: int) -> None:
   234тЖТ        self._pending_flags.add((key, flag))
   235тЖТ
   236тЖТ    def finalize_pending(self) -> None:
   237тЖТ        for key, flag in self._pending_flags:
   238тЖТ            self.set(key, flag, recursive=False)
   239тЖТ        self._pending_flags.clear()
   240тЖТ
   241тЖТ    def unset_all(self, key: Key) -> None:
   242тЖТ        cont = self._flags
   243тЖТ        for k in key[:-1]:
   244тЖТ            if k not in cont:
   245тЖТ                return
   246тЖТ            cont = cont[k]["nested"]
   247тЖТ        cont.pop(key[-1], None)
   248тЖТ
   249тЖТ    def set(self, key: Key, flag: int, *, recursive: bool) -> None:  # noqa: A003
   250тЖТ        cont = self._flags
   251тЖТ        key_parent, key_stem = key[:-1], key[-1]
   252тЖТ        for k in key_parent:
   253тЖТ            if k not in cont:
   254тЖТ                cont[k] = {"flags": set(), "recursive_flags": set(), "nested": {}}
   255тЖТ            cont = cont[k]["nested"]
   256тЖТ        if key_stem not in cont:
   257тЖТ            cont[key_stem] = {"flags": set(), "recursive_flags": set(), "nested": {}}
   258тЖТ        cont[key_stem]["recursive_flags" if recursive else "flags"].add(flag)
   259тЖТ
   260тЖТ    def is_(self, key: Key, flag: int) -> bool:
   261тЖТ        if not key:
   262тЖТ            return False  # document root has no flags
   263тЖТ        cont = self._flags
   264тЖТ        for k in key[:-1]:
   265тЖТ            if k not in cont:
   266тЖТ                return False
   267тЖТ            inner_cont = cont[k]
   268тЖТ            if flag in inner_cont["recursive_flags"]:
   269тЖТ                return True
   270тЖТ            cont = inner_cont["nested"]
   271тЖТ        key_stem = key[-1]
   272тЖТ        if key_stem in cont:
   273тЖТ            inner_cont = cont[key_stem]
   274тЖТ            return flag in inner_cont["flags"] or flag in inner_cont["recursive_flags"]
   275тЖТ        return False
   278тЖТclass NestedDict:
   279тЖТ    def __init__(self) -> None:
   280тЖТ        # The parsed content of the TOML document
   281тЖТ        self.dict: dict[str, Any] = {}
   282тЖТ
   283тЖТ    def get_or_create_nest(
   284тЖТ        self,
   285тЖТ        key: Key,
   286тЖТ        *,
   287тЖТ        access_lists: bool = True,
   288тЖТ    ) -> dict[str, Any]:
   289тЖТ        cont: Any = self.dict
   290тЖТ        for k in key:
   291тЖТ            if k not in cont:
   292тЖТ                cont[k] = {}
   293тЖТ            cont = cont[k]
   294тЖТ            if access_lists and isinstance(cont, list):
   295тЖТ                cont = cont[-1]
   296тЖТ            if not isinstance(cont, dict):
   297тЖТ                raise KeyError("There is no nest behind this key")
   298тЖТ        return cont  # type: ignore[no-any-return]
   299тЖТ
   300тЖТ    def append_nest_to_list(self, key: Key) -> None:
   301тЖТ        cont = self.get_or_create_nest(key[:-1])
   302тЖТ        last_key = key[-1]
   303тЖТ        if last_key in cont:
   304тЖТ            list_ = cont[last_key]
   305тЖТ            if not isinstance(list_, list):
   306тЖТ                raise KeyError("An object other than list found behind this key")
   307тЖТ            list_.append({})
   308тЖТ        else:
   309тЖТ            cont[last_key] = [{}]
   312тЖТclass Output:
   313тЖТ    def __init__(self) -> None:
   314тЖТ        self.data = NestedDict()
   315тЖТ        self.flags = Flags()

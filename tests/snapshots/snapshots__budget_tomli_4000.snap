   220‚Üíclass Flags:
   221‚Üí    """Flags that map to parsed keys/namespaces."""
   222‚Üí
   223‚Üí    # Marks an immutable namespace (inline array or inline table).
   224‚Üí    FROZEN: Final = 0
   225‚Üí    # Marks a nest that has been explicitly created and can no longer
   226‚Üí    # be opened using the "[table]" syntax.
   227‚Üí    EXPLICIT_NEST: Final = 1
   228‚Üí
   229‚Üí    def __init__(self) -> None:
   230‚Üí        self._flags: dict[str, dict[Any, Any]] = {}
   231‚Üí        self._pending_flags: set[tuple[Key, int]] = set()
   232‚Üí
   233‚Üí    def add_pending(self, key: Key, flag: int) -> None:
   234‚Üí        self._pending_flags.add((key, flag))
   235‚Üí
   236‚Üí    def finalize_pending(self) -> None:
   237‚Üí        for key, flag in self._pending_flags:
   238‚Üí            self.set(key, flag, recursive=False)
   239‚Üí        self._pending_flags.clear()
   240‚Üí
   241‚Üí    def unset_all(self, key: Key) -> None:
   242‚Üí        cont = self._flags
   243‚Üí        for k in key[:-1]:
   244‚Üí            if k not in cont:
   245‚Üí                return
   246‚Üí            cont = cont[k]["nested"]
   247‚Üí        cont.pop(key[-1], None)
   248‚Üí
   249‚Üí    def set(self, key: Key, flag: int, *, recursive: bool) -> None:  # noqa: A003
   250‚Üí        cont = self._flags
   251‚Üí        key_parent, key_stem = key[:-1], key[-1]
   252‚Üí        for k in key_parent:
   253‚Üí            if k not in cont:
   254‚Üí                cont[k] = {"flags": set(), "recursive_flags": set(), "nested": {}}
   255‚Üí            cont = cont[k]["nested"]
   256‚Üí        if key_stem not in cont:
   257‚Üí            cont[key_stem] = {"flags": set(), "recursive_flags": set(), "nested": {}}
   258‚Üí        cont[key_stem]["recursive_flags" if recursive else "flags"].add(flag)
   259‚Üí
   260‚Üí    def is_(self, key: Key, flag: int) -> bool:
   261‚Üí        if not key:
   262‚Üí            return False  # document root has no flags
   263‚Üí        cont = self._flags
   264‚Üí        for k in key[:-1]:
   265‚Üí            if k not in cont:
   266‚Üí                return False
   267‚Üí            inner_cont = cont[k]
   268‚Üí            if flag in inner_cont["recursive_flags"]:
   269‚Üí                return True
   270‚Üí            cont = inner_cont["nested"]
   271‚Üí        key_stem = key[-1]
   272‚Üí        if key_stem in cont:
   273‚Üí            inner_cont = cont[key_stem]
   274‚Üí            return flag in inner_cont["flags"] or flag in inner_cont["recursive_flags"]
   275‚Üí        return False
   278‚Üíclass NestedDict:
   279‚Üí    def __init__(self) -> None:
   280‚Üí        # The parsed content of the TOML document
   281‚Üí        self.dict: dict[str, Any] = {}
   282‚Üí
   283‚Üí    def get_or_create_nest(
   284‚Üí        self,
   285‚Üí        key: Key,
   286‚Üí        *,
   287‚Üí        access_lists: bool = True,
   288‚Üí    ) -> dict[str, Any]:
   289‚Üí        cont: Any = self.dict
   290‚Üí        for k in key:
   291‚Üí            if k not in cont:
   292‚Üí                cont[k] = {}
   293‚Üí            cont = cont[k]
   294‚Üí            if access_lists and isinstance(cont, list):
   295‚Üí                cont = cont[-1]
   296‚Üí            if not isinstance(cont, dict):
   297‚Üí                raise KeyError("There is no nest behind this key")
   298‚Üí        return cont  # type: ignore[no-any-return]
   299‚Üí
   300‚Üí    def append_nest_to_list(self, key: Key) -> None:
   301‚Üí        cont = self.get_or_create_nest(key[:-1])
   302‚Üí        last_key = key[-1]
   303‚Üí        if last_key in cont:
   304‚Üí            list_ = cont[last_key]
   305‚Üí            if not isinstance(list_, list):
   306‚Üí                raise KeyError("An object other than list found behind this key")
   307‚Üí            list_.append({})
   308‚Üí        else:
   309‚Üí            cont[last_key] = [{}]

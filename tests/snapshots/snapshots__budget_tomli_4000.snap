   764‚Üídef make_safe_parse_float(parse_float: ParseFloat) -> ParseFloat:
   765‚Üí    """A decorator to make `parse_float` safe.
   766‚Üí
   767‚Üí    `parse_float` must not return dicts or lists, because these types
   768‚Üí    would be mixed with parsed TOML tables and arrays, thus confusing
   769‚Üí    the parser. The returned decorated callable raises `ValueError`
   770‚Üí    instead of returning illegal types.
   771‚Üí    """
   772‚Üí    # The default `float` callable never returns illegal types. Optimize it.
   773‚Üí    if parse_float is float:
   774‚Üí        return float

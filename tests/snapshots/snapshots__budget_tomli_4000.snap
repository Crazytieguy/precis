     3тЖТfrom collections.abc import Callable
     4тЖТfrom pathlib import Path
     5тЖТimport timeit
     7тЖТimport pytomlpp
     8тЖТimport rtoml
     9тЖТimport toml
    10тЖТimport tomlkit
    12тЖТimport tomli
    15тЖТdef benchmark(
    16тЖТ    name: str,
    17тЖТ    run_count: int,
    18тЖТ    func: Callable,
    19тЖТ    col_width: tuple,
    20тЖТ    compare_to: float | None = None,
    21тЖТ) -> float:
    22тЖТ    placeholder = "Running..."
    23тЖТ    print(f"{name:>{col_width[0]}} | {placeholder}", end="", flush=True)
    24тЖТ    time_taken = min(timeit.repeat(func, number=run_count, repeat=5))
    25тЖТ    print("\b" * len(placeholder), end="")
    26тЖТ    time_suffix = " s"
    27тЖТ    print(f"{time_taken:{col_width[1]-len(time_suffix)}.3g}{time_suffix}", end="")
      тЖТтАж
    37тЖТdef run(run_count: int) -> None:
    38тЖТ    data_path = Path(__file__).parent / "data.toml"
    39тЖТ    test_data = data_path.read_bytes().decode()
    40тЖТ
    41тЖТ    col_width = (10, 10, 28)
    42тЖТ    col_head = ("parser", "exec time", "performance (more is better)")
    43тЖТ    print(f"Parsing data.toml {run_count} times:")

scripts/use_setuptools.py
     6тЖТfrom pathlib import Path
     7тЖТimport tomllib
     9тЖТimport tomli_w  # type: ignore[import-not-found]
    12тЖТdef use_setuptools() -> None:
    13тЖТ    pyproject_path = Path(__file__).parent.parent / "pyproject.toml"
    14тЖТ    data = tomllib.loads(pyproject_path.read_bytes().decode())
    15тЖТ    data["build-system"] = {
    16тЖТ        "requires": ["setuptools>=77.0.3", "mypy[mypyc]>=1.15"],
    17тЖТ        "build-backend": "setuptools.build_meta",
    18тЖТ    }
    19тЖТ    pyproject_path.write_bytes(tomli_w.dumps(data).encode())

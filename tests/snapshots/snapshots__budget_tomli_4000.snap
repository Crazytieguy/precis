fuzzer/fuzz.py
     1тЖТimport atheris
     4тЖТ    from math import isnan
     5тЖТ    import sys
     6тЖТ    import warnings
     8тЖТ    import tomli_w
    10тЖТ    import tomli
    20тЖТdef test_one_input(input_bytes: bytes) -> None:
    21тЖТ    # We need a Unicode string, not bytes
    22тЖТ    fdp = atheris.FuzzedDataProvider(input_bytes)
    23тЖТ    data = fdp.ConsumeUnicode(sys.maxsize)
    24тЖТ
    25тЖТ    try:
    26тЖТ        toml_obj = tomli.loads(data)
    27тЖТ    except (tomli.TOMLDecodeError, RecursionError):
    28тЖТ        return
    29тЖТ    except BaseException:
    30тЖТ        print_err(data)
    31тЖТ        raise
    32тЖТ
    33тЖТ    try:
    34тЖТ        recovered_data = tomli_w.dumps(toml_obj)
    35тЖТ    except RecursionError:
    36тЖТ        return
    37тЖТ    except BaseException:
    38тЖТ        print_err(data)
    39тЖТ        raise
    40тЖТ
    41тЖТ    roundtripped_obj = tomli.loads(recovered_data)
    42тЖТ    normalize_toml_obj(roundtripped_obj)
    43тЖТ    normalize_toml_obj(toml_obj)
    44тЖТ    if roundtripped_obj != toml_obj:
    45тЖТ        sys.stderr.write(
    46тЖТ            f"Original dict:\n{toml_obj}\nRoundtripped dict:\n{roundtripped_obj}\n"
    47тЖТ        )
    48тЖТ        sys.stderr.flush()
    49тЖТ        print_err(data)
    50тЖТ        raise Exception("Dicts not equal after roundtrip")
    53тЖТdef print_err(data):
    54тЖТ    codepoints = [hex(ord(x)) for x in data]
    55тЖТ    sys.stderr.write(f"Input was {type(data)}:\n{data}\nCodepoints:\n{codepoints}\n")
    56тЖТ    sys.stderr.flush()
    59тЖТdef normalize_toml_obj(toml_obj: dict) -> None:
    60тЖТ    """Make NaNs equal when compared (without using recursion)."""
    61тЖТ    to_process = [toml_obj]
    62тЖТ    while to_process:
    63тЖТ        cont = to_process.pop()
    64тЖТ        for k, v in cont.items() if isinstance(cont, dict) else enumerate(cont):
    65тЖТ            if isinstance(v, float) and isnan(v):
    66тЖТ                cont[k] = "nan"
    67тЖТ            elif isinstance(v, (dict, list)):
    68тЖТ                to_process.append(v)
    71тЖТdef main():
    72тЖТ    # For possible options, see https://llvm.org/docs/LibFuzzer.html#options
    73тЖТ    fuzzer_options = sys.argv
    74тЖТ    atheris.Setup(fuzzer_options, test_one_input)
    75тЖТ    atheris.Fuzz()

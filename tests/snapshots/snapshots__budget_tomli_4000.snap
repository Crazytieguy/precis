     7→import sys
     8→from types import MappingProxyType
    10→from ._re import (
    11→    RE_DATETIME,
    12→    RE_LOCALTIME,
    13→    RE_NUMBER,
    14→    match_to_datetime,
    15→    match_to_localtime,

    24Рєњ    from ._types Рђд
    26Рєњ# Inline tables/arrays are implemented using recursion. Pathologically
    27Рєњ# nested documents cause pure Python to raise RecursionError (which is OK),
    28Рєњ# but mypyc binary wheels will crash unrecoverably (not OK). According to
    29Рєњ# mypyc docs this will be fixed in the future:
    30Рєњ# https://mypyc.readthedocs.io/en/latest/differences_from_python.html#stack-overflows
      РєњРђд
    35РєњMAX_INLINE_NESTING: Final = sys.getrecursionlimit()
    37РєњASCII_CTRL Рђд
    39Рєњ# Neither of these sets include quotation mark or backslash. They are
    40Рєњ# currently handled as separate cases in the parser functions.
    41РєњILLEGAL_BASIC_STR_CHARS: Final = ASCII_CTRL - frozenset("\t")

    95тЖТ# No need to limit cache size. This is only ever called on input
    96тЖТ# that matched RE_DATETIME, so there is an implicit bound of
    97тЖТ# 24 (hours) * 60 (minutes) * 2 (offset direction) = 2880.
    98тЖТ@lru_cache(maxsize=None)
    99тЖТdef cached_tz(hour_str: str, minute_str: str, sign_str: str) -> timezone:
   100тЖТ    sign = 1 if sign_str == "+" else -1
   101тЖТ    return timezone(
   102тЖТ        timedelta(
   103тЖТ            hours=sign * int(hour_str),
   104тЖТ            minutes=sign * int(minute_str),
   105тЖТ        )

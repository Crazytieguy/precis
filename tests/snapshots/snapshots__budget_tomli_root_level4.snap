    19‚ÜíTYPE_CHECKING = False
    26‚Üí# Inline tables/arrays are implemented using recursion. Pathologically
    27‚Üí# nested documents cause pure Python to raise RecursionError (which is OK),
    28‚Üí# but mypyc binary wheels will crash unrecoverably (not OK). According to
    29‚Üí# mypyc docs this will be fixed in the future:
    30‚Üí# https://mypyc.readthedocs.io/en/latest/differences_from_python.html#stack-overflows
    31‚Üí# Before mypyc's fix is in, recursion needs to be limited by this library.
    32‚Üí# Choosing `sys.getrecursionlimit()` as maximum inline table/array nesting
    33‚Üí# level, as it allows more nesting than pure Python, but still seems a far
    34‚Üí# lower number than where mypyc binaries crash.
    35‚ÜíMAX_INLINE_NESTING: Final = sys.getrecursionlimit()
    37‚ÜíASCII_CTRL: Final = frozenset(chr(i) for i in range(32)) | frozenset(chr(127))
    39‚Üí# Neither of these sets include quotation mark or backslash. They are
    40‚Üí# currently handled as separate cases in the parser functions.
    41‚ÜíILLEGAL_BASIC_STR_CHARS: Final = ASCII_CTRL - frozenset("\t")
    42‚ÜíILLEGAL_MULTILINE_BASIC_STR_CHARS: Final = ASCII_CTRL - frozenset("\t\n")
    44‚ÜíILLEGAL_LITERAL_STR_CHARS: Final = ILLEGAL_BASIC_STR_CHARS
    45‚ÜíILLEGAL_MULTILINE_LITERAL_STR_CHARS: Final = ILLEGAL_MULTILINE_BASIC_STR_CHARS
    47‚ÜíILLEGAL_COMMENT_CHARS: Final = ILLEGAL_BASIC_STR_CHARS
    49‚ÜíTOML_WS: Final = frozenset(" \t")
    50‚ÜíTOML_WS_AND_NEWLINE: Final = TOML_WS | frozenset("\n")
    51‚ÜíBARE_KEY_CHARS: Final = frozenset(
    54‚ÜíKEY_INITIAL_CHARS: Final = BARE_KEY_CHARS | frozenset("\"'")

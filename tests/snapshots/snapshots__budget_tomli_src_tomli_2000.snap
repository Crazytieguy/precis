    26тЖТ# Inline tables/arrays are implemented using recursion. Pathologically
    27тЖТ# nested documents cause pure Python to raise RecursionError (which is OK),
    28тЖТ# but mypyc binary wheels will crash unrecoverably (not OK). According to
    29тЖТ# mypyc docs this will be fixed in the future:
    30тЖТ# https://mypyc.readthedocs.io/en/latest/differences_from_python.html#stack-overflows
    31тЖТ# Before mypyc's fix is in, recursion needs to be limited by this library.
    32тЖТ# Choosing `sys.getrecursionlimit()` as maximum inline table/array nesting
    33тЖТ# level, as it allows more nesting than pure Python, but still seems a far
    34тЖТ# lower number than where mypyc binaries crash.
    35тЖТMAX_INLINE_NESTING: Final = sys.getrecursionlimit()

   684→def parse_value(
   685→    src: str, pos: Pos, parse_float: ParseFloat, nest_lvl: int
   686→) -> tuple[Pos, Any]:
   687→    if nest_lvl > MAX_INLINE_NESTING:
   688→        # Pure Python should have raised RecursionError already.
   689→        # This ensures mypyc binaries eventually do the same.
   690→        raise RecursionError(  # pragma: no cover
   691→            "TOML inline arrays/tables are nested more than the allowed"
   692→            f" {MAX_INLINE_NESTING} levels"
   693→        )
   694→
   695→    try:
   696→        char: str | None = src[pos]
   697→    except IndexError:
   698→        char = None
   699→
   700→    # IMPORTANT: order conditions based on speed of checking and likelihood
   701→
   702→    # Basic strings
   703→    if char == '"':
   704→        if src.startswith('"""', pos):
   705→            return parse_multiline_str(src, pos, literal=False)
   706→        return parse_one_line_basic_str(src, pos)
   707→
   708→    # Literal strings
   709→    if char == "'":
   710→        if src.startswith("'''", pos):
   711→            return parse_multiline_str(src, pos, literal=True)
   712→        return parse_literal_str(src, pos)

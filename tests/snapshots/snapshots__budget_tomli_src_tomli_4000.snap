   652→def parse_basic_str(src: str, pos: Pos, *, multiline: bool) -> tuple[Pos, str]:
   653→    if multiline:
   654→        error_on = ILLEGAL_MULTILINE_BASIC_STR_CHARS
   655→        parse_escapes = parse_basic_str_escape_multiline
   656→    else:
   657→        error_on = ILLEGAL_BASIC_STR_CHARS

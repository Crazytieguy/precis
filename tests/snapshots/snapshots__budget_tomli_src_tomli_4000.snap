   760→def is_unicode_scalar_value(codepoint: int) -> bool:
   761→    return (0 <= codepoint <= 55295) or (57344 <= codepoint <= 1114111)
   764→def make_safe_parse_float(parse_float: ParseFloat) -> ParseFloat:
   765→    """A decorator to make `parse_float` safe.
   766→
   767→    `parse_float` must not return dicts or lists, because these types
   768→    would be mixed with parsed TOML tables and arrays, thus confusing
   769→    the parser. The returned decorated callable raises `ValueError`
   770→    instead of returning illegal types.
   771→    """
   772→    # The default `float` callable never returns illegal types. Optimize it.
   773→    if parse_float is float:
   774→        return float
   775→
   776→    def safe_parse_float(float_str: str) -> Any:
   777→        float_value = parse_float(float_str)
   778→        if isinstance(float_value, (dict, list)):
   779→            raise ValueError("parse_float must not return dicts or lists")
   780→        return float_value
   781→
   782→    return safe_parse_float

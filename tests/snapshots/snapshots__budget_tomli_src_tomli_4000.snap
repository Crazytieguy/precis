   670→                return pos + 3, result + src[start_pos:pos]
   671→            pos += 1
   672→            continue
   673→        if char == "\\":
   674→            result += src[start_pos:pos]
   675→            pos, parsed_escape = parse_escapes(src, pos)
   676→            result += parsed_escape
   677→            start_pos = pos

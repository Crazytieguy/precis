    59‚Üídef match_to_datetime(match: re.Match[str]) -> datetime | date:
    60‚Üí    """Convert a `RE_DATETIME` match to `datetime.datetime` or `datetime.date`.
    61‚Üí
    62‚Üí    Raises ValueError if the match does not correspond to a valid date
    63‚Üí    or datetime.
    64‚Üí    """
    65‚Üí    (
    66‚Üí        year_str,
    67‚Üí        month_str,
    68‚Üí        day_str,
    69‚Üí        hour_str,
    70‚Üí        minute_str,
    71‚Üí        sec_str,
    72‚Üí        micros_str,
    73‚Üí        zulu_time,
    74‚Üí        offset_sign_str,
    75‚Üí        offset_hour_str,
    76‚Üí        offset_minute_str,
    77‚Üí    ) = match.groups()
    78‚Üí    year, month, day = int(year_str), int(month_str), int(day_str)
    79‚Üí    if hour_str is None:
    80‚Üí        return date(year, month, day)
    81‚Üí    hour, minute = int(hour_str), int(minute_str)
    82‚Üí    sec = int(sec_str) if sec_str else 0
    83‚Üí    micros = int(micros_str.ljust(6, "0")) if micros_str else 0
    84‚Üí    if offset_sign_str:
    85‚Üí        tz: tzinfo | None = cached_tz(
    86‚Üí            offset_hour_str, offset_minute_str, offset_sign_str
    87‚Üí        )
    88‚Üí    elif zulu_time:
    89‚Üí        tz = timezone.utc
    90‚Üí    else:  # local date-time
    91‚Üí        tz = None
    92‚Üí    return datetime(year, month, day, hour, minute, sec, micros, tzinfo=tz)
    95‚Üí# No need to limit cache size. This is only ever called on input
    96‚Üí# that matched RE_DATETIME, so there is an implicit bound of
    97‚Üí# 24 (hours) * 60 (minutes) * 2 (offset direction) = 2880.
    98‚Üí@lru_cache(maxsize=None)
    99‚Üídef cached_tz(hour_str: str, minute_str: str, sign_str: str) -> timezone:
   100‚Üí    sign = 1 if sign_str == "+" else -1
   101‚Üí    return timezone(
   102‚Üí        timedelta(
   103‚Üí            hours=sign * int(hour_str),
   104‚Üí            minutes=sign * int(minute_str),
   105‚Üí        )
   106‚Üí    )
   109‚Üídef match_to_localtime(match: re.Match[str]) -> time:
   110‚Üí    hour_str, minute_str, sec_str, micros_str = match.groups()
   111‚Üí    sec = int(sec_str) if sec_str else 0
   112‚Üí    micros = int(micros_str.ljust(6, "0")) if micros_str else 0
   113‚Üí    return time(int(hour_str), int(minute_str), sec, micros)
   116‚Üídef match_to_number(match: re.Match[str], parse_float: ParseFloat) -> Any:
   117‚Üí    if match.group("floatpart"):
   118‚Üí        return parse_float(match.group())
   119‚Üí    return int(match.group(), 0)


    28‚Üí0
    29‚Üí(?:
    30‚Üí    x[0-9A-Fa-f](?:_?[0-9A-Fa-f])*   # hex
    31‚Üí    |
    32‚Üí    b[01](?:_?[01])*                 # bin
    33‚Üí    |
    34‚Üí    o[0-7](?:_?[0-7])*               # oct
    35‚Üí)
    36‚Üí|
    37‚Üí[+-]?(?:0|[1-9](?:_?[0-9])*)         # dec, integer part
    38‚Üí(?P<floatpart>
    39‚Üí    (?:\.[0-9](?:_?[0-9])*)?         # optional fractional part
    40‚Üí    (?:[eE][+-]?[0-9](?:_?[0-9])*)?  # optional exponent part
    41‚Üí)
    42‚Üí""",
    43‚Üí    flags=re.VERBOSE,
    44‚Üí)
    45‚ÜíRE_LOCALTIME: Final = re.compile(_TIME_RE_STR, flags=re.VERBOSE)
    46‚ÜíRE_DATETIME: Final = re.compile(

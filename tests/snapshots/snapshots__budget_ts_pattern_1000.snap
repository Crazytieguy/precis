   417‚Üí### `match`
   419‚Üí```ts
   420‚Üímatch(value);
   421‚Üí```
   422‚Üí
   423‚ÜíCreate a `Match` object on which you can later call `.with`, `.when`, `.otherwise` and `.run`.
   424‚Üí
   857‚Üí#### `P._` wildcard
   859‚ÜíThe `P._` pattern will match any value. You can also use `P.any`, which is an alias to `P._`.
   860‚Üí
   861‚Üí```ts
   862‚Üíimport { match, P } from 'ts-pattern';
   863‚Üí
   864‚Üíconst input = 'hello';
   865‚Üí
   866‚Üíconst output = match(input)
   867‚Üí  .with(P._, () => 'It will always match')
   868‚Üí  // OR
   869‚Üí  .with(P.any, () => 'It will always match')
   870‚Üí  .otherwise(() => 'This string will never be used');
   871‚Üí
   872‚Üíconsole.log(output);
   873‚Üí// => 'It will always match'
   874‚Üí```
   875‚Üí
  1623‚Üí### `P.infer`
  1625‚Üí`P.infer<typeof somePattern>` lets you infer a type of value from a type of pattern.
  1626‚Üí
  1627‚ÜíIt's particularly useful when validating an API response.
  1628‚Üí
  1629‚Üí```ts
  1630‚Üíconst postPattern = {
  1631‚Üí  title: P.string,
  1632‚Üí  content: P.string,
  1633‚Üí  stars: P.number.between(1, 5).optional(),
  1634‚Üí  author: {
  1635‚Üí    firstName: P.string,
  1636‚Üí    lastName: P.string.optional(),
  1637‚Üí    followerCount: P.number,
  1638‚Üí  },
  1639‚Üí} as const;
  1640‚Üí
  1641‚Üítype Post = P.infer<typeof postPattern>;
  1642‚Üí
  1643‚Üí// posts: Post[]
  1644‚Üíconst posts = await fetch(someUrl)

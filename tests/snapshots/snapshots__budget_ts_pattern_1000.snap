     3‚Üí * and .exhaustive() was specified
     4‚Üí */
     5‚Üíexport class NonExhaustiveError extends Error {
     6‚Üí  constructor(public input: unknown) {
     7‚Üí    let displayedValue;
     8‚Üí    try {
     9‚Üí      displayedValue = JSON.stringify(input);
    10‚Üí    } catch (e) {
    11‚Üí      displayedValue = input;
    12‚Üí    }
    13‚Üí    super(`Pattern matching error: no pattern matches value ${displayedValue}`);
    14‚Üí  }
    15‚Üí}

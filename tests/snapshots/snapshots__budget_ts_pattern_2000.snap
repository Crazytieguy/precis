    43Рєњ/**
    44Рєњ * A `Matcher` is an object implementing the match
    45Рєњ * protocol. It must define a `symbols.matcher` property
    46Рєњ * which returns an object with a `match()` method, taking
    47Рєњ * the input value and returning whether the pattern matches
    48Рєњ * or not, along with optional selections.
    49Рєњ */
    50Рєњexport interface Matcher<
    51Рєњ  input,
    52Рєњ  narrowed,
    53Рєњ  // Type of what this pattern selected from the input
    54Рєњ  matcherType extends MatcherType = 'default',
    55Рєњ  selections extends SelectionType = None,
    56Рєњ  // Type to exclude from the input union because
    57Рєњ  // it has been fully matched by this pattern
    58Рєњ  excluded = narrowed
    59Рєњ> {
    60Рєњ  [matcher](): MatcherProtocol<
    61Рєњ    input,
    62Рєњ    narrowed,
    63Рєњ    matcherType,
    64Рєњ    selections,
    65Рєњ    excluded
    66Рєњ  >;
    67Рєњ  // only used for array matchers
    68Рєњ  [symbols.isVariadic]?: boolean;
    69Рєњ}

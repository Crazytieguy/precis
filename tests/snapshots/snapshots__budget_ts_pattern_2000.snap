src/internals/symbols.ts
     1Рєњ/**
     2Рєњ * Symbols used internally within ts-pattern to construct and discriminate
     3Рєњ * Guard, Not, and Select, and AnonymousSelect patterns
     4Рєњ *
     5Рєњ * Symbols have the advantage of not appearing in auto-complete suggestions in
     6Рєњ * user defined patterns, and eliminate the risk of property
     7Рєњ * overlap between ts-pattern internals and user defined patterns.
     8Рєњ *
     9Рєњ * These symbols have to be visible to tsc for type inference to work, but
    10Рєњ * users should not import them
    11Рєњ * @module
    12Рєњ * @private
    13Рєњ * @internal
    14Рєњ */
    15Рєњ
    16Рєњexport const matcher = Symbol.for('@ts-pattern/matcher');
    17Рєњexport type matcher = typeof matcher;
    19Рєњexport const unset = Symbol.for('@ts-pattern/unset');
    20Рєњexport type unset = typeof unset;
    22Рєњexport const isVariadic = Symbol.for('@ts-pattern/isVariadic');
    23Рєњexport type isVariadic = typeof isVariadic;
    26Рєњexport const anonymousSelectKey = '@ts-pattern/anonymous-select-key';
    27Рєњexport type anonymousSelectKey = typeof anonymousSelectKey;
    29Рєњexport const override = Symbol.for('@ts-pattern/override');
    30Рєњexport type override = typeof override;

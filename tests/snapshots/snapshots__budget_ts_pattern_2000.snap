README.md
   417‚Üí### `match`
   419‚Üí```ts
   420‚Üímatch(value);
   421‚Üí```
   422‚Üí
   423‚ÜíCreate a `Match` object on which you can later call `.with`, `.when`, `.otherwise` and `.run`.
   424‚Üí
   857‚Üí#### `P._` wildcard
   859‚ÜíThe `P._` pattern will match any value. You can also use `P.any`, which is an alias to `P._`.
   860‚Üí
   861‚Üí```ts
   862‚Üíimport { match, P } from 'ts-pattern';
   863‚Üí
   864‚Üíconst input = 'hello';
   865‚Üí
   866‚Üíconst output = match(input)
   867‚Üí  .with(P._, () => 'It will always match')
   868‚Üí  // OR
   869‚Üí  .with(P.any, () => 'It will always match')
   870‚Üí  .otherwise(() => 'This string will never be used');
   871‚Üí
   872‚Üíconsole.log(output);
   873‚Üí// => 'It will always match'
   874‚Üí```
   875‚Üí
  1623‚Üí### `P.infer`
  1625‚Üí`P.infer<typeof somePattern>` lets you infer a type of value from a type of pattern.
  1626‚Üí
  1627‚ÜíIt's particularly useful when validating an API response.
  1628‚Üí
  1629‚Üí```ts
  1630‚Üíconst postPattern = {
  1631‚Üí  title: P.string,
  1632‚Üí  content: P.string,
  1633‚Üí  stars: P.number.between(1, 5).optional(),
  1634‚Üí  author: {
  1635‚Üí    firstName: P.string,
  1636‚Üí    lastName: P.string.optional(),
  1637‚Üí    followerCount: P.number,
  1638‚Üí  },
  1639‚Üí} as const;
  1640‚Üí
  1641‚Üítype Post = P.infer<typeof postPattern>;
  1642‚Üí
  1643‚Üí// posts: Post[]
  1644‚Üíconst posts = await fetch(someUrl)
  1645‚Üí  .then((res) => res.json())
  1646‚Üí  .then((res: unknown): Post[] =>
  1647‚Üí    isMatching({ data: P.array(postPattern) }, res) ? res.data : []
  1648‚Üí  );
  1649‚Üí```
  1650‚Üí
  1651‚ÜíAlthough not strictly necessary, using `as const` after the pattern definition ensures that TS-Pattern infers the most precise types possible.
  1652‚Üí
docs/v3-to-v4-migration-guide.md
     3‚Üí## Breaking changes
     5‚Üí### Imports
     7‚Üítype-specific wildcard patterns have moved from `__.<pattern>` to a new `Pattern` qualified module, also exported as `P` by ts-pattern.
     8‚Üí
     9‚Üí```diff
    10‚Üí- import { match, __ } from 'ts-pattern';
    11‚Üí+ import { match, Pattern } from 'ts-pattern';
    12‚Üí
    13‚Üí
    14‚Üíconst toString = (value: string | number) =>
    15‚Üí  match(value)
    16‚Üí-   .with(__.string, (v) => v)
    17‚Üí-   .with(__.number, (v) => `${v}`)
    18‚Üí+   .with(Pattern.string, (v) => v)
      ‚Üí‚Ä¶
   128‚Üí#### `P.array(pattern)`
   130‚ÜíTo match an array of elements, you can now use `P.array`:
   131‚Üí
   132‚Üí```ts
   133‚Üíimport { match, P } from 'ts-pattern';
   134‚Üí
   135‚Üíconst responsePattern = {
   136‚Üí  data: P.array({
   137‚Üí    id: P.string,
   138‚Üí    post: P.array({
   139‚Üí      title: P.string,
   140‚Üí      content: P.string,
   141‚Üí    }),
      ‚Üí‚Ä¶
   159‚Üí#### `P.optional(pattern)`
   161‚ÜíIf you want one of the keys of your pattern to be optional, you can now use `P.optional(subpattern)`.
   162‚Üí
   163‚ÜíIf you `P.select()` something in an optional pattern, it's type will be infered as `T | undefined`.
   164‚Üí
   165‚Üí```ts
   166‚Üíimport { match, P } from 'ts-pattern';
   167‚Üí
   168‚Üíconst doSomethingWithUser = (user: User | Org) =>
   169‚Üí  match(user)
   170‚Üí    .with(
   171‚Üí      {
   172‚Üí        type: 'user',
      ‚Üí‚Ä¶
   298‚Üí#### `P.infer<typeof pattern>`
   300‚ÜíTS-Pattern is pretty handy for parsing unknown payloads like HTTP responses. You can write a pattern for the shape you are expecting, and then use `isMatching(pattern, response)` to make sure the response has the correct shape.
   301‚Üí
   302‚ÜíOne limitation TS-Pattern had in its previous version was that it did not provide a way to get the TypeScript type of the value a given pattern matches. This is what `P.infer<typeof pattern>` does :)
   303‚Üí
   304‚Üí```ts
   305‚Üíconst postPattern = {
   306‚Üí  title: P.string,
   307‚Üí  description: P.optional(P.string),
   308‚Üí  content: P.string,
   309‚Üí  likeCount: P.number,
   310‚Üí};
   311‚Üí
      ‚Üí‚Ä¶
   336‚Üí#### `P.symbol`
   338‚Üí`P.symbol` is a wildcard pattern matching any **symbol**.
   339‚Üí
   340‚Üí```ts
   341‚Üímatch(Symbol('Hello'))
   342‚Üí  .with(P.symbol, () => 'this is a symbol!')
   343‚Üí  .exhaustive();
   344‚Üí```
   345‚Üí

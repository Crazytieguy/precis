    43вҶ’/**
    44вҶ’ * A `Matcher` is an object implementing the match
    45вҶ’ * protocol. It must define a `symbols.matcher` property
    46вҶ’ * which returns an object with a `match()` method, taking
    47вҶ’ * the input value and returning whether the pattern matches
    48вҶ’ * or not, along with optional selections.
    49вҶ’ */
    50вҶ’export interface Matcher<
    51вҶ’  input,
    52вҶ’  narrowed,
    53вҶ’  // Type of what this pattern selected from the input
    54вҶ’  matcherType extends MatcherType = 'default',
    55вҶ’  selections extends SelectionType = None,
    56вҶ’  // Type to exclude from the input union because
    57вҶ’  // it has been fully matched by this pattern
    58вҶ’  excluded = narrowed
    59вҶ’> {
    60вҶ’  [matcher](): MatcherProtocol<
    61вҶ’    input,
    62вҶ’    narrowed,
    63вҶ’    matcherType,
    64вҶ’    selections,
    65вҶ’    excluded
    66вҶ’  >;
    67вҶ’  // only used for array matchers

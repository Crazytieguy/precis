docs/v3-to-v4-migration-guide.md
     1→# TS-Pattern v3 to v4 Migration Guide
     2→
     3→## Breaking changes
     4→
     5→### Imports
     6→
     7→type-specific wildcard patterns have moved from `__.<pattern>` to a new `Pattern` qualified module, also exported as `P` by ts-pattern.
     8→
     9→```diff
    10→- import { match, __ } from 'ts-pattern';
    11→+ import { match, Pattern } from 'ts-pattern';
    12→
    13→
    14→const toString = (value: string | number) =>
    15→  match(value)
    16→-   .with(__.string, (v) => v)
    17→-   .with(__.number, (v) => `${v}`)
    18→+   .with(Pattern.string, (v) => v)
    19→+   .with(Pattern.number, (v) => `${v}`)
    20→    .exhaustive();
    21→```
    22→
    23→or
    24→
    25→```diff
    26→- import { match, __ } from 'ts-pattern';
    27→+ import { match, P } from 'ts-pattern';
    28→
    29→
    30→const toString = (value: string | number) =>
    31→  match(value)
    32→-   .with(__.string, (v) => v)
    33→-   .with(__.number, (v) => `${v}`)
    34→+   .with(P.string, (v) => v)
    35→+   .with(P.number, (v) => `${v}`)
    36→    .exhaustive();
    37→```
    38→
    39→#### `__`
    40→

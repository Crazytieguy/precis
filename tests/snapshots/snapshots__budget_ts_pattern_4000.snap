   122‚Üí## New features
   123‚Üí
      ‚Üí‚Ä¶
   126‚Üí### Arrays and unary tuples
   127‚Üí
   128‚Üí#### `P.array(pattern)`
   129‚Üí
   130‚ÜíTo match an array of elements, you can now use `P.array`:
   131‚Üí
   132‚Üí```ts
   133‚Üíimport { match, P } from 'ts-pattern';
   134‚Üí
   135‚Üíconst responsePattern = {
   136‚Üí  data: P.array({
   137‚Üí    id: P.string,
   138‚Üí    post: P.array({
   139‚Üí      title: P.string,
   140‚Üí      content: P.string,
   141‚Üí    }),
   142‚Üí  }),
   143‚Üí};
   144‚Üí
   145‚ÜífetchSomething().then((value: unknown) =>
   146‚Üí  match(value)
   147‚Üí    .with(responsePattern, (value) => {
   148‚Üí      // value: { data: { id: string, post: { title: string, content: string }[] }[] }
   149‚Üí      return value;
   150‚Üí    })
   151‚Üí    .otherwise(() => {
   152‚Üí      throw new Error('unexpected response');
   153‚Üí    })
   154‚Üí);
   155‚Üí```
   156‚Üí
   157‚Üí### Optional object properties
   158‚Üí
   159‚Üí#### `P.optional(pattern)`
   160‚Üí
   161‚ÜíIf you want one of the keys of your pattern to be optional, you can now use `P.optional(subpattern)`.
   162‚Üí
   163‚ÜíIf you `P.select()` something in an optional pattern, it's type will be infered as `T | undefined`.
   164‚Üí
   165‚Üí```ts
   166‚Üíimport { match, P } from 'ts-pattern';
   167‚Üí
   168‚Üíconst doSomethingWithUser = (user: User | Org) =>
   169‚Üí  match(user)
   170‚Üí    .with(
   171‚Üí      {
   172‚Üí        type: 'user',
   173‚Üí        detail: {
   174‚Üí          bio: P.optional(P.string),
   175‚Üí          socialLinks: P.optional({
   176‚Üí            twitter: P.select(),
   177‚Üí          }),
   178‚Üí        },
   179‚Üí      },
   180‚Üí      (twitterLink, value) => {
   181‚Üí        // twitterLink: string | undefined
   182‚Üí        /**
   183‚Üí         *  value.detail: {
   184‚Üí         *      bio?: string,
   185‚Üí         *      socialLinks?: {
   186‚Üí         *          twitter: string
   187‚Üí         *      }
   188‚Üí         *  }
   189‚Üí         **/
   190‚Üí      }
   191‚Üí    )
   192‚Üí    .otherwise(() => {
   193‚Üí      throw new Error('unexpected response');
   194‚Üí    });
   195‚Üí```
   196‚Üí
   197‚Üí### Union & intersection patterns
   198‚Üí
      ‚Üí‚Ä¶
   201‚Üí#### `P.union(...patterns)`
   202‚Üí
      ‚Üí‚Ä¶
   234‚Üí#### `P.intersection(...patterns)`
   235‚Üí

  1243‚Üí/**
  1244‚Üí * `P.instanceOf(SomeClass)` is a pattern matching instances of a given class.
  1245‚Üí *
  1246‚Üí * [Read the documentation for `P.instanceOf` on GitHub](https://github.com/gvergnaud/ts-pattern#pinstanceof-patterns)
  1247‚Üí *
  1248‚Üí *  @example
  1249‚Üí *   .with(P.instanceOf(SomeClass), () => 'will match on SomeClass instances')
  1250‚Üí */
  1251‚Üíexport function instanceOf<T extends AnyConstructor>(
  1252‚Üí  classConstructor: T
  1253‚Üí): Chainable<GuardP<unknown, InstanceType<T>>> {
  1254‚Üí  return chainable(when(isInstanceOf(classConstructor)));

docs/v3-to-v4-migration-guide.md
     1‚Üí# TS-Pattern v3 to v4 Migration Guide
     3‚Üí## Breaking changes
     5‚Üí### Imports
     7‚Üítype-specific wildcard patterns have moved from `__.<pattern>` to a new `Pattern` qualified module, also exported as `P` by ts-pattern.
     8‚Üí
     9‚Üí```diff
    10‚Üí- import { match, __ } from 'ts-pattern';
    11‚Üí+ import { match, Pattern } from 'ts-pattern';
    12‚Üí
    13‚Üí
    14‚Üíconst toString = (value: string | number) =>
    15‚Üí  match(value)
    16‚Üí-   .with(__.string, (v) => v)
    17‚Üí-   .with(__.number, (v) => `${v}`)
    18‚Üí+   .with(Pattern.string, (v) => v)
    19‚Üí+   .with(Pattern.number, (v) => `${v}`)
    20‚Üí    .exhaustive();
    21‚Üí```
    22‚Üí
    23‚Üíor
    24‚Üí
    25‚Üí```diff
    26‚Üí- import { match, __ } from 'ts-pattern';
    27‚Üí+ import { match, P } from 'ts-pattern';
    28‚Üí
    29‚Üí
    30‚Üíconst toString = (value: string | number) =>
    31‚Üí  match(value)
    32‚Üí-   .with(__.string, (v) => v)
    33‚Üí-   .with(__.number, (v) => `${v}`)
    34‚Üí+   .with(P.string, (v) => v)
    35‚Üí+   .with(P.number, (v) => `${v}`)
    36‚Üí    .exhaustive();
    37‚Üí```
    38‚Üí
    39‚Üí#### `__` ‚Ä¶
    57‚Üí#### `select()`, `not()`, `when()` ‚Ä¶
    79‚Üí#### `Pattern` type ‚Ä¶

src/match.ts
     7‚Üítype MatchState ‚Ä¶
    11‚Üíconst unmatched ‚Ä¶
    16‚Üí/**
    17‚Üí * `match` creates a **pattern matching expression**.
    18‚Üí *  * Use `.with(pattern, handler)` to pattern match on the input.
    19‚Üí *  * Use `.exhaustive()` or `.otherwise(() => defaultValue)` to end the expression and get the result.
    20‚Üí *
    21‚Üí * [Read the documentation for `match` on GitHub](https://github.com/gvergnaud/ts-pattern#match)
    22‚Üí *
    23‚Üí * @example
    24‚Üí *  declare let input: "A" | "B";
    25‚Üí *
    26‚Üí *  return match(input)
    27‚Üí *    .with("A", () => "It's an A!")
    28‚Üí *    .with("B", () => "It's a B!")
    29‚Üí *    .exhaustive();
    30‚Üí *
    31‚Üí */
    32‚Üíexport function match<const input, output = symbols.unset>(
    33‚Üí  value: input
    34‚Üí): Match<input, output> {
    35‚Üí  return new MatchExpression(value, unmatched) as any;
    36‚Üí}
    38‚Üí/**
    39‚Üí * This class represents a match expression. It follows the
    40‚Üí * builder pattern, we chain methods to add features to the expression
    41‚Üí * until we call `.exhaustive`, `.otherwise` or the unsafe `.run`
    42‚Üí * method to execute it.
    43‚Üí *
    44‚Üí * The types of this class aren't public, the public type definition
    45‚Üí * can be found in src/types/Match.ts.
    46‚Üí */
    47‚Üíclass MatchExpression<input, output> {
    48‚Üí  constructor(private input: input, private state: MatchState<output>) {}
    49‚Üí
    50‚Üí  with(...args: any[]): MatchExpression<input, output> {
    51‚Üí    if (this.state.matched) return this;
    52‚Üí
    53‚Üí    const handler: (selection: unknown, value: input) => output =
    54‚Üí      args[args.length - 1];
    55‚Üí
    56‚Üí    const patterns: Pattern<input>[] = [args[0]];
    57‚Üí    let predicate: ((value: input) => unknown) | undefined = undefined;
    58‚Üí
    59‚Üí    if (args.length === 3 && typeof args[1] === 'function') {
    60‚Üí      // case with guard as second argument
    61‚Üí      predicate = args[1];
    62‚Üí    } else if (args.length > 2) {
    63‚Üí      // case with several patterns
    64‚Üí      patterns.push(...args.slice(1, args.length - 1));
    65‚Üí    }
    66‚Üí
    67‚Üí    let hasSelections = false;
    68‚Üí    let selected: Record<string, unknown> = {};
    69‚Üí    const select = (key: string, value: unknown) => {
    70‚Üí      hasSelections = true;
    71‚Üí      selected[key] = value;
    72‚Üí    };
    73‚Üí
    74‚Üí    const matched =
    75‚Üí      patterns.some((pattern) => matchPattern(pattern, this.input, select)) &&
    76‚Üí      (predicate ? Boolean(predicate(this.input)) : true);
    77‚Üí
    78‚Üí    const selections = hasSelections
    79‚Üí      ? symbols.anonymousSelectKey in selected
    80‚Üí        ? selected[symbols.anonymousSelectKey]
    81‚Üí        : selected
    82‚Üí      : this.input;
    83‚Üí
    84‚Üí    const state = matched
    85‚Üí      ? {
    86‚Üí          matched: true as const,
    87‚Üí          value: handler(selections, this.input),
    88‚Üí        }
    89‚Üí      : unmatched;
    90‚Üí
    91‚Üí    return new MatchExpression(this.input, state);
    92‚Üí  }
    93‚Üí
    94‚Üí  when(
    95‚Üí    predicate: (value: input) => unknown,
    96‚Üí    handler: (selection: input, value: input) => output
    97‚Üí  ): MatchExpression<input, output> {
    98‚Üí    if (this.state.matched) return this;
    99‚Üí
   100‚Üí    const matched = Boolean(predicate(this.input));
   101‚Üí
   102‚Üí    return new MatchExpression<input, output>(
   103‚Üí      this.input,
   104‚Üí      matched
   105‚Üí        ? { matched: true, value: handler(this.input, this.input) }
   106‚Üí        : unmatched
   107‚Üí    );
   108‚Üí  }
   109‚Üí
   110‚Üí  otherwise(handler: (value: input) => output): output {
   111‚Üí    if (this.state.matched) return this.state.value;
   112‚Üí    return handler(this.input);
   113‚Üí  }
   114‚Üí
   115‚Üí  exhaustive(unexpectedValueHandler = defaultCatcher): output {
   116‚Üí    if (this.state.matched) return this.state.value;
   117‚Üí    return unexpectedValueHandler(this.input);

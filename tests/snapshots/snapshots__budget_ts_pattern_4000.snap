    12‚Üíexport const isObject = (value: unknown): value is Object =>
    13‚Üí  Boolean(value && typeof value === 'object');
    16‚Üíexport const isMatcher = (
    17‚Üí  x: unknown
    18‚Üí): x is Matcher<unknown, unknown, MatcherType, SelectionType> => {
    19‚Üí  const pattern = x as Matcher<unknown, unknown, MatcherType, SelectionType>;
    20‚Üí  return pattern && !!pattern[symbols.matcher];
    21‚Üí};
    24‚Üíconst isOptionalPattern = (
    25‚Üí  x: unknown
    26‚Üí): x is Matcher<unknown, unknown, 'optional', SelectionType> => {
    27‚Üí  return isMatcher(x) && x[symbols.matcher]().matcherType === 'optional';
    28‚Üí};
    32‚Üíexport const matchPattern = (
    33‚Üí  pattern: any,
    34‚Üí  value: any,
    35‚Üí  select: (key: string, value: unknown) => void
    36‚Üí): boolean => {
    37‚Üí  if (isMatcher(pattern)) {
    38‚Üí    const matcher = pattern[symbols.matcher]();
    39‚Üí    const { matched, selections } = matcher.match(value);
    40‚Üí    if (matched && selections) {
    41‚Üí      Object.keys(selections).forEach((key) => select(key, selections[key]));
    42‚Üí    }
    43‚Üí    return matched;
    44‚Üí  }
    45‚Üí
    46‚Üí  if (isObject(pattern)) {
    47‚Üí    if (!isObject(value)) return false;
    48‚Üí
      ‚Üí‚Ä¶
   120‚Üíexport const getSelectionKeys = (pattern: any): string[] => {
   121‚Üí  if (isObject(pattern)) {
   122‚Üí    if (isMatcher(pattern)) {
   123‚Üí      return pattern[symbols.matcher]().getSelectionKeys?.() ?? [];
   124‚Üí    }
   125‚Üí    if (Array.isArray(pattern)) return flatMap(pattern, getSelectionKeys);
   126‚Üí    return flatMap(Object.values(pattern), getSelectionKeys);
   127‚Üí  }
   128‚Üí  return [];
   129‚Üí};
   132‚Üíexport const flatMap = <a, b>(
   133‚Üí  xs: readonly a[],
   134‚Üí  f: (v: a) => readonly b[]
   135‚Üí): b[] => xs.reduce<b[]>((acc, x) => acc.concat(f(x)), []);
src/internals/symbols.ts
     1‚Üí/**
     2‚Üí * Symbols used internally within ts-pattern to construct and discriminate
     3‚Üí * Guard, Not, and Select, and AnonymousSelect patterns
     4‚Üí *
     5‚Üí * Symbols have the advantage of not appearing in auto-complete suggestions in
     6‚Üí * user defined patterns, and eliminate the risk of property
     7‚Üí * overlap between ts-pattern internals and user defined patterns.
     8‚Üí *
     9‚Üí * These symbols have to be visible to tsc for type inference to work, but
    10‚Üí * users should not import them
    11‚Üí * @module
    12‚Üí * @private
    13‚Üí * @internal
    14‚Üí */
    15‚Üí
    16‚Üíexport const matcher = Symbol.for('@ts-pattern/matcher');
    17‚Üíexport type matcher = typeof matcher;
    19‚Üíexport const unset = Symbol.for('@ts-pattern/unset');
    20‚Üíexport type unset = typeof unset;
    22‚Üíexport const isVariadic = Symbol.for('@ts-pattern/isVariadic');
    23‚Üíexport type isVariadic = typeof isVariadic;
    26‚Üíexport const anonymousSelectKey = '@ts-pattern/anonymous-select-key';
    27‚Üíexport type anonymousSelectKey = typeof anonymousSelectKey;
    29‚Üíexport const override = Symbol.for('@ts-pattern/override');
    30‚Üíexport type override = typeof override;

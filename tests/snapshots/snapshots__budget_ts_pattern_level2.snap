     4→export type BuildMany<data, xs extends readonly any[]> = xs extends any
     5→  ? BuildOne<data, xs>
     6→  : never;
    11→type BuildOne<data, xs extends readonly any[]> = xs extends [
    12→  [infer value, infer path],
    13→  ...infer tail
    14→]
    15→  ? BuildOne<SetDeep<data, value, path>, tail>
    16→  : data;
    19→export type SetDeep<data, value, path> = path extends readonly [
    20→  infer head,
    21→  ...infer tail
    22→]
    23→  ? data extends readonly any[]
    24→    ? data extends readonly [any, ...any]
    25→      ? head extends number
    26→        ? UpdateAt<data, Iterator<head>, SetDeep<data[head], value, tail>>
    27→        : never
    28→      : SetDeep<ValueOf<data>, value, tail>[]
    29→    : data extends Set<infer a>
    30→    ? Set<SetDeep<a, value, tail>>
    31→    : data extends Map<infer k, infer v>
    32→    ? Map<k, SetDeep<v, value, tail>>
    33→    : head extends keyof data
    34→    ? // if we intentionally set undefined on an optional key, we should keep
    35→      // the optional modifier, otherwise it will exclude the `undefined` type from
    36→      // our `value` type.
    37→      [IsOptionalKeysOf<data, head>, tail, undefined] extends [true, [], value]
    38→      ? { [k in keyof data]: k extends head ? value : data[k] }
    39→      : {
    40→          [k in keyof data]-?: k extends head
    41→            ? SetDeep<data[head], value, tail>
    42→            : data[k];
    43→        }
    44→    : data
    45→  : value;

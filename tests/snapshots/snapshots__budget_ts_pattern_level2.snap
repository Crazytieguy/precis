     8→export type PickReturnValue<a, b> = a extends symbols.unset ? b : a;
    10→interface NonExhaustiveError<i> {
    14→interface TSPatternError<i> {
    22→export type Match<
    23→  i,
    24→  o,
    25→  handledCases extends any[] = [],
    26→  inferredOutput = never
    27→> = {
    28→  /**
    29→   * `.with(pattern, handler)` Registers a pattern and an handler function that
    30→   * will be called if the pattern matches the input value.
    31→   *
    32→   * [Read the documentation for `.with()` on GitHub](https://github.com/gvergnaud/ts-pattern#with)
    33→   **/
    34→  with<
    35→    const p extends Pattern<i>,
    36→    c,
    37→    value extends MatchedValue<i, InvertPattern<p, i>>
    38→  >(
    39→    pattern: IsNever<p> extends true
    40→      ? /**
    41→         * HACK: Using `IsNever<p>` here is a hack to
    42→         * make sure the type checker forwards
    43→         * the input type parameter to pattern
    44→         * creator functions like `P.when`, `P.not`
    45→         * `P.union` when they are passed to `.with`
    46→         * directly.
    47→         */
    48→        Pattern<i>
    49→      : p,
    50→    handler: (
    51→      selections: FindSelected<value, p>,
    52→      value: value
    53→    ) => PickReturnValue<o, c>
    54→  ): InvertPatternForExclude<p, value> extends infer excluded
    55→    ? Match<
    56→        Exclude<i, excluded>,
    57→        o,
    58→        [...handledCases, excluded],
    59→        Union<inferredOutput, c>
    60→      >
    61→    : never;
    62→
    63→  with<
    64→    const p1 extends Pattern<i>,
    65→    const p2 extends Pattern<i>,
    66→    c,
    67→    p extends p1 | p2,
    68→    value extends p extends any ? MatchedValue<i, InvertPattern<p, i>> : never
    69→  >(
    70→    p1: p1,
    71→    p2: p2,
    72→    handler: (value: value) => PickReturnValue<o, c>
    73→  ): [
    74→    InvertPatternForExclude<p1, value>,
    75→    InvertPatternForExclude<p2, value>
    76→  ] extends [infer excluded1, infer excluded2]
    77→    ? Match<
    78→        Exclude<i, excluded1 | excluded2>,
    79→        o,
    80→        [...handledCases, excluded1, excluded2],
    81→        Union<inferredOutput, c>
    82→      >
    83→    : never;
    84→
    85→  with<
    86→    const p1 extends Pattern<i>,
    87→    const p2 extends Pattern<i>,
    88→    const p3 extends Pattern<i>,
    89→    const ps extends readonly Pattern<i>[],
    90→    c,
    91→    p extends p1 | p2 | p3 | ps[number],
    92→    value extends MatchedValue<i, InvertPattern<p, i>>
    93→  >(
    94→    ...args: [
    95→      p1: p1,
    96→      p2: p2,
    97→      p3: p3,
    98→      ...patterns: ps,
    99→      handler: (value: value) => PickReturnValue<o, c>
   100→    ]
   101→  ): [
   102→    InvertPatternForExclude<p1, value>,
   103→    InvertPatternForExclude<p2, value>,
   104→    InvertPatternForExclude<p3, value>,
   105→    MakeTuples<ps, value>
   106→  ] extends [
   107→    infer excluded1,
   108→    infer excluded2,
   109→    infer excluded3,
   110→    infer excludedRest
   111→  ]
   112→    ? Match<
   113→        Exclude<
   114→          i,
   115→          | excluded1
   116→          | excluded2
   117→          | excluded3
   118→          | Extract<excludedRest, any[]>[number]
   119→        >,
   120→        o,
   121→        [
   122→          ...handledCases,
   123→          excluded1,
   124→          excluded2,
   125→          excluded3,
   126→          ...Extract<excludedRest, any[]>
   127→        ],
   128→        Union<inferredOutput, c>
   129→      >
   130→    : never;
   131→
   132→  with<
   133→    const pat extends Pattern<i>,
   134→    pred extends (value: MatchedValue<i, InvertPattern<pat, i>>) => unknown,
   135→    c,
   136→    value extends GuardValue<pred>
   137→  >(
   138→    pattern: pat,
   139→    predicate: pred,
   140→    handler: (
   141→      selections: FindSelected<value, pat>,
   142→      value: value
   143→    ) => PickReturnValue<o, c>
   144→  ): pred extends (value: any) => value is infer narrowed
   145→    ? Match<
   146→        Exclude<i, narrowed>,
   147→        o,
   148→        [...handledCases, narrowed],
   149→        Union<inferredOutput, c>
   150→      >
   151→    : Match<i, o, handledCases, Union<inferredOutput, c>>;
   152→
   153→  /**
   154→   * `.when(predicate, handler)` Registers a predicate function and an handler function.
   155→   * If the predicate returns true, the handler function will be called.
   156→   *
   157→   * [Read the documentation for `.when()` on GitHub](https://github.com/gvergnaud/ts-pattern#when)
   158→   **/
   159→  when<pred extends (value: i) => unknown, c, value extends GuardValue<pred>>(
   160→    predicate: pred,
   161→    handler: (value: value) => PickReturnValue<o, c>
   162→  ): pred extends (value: any) => value is infer narrowed
   163→    ? Match<
   164→        Exclude<i, narrowed>,
   165→        o,
   166→        [...handledCases, narrowed],
   167→        Union<inferredOutput, c>
   168→      >
   169→    : Match<i, o, handledCases, Union<inferredOutput, c>>;
   170→
   171→  /**
   172→   * `.otherwise()` takes a **default handler function** that will be
   173→   * called if no previous pattern matched your input.
   174→   *
   175→   * Equivalent to `.with(P._, () => x).exhaustive()`
   176→   *
   177→   * [Read the documentation for `.otherwise()` on GitHub](https://github.com/gvergnaud/ts-pattern#otherwise)
   178→   *
   179→   **/
   180→  otherwise<c>(
   181→    handler: (value: i) => PickReturnValue<o, c>
   182→  ): PickReturnValue<o, Union<inferredOutput, c>>;
   183→
   184→  /**
   185→   * `.exhaustive()` checks that all cases are handled, and returns the result value.
   186→   *
   187→   * If you get a `NonExhaustiveError`, it means that you aren't handling
   188→   * all cases. You should probably add another `.with(...)` clause
   189→   * to match the missing case and prevent runtime errors.
   190→   *
   191→   * [Read the documentation for `.exhaustive()` on GitHub](https://github.com/gvergnaud/ts-pattern#exhaustive)
   192→   *
   193→   */
   194→  exhaustive: DeepExcludeAll<i, handledCases> extends infer remainingCases
   195→    ? [remainingCases] extends [never]
   196→      ? Exhaustive<o, inferredOutput>
   197→      : NonExhaustiveError<remainingCases>
   198→    : never;
   199→
   200→  /**
   201→   * `.run()` return the resulting value.
   202→   *
   203→   * ⚠️ calling this function is unsafe, and may throw if no pattern matches your input.
   204→   */
   205→  run(): PickReturnValue<o, inferredOutput>;
   206→
   207→  /**
   208→   * `.returnType<T>()` Lets you specify the return type for all of your branches.
   209→   *
   210→   * [Read the documentation for `.returnType()` on GitHub](https://github.com/gvergnaud/ts-pattern#returnType)
   211→   */
   212→  returnType: [inferredOutput] extends [never]
   213→    ? <output>() => Match<i, output, handledCases>
   214→    : TSPatternError<'calling `.returnType<T>()` is only allowed directly after `match(...)`.'>;
   215→
   216→  /**
   217→   * `.narrow()` narrows the input type to exclude all cases that have previously been handled.
   218→   *
   219→   * `.narrow()` is only useful if you want to excluded cases from union types or nullable
   220→   * properties that are deeply nested. Handled cases from top level union types are excluded
   221→   * by default.
   222→   *
   223→   * [Read the documentation for `.narrow() on GitHub](https://github.com/gvergnaud/ts-pattern#narrow)
   224→   */
   225→  narrow(): Match<DeepExcludeAll<i, handledCases>, o, [], inferredOutput>;
   226→};
   245→type DeepExcludeAll<a, tupleList extends any[]> = [a] extends [never]
   246→  ? never
   247→  : tupleList extends [infer excluded, ...infer tail]
   248→  ? DeepExcludeAll<DeepExclude<a, excluded>, tail>
   249→  : a;
   251→type MakeTuples<ps extends readonly any[], value> = {
   252→  -readonly [index in keyof ps]: InvertPatternForExclude<ps[index], value>;
   253→};
   261→type Exhaustive<output, inferredOutput> = {
   262→  /**
   263→   * `.exhaustive()` checks that all cases are handled, and returns the result value.
   264→   *
   265→   * If you get a `NonExhaustiveError`, it means that you aren't handling
   266→   * all cases. You should probably add another `.with(...)` clause
   267→   * to match the missing case and prevent runtime errors.
   268→   *
   269→   * [Read the documentation for `.exhaustive()` on GitHub](https://github.com/gvergnaud/ts-pattern#exhaustive)
   270→   *
   271→   */
   272→  (): PickReturnValue<output, inferredOutput>;
   273→  /**
   274→   * `.exhaustive(fallback)` checks that all cases are handled and returns the result value.
   275→   *
   276→   * The fallback function will be called if your input value doesn't match any pattern.
   277→   * This can only happen if the value you passed to `match` has an incorrect type.
   278→   *
   279→   * If you get a `NonExhaustiveError`, it means that you aren't handling
   280→   * all cases. You should probably add another `.with(...)` clause
   281→   * to match the missing case.
   282→   *
   283→   * [Read the documentation for `.exhaustive()` on GitHub](https://github.com/gvergnaud/ts-pattern#exhaustive)
   284→   */
   285→  <otherOutput>(
   286→    handler: (unexpectedValue: unknown) => PickReturnValue<output, otherOutput>
   287→  ): PickReturnValue<output, Union<inferredOutput, otherOutput>>;
   288→};
types/Pattern.ts
     7→export type MatcherType =
     8→  | 'not'
     9→  | 'optional'
    10→  | 'or'
    11→  | 'and'
    12→  | 'array'
    13→  | 'record'
    14→  | 'map'
    15→  | 'set'
    16→  | 'select'
    17→  | 'default'
    18→  | 'custom';
    23→export type MatcherProtocol<
    24→  input,
    25→  narrowed,
    26→  // Type of what this pattern selected from the input
    27→  matcherType extends MatcherType,
    28→  selections extends SelectionType,
    29→  // Type to exclude from the input union because
    30→  // it has been fully matched by this pattern
    31→  excluded
    32→> = {
    33→  match: <I>(value: I | input) => MatchResult;
    34→  getSelectionKeys?: () => string[];
    35→  matcherType?: matcherType;
    36→};
    38→export type MatchResult = {
    39→  matched: boolean;
    40→  selections?: Record<string, any>;
    41→};
    50→export interface Matcher<
    51→  input,
    52→  narrowed,
    53→  // Type of what this pattern selected from the input
    54→  matcherType extends MatcherType = 'default',
    55→  selections extends SelectionType = None,
    56→  // Type to exclude from the input union because
    57→  // it has been fully matched by this pattern
    58→  excluded = narrowed
    59→> {
    71→type PatternMatcher<input> = Matcher<input, unknown, any, any>;
    74→export type MatchedValue<a, invpattern> = WithDefault<
    75→  ExtractPreciseValue<a, invpattern>,
    76→  a
    77→>;
    79→export type AnyMatcher = Matcher<any, any, any, any, any>;
    81→type UnknownMatcher = PatternMatcher<unknown>;
    83→export type CustomP<input, pattern, narrowedOrFn> = Matcher<
    84→  input,
    85→  pattern,
    86→  //  👆
    87→  // for the input type to be instantiated correctly
    88→  // on subpatterns, it has to be passed through.
    89→  'custom',
    90→  None,
    91→  narrowedOrFn
    92→>;
    94→export type ArrayP<input, p> = Matcher<input, p, 'array'>;
    96→export type RecordP<input, pkey, pvalue> = Matcher<
    97→  input,
    98→  [pkey, pvalue],
    99→  'record'
   100→>;
   102→export type OptionalP<input, p> = Matcher<input, p, 'optional'>;
   104→export type MapP<input, pkey, pvalue> = Matcher<input, [pkey, pvalue], 'map'>;
   106→export type SetP<input, p> = Matcher<input, p, 'set'>;
   108→export type AndP<input, ps> = Matcher<input, ps, 'and'>;
   110→export type OrP<input, ps> = Matcher<input, ps, 'or'>;
   112→export type NotP<input, p> = Matcher<input, p, 'not'>;
   114→export type GuardP<input, narrowed> = Matcher<input, narrowed>;
   116→export type GuardExcludeP<input, narrowed, excluded> = Matcher<
   117→  input,
   118→  narrowed,
   119→  'default',
   120→  None,
   121→  excluded
   122→>;
   124→export type SelectP<
   125→  key extends string,
   126→  input = unknown,
   127→  p = Matcher<unknown, unknown>
   128→> = Matcher<input, p, 'select', Some<key>>;
   130→export type AnonymousSelectP = SelectP<symbols.anonymousSelectKey>;
   132→export interface Override<a> {
   136→export type UnknownProperties = { readonly [k: PropertyKey]: unknown };
   138→export type UnknownValuePattern =
   139→  | readonly []
   140→  | readonly [unknown, ...unknown[]]
   141→  | readonly [...unknown[], unknown]
   142→  | UnknownProperties
   143→  | Primitives
   144→  | UnknownMatcher;
   157→export type Pattern<a = unknown> = unknown extends a
   158→  ? UnknownValuePattern
   159→  : KnownPattern<a>;
   161→type KnownPattern<a> = KnownPatternInternal<a>;
   163→type KnownPatternInternal<
   164→  a,
   165→  objs = Exclude<a, Primitives | Map<any, any> | Set<any> | readonly any[]>,
   166→  arrays = Extract<a, readonly any[]>,
   167→  primitives = Extract<a, Primitives>
   168→> =
   169→  | primitives
   170→  | PatternMatcher<a>
   171→  | ([objs] extends [never] ? never : ObjectPattern<Readonly<MergeUnion<objs>>>)
   172→  | ([arrays] extends [never] ? never : ArrayPattern<arrays>);
   174→type ObjectPattern<a> =
   175→  | {
   176→      readonly [k in keyof a]?: Pattern<a[k]>;
   177→    }
   178→  | never;
   180→type ArrayPattern<a> = a extends readonly (infer i)[]
   181→  ? a extends readonly [any, ...any]
   182→    ? { readonly [index in keyof a]: Pattern<a[index]> }
   183→    :
   184→        | readonly []
   185→        | readonly [Pattern<i>, ...Pattern<i>[]]
   186→        | readonly [...Pattern<i>[], Pattern<i>]
   187→  : never;
   190→export type UnknownPattern = Chainable<GuardP<unknown, unknown>, never>;
   191→export type StringPattern = StringChainable<GuardP<unknown, string>, never>;
   192→export type NumberPattern = NumberChainable<GuardP<unknown, number>, never>;
   193→export type BooleanPattern = Chainable<GuardP<unknown, boolean>, never>;
   194→export type BigIntPattern = BigIntChainable<GuardP<unknown, bigint>, never>;
   195→export type SymbolPattern = Chainable<GuardP<unknown, symbol>, never>;
   196→export type NullishPattern = Chainable<
   197→  GuardP<unknown, null | undefined>,
   198→  never
   199→>;
   201→export type NonNullablePattern = Chainable<GuardP<unknown, {}>, never>;
   203→type MergeGuards<input, guard1, guard2> = [guard1, guard2] extends [
   204→  GuardExcludeP<any, infer narrowed1, infer excluded1>,
   205→  GuardExcludeP<any, infer narrowed2, infer excluded2>
   206→]
   207→  ? GuardExcludeP<input, narrowed1 & narrowed2, excluded1 & excluded2>
   208→  : never;
   210→export type Chainable<p, omitted extends string = never> = p &
   211→  Omit<
   212→    {
   213→      /**
   214→       * `.optional()` returns a pattern which matches if the
   215→       * key is undefined or if it is defined and the previous pattern matches its value.
   216→       *
   217→       * [Read the documentation for `P.optional` on GitHub](https://github.com/gvergnaud/ts-pattern#poptional-patterns)
   218→       *
   219→       * @example
   220→       *  match(value)
   221→       *   .with({ greeting: P.string.optional() }, () => 'will match { greeting?: string}')
   222→       */
   223→      optional<input>(): Chainable<OptionalP<input, p>, omitted | 'optional'>;
   224→      /**
   225→       * `pattern.and(pattern)` returns a pattern that matches
   226→       * if the previous pattern and the next one match the input.
   227→       *
   228→       * [Read the documentation for `P.intersection` on GitHub](https://github.com/gvergnaud/ts-pattern#pintersection-patterns)
   229→       *
   230→       * @example
   231→       *  match(value)
   232→       *   .with(
   233→       *     P.string.and(P.when(isUsername)),
   234→       *     (username) => '...'
   235→       *   )
   236→       */
   237→      and<input, const p2 extends Pattern<input>>(
   238→        pattern: p2
   239→      ): Chainable<AndP<input, [p, p2]>, omitted>;
   240→      /**
   241→       * `pattern.or(pattern)` returns a pattern that matches
   242→       * if **either** the previous pattern or the next one match the input.
   243→       *
   244→       * [Read the documentation for `P.union` on GitHub](https://github.com/gvergnaud/ts-pattern#punion-patterns)
   245→       *
   246→       * @example
   247→       *  match(value)
   248→       *   .with(
   249→       *     { value: P.string.or(P.number) },
   250→       *     ({ value }) => 'value: number | string'
   251→       *   )
   252→       */
   253→      or<input, const p2 extends Pattern<input>>(
   254→        pattern: p2
   255→      ): Chainable<OrP<input, [p, p2]>, omitted>;
   256→      /**
   257→       * `P.select()` will inject this property into the handler function's arguments.
   258→       *
   259→       * [Read the documentation for `P.select` on GitHub](https://github.com/gvergnaud/ts-pattern#pselect-patterns)
   260→       *
   261→       * @example
   262→       *  match<{ age: number }>(value)
   263→       *   .with({ age: P.string.select() }, (age) => 'age: number')
   264→       */
   265→      select<input>(): Chainable<
   266→        SelectP<symbols.anonymousSelectKey, input, p>,
   267→        omitted | 'select' | 'or' | 'and'
   268→      >;
   269→      select<input, k extends string>(
   270→        key: k
   271→      ): Chainable<SelectP<k, input, p>, omitted | 'select' | 'or' | 'and'>;
   272→    },
   273→    omitted
   274→  >;
   276→export type StringChainable<
   277→  p extends Matcher<any, any, any, any, any>,
   278→  omitted extends string = never
   279→> = Chainable<p, omitted> &
   280→  Omit<
   281→    {
   282→      /**
   283→       * `P.string.startsWith(start)` is a pattern, matching **strings** starting with `start`.
   284→       *
   285→       * [Read the documentation for `P.string.startsWith` on GitHub](https://github.com/gvergnaud/ts-pattern#pstringstartsWith)
   286→       *
   287→       * @example
   288→       *  match(value)
   289→       *   .with(P.string.startsWith('A'), () => 'value starts with an A')
   290→       */
   291→      startsWith<input, const start extends string>(
   292→        start: start
   293→      ): StringChainable<
   294→        MergeGuards<input, p, GuardP<unknown, `${start}${string}`>>,
   295→        omitted | 'startsWith'
   296→      >;
   297→      /**
   298→       * `P.string.endsWith(end)` is a pattern, matching **strings** ending with `end`.
   299→       *
   300→       * [Read the documentation for `P.string.endsWith` on GitHub](https://github.com/gvergnaud/ts-pattern#pstringendsWith)
   301→       *
   302→       * @example
   303→       *  match(value)
   304→       *   .with(P.string.endsWith('!'), () => 'value ends with an !')
   305→       */
   306→      endsWith<input, const end extends string>(
   307→        end: end
   308→      ): StringChainable<
   309→        MergeGuards<input, p, GuardP<unknown, `${string}${end}`>>,
   310→        omitted | 'endsWith'
   311→      >;
   312→      /**
   313→       * `P.string.minLength(min)` is a pattern, matching **strings** with at least `min` characters.
   314→       *
   315→       * [Read the documentation for `P.string.minLength` on GitHub](https://github.com/gvergnaud/ts-pattern#pstringminLength)
   316→       *
   317→       * @example
   318→       *  match(value)
   319→       *   .with(P.string.minLength(10), () => 'string with more length <= 10')
   320→       */
   321→      minLength<input, const min extends number>(
   322→        min: min
   323→      ): StringChainable<
   324→        MergeGuards<input, p, GuardExcludeP<unknown, string, never>>,
   325→        omitted | 'minLength'
   326→      >;
   327→      /**
   328→       * `P.string.length(len)` is a pattern, matching **strings** with exactly `len` characters.
   329→       *
   330→       * [Read the documentation for `P.string.length` on GitHub](https://github.com/gvergnaud/ts-pattern#pstringlength)
   331→       *
   332→       * @example
   333→       *  match(value)
   334→       *   .with(P.string.length(10), () => 'strings with length === 10')
   335→       */
   336→      length<input, const len extends number>(
   337→        len: len
   338→      ): StringChainable<
   339→        MergeGuards<input, p, GuardExcludeP<unknown, string, never>>,
   340→        omitted | 'length' | 'minLength' | 'maxLength'
   341→      >;
   342→      /**
   343→       * `P.string.maxLength(max)` is a pattern, matching **strings** with at most `max` characters.
   344→       *
   345→       * [Read the documentation for `P.string.maxLength` on GitHub](https://github.com/gvergnaud/ts-pattern#pstringmaxLength)
   346→       *
   347→       * @example
   348→       *  match(value)
   349→       *   .with(P.string.maxLength(10), () => 'string with more length >= 10')
   350→       */
   351→      maxLength<input, const max extends number>(
   352→        max: max
   353→      ): StringChainable<
   354→        MergeGuards<input, p, GuardExcludeP<unknown, string, never>>,
   355→        omitted | 'maxLength'
   356→      >;
   357→      /**
   358→       * `P.string.includes(substr)` is a pattern, matching **strings** containing `substr`.
   359→       *
   360→       * [Read the documentation for `P.string.includes` on GitHub](https://github.com/gvergnaud/ts-pattern#pstringincludes)
   361→       *
   362→       * @example
   363→       *  match(value)
   364→       *   .with(P.string.includes('http'), () => 'value contains http')
   365→       */
   366→      includes<input, const substr extends string>(
   367→        substr: substr
   368→      ): StringChainable<
   369→        MergeGuards<input, p, GuardExcludeP<unknown, string, never>>,
   370→        omitted
   371→      >;
   372→      /**
   373→       * `P.string.regex(expr)` is a pattern, matching **strings** that `expr` regular expression.
   374→       *
   375→       * [Read the documentation for `P.string.regex` on GitHub](https://github.com/gvergnaud/ts-pattern#pstringregex)
   376→       *
   377→       * @example
   378→       *  match(value)
   379→       *   .with(P.string.regex(/^https?:\/\//), () => 'url')
   380→       */
   381→      regex<input, const expr extends string | RegExp>(
   382→        expr: expr
   383→      ): StringChainable<
   384→        MergeGuards<input, p, GuardExcludeP<unknown, string, never>>,
   385→        omitted
   386→      >;
   387→    },
   388→    omitted
   389→  >;
   391→export type NumberChainable<p, omitted extends string = never> = Chainable<
   392→  p,
   393→  omitted
   394→> &
   395→  Omit<
   396→    {
   397→      /**
   398→       * `P.number.between(min, max)` matches **number** between `min` and `max`,
   399→       * equal to min or equal to max.
   400→       *
   401→       * [Read the documentation for `P.number.between` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumberbetween)
   402→       *
   403→       * @example
   404→       *  match(value)
   405→       *   .with(P.number.between(0, 10), () => '0 <= numbers <= 10')
   406→       */
   407→      between<input, const min extends number, const max extends number>(
   408→        min: min,
   409→        max: max
   410→      ): NumberChainable<
   411→        MergeGuards<input, p, GuardExcludeP<unknown, number, never>>,
   412→        omitted
   413→      >;
   414→      /**
   415→       * `P.number.lt(max)` matches **number** smaller than `max`.
   416→       *
   417→       * [Read the documentation for `P.number.lt` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumberlt)
   418→       *
   419→       * @example
   420→       *  match(value)
   421→       *   .with(P.number.lt(10), () => 'numbers < 10')
   422→       */
   423→      lt<input, const max extends number>(
   424→        max: max
   425→      ): NumberChainable<
   426→        MergeGuards<input, p, GuardExcludeP<unknown, number, never>>,
   427→        omitted
   428→      >;
   429→      /**
   430→       * `P.number.gt(min)` matches **number** greater than `min`.
   431→       *
   432→       * [Read the documentation for `P.number.gt` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumbergt)
   433→       *
   434→       * @example
   435→       *  match(value)
   436→       *   .with(P.number.gt(10), () => 'numbers > 10')
   437→       */
   438→      gt<input, const min extends number>(
   439→        min: min
   440→      ): NumberChainable<
   441→        MergeGuards<input, p, GuardExcludeP<unknown, number, never>>,
   442→        omitted
   443→      >;
   444→      /**
   445→       * `P.number.lte(max)` matches **number** smaller than or equal to `max`.
   446→       *
   447→       * [Read the documentation for `P.number.lte` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumberlte)
   448→       *
   449→       * @example
   450→       *  match(value)
   451→       *   .with(P.number.lte(10), () => 'numbers <= 10')
   452→       */
   453→      lte<input, const max extends number>(
   454→        max: max
   455→      ): NumberChainable<
   456→        MergeGuards<input, p, GuardExcludeP<unknown, number, never>>,
   457→        omitted
   458→      >;
   459→      /**
   460→       * `P.number.gte(min)` matches **number** greater than or equal to `min`.
   461→       *
   462→       * [Read the documentation for `P.number.gte` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumbergte)
   463→       *
   464→       * @example
   465→       *  match(value)
   466→       *   .with(P.number.gte(10), () => 'numbers >= 10')
   467→       */
   468→      gte<input, const min extends number>(
   469→        min: min
   470→      ): NumberChainable<
   471→        MergeGuards<input, p, GuardExcludeP<unknown, number, never>>,
   472→        omitted
   473→      >;
   474→      /**
   475→       * `P.number.int` matches **integer** numbers.
   476→       *
   477→       * [Read the documentation for `P.number.int` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumberint)
   478→       *
   479→       * @example
   480→       *  match(value)
   481→       *   .with(P.number.int, () => 'an integer')
   482→       */
   483→      int<input>(): NumberChainable<
   484→        MergeGuards<input, p, GuardExcludeP<unknown, number, never>>,
   485→        omitted | 'int'
   486→      >;
   487→      /**
   488→       * `P.number.finite` matches **finite numbers**.
   489→       *
   490→       * [Read the documentation for `P.number.finite` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumberfinite)
   491→       *
   492→       * @example
   493→       *  match(value)
   494→       *   .with(P.number.finite, () => 'not Infinity')
   495→       */
   496→      finite<input>(): NumberChainable<
   497→        MergeGuards<input, p, GuardExcludeP<unknown, number, never>>,
   498→        omitted | 'finite'
   499→      >;
   500→      /**
   501→       * `P.number.positive` matches **positive** numbers.
   502→       *
   503→       * [Read the documentation for `P.number.positive` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumberpositive)
   504→       *
   505→       * @example
   506→       *  match(value)
   507→       *   .with(P.number.positive, () => 'number > 0')
   508→       */
   509→      positive<input>(): NumberChainable<
   510→        MergeGuards<input, p, GuardExcludeP<unknown, number, never>>,
   511→        omitted | 'positive' | 'negative'
   512→      >;
   513→      /**
   514→       * `P.number.negative` matches **negative** numbers.
   515→       *
   516→       * [Read the documentation for `P.number.negative` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumbernegative)
   517→       *
   518→       * @example
   519→       *  match(value)
   520→       *   .with(P.number.negative, () => 'number < 0')
   521→       */
   522→      negative<input>(): NumberChainable<
   523→        MergeGuards<input, p, GuardExcludeP<unknown, number, never>>,
   524→        omitted | 'positive' | 'negative' | 'negative'
   525→      >;
   526→    },
   527→    omitted
   528→  >;
   530→export type BigIntChainable<p, omitted extends string = never> = Chainable<
   531→  p,
   532→  omitted
   533→> &
   534→  Omit<
   535→    {
   536→      /**
   537→       * `P.bigint.between(min, max)` matches **bigint** between `min` and `max`,
   538→       * equal to min or equal to max.
   539→       *
   540→       * [Read the documentation for `P.bigint.between` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumberbetween)
   541→       *
   542→       * @example
   543→       *  match(value)
   544→       *   .with(P.bigint.between(0, 10), () => '0 <= numbers <= 10')
   545→       */
   546→      between<input, const min extends bigint, const max extends bigint>(
   547→        min: min,
   548→        max: max
   549→      ): BigIntChainable<
   550→        MergeGuards<input, p, GuardExcludeP<unknown, bigint, never>>,
   551→        omitted
   552→      >;
   553→      /**
   554→       * `P.bigint.lt(max)` matches **bigint** smaller than `max`.
   555→       *
   556→       * [Read the documentation for `P.bigint.lt` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumberlt)
   557→       *
   558→       * @example
   559→       *  match(value)
   560→       *   .with(P.bigint.lt(10), () => 'numbers < 10')
   561→       */
   562→      lt<input, const max extends bigint>(
   563→        max: max
   564→      ): BigIntChainable<
   565→        MergeGuards<input, p, GuardExcludeP<unknown, bigint, never>>,
   566→        omitted
   567→      >;
   568→      /**
   569→       * `P.bigint.gt(min)` matches **bigint** greater than `min`.
   570→       *
   571→       * [Read the documentation for `P.bigint.gt` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumbergt)
   572→       *
   573→       * @example
   574→       *  match(value)
   575→       *   .with(P.bigint.gt(10), () => 'numbers > 10')
   576→       */
   577→      gt<input, const min extends bigint>(
   578→        min: min
   579→      ): BigIntChainable<
   580→        MergeGuards<input, p, GuardExcludeP<unknown, bigint, never>>,
   581→        omitted
   582→      >;
   583→      /**
   584→       * `P.bigint.lte(max)` matches **bigint** smaller than or equal to `max`.
   585→       *
   586→       * [Read the documentation for `P.bigint.lte` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumberlte)
   587→       *
   588→       * @example
   589→       *  match(value)
   590→       *   .with(P.bigint.lte(10), () => 'bigints <= 10')
   591→       */
   592→      lte<input, const max extends bigint>(
   593→        max: max
   594→      ): BigIntChainable<
   595→        MergeGuards<input, p, GuardExcludeP<unknown, bigint, never>>,
   596→        omitted
   597→      >;
   598→      /**
   599→       * `P.bigint.gte(min)` matches **bigint** greater than or equal to `min`.
   600→       *
   601→       * [Read the documentation for `P.bigint.gte` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumbergte)
   602→       *
   603→       * @example
   604→       *  match(value)
   605→       *   .with(P.bigint.gte(10), () => 'bigints >= 10')
   606→       */
   607→      gte<input, const min extends bigint>(
   608→        min: min
   609→      ): BigIntChainable<
   610→        MergeGuards<input, p, GuardExcludeP<unknown, bigint, never>>,
   611→        omitted
   612→      >;
   613→      /**
   614→       * `P.bigint.positive` matches **positive** bigints.
   615→       *
   616→       * [Read the documentation for `P.bigint.positive` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumberpositive)
   617→       *
   618→       * @example
   619→       *  match(value)
   620→       *   .with(P.bigint.positive, () => 'bigint > 0')
   621→       */
   622→      positive<input>(): BigIntChainable<
   623→        MergeGuards<input, p, GuardExcludeP<unknown, bigint, never>>,
   624→        omitted | 'positive' | 'negative'
   625→      >;
   626→      /**
   627→       * `P.bigint.negative` matches **negative** bigints.
   628→       *
   629→       * [Read the documentation for `P.bigint.negative` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumbernegative)
   630→       *
   631→       * @example
   632→       *  match(value)
   633→       *   .with(P.bigint.negative, () => 'bigint < 0')
   634→       */
   635→      negative<input>(): BigIntChainable<
   636→        MergeGuards<input, p, GuardExcludeP<unknown, bigint, never>>,
   637→        omitted | 'positive' | 'negative' | 'negative'
   638→      >;
   639→    },
   640→    omitted
   641→  >;
   643→export type Variadic<pattern> = pattern & Iterable<pattern>;
   645→export type ArrayChainable<
   646→  pattern,
   647→  omitted extends string = never
   648→> = Variadic<pattern> &
   649→  Omit<
   650→    {
   651→      /**
   652→       * `.optional()` returns a pattern which matches if the
   653→       * key is undefined or if it is defined and the previous pattern matches its value.
   654→       *
   655→       * [Read the documentation for `P.optional` on GitHub](https://github.com/gvergnaud/ts-pattern#poptional-patterns)
   656→       *
   657→       * @example
   658→       *  match(value)
   659→       *   .with({ greeting: P.string.optional() }, () => 'will match { greeting?: string}')
   660→       */
   661→      optional<input>(): ArrayChainable<
   662→        OptionalP<input, pattern>,
   663→        omitted | 'optional'
   664→      >;
   665→      /**
   666→       * `P.select()` will inject this property into the handler function's arguments.
   667→       *
   668→       * [Read the documentation for `P.select` on GitHub](https://github.com/gvergnaud/ts-pattern#pselect-patterns)
   669→       *
   670→       * @example
   671→       *  match<{ age: number }>(value)
   672→       *   .with({ age: P.string.select() }, (age) => 'age: number')
   673→       */
   674→      select<input>(): ArrayChainable<
   675→        SelectP<symbols.anonymousSelectKey, input, pattern>,
   676→        omitted | 'select'
   677→      >;
   678→      select<input, k extends string>(
   679→        key: k
   680→      ): ArrayChainable<SelectP<k, input, pattern>, omitted | 'select'>;
   681→    },
   682→    omitted
   683→  >;
types/helpers.ts
     1→export type ValueOf<a> = a extends readonly any[] ? a[number] : a[keyof a];
     3→export type Values<a extends object> = UnionToTuple<ValueOf<a>>;
    14→export type LeastUpperBound<a, b> = b extends a ? b : a extends b ? a : never;
    16→export type Contains<a, b> = a extends any
    17→  ? 'exclude' extends {
    18→      [k in keyof a]-?: Equal<a[k], b> extends true ? 'exclude' : 'include';
    19→    }[keyof a]
    20→    ? true
    21→    : false
    22→  : never;
    25→export type UnionToIntersection<union> = (
    26→  union extends any ? (k: union) => void : never
    27→) extends (k: infer intersection) => void
    28→  ? intersection
    29→  : never;
    31→export type IsUnion<a> = [a] extends [UnionToIntersection<a>] ? false : true;
    33→export type UnionToTuple<
    34→  union,
    35→  output extends any[] = []
    36→> = UnionToIntersection<
    37→  union extends any ? (t: union) => union : never
    38→> extends (_: any) => infer elem
    39→  ? UnionToTuple<Exclude<union, elem>, [elem, ...output]>
    40→  : output;
    42→export type Flatten<
    43→  xs extends readonly any[],
    44→  output extends any[] = []
    45→> = xs extends readonly [infer head, ...infer tail]
    46→  ? Flatten<tail, [...output, ...Extract<head, readonly any[]>]>
    47→  : output;
    49→export type Equal<a, b> = (<T>() => T extends a ? 1 : 2) extends <
    50→  T
    51→>() => T extends b ? 1 : 2
    52→  ? true
    53→  : false;
    55→export type Expect<a extends true> = a;
    57→export type IsAny<a> = 0 extends 1 & a ? true : false;
    59→export type IsNever<T> = [T] extends [never] ? true : false;
    61→export type Length<it extends readonly any[]> = it['length'];
    63→export type Iterator<
    64→  n extends number,
    65→  it extends any[] = []
    66→> = it['length'] extends n ? it : Iterator<n, [any, ...it]>;
    68→export type Next<it extends any[]> = [any, ...it];
    69→export type Prev<it extends any[]> = it extends readonly [any, ...infer tail]
    70→  ? tail
    71→  : [];
    73→export type Take<
    74→  xs extends readonly any[],
    75→  it extends any[],
    76→  output extends any[] = []
    77→> = Length<it> extends 0
    78→  ? output
    79→  : xs extends readonly [infer head, ...infer tail]
    80→  ? Take<tail, Prev<it>, [...output, head]>
    81→  : output;
    83→export type Drop<
    84→  xs extends readonly any[],
    85→  n extends any[]
    86→> = Length<n> extends 0
    87→  ? xs
    88→  : xs extends readonly [any, ...infer tail]
    89→  ? Drop<tail, Prev<n>>
    90→  : [];
    92→export type UpdateAt<
    93→  tail extends readonly any[],
    94→  n extends any[],
    95→  value,
    96→  inits extends readonly any[] = []
    97→> = Length<n> extends 0
    98→  ? tail extends readonly [any, ...infer tail]
    99→    ? [...inits, value, ...tail]
   100→    : inits
   101→  : tail extends readonly [infer head, ...infer tail]
   102→  ? UpdateAt<tail, Prev<n>, value, [...inits, head]>
   103→  : inits;
   105→export type BuiltInObjects =
   106→  | Function
   107→  | Date
   108→  | RegExp
   109→  | Generator
   110→  | { readonly [Symbol.toStringTag]: string }
   111→  | any[];
   113→export type IsPlainObject<o, excludeUnion = BuiltInObjects> = o extends object
   114→  ? // to excluded branded string types,
   115→    // like `string & { __brand: "id" }`
   116→    // and built-in objects
   117→    o extends string | excludeUnion
   118→    ? false
   119→    : true
   120→  : false;
   122→export type Compute<a extends any> = a extends BuiltInObjects
   123→  ? a
   124→  : { [k in keyof a]: a[k] };
   126→export type IntersectObjects<a> = (
   127→  a extends any ? keyof a : never
   128→) extends infer allKeys
   129→  ? {
   130→      [k in Extract<allKeys, PropertyKey>]: a extends any
   131→        ? k extends keyof a
   132→          ? a[k]
   133→          : never
   134→        : never;
   135→    }
   136→  : never;
   138→export type WithDefault<a, def> = [a] extends [never] ? def : a;
   140→export type IsLiteral<a> = [a] extends [null | undefined]
   141→  ? true
   142→  : [a] extends [string]
   143→  ? string extends a
   144→    ? false
   145→    : true
   146→  : [a] extends [number]
   147→  ? number extends a
   148→    ? false
   149→    : true
   150→  : [a] extends [boolean]
   151→  ? boolean extends a
   152→    ? false
   153→    : true
   154→  : [a] extends [symbol]
   155→  ? symbol extends a
   156→    ? false
   157→    : true
   158→  : [a] extends [bigint]
   159→  ? bigint extends a
   160→    ? false
   161→    : true
   162→  : false;
   164→export type Primitives =
   165→  | number
   166→  | boolean
   167→  | string
   168→  | undefined
   169→  | null
   170→  | symbol
   171→  | bigint;
   173→export type NonLiteralPrimitive = Exclude<Primitives, undefined | null>;
   175→export type TupleKeys = '0' | '1' | '2' | '3' | '4';
   177→export type Union<a, b> = [b] extends [a] ? a : [a] extends [b] ? b : a | b;
   182→export type GuardValue<fn> = fn extends (value: any) => value is infer b
   183→  ? b
   184→  : fn extends (value: infer a) => unknown
   185→  ? a
   186→  : never;
   188→export type GuardFunction<input, narrowed> =
   189→  | ((value: input) => value is Extract<narrowed, input>)
   190→  | ((value: input) => boolean);
   192→export type Some<bools extends boolean[]> = true extends bools[number]
   193→  ? true
   194→  : false;
   196→export type All<bools extends boolean[]> = bools[number] extends true
   197→  ? true
   198→  : false;
   200→export type Extends<a, b> = [a] extends [b] ? true : false;
   202→export type Not<a extends boolean> = a extends true ? false : true;
   204→type AllKeys<a> = a extends any ? keyof a : never;
   207→export type MergeUnion<a> =
   208→  | {
   209→      [k in AllKeys<a>]: a extends any
   210→        ? k extends keyof a
   211→          ? a[k]
   212→          : never
   213→        : never;
   214→    }
   215→  | never;
   217→export type IsFixedSizeTuple<a extends readonly any[]> = IsLiteral<Length<a>>;
   220→export type IsTuple<a> = a extends
   221→  | readonly []
   222→  | readonly [any, ...any]
   223→  | readonly [...any, any]
   224→  ? true
   225→  : false;
   227→export type IsStrictArray<a extends readonly any[]> = Not<IsTuple<a>>;
   229→export type IsReadonlyArray<a> = a extends readonly any[]
   230→  ? a extends any[] // mutable array
   231→    ? false
   232→    : true
   233→  : false;
   235→export type MaybeAddReadonly<
   236→  a,
   237→  shouldAdd extends boolean
   238→> = shouldAdd extends true ? Readonly<a> : a;
   240→export type MapKey<T> = T extends Map<infer K, any> ? K : never;
   242→export type MapValue<T> = T extends Map<any, infer V> ? V : never;
   244→export type SetValue<T> = T extends Set<infer V> ? V : never;
   246→export type RecordKey<T> = T extends Record<infer K, any> ? K : never;
   248→export type RecordValue<T> = T extends Record<any, infer V> ? V : never;
   250→export type ReadonlyArrayValue<T> = T extends ReadonlyArray<infer V>
   251→  ? V
   252→  : never;
   254→export type ExtractPlainObject<T> = T extends any

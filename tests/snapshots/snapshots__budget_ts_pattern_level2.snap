    91→    ? a extends readonly [infer a1, ...infer aRest]
    92→      ? ExtractPreciseValue<a1, b1> extends infer currentValue
    93→        ? [currentValue] extends [never]
    94→          ? never
    95→          : ExtractPreciseArrayValue<
    96→              aRest,
    97→              bRest,
    98→              isReadonly,
    99→              [...startOutput, currentValue],
   100→              endOutput
   101→            >
   102→        : never
   103→      : ExtractPreciseValue<aItem, b1> extends infer currentValue
   104→      ? [currentValue] extends [never]
   105→        ? never
   106→        : ExtractPreciseArrayValue<
   107→            aItem[],
   108→            bRest,
   109→            isReadonly,
   110→            [...startOutput, currentValue],
   111→            endOutput
   112→          >
   113→      : never
   114→    : b extends readonly [...infer bInit, infer b1]
   115→    ? a extends readonly [...infer aInit, infer a1]
   116→      ? ExtractPreciseValue<a1, b1> extends infer currentValue
   117→        ? [currentValue] extends [never]
   118→          ? never
   119→          : ExtractPreciseArrayValue<
   120→              aInit,
   121→              bInit,
   122→              isReadonly,
   123→              startOutput,
   124→              [...endOutput, currentValue]
   125→            >
   126→        : never
   127→      : ExtractPreciseValue<aItem, b1> extends infer currentValue
   128→      ? [currentValue] extends [never]
   129→        ? never
   130→        : ExtractPreciseArrayValue<
   131→            aItem[],
   132→            bInit,
   133→            isReadonly,
   134→            startOutput,
   135→            [...endOutput, currentValue]
   136→          >
   137→      : never
   138→    : ExtractPreciseValue<aItem, ValueOf<b>> extends infer currentValue
   139→    ? [currentValue] extends [never]
   140→      ? never
   141→      : MaybeAddReadonly<
   142→          [...startOutput, ...currentValue[], ...endOutput],
   143→          isReadonly
   144→        >
   145→    : never
   146→  : LeastUpperBound<a, b>;
types/FindSelected.ts
    11→type SelectionsRecord = Record<string, [unknown, unknown[]]>;
    13→export type None = {
    14→  type: 'none';
    15→};
    16→export type Some<key extends string> = {
    17→  type: 'some';
    18→  key: key;
    19→};
    21→export type SelectionType = None | Some<string>;
    24→type MapOptional<selections> = {
    25→  [k in keyof selections]: selections[k] extends [infer v, infer subpath]
    26→    ? [v | undefined, subpath]
    27→    : never;
    28→};
    31→type MapList<selections> = {
    32→  [k in keyof selections]: selections[k] extends [infer v, infer subpath]
    33→    ? [v[], subpath]
    34→    : never;
    35→};
    38→type ReduceFindSelectionUnion<
    39→  i,
    40→  ps extends readonly any[],
    41→  output = never
    42→> = ps extends readonly [infer head, ...infer tail]
    43→  ? ReduceFindSelectionUnion<i, tail, output | FindSelectionUnion<i, head>>
    44→  : output;
    47→type FindSelectionUnionInArray<
    48→  i,
    49→  p,
    50→  path extends any[] = [],
    51→  output = never
    52→> = i extends readonly (infer iItem)[]
    53→  ? p extends readonly []
    54→    ? output
    55→    : p extends readonly [infer p1, ...infer pRest]
    56→    ? i extends readonly [infer i1, ...infer iRest]
    57→      ? FindSelectionUnionInArray<
    58→          iRest,
    59→          pRest,
    60→          [...path, p['length']],
    61→          output | FindSelectionUnion<i1, p1, [...path, p['length']]>
    62→        >
    63→      : FindSelectionUnionInArray<
    64→          iItem[],
    65→          pRest,
    66→          [...path, p['length']],
    67→          output | FindSelectionUnion<iItem, p1, [...path, p['length']]>
    68→        >
    69→    : p extends readonly [...infer pInit, infer p1]
    70→    ? i extends readonly [...infer iInit, infer i1]
    71→      ? FindSelectionUnionInArray<
    72→          iInit,
    73→          pInit,
    74→          [...path, p['length']],
    75→          output | FindSelectionUnion<i1, p1, [...path, p['length']]>
    76→        >
    77→      : FindSelectionUnionInArray<
    78→          iItem[],
    79→          pInit,
    80→          [...path, p['length']],
    81→          output | FindSelectionUnion<iItem, p1, [...path, p['length']]>
    82→        >
    83→    : // If P is a matcher, in this case, it's likely an array matcher
    84→    p extends readonly [...(readonly (infer pRest & AnyMatcher)[])]
    85→    ? output | FindSelectionUnion<i, pRest, [...path, p['length']]>
    86→    :
    87→        | output
    88→        | FindSelectionUnion<
    89→            iItem,
    90→            ValueOf<p>,
    91→            [...path, Extract<p, readonly any[]>['length']]
    92→          >
    93→  : output;
    96→export type FindSelectionUnion<
    97→  i,
    98→  p,
    99→  // path just serves as an id, to identify different anonymous patterns which have the same type
   100→  path extends any[] = []
   101→  // inlining IsAny for perf
   102→> = 0 extends 1 & i
   103→  ? never
   104→  : // inlining IsAny for perf
   105→  0 extends 1 & p
   106→  ? never
   107→  : p extends Primitives
   108→  ? never
   109→  : p extends Matcher<any, infer pattern, infer matcherType, infer sel>
   110→  ? {
   111→      select: sel extends Some<infer k>
   112→        ? { [kk in k]: [i, path] } | FindSelectionUnion<i, pattern, path>
   113→        : never;
   114→      // selection of arrays, records, maps, and sets are arrays,
   115→      // because the selection function is being mapped on their values
   116→      array: i extends readonly (infer iItem)[]
   117→        ? MapList<FindSelectionUnion<iItem, pattern>>
   118→        : never;
   119→      record: [i, pattern] extends [
   120→        Record<infer k, infer v>,
   121→        [infer pkey, infer pvalue]
   122→      ]
   123→        ?
   124→            | MapList<FindSelectionUnion<k, pkey, path>>
   125→            | MapList<FindSelectionUnion<v, pvalue, path>>
   126→        : never;
   127→      map: [i, pattern] extends [
   128→        Map<infer k, infer v>,
   129→        [infer pkey, infer pvalue]
   130→      ]
   131→        ?
   132→            | MapList<FindSelectionUnion<k, pkey, path>>
   133→            | MapList<FindSelectionUnion<v, pvalue, path>>
   134→        : never;
   135→      set: i extends Set<infer v>
   136→        ? MapList<FindSelectionUnion<v, pattern, path>>
   137→        : never;
   138→      optional: MapOptional<FindSelectionUnion<i, pattern>>;
   139→      or: MapOptional<
   140→        ReduceFindSelectionUnion<i, Extract<pattern, readonly any[]>>
   141→      >;
   142→      and: ReduceFindSelectionUnion<i, Extract<pattern, readonly any[]>>;
   143→      not: never;
   144→      default: sel extends Some<infer k> ? { [kk in k]: [i, path] } : never;
   145→      custom: never;
   146→    }[matcherType]
   147→  : p extends readonly any[]
   148→  ? FindSelectionUnionInArray<i, p>
   149→  : p extends {}
   150→  ? i extends {}
   151→    ? {
   152→        [k in keyof p]: k extends keyof i
   153→          ? FindSelectionUnion<i[k], p[k], [...path, k]>
   154→          : never;
   155→      }[keyof p]
   156→    : never
   157→  : never;
   159→export type SeveralAnonymousSelectError<
   160→  a = 'You can only use a single anonymous selection (with `select()`) in your pattern. If you need to select multiple values, give them names with `select(<name>)` instead'
   161→> = {
   162→  __error: never;
   163→} & a;
   165→export type MixedNamedAndAnonymousSelectError<
   166→  a = 'Mixing named selections (`select("name")`) and anonymous selections (`select()`) is forbiden. Please, only use named selections.'
   167→> = {
   168→  __error: never;
   169→} & a;
   174→export type SelectionToArgs<selections extends SelectionsRecord> =
   175→  symbols.anonymousSelectKey extends keyof selections
   176→    ? // if there are several different paths for anonymous selections
   177→      // it means that P.select() has been used more than once.
   178→      IsUnion<selections[symbols.anonymousSelectKey][1]> extends true
   179→      ? SeveralAnonymousSelectError
   180→      : keyof selections extends symbols.anonymousSelectKey
   181→      ? selections[symbols.anonymousSelectKey][0]
   182→      : MixedNamedAndAnonymousSelectError
   183→    : { [k in keyof selections]: selections[k][0] };
   185→export type Selections<i, p> = FindSelectionUnion<i, p> extends infer u
   186→  ? [u] extends [never]
   187→    ? i
   188→    : SelectionToArgs<Extract<MergeUnion<u>, SelectionsRecord>>
   189→  : i;
   191→export type FindSelected<i, p> =
   192→  // This happens if the provided pattern didn't extend Pattern<i>,
   193→  // Because the type checker falls back on the general `Pattern<i>` type
   194→  // in this case.
   195→  Equal<p, Pattern<i>> extends true ? i : Selections<i, p>;
types/InvertPattern.ts
    29→type OptionalKeys<p> = ValueOf<{
    30→  [k in keyof p]: 0 extends 1 & p[k] // inlining IsAny for perf
    31→    ? never
    32→    : p[k] extends Matcher<any, any, infer matcherType>
    33→    ? matcherType extends 'optional'
    34→      ? k
    35→      : never
    36→    : never;
    37→}>;
    39→type ReduceUnion<
    40→  tuple extends readonly any[],
    41→  i,
    42→  output = never
    43→> = tuple extends readonly [infer p, ...infer tail]
    44→  ? ReduceUnion<tail, i, output | InvertPatternInternal<p, i>>
    45→  : output;
    47→type ReduceIntersection<
    48→  tuple extends readonly any[],
    49→  i,
    50→  output = unknown
    51→> = tuple extends readonly [infer p, ...infer tail]
    52→  ? ReduceIntersection<tail, i, output & InvertPatternInternal<p, i>>
    53→  : output;
    55→type InvertArrayPattern<
    56→  p,
    57→  i,
    58→  startOutput extends any[] = [],
    59→  endOutput extends any[] = []
    60→> = i extends readonly (infer ii)[]
    61→  ? p extends readonly []
    62→    ? [...startOutput, ...endOutput]
    63→    : p extends readonly [infer p1, ...infer pRest]
    64→    ? i extends readonly [infer i1, ...infer iRest]
    65→      ? InvertArrayPattern<
    66→          pRest,
    67→          iRest,
    68→          [...startOutput, InvertPatternInternal<p1, i1>],
    69→          endOutput
    70→        >
    71→      : InvertArrayPattern<
    72→          pRest,
    73→          ii[],
    74→          [...startOutput, InvertPatternInternal<p1, ii>],
    75→          endOutput
    76→        >
    77→    : p extends readonly [...infer pInit, infer p1]
    78→    ? i extends readonly [...infer iInit, infer i1]
    79→      ? InvertArrayPattern<
    80→          pInit,
    81→          iInit,
    82→          startOutput,
    83→          [...endOutput, InvertPatternInternal<p1, i1>]
    84→        >
    85→      : InvertArrayPattern<
    86→          pInit,
    87→          ii[],
    88→          startOutput,
    89→          [...endOutput, InvertPatternInternal<p1, ii>]
    90→        >
    91→    : // If P is a matcher, in this case, it's likely an array matcher
    92→    p extends readonly [...(readonly (infer pRest & AnyMatcher)[])]
    93→    ? [
    94→        ...startOutput,
    95→        ...Extract<InvertPatternInternal<pRest, i>, readonly any[]>,
    96→        ...endOutput
    97→      ]
    98→    : [...startOutput, ...InvertPatternInternal<ValueOf<p>, ii>[], ...endOutput]
    99→  : never;
   102→ * ### InvertPatternInternal
   106→export type InvertPattern<p, input> = Equal<Pattern<input>, p> extends true
   107→  ? never
   108→  : InvertPatternInternal<p, input>;
   110→type InvertPatternInternal<p, input> = 0 extends 1 & p
   111→  ? never
   112→  : p extends Matcher<
   113→      infer _input,
   114→      infer subpattern,
   115→      infer matcherType,
   116→      any,
   117→      infer narrowedOrFn
   118→    >
   119→  ? {
   120→      not: DeepExclude<input, InvertPatternInternal<subpattern, input>>;
   121→      select: InvertPatternInternal<subpattern, input>;
   122→      array: InvertPatternInternal<subpattern, ReadonlyArrayValue<input>>[];
   123→      record: subpattern extends [infer pk, infer pv]
   124→        ? Record<
   125→            Extract<InvertPatternInternal<pk, RecordKey<input>>, PropertyKey>,
   126→            InvertPatternInternal<pv, RecordValue<input>>
   127→          >
   128→        : never;
   129→      map: subpattern extends [infer pk, infer pv]
   130→        ? Map<
   131→            InvertPatternInternal<pk, MapKey<Extract<input, Map<any, any>>>>,
   132→            InvertPatternInternal<pv, MapValue<Extract<input, Map<any, any>>>>
   133→          >
   134→        : never;
   135→      set: Set<
   136→        InvertPatternInternal<subpattern, SetValue<Extract<input, Set<any>>>>
   137→      >;
   138→      optional:
   139→        | InvertPatternInternal<subpattern, Exclude<input, undefined>>
   140→        | undefined;
   141→      and: ReduceIntersection<Extract<subpattern, readonly any[]>, input>;
   142→      or: ReduceUnion<Extract<subpattern, readonly any[]>, input>;
   143→      default: [subpattern] extends [never] ? input : subpattern;
   144→      custom: Override<
   145→        narrowedOrFn extends Fn ? Call<narrowedOrFn, input> : narrowedOrFn
   146→      >;
   147→    }[matcherType]
   148→  : p extends Primitives
   149→  ? p
   150→  : p extends readonly any[]
   151→  ? InvertArrayPattern<
   152→      p,
   153→      WithDefault<Extract<input, readonly any[]>, unknown[]>
   154→    >
   155→  : IsPlainObject<p> extends true
   156→  ? OptionalKeys<p> extends infer optKeys
   157→    ? [optKeys] extends [never]
   158→      ? {
   159→          [k in Exclude<keyof p, optKeys>]: InvertPatternInternal<
   160→            p[k],
   161→            WithDefault<GetKey<ExtractPlainObject<input>, k>, unknown>
   162→          >;
   163→        }
   164→      : Compute<
   165→          {
   166→            [k in Exclude<keyof p, optKeys>]: InvertPatternInternal<
   167→              p[k],
   168→              WithDefault<GetKey<ExtractPlainObject<input>, k>, unknown>
   169→            >;
   170→          } & {
   171→            [k in Extract<optKeys, keyof p>]?: InvertPatternInternal<
   172→              p[k],
   173→              WithDefault<GetKey<ExtractPlainObject<input>, k>, unknown>
   174→            >;
   175→          }
   176→        >
   177→    : never
   178→  : p;
   180→export type ReduceIntersectionForExclude<
   181→  tuple extends readonly any[],
   182→  i,
   183→  output = unknown
   184→> = tuple extends readonly [infer p, ...infer tail]
   185→  ? ReduceIntersectionForExclude<
   186→      tail,
   187→      i,
   188→      output & InvertPatternForExcludeInternal<p, i, unknown>
   189→    >
   190→  : output;
   192→export type ReduceUnionForExclude<
   193→  tuple extends readonly any[],
   194→  i,
   195→  output = never
   196→> = tuple extends readonly [infer p, ...infer tail]
   197→  ? ReduceUnionForExclude<
   198→      tail,
   199→      i,
   200→      output | InvertPatternForExcludeInternal<p, i, never>
   201→    >
   202→  : output;
   204→type ExcludeIfExists<a, b> =
   205→  // If b is of type never, it probably means that P.not
   206→  // was called with a `P.when` that wasn't a type guard function.
   207→  // in this case we do not exclude
   208→  [b] extends [never]
   209→    ? never
   210→    : // If a is unknown, we can't exclude
   211→    // (Unless negative types are added in the future)
   212→    unknown extends a
   213→    ? never
   214→    : All<
   215→        [
   216→          // if `a` is one of the non-literal primitive
   217→          Extends<a, NonLiteralPrimitive>,
   218→          Not<IsLiteral<a>>,
   219→          // and b is a literal
   220→          IsLiteral<b>
   221→        ]
   222→      > extends true
   223→    ? // we shouldn't exclude because this will result in
   224→      // excluding the whole primitive type even though only
   225→      // one value has been handled by this pattern.
   226→      // In other words `P.not(10)` on a `number` input shouldn't
   227→      // exclude `number`.
   228→      never
   229→    : DeepExclude<a, b>;
   231→type InvertArrayPatternForExclude<
   232→  p,
   233→  i,
   234→  empty,
   235→  isReadonly extends boolean,
   236→  startOutput extends any[] = [],
   237→  endOutput extends any[] = []
   238→> = i extends readonly (infer ii)[]
   239→  ? p extends readonly []
   240→    ? MaybeAddReadonly<[...startOutput, ...endOutput], isReadonly>
   241→    : p extends readonly [infer p1, ...infer pRest]
   242→    ? i extends readonly [infer i1, ...infer iRest]
   243→      ? InvertArrayPatternForExclude<
   244→          pRest,
   245→          iRest,
   246→          empty,
   247→          isReadonly,
   248→          [...startOutput, InvertPatternForExcludeInternal<p1, i1, empty>],
   249→          endOutput
   250→        >
   251→      : InvertArrayPatternForExclude<
   252→          pRest,
   253→          ii[],
   254→          empty,
   255→          isReadonly,
   256→          [...startOutput, InvertPatternForExcludeInternal<p1, ii, empty>],
   257→          endOutput
   258→        >
   259→    : p extends readonly [...infer pInit, infer p1]
   260→    ? i extends readonly [...infer iInit, infer i1]
   261→      ? InvertArrayPatternForExclude<
   262→          pInit,
   263→          iInit,
   264→          empty,
   265→          isReadonly,
   266→          startOutput,
   267→          [...endOutput, InvertPatternForExcludeInternal<p1, i1, empty>]
   268→        >
   269→      : InvertArrayPatternForExclude<
   270→          pInit,
   271→          ii[],
   272→          empty,
   273→          isReadonly,
   274→          startOutput,
   275→          [...endOutput, InvertPatternForExcludeInternal<p1, ii, empty>]
   276→        >
   277→    : // If P is a matcher, in this case, it's likely an array matcher
   278→    p extends readonly [...(readonly (infer pRest & AnyMatcher)[])]
   279→    ? MaybeAddReadonly<
   280→        [
   281→          ...startOutput,
   282→          ...Extract<
   283→            InvertPatternForExcludeInternal<pRest, i, empty>,
   284→            readonly any[]
   285→          >,
   286→          ...endOutput
   287→        ],
   288→        isReadonly
   289→      >
   290→    : MaybeAddReadonly<
   291→        [
   292→          ...startOutput,
   293→          ...InvertPatternForExcludeInternal<ValueOf<p>, ii, empty>[],
   294→          ...endOutput
   295→        ],
   296→        isReadonly
   297→      >
   298→  : empty;
   301→ * ### InvertPatternForExclude
   303→export type InvertPatternForExclude<p, i> = Equal<Pattern<i>, p> extends true
   304→  ? never
   305→  : InvertPatternForExcludeInternal<p, i>;
   307→type InvertPatternForExcludeInternal<p, i, empty = never> =
   308→  // We need to prevent distribution because the boolean
   309→  // type is a union of literal as well as a Primitive type
   310→  // and it will end up being a false positif if we distribute it.
   311→  unknown extends p
   312→    ? i
   313→    : [p] extends [Primitives]
   314→    ? IsLiteral<p> extends true
   315→      ? p
   316→      : IsLiteral<i> extends true
   317→      ? p
   318→      : empty
   319→    : p extends Matcher<
   320→        infer matchableInput,
   321→        infer subpattern,
   322→        infer matcherType,
   323→        any,
   324→        infer excluded
   325→      >
   326→    ? {
   327→        select: InvertPatternForExcludeInternal<subpattern, i, empty>;
   328→        array: i extends readonly (infer ii)[]
   329→          ? MaybeAddReadonly<
   330→              InvertPatternForExcludeInternal<subpattern, ii, empty>[],
   331→              IsReadonlyArray<i>
   332→            >
   333→          : empty;
   334→        record: subpattern extends [infer pk, infer pv]
   335→          ? Record<
   336→              Extract<
   337→                InvertPatternForExcludeInternal<pk, RecordKey<i>, empty>,
   338→                PropertyKey
   339→              >,
   340→              InvertPatternForExcludeInternal<pv, RecordValue<i>, empty>
   341→            >
   342→          : empty;
   343→        map: subpattern extends [infer pk, infer pv]
   344→          ? i extends Map<infer ik, infer iv>
   345→            ? Map<
   346→                InvertPatternForExcludeInternal<pk, ik, empty>,
   347→                InvertPatternForExcludeInternal<pv, iv, empty>
   348→              >
   349→            : empty
   350→          : empty;
   351→        set: i extends Set<infer iv>
   352→          ? Set<InvertPatternForExcludeInternal<subpattern, iv, empty>>
   353→          : empty;
   354→        optional:
   355→          | InvertPatternForExcludeInternal<subpattern, i, empty>
   356→          | undefined;
   357→        and: ReduceIntersectionForExclude<
   358→          Extract<subpattern, readonly any[]>,
   359→          i
   360→        >;
   361→        or: ReduceUnionForExclude<Extract<subpattern, readonly any[]>, i>;
   362→        not: ExcludeIfExists<
   363→          // we use matchableInput if possible because it represent the
   364→          // union of all possible value, but i is only one of these values.
   365→          unknown extends matchableInput ? i : matchableInput,
   366→          InvertPatternForExcludeInternal<subpattern, i>
   367→        >;
   368→        default: excluded;
   369→        custom: excluded extends infer narrowedOrFn extends Fn
   370→          ? Call<narrowedOrFn, i>
   371→          : excluded;
   372→      }[matcherType]
   373→    : p extends readonly any[]
   374→    ? Extract<i, readonly any[]> extends infer arrayInput
   375→      ? InvertArrayPatternForExclude<
   376→          p,
   377→          arrayInput,
   378→          empty,
   379→          IsReadonlyArray<arrayInput>
   380→        >
   381→      : never
   382→    : IsPlainObject<p> extends true
   383→    ? Equal<{}, p> extends true
   384→      ? {}
   385→      : i extends object
   386→      ? [keyof p & keyof i] extends [never]
   387→        ? empty
   388→        : OptionalKeys<p> extends infer optKeys
   389→        ? [optKeys] extends [never]
   390→          ? {
   391→              readonly [k in keyof p]: k extends keyof i
   392→                ? InvertPatternForExcludeInternal<p[k], i[k], empty>
   393→                : InvertPatternInternal<p[k], unknown>;
   394→            }
   395→          : Compute<
   396→              {
   397→                readonly [k in Exclude<keyof p, optKeys>]: k extends keyof i
   398→                  ? InvertPatternForExcludeInternal<p[k], i[k], empty>
   399→                  : InvertPatternInternal<p[k], unknown>;
   400→              } & {
   401→                readonly [k in Extract<optKeys, keyof p>]?: k extends keyof i
   402→                  ? InvertPatternForExcludeInternal<p[k], i[k], empty>
   403→                  : InvertPatternInternal<p[k], unknown>;
   404→              }
   405→            >
   406→        : empty
   407→      : empty
   408→    : empty;
types/IsMatching.ts
    12→type IsMatchingTuple<a extends readonly any[], b extends readonly any[]> = [
    13→  a,
    14→  b
    15→] extends [readonly [], readonly []]
    16→  ? true
    17→  : [a, b] extends [
    18→      readonly [infer a1, ...infer aRest],
    19→      readonly [infer b1, ...infer bRest]
    20→    ]
    21→  ? IsMatching<a1, b1> extends true
    22→    ? IsMatchingTuple<aRest, bRest>
    23→    : false
    24→  : false;
    26→type IsMatchingArray<
    27→  a extends readonly any[],
    28→  b extends readonly any[]
    29→> = b extends readonly []
    30→  ? true // if b is an empty array and a is an array, the pattern matches.
    31→  : b extends readonly [infer b1, ...infer bRest]
    32→  ? a extends readonly [infer a1, ...infer aRest]
    33→    ? IsMatching<a1, b1> extends true
    34→      ? IsMatchingArray<aRest, bRest>
    35→      : false
    36→    : // if a is shorter than b, doesn't match
    37→    // example: a is [], b is [any, ...any[]]
    38→    a extends readonly []
    39→    ? false
    40→    : IsMatching<ValueOf<a>, b1> extends true
    41→    ? IsMatchingArray<a, bRest>
    42→    : false
    43→  : b extends readonly [...infer bInit, infer b1]
    44→  ? a extends readonly [...infer aInit, infer a1]
    45→    ? IsMatching<a1, b1> extends true
    46→      ? IsMatchingArray<aInit, bInit>
    47→      : false
    48→    : // if a is shorter than b, doesn't match
    49→    // example: a is [], b is [any, ...any[]]
    50→    a extends readonly []
    51→    ? false
    52→    : IsMatching<ValueOf<a>, b1> extends true
    53→    ? IsMatchingArray<a, bInit>
    54→    : false
    55→  : IsMatching<ValueOf<a>, ValueOf<b>>;
    57→export type IsMatching<a, b> = true extends IsUnion<a> | IsUnion<b>
    58→  ? true extends (
    59→      b extends any ? (a extends any ? IsMatching<a, b> : never) : never
    60→    )
    61→    ? true
    62→    : false
    63→  : // Special case for unknown, because this is the type
    64→  // of the inverted `_` wildcard pattern, which should
    65→  // match everything.
    66→  unknown extends b
    67→  ? true
    68→  : // Special case for `{}`, because this is the type
    69→  // of the inverted `P.nonNullable` wildcard pattern,
    70→  // which should match all objects.
    71→  {} extends b
    72→  ? true
    73→  : b extends Primitives
    74→  ? // if the pattern is a primitive, we want to check if there is
    75→    // an overlap between a and b!
    76→    a extends b
    77→    ? true
    78→    : b extends a
    79→    ? true
    80→    : false
    81→  : Equal<a, b> extends true
    82→  ? true
    83→  : b extends readonly any[]
    84→  ? a extends readonly any[]
    85→    ? // both tuples
    86→      All<[IsLiteral<Length<a>>, IsLiteral<Length<b>>]> extends true
    87→      ? // lengths are different
    88→        Equal<Length<a>, Length<b>> extends false
    89→        ? false
    90→        : IsMatchingTuple<a, b>
    91→      : IsMatchingArray<a, b>
    92→    : false
    93→  : IsPlainObject<b> extends true
    94→  ? true extends ( // `true extends union` means "if some cases of the a union are matching"
    95→      a extends any // loop over the `a` union
    96→        ? [keyof b & keyof a] extends [never] // if no common keys
    97→          ? false
    98→          : /**
    99→           * Intentionally not using ValueOf, to avoid reaching the
   100→           * 'type instanciation is too deep error'.
   101→           */
   102→          { [k in keyof b & keyof a]: IsMatching<a[k], b[k]> }[keyof b &
   103→              keyof a] extends true
   104→          ? true // all values are matching
   105→          : false
   106→        : never
   107→    )
   108→    ? true
   109→    : false
   110→  : b extends a
   111→  ? true
   112→  : false;

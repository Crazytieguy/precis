types/BuildMany.ts
     4‚Üíexport type BuildMany<data, xs extends readonly any[]> = xs extends any
     5‚Üí  ? BuildOne<data, xs>
     6‚Üí  : never;
    11‚Üítype BuildOne<data, xs extends readonly any[]> = xs extends [
    12‚Üí  [infer value, infer path],
    13‚Üí  ...infer tail
    14‚Üí]
    15‚Üí  ? BuildOne<SetDeep<data, value, path>, tail>
    16‚Üí  : data;
    19‚Üíexport type SetDeep<data, value, path> = path extends readonly [
    20‚Üí  infer head,
    21‚Üí  ...infer tail
    22‚Üí]
    23‚Üí  ? data extends readonly any[]
    24‚Üí    ? data extends readonly [any, ...any]
    25‚Üí      ? head extends number
    26‚Üí        ? UpdateAt<data, Iterator<head>, SetDeep<data[head], value, tail>>
    27‚Üí        : never
    28‚Üí      : SetDeep<ValueOf<data>, value, tail>[]
    29‚Üí    : data extends Set<infer a>
    30‚Üí    ? Set<SetDeep<a, value, tail>>
    31‚Üí    : data extends Map<infer k, infer v>
    32‚Üí    ? Map<k, SetDeep<v, value, tail>>
    33‚Üí    : head extends keyof data
    34‚Üí    ? // if we intentionally set undefined on an optional key, we should keep
    35‚Üí      // the optional modifier, otherwise it will exclude the `undefined` type from
    36‚Üí      // our `value` type.
    37‚Üí      [IsOptionalKeysOf<data, head>, tail, undefined] extends [true, [], value]
    38‚Üí      ? { [k in keyof data]: k extends head ? value : data[k] }
    39‚Üí      : {
    40‚Üí          [k in keyof data]-?: k extends head
    41‚Üí            ? SetDeep<data[head], value, tail>
    42‚Üí            : data[k];
    43‚Üí        }
    44‚Üí    : data
    45‚Üí  : value;

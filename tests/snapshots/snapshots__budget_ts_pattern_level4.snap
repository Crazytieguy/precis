    13‚Üíexport type ExtractPreciseValue<a, b> = b extends Override<infer b1>
    14‚Üí  ? b1
    15‚Üí  : unknown extends b
    16‚Üí  ? a
    17‚Üí  : // inlining IsAny for perf
    18‚Üí  0 extends 1 & b
    19‚Üí  ? a
    20‚Üí  : // inlining IsAny for perf
    21‚Üí  0 extends 1 & a
    22‚Üí  ? b
    23‚Üí  : b extends readonly any[]
    24‚Üí  ? ExtractPreciseArrayValue<a, b, IsReadonlyArray<a>>
    25‚Üí  : b extends Map<infer bk, infer bv>
    26‚Üí  ? a extends Map<infer ak, infer av>
    27‚Üí    ? Map<ExtractPreciseValue<ak, bk>, ExtractPreciseValue<av, bv>>
    28‚Üí    : LeastUpperBound<a, b>
    29‚Üí  : b extends Set<infer bv>
    30‚Üí  ? a extends Set<infer av>
    31‚Üí    ? Set<ExtractPreciseValue<av, bv>>
    32‚Üí    : LeastUpperBound<a, b>
    33‚Üí  : // We add `Error` to the excludeUnion because
    34‚Üí  // We want to consider them like primitive values in this context.
    35‚Üí  IsPlainObject<b, BuiltInObjects | Error> extends true
    36‚Üí  ? a extends object
    37‚Üí    ? a extends b
    38‚Üí      ? a
    39‚Üí      : b extends a
    40‚Üí      ? Contains<b, never> extends true
    41‚Üí        ? never
    42‚Üí        : // An empty object `{}` in a pattern means
    43‚Üí        // that this key must be non-nullable.
    44‚Üí        // If we find a key in `b` that doesn't exist in `a`
    45‚Üí        // and that contains `{}`, then the pattern does not match.
    46‚Üí        Contains<Omit<b, keyof a>, {}> extends true
    47‚Üí        ? never
    48‚Üí        : // If values have no keys in common, return `b`
    49‚Üí        [Exclude<keyof a, keyof b>] extends [never]
    50‚Üí        ? b
    51‚Üí        : // Otherwise return `b` with keys of `a`
    52‚Üí          // that do not exist on `b`.
    53‚Üí          // It can only be optional properties,
    54‚Üí          // otherwise `b extends a` wouldn't
    55‚Üí          // not have passed.
    56‚Üí          Compute<b & Omit<a, keyof b>>
    57‚Üí      : [keyof a & keyof b] extends [never]
    58‚Üí      ? never
    59‚Üí      : Compute<
    60‚Üí          // Keep other properties of `a`
    61‚Üí          {
    62‚Üí            // `in keyof a as ...` preserves property modifiers,
    63‚Üí            // unlike `in keyof Exclude<keyof a, keyof b>`.
    64‚Üí            [k in keyof a as k extends keyof b ? never : k]: a[k];
    65‚Üí          } & {
    66‚Üí            // use `b` to extract precise values on `a`.
    67‚Üí            // This has the effect of preserving the optional
    68‚Üí            // property modifier (?:) of b in the output type.
    69‚Üí            [k in keyof b]: k extends keyof a
    70‚Üí              ? ExtractPreciseValue<a[k], b[k]>
    71‚Üí              : b[k];
    72‚Üí          }
    73‚Üí        > extends infer result
    74‚Üí      ? Contains<Pick<result, keyof result & keyof b>, never> extends true
    75‚Üí        ? never
    76‚Üí        : result
    77‚Üí      : never
    78‚Üí    : LeastUpperBound<a, b>
    79‚Üí  : LeastUpperBound<a, b>;
    81‚Üítype ExtractPreciseArrayValue<
    82‚Üí  a,
    83‚Üí  b,
    84‚Üí  isReadonly extends boolean,
    85‚Üí  startOutput extends any[] = [],
    86‚Üí  endOutput extends any[] = []
    87‚Üí> = a extends readonly (infer aItem)[]
    88‚Üí  ? b extends readonly []
    89‚Üí    ? MaybeAddReadonly<[...startOutput, ...endOutput], isReadonly>
    90‚Üí    : b extends readonly [infer b1, ...infer bRest]
    91‚Üí    ? a extends readonly [infer a1, ...infer aRest]
    92‚Üí      ? ExtractPreciseValue<a1, b1> extends infer currentValue
    93‚Üí        ? [currentValue] extends [never]
    94‚Üí          ? never
    95‚Üí          : ExtractPreciseArrayValue<
    96‚Üí              aRest,
    97‚Üí              bRest,
    98‚Üí              isReadonly,
    99‚Üí              [...startOutput, currentValue],
   100‚Üí              endOutput
   101‚Üí            >
   102‚Üí        : never
   103‚Üí      : ExtractPreciseValue<aItem, b1> extends infer currentValue
   104‚Üí      ? [currentValue] extends [never]
   105‚Üí        ? never
   106‚Üí        : ExtractPreciseArrayValue<
   107‚Üí            aItem[],
   108‚Üí            bRest,
   109‚Üí            isReadonly,
   110‚Üí            [...startOutput, currentValue],
   111‚Üí            endOutput
   112‚Üí          >
   113‚Üí      : never
   114‚Üí    : b extends readonly [...infer bInit, infer b1]
   115‚Üí    ? a extends readonly [...infer aInit, infer a1]
   116‚Üí      ? ExtractPreciseValue<a1, b1> extends infer currentValue
   117‚Üí        ? [currentValue] extends [never]
   118‚Üí          ? never
   119‚Üí          : ExtractPreciseArrayValue<
   120‚Üí              aInit,
   121‚Üí              bInit,
   122‚Üí              isReadonly,
   123‚Üí              startOutput,
   124‚Üí              [...endOutput, currentValue]
   125‚Üí            >
   126‚Üí        : never
   127‚Üí      : ExtractPreciseValue<aItem, b1> extends infer currentValue
   128‚Üí      ? [currentValue] extends [never]
   129‚Üí        ? never
   130‚Üí        : ExtractPreciseArrayValue<
   131‚Üí            aItem[],
   132‚Üí            bInit,
   133‚Üí            isReadonly,
   134‚Üí            startOutput,
   135‚Üí            [...endOutput, currentValue]
   136‚Üí          >
   137‚Üí      : never
   138‚Üí    : ExtractPreciseValue<aItem, ValueOf<b>> extends infer currentValue
   139‚Üí    ? [currentValue] extends [never]
   140‚Üí      ? never
   141‚Üí      : MaybeAddReadonly<
   142‚Üí          [...startOutput, ...currentValue[], ...endOutput],
   143‚Üí          isReadonly
   144‚Üí        >
   145‚Üí    : never
   146‚Üí  : LeastUpperBound<a, b>;
types/FindSelected.ts
    11‚Üítype SelectionsRecord = Record<string, [unknown, unknown[]]>;
    13‚Üíexport type None = {
    14‚Üí  type: 'none';
    15‚Üí};
    16‚Üíexport type Some<key extends string> = {
    17‚Üí  type: 'some';
    18‚Üí  key: key;
    19‚Üí};
    21‚Üíexport type SelectionType = None | Some<string>;
    24‚Üítype MapOptional<selections> = {
    25‚Üí  [k in keyof selections]: selections[k] extends [infer v, infer subpath]
    26‚Üí    ? [v | undefined, subpath]
    27‚Üí    : never;
    28‚Üí};
    31‚Üítype MapList<selections> = {
    32‚Üí  [k in keyof selections]: selections[k] extends [infer v, infer subpath]
    33‚Üí    ? [v[], subpath]
    34‚Üí    : never;
    35‚Üí};
    38‚Üítype ReduceFindSelectionUnion<
    39‚Üí  i,
    40‚Üí  ps extends readonly any[],
    41‚Üí  output = never
    42‚Üí> = ps extends readonly [infer head, ...infer tail]
    43‚Üí  ? ReduceFindSelectionUnion<i, tail, output | FindSelectionUnion<i, head>>
    44‚Üí  : output;
    47‚Üítype FindSelectionUnionInArray<
    48‚Üí  i,
    49‚Üí  p,
    50‚Üí  path extends any[] = [],
    51‚Üí  output = never
    52‚Üí> = i extends readonly (infer iItem)[]
    53‚Üí  ? p extends readonly []
    54‚Üí    ? output
    55‚Üí    : p extends readonly [infer p1, ...infer pRest]
    56‚Üí    ? i extends readonly [infer i1, ...infer iRest]
    57‚Üí      ? FindSelectionUnionInArray<
    58‚Üí          iRest,
    59‚Üí          pRest,
    60‚Üí          [...path, p['length']],
    61‚Üí          output | FindSelectionUnion<i1, p1, [...path, p['length']]>
    62‚Üí        >
    63‚Üí      : FindSelectionUnionInArray<
    64‚Üí          iItem[],
    65‚Üí          pRest,
    66‚Üí          [...path, p['length']],
    67‚Üí          output | FindSelectionUnion<iItem, p1, [...path, p['length']]>
    68‚Üí        >
    69‚Üí    : p extends readonly [...infer pInit, infer p1]
    70‚Üí    ? i extends readonly [...infer iInit, infer i1]
    71‚Üí      ? FindSelectionUnionInArray<
    72‚Üí          iInit,
    73‚Üí          pInit,
    74‚Üí          [...path, p['length']],
    75‚Üí          output | FindSelectionUnion<i1, p1, [...path, p['length']]>
    76‚Üí        >
    77‚Üí      : FindSelectionUnionInArray<
    78‚Üí          iItem[],
    79‚Üí          pInit,
    80‚Üí          [...path, p['length']],
    81‚Üí          output | FindSelectionUnion<iItem, p1, [...path, p['length']]>
    82‚Üí        >
    83‚Üí    : // If P is a matcher, in this case, it's likely an array matcher
    84‚Üí    p extends readonly [...(readonly (infer pRest & AnyMatcher)[])]
    85‚Üí    ? output | FindSelectionUnion<i, pRest, [...path, p['length']]>
    86‚Üí    :
    87‚Üí        | output
    88‚Üí        | FindSelectionUnion<
    89‚Üí            iItem,
    90‚Üí            ValueOf<p>,
    91‚Üí            [...path, Extract<p, readonly any[]>['length']]
    92‚Üí          >
    93‚Üí  : output;
    96‚Üíexport type FindSelectionUnion<
    97‚Üí  i,
    98‚Üí  p,
    99‚Üí  // path just serves as an id, to identify different anonymous patterns which have the same type
   100‚Üí  path extends any[] = []
   101‚Üí  // inlining IsAny for perf
   102‚Üí> = 0 extends 1 & i
   103‚Üí  ? never
   104‚Üí  : // inlining IsAny for perf
   105‚Üí  0 extends 1 & p
   106‚Üí  ? never
   107‚Üí  : p extends Primitives
   108‚Üí  ? never
   109‚Üí  : p extends Matcher<any, infer pattern, infer matcherType, infer sel>
   110‚Üí  ? {
   111‚Üí      select: sel extends Some<infer k>
   112‚Üí        ? { [kk in k]: [i, path] } | FindSelectionUnion<i, pattern, path>
   113‚Üí        : never;
   114‚Üí      // selection of arrays, records, maps, and sets are arrays,
   115‚Üí      // because the selection function is being mapped on their values
   116‚Üí      array: i extends readonly (infer iItem)[]
   117‚Üí        ? MapList<FindSelectionUnion<iItem, pattern>>
   118‚Üí        : never;
   119‚Üí      record: [i, pattern] extends [
   120‚Üí        Record<infer k, infer v>,
   121‚Üí        [infer pkey, infer pvalue]
   122‚Üí      ]
   123‚Üí        ?
   124‚Üí            | MapList<FindSelectionUnion<k, pkey, path>>
   125‚Üí            | MapList<FindSelectionUnion<v, pvalue, path>>
   126‚Üí        : never;
   127‚Üí      map: [i, pattern] extends [
   128‚Üí        Map<infer k, infer v>,
   129‚Üí        [infer pkey, infer pvalue]
   130‚Üí      ]
   131‚Üí        ?
   132‚Üí            | MapList<FindSelectionUnion<k, pkey, path>>
   133‚Üí            | MapList<FindSelectionUnion<v, pvalue, path>>
   134‚Üí        : never;
   135‚Üí      set: i extends Set<infer v>
   136‚Üí        ? MapList<FindSelectionUnion<v, pattern, path>>
   137‚Üí        : never;
   138‚Üí      optional: MapOptional<FindSelectionUnion<i, pattern>>;
   139‚Üí      or: MapOptional<
   140‚Üí        ReduceFindSelectionUnion<i, Extract<pattern, readonly any[]>>
   141‚Üí      >;
   142‚Üí      and: ReduceFindSelectionUnion<i, Extract<pattern, readonly any[]>>;
   143‚Üí      not: never;
   144‚Üí      default: sel extends Some<infer k> ? { [kk in k]: [i, path] } : never;
   145‚Üí      custom: never;
   146‚Üí    }[matcherType]
   147‚Üí  : p extends readonly any[]
   148‚Üí  ? FindSelectionUnionInArray<i, p>
   149‚Üí  : p extends {}
   150‚Üí  ? i extends {}
   151‚Üí    ? {
   152‚Üí        [k in keyof p]: k extends keyof i
   153‚Üí          ? FindSelectionUnion<i[k], p[k], [...path, k]>
   154‚Üí          : never;
   155‚Üí      }[keyof p]
   156‚Üí    : never
   157‚Üí  : never;
   159‚Üíexport type SeveralAnonymousSelectError<
   160‚Üí  a = 'You can only use a single anonymous selection (with `select()`) in your pattern. If you need to select multiple values, give them names with `select(<name>)` instead'
   161‚Üí> = {
   162‚Üí  __error: never;
   163‚Üí} & a;
   165‚Üíexport type MixedNamedAndAnonymousSelectError<
   166‚Üí  a = 'Mixing named selections (`select("name")`) and anonymous selections (`select()`) is forbiden. Please, only use named selections.'
   167‚Üí> = {
   168‚Üí  __error: never;
   169‚Üí} & a;
   174‚Üíexport type SelectionToArgs<selections extends SelectionsRecord> =
   175‚Üí  symbols.anonymousSelectKey extends keyof selections
   176‚Üí    ? // if there are several different paths for anonymous selections
   177‚Üí      // it means that P.select() has been used more than once.
   178‚Üí      IsUnion<selections[symbols.anonymousSelectKey][1]> extends true
   179‚Üí      ? SeveralAnonymousSelectError
   180‚Üí      : keyof selections extends symbols.anonymousSelectKey
   181‚Üí      ? selections[symbols.anonymousSelectKey][0]
   182‚Üí      : MixedNamedAndAnonymousSelectError
   183‚Üí    : { [k in keyof selections]: selections[k][0] };
   185‚Üíexport type Selections<i, p> = FindSelectionUnion<i, p> extends infer u
   186‚Üí  ? [u] extends [never]
   187‚Üí    ? i
   188‚Üí    : SelectionToArgs<Extract<MergeUnion<u>, SelectionsRecord>>
   189‚Üí  : i;
   191‚Üíexport type FindSelected<i, p> =
   192‚Üí  // This happens if the provided pattern didn't extend Pattern<i>,
   193‚Üí  // Because the type checker falls back on the general `Pattern<i>` type
   194‚Üí  // in this case.
   195‚Üí  Equal<p, Pattern<i>> extends true ? i : Selections<i, p>;

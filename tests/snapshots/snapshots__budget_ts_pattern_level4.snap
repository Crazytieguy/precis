    17‚Üí/**
    18‚Üí * DistributeMatchingUnions takes two arguments:
    19‚Üí * - a data structure of type `a` containing unions
    20‚Üí * - a pattern `p`, matching this data structure
    21‚Üí * and turns it into a union of all possible
    22‚Üí * combination of each unions contained in `a` that matches `p`.
    23‚Üí *
    24‚Üí * It does this in 3 main steps:
    25‚Üí *  - 1. Find all unions contained in the data structure, that matches `p`
    26‚Üí *    with `FindUnions<a, p>`. It returns a tree of [union, path] pairs.
    27‚Üí *  - 2. this tree is passed to the `Distribute` type level function,
    28‚Üí *    Which turns it into a union of list of `[singleValue, path]` pairs.
    29‚Üí *    Each list correspond to one of the possible combination of the unions
    30‚Üí *    found in `a`.
    31‚Üí *  - 3. build a data structure with the same shape as `a` for each combination
    32‚Üí *    and return the union of these data structures.
    33‚Üí *
    34‚Üí * @example
    35‚Üí * type t1 = DistributeMatchingUnions<['a' | 'b', 1 | 2], ['a', 1]>;
    36‚Üí * // => ['a', 1] | ['a', 2] | ['b', 1] | ['b', 2]
    37‚Üí *
    38‚Üí * type t2 = DistributeMatchingUnions<['a' | 'b', 1 | 2], ['a', unknown]>;
    39‚Üí * // => ['a', 1 | 2] | ['b', 1 | 2]
    40‚Üí */
    41‚Üíexport type DistributeMatchingUnions<a, p> = IsAny<a> extends true
    42‚Üí  ? any
    43‚Üí  : BuildMany<a, Distribute<FindUnionsMany<a, p>>>;
    46‚Üíexport type FindUnionsMany<
    47‚Üí  a,
    48‚Üí  p,
    49‚Üí  path extends PropertyKey[] = []
    50‚Üí> = UnionToTuple<
    51‚Üí  (
    52‚Üí    p extends any
    53‚Üí      ? IsMatching<a, p> extends true
    54‚Üí        ? FindUnions<a, p, path>
    55‚Üí        : []
    56‚Üí      : never
    57‚Üí  ) extends readonly (infer T)[]
    58‚Üí    ? T
    59‚Üí    : never
    60‚Üí>;
    62‚Üí/**
    63‚Üí * The reason we don't look further down the tree with lists,
    64‚Üí * Set and Maps is that they can be heterogeneous,
    65‚Üí * so matching on a A[] for a in input of (A|B)[]
    66‚Üí * doesn't rule anything out. You can still have
    67‚Üí * a (A|B)[] afterward. The same logic goes for Set and Maps.
    68‚Üí *
    69‚Üí * Kinds are types of types.
    70‚Üí *
    71‚Üí * kind UnionConfig = {
    72‚Üí *  cases: Union<{
    73‚Üí *    value: b,
    74‚Üí *    subUnions: UnionConfig[]
    75‚Üí *  }>,
    76‚Üí *  path: string[]
    77‚Üí * }
    78‚Üí * FindUnions :: Pattern a p => a -> p -> UnionConfig[]
    79‚Üí */
    80‚Üíexport type FindUnions<
    81‚Üí  a,
    82‚Üí  p,
    83‚Üí  path extends PropertyKey[] = []
    84‚Üí> = unknown extends p
    85‚Üí  ? []
    86‚Üí  : IsAny<p> extends true
    87‚Üí  ? [] // Don't try to find unions after 5 levels
    88‚Üí  : Length<path> extends 5
    89‚Üí  ? []
    90‚Üí  : IsUnion<a> extends true
    91‚Üí  ? [
    92‚Üí      {
    93‚Üí        cases: a extends any
    94‚Üí          ? {
    95‚Üí              value: a;
    96‚Üí              subUnions: FindUnionsMany<a, p, path>;
    97‚Üí            }
    98‚Üí          : never;
    99‚Üí        path: path;
   100‚Üí      }
   101‚Üí    ]
   102‚Üí  : [a, p] extends [readonly any[], readonly any[]]
   103‚Üí  ? [a, p] extends [
   104‚Üí      readonly [infer a1, infer a2, infer a3, infer a4, infer a5],
   105‚Üí      readonly [infer p1, infer p2, infer p3, infer p4, infer p5]
   106‚Üí    ]
   107‚Üí    ? [
   108‚Üí        ...FindUnions<a1, p1, [...path, 0]>,
   109‚Üí        ...FindUnions<a2, p2, [...path, 1]>,
   110‚Üí        ...FindUnions<a3, p3, [...path, 2]>,
   111‚Üí        ...FindUnions<a4, p4, [...path, 3]>,
   112‚Üí        ...FindUnions<a5, p5, [...path, 4]>
   113‚Üí      ]
   114‚Üí    : [a, p] extends [
   115‚Üí        readonly [infer a1, infer a2, infer a3, infer a4],
   116‚Üí        readonly [infer p1, infer p2, infer p3, infer p4]
   117‚Üí      ]
   118‚Üí    ? [
   119‚Üí        ...FindUnions<a1, p1, [...path, 0]>,
   120‚Üí        ...FindUnions<a2, p2, [...path, 1]>,
   121‚Üí        ...FindUnions<a3, p3, [...path, 2]>,
   122‚Üí        ...FindUnions<a4, p4, [...path, 3]>
   123‚Üí      ]
   124‚Üí    : [a, p] extends [
   125‚Üí        readonly [infer a1, infer a2, infer a3],
   126‚Üí        readonly [infer p1, infer p2, infer p3]
   127‚Üí      ]
   128‚Üí    ? [
   129‚Üí        ...FindUnions<a1, p1, [...path, 0]>,
   130‚Üí        ...FindUnions<a2, p2, [...path, 1]>,
   131‚Üí        ...FindUnions<a3, p3, [...path, 2]>
   132‚Üí      ]
   133‚Üí    : [a, p] extends [
   134‚Üí        readonly [infer a1, infer a2],
   135‚Üí        readonly [infer p1, infer p2]
   136‚Üí      ]
   137‚Üí    ? [...FindUnions<a1, p1, [...path, 0]>, ...FindUnions<a2, p2, [...path, 1]>]
   138‚Üí    : [a, p] extends [readonly [infer a1], readonly [infer p1]]
   139‚Üí    ? FindUnions<a1, p1, [...path, 0]>
   140‚Üí    : /**
   141‚Üí     * Special case when matching with a variadic tuple on a regular array.
   142‚Üí     * in this case we turn the input array `A[]` into `[] | [A, ...A[]]`
   143‚Üí     * to remove one of these cases during DeepExclude.
   144‚Üí     */
   145‚Üí    p extends readonly [] | readonly [any, ...any] | readonly [...any, any]
   146‚Üí    ? IsStrictArray<Extract<a, readonly any[]>> extends false
   147‚Üí      ? []
   148‚Üí      : [
   149‚Üí          ArrayToVariadicUnion<a, p> extends infer aUnion
   150‚Üí            ? {
   151‚Üí                cases: aUnion extends any
   152‚Üí                  ? {
   153‚Üí                      value: aUnion;
   154‚Üí                      subUnions: [];
   155‚Üí                    }
   156‚Üí                  : never;
   157‚Üí                path: path;
   158‚Üí              }
   159‚Üí            : never
   160‚Üí        ]
   161‚Üí    : []
   162‚Üí  : a extends Set<any>
   163‚Üí  ? []
   164‚Üí  : a extends Map<any, any>
   165‚Üí  ? []
   166‚Üí  : [IsPlainObject<a>, IsPlainObject<p>] extends [true, true]
   167‚Üí  ? Flatten<
   168‚Üí      Values<{
   169‚Üí        [k in keyof a & keyof p]: FindUnions<a[k], p[k], [...path, k]>;
   170‚Üí      }>
   171‚Üí    >
   172‚Üí  : [];
   174‚Üíexport type ArrayToVariadicUnion<input, excluded> = MaybeAddReadonly<
   175‚Üí  | (input extends readonly [any, ...any] | readonly [...any, any] ? never : [])
   176‚Üí  | (excluded extends readonly [...any, any]
   177‚Üí      ? [...Extract<input, readonly any[]>, ValueOf<input>]
   178‚Üí      : [ValueOf<input>, ...Extract<input, readonly any[]>]),
   179‚Üí  IsReadonlyArray<input>
   180‚Üí>;
   183‚Üíexport type Distribute<unions extends readonly any[]> =
   184‚Üí  unions extends readonly [
   185‚Üí    { cases: infer cases; path: infer path },
   186‚Üí    ...infer tail
   187‚Üí  ]
   188‚Üí    ? cases extends { value: infer value; subUnions: infer subUnions }
   189‚Üí      ? [
   190‚Üí          [value, path],
   191‚Üí          ...Distribute<Extract<subUnions, readonly any[]>>,
   192‚Üí          ...Distribute<tail>
   193‚Üí        ]
   194‚Üí      : never
   195‚Üí    : [];

    29‚Üítype OptionalKeys<p> = ValueOf<{
    30‚Üí  [k in keyof p]: 0 extends 1 & p[k] // inlining IsAny for perf
    31‚Üí    ? never
    32‚Üí    : p[k] extends Matcher<any, any, infer matcherType>
    33‚Üí    ? matcherType extends 'optional'
    34‚Üí      ? k
    35‚Üí      : never
    36‚Üí    : never;
    37‚Üí}>;
    39‚Üítype ReduceUnion<
    40‚Üí  tuple extends readonly any[],
    41‚Üí  i,
    42‚Üí  output = never
    43‚Üí> = tuple extends readonly [infer p, ...infer tail]
    44‚Üí  ? ReduceUnion<tail, i, output | InvertPatternInternal<p, i>>
    45‚Üí  : output;
    47‚Üítype ReduceIntersection<
    48‚Üí  tuple extends readonly any[],
    49‚Üí  i,
    50‚Üí  output = unknown
    51‚Üí> = tuple extends readonly [infer p, ...infer tail]
    52‚Üí  ? ReduceIntersection<tail, i, output & InvertPatternInternal<p, i>>
    53‚Üí  : output;
    55‚Üítype InvertArrayPattern<
    56‚Üí  p,
    57‚Üí  i,
    58‚Üí  startOutput extends any[] = [],
    59‚Üí  endOutput extends any[] = []
    60‚Üí> = i extends readonly (infer ii)[]
    61‚Üí  ? p extends readonly []
    62‚Üí    ? [...startOutput, ...endOutput]
    63‚Üí    : p extends readonly [infer p1, ...infer pRest]
    64‚Üí    ? i extends readonly [infer i1, ...infer iRest]
    65‚Üí      ? InvertArrayPattern<
    66‚Üí          pRest,
    67‚Üí          iRest,
    68‚Üí          [...startOutput, InvertPatternInternal<p1, i1>],
    69‚Üí          endOutput
    70‚Üí        >
    71‚Üí      : InvertArrayPattern<
    72‚Üí          pRest,
    73‚Üí          ii[],
    74‚Üí          [...startOutput, InvertPatternInternal<p1, ii>],
    75‚Üí          endOutput
    76‚Üí        >
    77‚Üí    : p extends readonly [...infer pInit, infer p1]
    78‚Üí    ? i extends readonly [...infer iInit, infer i1]
    79‚Üí      ? InvertArrayPattern<
    80‚Üí          pInit,
    81‚Üí          iInit,
    82‚Üí          startOutput,
    83‚Üí          [...endOutput, InvertPatternInternal<p1, i1>]
    84‚Üí        >
    85‚Üí      : InvertArrayPattern<
    86‚Üí          pInit,
    87‚Üí          ii[],
    88‚Üí          startOutput,
    89‚Üí          [...endOutput, InvertPatternInternal<p1, ii>]
    90‚Üí        >
    91‚Üí    : // If P is a matcher, in this case, it's likely an array matcher
    92‚Üí    p extends readonly [...(readonly (infer pRest & AnyMatcher)[])]
    93‚Üí    ? [
    94‚Üí        ...startOutput,
    95‚Üí        ...Extract<InvertPatternInternal<pRest, i>, readonly any[]>,
    96‚Üí        ...endOutput
    97‚Üí      ]
    98‚Üí    : [...startOutput, ...InvertPatternInternal<ValueOf<p>, ii>[], ...endOutput]
    99‚Üí  : never;
   101‚Üí/**
   102‚Üí * ### InvertPatternInternal
   103‚Üí * Since patterns have special wildcard values, we need a way
   104‚Üí * to transform a pattern into the type of value it represents
   105‚Üí */
   106‚Üíexport type InvertPattern<p, input> = Equal<Pattern<input>, p> extends true
   107‚Üí  ? never
   108‚Üí  : InvertPatternInternal<p, input>;
   110‚Üítype InvertPatternInternal<p, input> = 0 extends 1 & p
   111‚Üí  ? never
   112‚Üí  : p extends Matcher<
   113‚Üí      infer _input,
   114‚Üí      infer subpattern,
   115‚Üí      infer matcherType,
   116‚Üí      any,
   117‚Üí      infer narrowedOrFn
   118‚Üí    >
   119‚Üí  ? {
   120‚Üí      not: DeepExclude<input, InvertPatternInternal<subpattern, input>>;
   121‚Üí      select: InvertPatternInternal<subpattern, input>;
   122‚Üí      array: InvertPatternInternal<subpattern, ReadonlyArrayValue<input>>[];
   123‚Üí      record: subpattern extends [infer pk, infer pv]
   124‚Üí        ? Record<
   125‚Üí            Extract<InvertPatternInternal<pk, RecordKey<input>>, PropertyKey>,
   126‚Üí            InvertPatternInternal<pv, RecordValue<input>>
   127‚Üí          >
   128‚Üí        : never;
   129‚Üí      map: subpattern extends [infer pk, infer pv]
   130‚Üí        ? Map<
   131‚Üí            InvertPatternInternal<pk, MapKey<Extract<input, Map<any, any>>>>,
   132‚Üí            InvertPatternInternal<pv, MapValue<Extract<input, Map<any, any>>>>
   133‚Üí          >
   134‚Üí        : never;
   135‚Üí      set: Set<
   136‚Üí        InvertPatternInternal<subpattern, SetValue<Extract<input, Set<any>>>>
   137‚Üí      >;
   138‚Üí      optional:
   139‚Üí        | InvertPatternInternal<subpattern, Exclude<input, undefined>>
   140‚Üí        | undefined;
   141‚Üí      and: ReduceIntersection<Extract<subpattern, readonly any[]>, input>;
   142‚Üí      or: ReduceUnion<Extract<subpattern, readonly any[]>, input>;
   143‚Üí      default: [subpattern] extends [never] ? input : subpattern;
   144‚Üí      custom: Override<
   145‚Üí        narrowedOrFn extends Fn ? Call<narrowedOrFn, input> : narrowedOrFn
   146‚Üí      >;
   147‚Üí    }[matcherType]
   148‚Üí  : p extends Primitives
   149‚Üí  ? p
   150‚Üí  : p extends readonly any[]
   151‚Üí  ? InvertArrayPattern<
   152‚Üí      p,
   153‚Üí      WithDefault<Extract<input, readonly any[]>, unknown[]>
   154‚Üí    >
   155‚Üí  : IsPlainObject<p> extends true
   156‚Üí  ? OptionalKeys<p> extends infer optKeys
   157‚Üí    ? [optKeys] extends [never]
   158‚Üí      ? {
   159‚Üí          [k in Exclude<keyof p, optKeys>]: InvertPatternInternal<
   160‚Üí            p[k],
   161‚Üí            WithDefault<GetKey<ExtractPlainObject<input>, k>, unknown>
   162‚Üí          >;
   163‚Üí        }
   164‚Üí      : Compute<
   165‚Üí          {
   166‚Üí            [k in Exclude<keyof p, optKeys>]: InvertPatternInternal<
   167‚Üí              p[k],
   168‚Üí              WithDefault<GetKey<ExtractPlainObject<input>, k>, unknown>
   169‚Üí            >;
   170‚Üí          } & {
   171‚Üí            [k in Extract<optKeys, keyof p>]?: InvertPatternInternal<
   172‚Üí              p[k],
   173‚Üí              WithDefault<GetKey<ExtractPlainObject<input>, k>, unknown>
   174‚Üí            >;
   175‚Üí          }
   176‚Üí        >
   177‚Üí    : never
   178‚Üí  : p;
   180‚Üíexport type ReduceIntersectionForExclude<
   181‚Üí  tuple extends readonly any[],
   182‚Üí  i,
   183‚Üí  output = unknown
   184‚Üí> = tuple extends readonly [infer p, ...infer tail]
   185‚Üí  ? ReduceIntersectionForExclude<
   186‚Üí      tail,
   187‚Üí      i,
   188‚Üí      output & InvertPatternForExcludeInternal<p, i, unknown>
   189‚Üí    >
   190‚Üí  : output;
   192‚Üíexport type ReduceUnionForExclude<
   193‚Üí  tuple extends readonly any[],
   194‚Üí  i,
   195‚Üí  output = never
   196‚Üí> = tuple extends readonly [infer p, ...infer tail]
   197‚Üí  ? ReduceUnionForExclude<
   198‚Üí      tail,
   199‚Üí      i,
   200‚Üí      output | InvertPatternForExcludeInternal<p, i, never>
   201‚Üí    >
   202‚Üí  : output;
   204‚Üítype ExcludeIfExists<a, b> =
   205‚Üí  // If b is of type never, it probably means that P.not
   206‚Üí  // was called with a `P.when` that wasn't a type guard function.
   207‚Üí  // in this case we do not exclude
   208‚Üí  [b] extends [never]
   209‚Üí    ? never
   210‚Üí    : // If a is unknown, we can't exclude
   211‚Üí    // (Unless negative types are added in the future)
   212‚Üí    unknown extends a
   213‚Üí    ? never
   214‚Üí    : All<
   215‚Üí        [
   216‚Üí          // if `a` is one of the non-literal primitive
   217‚Üí          Extends<a, NonLiteralPrimitive>,
   218‚Üí          Not<IsLiteral<a>>,
   219‚Üí          // and b is a literal
   220‚Üí          IsLiteral<b>
   221‚Üí        ]
   222‚Üí      > extends true
   223‚Üí    ? // we shouldn't exclude because this will result in
   224‚Üí      // excluding the whole primitive type even though only
   225‚Üí      // one value has been handled by this pattern.
   226‚Üí      // In other words `P.not(10)` on a `number` input shouldn't
   227‚Üí      // exclude `number`.
   228‚Üí      never
   229‚Üí    : DeepExclude<a, b>;
   231‚Üítype InvertArrayPatternForExclude<
   232‚Üí  p,
   233‚Üí  i,
   234‚Üí  empty,
   235‚Üí  isReadonly extends boolean,
   236‚Üí  startOutput extends any[] = [],
   237‚Üí  endOutput extends any[] = []
   238‚Üí> = i extends readonly (infer ii)[]
   239‚Üí  ? p extends readonly []
   240‚Üí    ? MaybeAddReadonly<[...startOutput, ...endOutput], isReadonly>
   241‚Üí    : p extends readonly [infer p1, ...infer pRest]
   242‚Üí    ? i extends readonly [infer i1, ...infer iRest]
   243‚Üí      ? InvertArrayPatternForExclude<
   244‚Üí          pRest,
   245‚Üí          iRest,
   246‚Üí          empty,
   247‚Üí          isReadonly,
   248‚Üí          [...startOutput, InvertPatternForExcludeInternal<p1, i1, empty>],
   249‚Üí          endOutput
   250‚Üí        >
   251‚Üí      : InvertArrayPatternForExclude<
   252‚Üí          pRest,
   253‚Üí          ii[],
   254‚Üí          empty,
   255‚Üí          isReadonly,
   256‚Üí          [...startOutput, InvertPatternForExcludeInternal<p1, ii, empty>],
   257‚Üí          endOutput
   258‚Üí        >
   259‚Üí    : p extends readonly [...infer pInit, infer p1]
   260‚Üí    ? i extends readonly [...infer iInit, infer i1]
   261‚Üí      ? InvertArrayPatternForExclude<
   262‚Üí          pInit,
   263‚Üí          iInit,
   264‚Üí          empty,
   265‚Üí          isReadonly,
   266‚Üí          startOutput,
   267‚Üí          [...endOutput, InvertPatternForExcludeInternal<p1, i1, empty>]
   268‚Üí        >
   269‚Üí      : InvertArrayPatternForExclude<
   270‚Üí          pInit,
   271‚Üí          ii[],
   272‚Üí          empty,
   273‚Üí          isReadonly,
   274‚Üí          startOutput,
   275‚Üí          [...endOutput, InvertPatternForExcludeInternal<p1, ii, empty>]
   276‚Üí        >
   277‚Üí    : // If P is a matcher, in this case, it's likely an array matcher
   278‚Üí    p extends readonly [...(readonly (infer pRest & AnyMatcher)[])]
   279‚Üí    ? MaybeAddReadonly<
   280‚Üí        [
   281‚Üí          ...startOutput,
   282‚Üí          ...Extract<
   283‚Üí            InvertPatternForExcludeInternal<pRest, i, empty>,
   284‚Üí            readonly any[]
   285‚Üí          >,
   286‚Üí          ...endOutput
   287‚Üí        ],
   288‚Üí        isReadonly
   289‚Üí      >
   290‚Üí    : MaybeAddReadonly<
   291‚Üí        [
   292‚Üí          ...startOutput,
   293‚Üí          ...InvertPatternForExcludeInternal<ValueOf<p>, ii, empty>[],
   294‚Üí          ...endOutput
   295‚Üí        ],
   296‚Üí        isReadonly
   297‚Üí      >
   298‚Üí  : empty;
   300‚Üí/**
   301‚Üí * ### InvertPatternForExclude
   302‚Üí */
   303‚Üíexport type InvertPatternForExclude<p, i> = Equal<Pattern<i>, p> extends true
   304‚Üí  ? never
   305‚Üí  : InvertPatternForExcludeInternal<p, i>;
   307‚Üítype InvertPatternForExcludeInternal<p, i, empty = never> =
   308‚Üí  // We need to prevent distribution because the boolean
   309‚Üí  // type is a union of literal as well as a Primitive type
   310‚Üí  // and it will end up being a false positif if we distribute it.
   311‚Üí  unknown extends p
   312‚Üí    ? i
   313‚Üí    : [p] extends [Primitives]
   314‚Üí    ? IsLiteral<p> extends true
   315‚Üí      ? p
   316‚Üí      : IsLiteral<i> extends true
   317‚Üí      ? p
   318‚Üí      : empty
   319‚Üí    : p extends Matcher<
   320‚Üí        infer matchableInput,
   321‚Üí        infer subpattern,
   322‚Üí        infer matcherType,
   323‚Üí        any,
   324‚Üí        infer excluded
   325‚Üí      >
   326‚Üí    ? {
   327‚Üí        select: InvertPatternForExcludeInternal<subpattern, i, empty>;
   328‚Üí        array: i extends readonly (infer ii)[]
   329‚Üí          ? MaybeAddReadonly<
   330‚Üí              InvertPatternForExcludeInternal<subpattern, ii, empty>[],
   331‚Üí              IsReadonlyArray<i>
   332‚Üí            >
   333‚Üí          : empty;
   334‚Üí        record: subpattern extends [infer pk, infer pv]
   335‚Üí          ? Record<
   336‚Üí              Extract<
   337‚Üí                InvertPatternForExcludeInternal<pk, RecordKey<i>, empty>,
   338‚Üí                PropertyKey
   339‚Üí              >,
   340‚Üí              InvertPatternForExcludeInternal<pv, RecordValue<i>, empty>
   341‚Üí            >
   342‚Üí          : empty;
   343‚Üí        map: subpattern extends [infer pk, infer pv]
   344‚Üí          ? i extends Map<infer ik, infer iv>
   345‚Üí            ? Map<
   346‚Üí                InvertPatternForExcludeInternal<pk, ik, empty>,
   347‚Üí                InvertPatternForExcludeInternal<pv, iv, empty>
   348‚Üí              >
   349‚Üí            : empty
   350‚Üí          : empty;
   351‚Üí        set: i extends Set<infer iv>
   352‚Üí          ? Set<InvertPatternForExcludeInternal<subpattern, iv, empty>>
   353‚Üí          : empty;
   354‚Üí        optional:
   355‚Üí          | InvertPatternForExcludeInternal<subpattern, i, empty>
   356‚Üí          | undefined;
   357‚Üí        and: ReduceIntersectionForExclude<
   358‚Üí          Extract<subpattern, readonly any[]>,
   359‚Üí          i
   360‚Üí        >;
   361‚Üí        or: ReduceUnionForExclude<Extract<subpattern, readonly any[]>, i>;
   362‚Üí        not: ExcludeIfExists<
   363‚Üí          // we use matchableInput if possible because it represent the
   364‚Üí          // union of all possible value, but i is only one of these values.
   365‚Üí          unknown extends matchableInput ? i : matchableInput,
   366‚Üí          InvertPatternForExcludeInternal<subpattern, i>
   367‚Üí        >;
   368‚Üí        default: excluded;
   369‚Üí        custom: excluded extends infer narrowedOrFn extends Fn
   370‚Üí          ? Call<narrowedOrFn, i>
   371‚Üí          : excluded;
   372‚Üí      }[matcherType]
   373‚Üí    : p extends readonly any[]
   374‚Üí    ? Extract<i, readonly any[]> extends infer arrayInput
   375‚Üí      ? InvertArrayPatternForExclude<
   376‚Üí          p,
   377‚Üí          arrayInput,
   378‚Üí          empty,
   379‚Üí          IsReadonlyArray<arrayInput>
   380‚Üí        >
   381‚Üí      : never
   382‚Üí    : IsPlainObject<p> extends true
   383‚Üí    ? Equal<{}, p> extends true
   384‚Üí      ? {}
   385‚Üí      : i extends object
   386‚Üí      ? [keyof p & keyof i] extends [never]
   387‚Üí        ? empty
   388‚Üí        : OptionalKeys<p> extends infer optKeys
   389‚Üí        ? [optKeys] extends [never]
   390‚Üí          ? {
   391‚Üí              readonly [k in keyof p]: k extends keyof i
   392‚Üí                ? InvertPatternForExcludeInternal<p[k], i[k], empty>
   393‚Üí                : InvertPatternInternal<p[k], unknown>;
   394‚Üí            }
   395‚Üí          : Compute<
   396‚Üí              {
   397‚Üí                readonly [k in Exclude<keyof p, optKeys>]: k extends keyof i
   398‚Üí                  ? InvertPatternForExcludeInternal<p[k], i[k], empty>
   399‚Üí                  : InvertPatternInternal<p[k], unknown>;
   400‚Üí              } & {
   401‚Üí                readonly [k in Extract<optKeys, keyof p>]?: k extends keyof i
   402‚Üí                  ? InvertPatternForExcludeInternal<p[k], i[k], empty>
   403‚Üí                  : InvertPatternInternal<p[k], unknown>;
   404‚Üí              }
   405‚Üí            >
   406‚Üí        : empty
   407‚Üí      : empty
   408‚Üí    : empty;
types/IsMatching.ts
    12‚Üítype IsMatchingTuple<a extends readonly any[], b extends readonly any[]> = [
    13‚Üí  a,
    14‚Üí  b
    15‚Üí] extends [readonly [], readonly []]
    16‚Üí  ? true
    17‚Üí  : [a, b] extends [
    18‚Üí      readonly [infer a1, ...infer aRest],
    19‚Üí      readonly [infer b1, ...infer bRest]
    20‚Üí    ]
    21‚Üí  ? IsMatching<a1, b1> extends true
    22‚Üí    ? IsMatchingTuple<aRest, bRest>
    23‚Üí    : false
    24‚Üí  : false;
    26‚Üítype IsMatchingArray<
    27‚Üí  a extends readonly any[],
    28‚Üí  b extends readonly any[]
    29‚Üí> = b extends readonly []
    30‚Üí  ? true // if b is an empty array and a is an array, the pattern matches.
    31‚Üí  : b extends readonly [infer b1, ...infer bRest]
    32‚Üí  ? a extends readonly [infer a1, ...infer aRest]
    33‚Üí    ? IsMatching<a1, b1> extends true
    34‚Üí      ? IsMatchingArray<aRest, bRest>
    35‚Üí      : false
    36‚Üí    : // if a is shorter than b, doesn't match
    37‚Üí    // example: a is [], b is [any, ...any[]]
    38‚Üí    a extends readonly []
    39‚Üí    ? false
    40‚Üí    : IsMatching<ValueOf<a>, b1> extends true
    41‚Üí    ? IsMatchingArray<a, bRest>
    42‚Üí    : false
    43‚Üí  : b extends readonly [...infer bInit, infer b1]
    44‚Üí  ? a extends readonly [...infer aInit, infer a1]
    45‚Üí    ? IsMatching<a1, b1> extends true
    46‚Üí      ? IsMatchingArray<aInit, bInit>
    47‚Üí      : false
    48‚Üí    : // if a is shorter than b, doesn't match
    49‚Üí    // example: a is [], b is [any, ...any[]]
    50‚Üí    a extends readonly []
    51‚Üí    ? false
    52‚Üí    : IsMatching<ValueOf<a>, b1> extends true
    53‚Üí    ? IsMatchingArray<a, bInit>
    54‚Üí    : false
    55‚Üí  : IsMatching<ValueOf<a>, ValueOf<b>>;
    57‚Üíexport type IsMatching<a, b> = true extends IsUnion<a> | IsUnion<b>
    58‚Üí  ? true extends (
    59‚Üí      b extends any ? (a extends any ? IsMatching<a, b> : never) : never
    60‚Üí    )
    61‚Üí    ? true
    62‚Üí    : false
    63‚Üí  : // Special case for unknown, because this is the type
    64‚Üí  // of the inverted `_` wildcard pattern, which should
    65‚Üí  // match everything.
    66‚Üí  unknown extends b
    67‚Üí  ? true
    68‚Üí  : // Special case for `{}`, because this is the type
    69‚Üí  // of the inverted `P.nonNullable` wildcard pattern,
    70‚Üí  // which should match all objects.
    71‚Üí  {} extends b
    72‚Üí  ? true
    73‚Üí  : b extends Primitives
    74‚Üí  ? // if the pattern is a primitive, we want to check if there is
    75‚Üí    // an overlap between a and b!
    76‚Üí    a extends b
    77‚Üí    ? true
    78‚Üí    : b extends a
    79‚Üí    ? true
    80‚Üí    : false
    81‚Üí  : Equal<a, b> extends true
    82‚Üí  ? true
    83‚Üí  : b extends readonly any[]
    84‚Üí  ? a extends readonly any[]
    85‚Üí    ? // both tuples
    86‚Üí      All<[IsLiteral<Length<a>>, IsLiteral<Length<b>>]> extends true
    87‚Üí      ? // lengths are different
    88‚Üí        Equal<Length<a>, Length<b>> extends false
    89‚Üí        ? false
    90‚Üí        : IsMatchingTuple<a, b>
    91‚Üí      : IsMatchingArray<a, b>
    92‚Üí    : false
    93‚Üí  : IsPlainObject<b> extends true
    94‚Üí  ? true extends ( // `true extends union` means "if some cases of the a union are matching"
    95‚Üí      a extends any // loop over the `a` union
    96‚Üí        ? [keyof b & keyof a] extends [never] // if no common keys
    97‚Üí          ? false
    98‚Üí          : /**
    99‚Üí           * Intentionally not using ValueOf, to avoid reaching the
   100‚Üí           * 'type instanciation is too deep error'.
   101‚Üí           */
   102‚Üí          { [k in keyof b & keyof a]: IsMatching<a[k], b[k]> }[keyof b &
   103‚Üí              keyof a] extends true
   104‚Üí          ? true // all values are matching
   105‚Üí          : false
   106‚Üí        : never
   107‚Üí    )
   108‚Üí    ? true
   109‚Üí    : false
   110‚Üí  : b extends a
   111‚Üí  ? true
   112‚Üí  : false;
types/Match.ts
     8‚Üíexport type PickReturnValue<a, b> = a extends symbols.unset ? b : a;
    10‚Üíinterface NonExhaustiveError<i> {
    14‚Üíinterface TSPatternError<i> {
    18‚Üí/**
    19‚Üí * #### Match
    20‚Üí * An interface to create a pattern matching clause.
    21‚Üí */
    22‚Üíexport type Match<
    23‚Üí  i,
    24‚Üí  o,
    25‚Üí  handledCases extends any[] = [],
    26‚Üí  inferredOutput = never
    27‚Üí> = {
    28‚Üí  /**
    29‚Üí   * `.with(pattern, handler)` Registers a pattern and an handler function that
    30‚Üí   * will be called if the pattern matches the input value.
    31‚Üí   *
    32‚Üí   * [Read the documentation for `.with()` on GitHub](https://github.com/gvergnaud/ts-pattern#with)
    33‚Üí   **/
    34‚Üí  with<
    35‚Üí    const p extends Pattern<i>,
    36‚Üí    c,
    37‚Üí    value extends MatchedValue<i, InvertPattern<p, i>>
    38‚Üí  >(
    39‚Üí    pattern: IsNever<p> extends true
    40‚Üí      ? /**
    41‚Üí         * HACK: Using `IsNever<p>` here is a hack to
    42‚Üí         * make sure the type checker forwards
    43‚Üí         * the input type parameter to pattern
    44‚Üí         * creator functions like `P.when`, `P.not`
    45‚Üí         * `P.union` when they are passed to `.with`
    46‚Üí         * directly.
    47‚Üí         */
    48‚Üí        Pattern<i>
    49‚Üí      : p,
    50‚Üí    handler: (
    51‚Üí      selections: FindSelected<value, p>,
    52‚Üí      value: value
    53‚Üí    ) => PickReturnValue<o, c>
    54‚Üí  ): InvertPatternForExclude<p, value> extends infer excluded
    55‚Üí    ? Match<
    56‚Üí        Exclude<i, excluded>,
    57‚Üí        o,
    58‚Üí        [...handledCases, excluded],
    59‚Üí        Union<inferredOutput, c>
    60‚Üí      >
    61‚Üí    : never;
    62‚Üí
    63‚Üí  with<
    64‚Üí    const p1 extends Pattern<i>,
    65‚Üí    const p2 extends Pattern<i>,
    66‚Üí    c,
    67‚Üí    p extends p1 | p2,
    68‚Üí    value extends p extends any ? MatchedValue<i, InvertPattern<p, i>> : never
    69‚Üí  >(
    70‚Üí    p1: p1,
    71‚Üí    p2: p2,
    72‚Üí    handler: (value: value) => PickReturnValue<o, c>
    73‚Üí  ): [
    74‚Üí    InvertPatternForExclude<p1, value>,
    75‚Üí    InvertPatternForExclude<p2, value>
    76‚Üí  ] extends [infer excluded1, infer excluded2]
    77‚Üí    ? Match<
    78‚Üí        Exclude<i, excluded1 | excluded2>,
    79‚Üí        o,
    80‚Üí        [...handledCases, excluded1, excluded2],
    81‚Üí        Union<inferredOutput, c>
    82‚Üí      >
    83‚Üí    : never;
    84‚Üí
    85‚Üí  with<
    86‚Üí    const p1 extends Pattern<i>,
    87‚Üí    const p2 extends Pattern<i>,
    88‚Üí    const p3 extends Pattern<i>,
    89‚Üí    const ps extends readonly Pattern<i>[],
    90‚Üí    c,
    91‚Üí    p extends p1 | p2 | p3 | ps[number],
    92‚Üí    value extends MatchedValue<i, InvertPattern<p, i>>
    93‚Üí  >(
    94‚Üí    ...args: [
    95‚Üí      p1: p1,
    96‚Üí      p2: p2,
    97‚Üí      p3: p3,
    98‚Üí      ...patterns: ps,
    99‚Üí      handler: (value: value) => PickReturnValue<o, c>
   100‚Üí    ]
   101‚Üí  ): [
   102‚Üí    InvertPatternForExclude<p1, value>,
   103‚Üí    InvertPatternForExclude<p2, value>,
   104‚Üí    InvertPatternForExclude<p3, value>,
   105‚Üí    MakeTuples<ps, value>
   106‚Üí  ] extends [
   107‚Üí    infer excluded1,
   108‚Üí    infer excluded2,
   109‚Üí    infer excluded3,
   110‚Üí    infer excludedRest
   111‚Üí  ]
   112‚Üí    ? Match<
   113‚Üí        Exclude<
   114‚Üí          i,
   115‚Üí          | excluded1
   116‚Üí          | excluded2
   117‚Üí          | excluded3
   118‚Üí          | Extract<excludedRest, any[]>[number]
   119‚Üí        >,
   120‚Üí        o,
   121‚Üí        [
   122‚Üí          ...handledCases,
   123‚Üí          excluded1,
   124‚Üí          excluded2,
   125‚Üí          excluded3,
   126‚Üí          ...Extract<excludedRest, any[]>
   127‚Üí        ],
   128‚Üí        Union<inferredOutput, c>
   129‚Üí      >
   130‚Üí    : never;
   131‚Üí
   132‚Üí  with<
   133‚Üí    const pat extends Pattern<i>,
   134‚Üí    pred extends (value: MatchedValue<i, InvertPattern<pat, i>>) => unknown,
   135‚Üí    c,
   136‚Üí    value extends GuardValue<pred>
   137‚Üí  >(
   138‚Üí    pattern: pat,
   139‚Üí    predicate: pred,
   140‚Üí    handler: (
   141‚Üí      selections: FindSelected<value, pat>,
   142‚Üí      value: value
   143‚Üí    ) => PickReturnValue<o, c>
   144‚Üí  ): pred extends (value: any) => value is infer narrowed
   145‚Üí    ? Match<
   146‚Üí        Exclude<i, narrowed>,
   147‚Üí        o,
   148‚Üí        [...handledCases, narrowed],
   149‚Üí        Union<inferredOutput, c>
   150‚Üí      >
   151‚Üí    : Match<i, o, handledCases, Union<inferredOutput, c>>;
   152‚Üí
   153‚Üí  /**
   154‚Üí   * `.when(predicate, handler)` Registers a predicate function and an handler function.
   155‚Üí   * If the predicate returns true, the handler function will be called.
   156‚Üí   *
   157‚Üí   * [Read the documentation for `.when()` on GitHub](https://github.com/gvergnaud/ts-pattern#when)
   158‚Üí   **/
   159‚Üí  when<pred extends (value: i) => unknown, c, value extends GuardValue<pred>>(
   160‚Üí    predicate: pred,
   161‚Üí    handler: (value: value) => PickReturnValue<o, c>
   162‚Üí  ): pred extends (value: any) => value is infer narrowed
   163‚Üí    ? Match<
   164‚Üí        Exclude<i, narrowed>,
   165‚Üí        o,
   166‚Üí        [...handledCases, narrowed],
   167‚Üí        Union<inferredOutput, c>
   168‚Üí      >
   169‚Üí    : Match<i, o, handledCases, Union<inferredOutput, c>>;
   170‚Üí
   171‚Üí  /**
   172‚Üí   * `.otherwise()` takes a **default handler function** that will be
   173‚Üí   * called if no previous pattern matched your input.
   174‚Üí   *
   175‚Üí   * Equivalent to `.with(P._, () => x).exhaustive()`
   176‚Üí   *
   177‚Üí   * [Read the documentation for `.otherwise()` on GitHub](https://github.com/gvergnaud/ts-pattern#otherwise)
   178‚Üí   *
   179‚Üí   **/
   180‚Üí  otherwise<c>(
   181‚Üí    handler: (value: i) => PickReturnValue<o, c>
   182‚Üí  ): PickReturnValue<o, Union<inferredOutput, c>>;
   183‚Üí
   184‚Üí  /**
   185‚Üí   * `.exhaustive()` checks that all cases are handled, and returns the result value.
   186‚Üí   *
   187‚Üí   * If you get a `NonExhaustiveError`, it means that you aren't handling
   188‚Üí   * all cases. You should probably add another `.with(...)` clause
   189‚Üí   * to match the missing case and prevent runtime errors.
   190‚Üí   *
   191‚Üí   * [Read the documentation for `.exhaustive()` on GitHub](https://github.com/gvergnaud/ts-pattern#exhaustive)
   192‚Üí   *
   193‚Üí   */
   194‚Üí  exhaustive: DeepExcludeAll<i, handledCases> extends infer remainingCases
   195‚Üí    ? [remainingCases] extends [never]
   196‚Üí      ? Exhaustive<o, inferredOutput>
   197‚Üí      : NonExhaustiveError<remainingCases>
   198‚Üí    : never;
   199‚Üí
   200‚Üí  /**
   201‚Üí   * `.run()` return the resulting value.
   202‚Üí   *
   203‚Üí   * ‚öÝÔ∏è calling this function is unsafe, and may throw if no pattern matches your input.
   204‚Üí   */
   205‚Üí  run(): PickReturnValue<o, inferredOutput>;
   206‚Üí
   207‚Üí  /**
   208‚Üí   * `.returnType<T>()` Lets you specify the return type for all of your branches.
   209‚Üí   *
   210‚Üí   * [Read the documentation for `.returnType()` on GitHub](https://github.com/gvergnaud/ts-pattern#returnType)
   211‚Üí   */
   212‚Üí  returnType: [inferredOutput] extends [never]
   213‚Üí    ? <output>() => Match<i, output, handledCases>
   214‚Üí    : TSPatternError<'calling `.returnType<T>()` is only allowed directly after `match(...)`.'>;
   215‚Üí
   216‚Üí  /**
   217‚Üí   * `.narrow()` narrows the input type to exclude all cases that have previously been handled.
   218‚Üí   *
   219‚Üí   * `.narrow()` is only useful if you want to excluded cases from union types or nullable
   220‚Üí   * properties that are deeply nested. Handled cases from top level union types are excluded
   221‚Üí   * by default.
   222‚Üí   *
   223‚Üí   * [Read the documentation for `.narrow() on GitHub](https://github.com/gvergnaud/ts-pattern#narrow)
   224‚Üí   */
   225‚Üí  narrow(): Match<DeepExcludeAll<i, handledCases>, o, [], inferredOutput>;
   226‚Üí};
   228‚Üí/**
   229‚Üí * Potential for optimization here:
   230‚Üí *
   231‚Üí * Since DeepExclude distributes the union of the input type, it can
   232‚Üí * generate very large union types on patterns touching several unions at once.
   233‚Üí * If we were sorting patterns from those which distribute the smallest
   234‚Üí * amount of union types to those which distribute the largest, we would eliminate
   235‚Üí * cheap cases more quickly and have less cases in the input type for patterns
   236‚Üí * that will be expensive to exclude.
   237‚Üí *
   238‚Üí * This pre supposes that we have a cheap way of telling if the number
   239‚Üí * of union types a pattern touches and a cheap way of sorting the tuple
   240‚Üí * of patterns.
   241‚Üí * - For the first part, we could reuse `FindMatchingUnions` and pick the `length`
   242‚Üí *   of the returned tuple.
   243‚Üí * - For the second part though I'm not aware a cheap way of sorting a tuple.
   244‚Üí */
   245‚Üítype DeepExcludeAll<a, tupleList extends any[]> = [a] extends [never]
   246‚Üí  ? never
   247‚Üí  : tupleList extends [infer excluded, ...infer tail]
   248‚Üí  ? DeepExcludeAll<DeepExclude<a, excluded>, tail>
   249‚Üí  : a;
   251‚Üítype MakeTuples<ps extends readonly any[], value> = {
   252‚Üí  -readonly [index in keyof ps]: InvertPatternForExclude<ps[index], value>;
   253‚Üí};
   255‚Üí/**
   256‚Üí * The type of an overloaded function for `.exhaustive`,
   257‚Üí * permitting calling it with or without a catch-all handler function.
   258‚Üí *
   259‚Üí * By default, TS-Pattern will throw an error if a runtime value isn't handled.
   260‚Üí */
   261‚Üítype Exhaustive<output, inferredOutput> = {
   262‚Üí  /**
   263‚Üí   * `.exhaustive()` checks that all cases are handled, and returns the result value.
   264‚Üí   *
   265‚Üí   * If you get a `NonExhaustiveError`, it means that you aren't handling
   266‚Üí   * all cases. You should probably add another `.with(...)` clause
   267‚Üí   * to match the missing case and prevent runtime errors.
   268‚Üí   *
   269‚Üí   * [Read the documentation for `.exhaustive()` on GitHub](https://github.com/gvergnaud/ts-pattern#exhaustive)
   270‚Üí   *
   271‚Üí   */
   272‚Üí  (): PickReturnValue<output, inferredOutput>;
   273‚Üí  /**
   274‚Üí   * `.exhaustive(fallback)` checks that all cases are handled and returns the result value.
   275‚Üí   *
   276‚Üí   * The fallback function will be called if your input value doesn't match any pattern.
   277‚Üí   * This can only happen if the value you passed to `match` has an incorrect type.
   278‚Üí   *
   279‚Üí   * If you get a `NonExhaustiveError`, it means that you aren't handling
   280‚Üí   * all cases. You should probably add another `.with(...)` clause
   281‚Üí   * to match the missing case.
   282‚Üí   *
   283‚Üí   * [Read the documentation for `.exhaustive()` on GitHub](https://github.com/gvergnaud/ts-pattern#exhaustive)
   284‚Üí   */
   285‚Üí  <otherOutput>(
   286‚Üí    handler: (unexpectedValue: unknown) => PickReturnValue<output, otherOutput>
   287‚Üí  ): PickReturnValue<output, Union<inferredOutput, otherOutput>>;
   288‚Üí};
types/Pattern.ts
     7‚Üíexport type MatcherType =
     8‚Üí  | 'not'
     9‚Üí  | 'optional'
    10‚Üí  | 'or'
    11‚Üí  | 'and'
    12‚Üí  | 'array'
    13‚Üí  | 'record'
    14‚Üí  | 'map'
    15‚Üí  | 'set'
    16‚Üí  | 'select'
    17‚Üí  | 'default'
    18‚Üí  | 'custom';
    23‚Üíexport type MatcherProtocol<
    24‚Üí  input,
    25‚Üí  narrowed,
    26‚Üí  // Type of what this pattern selected from the input
    27‚Üí  matcherType extends MatcherType,
    28‚Üí  selections extends SelectionType,
    29‚Üí  // Type to exclude from the input union because
    30‚Üí  // it has been fully matched by this pattern
    31‚Üí  excluded
    32‚Üí> = {
    33‚Üí  match: <I>(value: I | input) => MatchResult;
    34‚Üí  getSelectionKeys?: () => string[];
    35‚Üí  matcherType?: matcherType;
    36‚Üí};
    38‚Üíexport type MatchResult = {
    39‚Üí  matched: boolean;
    40‚Üí  selections?: Record<string, any>;
    41‚Üí};
    43‚Üí/**
    44‚Üí * A `Matcher` is an object implementing the match
    45‚Üí * protocol. It must define a `symbols.matcher` property
    46‚Üí * which returns an object with a `match()` method, taking
    47‚Üí * the input value and returning whether the pattern matches
    48‚Üí * or not, along with optional selections.
    49‚Üí */
    50‚Üíexport interface Matcher<
    51‚Üí  input,
    52‚Üí  narrowed,
    53‚Üí  // Type of what this pattern selected from the input
    54‚Üí  matcherType extends MatcherType = 'default',
    55‚Üí  selections extends SelectionType = None,
    56‚Üí  // Type to exclude from the input union because
    57‚Üí  // it has been fully matched by this pattern
    58‚Üí  excluded = narrowed
    59‚Üí> {
    60‚Üí  [matcher](): MatcherProtocol<
    61‚Üí    input,
    62‚Üí    narrowed,
    63‚Üí    matcherType,
    64‚Üí    selections,
    65‚Üí    excluded
    66‚Üí  >;
    67‚Üí  // only used for array matchers
    68‚Üí  [symbols.isVariadic]?: boolean;
    69‚Üí}
    71‚Üítype PatternMatcher<input> = Matcher<input, unknown, any, any>;
    74‚Üíexport type MatchedValue<a, invpattern> = WithDefault<
    75‚Üí  ExtractPreciseValue<a, invpattern>,
    76‚Üí  a
    77‚Üí>;
    79‚Üíexport type AnyMatcher = Matcher<any, any, any, any, any>;
    81‚Üítype UnknownMatcher = PatternMatcher<unknown>;
    83‚Üíexport type CustomP<input, pattern, narrowedOrFn> = Matcher<
    84‚Üí  input,
    85‚Üí  pattern,
    86‚Üí  //  üëÜ
    87‚Üí  // for the input type to be instantiated correctly
    88‚Üí  // on subpatterns, it has to be passed through.
    89‚Üí  'custom',
    90‚Üí  None,
    91‚Üí  narrowedOrFn
    92‚Üí>;
    94‚Üíexport type ArrayP<input, p> = Matcher<input, p, 'array'>;
    96‚Üíexport type RecordP<input, pkey, pvalue> = Matcher<
    97‚Üí  input,
    98‚Üí  [pkey, pvalue],
    99‚Üí  'record'
   100‚Üí>;
   102‚Üíexport type OptionalP<input, p> = Matcher<input, p, 'optional'>;
   104‚Üíexport type MapP<input, pkey, pvalue> = Matcher<input, [pkey, pvalue], 'map'>;
   106‚Üíexport type SetP<input, p> = Matcher<input, p, 'set'>;
   108‚Üíexport type AndP<input, ps> = Matcher<input, ps, 'and'>;
   110‚Üíexport type OrP<input, ps> = Matcher<input, ps, 'or'>;
   112‚Üíexport type NotP<input, p> = Matcher<input, p, 'not'>;
   114‚Üíexport type GuardP<input, narrowed> = Matcher<input, narrowed>;
   116‚Üíexport type GuardExcludeP<input, narrowed, excluded> = Matcher<
   117‚Üí  input,
   118‚Üí  narrowed,
   119‚Üí  'default',
   120‚Üí  None,
   121‚Üí  excluded
   122‚Üí>;
   124‚Üíexport type SelectP<
   125‚Üí  key extends string,
   126‚Üí  input = unknown,
   127‚Üí  p = Matcher<unknown, unknown>
   128‚Üí> = Matcher<input, p, 'select', Some<key>>;
   130‚Üíexport type AnonymousSelectP = SelectP<symbols.anonymousSelectKey>;
   132‚Üíexport interface Override<a> {
   133‚Üí  [symbols.override]: a;
   134‚Üí}
   136‚Üíexport type UnknownProperties = { readonly [k: PropertyKey]: unknown };
   138‚Üíexport type UnknownValuePattern =
   139‚Üí  | readonly []
   140‚Üí  | readonly [unknown, ...unknown[]]
   141‚Üí  | readonly [...unknown[], unknown]
   142‚Üí  | UnknownProperties
   143‚Üí  | Primitives
   144‚Üí  | UnknownMatcher;
   146‚Üí/**
   147‚Üí * `Pattern<a>` is the generic type for patterns matching a value of type `a`. A pattern can be any (nested) javascript value.
   148‚Üí *
   149‚Üí * They can also be wildcards, like `P._`, `P.string`, `P.number`,
   150‚Üí * or other matchers, like `P.when(predicate)`, `P.not(pattern)`, etc.
   151‚Üí *
   152‚Üí * [Read the documentation for `P.Pattern` on GitHub](https://github.com/gvergnaud/ts-pattern#patterns)
   153‚Üí *
   154‚Üí * @example
   155‚Üí * const pattern: P.Pattern<User> = { name: P.string¬Ý}
   156‚Üí */
   157‚Üíexport type Pattern<a = unknown> = unknown extends a
   158‚Üí  ? UnknownValuePattern
   159‚Üí  : KnownPattern<a>;
   161‚Üítype KnownPattern<a> = KnownPatternInternal<a>;
   163‚Üítype KnownPatternInternal<
   164‚Üí  a,
   165‚Üí  objs = Exclude<a, Primitives | Map<any, any> | Set<any> | readonly any[]>,
   166‚Üí  arrays = Extract<a, readonly any[]>,
   167‚Üí  primitives = Extract<a, Primitives>
   168‚Üí> =
   169‚Üí  | primitives
   170‚Üí  | PatternMatcher<a>
   171‚Üí  | ([objs] extends [never] ? never : ObjectPattern<Readonly<MergeUnion<objs>>>)
   172‚Üí  | ([arrays] extends [never] ? never : ArrayPattern<arrays>);
   174‚Üítype ObjectPattern<a> =
   175‚Üí  | {
   176‚Üí      readonly [k in keyof a]?: Pattern<a[k]>;
   177‚Üí    }
   178‚Üí  | never;
   180‚Üítype ArrayPattern<a> = a extends readonly (infer i)[]
   181‚Üí  ? a extends readonly [any, ...any]
   182‚Üí    ? { readonly [index in keyof a]: Pattern<a[index]> }
   183‚Üí    :
   184‚Üí        | readonly []
   185‚Üí        | readonly [Pattern<i>, ...Pattern<i>[]]
   186‚Üí        | readonly [...Pattern<i>[], Pattern<i>]
   187‚Üí  : never;
   190‚Üíexport type UnknownPattern = Chainable<GuardP<unknown, unknown>, never>;
   191‚Üíexport type StringPattern = StringChainable<GuardP<unknown, string>, never>;
   192‚Üíexport type NumberPattern = NumberChainable<GuardP<unknown, number>, never>;
   193‚Üíexport type BooleanPattern = Chainable<GuardP<unknown, boolean>, never>;
   194‚Üíexport type BigIntPattern = BigIntChainable<GuardP<unknown, bigint>, never>;
   195‚Üíexport type SymbolPattern = Chainable<GuardP<unknown, symbol>, never>;
   196‚Üíexport type NullishPattern = Chainable<
   197‚Üí  GuardP<unknown, null | undefined>,
   198‚Üí  never
   199‚Üí>;
   201‚Üíexport type NonNullablePattern = Chainable<GuardP<unknown, {}>, never>;
   203‚Üítype MergeGuards<input, guard1, guard2> = [guard1, guard2] extends [
   204‚Üí  GuardExcludeP<any, infer narrowed1, infer excluded1>,
   205‚Üí  GuardExcludeP<any, infer narrowed2, infer excluded2>
   206‚Üí]
   207‚Üí  ? GuardExcludeP<input, narrowed1 & narrowed2, excluded1 & excluded2>
   208‚Üí  : never;
   210‚Üíexport type Chainable<p, omitted extends string = never> = p &
   211‚Üí  Omit<
   212‚Üí    {
   213‚Üí      /**
   214‚Üí       * `.optional()` returns a pattern which matches if the
   215‚Üí       * key is undefined or if it is defined and the previous pattern matches its value.
   216‚Üí       *
   217‚Üí       * [Read the documentation for `P.optional` on GitHub](https://github.com/gvergnaud/ts-pattern#poptional-patterns)
   218‚Üí       *
   219‚Üí       * @example
   220‚Üí       *  match(value)
   221‚Üí       *   .with({ greeting: P.string.optional() }, () => 'will match { greeting?: string}')
   222‚Üí       */
   223‚Üí      optional<input>(): Chainable<OptionalP<input, p>, omitted | 'optional'>;
   224‚Üí      /**
   225‚Üí       * `pattern.and(pattern)` returns a pattern that matches
   226‚Üí       * if the previous pattern and the next one match the input.
   227‚Üí       *
   228‚Üí       * [Read the documentation for `P.intersection` on GitHub](https://github.com/gvergnaud/ts-pattern#pintersection-patterns)
   229‚Üí       *
   230‚Üí       * @example
   231‚Üí       *  match(value)
   232‚Üí       *   .with(
   233‚Üí       *     P.string.and(P.when(isUsername)),
   234‚Üí       *     (username) => '...'
   235‚Üí       *   )
   236‚Üí       */
   237‚Üí      and<input, const p2 extends Pattern<input>>(
   238‚Üí        pattern: p2
   239‚Üí      ): Chainable<AndP<input, [p, p2]>, omitted>;
   240‚Üí      /**
   241‚Üí       * `pattern.or(pattern)` returns a pattern that matches
   242‚Üí       * if **either** the previous pattern or the next one match the input.
   243‚Üí       *
   244‚Üí       * [Read the documentation for `P.union` on GitHub](https://github.com/gvergnaud/ts-pattern#punion-patterns)
   245‚Üí       *
   246‚Üí       * @example
   247‚Üí       *  match(value)
   248‚Üí       *   .with(
   249‚Üí       *     { value: P.string.or(P.number) },
   250‚Üí       *     ({ value }) => 'value: number | string'
   251‚Üí       *   )
   252‚Üí       */
   253‚Üí      or<input, const p2 extends Pattern<input>>(
   254‚Üí        pattern: p2
   255‚Üí      ): Chainable<OrP<input, [p, p2]>, omitted>;
   256‚Üí      /**
   257‚Üí       * `P.select()` will inject this property into the handler function's arguments.
   258‚Üí       *
   259‚Üí       * [Read the documentation for `P.select` on GitHub](https://github.com/gvergnaud/ts-pattern#pselect-patterns)
   260‚Üí       *
   261‚Üí       * @example
   262‚Üí       *  match<{ age: number }>(value)
   263‚Üí       *   .with({ age: P.string.select() }, (age) => 'age: number')
   264‚Üí       */
   265‚Üí      select<input>(): Chainable<
   266‚Üí        SelectP<symbols.anonymousSelectKey, input, p>,
   267‚Üí        omitted | 'select' | 'or' | 'and'
   268‚Üí      >;
   269‚Üí      select<input, k extends string>(
   270‚Üí        key: k
   271‚Üí      ): Chainable<SelectP<k, input, p>, omitted | 'select' | 'or' | 'and'>;
   272‚Üí    },
   273‚Üí    omitted
   274‚Üí  >;
   276‚Üíexport type StringChainable<
   277‚Üí  p extends Matcher<any, any, any, any, any>,
   278‚Üí  omitted extends string = never
   279‚Üí> = Chainable<p, omitted> &
   280‚Üí  Omit<
   281‚Üí    {
   282‚Üí      /**
   283‚Üí       * `P.string.startsWith(start)` is a pattern, matching **strings** starting with `start`.
   284‚Üí       *
   285‚Üí       * [Read the documentation for `P.string.startsWith` on GitHub](https://github.com/gvergnaud/ts-pattern#pstringstartsWith)
   286‚Üí       *
   287‚Üí       * @example
   288‚Üí       *  match(value)
   289‚Üí       *   .with(P.string.startsWith('A'), () => 'value starts with an A')
   290‚Üí       */
   291‚Üí      startsWith<input, const start extends string>(
   292‚Üí        start: start
   293‚Üí      ): StringChainable<
   294‚Üí        MergeGuards<input, p, GuardP<unknown, `${start}${string}`>>,
   295‚Üí        omitted | 'startsWith'
   296‚Üí      >;
   297‚Üí      /**
   298‚Üí       * `P.string.endsWith(end)` is a pattern, matching **strings** ending with `end`.
   299‚Üí       *
   300‚Üí       * [Read the documentation for `P.string.endsWith` on GitHub](https://github.com/gvergnaud/ts-pattern#pstringendsWith)
   301‚Üí       *
   302‚Üí       * @example
   303‚Üí       *  match(value)
   304‚Üí       *   .with(P.string.endsWith('!'), () => 'value ends with an !')
   305‚Üí       */
   306‚Üí      endsWith<input, const end extends string>(
   307‚Üí        end: end
   308‚Üí      ): StringChainable<
   309‚Üí        MergeGuards<input, p, GuardP<unknown, `${string}${end}`>>,
   310‚Üí        omitted | 'endsWith'
   311‚Üí      >;
   312‚Üí      /**
   313‚Üí       * `P.string.minLength(min)` is a pattern, matching **strings** with at least `min` characters.
   314‚Üí       *
   315‚Üí       * [Read the documentation for `P.string.minLength` on GitHub](https://github.com/gvergnaud/ts-pattern#pstringminLength)
   316‚Üí       *
   317‚Üí       * @example
   318‚Üí       *  match(value)
   319‚Üí       *   .with(P.string.minLength(10), () => 'string with more length <= 10')
   320‚Üí       */
   321‚Üí      minLength<input, const min extends number>(
   322‚Üí        min: min
   323‚Üí      ): StringChainable<
   324‚Üí        MergeGuards<input, p, GuardExcludeP<unknown, string, never>>,
   325‚Üí        omitted | 'minLength'
   326‚Üí      >;
   327‚Üí      /**
   328‚Üí       * `P.string.length(len)` is a pattern, matching **strings** with exactly `len` characters.
   329‚Üí       *
   330‚Üí       * [Read the documentation for `P.string.length` on GitHub](https://github.com/gvergnaud/ts-pattern#pstringlength)
   331‚Üí       *
   332‚Üí       * @example
   333‚Üí       *  match(value)
   334‚Üí       *   .with(P.string.length(10), () => 'strings with length === 10')
   335‚Üí       */
   336‚Üí      length<input, const len extends number>(
   337‚Üí        len: len
   338‚Üí      ): StringChainable<
   339‚Üí        MergeGuards<input, p, GuardExcludeP<unknown, string, never>>,
   340‚Üí        omitted | 'length' | 'minLength' | 'maxLength'
   341‚Üí      >;
   342‚Üí      /**
   343‚Üí       * `P.string.maxLength(max)` is a pattern, matching **strings** with at most `max` characters.
   344‚Üí       *
   345‚Üí       * [Read the documentation for `P.string.maxLength` on GitHub](https://github.com/gvergnaud/ts-pattern#pstringmaxLength)
   346‚Üí       *
   347‚Üí       * @example
   348‚Üí       *  match(value)
   349‚Üí       *   .with(P.string.maxLength(10), () => 'string with more length >= 10')
   350‚Üí       */
   351‚Üí      maxLength<input, const max extends number>(
   352‚Üí        max: max
   353‚Üí      ): StringChainable<
   354‚Üí        MergeGuards<input, p, GuardExcludeP<unknown, string, never>>,
   355‚Üí        omitted | 'maxLength'
   356‚Üí      >;
   357‚Üí      /**
   358‚Üí       * `P.string.includes(substr)` is a pattern, matching **strings** containing `substr`.
   359‚Üí       *
   360‚Üí       * [Read the documentation for `P.string.includes` on GitHub](https://github.com/gvergnaud/ts-pattern#pstringincludes)
   361‚Üí       *
   362‚Üí       * @example
   363‚Üí       *  match(value)
   364‚Üí       *   .with(P.string.includes('http'), () => 'value contains http')
   365‚Üí       */
   366‚Üí      includes<input, const substr extends string>(
   367‚Üí        substr: substr
   368‚Üí      ): StringChainable<
   369‚Üí        MergeGuards<input, p, GuardExcludeP<unknown, string, never>>,
   370‚Üí        omitted
   371‚Üí      >;
   372‚Üí      /**
   373‚Üí       * `P.string.regex(expr)` is a pattern, matching **strings** that `expr` regular expression.
   374‚Üí       *
   375‚Üí       * [Read the documentation for `P.string.regex` on GitHub](https://github.com/gvergnaud/ts-pattern#pstringregex)
   376‚Üí       *
   377‚Üí       * @example
   378‚Üí       *  match(value)
   379‚Üí       *   .with(P.string.regex(/^https?:\/\//), () => 'url')
   380‚Üí       */
   381‚Üí      regex<input, const expr extends string | RegExp>(
   382‚Üí        expr: expr
   383‚Üí      ): StringChainable<
   384‚Üí        MergeGuards<input, p, GuardExcludeP<unknown, string, never>>,
   385‚Üí        omitted
   386‚Üí      >;
   387‚Üí    },
   388‚Üí    omitted
   389‚Üí  >;
   391‚Üíexport type NumberChainable<p, omitted extends string = never> = Chainable<
   392‚Üí  p,
   393‚Üí  omitted
   394‚Üí> &
   395‚Üí  Omit<
   396‚Üí    {
   397‚Üí      /**
   398‚Üí       * `P.number.between(min, max)` matches **number** between `min` and `max`,
   399‚Üí       * equal to min or equal to max.
   400‚Üí       *
   401‚Üí       * [Read the documentation for `P.number.between` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumberbetween)
   402‚Üí       *
   403‚Üí       * @example
   404‚Üí       *  match(value)
   405‚Üí       *   .with(P.number.between(0, 10), () => '0 <= numbers <= 10')
   406‚Üí       */
   407‚Üí      between<input, const min extends number, const max extends number>(
   408‚Üí        min: min,
   409‚Üí        max: max
   410‚Üí      ): NumberChainable<
   411‚Üí        MergeGuards<input, p, GuardExcludeP<unknown, number, never>>,
   412‚Üí        omitted
   413‚Üí      >;
   414‚Üí      /**
   415‚Üí       * `P.number.lt(max)` matches **number** smaller than `max`.
   416‚Üí       *
   417‚Üí       * [Read the documentation for `P.number.lt` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumberlt)
   418‚Üí       *
   419‚Üí       * @example
   420‚Üí       *  match(value)
   421‚Üí       *   .with(P.number.lt(10), () => 'numbers < 10')
   422‚Üí       */
   423‚Üí      lt<input, const max extends number>(
   424‚Üí        max: max
   425‚Üí      ): NumberChainable<
   426‚Üí        MergeGuards<input, p, GuardExcludeP<unknown, number, never>>,
   427‚Üí        omitted
   428‚Üí      >;
   429‚Üí      /**
   430‚Üí       * `P.number.gt(min)` matches **number** greater than `min`.
   431‚Üí       *
   432‚Üí       * [Read the documentation for `P.number.gt` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumbergt)
   433‚Üí       *
   434‚Üí       * @example
   435‚Üí       *  match(value)
   436‚Üí       *   .with(P.number.gt(10), () => 'numbers > 10')
   437‚Üí       */
   438‚Üí      gt<input, const min extends number>(
   439‚Üí        min: min
   440‚Üí      ): NumberChainable<
   441‚Üí        MergeGuards<input, p, GuardExcludeP<unknown, number, never>>,
   442‚Üí        omitted
   443‚Üí      >;
   444‚Üí      /**
   445‚Üí       * `P.number.lte(max)` matches **number** smaller than or equal to `max`.
   446‚Üí       *
   447‚Üí       * [Read the documentation for `P.number.lte` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumberlte)
   448‚Üí       *
   449‚Üí       * @example
   450‚Üí       *  match(value)
   451‚Üí       *   .with(P.number.lte(10), () => 'numbers <= 10')
   452‚Üí       */
   453‚Üí      lte<input, const max extends number>(
   454‚Üí        max: max
   455‚Üí      ): NumberChainable<
   456‚Üí        MergeGuards<input, p, GuardExcludeP<unknown, number, never>>,
   457‚Üí        omitted
   458‚Üí      >;
   459‚Üí      /**
   460‚Üí       * `P.number.gte(min)` matches **number** greater than or equal to `min`.
   461‚Üí       *
   462‚Üí       * [Read the documentation for `P.number.gte` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumbergte)
   463‚Üí       *
   464‚Üí       * @example
   465‚Üí       *  match(value)
   466‚Üí       *   .with(P.number.gte(10), () => 'numbers >= 10')
   467‚Üí       */
   468‚Üí      gte<input, const min extends number>(
   469‚Üí        min: min
   470‚Üí      ): NumberChainable<
   471‚Üí        MergeGuards<input, p, GuardExcludeP<unknown, number, never>>,
   472‚Üí        omitted
   473‚Üí      >;
   474‚Üí      /**
   475‚Üí       * `P.number.int` matches **integer** numbers.
   476‚Üí       *
   477‚Üí       * [Read the documentation for `P.number.int` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumberint)
   478‚Üí       *
   479‚Üí       * @example
   480‚Üí       *  match(value)
   481‚Üí       *   .with(P.number.int, () => 'an integer')
   482‚Üí       */
   483‚Üí      int<input>(): NumberChainable<
   484‚Üí        MergeGuards<input, p, GuardExcludeP<unknown, number, never>>,
   485‚Üí        omitted | 'int'
   486‚Üí      >;
   487‚Üí      /**
   488‚Üí       * `P.number.finite` matches **finite numbers**.
   489‚Üí       *
   490‚Üí       * [Read the documentation for `P.number.finite` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumberfinite)
   491‚Üí       *
   492‚Üí       * @example
   493‚Üí       *  match(value)
   494‚Üí       *   .with(P.number.finite, () => 'not Infinity')
   495‚Üí       */
   496‚Üí      finite<input>(): NumberChainable<
   497‚Üí        MergeGuards<input, p, GuardExcludeP<unknown, number, never>>,
   498‚Üí        omitted | 'finite'
   499‚Üí      >;
   500‚Üí      /**
   501‚Üí       * `P.number.positive` matches **positive** numbers.
   502‚Üí       *
   503‚Üí       * [Read the documentation for `P.number.positive` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumberpositive)
   504‚Üí       *
   505‚Üí       * @example
   506‚Üí       *  match(value)
   507‚Üí       *   .with(P.number.positive, () => 'number > 0')
   508‚Üí       */
   509‚Üí      positive<input>(): NumberChainable<
   510‚Üí        MergeGuards<input, p, GuardExcludeP<unknown, number, never>>,
   511‚Üí        omitted | 'positive' | 'negative'
   512‚Üí      >;
   513‚Üí      /**
   514‚Üí       * `P.number.negative` matches **negative** numbers.
   515‚Üí       *
   516‚Üí       * [Read the documentation for `P.number.negative` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumbernegative)
   517‚Üí       *
   518‚Üí       * @example
   519‚Üí       *  match(value)
   520‚Üí       *   .with(P.number.negative, () => 'number < 0')
   521‚Üí       */
   522‚Üí      negative<input>(): NumberChainable<
   523‚Üí        MergeGuards<input, p, GuardExcludeP<unknown, number, never>>,
   524‚Üí        omitted | 'positive' | 'negative' | 'negative'
   525‚Üí      >;
   526‚Üí    },
   527‚Üí    omitted
   528‚Üí  >;
   530‚Üíexport type BigIntChainable<p, omitted extends string = never> = Chainable<
   531‚Üí  p,
   532‚Üí  omitted
   533‚Üí> &
   534‚Üí  Omit<
   535‚Üí    {
   536‚Üí      /**
   537‚Üí       * `P.bigint.between(min, max)` matches **bigint** between `min` and `max`,
   538‚Üí       * equal to min or equal to max.
   539‚Üí       *
   540‚Üí       * [Read the documentation for `P.bigint.between` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumberbetween)
   541‚Üí       *
   542‚Üí       * @example
   543‚Üí       *  match(value)
   544‚Üí       *   .with(P.bigint.between(0, 10), () => '0 <= numbers <= 10')
   545‚Üí       */
   546‚Üí      between<input, const min extends bigint, const max extends bigint>(
   547‚Üí        min: min,
   548‚Üí        max: max
   549‚Üí      ): BigIntChainable<
   550‚Üí        MergeGuards<input, p, GuardExcludeP<unknown, bigint, never>>,
   551‚Üí        omitted
   552‚Üí      >;
   553‚Üí      /**
   554‚Üí       * `P.bigint.lt(max)` matches **bigint** smaller than `max`.
   555‚Üí       *
   556‚Üí       * [Read the documentation for `P.bigint.lt` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumberlt)
   557‚Üí       *
   558‚Üí       * @example
   559‚Üí       *  match(value)
   560‚Üí       *   .with(P.bigint.lt(10), () => 'numbers < 10')
   561‚Üí       */
   562‚Üí      lt<input, const max extends bigint>(
   563‚Üí        max: max
   564‚Üí      ): BigIntChainable<
   565‚Üí        MergeGuards<input, p, GuardExcludeP<unknown, bigint, never>>,
   566‚Üí        omitted
   567‚Üí      >;
   568‚Üí      /**
   569‚Üí       * `P.bigint.gt(min)` matches **bigint** greater than `min`.
   570‚Üí       *
   571‚Üí       * [Read the documentation for `P.bigint.gt` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumbergt)
   572‚Üí       *
   573‚Üí       * @example
   574‚Üí       *  match(value)
   575‚Üí       *   .with(P.bigint.gt(10), () => 'numbers > 10')
   576‚Üí       */
   577‚Üí      gt<input, const min extends bigint>(
   578‚Üí        min: min
   579‚Üí      ): BigIntChainable<
   580‚Üí        MergeGuards<input, p, GuardExcludeP<unknown, bigint, never>>,
   581‚Üí        omitted
   582‚Üí      >;
   583‚Üí      /**
   584‚Üí       * `P.bigint.lte(max)` matches **bigint** smaller than or equal to `max`.
   585‚Üí       *
   586‚Üí       * [Read the documentation for `P.bigint.lte` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumberlte)
   587‚Üí       *
   588‚Üí       * @example
   589‚Üí       *  match(value)
   590‚Üí       *   .with(P.bigint.lte(10), () => 'bigints <= 10')
   591‚Üí       */
   592‚Üí      lte<input, const max extends bigint>(
   593‚Üí        max: max
   594‚Üí      ): BigIntChainable<
   595‚Üí        MergeGuards<input, p, GuardExcludeP<unknown, bigint, never>>,
   596‚Üí        omitted
   597‚Üí      >;
   598‚Üí      /**
   599‚Üí       * `P.bigint.gte(min)` matches **bigint** greater than or equal to `min`.
   600‚Üí       *
   601‚Üí       * [Read the documentation for `P.bigint.gte` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumbergte)
   602‚Üí       *
   603‚Üí       * @example
   604‚Üí       *  match(value)
   605‚Üí       *   .with(P.bigint.gte(10), () => 'bigints >= 10')
   606‚Üí       */
   607‚Üí      gte<input, const min extends bigint>(
   608‚Üí        min: min
   609‚Üí      ): BigIntChainable<
   610‚Üí        MergeGuards<input, p, GuardExcludeP<unknown, bigint, never>>,
   611‚Üí        omitted
   612‚Üí      >;
   613‚Üí      /**
   614‚Üí       * `P.bigint.positive` matches **positive** bigints.
   615‚Üí       *
   616‚Üí       * [Read the documentation for `P.bigint.positive` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumberpositive)
   617‚Üí       *
   618‚Üí       * @example
   619‚Üí       *  match(value)
   620‚Üí       *   .with(P.bigint.positive, () => 'bigint > 0')
   621‚Üí       */
   622‚Üí      positive<input>(): BigIntChainable<
   623‚Üí        MergeGuards<input, p, GuardExcludeP<unknown, bigint, never>>,
   624‚Üí        omitted | 'positive' | 'negative'
   625‚Üí      >;
   626‚Üí      /**
   627‚Üí       * `P.bigint.negative` matches **negative** bigints.
   628‚Üí       *
   629‚Üí       * [Read the documentation for `P.bigint.negative` on GitHub](https://github.com/gvergnaud/ts-pattern#pnumbernegative)
   630‚Üí       *
   631‚Üí       * @example
   632‚Üí       *  match(value)
   633‚Üí       *   .with(P.bigint.negative, () => 'bigint < 0')
   634‚Üí       */
   635‚Üí      negative<input>(): BigIntChainable<
   636‚Üí        MergeGuards<input, p, GuardExcludeP<unknown, bigint, never>>,
   637‚Üí        omitted | 'positive' | 'negative' | 'negative'
   638‚Üí      >;
   639‚Üí    },
   640‚Üí    omitted
   641‚Üí  >;
   643‚Üíexport type Variadic<pattern> = pattern & Iterable<pattern>;
   645‚Üíexport type ArrayChainable<
   646‚Üí  pattern,
   647‚Üí  omitted extends string = never
   648‚Üí> = Variadic<pattern> &
   649‚Üí  Omit<
   650‚Üí    {
   651‚Üí      /**
   652‚Üí       * `.optional()` returns a pattern which matches if the
   653‚Üí       * key is undefined or if it is defined and the previous pattern matches its value.
   654‚Üí       *
   655‚Üí       * [Read the documentation for `P.optional` on GitHub](https://github.com/gvergnaud/ts-pattern#poptional-patterns)
   656‚Üí       *
   657‚Üí       * @example
   658‚Üí       *  match(value)
   659‚Üí       *   .with({ greeting: P.string.optional() }, () => 'will match { greeting?: string}')
   660‚Üí       */
   661‚Üí      optional<input>(): ArrayChainable<
   662‚Üí        OptionalP<input, pattern>,
   663‚Üí        omitted | 'optional'
   664‚Üí      >;
   665‚Üí      /**
   666‚Üí       * `P.select()` will inject this property into the handler function's arguments.
   667‚Üí       *
   668‚Üí       * [Read the documentation for `P.select` on GitHub](https://github.com/gvergnaud/ts-pattern#pselect-patterns)
   669‚Üí       *
   670‚Üí       * @example
   671‚Üí       *  match<{ age: number }>(value)
   672‚Üí       *   .with({ age: P.string.select() }, (age) => 'age: number')
   673‚Üí       */
   674‚Üí      select<input>(): ArrayChainable<
   675‚Üí        SelectP<symbols.anonymousSelectKey, input, pattern>,
   676‚Üí        omitted | 'select'
   677‚Üí      >;
   678‚Üí      select<input, k extends string>(
   679‚Üí        key: k
   680‚Üí      ): ArrayChainable<SelectP<k, input, pattern>, omitted | 'select'>;
   681‚Üí    },
   682‚Üí    omitted
   683‚Üí  >;
types/helpers.ts
     1‚Üíexport type ValueOf<a> = a extends readonly any[] ? a[number] : a[keyof a];
     3‚Üíexport type Values<a extends object> = UnionToTuple<ValueOf<a>>;
     5‚Üí/**
     6‚Üí * ### LeastUpperBound
     7‚Üí * An interesting one. A type taking two imbricated sets and returning the
     8‚Üí * smallest one.
     9‚Üí * We need that because sometimes the pattern's inferred type holds more
    10‚Üí * information than the value on which we are matching (if the value is any
    11‚Üí * or unknown for instance).
    12‚Üí */
    13‚Üí
    14‚Üíexport type LeastUpperBound<a, b> = b extends a ? b : a extends b ? a : never;
    16‚Üíexport type Contains<a, b> = a extends any
    17‚Üí  ? 'exclude' extends {
    18‚Üí      [k in keyof a]-?: Equal<a[k], b> extends true ? 'exclude' : 'include';
    19‚Üí    }[keyof a]
    20‚Üí    ? true
    21‚Üí    : false
    22‚Üí  : never;
    25‚Üíexport type UnionToIntersection<union> = (
    26‚Üí  union extends any ? (k: union) => void : never
    27‚Üí) extends (k: infer intersection) => void
    28‚Üí  ? intersection
    29‚Üí  : never;
    31‚Üíexport type IsUnion<a> = [a] extends [UnionToIntersection<a>] ? false : true;
    33‚Üíexport type UnionToTuple<
    34‚Üí  union,
    35‚Üí  output extends any[] = []
    36‚Üí> = UnionToIntersection<
    37‚Üí  union extends any ? (t: union) => union : never
    38‚Üí> extends (_: any) => infer elem
    39‚Üí  ? UnionToTuple<Exclude<union, elem>, [elem, ...output]>
    40‚Üí  : output;
    42‚Üíexport type Flatten<
    43‚Üí  xs extends readonly any[],
    44‚Üí  output extends any[] = []
    45‚Üí> = xs extends readonly [infer head, ...infer tail]
    46‚Üí  ? Flatten<tail, [...output, ...Extract<head, readonly any[]>]>
    47‚Üí  : output;
    49‚Üíexport type Equal<a, b> = (<T>() => T extends a ? 1 : 2) extends <
    50‚Üí  T
    51‚Üí>() => T extends b ? 1 : 2
    52‚Üí  ? true
    53‚Üí  : false;
    55‚Üíexport type Expect<a extends true> = a;
    57‚Üíexport type IsAny<a> = 0 extends 1 & a ? true : false;
    59‚Üíexport type IsNever<T> = [T] extends [never] ? true : false;
    61‚Üíexport type Length<it extends readonly any[]> = it['length'];
    63‚Üíexport type Iterator<
    64‚Üí  n extends number,
    65‚Üí  it extends any[] = []
    66‚Üí> = it['length'] extends n ? it : Iterator<n, [any, ...it]>;
    68‚Üíexport type Next<it extends any[]> = [any, ...it];
    69‚Üíexport type Prev<it extends any[]> = it extends readonly [any, ...infer tail]
    70‚Üí  ? tail
    71‚Üí  : [];
    73‚Üíexport type Take<
    74‚Üí  xs extends readonly any[],
    75‚Üí  it extends any[],
    76‚Üí  output extends any[] = []
    77‚Üí> = Length<it> extends 0
    78‚Üí  ? output
    79‚Üí  : xs extends readonly [infer head, ...infer tail]
    80‚Üí  ? Take<tail, Prev<it>, [...output, head]>
    81‚Üí  : output;
    83‚Üíexport type Drop<
    84‚Üí  xs extends readonly any[],
    85‚Üí  n extends any[]
    86‚Üí> = Length<n> extends 0
    87‚Üí  ? xs
    88‚Üí  : xs extends readonly [any, ...infer tail]
    89‚Üí  ? Drop<tail, Prev<n>>
    90‚Üí  : [];
    92‚Üíexport type UpdateAt<
    93‚Üí  tail extends readonly any[],
    94‚Üí  n extends any[],
    95‚Üí  value,
    96‚Üí  inits extends readonly any[] = []
    97‚Üí> = Length<n> extends 0
    98‚Üí  ? tail extends readonly [any, ...infer tail]
    99‚Üí    ? [...inits, value, ...tail]
   100‚Üí    : inits
   101‚Üí  : tail extends readonly [infer head, ...infer tail]
   102‚Üí  ? UpdateAt<tail, Prev<n>, value, [...inits, head]>
   103‚Üí  : inits;
   105‚Üíexport type BuiltInObjects =
   106‚Üí  | Function
   107‚Üí  | Date
   108‚Üí  | RegExp
   109‚Üí  | Generator
   110‚Üí  | { readonly [Symbol.toStringTag]: string }
   111‚Üí  | any[];
   113‚Üíexport type IsPlainObject<o, excludeUnion = BuiltInObjects> = o extends object
   114‚Üí  ? // to excluded branded string types,
   115‚Üí    // like `string & { __brand: "id" }`
   116‚Üí    // and built-in objects
   117‚Üí    o extends string | excludeUnion
   118‚Üí    ? false
   119‚Üí    : true
   120‚Üí  : false;
   122‚Üíexport type Compute<a extends any> = a extends BuiltInObjects
   123‚Üí  ? a
   124‚Üí  : { [k in keyof a]: a[k] };
   126‚Üíexport type IntersectObjects<a> = (
   127‚Üí  a extends any ? keyof a : never
   128‚Üí) extends infer allKeys
   129‚Üí  ? {
   130‚Üí      [k in Extract<allKeys, PropertyKey>]: a extends any
   131‚Üí        ? k extends keyof a
   132‚Üí          ? a[k]
   133‚Üí          : never
   134‚Üí        : never;
   135‚Üí    }
   136‚Üí  : never;
   138‚Üíexport type WithDefault<a, def> = [a] extends [never] ? def : a;
   140‚Üíexport type IsLiteral<a> = [a] extends [null | undefined]
   141‚Üí  ? true
   142‚Üí  : [a] extends [string]
   143‚Üí  ? string extends a
   144‚Üí    ? false
   145‚Üí    : true
   146‚Üí  : [a] extends [number]
   147‚Üí  ? number extends a
   148‚Üí    ? false
   149‚Üí    : true
   150‚Üí  : [a] extends [boolean]
   151‚Üí  ? boolean extends a
   152‚Üí    ? false
   153‚Üí    : true
   154‚Üí  : [a] extends [symbol]
   155‚Üí  ? symbol extends a
   156‚Üí    ? false
   157‚Üí    : true
   158‚Üí  : [a] extends [bigint]
   159‚Üí  ? bigint extends a
   160‚Üí    ? false
   161‚Üí    : true
   162‚Üí  : false;
   164‚Üíexport type Primitives =
   165‚Üí  | number
   166‚Üí  | boolean
   167‚Üí  | string
   168‚Üí  | undefined
   169‚Üí  | null
   170‚Üí  | symbol
   171‚Üí  | bigint;
   173‚Üíexport type NonLiteralPrimitive = Exclude<Primitives, undefined | null>;
   175‚Üíexport type TupleKeys = '0' | '1' | '2' | '3' | '4';
   177‚Üíexport type Union<a, b> = [b] extends [a] ? a : [a] extends [b] ? b : a | b;
   179‚Üí/**
   180‚Üí * GuardValue returns the value guarded by a type guard function.
   181‚Üí */
   182‚Üíexport type GuardValue<fn> = fn extends (value: any) => value is infer b
   183‚Üí  ? b
   184‚Üí  : fn extends (value: infer a) => unknown
   185‚Üí  ? a
   186‚Üí  : never;
   188‚Üíexport type GuardFunction<input, narrowed> =
   189‚Üí  | ((value: input) => value is Extract<narrowed, input>)
   190‚Üí  | ((value: input) => boolean);
   192‚Üíexport type Some<bools extends boolean[]> = true extends bools[number]
   193‚Üí  ? true
   194‚Üí  : false;
   196‚Üíexport type All<bools extends boolean[]> = bools[number] extends true
   197‚Üí  ? true
   198‚Üí  : false;
   200‚Üíexport type Extends<a, b> = [a] extends [b] ? true : false;
   202‚Üíexport type Not<a extends boolean> = a extends true ? false : true;
   204‚Üítype AllKeys<a> = a extends any ? keyof a : never;
   207‚Üíexport type MergeUnion<a> =
   208‚Üí  | {
   209‚Üí      [k in AllKeys<a>]: a extends any
   210‚Üí        ? k extends keyof a
   211‚Üí          ? a[k]
   212‚Üí          : never
   213‚Üí        : never;
   214‚Üí    }
   215‚Üí  | never;
   217‚Üíexport type IsFixedSizeTuple<a extends readonly any[]> = IsLiteral<Length<a>>;
   220‚Üíexport type IsTuple<a> = a extends
   221‚Üí  | readonly []
   222‚Üí  | readonly [any, ...any]
   223‚Üí  | readonly [...any, any]
   224‚Üí  ? true
   225‚Üí  : false;
   227‚Üíexport type IsStrictArray<a extends readonly any[]> = Not<IsTuple<a>>;
   229‚Üíexport type IsReadonlyArray<a> = a extends readonly any[]
   230‚Üí  ? a extends any[] // mutable array
   231‚Üí    ? false
   232‚Üí    : true
   233‚Üí  : false;
   235‚Üíexport type MaybeAddReadonly<
   236‚Üí  a,
   237‚Üí  shouldAdd extends boolean
   238‚Üí> = shouldAdd extends true ? Readonly<a> : a;
   240‚Üíexport type MapKey<T> = T extends Map<infer K, any> ? K : never;
   242‚Üíexport type MapValue<T> = T extends Map<any, infer V> ? V : never;
   244‚Üíexport type SetValue<T> = T extends Set<infer V> ? V : never;
   246‚Üíexport type RecordKey<T> = T extends Record<infer K, any> ? K : never;
   248‚Üíexport type RecordValue<T> = T extends Record<any, infer V> ? V : never;
   250‚Üíexport type ReadonlyArrayValue<T> = T extends ReadonlyArray<infer V>
   251‚Üí  ? V
   252‚Üí  : never;
   254‚Üíexport type ExtractPlainObject<T> = T extends any
   255‚Üí  ? IsPlainObject<T> extends true
   256‚Üí    ? T
   257‚Üí    : never
   258‚Üí  : never;
   260‚Üíexport type GetKey<O, K> = O extends any
   261‚Üí  ? K extends keyof O
   262‚Üí    ? O[K]
   263‚Üí    : never
   264‚Üí  : never;
   266‚Üíexport interface Fn {
   267‚Üí  input: unknown;
   268‚Üí  output: unknown;
   269‚Üí}
   271‚Üíexport type Call<fn extends Fn, input> = (fn & {
   272‚Üí  input: input;
   273‚Üí})['output'];
   275‚Üíexport type IsOptionalKeysOf<obj, key extends keyof obj> = {} extends Pick<
   276‚Üí  obj,
   277‚Üí  key
   278‚Üí>
   279‚Üí  ? true
   280‚Üí  : false;
types/index.ts

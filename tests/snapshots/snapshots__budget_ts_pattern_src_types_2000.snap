    22→export type Match
   132→  with<
   133→    const pat extends Pattern<i>,
   134→    pred extends (value: MatchedValue<i, InvertPattern<pat, i>>) => unknown,
   135→    c,
   136→    value extends GuardValue<pred>
   137→  >(
   138→    pattern: pat,
   139→    predicate: pred,
   140→    handler: (
   141→      selections: FindSelected<value, pat>,
   142→      value: value
   143→    ) => PickReturnValue<o, c>
   144→  ): pred extends (value: any) => value is infer narrowed
   145→    ? Match<
   146→        Exclude<i, narrowed>,
   147→        o,
   148→        [...handledCases, narrowed],
   149→        Union<inferredOutput, c>
   150→      >
   151→    : Match<i, o, handledCases, Union<inferredOutput, c>>;
   153→  /**
   159→  when<pred extends (value: i) => unknown, c, value extends GuardValue<pred>>(
   160→    predicate: pred,
   161→    handler: (value: value) => PickReturnValue<o, c>
   162→  ): pred extends (value: any) => value is infer narrowed
   163→    ? Match<
   164→        Exclude<i, narrowed>,
   165→        o,
   166→        [...handledCases, narrowed],
   167→        Union<inferredOutput, c>
   168→      >
   169→    : Match<i, o, handledCases, Union<inferredOutput, c>>;
   171→  /**
   180→  otherwise<c>(
   181→    handler: (value: i) => PickReturnValue<o, c>
   182→  ): PickReturnValue<o, Union<inferredOutput, c>>;
   200→  /**
   205→  run(): PickReturnValue<o, inferredOutput>;
   216→  /**
   225→  narrow(): Match<DeepExcludeAll<i, handledCases>, o, [], inferredOutput>;
   228→/**
   229→ * Potential for optimization here:
   230→ *
   231→ * Since DeepExclude distributes the union of the input type, it can
   232→ * generate very large union types on patterns touching several unions at once.
   233→ * If we were sorting patterns from those which distribute the smallest
   234→ * amount of union types to those which distribute the largest, we would eliminate
   235→ * cheap cases more quickly and have less cases in the input type for patterns
   236→ * that will be expensive to exclude.
   237→ *
   238→ * This pre supposes that we have a cheap way of telling if the number
   239→ * of union types a pattern touches and a cheap way of sorting the tuple
   240→ * of patterns.
   241→ * - For the first part, we could reuse `FindMatchingUnions` and pick the `length`
   242→ *   of the returned tuple.
   243→ * - For the second part though I'm not aware a cheap way of sorting a tuple.
   244→ */
   245→type DeepExcludeAll<a, tupleList extends any[]> = [a] extends [never]
   246→  ? never
   247→  : tupleList extends [infer excluded, ...infer tail]
   248→  ? DeepExcludeAll<DeepExclude<a, excluded>, tail>
   249→  : a;
   251→type MakeTuples
   255→/**
   256→ * The type of an overloaded function for `.exhaustive`,
   257→ * permitting calling it with or without a catch-all handler function.
   258→ *
   259→ * By default, TS-Pattern will throw an error if a runtime value isn't handled.
   260→ */
   261→type Exhaustive<output, inferredOutput> = {
   262→  /**
   263→   * `.exhaustive()` checks that all cases are handled, and returns the result value.
   264→   *
   265→   * If you get a `NonExhaustiveError`, it means that you aren't handling
   266→   * all cases. You should probably add another `.with(...)` clause
   267→   * to match the missing case and prevent runtime errors.
   268→   *
   269→   * [Read the documentation for `.exhaustive()` on GitHub](https://github.com/gvergnaud/ts-pattern#exhaustive)
   270→   *
   271→   */
   272→  (): PickReturnValue<output, inferredOutput>;
   273→  /**
   274→   * `.exhaustive(fallback)` checks that all cases are handled and returns the result value.
   275→   *
   276→   * The fallback function will be called if your input value doesn't match any pattern.
   277→   * This can only happen if the value you passed to `match` has an incorrect type.
   278→   *
   279→   * If you get a `NonExhaustiveError`, it means that you aren't handling
   280→   * all cases. You should probably add another `.with(...)` clause
   281→   * to match the missing case.
   282→   *
   283→   * [Read the documentation for `.exhaustive()` on GitHub](https://github.com/gvergnaud/ts-pattern#exhaustive)
   284→   */
   285→  <otherOutput>(
   286→    handler: (unexpectedValue: unknown) => PickReturnValue<output, otherOutput>
   287→  ): PickReturnValue<output, Union<inferredOutput, otherOutput>>;
   288→};
Pattern.ts
     7→export type MatcherType
    23→export type MatcherProtocol
    38→export type MatchResult
    43→/**
    44→ * A `Matcher` is an object implementing the match
    45→ * protocol. It must define a `symbols.matcher` property
    46→ * which returns an object with a `match()` method, taking
    47→ * the input value and returning whether the pattern matches
    48→ * or not, along with optional selections.
    49→ */
    50→export interface Matcher<
    51→  input,
    52→  narrowed,
    53→  // Type of what this pattern selected from the input
    54→  matcherType extends MatcherType = 'default',
    55→  selections extends SelectionType = None,
    56→  // Type to exclude from the input union because
    57→  // it has been fully matched by this pattern
    58→  excluded = narrowed
    59→> {
    60→  [matcher](): MatcherProtocol<
    61→    input,
    62→    narrowed,
    63→    matcherType,
    64→    selections,
    65→    excluded
    66→  >;
    67→  // only used for array matchers
    68→  [symbols.isVariadic]?: boolean;
    69→}

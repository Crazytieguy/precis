    82Ôćĺ  p,
    83Ôćĺ  path extends PropertyKey[] = []
    84Ôćĺ> = unknown extends p
    85Ôćĺ  ? []
    86Ôćĺ  : IsAny<p> extends true
    87Ôćĺ  ? [] // Don't try to find unions after 5 levels
    88Ôćĺ  : Length<path> extends 5
    89Ôćĺ  ? []
    90Ôćĺ  : IsUnion<a> extends true
    91Ôćĺ  ? [
    92Ôćĺ      {
    93Ôćĺ        cases: a extends any
    94Ôćĺ          ? {
    95Ôćĺ              value: a;
    96Ôćĺ              subUnions: FindUnionsMany<a, p, path>;
    97Ôćĺ            }
    98Ôćĺ          : never;
    99Ôćĺ        path: path;
   100Ôćĺ      }
   101Ôćĺ    ]
   102Ôćĺ  : [a, p] extends [readonly any[], readonly any[]]
   103Ôćĺ  ? [a, p] extends [
   104Ôćĺ      readonly [infer a1, infer a2, infer a3, infer a4, infer a5],
   105Ôćĺ      readonly [infer p1, infer p2, infer p3, infer p4, infer p5]
   106Ôćĺ    ]
   107Ôćĺ    ? [

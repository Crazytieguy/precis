DistributeUnions.ts
    17→/**
    18→ * DistributeMatchingUnions takes two arguments:
    19→ * - a data structure of type `a` containing unions
    20→ * - a pattern `p`, matching this data structure
    21→ * and turns it into a union of all possible
    22→ * combination of each unions contained in `a` that matches `p`.
    23→ *
    24→ * It does this in 3 main steps:
    25→ *  - 1. Find all unions contained in the data structure, that matches `p`
    26→ *    with `FindUnions<a, p>`. It returns a tree of [union, path] pairs.
    27→ *  - 2. this tree is passed to the `Distribute` type level function,
    28→ *    Which turns it into a union of list of `[singleValue, path]` pairs.
    29→ *    Each list correspond to one of the possible combination of the unions
    30→ *    found in `a`.
    31→ *  - 3. build a data structure with the same shape as `a` for each combination
    32→ *    and return the union of these data structures.
    33→ *
    34→ * @example
    35→ * type t1 = DistributeMatchingUnions<['a' | 'b', 1 | 2], ['a', 1]>;
    36→ * // => ['a', 1] | ['a', 2] | ['b', 1] | ['b', 2]
    37→ *
    38→ * type t2 = DistributeMatchingUnions<['a' | 'b', 1 | 2], ['a', unknown]>;
    39→ * // => ['a', 1 | 2] | ['b', 1 | 2]
    40→ */
    41→export type DistributeMatchingUnions<a, p> = IsAny<a> extends true
    42→  ? any
    43→  : BuildMany<a, Distribute<FindUnionsMany<a, p>>>;
    46→export type FindUnionsMany
    62→/**
    63→ * The reason we don't look further down the tree with lists,
    64→ * Set and Maps is that they can be heterogeneous,
    65→ * so matching on a A[] for a in input of (A|B)[]
    66→ * doesn't rule anything out. You can still have
    67→ * a (A|B)[] afterward. The same logic goes for Set and Maps.
    68→ *
    69→ * Kinds are types of types.
    70→ *
    71→ * kind UnionConfig = {
    72→ *  cases: Union<{
    73→ *    value: b,
    74→ *    subUnions: UnionConfig[]
    75→ *  }>,
    76→ *  path: string[]
    77→ * }
    78→ * FindUnions :: Pattern a p => a -> p -> UnionConfig[]
    79→ */
    80→export type FindUnions<
    81→  a,
    82→  p,
    83→  path extends PropertyKey[] = []
    84→> = unknown extends p
    85→  ? []
    86→  : IsAny<p> extends true
    87→  ? [] // Don't try to find unions after 5 levels
    88→  : Length<path> extends 5
    89→  ? []
    90→  : IsUnion<a> extends true
    91→  ? [
    92→      {
    93→        cases: a extends any
    94→          ? {
    95→              value: a;
    96→              subUnions: FindUnionsMany<a, p, path>;
    97→            }
    98→          : never;
    99→        path: path;
   100→      }
   101→    ]
   102→  : [a, p] extends [readonly any[], readonly any[]]
   103→  ? [a, p] extends [
   104→      readonly [infer a1, infer a2, infer a3, infer a4, infer a5],
   105→      readonly [infer p1, infer p2, infer p3, infer p4, infer p5]
   106→    ]
   107→    ? [
   108→        ...FindUnions<a1, p1, [...path, 0]>,
   109→        ...FindUnions<a2, p2, [...path, 1]>,
   110→        ...FindUnions<a3, p3, [...path, 2]>,
   111→        ...FindUnions<a4, p4, [...path, 3]>,
   112→        ...FindUnions<a5, p5, [...path, 4]>
   113→      ]
   114→    : [a, p] extends [
   115→        readonly [infer a1, infer a2, infer a3, infer a4],
   116→        readonly [infer p1, infer p2, infer p3, infer p4]
   117→      ]
   118→    ? [
   119→        ...FindUnions<a1, p1, [...path, 0]>,
   120→        ...FindUnions<a2, p2, [...path, 1]>,
   121→        ...FindUnions<a3, p3, [...path, 2]>,
   122→        ...FindUnions<a4, p4, [...path, 3]>
   123→      ]
   124→    : [a, p] extends [
   125→        readonly [infer a1, infer a2, infer a3],
   126→        readonly [infer p1, infer p2, infer p3]
   127→      ]
   128→    ? [
   129→        ...FindUnions<a1, p1, [...path, 0]>,
   130→        ...FindUnions<a2, p2, [...path, 1]>,
   131→        ...FindUnions<a3, p3, [...path, 2]>
   132→      ]
   133→    : [a, p] extends [
   134→        readonly [infer a1, infer a2],
   135→        readonly [infer p1, infer p2]
   136→      ]
   137→    ? [...FindUnions<a1, p1, [...path, 0]>, ...FindUnions<a2, p2, [...path, 1]>]
   138→    : [a, p] extends [readonly [infer a1], readonly [infer p1]]
   139→    ? FindUnions<a1, p1, [...path, 0]>
   140→    : /**
   141→     * Special case when matching with a variadic tuple on a regular array.
   142→     * in this case we turn the input array `A[]` into `[] | [A, ...A[]]`
   143→     * to remove one of these cases during DeepExclude.
   144→     */
   145→    p extends readonly [] | readonly [any, ...any] | readonly [...any, any]
   146→    ? IsStrictArray<Extract<a, readonly any[]>> extends false
   147→      ? []
   148→      : [
   149→          ArrayToVariadicUnion<a, p> extends infer aUnion
   150→            ? {
   151→                cases: aUnion extends any
   152→                  ? {
   153→                      value: aUnion;
   154→                      subUnions: [];
   155→                    }
   156→                  : never;
   157→                path: path;
   158→              }
   159→            : never
   160→        ]
   161→    : []
   162→  : a extends Set<any>
   163→  ? []
   164→  : a extends Map<any, any>
   165→  ? []
   166→  : [IsPlainObject<a>, IsPlainObject<p>] extends [true, true]
   167→  ? Flatten<
   168→      Values<{
   169→        [k in keyof a & keyof p]: FindUnions<a[k], p[k], [...path, k]>;
   170→      }>
   171→    >
   172→  : [];
   174→export type ArrayToVariadicUnion
   183→export type Distribute

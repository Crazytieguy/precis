   651→      /**
   652→       * `.optional()` returns a pattern which matches if the
   653→       * key is undefined or if it is defined and the previous pattern matches its value.
   654→       *
   655→       * [Read the documentation for `P.optional` on GitHub](https://github.com/gvergnaud/ts-pattern#poptional-patterns)
   656→       *
   657→       * @example
      →…
   661→      optional<input>(): ArrayChainable<
   662→        OptionalP<input, pattern>,
   663→        omitted | 'optional'
   664→      >;
   678→      select<input, k extends string>(
   679→        key: k
   680→      ): ArrayChainable<SelectP<k, input, pattern>, omitted | 'select'>;


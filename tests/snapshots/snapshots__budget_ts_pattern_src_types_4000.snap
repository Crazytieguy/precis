    18‚Üí * DistributeMatchingUnions takes two arguments:
    19‚Üí * - a data structure of type `a` containing unions
    20‚Üí * - a pattern `p`, matching this data structure
    21‚Üí * and turns it into a union of all possible
    22‚Üí * combination of each unions contained in `a` that matches `p`.
    23‚Üí *
    24‚Üí * It does this in 3 main steps:
    25‚Üí *  - 1. Find all unions contained in the data structure, that matches `p`
    26‚Üí *    with `FindUnions<a, p>`. It returns a tree of [union, path] pairs.
    27‚Üí *  - 2. this tree is passed to the `Distribute` type level function,
    28‚Üí *    Which turns it into a union of list of `[singleValue, path]` pairs.
    29‚Üí *    Each list correspond to one of the possible combination of the unions
    30‚Üí *    found in `a`.
    31‚Üí *  - 3. build a data structure with the same shape as `a` for each combination
    32‚Üí *    and return the union of these data structures.
    33‚Üí *
    34‚Üí * @example
    35‚Üí * type t1 = DistributeMatchingUnions<['a' | 'b', 1 | 2], ['a', 1]>;
    36‚Üí * // => ['a', 1] | ['a', 2] | ['b', 1] | ['b', 2]
    37‚Üí *
    38‚Üí * type t2 = DistributeMatchingUnions<['a' | 'b', 1 | 2], ['a', unknown]>;
    39‚Üí * // => ['a', 1 | 2] | ['b', 1 | 2]
    41‚Üíexport type DistributeMatchingUnions<a, p> = IsAny<a> extends true
    42‚Üí  ? any
    43‚Üí  : BuildMany<a, Distribute<FindUnionsMany<a, p>>>;
    63‚Üí * The reason we don't look further down the tree with lists,
    64‚Üí * Set and Maps is that they can be heterogeneous,
    65‚Üí * so matching on a A[] for a in input of (A|B)[]
    66‚Üí * doesn't rule anything out. You can still have
    67‚Üí * a (A|B)[] afterward. The same logic goes for Set and Maps.
    68‚Üí *
    69‚Üí * Kinds are types of types.
    70‚Üí *
    71‚Üí * kind UnionConfig = {
    72‚Üí *  cases: Union<{
    73‚Üí *    value: b,
    74‚Üí *    subUnions: UnionConfig[]
    75‚Üí *  }>,
    76‚Üí *  path: string[]
    77‚Üí * }
    78‚Üí * FindUnions :: Pattern a p => a -> p -> UnionConfig[]
    80‚Üíexport type FindUnions<
    81‚Üí  a,
    82‚Üí  p,
    83‚Üí  path extends PropertyKey[] = []
    84‚Üí> = unknown extends p
    85‚Üí  ? []
    86‚Üí  : IsAny<p> extends true
    87‚Üí  ? [] // Don't try to find unions after 5 levels
    88‚Üí  : Length<path> extends 5
    89‚Üí  ? []
    90‚Üí  : IsUnion<a> extends true
    91‚Üí  ? [
    92‚Üí      {
    93‚Üí        cases: a extends any
    94‚Üí          ? {
    95‚Üí              value: a;
    96‚Üí              subUnions: FindUnionsMany<a, p, path>;
    97‚Üí            }
    98‚Üí          : never;
    99‚Üí        path: path;
   100‚Üí      }
   101‚Üí    ]
   102‚Üí  : [a, p] extends [readonly any[], readonly any[]]
   103‚Üí  ? [a, p] extends [
   104‚Üí      readonly [infer a1, infer a2, infer a3, infer a4, infer a5],
   105‚Üí      readonly [infer p1, infer p2, infer p3, infer p4, infer p5]
   106‚Üí    ]
   107‚Üí    ? [
   108‚Üí        ...FindUnions<a1, p1, [...path, 0]>,

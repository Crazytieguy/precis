   488→class TypeguardTransformer(NodeTransformer):
   489→    def __init__(
   490→        self, target_path: Sequence[str] | None = None, target_lineno: int | None = None
   491→    ) -> None:
   492→        self._target_path = tuple(target_path) if target_path else None
   493→        self._memo = self._module_memo = TransformMemo(None, None, ())
   498→    def generic_visit
   516→    @contextmanager
   517→    def _use_memo(
   518→        self, node: ClassDef | FunctionDef | AsyncFunctionDef
   519→    ) -> Generator[None, Any, None]:
   520→        new_memo = TransformMemo(node, self._memo, self._memo.path + (node.name,))
   521→        old_memo = self._memo
   522→        self._memo = new_memo
   523→
   524→        if isinstance(node, (FunctionDef, AsyncFunctionDef)):
   525→            new_memo.should_instrument = (
   526→                self._target_path is None or new_memo.path == self._target_path
   527→            )
   528→            if new_memo.should_instrument:
   529→                # Check if the function is a generator function
   530→                detector = GeneratorDetector()
   531→                detector.visit(node)
   532→
   570→    def _get_import(self, module: str, name: str) -> Name:
   571→        memo = self._memo if self._target_path else self._module_memo
   572→        return memo.get_import(module, name)
   580→    def _convert_annotation(self, annotation: expr | None) -> expr | None:
   581→        if annotation is None:
   582→            return None

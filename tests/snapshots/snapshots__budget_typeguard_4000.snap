    68→@pytest.fixture
    69→def chdir_local() -> None:
    70→    """
    71→    Change to the local directory. This is so that mypy treats imports from
    72→    typeguard as external imports instead of source code (which is handled
    73→    differently by mypy).
    74→    """
    75→    os.chdir(os.path.dirname(__file__))
    78→@pytest.mark.usefixtures("chdir_local")
    79→def test_positive() -> None:
    80→    """
    81→    Run mypy on the positive test file.  There should be no errors.
    82→    """
    83→    subprocess.check_call(get_mypy_cmd(POSITIVE_FILE))
    86→@pytest.mark.usefixtures("chdir_local")
    87→def test_negative() -> None:
    88→    """
    89→    Run mypy on the negative test file. This should fail. The errors from mypy
    90→    should match the comments in the file.
    91→    """
    92→    got_errors = get_mypy_errors()
    93→    expected_errors = get_expected_errors()
    94→
    95→    if set(got_errors) != set(expected_errors):
    96→        raise RuntimeError(
    97→            f"Expected error lines {set(expected_errors)} does not "
    98→            + f"match mypy error lines {set(got_errors)}."
    99→        )
   100→
   101→    mismatches = [
   102→        (idx, expected_errors[idx], got_errors[idx])
   103→        for idx in expected_errors
   104→        if expected_errors[idx] != got_errors[idx]
   105→    ]
   106→    for idx, expected, got in mismatches:
   107→        print(f"Line {idx}", f"Expected: {expected}", f"Got:      {got}", sep="\n\t")
   108→
   109→    if mismatches:
   110→        raise RuntimeError("Error messages changed")

src/typeguard/_memo.py
     8â†’class TypeCheckMemo:
     9â†’    """
    10â†’    Contains information necessary for type checkers to do their work.
    11â†’
    12â†’    .. attribute:: globals
    13â†’       :type: dict[str, Any]
    14â†’
    15â†’        Dictionary of global variables to use for resolving forward references.
    16â†’
    17â†’    .. attribute:: locals
    18â†’       :type: dict[str, Any]
    19â†’
    20â†’        Dictionary of local variables to use for resolving forward references.
    21â†’
    22â†’    .. attribute:: self_type
    23â†’       :type: type | None
    24â†’
    25â†’        When running type checks within an instance method or class method, this is the
    26â†’        class object that the first argument (usually named ``self`` or ``cls``) refers
    27â†’        to.
    28â†’
    29â†’    .. attribute:: config
    30â†’       :type: TypeCheckConfiguration
    31â†’
    32â†’         Contains the configuration for a particular set of type checking operations.
    33â†’    """
    34â†’
    35â†’    __slots__ = "globals", "locals", "self_type", "config"
    36â†’
    37â†’    def __init__(
    38â†’        self,
    39â†’        globals: dict[str, Any],
    40â†’        locals: dict[str, Any],
    41â†’        *,
    42â†’        self_type: type | None = None,
    43â†’        config: TypeCheckConfiguration = global_config,
    44â†’    ):
    45â†’        self.globals = globals
    46â†’        self.locals = locals
    47â†’        self.self_type = self_type
    48â†’        self.config = config

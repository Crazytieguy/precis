    55→class TypeguardLoader(SourceFileLoader):
    56→    @staticmethod
    57→    def source_to_code(
    58→        data: Buffer | str | ast.Module | ast.Expression | ast.Interactive,
    59→        path: Buffer | str | PathLike[str] = "<string>",
    60→        *,
    61→        _optimize: int = -1,
    62→    ) -> CodeType:
    63→        if isinstance(path, (str, PathLike)):
    64→            filename = path
    65→        else:
    66→            filename = os.fsdecode(bytes(path))
    67→
    68→        if isinstance(data, (ast.Module, ast.Expression, ast.Interactive)):
    69→            module = data
    70→        else:
    71→            if isinstance(data, str):
    72→                source = data
    73→            else:
    74→                source = decode_source(data)
    75→
    76→            module = _call_with_frames_removed(
    77→                ast.parse,
    78→                source,
    79→                filename,
    80→                "exec",
    81→            )
    82→
    83→        tree = TypeguardTransformer().visit(module)
    84→        ast.fix_missing_locations(tree)
    85→
    86→        if global_config.debug_instrumentation and sys.version_info >= (3, 9):
    87→            print(
    88→                f"Source code of {path!r} after instrumentation:\n"
    89→                "----------------------------------------------",
    90→                file=sys.stderr,
    91→            )
    92→            print(ast.unparse(tree), file=sys.stderr)
    93→            print("----------------------------------------------", file=sys.stderr)
    94→
    95→        return _call_with_frames_removed(
    96→            compile, tree, filename, "exec", 0, dont_inherit=True
    97→        )

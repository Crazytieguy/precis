    55â†’class TypeguardLoader(SourceFileLoader):
    56â†’    @staticmethod
    57â†’    def source_to_code(
    58â†’        data: Buffer | str | ast.Module | ast.Expression | ast.Interactive,
    59â†’        path: Buffer | str | PathLike[str] = "<string>",
    60â†’        *,
    61â†’        _optimize: int = -1,
    62â†’    ) -> CodeType:
    63â†’        if isinstance(path, (str, PathLike)):
    64â†’            filename = path
    65â†’        else:
    66â†’            filename = os.fsdecode(bytes(path))
    67â†’
    68â†’        if isinstance(data, (ast.Module, ast.Expression, ast.Interactive)):
    69â†’            module = data
    70â†’        else:
    71â†’            if isinstance(data, str):
    72â†’                source = data
    73â†’            else:
    74â†’                source = decode_source(data)
    75â†’
    76â†’            module = _call_with_frames_removed(
    77â†’                ast.parse,
    78â†’                source,
    79â†’                filename,
    80â†’                "exec",
    81â†’            )
    82â†’
    83â†’        tree = TypeguardTransformer().visit(module)
    84â†’        ast.fix_missing_locations(tree)
    85â†’
    86â†’        if global_config.debug_instrumentation and sys.version_info >= (3, 9):
    87â†’            print(
    88â†’                f"Source code of {path!r} after instrumentation:\n"
    89â†’                "----------------------------------------------",
    90â†’                file=sys.stderr,
    91â†’            )
    92â†’            print(ast.unparse(tree), file=sys.stderr)
    93â†’            print("----------------------------------------------", file=sys.stderr)
    94â†’
    95â†’        return _call_with_frames_removed(
    96â†’            compile, tree, filename, "exec", 0, dont_inherit=True
    97â†’        )

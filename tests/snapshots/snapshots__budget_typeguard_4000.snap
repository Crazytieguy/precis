    99â†’    def exec_module(self, module: ModuleType) -> None:
   100â†’        # Use a custom optimization marker â€“ the import lock should make this monkey
   101â†’        # patch safe
   102â†’        with patch(
   103â†’            "importlib._bootstrap_external.cache_from_source",
   104â†’            optimized_cache_from_source,
   105â†’        ):
   106â†’            super().exec_module(module)
   109â†’class TypeguardFinder(MetaPathFinder):
   110â†’    """
   111â†’    Wraps another path finder and instruments the module with
   112â†’    :func:`@typechecked <typeguard.typechecked>` if :meth:`should_instrument` returns
   113â†’    ``True``.
   114â†’
   115â†’    Should not be used directly, but rather via :func:`~.install_import_hook`.
   116â†’
   117â†’    .. versionadded:: 2.6
   118â†’    """
   119â†’
   120â†’    def __init__(self, packages: list[str] | None, original_pathfinder: MetaPathFinder):
   121â†’        self.packages = packages
   122â†’        self._original_pathfinder = original_pathfinder
   123â†’
   124â†’    def find_spec(
   125â†’        self,
   126â†’        fullname: str,
   127â†’        path: Sequence[str] | None,
   128â†’        target: types.ModuleType | None = None,
   129â†’    ) -> ModuleSpec | None:
   130â†’        if self.should_instrument(fullname):
   131â†’            spec = self._original_pathfinder.find_spec(fullname, path, target)
   132â†’            if spec is not None and isinstance(spec.loader, SourceFileLoader):
   133â†’                spec.loader = TypeguardLoader(spec.loader.name, spec.loader.path)
   134â†’                return spec
   135â†’
   136â†’        return None
   137â†’
   138â†’    def should_instrument(self, module_name: str) -> bool:
   139â†’        """
   140â†’        Determine whether the module with the given name should be instrumented.
   141â†’
   142â†’        :param module_name: full name of the module that is about to be imported (e.g.
   143â†’            ``xyz.abc``)
   144â†’
   145â†’        """
   146â†’        if self.packages is None:
   147â†’            return True
   148â†’
   149â†’        for package in self.packages:
   150â†’            if module_name == package or module_name.startswith(package + "."):
   151â†’                return True
   152â†’
   153â†’        return False
   156â†’class ImportHookManager:
   157â†’    """
   158â†’    A handle that can be used to uninstall the Typeguard import hook.
   159â†’    """
   160â†’
   161â†’    def __init__(self, hook: MetaPathFinder):
   162â†’        self.hook = hook

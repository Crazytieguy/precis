   488→class TypeguardTransformer(NodeTransformer):
   489→    def __init__ …
   498→    def generic_visit …
   516→    @contextmanager
   517→    def _use_memo(
   518→        self, node: ClassDef | FunctionDef | AsyncFunctionDef
   519→    ) -> Generator[None, Any, None]:
   520→        new_memo = TransformMemo(node, self._memo, self._memo.path + (node.name,))
   521→        old_memo = self._memo
   522→        self._memo = new_memo
   523→
   524→        if isinstance(node, (FunctionDef, AsyncFunctionDef)):
   525→            new_memo.should_instrument = (
   526→                self._target_path is None or new_memo.path == self._target_path
   527→            )
   528→            if new_memo.should_instrument:
   529→                # Check if the function is a generator function
   530→                detector = GeneratorDetector()
   531→                detector.visit(node)
   532→
   533→                # Extract yield, send and return types where possible from a subscripted
   534→                # annotation like Generator[int, str, bool]
   535→                return_annotation = deepcopy(node.returns)
   536→                if detector.contains_yields and new_memo.name_matches(
   537→                    return_annotation, *generator_names
   538→                ):
   539→                    if isinstance(return_annotation, Subscript):
   540→                        if isinstance(return_annotation.slice, Tuple):
   541→                            items = return_annotation.slice.elts
   542→                        else:
   543→                            items = [return_annotation.slice]
   544→
   545→                        if len(items) > 0:
   546→                            new_memo.yield_annotation = self._convert_annotation(
   547→                                items[0]
   548→                            )
   549→
   550→                        if len(items) > 1:
   551→                            new_memo.send_annotation = self._convert_annotation(
   552→                                items[1]
   553→                            )
   554→
   555→                        if len(items) > 2:
   556→                            new_memo.return_annotation = self._convert_annotation(
   557→                                items[2]
   558→                            )
   559→                else:
   560→                    new_memo.return_annotation = self._convert_annotation(
   561→                        return_annotation
   562→                    )
   563→
   564→        if isinstance(node, AsyncFunctionDef):
   565→            new_memo.is_async = True
   566→
   567→        yield
   568→        self._memo = old_memo
   570→    def _get_import(self, module: str, name: str) -> Name:
   571→        memo = self._memo if self._target_path else self._module_memo
   572→        return memo.get_import(module, name)
   580→    def _convert_annotation(self, annotation: expr | None) -> expr | None:
   581→        if annotation is None:
   582→            return None
   583→
   584→        # Convert PEP 604 unions (x | y) and generic built-in collections where
   585→        # necessary, and undo forward references
   586→        new_annotation = cast(expr, AnnotationTransformer(self).visit(annotation))
   587→        if isinstance(new_annotation, expr):
   588→            new_annotation = ast.copy_location(new_annotation, annotation)
   589→
   590→            # Store names used in the annotation
   591→            names = {node.id for node in walk(new_annotation) if isinstance(node, Name)}
   592→            self.names_used_in_annotations.update(names)
   593→
   594→        return new_annotation

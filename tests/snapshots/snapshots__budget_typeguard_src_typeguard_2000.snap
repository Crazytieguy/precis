    14тЖТclass ForwardRefPolicy(Enum):
    15тЖТ    """
    16тЖТ    Defines how unresolved forward references are handled.
    17тЖТ
    18тЖТ    Members:
    19тЖТ
    20тЖТ    * ``ERROR``: propagate the :exc:`NameError` when the forward reference lookup fails
    21тЖТ    * ``WARN``: emit a :class:`~.TypeHintWarning` if the forward reference lookup fails
    22тЖТ    * ``IGNORE``: silently skip checks for unresolveable forward references
    23тЖТ    """
    24тЖТ
    25тЖТ    ERROR = auto()
    26тЖТ    WARN = auto()
    27тЖТ    IGNORE = auto()
    30тЖТclass CollectionCheckStrategy(Enum):
    31тЖТ    """
    32тЖТ    Specifies how thoroughly the contents of collections are type checked.
    33тЖТ
    34тЖТ    This has an effect on the following built-in checkers:
    35тЖТ
    36тЖТ    * ``AbstractSet``
    37тЖТ    * ``Dict``
    38тЖТ    * ``List``
    39тЖТ    * ``Mapping``
    40тЖТ    * ``Set``
    41тЖТ    * ``Tuple[<type>, ...]`` (arbitrarily sized tuples)
    42тЖТ
    43тЖТ    Members:
    44тЖТ
    45тЖТ    * ``FIRST_ITEM``: check only the first item
    46тЖТ    * ``ALL_ITEMS``: check all items
    47тЖТ    """
    48тЖТ
    49тЖТ    FIRST_ITEM = auto()
    50тЖТ    ALL_ITEMS = auto()

   488тЖТclass TypeguardTransformer(NodeTransformer):
   489тЖТ    def __init__ тАж
   498тЖТ    def generic_visit тАж
   516тЖТ    @contextmanager
   517тЖТ    def _use_memo(
   518тЖТ        self, node: ClassDef | FunctionDef | AsyncFunctionDef
   519тЖТ    ) -> Generator[None, Any, None]:
   520тЖТ        new_memo = TransformMemo(node, self._memo, self._memo.path + (node.name,))
   521тЖТ        old_memo = self._memo
   522тЖТ        self._memo = new_memo
   523тЖТ
   524тЖТ        if isinstance(node, (FunctionDef, AsyncFunctionDef)):
   525тЖТ            new_memo.should_instrument = (
   526тЖТ                self._target_path is None or new_memo.path == self._target_path
   527тЖТ            )
   528тЖТ            if new_memo.should_instrument:
   529тЖТ                # Check if the function is a generator function
   530тЖТ                detector = GeneratorDetector()
   531тЖТ                detector.visit(node)
   532тЖТ
   533тЖТ                # Extract yield, send and return types where possible from a subscripted
   534тЖТ                # annotation like Generator[int, str, bool]
   535тЖТ                return_annotation = deepcopy(node.returns)
   536тЖТ                if detector.contains_yields and new_memo.name_matches(
   537тЖТ                    return_annotation, *generator_names
   538тЖТ                ):
   539тЖТ                    if isinstance(return_annotation, Subscript):
   540тЖТ                        if isinstance(return_annotation.slice, Tuple):
   541тЖТ                            items = return_annotation.slice.elts
   542тЖТ                        else:
   543тЖТ                            items = [return_annotation.slice]
   544тЖТ
   545тЖТ                        if len(items) > 0:
   546тЖТ                            new_memo.yield_annotation = self._convert_annotation(
   547тЖТ                                items[0]
   548тЖТ                            )
   549тЖТ
   550тЖТ                        if len(items) > 1:
   551тЖТ                            new_memo.send_annotation = self._convert_annotation(
   552тЖТ                                items[1]
   553тЖТ                            )
   554тЖТ
   555тЖТ                        if len(items) > 2:
   556тЖТ                            new_memo.return_annotation = self._convert_annotation(
   557тЖТ                                items[2]
   558тЖТ                            )
   559тЖТ                else:
   560тЖТ                    new_memo.return_annotation = self._convert_annotation(
   561тЖТ                        return_annotation
   562тЖТ                    )
   563тЖТ
   564тЖТ        if isinstance(node, AsyncFunctionDef):
   565тЖТ            new_memo.is_async = True
   566тЖТ
   567тЖТ        yield
   568тЖТ        self._memo = old_memo
   570тЖТ    def _get_import(self, module: str, name: str) -> Name:
   571тЖТ        memo = self._memo if self._target_path else self._module_memo
   572тЖТ        return memo.get_import(module, name)
   580тЖТ    def _convert_annotation(self, annotation: expr | None) -> expr | None:
   581тЖТ        if annotation is None:
   582тЖТ            return None
   583тЖТ
   584тЖТ        # Convert PEP 604 unions (x | y) and generic built-in collections where
   585тЖТ        # necessary, and undo forward references
   586тЖТ        new_annotation = cast(expr, AnnotationTransformer(self).visit(annotation))
   587тЖТ        if isinstance(new_annotation, expr):
   588тЖТ            new_annotation = ast.copy_location(new_annotation, annotation)
   589тЖТ
   590тЖТ            # Store names used in the annotation
   591тЖТ            names = {node.id for node in walk(new_annotation) if isinstance(node, Name)}
   592тЖТ            self.names_used_in_annotations.update(names)
   593тЖТ
   594тЖТ        return new_annotation

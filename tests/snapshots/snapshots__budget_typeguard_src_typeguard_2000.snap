    55тЖТclass TypeguardLoader(SourceFileLoader):
    56тЖТ    @staticmethod
    57тЖТ    def source_to_code(
    58тЖТ        data: Buffer | str | ast.Module | ast.Expression | ast.Interactive,
    59тЖТ        path: Buffer | str | PathLike[str] = "<string>",
    60тЖТ        *,
    61тЖТ        _optimize: int = -1,
    62тЖТ    ) -> CodeType:
    63тЖТ        if isinstance(path, (str, PathLike)):
    64тЖТ            filename = path
    65тЖТ        else:
    66тЖТ            filename = os.fsdecode(bytes(path))
    67тЖТ
    68тЖТ        if isinstance(data, (ast.Module, ast.Expression, ast.Interactive)):
    69тЖТ            module = data
    70тЖТ        else:
    71тЖТ            if isinstance(data, str):
    72тЖТ                source = data
    73тЖТ            else:
    74тЖТ                source = decode_source(data)
    75тЖТ
    76тЖТ            module = _call_with_frames_removed(
    77тЖТ                ast.parse,
    78тЖТ                source,
    79тЖТ                filename,
    80тЖТ                "exec",
    81тЖТ            )
    82тЖТ
    83тЖТ        tree = TypeguardTransformer().visit(module)
    84тЖТ        ast.fix_missing_locations(tree)
    85тЖТ
    86тЖТ        if global_config.debug_instrumentation and sys.version_info >= (3, 9):
    87тЖТ            print(
    88тЖТ                f"Source code of {path!r} after instrumentation:\n"
    89тЖТ                "----------------------------------------------",
    90тЖТ                file=sys.stderr,
    91тЖТ            )
    92тЖТ            print(ast.unparse(tree), file=sys.stderr)
    93тЖТ            print("----------------------------------------------", file=sys.stderr)
    94тЖТ
    95тЖТ        return _call_with_frames_removed(
    96тЖТ            compile, tree, filename, "exec", 0, dont_inherit=True
    97тЖТ        )

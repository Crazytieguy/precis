   488‚Üíclass TypeguardTransformer(NodeTransformer):
   489‚Üí    def __init__ ‚Ä¶
   498‚Üí    def generic_visit ‚Ä¶
   516‚Üí    @contextmanager
   517‚Üí    def _use_memo(
   518‚Üí        self, node: ClassDef | FunctionDef | AsyncFunctionDef
   519‚Üí    ) -> Generator[None, Any, None]:
   520‚Üí        new_memo = TransformMemo(node, self._memo, self._memo.path + (node.name,))
   521‚Üí        old_memo = self._memo
   522‚Üí        self._memo = new_memo
   523‚Üí
   524‚Üí        if isinstance(node, (FunctionDef, AsyncFunctionDef)):
   525‚Üí            new_memo.should_instrument = (
   526‚Üí                self._target_path is None or new_memo.path == self._target_path
   527‚Üí            )
   528‚Üí            if new_memo.should_instrument:
   529‚Üí                # Check if the function is a generator function
   530‚Üí                detector = GeneratorDetector()
   531‚Üí                detector.visit(node)
   532‚Üí
   533‚Üí                # Extract yield, send and return types where possible from a subscripted
   534‚Üí                # annotation like Generator[int, str, bool]
   535‚Üí                return_annotation = deepcopy(node.returns)
   536‚Üí                if detector.contains_yields and new_memo.name_matches(
   537‚Üí                    return_annotation, *generator_names
   538‚Üí                ):
   539‚Üí                    if isinstance(return_annotation, Subscript):
   540‚Üí                        if isinstance(return_annotation.slice, Tuple):
   541‚Üí                            items = return_annotation.slice.elts
   542‚Üí                        else:
   543‚Üí                            items = [return_annotation.slice]
   544‚Üí
   545‚Üí                        if len(items) > 0:
   546‚Üí                            new_memo.yield_annotation = self._convert_annotation(
   547‚Üí                                items[0]
   548‚Üí                            )
   549‚Üí
   550‚Üí                        if len(items) > 1:
   551‚Üí                            new_memo.send_annotation = self._convert_annotation(
   552‚Üí                                items[1]
   553‚Üí                            )
   554‚Üí
   555‚Üí                        if len(items) > 2:
   556‚Üí                            new_memo.return_annotation = self._convert_annotation(
   557‚Üí                                items[2]
   558‚Üí                            )
   559‚Üí                else:
   560‚Üí                    new_memo.return_annotation = self._convert_annotation(
   561‚Üí                        return_annotation
   562‚Üí                    )
   563‚Üí
      ‚Üí‚Ä¶
   570‚Üí    def _get_import(self, module: str, name: str) -> Name:
   571‚Üí        memo = self._memo if self._target_path else self._module_memo
   572‚Üí        return memo.get_import(module, name)
   580‚Üí    def _convert_annotation(self, annotation: expr | None) -> expr | None:
   581‚Üí        if annotation is None:
   582‚Üí            return None
   583‚Üí
   584‚Üí        # Convert PEP 604 unions (x | y) and generic built-in collections where
   585‚Üí        # necessary, and undo forward references
   586‚Üí        new_annotation = cast(expr, AnnotationTransformer(self).visit(annotation))
   587‚Üí        if isinstance(new_annotation, expr):
   588‚Üí            new_annotation = ast.copy_location(new_annotation, annotation)
   589‚Üí
   590‚Üí            # Store names used in the annotation
   591‚Üí            names = {node.id for node in walk(new_annotation) if isinstance(node, Name)}
   592‚Üí            self.names_used_in_annotations.update(names)
   593‚Üí
   594‚Üí        return new_annotation

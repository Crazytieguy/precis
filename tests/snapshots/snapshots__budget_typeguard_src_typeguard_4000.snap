    55→class TypeguardLoader(SourceFileLoader):
    56→    @staticmethod
    57→    def source_to_code(
    58→        data: Buffer | str | ast.Module | ast.Expression | ast.Interactive,
    59→        path: Buffer | str | PathLike[str] = "<string>",
    60→        *,
    61→        _optimize: int = -1,
    62→    ) -> CodeType:
    63→        if isinstance(path, (str, PathLike)):
    64→            filename = path
    65→        else:
    66→            filename = os.fsdecode(bytes(path))
    67→
    68→        if isinstance(data, (ast.Module, ast.Expression, ast.Interactive)):
    69→            module = data
    70→        else:
    71→            if isinstance(data, str):
    72→                source = data
    73→            else:
    74→                source = decode_source(data)
    75→
    76→            module = _call_with_frames_removed(
    77→                ast.parse,
    78→                source,
    79→                filename,
    80→                "exec",
    81→            )
    82→
    83→        tree = TypeguardTransformer().visit(module)
    84→        ast.fix_missing_locations(tree)
    85→
    86→        if global_config.debug_instrumentation and sys.version_info >= (3, 9):
    87→            print(
    88→                f"Source code of {path!r} after instrumentation:\n"
    89→                "----------------------------------------------",
    90→                file=sys.stderr,
    91→            )
    92→            print(ast.unparse(tree), file=sys.stderr)
    93→            print("----------------------------------------------", file=sys.stderr)
    94→
    95→        return _call_with_frames_removed(
    96→            compile, tree, filename, "exec", 0, dont_inherit=True
    97→        )
    98→
    99→    def exec_module(self, module: ModuleType) -> None:
   100→        # Use a custom optimization marker – the import lock should make this monkey
   101→        # patch safe
   102→        with patch(
   103→            "importlib._bootstrap_external.cache_from_source",
   104→            optimized_cache_from_source,
   105→        ):
   106→            super().exec_module(module)
   109→class TypeguardFinder(MetaPathFinder):
   119→
   120→    def __init__(self, packages: list[str] | None, original_pathfinder: MetaPathFinder):
   121→        self.packages = packages
   122→        self._original_pathfinder = original_pathfinder
   123→
   124→    def find_spec(
   125→        self,
   126→        fullname: str,
   127→        path: Sequence[str] | None,
   128→        target: types.ModuleType | None = None,
   129→    ) -> ModuleSpec | None:
   130→        if self.should_instrument(fullname):
   131→            spec = self._original_pathfinder.find_spec(fullname, path, target)
   132→            if spec is not None and isinstance(spec.loader, SourceFileLoader):
   133→                spec.loader = TypeguardLoader(spec.loader.name, spec.loader.path)
   134→                return spec
   135→
   136→        return None
   137→
   138→    def should_instrument(self, module_name: str) -> bool:
   139→        """
   140→        Determine whether the module with the given name should be instrumented.
   141→
   142→        :param module_name: full name of the module that is about to be imported (e.g.
   143→            ``xyz.abc``)
   144→
   145→        """
   146→        if self.packages is None:
   147→            return True
   148→
   149→        for package in self.packages:
   150→            if module_name == package or module_name.startswith(package + "."):
   151→                return True
   152→
   153→        return False

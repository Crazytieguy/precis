   109→class TypeguardFinder(MetaPathFinder):
   119→
   120→    def __init__(self, packages: list[str] | None, original_pathfinder: MetaPathFinder):
   121→        self.packages = packages
   122→        self._original_pathfinder = original_pathfinder
   123→
   124→    def find_spec(
   125→        self,
   126→        fullname: str,
   127→        path: Sequence[str] | None,
   128→        target: types.ModuleType | None = None,
   129→    ) -> ModuleSpec | None:
   130→        if self.should_instrument(fullname):
   131→            spec = self._original_pathfinder.find_spec(fullname, path, target)
   132→            if spec is not None and isinstance(spec.loader, SourceFileLoader):
   133→                spec.loader = TypeguardLoader(spec.loader.name, spec.loader.path)
   134→                return spec
   135→
   136→        return None
   137→
   138→    def should_instrument(self, module_name: str) -> bool:
   139→        """
   140→        Determine whether the module with the given name should be instrumented.
   141→
   142→        :param module_name: full name of the module that is about to be imported (e.g.
   143→            ``xyz.abc``)
   144→
   145→        """
   146→        if self.packages is None:
   147→            return True
   148→
   149→        for package in self.packages:
   150→            if module_name == package or module_name.startswith(package + "."):
   151→                return True
   152→
   153→        return False

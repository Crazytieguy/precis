    14‚Üíclass ForwardRefPolicy(Enum):
    15‚Üí    """
    16‚Üí    Defines how unresolved forward references are handled.
    17‚Üí
    18‚Üí    Members:
    19‚Üí
    20‚Üí    * ``ERROR``: propagate the :exc:`NameError` when the forward reference lookup fails
    21‚Üí    * ``WARN``: emit a :class:`~.TypeHintWarning` if the forward reference lookup fails
    22‚Üí    * ``IGNORE``: silently skip checks for unresolveable forward references
    23‚Üí    """
    24‚Üí
    25‚Üí    ERROR = auto()
    26‚Üí    WARN = auto()
    27‚Üí    IGNORE = auto()
    30‚Üíclass CollectionCheckStrategy(Enum):
    31‚Üí    """
    32‚Üí    Specifies how thoroughly the contents of collections are type checked.
    33‚Üí
    34‚Üí    This has an effect on the following built-in checkers:
    35‚Üí
    36‚Üí    * ``AbstractSet``
    37‚Üí    * ``Dict``
    38‚Üí    * ``List``
    39‚Üí    * ``Mapping``
    40‚Üí    * ``Set``
    41‚Üí    * ``Tuple[<type>, ...]`` (arbitrarily sized tuples)
    42‚Üí
    43‚Üí    Members:
    44‚Üí
    45‚Üí    * ``FIRST_ITEM``: check only the first item
    46‚Üí    * ``ALL_ITEMS``: check all items
    47‚Üí    """
    48‚Üí
    49‚Üí    FIRST_ITEM = auto()
    50‚Üí    ALL_ITEMS = auto()
    51‚Üí

   414→            if isinstance(node.slice, Tuple):
   415→                if self._memo.name_matches(node.value, *annotated_names):
   416→                    # Only treat the first argument to typing.Annotated as a potential
   417→                    # forward reference
   418→                    items = cast(
   419→                        typing.List[expr],

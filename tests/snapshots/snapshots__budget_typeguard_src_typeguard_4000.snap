    67→PreliminaryNameTypePair: typing.TypeAlias = tuple[Constant, "expr | None"]
    68→NameTypePair: typing.TypeAlias = tuple[Constant, expr]
   117→@dataclass
   118→class TransformMemo:
   119→    node: Module | ClassDef | FunctionDef | AsyncFunctionDef | None
   120→    parent: TransformMemo | None
   121→    path: tuple[str, ...]
   122→    joined_path: Constant = field(init=False)
   123→    return_annotation: expr | None = None
   124→    yield_annotation: expr | None = None
   125→    send_annotation: expr | None = None
   126→    is_async: bool = False
   127→    local_names: set[str] = field(init=False, default_factory=set)
   128→    imported_names: dict[str, str] = field(init=False, default_factory=dict)
   129→    ignored_names: set[str] = field(init=False, default_factory=set)
   130→    load_names: defaultdict[str, dict[str, Name]] = field(
   131→        init=False, default_factory=lambda: defaultdict(dict)
   132→    )
   133→    has_yield_expressions: bool = field(init=False, default=False)
   134→    has_return_expressions: bool = field(init=False, default=False)
   135→    memo_var_name: Name | None = field(init=False, default=None)
   136→    should_instrument: bool = field(init=False, default=True)
   137→    variable_annotations: dict[str, expr] = field(init=False, default_factory=dict)
   138→    configuration_overrides: dict[str, Any] = field(init=False, default_factory=dict)
   139→    code_inject_index: int = field(init=False, default=0)
   140→
   141→    def __post_init__(self) -> None:
   142→        elements: list[str] = []
   143→        memo = self
   144→        while isinstance(memo.node, (ClassDef, FunctionDef, AsyncFunctionDef)):
   145→            elements.insert(0, memo.node.name)
   146→            if not memo.parent:
   147→                break
   148→
   149→            memo = memo.parent
   150→            if isinstance(memo.node, (FunctionDef, AsyncFunctionDef)):
   151→                elements.insert(0, "<locals>")
   152→
   153→        self.joined_path = Constant(".".join(elements))
   154→
   155→        # Figure out where to insert instrumentation code
   156→        if self.node:
   157→            for index, child in enumerate(self.node.body):
   158→                if isinstance(child, ImportFrom) and child.module == "__future__":
   159→                    # (module only) __future__ imports must come first
   160→                    continue
   161→                elif (
   162→                    isinstance(child, Expr)
   163→                    and isinstance(child.value, Constant)
   164→                    and isinstance(child.value.value, str)
   165→                ):
   166→                    continue  # docstring
   167→
   168→                self.code_inject_index = index
   169→                break
   170→
   171→    def get_unused_name(self, name: str) -> str:
   172→        memo: TransformMemo | None = self
   173→        while memo is not None:
   174→            if name in memo.local_names:
   175→                memo = self
   176→                name += "_"
   177→            else:
   178→                memo = memo.parent
   179→
   180→        self.local_names.add(name)
   181→        return name
   182→
   183→    def is_ignored_name(self, expression: expr | Expr | None) -> bool:
   184→        top_expression = (
   185→            expression.value if isinstance(expression, Expr) else expression
   186→        )
   187→
   188→        if isinstance(top_expression, Attribute) and isinstance(
   189→            top_expression.value, Name
   190→        ):
   191→            name = top_expression.value.id
   192→        elif isinstance(top_expression, Name):
   193→            name = top_expression.id
   194→        else:
   195→            return False
   196→
   197→        memo: TransformMemo | None = self
   198→        while memo is not None:
   199→            if name in memo.ignored_names:
   200→                return True
   201→
   202→            memo = memo.parent
   203→
   204→        return False
   205→
   206→    def get_memo_name(self) -> Name:
   207→        if not self.memo_var_name:
   208→            self.memo_var_name = Name(id="memo", ctx=Load())
   209→
   210→        return self.memo_var_name
   211→
   212→    def get_import(self, module: str, name: str) -> Name:
   213→        if module in self.load_names and name in self.load_names[module]:
   214→            return self.load_names[module][name]
   215→
   216→        qualified_name = f"{module}.{name}"
   217→        if name in self.imported_names and self.imported_names[name] == qualified_name:
   218→            return Name(id=name, ctx=Load())
   219→
   220→        alias = self.get_unused_name(name)
   221→        node = self.load_names[module][name] = Name(id=alias, ctx=Load())
   222→        self.imported_names[name] = qualified_name
   223→        return node
   224→
   225→    def insert_imports(self, node: Module | FunctionDef | AsyncFunctionDef) -> None:
   226→        """Insert imports needed by injected code."""
   227→        if not self.load_names:
   228→            return
   229→
   230→        # Insert imports after any "from __future__ ..." imports and any docstring
   231→        for modulename, names in self.load_names.items():
   232→            aliases = [
   233→                alias(orig_name, new_name.id if orig_name != new_name.id else None)
   234→                for orig_name, new_name in sorted(names.items())
   235→            ]
   236→            node.body.insert(self.code_inject_index, ImportFrom(modulename, aliases, 0))
   237→
   238→    def name_matches(self, expression: expr | Expr | None, *names: str) -> bool:
   239→        if expression is None:
   240→            return False
   241→
   242→        path: list[str] = []
   243→        top_expression = (
   244→            expression.value if isinstance(expression, Expr) else expression
   245→        )
   246→
   247→        if isinstance(top_expression, Subscript):
   248→            top_expression = top_expression.value
   249→        elif isinstance(top_expression, Call):
   250→            top_expression = top_expression.func
   251→
   252→        while isinstance(top_expression, Attribute):
   253→            path.insert(0, top_expression.attr)
   254→            top_expression = top_expression.value
   255→
   256→        if not isinstance(top_expression, Name):
   257→            return False
   258→
   259→        if top_expression.id in self.imported_names:
   260→            translated = self.imported_names[top_expression.id]
   261→        elif hasattr(builtins, top_expression.id):
   262→            translated = "builtins." + top_expression.id
   263→        else:
   264→            translated = top_expression.id
   265→
   266→        path.insert(0, translated)
   267→        joined_path = ".".join(path)
   268→        if joined_path in names:
   269→            return True
   270→        elif self.parent:
   271→            return self.parent.name_matches(expression, *names)
   272→        else:
   273→            return False
   274→
   275→    def get_config_keywords(self) -> list[keyword]:
   276→        if self.parent and isinstance(self.parent.node, ClassDef):
   277→            overrides = self.parent.configuration_overrides.copy()
   278→        else:
   279→            overrides = {}
   280→
   281→        overrides.update(self.configuration_overrides)
   282→        return [keyword(key, value) for key, value in overrides.items()]
   285→class NameCollector(NodeVisitor):
   286→    def __init__(self) -> None:
   287→        self.names: set[str] = set()
   288→
   289→    def visit_Import(self, node: Import) -> None:
   290→        for name in node.names:
   291→            self.names.add(name.asname or name.name)
   292→
   293→    def visit_ImportFrom(self, node: ImportFrom) -> None:
   294→        for name in node.names:
   295→            self.names.add(name.asname or name.name)
   296→
   297→    def visit_Assign(self, node: Assign) -> None:
   298→        for target in node.targets:
   299→            if isinstance(target, Name):
   300→                self.names.add(target.id)
   301→
   302→    def visit_NamedExpr(self, node: NamedExpr) -> Any:
   303→        if isinstance(node.target, Name):
   304→            self.names.add(node.target.id)
   305→
   306→    def visit_FunctionDef(self, node: FunctionDef) -> None:
   307→        pass
   308→
   309→    def visit_ClassDef(self, node: ClassDef) -> None:
   310→        pass
   313→class GeneratorDetector(NodeVisitor):
   315→
   316→    contains_yields: bool = False
   317→    in_root_function: bool = False
   318→
   319→    def visit_Yield(self, node: Yield) -> Any:
   320→        self.contains_yields = True
   321→
   322→    def visit_YieldFrom(self, node: YieldFrom) -> Any:
   323→        self.contains_yields = True
   324→
   325→    def visit_ClassDef(self, node: ClassDef) -> Any:
   326→        pass
   327→
   328→    def visit_FunctionDef(self, node: FunctionDef | AsyncFunctionDef) -> Any:
   329→        if not self.in_root_function:
   330→            self.in_root_function = True
   331→            self.generic_visit(node)
   332→            self.in_root_function = False
   333→
   334→    def visit_AsyncFunctionDef(self, node: AsyncFunctionDef) -> Any:
   335→        self.visit_FunctionDef(node)
   338→class AnnotationTransformer(NodeTransformer):
   339→    type_substitutions: ClassVar[dict[str, tuple[str, str]]] = {
   340→        "builtins.dict": ("typing", "Dict"),
   341→        "builtins.list": ("typing", "List"),
   342→        "builtins.tuple": ("typing", "Tuple"),
   343→        "builtins.set": ("typing", "Set"),
   344→        "builtins.frozenset": ("typing", "FrozenSet"),
   345→    }
   346→
   347→    def __init__(self, transformer: TypeguardTransformer):
   348→        self.transformer = transformer
   349→        self._memo = transformer._memo
   350→        self._level = 0
   351→
   352→    def visit(self, node: AST) -> Any:
   353→        # Don't process Literals
   354→        if isinstance(node, expr) and self._memo.name_matches(node, *literal_names):
   355→            return node
   356→
   357→        self._level += 1
   358→        new_node = super().visit(node)
   359→        self._level -= 1
   360→
   361→        if isinstance(new_node, Expression) and not hasattr(new_node, "body"):
   362→            return None
   363→
   364→        # Return None if this new node matches a variation of typing.Any
   365→        if (
   366→            self._level == 0
   367→            and isinstance(new_node, expr)
   368→            and self._memo.name_matches(new_node, *anytype_names)
   369→        ):
   370→            return None
   371→
   372→        return new_node
   373→
   374→    def visit_BinOp(self, node: BinOp) -> Any:
   375→        self.generic_visit(node)
   376→
   377→        if isinstance(node.op, BitOr):
   378→            # If either branch of the BinOp has been transformed to `None`, it means
   379→            # that a type in the union was ignored, so the entire annotation should be
   380→            # ignored
   381→            if not hasattr(node, "left") or not hasattr(node, "right"):
   382→                return None
   383→
   384→            # Return Any if either side is Any
   385→            if self._memo.name_matches(node.left, *anytype_names):
   386→                return node.left
   387→            elif self._memo.name_matches(node.right, *anytype_names):
   388→                return node.right
   389→
   390→            # Turn union types to typing.Union constructs on Python 3.9
   391→            if sys.version_info < (3, 10):
   392→                union_name = self.transformer._get_import("typing", "Union")
   393→                return Subscript(
   394→                    value=union_name,
   395→                    slice=Tuple(elts=[node.left, node.right], ctx=Load()),
   396→                    ctx=Load(),
   397→                )
   398→
   399→        return node
   400→
   401→    def visit_Attribute(self, node: Attribute) -> Any:
   402→        if self._memo.is_ignored_name(node):
   403→            return None
   404→
   405→        return node
   406→
   407→    def visit_Subscript(self, node: Subscript) -> Any:

    55‚Üíclass TypeguardLoader(SourceFileLoader):
    56‚Üí    @staticmethod
    57‚Üí    def source_to_code(
    58‚Üí        data: Buffer | str | ast.Module | ast.Expression | ast.Interactive,
    59‚Üí        path: Buffer | str | PathLike[str] = "<string>",
    60‚Üí        *,
    61‚Üí        _optimize: int = -1,
    62‚Üí    ) -> CodeType:
    63‚Üí        if isinstance(path, (str, PathLike)):
    64‚Üí            filename = path
    65‚Üí        else:
    66‚Üí            filename = os.fsdecode(bytes(path))
    67‚Üí
    68‚Üí        if isinstance(data, (ast.Module, ast.Expression, ast.Interactive)):
    69‚Üí            module = data
    70‚Üí        else:
    71‚Üí            if isinstance(data, str):
    72‚Üí                source = data
    73‚Üí            else:
    74‚Üí                source = decode_source(data)
    75‚Üí
    76‚Üí            module = _call_with_frames_removed(
    77‚Üí                ast.parse,
    78‚Üí                source,
    79‚Üí                filename,
    80‚Üí                "exec",
    81‚Üí            )
    82‚Üí
    83‚Üí        tree = TypeguardTransformer().visit(module)
    84‚Üí        ast.fix_missing_locations(tree)
    85‚Üí
    86‚Üí        if global_config.debug_instrumentation and sys.version_info >= (3, 9):
    87‚Üí            print(
    88‚Üí                f"Source code of {path!r} after instrumentation:\n"
    89‚Üí                "----------------------------------------------",
    90‚Üí                file=sys.stderr,
    91‚Üí            )
    92‚Üí            print(ast.unparse(tree), file=sys.stderr)
    93‚Üí            print("----------------------------------------------", file=sys.stderr)
    94‚Üí
    95‚Üí        return _call_with_frames_removed(
    96‚Üí            compile, tree, filename, "exec", 0, dont_inherit=True
    97‚Üí        )
   109‚Üíclass TypeguardFinder(MetaPathFinder):

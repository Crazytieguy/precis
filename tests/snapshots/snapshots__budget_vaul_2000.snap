   105→/**
   106→ * Receives functions as arguments and returns a new function that calls all.
   107→ */
   108→export function chain<T>(...fns: T[]) {
   109→  return (...args: T extends AnyFunction ? Parameters<T> : never) => {
   110→    for (const fn of fns) {
   111→      if (typeof fn === 'function') {
   112→        // @ts-ignore
   113→        fn(...args);
   114→      }
   115→    }
   116→  };
   117→}

    68→export function usePreventScroll(options: PreventScrollOptions = {}) {
    69→  let { isDisabled } = options;
    70→
    71→  useIsomorphicLayoutEffect(() => {
    72→    if (isDisabled) {
    73→      return;
    74→    }
    75→

    63→/**
    64→ * Prevents scrolling on the document body on mount, and
    65→ * restores it on unmount. Also ensures that content does not
    66→ * shift due to the scrollbars disappearing.
    67→ */
    68→export function usePreventScroll(options: PreventScrollOptions = {}) {
    69→  let { isDisabled } = options;
    70→
    71→  useIsomorphicLayoutEffect(() => {
    72→    if (isDisabled) {
    73→      return;
    74→    }
    75→
    76→    preventScrollCount++;
    77→    if (preventScrollCount === 1) {
    78→      if (isIOS()) {
    79→        restore = preventScrollMobileSafari();
    80→      }
    81→    }
    82→
    83→    return () => {
    84→      preventScrollCount--;
    85→      if (preventScrollCount === 0) {
    86→        restore?.();
    87→      }
    88→    };
    89→  }, [isDisabled]);
    90→}

   122→      restorePositionSetting();
   123→    };
   124→  }, [modal, restorePositionSetting]);
   125→
   126→  React.useEffect(() => {
   127→    if (nested || !hasBeenOpened) return;
   128→    // This is needed to force Safari toolbar to show **before** the drawer starts animating to prevent a gnarly shift from happening
   129→    if (isOpen) {
   130→      // avoid for standalone mode (PWA)

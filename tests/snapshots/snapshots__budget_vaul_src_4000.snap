   109→    };
   110→  }, []);
   111→
   112→  React.useEffect(() => {
   113→    if (!modal) return;
   114→
   115→    return () => {
   116→      if (typeof document === 'undefined') return;
   117→
   118→      // Another drawer is opened, safe to ignore the execution
   119→      const hasDrawerOpened = !!document.querySelector('[data-vaul-drawer]');
   120→      if (hasDrawerOpened) return;

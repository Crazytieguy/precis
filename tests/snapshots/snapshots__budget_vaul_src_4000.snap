     3→import React from 'react';
     5→type UseControllableStateParams<T> = {
     6→  prop?: T | undefined;
     7→  defaultProp?: T | undefined;
     8→  onChange?: (state: T) => void;
     9→};
    11→type SetStateFn<T> = (prevState?: T) => T;
    13→function useCallbackRef<T extends (...args: any[]) => any>(callback: T | undefined): T {
    14→  const callbackRef = React.useRef(callback);
    15→
      →…
    24→function useUncontrolledState<T>({ defaultProp, onChange }: Omit<UseControllableStateParams<T>, 'prop'>) {
    25→  const uncontrolledState = React.useState<T | undefined>(defaultProp);
    26→  const [value] = uncontrolledState;
      →…
    39→export function useControllableState<T>({ prop, defaultProp, onChange = () => {} }: UseControllableStateParams<T>) {
    40→  const [uncontrolledProp, setUncontrolledProp] = useUncontrolledState({ defaultProp, onChange });
    41→  const isControlled = prop !== undefined;
    42→  const value = isControlled ? prop : uncontrolledProp;
    43→  const handleChange = useCallbackRef(onChange);
    44→
    45→  const setValue: React.Dispatch<React.SetStateAction<T | undefined>> = React.useCallback(
    46→    (nextValue) => {
    47→      if (isControlled) {
    48→        const setter = nextValue as SetStateFn<T>;
    49→        const value = typeof nextValue === 'function' ? setter(prop) : nextValue;
    50→        if (value !== prop) handleChange(value as T);
    51→      } else {
    52→        setUncontrolledProp(nextValue);
    53→      }
    54→    },
    55→    [isControlled, prop, setUncontrolledProp, handleChange],
    56→  );
    57→
    58→  return [value, setValue] as const;
    59→}

use-position-fixed.ts
     1→import React from 'react';
     2→import { isSafari } from './browser';
     6→/**
     7→ * This hook is necessary to prevent buggy behavior on iOS devices (need to test on Android).
     8→ * I won't get into too much detail about what bugs it solves, but so far I've found that setting the body to `position: fixed` is the most reliable way to prevent those bugs.
     9→ * Issues that this hook solves:
    10→ * https://github.com/emilkowalski/vaul/issues/435
    11→ * https://github.com/emilkowalski/vaul/issues/433
    12→ * And more that I discovered, but were just not reported.
    13→ */
    14→
    15→export function usePositionFixed({
    16→  isOpen,
    17→  modal,
    18→  nested,
    19→  hasBeenOpened,
    20→  preventScrollRestoration,
    21→  noBodyStyles,
    22→}: {
    23→  isOpen: boolean;
    24→  modal: boolean;
    25→  nested: boolean;
    26→  hasBeenOpened: boolean;
    27→  preventScrollRestoration: boolean;
    28→  noBodyStyles: boolean;
    29→}) {
    30→  const [activeUrl, setActiveUrl] = React.useState(() => (typeof window !== 'undefined' ? window.location.href : ''));
    31→  const scrollPos = React.useRef(0);
    32→
    33→  const setPositionFixed = React.useCallback(() => {
    34→    // All browsers on iOS will return true here.
    35→    if (!isSafari()) return;

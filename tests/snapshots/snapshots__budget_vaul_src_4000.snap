   134→      if (!modal) {
   135→        window.setTimeout(() => {
   136→          restorePositionSetting();
   137→        }, 500);
   138→      }
   139→    } else {
   140→      restorePositionSetting();
   141→    }
   142→  }, [isOpen, hasBeenOpened, activeUrl, modal, nested, setPositionFixed, restorePositionSetting]);
   143→
   144→  return { restorePositionSetting };
   145→}


    48→      const { scrollX, innerHeight } = window;
    49→
    50→      document.body.style.setProperty('position', 'fixed', 'important');
    51→      Object.assign(document.body.style, {
    52→        top: `${-scrollPos.current}px`,
    53→        left: `${-scrollX}px`,
    54→        right: '0px',
    55→        height: 'auto',
    56→      });
    57→
    58→      window.setTimeout(
    59→        () =>

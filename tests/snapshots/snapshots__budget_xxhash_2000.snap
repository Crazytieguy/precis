    36Ôćĺ// Sum64String computes the 64-bit xxHash digest of s with a zero seed.
    37Ôćĺ// It may be faster than Sum64([]byte(s)) by avoiding a copy.
    38Ôćĺfunc Sum64String(s string) uint64 {
    39Ôćĺ	b := *(*[]byte)(unsafe.Pointer(&sliceHeader{s, len(s)}))
    40Ôćĺ	return Sum64(b)
    41Ôćĺ}
    43Ôćĺ// WriteString adds more data to d. It always returns len(s), nil.
    44Ôćĺ// It may be faster than Write([]byte(s)) by avoiding a copy.
    45Ôćĺfunc (d *Digest) WriteString(s string) (n int, err error) {
    46Ôćĺ	d.Write(*(*[]byte)(unsafe.Pointer(&sliceHeader{s, len(s)})))
    47Ôćĺ	// d.Write always returns len(s), nil.
    48Ôćĺ	// Ignoring the return output and returning these fixed values buys a
    49Ôćĺ	// savings of 6 in the inliner's cost model.
    50Ôćĺ	return len(s), nil
    51Ôćĺ}
    53Ôćĺ// sliceHeader is similar to reflect.SliceHeader, but it assumes that the layout
    54Ôćĺ// of the first two words is the same as the layout of a string.
    55Ôćĺtype sliceHeader struct {
    56Ôćĺ	s   string
    57Ôćĺ	cap int
    58Ôćĺ}

   112â†’// Sum appends the current hash to b and returns the resulting slice.
   113â†’func (d *Digest) Sum(b []byte) []byte {
   114â†’	s := d.Sum64()
   115â†’	return append(
   116â†’		b,
   117â†’		byte(s>>56),
   118â†’		byte(s>>48),
   119â†’		byte(s>>40),
   120â†’		byte(s>>32),
   121â†’		byte(s>>24),
   122â†’		byte(s>>16),
   123â†’		byte(s>>8),
   124â†’		byte(s),
   125â†’	)
   126â†’}

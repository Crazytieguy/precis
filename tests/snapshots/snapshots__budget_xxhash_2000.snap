   170â†’const (
   171â†’	magic         = "xxh\x06"
   172â†’	marshaledSize = len(magic) + 8*5 + 32
   173â†’)
   175â†’// MarshalBinary implements the encoding.BinaryMarshaler interface.
   176â†’func (d *Digest) MarshalBinary() ([]byte, error) {
   177â†’	b := make([]byte, 0, marshaledSize)
   178â†’	b = append(b, magic...)
   179â†’	b = appendUint64(b, d.v1)
   180â†’	b = appendUint64(b, d.v2)
   181â†’	b = appendUint64(b, d.v3)
   182â†’	b = appendUint64(b, d.v4)
   183â†’	b = appendUint64(b, d.total)
   184â†’	b = append(b, d.mem[:d.n]...)
   185â†’	b = b[:len(b)+len(d.mem)-d.n]
   186â†’	return b, nil
   187â†’}
   189â†’// UnmarshalBinary implements the encoding.BinaryUnmarshaler interface.
   190â†’func (d *Digest) UnmarshalBinary(b []byte) error {
   191â†’	if len(b) < len(magic) || string(b[:len(magic)]) != magic {
   192â†’		return errors.New("xxhash: invalid hash state identifier")
   193â†’	}
   194â†’	if len(b) != marshaledSize {
   195â†’		return errors.New("xxhash: invalid hash state size")
   196â†’	}
   197â†’	b = b[len(magic):]
   198â†’	b, d.v1 = consumeUint64(b)
   199â†’	b, d.v2 = consumeUint64(b)
   200â†’	b, d.v3 = consumeUint64(b)
   201â†’	b, d.v4 = consumeUint64(b)
   202â†’	b, d.total = consumeUint64(b)
   203â†’	copy(d.mem[:], b)
   204â†’	d.n = int(d.total % uint64(len(d.mem)))
   205â†’	return nil
   206â†’}
   208â†’func appendUint64(b []byte, x uint64) []byte {
   209â†’	var a [8]byte
   210â†’	binary.LittleEndian.PutUint64(a[:], x)
   211â†’	return append(b, a[:]...)
   212â†’}
   214â†’func consumeUint64(b []byte) ([]byte, uint64) {
   215â†’	x := u64(b)
   216â†’	return b[8:], x
   217â†’}
   219â†’func u64(b []byte) uint64 { return binary.LittleEndian.Uint64(b) }
   220â†’func u32(b []byte) uint32 { return binary.LittleEndian.Uint32(b) }
   222â†’func round(acc, input uint64) uint64 {
   223â†’	acc += input * prime2
   224â†’	acc = rol31(acc)
   225â†’	acc *= prime1
   226â†’	return acc
   227â†’}
   229â†’func mergeRound(acc, val uint64) uint64 {
   230â†’	val = round(0, val)
   231â†’	acc ^= val
   232â†’	acc = acc*prime1 + prime4
   233â†’	return acc
   234â†’}
   236â†’func rol1(x uint64) uint64  { return bits.RotateLeft64(x, 1) }
   237â†’func rol7(x uint64) uint64  { return bits.RotateLeft64(x, 7) }
   238â†’func rol11(x uint64) uint64 { return bits.RotateLeft64(x, 11) }
   239â†’func rol12(x uint64) uint64 { return bits.RotateLeft64(x, 12) }
   240â†’func rol18(x uint64) uint64 { return bits.RotateLeft64(x, 18) }
   241â†’func rol23(x uint64) uint64 { return bits.RotateLeft64(x, 23) }
   242â†’func rol27(x uint64) uint64 { return bits.RotateLeft64(x, 27) }
   243â†’func rol31(x uint64) uint64 { return bits.RotateLeft64(x, 31) }

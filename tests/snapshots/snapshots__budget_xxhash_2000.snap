    36‚Üí// Sum64String computes the 64-bit xxHash digest of s with a zero seed.
    37‚Üí// It may be faster than Sum64([]byte(s)) by avoiding a copy.
    38‚Üífunc Sum64String(s string) uint64 {
    39‚Üí	b := *(*[]byte)(unsafe.Pointer(&sliceHeader{s, len(s)}))
    40‚Üí	return Sum64(b)
    41‚Üí}
    43‚Üí// WriteString adds more data to d. It always returns len(s), nil.
    44‚Üí// It may be faster than Write([]byte(s)) by avoiding a copy.
    45‚Üífunc (d *Digest) WriteString(s string) (n int, err error) {
    46‚Üí	d.Write(*(*[]byte)(unsafe.Pointer(&sliceHeader{s, len(s)})))
    47‚Üí	// d.Write always returns len(s), nil.
    48‚Üí	// Ignoring the return output and returning these fixed values buys a
    49‚Üí	// savings of 6 in the inliner's cost model.
    50‚Üí	return len(s), nil
    51‚Üí}

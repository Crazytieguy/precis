    43â†’func printHash(r io.Reader, name string) {
    44â†’	h := xxhash.New()
    45â†’	if _, err := io.Copy(h, r); err != nil {
    46â†’		fmt.Fprintln(os.Stderr, err)
    47â†’		return
    48â†’	}
    49â†’	fmt.Printf("%016x  %s\n", h.Sum64(), name)
    50â†’}

   170Ôćĺconst (
   171Ôćĺ	magic         = "xxh\x06"
   172Ôćĺ	marshaledSize = len(magic) + 8*5 + 32
   173Ôćĺ)
   175Ôćĺ// MarshalBinary implements the encoding.BinaryMarshaler interface.
   176Ôćĺfunc (d *Digest) MarshalBinary() ([]byte, error) {
   177Ôćĺ	b := make([]byte, 0, marshaledSize)
   178Ôćĺ	b = append(b, magic...)
   179Ôćĺ	b = appendUint64(b, d.v1)
   180Ôćĺ	b = appendUint64(b, d.v2)
   181Ôćĺ	b = appendUint64(b, d.v3)
   182Ôćĺ	b = appendUint64(b, d.v4)
   183Ôćĺ	b = appendUint64(b, d.total)
   184Ôćĺ	b = append(b, d.mem[:d.n]...)
   185Ôćĺ	b = b[:len(b)+len(d.mem)-d.n]
   186Ôćĺ	return b, nil
   187Ôćĺ}
   189Ôćĺ// UnmarshalBinary implements the encoding.BinaryUnmarshaler interface.
   190Ôćĺfunc (d *Digest) UnmarshalBinary(b []byte) error {
   191Ôćĺ	if len(b) < len(magic) || string(b[:len(magic)]) != magic {
   192Ôćĺ		return errors.New("xxhash: invalid hash state identifier")
   193Ôćĺ	}
   194Ôćĺ	if len(b) != marshaledSize {
   195Ôćĺ		return errors.New("xxhash: invalid hash state size")
   196Ôćĺ	}
   197Ôćĺ	b = b[len(magic):]
   198Ôćĺ	b, d.v1 = consumeUint64(b)
   199Ôćĺ	b, d.v2 = consumeUint64(b)
   200Ôćĺ	b, d.v3 = consumeUint64(b)
   201Ôćĺ	b, d.v4 = consumeUint64(b)
   202Ôćĺ	b, d.total = consumeUint64(b)
   203Ôćĺ	copy(d.mem[:], b)
   204Ôćĺ	d.n = int(d.total % uint64(len(d.mem)))
   205Ôćĺ	return nil
   206Ôćĺ}
   208Ôćĺfunc appendUint64(b []byte, x uint64) []byte {
   209Ôćĺ	var a [8]byte
   210Ôćĺ	binary.LittleEndian.PutUint64(a[:], x)
   211Ôćĺ	return append(b, a[:]...)
   212Ôćĺ}
   214Ôćĺfunc consumeUint64(b []byte) ([]byte, uint64) {
   215Ôćĺ	x := u64(b)
   216Ôćĺ	return b[8:], x
   217Ôćĺ}
   219Ôćĺfunc u64(b []byte) uint64 { return binary.LittleEndian.Uint64(b) }
   220Ôćĺfunc u32(b []byte) uint32 { return binary.LittleEndian.Uint32(b) }
   222Ôćĺfunc round(acc, input uint64) uint64 {
   223Ôćĺ	acc += input * prime2
   224Ôćĺ	acc = rol31(acc)
   225Ôćĺ	acc *= prime1
   226Ôćĺ	return acc
   227Ôćĺ}
   229Ôćĺfunc mergeRound(acc, val uint64) uint64 {
   230Ôćĺ	val = round(0, val)
   231Ôćĺ	acc ^= val
   232Ôćĺ	acc = acc*prime1 + prime4
   233Ôćĺ	return acc
   234Ôćĺ}
   236Ôćĺfunc rol1(x uint64) uint64  { return bits.RotateLeft64(x, 1) }
   237Ôćĺfunc rol7(x uint64) uint64  { return bits.RotateLeft64(x, 7) }
   238Ôćĺfunc rol11(x uint64) uint64 { return bits.RotateLeft64(x, 11) }
   239Ôćĺfunc rol12(x uint64) uint64 { return bits.RotateLeft64(x, 12) }
   240Ôćĺfunc rol18(x uint64) uint64 { return bits.RotateLeft64(x, 18) }
   241Ôćĺfunc rol23(x uint64) uint64 { return bits.RotateLeft64(x, 23) }
   242Ôćĺfunc rol27(x uint64) uint64 { return bits.RotateLeft64(x, 27) }
   243Ôćĺfunc rol31(x uint64) uint64 { return bits.RotateLeft64(x, 31) }

     8â†’// Sum64String computes the 64-bit xxHash digest of s with a zero seed.
     9â†’func Sum64String(s string) uint64 {
    10â†’	return Sum64([]byte(s))
    11â†’}
    13â†’// WriteString adds more data to d. It always returns len(s), nil.
    14â†’func (d *Digest) WriteString(s string) (n int, err error) {
    15â†’	return d.Write([]byte(s))
    16â†’}
xxhash_unsafe.go
    36â†’// Sum64String computes the 64-bit xxHash digest of s with a zero seed.
    37â†’// It may be faster than Sum64([]byte(s)) by avoiding a copy.
    38â†’func Sum64String(s string) uint64 {
    39â†’	b := *(*[]byte)(unsafe.Pointer(&sliceHeader{s, len(s)}))
    40â†’	return Sum64(b)
    41â†’}
    43â†’// WriteString adds more data to d. It always returns len(s), nil.
    44â†’// It may be faster than Write([]byte(s)) by avoiding a copy.
    45â†’func (d *Digest) WriteString(s string) (n int, err error) {
    46â†’	d.Write(*(*[]byte)(unsafe.Pointer(&sliceHeader{s, len(s)})))
    47â†’	// d.Write always returns len(s), nil.
    48â†’	// Ignoring the return output and returning these fixed values buys a
    49â†’	// savings of 6 in the inliner's cost model.
    50â†’	return len(s), nil
    51â†’}
    53â†’// sliceHeader is similar to reflect.SliceHeader, but it assumes that the layout
    54â†’// of the first two words is the same as the layout of a string.
    55â†’type sliceHeader struct {
    56â†’	s   string
    57â†’	cap int
    58â†’}

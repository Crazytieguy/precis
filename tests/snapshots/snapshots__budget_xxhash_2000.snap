    43Ôćĺfunc printHash(r io.Reader, name string) {
    44Ôćĺ	h := xxhash.New()
    45Ôćĺ	if _, err := io.Copy(h, r); err != nil {
    46Ôćĺ		fmt.Fprintln(os.Stderr, err)

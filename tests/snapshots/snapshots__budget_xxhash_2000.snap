    11â†’func main() {
    12â†’	if contains(os.Args[1:], "-h") {
    13â†’		fmt.Fprintf(os.Stderr, `Usage:
    14â†’  %s [filenames]
    15â†’If no filenames are provided or only - is given, input is read from stdin.
    16â†’`, os.Args[0])
    17â†’		os.Exit(1)
    18â†’	}
    19â†’	if len(os.Args) < 2 || len(os.Args) == 2 && os.Args[1] == "-" {
    20â†’		printHash(os.Stdin, "-")
    21â†’		return
    22â†’	}

    23Ôćĺvar primes = [...]uint64{prime1, prime2, prime3, prime4, prime5}
    25Ôćĺ// Digest implements hash.Hash64.
    26Ôćĺ//
    27Ôćĺ// Note that a zero-valued Digest is not ready to receive writes.
    28Ôćĺ// Call Reset or create a Digest using New before calling other methods.
    29Ôćĺtype Digest struct {
    30Ôćĺ	v1    uint64
    31Ôćĺ	v2    uint64
    32Ôćĺ	v3    uint64
    33Ôćĺ	v4    uint64
    34Ôćĺ	total uint64
    35Ôćĺ	mem   [32]byte
    36Ôćĺ	n     int // how much of mem is used
    37Ôćĺ}
    39Ôćĺ// New creates a new Digest with a zero seed.
    40Ôćĺfunc New() *Digest {
    41Ôćĺ	return NewWithSeed(0)
    42Ôćĺ}
    44Ôćĺ// NewWithSeed creates a new Digest with the given seed.
    45Ôćĺfunc NewWithSeed(seed uint64) *Digest {
    46Ôćĺ	var d Digest
    47Ôćĺ	d.ResetWithSeed(seed)
    48Ôćĺ	return &d
    49Ôćĺ}
    51Ôćĺ// Reset clears the Digest's state so that it can be reused.
    52Ôćĺ// It uses a seed value of zero.
    53Ôćĺfunc (d *Digest) Reset() {
    54Ôćĺ	d.ResetWithSeed(0)
    55Ôćĺ}
    57Ôćĺ// ResetWithSeed clears the Digest's state so that it can be reused.
    58Ôćĺ// It uses the given seed to initialize the state.
    59Ôćĺfunc (d *Digest) ResetWithSeed(seed uint64) {
    60Ôćĺ	d.v1 = seed + prime1 + prime2
    61Ôćĺ	d.v2 = seed + prime2
    62Ôćĺ	d.v3 = seed
    63Ôćĺ	d.v4 = seed - prime1
    64Ôćĺ	d.total = 0
    65Ôćĺ	d.n = 0
    66Ôćĺ}
    68Ôćĺ// Size always returns 8 bytes.
    69Ôćĺfunc (d *Digest) Size() int { return 8 }
    71Ôćĺ// BlockSize always returns 32 bytes.
    72Ôćĺfunc (d *Digest) BlockSize() int { return 32 }
    74Ôćĺ// Write adds more data to d. It always returns len(b), nil.
    75Ôćĺfunc (d *Digest) Write(b []byte) (n int, err error) {
    76Ôćĺ	n = len(b)
    77Ôćĺ	d.total += uint64(n)
    78Ôćĺ
    79Ôćĺ	memleft := d.mem[d.n&(len(d.mem)-1):]
    80Ôćĺ
    81Ôćĺ	if d.n+n < 32 {
    82Ôćĺ		// This new data doesn't even fill the current block.
    83Ôćĺ		copy(memleft, b)
    84Ôćĺ		d.n += n
    85Ôćĺ		return
    86Ôćĺ	}
    87Ôćĺ
    88Ôćĺ	if d.n > 0 {
    89Ôćĺ		// Finish off the partial block.
    90Ôćĺ		c := copy(memleft, b)
    91Ôćĺ		d.v1 = round(d.v1, u64(d.mem[0:8]))
    92Ôćĺ		d.v2 = round(d.v2, u64(d.mem[8:16]))
    93Ôćĺ		d.v3 = round(d.v3, u64(d.mem[16:24]))
    94Ôćĺ		d.v4 = round(d.v4, u64(d.mem[24:32]))
    95Ôćĺ		b = b[c:]
    96Ôćĺ		d.n = 0
    97Ôćĺ	}

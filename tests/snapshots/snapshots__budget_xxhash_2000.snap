    11â†’const (
    12â†’	prime1 uint64 = 11400714785074694791
    13â†’	prime2 uint64 = 14029467366897019727
    14â†’	prime3 uint64 = 1609587929392839161
    15â†’	prime4 uint64 = 9650029242287828579
    16â†’	prime5 uint64 = 2870177450012600261
    17â†’)
    19â†’// Store the primes in an array as well.
    20â†’//
    21â†’// The consts are used when possible in Go code to avoid MOVs but we need a
    22â†’// contiguous array for the assembly code.
    23â†’var primes = [...]uint64{prime1, prime2, prime3, prime4, prime5}
    25â†’// Digest implements hash.Hash64.
    26â†’//
    27â†’// Note that a zero-valued Digest is not ready to receive writes.
    28â†’// Call Reset or create a Digest using New before calling other methods.
    29â†’type Digest struct {
    30â†’	v1    uint64
    31â†’	v2    uint64
    32â†’	v3    uint64
    33â†’	v4    uint64
    34â†’	total uint64
    35â†’	mem   [32]byte
    36â†’	n     int // how much of mem is used
    37â†’}
    39â†’// New creates a new Digest with a zero seed.
    40â†’func New() *Digest {
    41â†’	return NewWithSeed(0)
    42â†’}
    44â†’// NewWithSeed creates a new Digest with the given seed.
    45â†’func NewWithSeed(seed uint64) *Digest {
    46â†’	var d Digest
    47â†’	d.ResetWithSeed(seed)
    48â†’	return &d
    49â†’}
    51â†’// Reset clears the Digest's state so that it can be reused.
    52â†’// It uses a seed value of zero.
    53â†’func (d *Digest) Reset() {
    54â†’	d.ResetWithSeed(0)
    55â†’}
    57â†’// ResetWithSeed clears the Digest's state so that it can be reused.
    58â†’// It uses the given seed to initialize the state.
    59â†’func (d *Digest) ResetWithSeed(seed uint64) {
    60â†’	d.v1 = seed + prime1 + prime2
    61â†’	d.v2 = seed + prime2
    62â†’	d.v3 = seed
    63â†’	d.v4 = seed - prime1
    64â†’	d.total = 0
    65â†’	d.n = 0
    66â†’}
    68â†’// Size always returns 8 bytes.
    69â†’func (d *Digest) Size() int { return 8 }
    71â†’// BlockSize always returns 32 bytes.
    72â†’func (d *Digest) BlockSize() int { return 32 }
    74â†’// Write adds more data to d. It always returns len(b), nil.
    75â†’func (d *Digest) Write(b []byte) (n int, err error) {
    76â†’	n = len(b)
    77â†’	d.total += uint64(n)
    78â†’
    79â†’	memleft := d.mem[d.n&(len(d.mem)-1):]
    80â†’
    81â†’	if d.n+n < 32 {
    82â†’		// This new data doesn't even fill the current block.
    83â†’		copy(memleft, b)
    84â†’		d.n += n
    85â†’		return
    86â†’	}
    87â†’
    88â†’	if d.n > 0 {
    89â†’		// Finish off the partial block.
    90â†’		c := copy(memleft, b)
    91â†’		d.v1 = round(d.v1, u64(d.mem[0:8]))
    92â†’		d.v2 = round(d.v2, u64(d.mem[8:16]))
    93â†’		d.v3 = round(d.v3, u64(d.mem[16:24]))
    94â†’		d.v4 = round(d.v4, u64(d.mem[24:32]))
    95â†’		b = b[c:]
    96â†’		d.n = 0
    97â†’	}
    98â†’

    23ŌåÆvar primes = [...]uint64{prime1, prime2, prime3, prime4, prime5}
    25ŌåÆ// Digest implements hash.Hash64.
    26ŌåÆ//
    27ŌåÆ// Note that a zero-valued Digest is not ready to receive writes.
    28ŌåÆ// Call Reset or create a Digest using New before calling other methods.
    29ŌåÆtype Digest struct {
    30ŌåÆ	v1    uint64
    31ŌåÆ	v2    uint64
    32ŌåÆ	v3    uint64
    33ŌåÆ	v4    uint64
    34ŌåÆ	total uint64
    35ŌåÆ	mem   [32]byte
    36ŌåÆ	n     int // how much of mem is used
    37ŌåÆ}
    39ŌåÆ// New creates a new Digest with a zero seed.
    40ŌåÆfunc New() *Digest {
    41ŌåÆ	return NewWithSeed(0)
    42ŌåÆ}
    44ŌåÆ// NewWithSeed creates a new Digest with the given seed.
    45ŌåÆfunc NewWithSeed(seed uint64) *Digest {
    46ŌåÆ	var d Digest
    47ŌåÆ	d.ResetWithSeed(seed)
    48ŌåÆ	return &d
    49ŌåÆ}
    51ŌåÆ// Reset clears the Digest's state so that it can be reused.
    52ŌåÆ// It uses a seed value of zero.
    53ŌåÆfunc (d *Digest) Reset() {
    54ŌåÆ	d.ResetWithSeed(0)
    55ŌåÆ}
    57ŌåÆ// ResetWithSeed clears the Digest's state so that it can be reused.
    58ŌåÆ// It uses the given seed to initialize the state.
    59ŌåÆfunc (d *Digest) ResetWithSeed(seed uint64) {
    60ŌåÆ	d.v1 = seed + prime1 + prime2
    61ŌåÆ	d.v2 = seed + prime2
    62ŌåÆ	d.v3 = seed
    63ŌåÆ	d.v4 = seed - prime1
    64ŌåÆ	d.total = 0
    65ŌåÆ	d.n = 0
    66ŌåÆ}
    68ŌåÆ// Size always returns 8 bytes.
    69ŌåÆfunc (d *Digest) Size() int { return 8 }
    71ŌåÆ// BlockSize always returns 32 bytes.
    72ŌåÆfunc (d *Digest) BlockSize() int { return 32 }
    74ŌåÆ// Write adds more data to d. It always returns len(b), nil.
    75ŌåÆfunc (d *Digest) Write(b []byte) (n int, err error) {
    76ŌåÆ	n = len(b)
    77ŌåÆ	d.total += uint64(n)
    78ŌåÆ
    79ŌåÆ	memleft := d.mem[d.n&(len(d.mem)-1):]
    80ŌåÆ
    81ŌåÆ	if d.n+n < 32 {
    82ŌåÆ		// This new data doesn't even fill the current block.
    83ŌåÆ		copy(memleft, b)
    84ŌåÆ		d.n += n
    85ŌåÆ		return
    86ŌåÆ	}
    87ŌåÆ
    88ŌåÆ	if d.n > 0 {
    89ŌåÆ		// Finish off the partial block.
    90ŌåÆ		c := copy(memleft, b)
    91ŌåÆ		d.v1 = round(d.v1, u64(d.mem[0:8]))
    92ŌåÆ		d.v2 = round(d.v2, u64(d.mem[8:16]))
    93ŌåÆ		d.v3 = round(d.v3, u64(d.mem[16:24]))
    94ŌåÆ		d.v4 = round(d.v4, u64(d.mem[24:32]))
    95ŌåÆ		b = b[c:]
    96ŌåÆ		d.n = 0
    97ŌåÆ	}
    98ŌåÆ
    99ŌåÆ	if len(b) >= 32 {
   100ŌåÆ		// One or more full blocks left.
   101ŌåÆ		nw := writeBlocks(d, b)
   102ŌåÆ		b = b[nw:]
   103ŌåÆ	}
   104ŌåÆ
   105ŌåÆ	// Store any remaining partial block.
   106ŌåÆ	copy(d.mem[:], b)
   107ŌåÆ	d.n = len(b)
   108ŌåÆ
   109ŌåÆ	return
   110ŌåÆ}
   112ŌåÆ// Sum appends the current hash to b and returns the resulting slice.
   113ŌåÆfunc (d *Digest) Sum(b []byte) []byte {
   114ŌåÆ	s := d.Sum64()
   115ŌåÆ	return append(
   116ŌåÆ		b,
   117ŌåÆ		byte(s>>56),
   118ŌåÆ		byte(s>>48),
   119ŌåÆ		byte(s>>40),
   120ŌåÆ		byte(s>>32),
   121ŌåÆ		byte(s>>24),
   122ŌåÆ		byte(s>>16),
   123ŌåÆ		byte(s>>8),
   124ŌåÆ		byte(s),
   125ŌåÆ	)
   126ŌåÆ}
   128ŌåÆ// Sum64 returns the current hash.
   129ŌåÆfunc (d *Digest) Sum64() uint64 {
   130ŌåÆ	var h uint64
   131ŌåÆ
   132ŌåÆ	if d.total >= 32 {
   133ŌåÆ		v1, v2, v3, v4 := d.v1, d.v2, d.v3, d.v4
   134ŌåÆ		h = rol1(v1) + rol7(v2) + rol12(v3) + rol18(v4)
   135ŌåÆ		h = mergeRound(h, v1)
   136ŌåÆ		h = mergeRound(h, v2)
   137ŌåÆ		h = mergeRound(h, v3)
   138ŌåÆ		h = mergeRound(h, v4)
   139ŌåÆ	} else {
   140ŌåÆ		h = d.v3 + prime5
   141ŌåÆ	}
   142ŌåÆ
   143ŌåÆ	h += d.total
   144ŌåÆ
   145ŌåÆ	b := d.mem[:d.n&(len(d.mem)-1)]
   146ŌåÆ	for ; len(b) >= 8; b = b[8:] {
   147ŌåÆ		k1 := round(0, u64(b[:8]))
   148ŌåÆ		h ^= k1
   149ŌåÆ		h = rol27(h)*prime1 + prime4
   150ŌåÆ	}
   151ŌåÆ	if len(b) >= 4 {
   152ŌåÆ		h ^= uint64(u32(b[:4])) * prime1
   153ŌåÆ		h = rol23(h)*prime2 + prime3
   154ŌåÆ		b = b[4:]
   155ŌåÆ	}
   156ŌåÆ	for ; len(b) > 0; b = b[1:] {
   157ŌåÆ		h ^= uint64(b[0]) * prime5
   158ŌåÆ		h = rol11(h) * prime1
   159ŌåÆ	}
   160ŌåÆ
   161ŌåÆ	h ^= h >> 33
   162ŌåÆ	h *= prime2
   163ŌåÆ	h ^= h >> 29
   164ŌåÆ	h *= prime3
   165ŌåÆ	h ^= h >> 32
   166ŌåÆ
   167ŌåÆ	return h
   168ŌåÆ}
   170ŌåÆconst (
   171ŌåÆ	magic         = "xxh\x06"
   172ŌåÆ	marshaledSize = len(magic) + 8*5 + 32
   173ŌåÆ)
   175ŌåÆ// MarshalBinary implements the encoding.BinaryMarshaler interface.
   176ŌåÆfunc (d *Digest) MarshalBinary() ([]byte, error) {
   177ŌåÆ	b := make([]byte, 0, marshaledSize)
   178ŌåÆ	b = append(b, magic...)
   179ŌåÆ	b = appendUint64(b, d.v1)
   180ŌåÆ	b = appendUint64(b, d.v2)
   181ŌåÆ	b = appendUint64(b, d.v3)
   182ŌåÆ	b = appendUint64(b, d.v4)
   183ŌåÆ	b = appendUint64(b, d.total)
   184ŌåÆ	b = append(b, d.mem[:d.n]...)
   185ŌåÆ	b = b[:len(b)+len(d.mem)-d.n]
   186ŌåÆ	return b, nil
   187ŌåÆ}
   189ŌåÆ// UnmarshalBinary implements the encoding.BinaryUnmarshaler interface.
   190ŌåÆfunc (d *Digest) UnmarshalBinary(b []byte) error {
   191ŌåÆ	if len(b) < len(magic) || string(b[:len(magic)]) != magic {
   192ŌåÆ		return errors.New("xxhash: invalid hash state identifier")
   193ŌåÆ	}
   194ŌåÆ	if len(b) != marshaledSize {
   195ŌåÆ		return errors.New("xxhash: invalid hash state size")
   196ŌåÆ	}
   197ŌåÆ	b = b[len(magic):]
   198ŌåÆ	b, d.v1 = consumeUint64(b)
   199ŌåÆ	b, d.v2 = consumeUint64(b)
   200ŌåÆ	b, d.v3 = consumeUint64(b)
   201ŌåÆ	b, d.v4 = consumeUint64(b)
   202ŌåÆ	b, d.total = consumeUint64(b)
   203ŌåÆ	copy(d.mem[:], b)
   204ŌåÆ	d.n = int(d.total % uint64(len(d.mem)))
   205ŌåÆ	return nil
   206ŌåÆ}
   208ŌåÆfunc appendUint64(b []byte, x uint64) []byte {
   209ŌåÆ	var a [8]byte
   210ŌåÆ	binary.LittleEndian.PutUint64(a[:], x)
   211ŌåÆ	return append(b, a[:]...)
   212ŌåÆ}
   214ŌåÆfunc consumeUint64(b []byte) ([]byte, uint64) {
   215ŌåÆ	x := u64(b)
   216ŌåÆ	return b[8:], x
   217ŌåÆ}
   219ŌåÆfunc u64(b []byte) uint64 { return binary.LittleEndian.Uint64(b) }
   220ŌåÆfunc u32(b []byte) uint32 { return binary.LittleEndian.Uint32(b) }
   222ŌåÆfunc round(acc, input uint64) uint64 {
   223ŌåÆ	acc += input * prime2
   224ŌåÆ	acc = rol31(acc)
   225ŌåÆ	acc *= prime1
   226ŌåÆ	return acc
   227ŌåÆ}
   229ŌåÆfunc mergeRound(acc, val uint64) uint64 {
   230ŌåÆ	val = round(0, val)
   231ŌåÆ	acc ^= val
   232ŌåÆ	acc = acc*prime1 + prime4
   233ŌåÆ	return acc
   234ŌåÆ}
   236ŌåÆfunc rol1(x uint64) uint64  { return bits.RotateLeft64(x, 1) }
   237ŌåÆfunc rol7(x uint64) uint64  { return bits.RotateLeft64(x, 7) }
   238ŌåÆfunc rol11(x uint64) uint64 { return bits.RotateLeft64(x, 11) }
   239ŌåÆfunc rol12(x uint64) uint64 { return bits.RotateLeft64(x, 12) }
   240ŌåÆfunc rol18(x uint64) uint64 { return bits.RotateLeft64(x, 18) }
   241ŌåÆfunc rol23(x uint64) uint64 { return bits.RotateLeft64(x, 23) }
   242ŌåÆfunc rol27(x uint64) uint64 { return bits.RotateLeft64(x, 27) }
   243ŌåÆfunc rol31(x uint64) uint64 { return bits.RotateLeft64(x, 31) }

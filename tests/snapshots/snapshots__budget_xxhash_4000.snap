   108→func BenchmarkHashes(b *testing.B) {
   109→	for _, bb := range benchmarks {
   110→		for _, benchSize := range []struct {
   111→			name string
   112→			n    int
   113→		}{
   114→			{"5B", 5},
   115→			{"100B", 100},
   116→			{"4KB", 4e3},
   117→			{"10MB", 10e6},
   118→		} {
   119→			input := make([]byte, benchSize.n)
   120→			for i := range input {
   121→				input[i] = byte(i)
   122→			}
   123→			inputString := string(input)
   124→			if bb.directBytes != nil {
   125→				name := fmt.Sprintf("%s,direct,bytes,n=%s", bb.name, benchSize.name)
   126→				b.Run(name, func(b *testing.B) {
   127→					benchmarkHashBytes(b, input, bb.directBytes)
   128→				})
   129→			}
   130→			if bb.directString != nil {
   131→				name := fmt.Sprintf("%s,direct,string,n=%s", bb.name, benchSize.name)
   132→				b.Run(name, func(b *testing.B) {
   133→					benchmarkHashString(b, inputString, bb.directString)
   134→				})
   135→			}
   136→			if bb.digestBytes != nil {
   137→				name := fmt.Sprintf("%s,digest,bytes,n=%s", bb.name, benchSize.name)
   138→				b.Run(name, func(b *testing.B) {
   139→					benchmarkHashBytes(b, input, bb.digestBytes)
   140→				})
   141→			}
   142→			if bb.digestString != nil {
   143→				name := fmt.Sprintf("%s,digest,string,n=%s", bb.name, benchSize.name)
   144→				b.Run(name, func(b *testing.B) {
   145→					benchmarkHashString(b, inputString, bb.digestString)
   146→				})
   147→			}
   148→		}
   149→	}
   150→}
   152→func benchmarkHashBytes(b *testing.B, input []byte, fn func([]byte) uint64) {
   153→	b.SetBytes(int64(len(input)))
   154→	for i := 0; i < b.N; i++ {
   155→		sink = fn(input)
   156→	}
   157→}
   159→func benchmarkHashString(b *testing.B, input string, fn func(string) uint64) {
   160→	b.SetBytes(int64(len(input)))
   161→	for i := 0; i < b.N; i++ {
   162→		sink = fn(input)
   163→	}
   164→}

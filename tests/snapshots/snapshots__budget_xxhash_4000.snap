    36ŌåÆ// Sum64String computes the 64-bit xxHash digest of s with a zero seed.
    37ŌåÆ// It may be faster than Sum64([]byte(s)) by avoiding a copy.
    38ŌåÆfunc Sum64String(s string) uint64 {
    39ŌåÆ	b := *(*[]byte)(unsafe.Pointer(&sliceHeader{s, len(s)}))
    40ŌåÆ	return Sum64(b)
    41ŌåÆ}
    43ŌåÆ// WriteString adds more data to d. It always returns len(s), nil.
    44ŌåÆ// It may be faster than Write([]byte(s)) by avoiding a copy.
    45ŌåÆfunc (d *Digest) WriteString(s string) (n int, err error) {
    46ŌåÆ	d.Write(*(*[]byte)(unsafe.Pointer(&sliceHeader{s, len(s)})))
    47ŌåÆ	// d.Write always returns len(s), nil.
    48ŌåÆ	// Ignoring the return output and returning these fixed values buys a
    49ŌåÆ	// savings of 6 in the inliner's cost model.
    50ŌåÆ	return len(s), nil
    51ŌåÆ}
    53ŌåÆ// sliceHeader is similar to reflect.SliceHeader, but it assumes that the layout
    54ŌåÆ// of the first two words is the same as the layout of a string.
    55ŌåÆtype sliceHeader struct {
    56ŌåÆ	s   string
    57ŌåÆ	cap int
    58ŌåÆ}

    31ŌåÆ	}
    32ŌåÆ}
    34ŌåÆfunc contains(ss []string, s string) bool {
    35ŌåÆ	for _, s1 := range ss {
    36ŌåÆ		if s1 == s {
    37ŌåÆ			return true
    38ŌåÆ		}
    39ŌåÆ	}
    40ŌåÆ	return false
    41ŌåÆ}
    43ŌåÆfunc printHash(r io.Reader, name string) {
    44ŌåÆ	h := xxhash.New()
    45ŌåÆ	if _, err := io.Copy(h, r); err != nil {
    46ŌåÆ		fmt.Fprintln(os.Stderr, err)
    47ŌåÆ		return
    48ŌåÆ	}
    49ŌåÆ	fmt.Printf("%016x  %s\n", h.Sum64(), name)
    50ŌåÆ}

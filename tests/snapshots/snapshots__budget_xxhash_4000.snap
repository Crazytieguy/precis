     1‚Üí//go:build ignore
     2‚Üí// +build ignore
     3‚Üí
     4‚Üípackage main
     5‚Üí
     6‚Üíimport (
     7‚Üí	"fmt"
     8‚Üí	"log"
     9‚Üí	"testing"
    10‚Üí
    11‚Üí	"github.com/cespare/xxhash/v2"
    12‚Üí)
    13‚Üí
    14‚Üíconst (
    15‚Üí	in   = "Call me Ishmael. Some years ago--never mind how long precisely-"
    16‚Üí	want = uint64(0x02a2e85470d6fd96)
    17‚Üí)
    18‚Üí
    19‚Üífunc TestSum(t *testing.T) {
    20‚Üí	got := xxhash.Sum64String(in)
    21‚Üí	if got != want {
    22‚Üí		t.Fatalf("Sum64String: got 0x%x; want 0x%x", got, want)
    23‚Üí	}
    24‚Üí}
    25‚Üí
    26‚Üífunc TestDigest(t *testing.T) {
    27‚Üí	for chunkSize := 1; chunkSize <= len(in); chunkSize++ {
    28‚Üí		name := fmt.Sprintf("[chunkSize=%d]", chunkSize)
    29‚Üí		t.Run(name, func(t *testing.T) {
    30‚Üí			d := xxhash.New()
    31‚Üí			for i := 0; i < len(in); i += chunkSize {
    32‚Üí				chunk := in[i:]
    33‚Üí				if len(chunk) > chunkSize {
    34‚Üí					chunk = chunk[:chunkSize]
    35‚Üí				}
    36‚Üí				n, err := d.WriteString(chunk)
    37‚Üí				if err != nil || n != len(chunk) {
    38‚Üí					t.Fatalf("Digest.WriteString: got (%d, %v); want (%d, nil)",
    39‚Üí						n, err, len(chunk))
    40‚Üí				}
    41‚Üí			}
    42‚Üí			if got := d.Sum64(); got != want {
    43‚Üí				log.Fatalf("Digest.Sum64: got 0x%x; want 0x%x", got, want)
    44‚Üí			}
    45‚Üí		})
    46‚Üí	}
    47‚Üí}
xxhash.go
     1‚Üí// Package xxhash implements the 64-bit variant of xxHash (XXH64) as described
     2‚Üí// at https://xxhash.com/.
     3‚Üípackage xxhash
     4‚Üí
     5‚Üíimport (
     6‚Üí	"encoding/binary"
     7‚Üí	"errors"
     8‚Üí	"math/bits"
     9‚Üí)
    10‚Üí
    11‚Üíconst (
    12‚Üí	prime1 uint64 = 11400714785074694791
    13‚Üí	prime2 uint64 = 14029467366897019727
    14‚Üí	prime3 uint64 = 1609587929392839161
    15‚Üí	prime4 uint64 = 9650029242287828579
    16‚Üí	prime5 uint64 = 2870177450012600261
    17‚Üí)
    18‚Üí
    19‚Üí// Store the primes in an array as well.
    20‚Üí//
    21‚Üí// The consts are used when possible in Go code to avoid MOVs but we need a
    22‚Üí// contiguous array for the assembly code.
    23‚Üívar primes = [...]uint64{prime1, prime2, prime3, prime4, prime5}
    24‚Üí
    25‚Üí// Digest implements hash.Hash64.
    26‚Üí//
    27‚Üí// Note that a zero-valued Digest is not ready to receive writes.
    28‚Üí// Call Reset or create a Digest using New before calling other methods.
    29‚Üítype Digest struct {
    30‚Üí	v1    uint64
    31‚Üí	v2    uint64
    32‚Üí	v3    uint64
    33‚Üí	v4    uint64
    34‚Üí	total uint64
    35‚Üí	mem   [32]byte
    36‚Üí	n     int // how much of mem is used
    37‚Üí}
    38‚Üí
    39‚Üí// New creates a new Digest with a zero seed.
    40‚Üífunc New() *Digest {
    41‚Üí	return NewWithSeed(0)
    42‚Üí}
    43‚Üí
    44‚Üí// NewWithSeed creates a new Digest with the given seed.
    45‚Üífunc NewWithSeed(seed uint64) *Digest {
    46‚Üí	var d Digest
    47‚Üí	d.ResetWithSeed(seed)
    48‚Üí	return &d
    49‚Üí}
    50‚Üí
    51‚Üí// Reset clears the Digest's state so that it can be reused.
    52‚Üí// It uses a seed value of zero.
    53‚Üífunc (d *Digest) Reset() {
    54‚Üí	d.ResetWithSeed(0)
    55‚Üí}
    56‚Üí
    57‚Üí// ResetWithSeed clears the Digest's state so that it can be reused.
    58‚Üí// It uses the given seed to initialize the state.
    59‚Üífunc (d *Digest) ResetWithSeed(seed uint64) {
    60‚Üí	d.v1 = seed + prime1 + prime2
    61‚Üí	d.v2 = seed + prime2
    62‚Üí	d.v3 = seed
    63‚Üí	d.v4 = seed - prime1
    64‚Üí	d.total = 0
    65‚Üí	d.n = 0
    66‚Üí}
    67‚Üí
    68‚Üí// Size always returns 8 bytes.
    69‚Üífunc (d *Digest) Size() int { return 8 }
    70‚Üí
    71‚Üí// BlockSize always returns 32 bytes.
    72‚Üífunc (d *Digest) BlockSize() int { return 32 }
    73‚Üí
    74‚Üí// Write adds more data to d. It always returns len(b), nil.
    75‚Üífunc (d *Digest) Write(b []byte) (n int, err error) {
    76‚Üí	n = len(b)
    77‚Üí	d.total += uint64(n)
    78‚Üí
    79‚Üí	memleft := d.mem[d.n&(len(d.mem)-1):]
    80‚Üí
    81‚Üí	if d.n+n < 32 {
    82‚Üí		// This new data doesn't even fill the current block.
    83‚Üí		copy(memleft, b)
    84‚Üí		d.n += n
    85‚Üí		return
    86‚Üí	}
    87‚Üí
    88‚Üí	if d.n > 0 {
    89‚Üí		// Finish off the partial block.
    90‚Üí		c := copy(memleft, b)
    91‚Üí		d.v1 = round(d.v1, u64(d.mem[0:8]))
    92‚Üí		d.v2 = round(d.v2, u64(d.mem[8:16]))
    93‚Üí		d.v3 = round(d.v3, u64(d.mem[16:24]))
    94‚Üí		d.v4 = round(d.v4, u64(d.mem[24:32]))
    95‚Üí		b = b[c:]
    96‚Üí		d.n = 0
    97‚Üí	}
    98‚Üí
    99‚Üí	if len(b) >= 32 {
   100‚Üí		// One or more full blocks left.
   101‚Üí		nw := writeBlocks(d, b)
   102‚Üí		b = b[nw:]
   103‚Üí	}
   104‚Üí
   105‚Üí	// Store any remaining partial block.
   106‚Üí	copy(d.mem[:], b)
   107‚Üí	d.n = len(b)
   108‚Üí
   109‚Üí	return
   110‚Üí}
   111‚Üí
   112‚Üí// Sum appends the current hash to b and returns the resulting slice.
   113‚Üífunc (d *Digest) Sum(b []byte) []byte {
   114‚Üí	s := d.Sum64()
   115‚Üí	return append(
   116‚Üí		b,
   117‚Üí		byte(s>>56),
   118‚Üí		byte(s>>48),
   119‚Üí		byte(s>>40),
   120‚Üí		byte(s>>32),
   121‚Üí		byte(s>>24),
   122‚Üí		byte(s>>16),
   123‚Üí		byte(s>>8),
   124‚Üí		byte(s),
   125‚Üí	)
   126‚Üí}
   127‚Üí
   128‚Üí// Sum64 returns the current hash.
   129‚Üífunc (d *Digest) Sum64() uint64 {
   130‚Üí	var h uint64
   131‚Üí
   132‚Üí	if d.total >= 32 {
   133‚Üí		v1, v2, v3, v4 := d.v1, d.v2, d.v3, d.v4
   134‚Üí		h = rol1(v1) + rol7(v2) + rol12(v3) + rol18(v4)
   135‚Üí		h = mergeRound(h, v1)
   136‚Üí		h = mergeRound(h, v2)
   137‚Üí		h = mergeRound(h, v3)
   138‚Üí		h = mergeRound(h, v4)
   139‚Üí	} else {
   140‚Üí		h = d.v3 + prime5
   141‚Üí	}
   142‚Üí
   143‚Üí	h += d.total
   144‚Üí
   145‚Üí	b := d.mem[:d.n&(len(d.mem)-1)]
   146‚Üí	for ; len(b) >= 8; b = b[8:] {
   147‚Üí		k1 := round(0, u64(b[:8]))
   148‚Üí		h ^= k1
   149‚Üí		h = rol27(h)*prime1 + prime4
   150‚Üí	}
   151‚Üí	if len(b) >= 4 {
   152‚Üí		h ^= uint64(u32(b[:4])) * prime1
   153‚Üí		h = rol23(h)*prime2 + prime3
   154‚Üí		b = b[4:]
   155‚Üí	}
   156‚Üí	for ; len(b) > 0; b = b[1:] {
   157‚Üí		h ^= uint64(b[0]) * prime5
   158‚Üí		h = rol11(h) * prime1
   159‚Üí	}
   160‚Üí
   161‚Üí	h ^= h >> 33
   162‚Üí	h *= prime2
   163‚Üí	h ^= h >> 29
   164‚Üí	h *= prime3
   165‚Üí	h ^= h >> 32
   166‚Üí
   167‚Üí	return h
   168‚Üí}
   169‚Üí
   170‚Üíconst (
   171‚Üí	magic         = "xxh\x06"
   172‚Üí	marshaledSize = len(magic) + 8*5 + 32
   173‚Üí)
   174‚Üí
   175‚Üí// MarshalBinary implements the encoding.BinaryMarshaler interface.
   176‚Üífunc (d *Digest) MarshalBinary() ([]byte, error) {
   177‚Üí	b := make([]byte, 0, marshaledSize)
   178‚Üí	b = append(b, magic...)
   179‚Üí	b = appendUint64(b, d.v1)
   180‚Üí	b = appendUint64(b, d.v2)
   181‚Üí	b = appendUint64(b, d.v3)
   182‚Üí	b = appendUint64(b, d.v4)
   183‚Üí	b = appendUint64(b, d.total)
   184‚Üí	b = append(b, d.mem[:d.n]...)
   185‚Üí	b = b[:len(b)+len(d.mem)-d.n]
   186‚Üí	return b, nil
   187‚Üí}
   188‚Üí
   189‚Üí// UnmarshalBinary implements the encoding.BinaryUnmarshaler interface.
   190‚Üífunc (d *Digest) UnmarshalBinary(b []byte) error {
   191‚Üí	if len(b) < len(magic) || string(b[:len(magic)]) != magic {
   192‚Üí		return errors.New("xxhash: invalid hash state identifier")
   193‚Üí	}
   194‚Üí	if len(b) != marshaledSize {
   195‚Üí		return errors.New("xxhash: invalid hash state size")
   196‚Üí	}
   197‚Üí	b = b[len(magic):]
   198‚Üí	b, d.v1 = consumeUint64(b)
   199‚Üí	b, d.v2 = consumeUint64(b)
   200‚Üí	b, d.v3 = consumeUint64(b)
   201‚Üí	b, d.v4 = consumeUint64(b)
   202‚Üí	b, d.total = consumeUint64(b)
   203‚Üí	copy(d.mem[:], b)
   204‚Üí	d.n = int(d.total % uint64(len(d.mem)))
   205‚Üí	return nil
   206‚Üí}
   207‚Üí
   208‚Üífunc appendUint64(b []byte, x uint64) []byte {
   209‚Üí	var a [8]byte
   210‚Üí	binary.LittleEndian.PutUint64(a[:], x)
   211‚Üí	return append(b, a[:]...)
   212‚Üí}
   213‚Üí
   214‚Üífunc consumeUint64(b []byte) ([]byte, uint64) {
   215‚Üí	x := u64(b)
   216‚Üí	return b[8:], x
   217‚Üí}
   218‚Üí
   219‚Üífunc u64(b []byte) uint64 { return binary.LittleEndian.Uint64(b) }
   220‚Üífunc u32(b []byte) uint32 { return binary.LittleEndian.Uint32(b) }
   221‚Üí
   222‚Üífunc round(acc, input uint64) uint64 {
   223‚Üí	acc += input * prime2
   224‚Üí	acc = rol31(acc)
   225‚Üí	acc *= prime1
   226‚Üí	return acc
   227‚Üí}
   228‚Üí
   229‚Üífunc mergeRound(acc, val uint64) uint64 {
   230‚Üí	val = round(0, val)
   231‚Üí	acc ^= val
   232‚Üí	acc = acc*prime1 + prime4
   233‚Üí	return acc
   234‚Üí}
   235‚Üí
   236‚Üífunc rol1(x uint64) uint64  { return bits.RotateLeft64(x, 1) }
   237‚Üífunc rol7(x uint64) uint64  { return bits.RotateLeft64(x, 7) }
   238‚Üífunc rol11(x uint64) uint64 { return bits.RotateLeft64(x, 11) }
   239‚Üífunc rol12(x uint64) uint64 { return bits.RotateLeft64(x, 12) }
   240‚Üífunc rol18(x uint64) uint64 { return bits.RotateLeft64(x, 18) }
   241‚Üífunc rol23(x uint64) uint64 { return bits.RotateLeft64(x, 23) }
   242‚Üífunc rol27(x uint64) uint64 { return bits.RotateLeft64(x, 27) }
   243‚Üífunc rol31(x uint64) uint64 { return bits.RotateLeft64(x, 31) }

xxhash_other.go
     1‚Üí//go:build (!amd64 && !arm64) || appengine || !gc || purego
     2‚Üí// +build !amd64,!arm64 appengine !gc purego
     3‚Üí
     4‚Üípackage xxhash
     5‚Üí
     6‚Üí// Sum64 computes the 64-bit xxHash digest of b with a zero seed.
     7‚Üífunc Sum64(b []byte) uint64 {
     8‚Üí	// A simpler version would be
     9‚Üí	//   d := New()
    10‚Üí	//   d.Write(b)
    11‚Üí	//   return d.Sum64()
    12‚Üí	// but this is faster, particularly for small inputs.
    13‚Üí
    14‚Üí	n := len(b)
    15‚Üí	var h uint64
    16‚Üí
    17‚Üí	if n >= 32 {
    18‚Üí		v1 := primes[0] + prime2
    19‚Üí		v2 := prime2
    20‚Üí		v3 := uint64(0)
    21‚Üí		v4 := -primes[0]
    22‚Üí		for len(b) >= 32 {
    23‚Üí			v1 = round(v1, u64(b[0:8:len(b)]))
    24‚Üí			v2 = round(v2, u64(b[8:16:len(b)]))
    25‚Üí			v3 = round(v3, u64(b[16:24:len(b)]))
    26‚Üí			v4 = round(v4, u64(b[24:32:len(b)]))
    27‚Üí			b = b[32:len(b):len(b)]
    28‚Üí		}
    29‚Üí		h = rol1(v1) + rol7(v2) + rol12(v3) + rol18(v4)
    30‚Üí		h = mergeRound(h, v1)
    31‚Üí		h = mergeRound(h, v2)
    32‚Üí		h = mergeRound(h, v3)
    33‚Üí		h = mergeRound(h, v4)
    34‚Üí	} else {
    35‚Üí		h = prime5
    36‚Üí	}
    37‚Üí
    38‚Üí	h += uint64(n)
    39‚Üí
    40‚Üí	for ; len(b) >= 8; b = b[8:] {
    41‚Üí		k1 := round(0, u64(b[:8]))
    42‚Üí		h ^= k1
    43‚Üí		h = rol27(h)*prime1 + prime4
    44‚Üí	}
    45‚Üí	if len(b) >= 4 {
    46‚Üí		h ^= uint64(u32(b[:4])) * prime1
    47‚Üí		h = rol23(h)*prime2 + prime3
    48‚Üí		b = b[4:]
    49‚Üí	}
    50‚Üí	for ; len(b) > 0; b = b[1:] {
    51‚Üí		h ^= uint64(b[0]) * prime5
    52‚Üí		h = rol11(h) * prime1
    53‚Üí	}
    54‚Üí
    55‚Üí	h ^= h >> 33
    56‚Üí	h *= prime2
    57‚Üí	h ^= h >> 29
    58‚Üí	h *= prime3
    59‚Üí	h ^= h >> 32
    60‚Üí
    61‚Üí	return h
    62‚Üí}
    63‚Üí
    64‚Üífunc writeBlocks(d *Digest, b []byte) int {
    65‚Üí	v1, v2, v3, v4 := d.v1, d.v2, d.v3, d.v4
    66‚Üí	n := len(b)
    67‚Üí	for len(b) >= 32 {
    68‚Üí		v1 = round(v1, u64(b[0:8:len(b)]))
    69‚Üí		v2 = round(v2, u64(b[8:16:len(b)]))
    70‚Üí		v3 = round(v3, u64(b[16:24:len(b)]))
    71‚Üí		v4 = round(v4, u64(b[24:32:len(b)]))
    72‚Üí		b = b[32:len(b):len(b)]
    73‚Üí	}
    74‚Üí	d.v1, d.v2, d.v3, d.v4 = v1, v2, v3, v4
    75‚Üí	return n - len(b)
    76‚Üí}
xxhash_safe.go
     1‚Üí//go:build appengine
     2‚Üí// +build appengine
     3‚Üí
     4‚Üí// This file contains the safe implementations of otherwise unsafe-using code.
     5‚Üí
     6‚Üípackage xxhash
     7‚Üí
     8‚Üí// Sum64String computes the 64-bit xxHash digest of s with a zero seed.
     9‚Üífunc Sum64String(s string) uint64 {
    10‚Üí	return Sum64([]byte(s))
    11‚Üí}
    12‚Üí
    13‚Üí// WriteString adds more data to d. It always returns len(s), nil.
    14‚Üífunc (d *Digest) WriteString(s string) (n int, err error) {
    15‚Üí	return d.Write([]byte(s))
    16‚Üí}
xxhash_unsafe.go
     1‚Üí//go:build !appengine
     2‚Üí// +build !appengine
     3‚Üí
     4‚Üí// This file encapsulates usage of unsafe.
     5‚Üí// xxhash_safe.go contains the safe implementations.
     6‚Üí
     7‚Üípackage xxhash
     8‚Üí
     9‚Üíimport (
    10‚Üí	"unsafe"
    11‚Üí)
    12‚Üí
    13‚Üí// In the future it's possible that compiler optimizations will make these
    14‚Üí// XxxString functions unnecessary by realizing that calls such as
    15‚Üí// Sum64([]byte(s)) don't need to copy s. See https://go.dev/issue/2205.
    16‚Üí// If that happens, even if we keep these functions they can be replaced with
    17‚Üí// the trivial safe code.
    18‚Üí
    19‚Üí// NOTE: The usual way of doing an unsafe string-to-[]byte conversion is:
    20‚Üí//
    21‚Üí//   var b []byte
    22‚Üí//   bh := (*reflect.SliceHeader)(unsafe.Pointer(&b))
    23‚Üí//   bh.Data = (*reflect.StringHeader)(unsafe.Pointer(&s)).Data
    24‚Üí//   bh.Len = len(s)
    25‚Üí//   bh.Cap = len(s)
    26‚Üí//
    27‚Üí// Unfortunately, as of Go 1.15.3 the inliner's cost model assigns a high enough
    28‚Üí// weight to this sequence of expressions that any function that uses it will
    29‚Üí// not be inlined. Instead, the functions below use a different unsafe
    30‚Üí// conversion designed to minimize the inliner weight and allow both to be
    31‚Üí// inlined. There is also a test (TestInlining) which verifies that these are
    32‚Üí// inlined.
    33‚Üí//
    34‚Üí// See https://github.com/golang/go/issues/42739 for discussion.
    35‚Üí
    36‚Üí// Sum64String computes the 64-bit xxHash digest of s with a zero seed.
    37‚Üí// It may be faster than Sum64([]byte(s)) by avoiding a copy.
    38‚Üífunc Sum64String(s string) uint64 {
    39‚Üí	b := *(*[]byte)(unsafe.Pointer(&sliceHeader{s, len(s)}))
    40‚Üí	return Sum64(b)
    41‚Üí}
    42‚Üí
    43‚Üí// WriteString adds more data to d. It always returns len(s), nil.
    44‚Üí// It may be faster than Write([]byte(s)) by avoiding a copy.
    45‚Üífunc (d *Digest) WriteString(s string) (n int, err error) {
    46‚Üí	d.Write(*(*[]byte)(unsafe.Pointer(&sliceHeader{s, len(s)})))
    47‚Üí	// d.Write always returns len(s), nil.
    48‚Üí	// Ignoring the return output and returning these fixed values buys a
    49‚Üí	// savings of 6 in the inliner's cost model.
    50‚Üí	return len(s), nil
    51‚Üí}
    52‚Üí
    53‚Üí// sliceHeader is similar to reflect.SliceHeader, but it assumes that the layout
    54‚Üí// of the first two words is the same as the layout of a string.
    55‚Üítype sliceHeader struct {
    56‚Üí	s   string
    57‚Üí	cap int
    58‚Üí}
xxhsum/xxhsum.go
     1‚Üípackage main
     2‚Üí
     3‚Üíimport (
     4‚Üí	"fmt"
     5‚Üí	"io"
     6‚Üí	"os"
     7‚Üí
     8‚Üí	"github.com/cespare/xxhash/v2"
     9‚Üí)
    10‚Üí
    11‚Üífunc main() {
    12‚Üí	if contains(os.Args[1:], "-h") {
    13‚Üí		fmt.Fprintf(os.Stderr, `Usage:
    14‚Üí  %s [filenames]
    15‚ÜíIf no filenames are provided or only - is given, input is read from stdin.
    16‚Üí`, os.Args[0])
    17‚Üí		os.Exit(1)
    18‚Üí	}
    19‚Üí	if len(os.Args) < 2 || len(os.Args) == 2 && os.Args[1] == "-" {
    20‚Üí		printHash(os.Stdin, "-")
    21‚Üí		return
    22‚Üí	}
    23‚Üí	for _, path := range os.Args[1:] {
    24‚Üí		f, err := os.Open(path)
    25‚Üí		if err != nil {
    26‚Üí			fmt.Fprintln(os.Stderr, err)
    27‚Üí			continue
    28‚Üí		}
    29‚Üí		printHash(f, path)
    30‚Üí		f.Close()
    31‚Üí	}
    32‚Üí}
    33‚Üí
    34‚Üífunc contains(ss []string, s string) bool {
    35‚Üí	for _, s1 := range ss {
    36‚Üí		if s1 == s {
    37‚Üí			return true
    38‚Üí		}
    39‚Üí	}
    40‚Üí	return false
    41‚Üí}
    42‚Üí
    43‚Üífunc printHash(r io.Reader, name string) {
    44‚Üí	h := xxhash.New()
    45‚Üí	if _, err := io.Copy(h, r); err != nil {
    46‚Üí		fmt.Fprintln(os.Stderr, err)
    47‚Üí		return
    48‚Üí	}
    49‚Üí	fmt.Printf("%016x  %s\n", h.Sum64(), name)
    50‚Üí}

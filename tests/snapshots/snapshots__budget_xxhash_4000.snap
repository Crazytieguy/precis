xxhash_other.go
     6ŌåÆ// Sum64 computes the 64-bit xxHash digest of b with a zero seed.
     7ŌåÆfunc Sum64(b []byte) uint64 {
     8ŌåÆ	// A simpler version would be
     9ŌåÆ	//   d := New()
    10ŌåÆ	//   d.Write(b)
    11ŌåÆ	//   return d.Sum64()
    12ŌåÆ	// but this is faster, particularly for small inputs.
    13ŌåÆ
    14ŌåÆ	n := len(b)
    15ŌåÆ	var h uint64
    16ŌåÆ
    17ŌåÆ	if n >= 32 {
    18ŌåÆ		v1 := primes[0] + prime2
    19ŌåÆ		v2 := prime2
    20ŌåÆ		v3 := uint64(0)
    21ŌåÆ		v4 := -primes[0]
    22ŌåÆ		for len(b) >= 32 {
    23ŌåÆ			v1 = round(v1, u64(b[0:8:len(b)]))
    24ŌåÆ			v2 = round(v2, u64(b[8:16:len(b)]))
    25ŌåÆ			v3 = round(v3, u64(b[16:24:len(b)]))
    26ŌåÆ			v4 = round(v4, u64(b[24:32:len(b)]))
    27ŌåÆ			b = b[32:len(b):len(b)]
    28ŌåÆ		}
    29ŌåÆ		h = rol1(v1) + rol7(v2) + rol12(v3) + rol18(v4)
    30ŌåÆ		h = mergeRound(h, v1)
    31ŌåÆ		h = mergeRound(h, v2)
    32ŌåÆ		h = mergeRound(h, v3)
    33ŌåÆ		h = mergeRound(h, v4)
    34ŌåÆ	} else {
    35ŌåÆ		h = prime5
    36ŌåÆ	}
    37ŌåÆ
    38ŌåÆ	h += uint64(n)
    39ŌåÆ
    40ŌåÆ	for ; len(b) >= 8; b = b[8:] {
    41ŌåÆ		k1 := round(0, u64(b[:8]))
    42ŌåÆ		h ^= k1
    43ŌåÆ		h = rol27(h)*prime1 + prime4
    44ŌåÆ	}
    45ŌåÆ	if len(b) >= 4 {
    46ŌåÆ		h ^= uint64(u32(b[:4])) * prime1
    47ŌåÆ		h = rol23(h)*prime2 + prime3
    48ŌåÆ		b = b[4:]
    49ŌåÆ	}
    50ŌåÆ	for ; len(b) > 0; b = b[1:] {
    51ŌåÆ		h ^= uint64(b[0]) * prime5
    52ŌåÆ		h = rol11(h) * prime1
    53ŌåÆ	}
    54ŌåÆ
    55ŌåÆ	h ^= h >> 33
    56ŌåÆ	h *= prime2
    57ŌåÆ	h ^= h >> 29
    58ŌåÆ	h *= prime3
    59ŌåÆ	h ^= h >> 32
    60ŌåÆ
    61ŌåÆ	return h
    62ŌåÆ}
    64ŌåÆfunc writeBlocks(d *Digest, b []byte) int {
    65ŌåÆ	v1, v2, v3, v4 := d.v1, d.v2, d.v3, d.v4
    66ŌåÆ	n := len(b)
    67ŌåÆ	for len(b) >= 32 {
    68ŌåÆ		v1 = round(v1, u64(b[0:8:len(b)]))
    69ŌåÆ		v2 = round(v2, u64(b[8:16:len(b)]))
    70ŌåÆ		v3 = round(v3, u64(b[16:24:len(b)]))
    71ŌåÆ		v4 = round(v4, u64(b[24:32:len(b)]))
    72ŌåÆ		b = b[32:len(b):len(b)]
    73ŌåÆ	}
    74ŌåÆ	d.v1, d.v2, d.v3, d.v4 = v1, v2, v3, v4
    75ŌåÆ	return n - len(b)
    76ŌåÆ}

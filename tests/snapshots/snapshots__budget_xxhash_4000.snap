    11ŌåÆconst (
    12ŌåÆ	prime1 uint64 = 11400714785074694791
    13ŌåÆ	prime2 uint64 = 14029467366897019727
    14ŌåÆ	prime3 uint64 = 1609587929392839161
    15ŌåÆ	prime4 uint64 = 9650029242287828579
    16ŌåÆ	prime5 uint64 = 2870177450012600261
    17ŌåÆ)
    19ŌåÆ// Store the primes in an array as well.
    20ŌåÆ//
    21ŌåÆ// The consts are used when possible in Go code to avoid MOVs but we need a

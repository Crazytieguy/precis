    11ŌåÆfunc main() {
    12ŌåÆ	if contains(os.Args[1:], "-h") {
    13ŌåÆ		fmt.Fprintf(os.Stderr, `Usage:
    14ŌåÆ  %s [filenames]
    15ŌåÆIf no filenames are provided or only - is given, input is read from stdin.
    16ŌåÆ`, os.Args[0])
    17ŌåÆ		os.Exit(1)
    18ŌåÆ	}
    19ŌåÆ	if len(os.Args) < 2 || len(os.Args) == 2 && os.Args[1] == "-" {
    20ŌåÆ		printHash(os.Stdin, "-")
    21ŌåÆ		return
    22ŌåÆ	}
    23ŌåÆ	for _, path := range os.Args[1:] {
    24ŌåÆ		f, err := os.Open(path)
    25ŌåÆ		if err != nil {
    26ŌåÆ			fmt.Fprintln(os.Stderr, err)
    27ŌåÆ			continue
    28ŌåÆ		}
    29ŌåÆ		printHash(f, path)

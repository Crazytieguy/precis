   540Ôćĺ///     you should freely add human-readable context to errors wherever it would
   541Ôćĺ///     be helpful.
   542Ôćĺ///
   543Ôćĺ///     ```
   544Ôćĺ///     # use anyhow::bail;
   545Ôćĺ///     # use thiserror::Error;
   546Ôćĺ///     #
   547Ôćĺ///     # #[derive(Error, Debug)]
   548Ôćĺ///     # #[error("???")]
   549Ôćĺ///     # struct SuspiciousError;
   550Ôćĺ///     #
   551Ôćĺ///     # fn helper() -> Result<()> {
   552Ôćĺ///     #     bail!(SuspiciousError);
   553Ôćĺ///     # }
   554Ôćĺ///     #
   555Ôćĺ///     use anyhow::{Context, Result};
   556Ôćĺ///
   557Ôćĺ///     fn do_it() -> Result<()> {
   558Ôćĺ///         helper().context("Failed to complete the work")?;
   559Ôćĺ///         # const IGNORE: &str = stringify! {
   560Ôćĺ///         ...
   561Ôćĺ///         # };
   562Ôćĺ///         # unreachable!()
   563Ôćĺ///     }
   564Ôćĺ///
   565Ôćĺ///     fn main() {
   566Ôćĺ///         let err = do_it().unwrap_err();

   288Ôćĺ/// The `Error` type, a wrapper around a dynamic error type.
   289Ôćĺ///
   290Ôćĺ/// `Error` works a lot like `Box<dyn std::error::Error>`, but with these
   291Ôćĺ/// differences:
   292Ôćĺ///
   293Ôćĺ/// - `Error` requires that the error is `Send`, `Sync`, and `'static`.
   294Ôćĺ/// - `Error` guarantees that a backtrace is available, even if the underlying
   295Ôćĺ///   error type does not provide one.
   296Ôćĺ/// - `Error` is represented as a narrow pointer &mdash; exactly one word in
   297Ôćĺ///   size instead of two.
   298Ôćĺ///
   299Ôćĺ/// <br>
   300Ôćĺ///
   301Ôćĺ/// # Display representations
   302Ôćĺ///
   303Ôćĺ/// When you print an error object using "{}" or to_string(), only the outermost
   304Ôćĺ/// underlying error or context is printed, not any of the lower level causes.
   305Ôćĺ/// This is exactly as if you had called the Display impl of the error from
   306Ôćĺ/// which you constructed your anyhow::Error.
   307Ôćĺ///
   308Ôćĺ/// ```console
   309Ôćĺ/// Failed to read instrs from ./path/to/instrs.json
   310Ôćĺ/// ```
   311Ôćĺ///
   312Ôćĺ/// To print causes as well using anyhow's default formatting of causes, use the
   313Ôćĺ/// alternate selector "{:#}".
   314Ôćĺ///
   315Ôćĺ/// ```console
   316Ôćĺ/// Failed to read instrs from ./path/to/instrs.json: No such file or directory (os error 2)
   317Ôćĺ/// ```
   318Ôćĺ///
   319Ôćĺ/// The Debug format "{:?}" includes your backtrace if one was captured. Note
   320Ôćĺ/// that this is the representation you get by default if you return an error
   321Ôćĺ/// from `fn main` instead of printing it explicitly yourself.
   322Ôćĺ///
   323Ôćĺ/// ```console
   324Ôćĺ/// Error: Failed to read instrs from ./path/to/instrs.json
   325Ôćĺ///
   326Ôćĺ/// Caused by:
   327Ôćĺ///     No such file or directory (os error 2)
   328Ôćĺ/// ```
   329Ôćĺ///
   330Ôćĺ/// and if there is a backtrace available:
   331Ôćĺ///
   332Ôćĺ/// ```console
   333Ôćĺ/// Error: Failed to read instrs from ./path/to/instrs.json
   334Ôćĺ///
   335Ôćĺ/// Caused by:
   336Ôćĺ///     No such file or directory (os error 2)
   337Ôćĺ///
   338Ôćĺ/// Stack backtrace:
   339Ôćĺ///    0: <E as anyhow::context::ext::StdError>::ext_context
   340Ôćĺ///              at /git/anyhow/src/backtrace.rs:26
   341Ôćĺ///    1: core::result::Result<T,E>::map_err
   342Ôćĺ///              at /git/rustc/src/libcore/result.rs:596
   343Ôćĺ///    2: anyhow::context::<impl anyhow::Context<T,E> for core::result::Result<T,E>>::with_context
   344Ôćĺ///              at /git/anyhow/src/context.rs:58
   345Ôćĺ///    3: testing::main
   346Ôćĺ///              at src/main.rs:5
   347Ôćĺ///    4: std::rt::lang_start
   348Ôćĺ///              at /git/rustc/src/libstd/rt.rs:61
   349Ôćĺ///    5: main
   350Ôćĺ///    6: __libc_start_main
   351Ôćĺ///    7: _start
   352Ôćĺ/// ```
   353Ôćĺ///
   354Ôćĺ/// To see a conventional struct-style Debug representation, use "{:#?}".
   355Ôćĺ///
   356Ôćĺ/// ```console
   357Ôćĺ/// Error {
   358Ôćĺ///     context: "Failed to read instrs from ./path/to/instrs.json",
   359Ôćĺ///     source: Os {
   360Ôćĺ///         code: 2,
   361Ôćĺ///         kind: NotFound,
   362Ôćĺ///         message: "No such file or directory",
   363Ôćĺ///     },
   364Ôćĺ/// }
   365Ôćĺ/// ```
   366Ôćĺ///
   367Ôćĺ/// If none of the built-in representations are appropriate and you would prefer
   368Ôćĺ/// to render the error and its cause chain yourself, it can be done something
   369Ôćĺ/// like this:
   370Ôćĺ///
   371Ôćĺ/// ```
   372Ôćĺ/// use anyhow::{Context, Result};
   373Ôćĺ///
   374Ôćĺ/// fn main() {
   375Ôćĺ///     if let Err(err) = try_main() {
   376Ôćĺ///         eprintln!("ERROR: {}", err);
   377Ôćĺ///         err.chain().skip(1).for_each(|cause| eprintln!("because: {}", cause));
   378Ôćĺ///         std::process::exit(1);
   379Ôćĺ///     }
   380Ôćĺ/// }
   381Ôćĺ///
   382Ôćĺ/// fn try_main() -> Result<()> {
   383Ôćĺ///     # const IGNORE: &str = stringify! {
   384Ôćĺ///     ...
   385Ôćĺ///     # };
   386Ôćĺ///     # Ok(())
   387Ôćĺ/// }
   388Ôćĺ/// ```
   389Ôćĺ#[repr(transparent)]
   390Ôćĺpub struct Error {
   394Ôćĺ/// Iterator of a chain of source errors.
   395Ôćĺ///
   396Ôćĺ/// This type is the iterator returned by [`Error::chain`].
   397Ôćĺ///
   398Ôćĺ/// # Example
   399Ôćĺ///
   400Ôćĺ/// ```
   401Ôćĺ/// use anyhow::Error;
   402Ôćĺ/// use std::io;
   403Ôćĺ///
   404Ôćĺ/// pub fn underlying_io_error_kind(error: &Error) -> Option<io::ErrorKind> {
   405Ôćĺ///     for cause in error.chain() {
   406Ôćĺ///         if let Some(io_error) = cause.downcast_ref::<io::Error>() {
   407Ôćĺ///             return Some(io_error.kind());
   408Ôćĺ///         }
   409Ôćĺ///     }
   410Ôćĺ///     None
   411Ôćĺ/// }
   412Ôćĺ/// ```
   413Ôćĺ#[cfg(any(feature = "std", not(anyhow_no_core_error)))]
   414Ôćĺ#[derive(Clone)]
   415Ôćĺpub struct Chain<'a> {
   419Ôćĺ/// `Result<T, Error>`
   420Ôćĺ///
   421Ôćĺ/// This is a reasonable return type to use throughout your application but also
   422Ôćĺ/// for `fn main`; if you do, failures will be printed along with any
   423Ôćĺ/// [context][Context] and a backtrace if one was captured.
   424Ôćĺ///
   425Ôćĺ/// `anyhow::Result` may be used with one *or* two type parameters.
   426Ôćĺ///
   427Ôćĺ/// ```rust
   428Ôćĺ/// use anyhow::Result;
   429Ôćĺ///
   430Ôćĺ/// # const IGNORE: &str = stringify! {
   431Ôćĺ/// fn demo1() -> Result<T> {...}

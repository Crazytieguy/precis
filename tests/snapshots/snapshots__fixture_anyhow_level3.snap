   568Ôćĺ///             // If helper() returned SuspiciousError, this downcast will
   569Ôćĺ///             // correctly succeed even with the context in between.
   570Ôćĺ///             # return;
   571Ôćĺ///         }
   572Ôćĺ///         # panic!("expected downcast to succeed");
   573Ôćĺ///     }
   574Ôćĺ///     ```
   575Ôćĺ///
   576Ôćĺ///   - **Attaching context whose type is used in downcasts onto errors whose
   577Ôćĺ///     type is insignificant.**
   578Ôćĺ///
   579Ôćĺ///     Some codebases prefer to use machine-readable context to categorize
   580Ôćĺ///     lower level errors in a way that will be actionable to higher levels of
   581Ôćĺ///     the application.
   582Ôćĺ///
   583Ôćĺ///     ```
   584Ôćĺ///     # use anyhow::bail;
   585Ôćĺ///     # use thiserror::Error;
   586Ôćĺ///     #
   587Ôćĺ///     # #[derive(Error, Debug)]
   588Ôćĺ///     # #[error("???")]
   589Ôćĺ///     # struct HelperFailed;
   590Ôćĺ///     #
   591Ôćĺ///     # fn helper() -> Result<()> {
   592Ôćĺ///     #     bail!("no such file or directory");
   593Ôćĺ///     # }
   594Ôćĺ///     #
   595Ôćĺ///     use anyhow::{Context, Result};
   596Ôćĺ///
   597Ôćĺ///     fn do_it() -> Result<()> {
   598Ôćĺ///         helper().context(HelperFailed)?;
   599Ôćĺ///         # const IGNORE: &str = stringify! {
   600Ôćĺ///         ...
   601Ôćĺ///         # };
   602Ôćĺ///         # unreachable!()
   603Ôćĺ///     }
   604Ôćĺ///
   605Ôćĺ///     fn main() {
   606Ôćĺ///         let err = do_it().unwrap_err();
   607Ôćĺ///         if let Some(e) = err.downcast_ref::<HelperFailed>() {
   608Ôćĺ///             // If helper failed, this downcast will succeed because
   609Ôćĺ///             // HelperFailed is the context that has been attached to
   610Ôćĺ///             // that error.
   611Ôćĺ///             # return;
   612Ôćĺ///         }
   613Ôćĺ///         # panic!("expected downcast to succeed");
   614Ôćĺ///     }

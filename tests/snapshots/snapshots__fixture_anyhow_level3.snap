    19Ôćĺ/// #
    20Ôćĺ/// # fn main() -> Result<()> {
    21Ôćĺ/// #     let user = 0;
    22Ôćĺ/// #     let resource = 0;
    23Ôćĺ/// #
    24Ôćĺ/// if !has_permission(user, resource) {
    25Ôćĺ///     bail!("permission denied for accessing {}", resource);

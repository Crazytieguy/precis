   433Ôćĺ///
   434Ôćĺ/// fn demo2() -> Result<T, OtherError> {...}
   435Ôćĺ///            // ^ equivalent to std::result::Result<T, OtherError>
   436Ôćĺ/// # };
   437Ôćĺ/// ```
   438Ôćĺ///
   439Ôćĺ/// # Example
   440Ôćĺ///
   441Ôćĺ/// ```
   442Ôćĺ/// # pub trait Deserialize {}
   443Ôćĺ/// #
   444Ôćĺ/// # mod serde_json {
   445Ôćĺ/// #     use super::Deserialize;
   446Ôćĺ/// #     use std::io;
   447Ôćĺ/// #
   448Ôćĺ/// #     pub fn from_str<T: Deserialize>(json: &str) -> io::Result<T> {
   449Ôćĺ/// #         unimplemented!()
   450Ôćĺ/// #     }
   451Ôćĺ/// # }
   452Ôćĺ/// #
   453Ôćĺ/// # #[derive(Debug)]
   454Ôćĺ/// # struct ClusterMap;
   455Ôćĺ/// #
   456Ôćĺ/// # impl Deserialize for ClusterMap {}
   457Ôćĺ/// #
   458Ôćĺ/// use anyhow::Result;
   459Ôćĺ///
   460Ôćĺ/// fn main() -> Result<()> {
   461Ôćĺ///     # return Ok(());
   462Ôćĺ///     let config = std::fs::read_to_string("cluster.json")?;
   463Ôćĺ///     let map: ClusterMap = serde_json::from_str(&config)?;
   464Ôćĺ///     println!("cluster info: {:#?}", map);
   465Ôćĺ///     Ok(())
   466Ôćĺ/// }
   467Ôćĺ/// ```
   468Ôćĺpub type Result<T, E = Error> = core::result::Result<T, E>;
   470Ôćĺ/// Provides the `context` method for `Result`.
   471Ôćĺ///
   472Ôćĺ/// This trait is sealed and cannot be implemented for types outside of
   473Ôćĺ/// `anyhow`.
   474Ôćĺ///
   475Ôćĺ/// <br>
   476Ôćĺ///
   477Ôćĺ/// # Example
   478Ôćĺ///
   479Ôćĺ/// ```
   480Ôćĺ/// use anyhow::{Context, Result};
   481Ôćĺ/// use std::fs;
   482Ôćĺ/// use std::path::PathBuf;
   483Ôćĺ///
   484Ôćĺ/// pub struct ImportantThing {
   485Ôćĺ///     path: PathBuf,
   486Ôćĺ/// }
   487Ôćĺ///
   488Ôćĺ/// impl ImportantThing {
   489Ôćĺ///     # const IGNORE: &'static str = stringify! {
   490Ôćĺ///     pub fn detach(&mut self) -> Result<()> {...}
   491Ôćĺ///     # };
   492Ôćĺ///     # fn detach(&mut self) -> Result<()> {
   493Ôćĺ///     #     unimplemented!()
   494Ôćĺ///     # }
   495Ôćĺ/// }
   496Ôćĺ///
   497Ôćĺ/// pub fn do_it(mut it: ImportantThing) -> Result<Vec<u8>> {
   498Ôćĺ///     it.detach().context("Failed to detach the important thing")?;
   499Ôćĺ///
   500Ôćĺ///     let path = &it.path;

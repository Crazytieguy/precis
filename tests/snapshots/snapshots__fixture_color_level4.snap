   538â†’// Black is a convenient helper function to print with black foreground. A
   539â†’// newline is appended to format by default.
   540â†’func Black(format string, a ...interface{}) { colorPrint(format, FgBlack, a...) }
   542â†’// Red is a convenient helper function to print with red foreground. A
   543â†’// newline is appended to format by default.

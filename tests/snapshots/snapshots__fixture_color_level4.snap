    15â†’var (
    16â†’	// NoColor defines if the output is colorized or not. It's dynamically set to
    17â†’	// false or true based on the stdout's file descriptor referring to a terminal
    18â†’	// or not. It's also set to true if the NO_COLOR environment variable is
    19â†’	// set (regardless of its value). This is a global option and affects all
    20â†’	// colors. For more control over each color block use the methods
    21â†’	// DisableColor() individually.
    22â†’	NoColor = noColorIsSet() || os.Getenv("TERM") == "dumb" ||
    25â†’	// Output defines the standard output of the print functions. By default,
    26â†’	// os.Stdout is used.
    27â†’	Output = colorable.NewColorableStdout()
    29â†’	// Error defines a color supporting writer for os.Stderr.
    30â†’	Error = colorable.NewColorableStderr()
    32â†’	// colorsCache is used to reduce the count of created Color objects and
    33â†’	// allows to reuse already created objects with required Attribute.
    34â†’	colorsCache   = make(map[Attribute]*Color)
    35â†’	colorsCacheMu sync.Mutex // protects colorsCache
    38â†’// noColorIsSet returns true if the environment variable NO_COLOR is set to a non-empty string.
    39â†’func noColorIsSet() bool {
    43â†’// Color defines a custom color object which is defined by SGR parameters.
    44â†’type Color struct {
    45â†’	params  []Attribute
    46â†’	noColor *bool
    47â†’}
    49â†’// Attribute defines a single SGR Code
    50â†’type Attribute int

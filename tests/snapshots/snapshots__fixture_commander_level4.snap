    12‚Üíclass Help {
    13‚Üí  constructor() {
    14‚Üí    this.helpWidth = undefined;
    15‚Üí    this.minWidthToWrap = 40;
    16‚Üí    this.sortSubcommands = false;
    17‚Üí    this.sortOptions = false;
    18‚Üí    this.showGlobalOptions = false;
    19‚Üí  }
    20‚Üí
    21‚Üí  /**
    22‚Üí   * prepareContext is called by Commander after applying overrides from `Command.configureHelp()`
    23‚Üí   * and just before calling `formatHelp()`.
    24‚Üí   *
    25‚Üí   * Commander just uses the helpWidth and the rest is provided for optional use by more complex subclasses.
    26‚Üí   *
    27‚Üí   * @param {{ error?: boolean, helpWidth?: number, outputHasColors?: boolean }} contextOptions
    28‚Üí   */
    29‚Üí  prepareContext(contextOptions) {
    30‚Üí    this.helpWidth = this.helpWidth ?? contextOptions.helpWidth ?? 80;
    31‚Üí  }
    32‚Üí
    33‚Üí  /**
    34‚Üí   * Get an array of the visible subcommands. Includes a placeholder for the implicit help command, if there is one.
    35‚Üí   *
    36‚Üí   * @param {Command} cmd
    37‚Üí   * @returns {Command[]}
    38‚Üí   */
    39‚Üí
    40‚Üí  visibleCommands(cmd) {
    41‚Üí    const visibleCommands = cmd.commands.filter((cmd) => !cmd._hidden);
    42‚Üí    const helpCommand = cmd._getHelpCommand();
    43‚Üí    if (helpCommand && !helpCommand._hidden) {
    44‚Üí      visibleCommands.push(helpCommand);
    45‚Üí    }
    46‚Üí    if (this.sortSubcommands) {
    47‚Üí      visibleCommands.sort((a, b) => {
    48‚Üí        // @ts-ignore: because overloaded return type
    49‚Üí        return a.name().localeCompare(b.name());
    50‚Üí      });
    51‚Üí    }
    52‚Üí    return visibleCommands;
    53‚Üí  }
    54‚Üí
    55‚Üí  /**
    56‚Üí   * Compare options for sort.
    57‚Üí   *
    58‚Üí   * @param {Option} a
    59‚Üí   * @param {Option} b
    60‚Üí   * @returns {number}
    61‚Üí   */
    62‚Üí  compareOptions(a, b) {
    63‚Üí    const getSortKey = (option) => {
    64‚Üí      // WYSIWYG for order displayed in help. Short used for comparison if present. No special handling for negated.
    65‚Üí      return option.short
    66‚Üí        ? option.short.replace(/^-/, '')
    67‚Üí        : option.long.replace(/^--/, '');
    68‚Üí    };
    69‚Üí    return getSortKey(a).localeCompare(getSortKey(b));
    70‚Üí  }
    71‚Üí
    72‚Üí  /**
    73‚Üí   * Get an array of the visible options. Includes a placeholder for the implicit help option, if there is one.
    74‚Üí   *
    75‚Üí   * @param {Command} cmd
    76‚Üí   * @returns {Option[]}
    77‚Üí   */
    78‚Üí
    79‚Üí  visibleOptions(cmd) {
    80‚Üí    const visibleOptions = cmd.options.filter((option) => !option.hidden);
    81‚Üí    // Built-in help option.
    82‚Üí    const helpOption = cmd._getHelpOption();
    83‚Üí    if (helpOption && !helpOption.hidden) {
    84‚Üí      // Automatically hide conflicting flags. Bit dubious but a historical behaviour that is convenient for single-command programs.
    85‚Üí      const removeShort = helpOption.short && cmd._findOption(helpOption.short);
    86‚Üí      const removeLong = helpOption.long && cmd._findOption(helpOption.long);
    87‚Üí      if (!removeShort && !removeLong) {
    88‚Üí        visibleOptions.push(helpOption); // no changes needed
    89‚Üí      } else if (helpOption.long && !removeLong) {
    90‚Üí        visibleOptions.push(
    91‚Üí          cmd.createOption(helpOption.long, helpOption.description),
    92‚Üí        );
    93‚Üí      } else if (helpOption.short && !removeShort) {
    94‚Üí        visibleOptions.push(
    95‚Üí          cmd.createOption(helpOption.short, helpOption.description),
    96‚Üí        );
    97‚Üí      }
    98‚Üí    }
    99‚Üí    if (this.sortOptions) {
   100‚Üí      visibleOptions.sort(this.compareOptions);
   101‚Üí    }
   102‚Üí    return visibleOptions;
   103‚Üí  }
   104‚Üí
   105‚Üí  /**
   106‚Üí   * Get an array of the visible global options. (Not including help.)
   107‚Üí   *
   108‚Üí   * @param {Command} cmd
   109‚Üí   * @returns {Option[]}
   110‚Üí   */
   111‚Üí
   112‚Üí  visibleGlobalOptions(cmd) {
   113‚Üí    if (!this.showGlobalOptions) return [];
   114‚Üí
   115‚Üí    const globalOptions = [];
   116‚Üí    for (
   117‚Üí      let ancestorCmd = cmd.parent;
   118‚Üí      ancestorCmd;
   119‚Üí      ancestorCmd = ancestorCmd.parent
   120‚Üí    ) {
   121‚Üí      const visibleOptions = ancestorCmd.options.filter(
   122‚Üí        (option) => !option.hidden,
   123‚Üí      );
   124‚Üí      globalOptions.push(...visibleOptions);
   125‚Üí    }
   126‚Üí    if (this.sortOptions) {
   127‚Üí      globalOptions.sort(this.compareOptions);
   128‚Üí    }
   129‚Üí    return globalOptions;
   130‚Üí  }
   131‚Üí
   132‚Üí  /**
   133‚Üí   * Get an array of the arguments if any have a description.
   134‚Üí   *
   135‚Üí   * @param {Command} cmd
   136‚Üí   * @returns {Argument[]}
   137‚Üí   */
   138‚Üí
   139‚Üí  visibleArguments(cmd) {
   140‚Üí    // Side effect! Apply the legacy descriptions before the arguments are displayed.
   141‚Üí    if (cmd._argsDescription) {
   142‚Üí      cmd.registeredArguments.forEach((argument) => {
   143‚Üí        argument.description =
   144‚Üí          argument.description || cmd._argsDescription[argument.name()] || '';
   145‚Üí      });
   146‚Üí    }
   147‚Üí
   148‚Üí    // If there are any arguments with a description then return all the arguments.
   149‚Üí    if (cmd.registeredArguments.find((argument) => argument.description)) {
   150‚Üí      return cmd.registeredArguments;
   151‚Üí    }
   152‚Üí    return [];
   153‚Üí  }
   154‚Üí
   155‚Üí  /**
   156‚Üí   * Get the command term to show in the list of subcommands.
   157‚Üí   *
   158‚Üí   * @param {Command} cmd
   159‚Üí   * @returns {string}
   160‚Üí   */
   161‚Üí
   162‚Üí  subcommandTerm(cmd) {
   163‚Üí    // Legacy. Ignores custom usage string, and nested commands.
   164‚Üí    const args = cmd.registeredArguments
   165‚Üí      .map((arg) => humanReadableArgName(arg))
   166‚Üí      .join(' ');
   167‚Üí    return (
   168‚Üí      cmd._name +
   169‚Üí      (cmd._aliases[0] ? '|' + cmd._aliases[0] : '') +
   170‚Üí      (cmd.options.length ? ' [options]' : '') + // simplistic check for non-help option
   171‚Üí      (args ? ' ' + args : '')
   172‚Üí    );
   173‚Üí  }
   174‚Üí
   175‚Üí  /**
   176‚Üí   * Get the option term to show in the list of options.
   177‚Üí   *
   178‚Üí   * @param {Option} option
   179‚Üí   * @returns {string}

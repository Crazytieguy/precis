   317‚Üí
   318‚Üí  /**
   319‚Üí   * Get the option description to show in the list of options.
   320‚Üí   *
   321‚Üí   * @param {Option} option
   322‚Üí   * @return {string}
   323‚Üí   */
   324‚Üí
   325‚Üí  optionDescription(option) {
   326‚Üí    const extraInfo = [];
   327‚Üí
   328‚Üí    if (option.argChoices) {
   329‚Üí      extraInfo.push(
   330‚Üí        // use stringify to match the display of the default value
   331‚Üí        `choices: ${option.argChoices.map((choice) => JSON.stringify(choice)).join(', ')}`,
   332‚Üí      );
   333‚Üí    }
   334‚Üí    if (option.defaultValue !== undefined) {
   335‚Üí      // default for boolean and negated more for programmer than end user,
   336‚Üí      // but show true/false for boolean option as may be for hand-rolled env or config processing.
   337‚Üí      const showDefault =
   338‚Üí        option.required ||
   339‚Üí        option.optional ||
   340‚Üí        (option.isBoolean() && typeof option.defaultValue === 'boolean');
   341‚Üí      if (showDefault) {
   342‚Üí        extraInfo.push(
   343‚Üí          `default: ${option.defaultValueDescription || JSON.stringify(option.defaultValue)}`,
   344‚Üí        );
   345‚Üí      }
   346‚Üí    }
   347‚Üí    // preset for boolean and negated are more for programmer than end user
   348‚Üí    if (option.presetArg !== undefined && option.optional) {
   349‚Üí      extraInfo.push(`preset: ${JSON.stringify(option.presetArg)}`);
   350‚Üí    }
   351‚Üí    if (option.envVar !== undefined) {
   352‚Üí      extraInfo.push(`env: ${option.envVar}`);
   353‚Üí    }
   354‚Üí    if (extraInfo.length > 0) {
   355‚Üí      const extraDescription = `(${extraInfo.join(', ')})`;
   356‚Üí      if (option.description) {
   357‚Üí        return `${option.description} ${extraDescription}`;
   358‚Üí      }
   359‚Üí      return extraDescription;
   360‚Üí    }
   361‚Üí
   362‚Üí    return option.description;
   363‚Üí  }
   364‚Üí
   365‚Üí  /**
   366‚Üí   * Get the argument description to show in the list of arguments.
   367‚Üí   *
   368‚Üí   * @param {Argument} argument
   369‚Üí   * @return {string}
   370‚Üí   */
   371‚Üí
   372‚Üí  argumentDescription(argument) {
   373‚Üí    const extraInfo = [];
   374‚Üí    if (argument.argChoices) {
   375‚Üí      extraInfo.push(
   376‚Üí        // use stringify to match the display of the default value
   377‚Üí        `choices: ${argument.argChoices.map((choice) => JSON.stringify(choice)).join(', ')}`,
   378‚Üí      );
   379‚Üí    }
   380‚Üí    if (argument.defaultValue !== undefined) {
   381‚Üí      extraInfo.push(
   382‚Üí        `default: ${argument.defaultValueDescription || JSON.stringify(argument.defaultValue)}`,
   383‚Üí      );
   384‚Üí    }
   385‚Üí    if (extraInfo.length > 0) {
   386‚Üí      const extraDescription = `(${extraInfo.join(', ')})`;
   387‚Üí      if (argument.description) {
   388‚Üí        return `${argument.description} ${extraDescription}`;
   389‚Üí      }
   390‚Üí      return extraDescription;
   391‚Üí    }
   392‚Üí    return argument.description;
   393‚Üí  }
   394‚Üí
   395‚Üí  /**
   396‚Üí   * Format a list of items, given a heading and an array of formatted items.
   397‚Üí   *
   398‚Üí   * @param {string} heading
   399‚Üí   * @param {string[]} items
   400‚Üí   * @param {Help} helper
   401‚Üí   * @returns string[]
   402‚Üí   */
   403‚Üí  formatItemList(heading, items, helper) {
   404‚Üí    if (items.length === 0) return [];
   405‚Üí
   406‚Üí    return [helper.styleTitle(heading), ...items, ''];
   407‚Üí  }
   408‚Üí
   409‚Üí  /**
   410‚Üí   * Group items by their help group heading.
   411‚Üí   *
   412‚Üí   * @param {Command[] | Option[]} unsortedItems
   413‚Üí   * @param {Command[] | Option[]} visibleItems
   414‚Üí   * @param {Function} getGroup
   415‚Üí   * @returns {Map<string, Command[] | Option[]>}
   416‚Üí   */
   417‚Üí  groupItems(unsortedItems, visibleItems, getGroup) {
   418‚Üí    const result = new Map();
   419‚Üí    // Add groups in order of appearance in unsortedItems.
   420‚Üí    unsortedItems.forEach((item) => {
   421‚Üí      const group = getGroup(item);
   422‚Üí      if (!result.has(group)) result.set(group, []);
   423‚Üí    });
   424‚Üí    // Add items in order of appearance in visibleItems.
   425‚Üí    visibleItems.forEach((item) => {
   426‚Üí      const group = getGroup(item);
   427‚Üí      if (!result.has(group)) {
   428‚Üí        result.set(group, []);
   429‚Üí      }
   430‚Üí      result.get(group).push(item);
   431‚Üí    });
   432‚Üí    return result;
   433‚Üí  }
   434‚Üí
   435‚Üí  /**
   436‚Üí   * Generate the built-in help text.
   437‚Üí   *
   438‚Üí   * @param {Command} cmd
   439‚Üí   * @param {Help} helper

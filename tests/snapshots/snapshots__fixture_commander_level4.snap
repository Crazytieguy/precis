     1‚Üí/**
     2‚Üí * CommanderError class
     3‚Üí */
     4‚Üíclass CommanderError extends Error {
     5‚Üí  /**
     6‚Üí   * Constructs the CommanderError class
     7‚Üí   * @param {number} exitCode suggested exit code which could be used with process.exit
     8‚Üí   * @param {string} code an id string representing the error
     9‚Üí   * @param {string} message human-readable description of the error
    10‚Üí   */
    11‚Üí  constructor(exitCode, code, message) {
    12‚Üí    super(message);
    13‚Üí    // properly capture stack trace in Node.js
    14‚Üí    Error.captureStackTrace(this, this.constructor);
    15‚Üí    this.name = this.constructor.name;
    16‚Üí    this.code = code;
    17‚Üí    this.exitCode = exitCode;
    18‚Üí    this.nestedError = undefined;
    19‚Üí  }
    20‚Üí}
    22‚Üí/**
    23‚Üí * InvalidArgumentError class
    24‚Üí */
    25‚Üíclass InvalidArgumentError extends CommanderError {
    26‚Üí  /**
    27‚Üí   * Constructs the InvalidArgumentError class
    28‚Üí   * @param {string} [message] explanation of why argument is invalid
    29‚Üí   */
    30‚Üí  constructor(message) {
    31‚Üí    super(1, 'commander.invalidArgument', message);
    32‚Üí    // properly capture stack trace in Node.js
    33‚Üí    Error.captureStackTrace(this, this.constructor);
    34‚Üí    this.name = this.constructor.name;
    35‚Üí  }
    36‚Üí}

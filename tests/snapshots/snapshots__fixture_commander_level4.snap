   282→   *
   283→   * @param {Command} cmd - new subcommand
   284→   * @param {object} [opts] - configuration options
   285→   * @return {Command} `this` command for chaining
   286→   */
   287→
   288→  addCommand(cmd, opts) {
   289→    if (!cmd._name) {
   290→      throw new Error(`Command passed to .addCommand() must have a name
   291→- specify the name in Command constructor or using .name()`);

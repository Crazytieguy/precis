   309‚Üí   * @param {Command} cmd
   310‚Üí   * @returns {string}
   311‚Üí   */
   312‚Üí
   313‚Üí  subcommandDescription(cmd) {
   314‚Üí    // @ts-ignore: because overloaded return type
   315‚Üí    return cmd.summary() || cmd.description();

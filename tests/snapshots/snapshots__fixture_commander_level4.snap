   195‚Üí  }
   196‚Üí
   197‚Üí  /**
   198‚Üí   * Get the longest command term length.
   199‚Üí   *
   200‚Üí   * @param {Command} cmd
   201‚Üí   * @param {Help} helper
   202‚Üí   * @returns {number}
   203‚Üí   */
   204‚Üí
   205‚Üí  longestSubcommandTermLength(cmd, helper) {
   206‚Üí    return helper.visibleCommands(cmd).reduce((max, command) => {
   207‚Üí      return Math.max(
   208‚Üí        max,
   209‚Üí        this.displayWidth(
   210‚Üí          helper.styleSubcommandTerm(helper.subcommandTerm(command)),
   211‚Üí        ),
   212‚Üí      );
   213‚Üí    }, 0);
   214‚Üí  }
   215‚Üí
   216‚Üí  /**
   217‚Üí   * Get the longest option term length.
   218‚Üí   *
   219‚Üí   * @param {Command} cmd
   220‚Üí   * @param {Help} helper
   221‚Üí   * @returns {number}
   222‚Üí   */
   223‚Üí
   224‚Üí  longestOptionTermLength(cmd, helper) {
   225‚Üí    return helper.visibleOptions(cmd).reduce((max, option) => {
   226‚Üí      return Math.max(
   227‚Üí        max,
   228‚Üí        this.displayWidth(helper.styleOptionTerm(helper.optionTerm(option))),
   229‚Üí      );
   230‚Üí    }, 0);
   231‚Üí  }
   232‚Üí
   233‚Üí  /**
   234‚Üí   * Get the longest global option term length.
   235‚Üí   *
   236‚Üí   * @param {Command} cmd
   237‚Üí   * @param {Help} helper
   238‚Üí   * @returns {number}
   239‚Üí   */
   240‚Üí
   241‚Üí  longestGlobalOptionTermLength(cmd, helper) {
   242‚Üí    return helper.visibleGlobalOptions(cmd).reduce((max, option) => {
   243‚Üí      return Math.max(
   244‚Üí        max,
   245‚Üí        this.displayWidth(helper.styleOptionTerm(helper.optionTerm(option))),
   246‚Üí      );
   247‚Üí    }, 0);
   248‚Üí  }
   249‚Üí
   250‚Üí  /**
   251‚Üí   * Get the longest argument term length.
   252‚Üí   *
   253‚Üí   * @param {Command} cmd
   254‚Üí   * @param {Help} helper
   255‚Üí   * @returns {number}
   256‚Üí   */
   257‚Üí
   258‚Üí  longestArgumentTermLength(cmd, helper) {
   259‚Üí    return helper.visibleArguments(cmd).reduce((max, argument) => {
   260‚Üí      return Math.max(
   261‚Üí        max,
   262‚Üí        this.displayWidth(
   263‚Üí          helper.styleArgumentTerm(helper.argumentTerm(argument)),
   264‚Üí        ),
   265‚Üí      );
   266‚Üí    }, 0);
   267‚Üí  }
   268‚Üí
   269‚Üí  /**
   270‚Üí   * Get the command usage to be displayed at the top of the built-in help.

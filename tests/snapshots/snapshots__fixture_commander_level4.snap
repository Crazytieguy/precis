    12→class Help {
    13→  constructor() {
    14→    this.helpWidth = undefined;
    15→    this.minWidthToWrap = 40;
    16→    this.sortSubcommands = false;
    17→    this.sortOptions = false;
    18→    this.showGlobalOptions = false;
    19→  }
    20→
    21→  /**
    22→   * prepareContext is called by Commander after applying overrides from `Command.configureHelp()`
    23→   * and just before calling `formatHelp()`.
    24→   *
    25→   * Commander just uses the helpWidth and the rest is provided for optional use by more complex subclasses.
    26→   *
    27→   * @param {{ error?: boolean, helpWidth?: number, outputHasColors?: boolean }} contextOptions
    28→   */
    29→  prepareContext(contextOptions) {
    30→    this.helpWidth = this.helpWidth ?? contextOptions.helpWidth ?? 80;
    31→  }
    32→
    33→  /**
    34→   * Get an array of the visible subcommands. Includes a placeholder for the implicit help command, if there is one.
    35→   *

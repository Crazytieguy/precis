   534‚Üí   */
   535‚Üí  displayWidth(str) {
   536‚Üí    return stripColor(str).length;
   537‚Üí  }
   538‚Üí
   539‚Üí  /**
   540‚Üí   * Style the title for displaying in the help. Called with 'Usage:', 'Options:', etc.
   541‚Üí   *
   542‚Üí   * @param {string} str
   543‚Üí   * @returns {string}
   544‚Üí   */
   545‚Üí  styleTitle(str) {
   546‚Üí    return str;
   547‚Üí  }
   548‚Üí
   549‚Üí  styleUsage(str) {
   550‚Üí    // Usage has lots of parts the user might like to color separately! Assume default usage string which is formed like:
   551‚Üí    //    command subcommand [options] [command] <foo> [bar]
   552‚Üí    return str
   553‚Üí      .split(' ')
   554‚Üí      .map((word) => {
   555‚Üí        if (word === '[options]') return this.styleOptionText(word);
   556‚Üí        if (word === '[command]') return this.styleSubcommandText(word);
   557‚Üí        if (word[0] === '[' || word[0] === '<')
   558‚Üí          return this.styleArgumentText(word);
   559‚Üí        return this.styleCommandText(word); // Restrict to initial words?
   560‚Üí      })
   561‚Üí      .join(' ');
   562‚Üí  }
   563‚Üí  styleCommandDescription(str) {
   564‚Üí    return this.styleDescriptionText(str);
   565‚Üí  }
   566‚Üí  styleOptionDescription(str) {
   567‚Üí    return this.styleDescriptionText(str);
   568‚Üí  }
   569‚Üí  styleSubcommandDescription(str) {
   570‚Üí    return this.styleDescriptionText(str);
   571‚Üí  }
   572‚Üí  styleArgumentDescription(str) {
   573‚Üí    return this.styleDescriptionText(str);
   574‚Üí  }
   575‚Üí  styleDescriptionText(str) {
   576‚Üí    return str;
   577‚Üí  }
   578‚Üí  styleOptionTerm(str) {
   579‚Üí    return this.styleOptionText(str);
   580‚Üí  }
   581‚Üí  styleSubcommandTerm(str) {
   582‚Üí    // This is very like usage with lots of parts! Assume default string which is formed like:
   583‚Üí    //    subcommand [options] <foo> [bar]
   584‚Üí    return str
   585‚Üí      .split(' ')
   586‚Üí      .map((word) => {
   587‚Üí        if (word === '[options]') return this.styleOptionText(word);
   588‚Üí        if (word[0] === '[' || word[0] === '<')
   589‚Üí          return this.styleArgumentText(word);

    60→   * @returns {number}
    61→   */
    62→  compareOptions(a, b) {
    63→    const getSortKey = (option) => {
    64→      // WYSIWYG for order displayed in help. Short used for comparison if present. No special handling for negated.
    65→      return option.short
    66→        ? option.short.replace(/^-/, '')

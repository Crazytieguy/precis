   449‚Üí    }
   450‚Üí
   451‚Üí    // Usage
   452‚Üí    let output = [
   453‚Üí      `${helper.styleTitle('Usage:')} ${helper.styleUsage(helper.commandUsage(cmd))}`,
   454‚Üí      '',
   455‚Üí    ];
   456‚Üí
   457‚Üí    // Description
   458‚Üí    const commandDescription = helper.commandDescription(cmd);
   459‚Üí    if (commandDescription.length > 0) {
   460‚Üí      output = output.concat([
   461‚Üí        helper.boxWrap(
   462‚Üí          helper.styleCommandDescription(commandDescription),
   463‚Üí          helpWidth,
   464‚Üí        ),
   465‚Üí        '',
   466‚Üí      ]);
   467‚Üí    }
   468‚Üí
   469‚Üí    // Arguments
   470‚Üí    const argumentList = helper.visibleArguments(cmd).map((argument) => {
   471‚Üí      return callFormatItem(
   472‚Üí        helper.styleArgumentTerm(helper.argumentTerm(argument)),
   473‚Üí        helper.styleArgumentDescription(helper.argumentDescription(argument)),
   474‚Üí      );
   475‚Üí    });
   476‚Üí    output = output.concat(
   477‚Üí      this.formatItemList('Arguments:', argumentList, helper),
   478‚Üí    );
   479‚Üí
   480‚Üí    // Options
   481‚Üí    const optionGroups = this.groupItems(
   482‚Üí      cmd.options,
   483‚Üí      helper.visibleOptions(cmd),
   484‚Üí      (option) => option.helpGroupHeading ?? 'Options:',
   485‚Üí    );
   486‚Üí    optionGroups.forEach((options, group) => {
   487‚Üí      const optionList = options.map((option) => {
   488‚Üí        return callFormatItem(
   489‚Üí          helper.styleOptionTerm(helper.optionTerm(option)),
   490‚Üí          helper.styleOptionDescription(helper.optionDescription(option)),
   491‚Üí        );
   492‚Üí      });

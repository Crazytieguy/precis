    37→   * @returns {Command[]}
    38→   */
    39→
    40→  visibleCommands(cmd) {
    41→    const visibleCommands = cmd.commands.filter((cmd) => !cmd._hidden);
    42→    const helpCommand = cmd._getHelpCommand();
    43→    if (helpCommand && !helpCommand._hidden) {
    44→      visibleCommands.push(helpCommand);
    45→    }

   501‚Üí            helper.styleOptionTerm(helper.optionTerm(option)),
   502‚Üí            helper.styleOptionDescription(helper.optionDescription(option)),
   503‚Üí          );
   504‚Üí        });
   505‚Üí      output = output.concat(
   506‚Üí        this.formatItemList('Global Options:', globalOptionList, helper),
   507‚Üí      );
   508‚Üí    }
   509‚Üí
   510‚Üí    // Commands
   511‚Üí    const commandGroups = this.groupItems(
   512‚Üí      cmd.commands,
   513‚Üí      helper.visibleCommands(cmd),
   514‚Üí      (sub) => sub.helpGroup() || 'Commands:',
   515‚Üí    );
   516‚Üí    commandGroups.forEach((commands, group) => {
   517‚Üí      const commandList = commands.map((sub) => {
   518‚Üí        return callFormatItem(
   519‚Üí          helper.styleSubcommandTerm(helper.subcommandTerm(sub)),
   520‚Üí          helper.styleSubcommandDescription(helper.subcommandDescription(sub)),
   521‚Üí        );
   522‚Üí      });
   523‚Üí      output = output.concat(this.formatItemList(group, commandList, helper));
   524‚Üí    });
   525‚Üí
   526‚Üí    return output.join('\n');
   527‚Üí  }
   528‚Üí
   529‚Üí  /**

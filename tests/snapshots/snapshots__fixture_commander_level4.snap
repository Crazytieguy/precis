     3‚Üíclass Argument {
     4‚Üí  /**
     5‚Üí   * Initialize a new command argument with the given name and description.
     6‚Üí   * The default is that the argument is required, and you can explicitly
     7‚Üí   * indicate this with <> around the name. Put [] around the name for an optional argument.
     8‚Üí   *
     9‚Üí   * @param {string} name
    10‚Üí   * @param {string} [description]
    11‚Üí   */
    12‚Üí
    13‚Üí  constructor(name, description) {
    14‚Üí    this.description = description || '';
    15‚Üí    this.variadic = false;
    16‚Üí    this.parseArg = undefined;
    17‚Üí    this.defaultValue = undefined;
    18‚Üí    this.defaultValueDescription = undefined;
    19‚Üí    this.argChoices = undefined;
    20‚Üí
    21‚Üí    switch (name[0]) {
    22‚Üí      case '<': // e.g. <required>
    23‚Üí        this.required = true;
    24‚Üí        this._name = name.slice(1, -1);
    25‚Üí        break;
    26‚Üí      case '[': // e.g. [optional]
    27‚Üí        this.required = false;
    28‚Üí        this._name = name.slice(1, -1);
    29‚Üí        break;
    30‚Üí      default:
    31‚Üí        this.required = true;
    32‚Üí        this._name = name;
    33‚Üí        break;
    34‚Üí    }
    35‚Üí
    36‚Üí    if (this._name.endsWith('...')) {
    37‚Üí      this.variadic = true;
    38‚Üí      this._name = this._name.slice(0, -3);
    39‚Üí    }
    40‚Üí  }
    41‚Üí
    42‚Üí  /**
    43‚Üí   * Return argument name.
    44‚Üí   *
    45‚Üí   * @return {string}
    46‚Üí   */
    47‚Üí
    48‚Üí  name() {
    49‚Üí    return this._name;
    50‚Üí  }
    51‚Üí
    52‚Üí  /**
    53‚Üí   * @package
    54‚Üí   */
    55‚Üí
    56‚Üí  _collectValue(value, previous) {
    57‚Üí    if (previous === this.defaultValue || !Array.isArray(previous)) {
    58‚Üí      return [value];
    59‚Üí    }
    60‚Üí
    61‚Üí    previous.push(value);
    62‚Üí    return previous;
    63‚Üí  }
    64‚Üí
    65‚Üí  /**
    66‚Üí   * Set the default value, and optionally supply the description to be displayed in the help.
    67‚Üí   *

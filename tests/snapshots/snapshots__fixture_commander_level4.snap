   593‚Üí  }
   594‚Üí  styleArgumentTerm(str) {
   595‚Üí    return this.styleArgumentText(str);
   596‚Üí  }
   597‚Üí  styleOptionText(str) {
   598‚Üí    return str;
   599‚Üí  }
   600‚Üí  styleArgumentText(str) {
   601‚Üí    return str;
   602‚Üí  }
   603‚Üí  styleSubcommandText(str) {
   604‚Üí    return str;
   605‚Üí  }
   606‚Üí  styleCommandText(str) {
   607‚Üí    return str;
   608‚Üí  }

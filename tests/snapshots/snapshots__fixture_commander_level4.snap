   181‚Üí
   182‚Üí  optionTerm(option) {
   183‚Üí    return option.flags;
   184‚Üí  }
   185‚Üí
   186‚Üí  /**
   187‚Üí   * Get the argument term to show in the list of arguments.
   188‚Üí   *
   189‚Üí   * @param {Argument} argument
   190‚Üí   * @returns {string}
   191‚Üí   */
   192‚Üí
   193‚Üí  argumentTerm(argument) {

   663‚Üí    const remainingWidth = helpWidth - termWidth - spacerWidth - itemIndent;
   664‚Üí    let formattedDescription;
   665‚Üí    if (
   666‚Üí      remainingWidth < this.minWidthToWrap ||
   667‚Üí      helper.preformatted(description)
   668‚Üí    ) {
   669‚Üí      formattedDescription = description;
   670‚Üí    } else {
   671‚Üí      const wrappedDescription = helper.boxWrap(description, remainingWidth);
   672‚Üí      formattedDescription = wrappedDescription.replace(
   673‚Üí        /\n/g,
   674‚Üí        '\n' + ' '.repeat(termWidth + spacerWidth),
   675‚Üí      );
   676‚Üí    }
   677‚Üí
   678‚Üí    // Construct and overall indent.
   679‚Üí    return (
   680‚Üí      itemIndentStr +
   681‚Üí      paddedTerm +
   682‚Üí      ' '.repeat(spacerWidth) +
   683‚Üí      formattedDescription.replace(/\n/g, `\n${itemIndentStr}`)
   684‚Üí    );
   685‚Üí  }
   686‚Üí
   687‚Üí  /**
   688‚Üí   * Wrap a string at whitespace, preserving existing line breaks.
   689‚Üí   * Wrapping is skipped if the width is less than `minWidthToWrap`.
   690‚Üí   *
   691‚Üí   * @param {string} str
   692‚Üí   * @param {number} width

   617‚Üí
   618‚Üí  padWidth(cmd, helper) {
   619‚Üí    return Math.max(
   620‚Üí      helper.longestOptionTermLength(cmd, helper),
   621‚Üí      helper.longestGlobalOptionTermLength(cmd, helper),
   622‚Üí      helper.longestSubcommandTermLength(cmd, helper),
   623‚Üí      helper.longestArgumentTermLength(cmd, helper),
   624‚Üí    );
   625‚Üí  }
   626‚Üí
   627‚Üí  /**
   628‚Üí   * Detect manually wrapped and indented strings by checking for line break followed by whitespace.

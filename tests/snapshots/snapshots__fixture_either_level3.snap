    99‚Üí/// ```
   100‚Üí/// use either::{Either, Left, Right};
   101‚Üí///
   102‚Üí/// fn twice(wrapper: Either<u32, &str>) -> Either<u32, &str> {
   103‚Üí///     let value = either::try_left!(wrapper);
   104‚Üí///     Left(value * 2)
   105‚Üí/// }
   106‚Üí///
   107‚Üí/// fn main() {
   108‚Üí///     assert_eq!(twice(Left(2)), Left(4));

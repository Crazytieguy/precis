    41‚Üí/// The enum `Either` with variants `Left` and `Right` is a general purpose
    42‚Üí/// sum type with two cases.
    43‚Üí///
    44‚Üí/// The `Either` type is symmetric and treats its variants the same way, without
    45‚Üí/// preference.
    46‚Üí/// (For representing success or error, use the regular `Result` enum instead.)
    47‚Üí#[cfg_attr(feature = "serde", derive(serde::Serialize, serde::Deserialize))]
    48‚Üí#[derive(Copy, PartialEq, Eq, PartialOrd, Ord, Hash, Debug)]
    49‚Üípub enum Either<L, R> {
    56‚Üí/// Evaluate the provided expression for both [`Either::Left`] and [`Either::Right`].
    57‚Üí///
    58‚Üí/// This macro is useful in cases where both sides of [`Either`] can be interacted with
    59‚Üí/// in the same way even though the don't share the same type.
    60‚Üí///
    61‚Üí/// Syntax: `either::for_both!(` *expression* `,` *pattern* `=>` *expression* `)`
    62‚Üí///
    63‚Üí/// # Example
    64‚Üí///
    65‚Üí/// ```
    66‚Üí/// use either::Either;
    67‚Üí///
    68‚Üí/// fn length(owned_or_borrowed: Either<String, &'static str>) -> usize {
    69‚Üí///     either::for_both!(owned_or_borrowed, s => s.len())
    70‚Üí/// }
    71‚Üí///
    72‚Üí/// fn main() {
    73‚Üí///     let borrowed = Either::Right("Hello world!");
    74‚Üí///     let owned = Either::Left("Hello world!".to_owned());
    75‚Üí///
    76‚Üí///     assert_eq!(length(borrowed), 12);
    77‚Üí///     assert_eq!(length(owned), 12);
    78‚Üí/// }
    79‚Üí/// ```
    80‚Üí#[macro_export]
    81‚Üímacro_rules! for_both {
    90‚Üí/// Macro for unwrapping the left side of an [`Either`], which fails early
    91‚Üí/// with the opposite side. Can only be used in functions that return
    92‚Üí/// `Either` because of the early return of `Right` that it provides.
    93‚Üí///
    94‚Üí/// See also [`try_right!`] for its dual, which applies the same just to the
    95‚Üí/// right side.
    96‚Üí///
    97‚Üí/// # Example

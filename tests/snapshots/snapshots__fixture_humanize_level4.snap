   280→      >>> apnumber("7")
   281→      'seven'
   282→      >>> apnumber("foo")
   283→      'foo'
   284→      >>> apnumber(None)
   285→      'None'
   286→
   287→      ```
   288→
   289→    Args:
   290→        value (int, float, str): Integer to convert.
   291→
   292→    Returns:
   293→        str: For numbers 0-9, the number spelled out. Otherwise, the number. This always
   294→            returns a string unless the value was not `int`-able, then `str(value)`
   295→            is returned.
   296→    """
   321→def fractional(value: NumberOrString) -> str:
   322→    """Convert to fractional number.
   323→
   324→    There will be some cases where one might not want to show ugly decimal places for
   325→    floats and decimals.
   326→
   327→    This function returns a human-readable fractional number in form of fractions and
   328→    mixed fractions.
   329→
   330→    Pass in a string, or a number or a float, and this function returns:
   331→
   332→    * a string representation of a fraction
   333→    * or a whole number
   334→    * or a mixed fraction
   335→    * or the str output of the value, if it could not be converted
   336→
   337→    Examples:
   338→        ```pycon
   339→        >>> fractional(0.3)
   340→        '3/10'
   341→        >>> fractional(1.3)
   342→        '1 3/10'
   343→        >>> fractional(float(1/3))
   344→        '1/3'
   345→        >>> fractional(1)
   346→        '1'
   347→        >>> fractional("ten")
   348→        'ten'
   349→        >>> fractional(None)
   350→        'None'
   351→
   352→        ```
   353→
   354→    Args:
   355→        value (int, float, str): Integer to convert.
   356→
   357→    Returns:
   358→        str: Fractional number as a string.
   359→    """
   385→def scientific(value: NumberOrString, precision: int = 2) -> str:
   386→    """Return number in string scientific notation z.wq x 10ⁿ.
   387→
   388→    Examples:
   389→        ```pycon
   390→        >>> scientific(float(0.3))
   391→        '3.00 x 10⁻¹'
   392→        >>> scientific(int(500))
   393→        '5.00 x 10²'
   394→        >>> scientific(-1000)
   395→        '-1.00 x 10³'
   396→        >>> scientific(1000, 1)
   397→        '1.0 x 10³'
   398→        >>> scientific(1000, 3)
   399→        '1.000 x 10³'
   400→        >>> scientific("99")
   401→        '9.90 x 10¹'
   402→        >>> scientific("foo")
   403→        'foo'
   404→        >>> scientific(None)
   405→        'None'
   406→
   407→        ```
   408→
   409→    Args:
   410→        value (int, float, str): Input number.
   411→        precision (int): Number of decimal for first part of the number.
   412→
   413→    Returns:
   414→        str: Number in scientific notation z.wq x 10ⁿ.
   415→    """

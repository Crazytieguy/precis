   110ŌåÆdef intcomma(value: NumberOrString, ndigits: int | None = None) -> str:
   111ŌåÆ    """Converts an integer to a string containing commas every three digits.
   112ŌåÆ
   113ŌåÆ    For example, 3000 becomes "3,000" and 45000 becomes "45,000". To maintain some
   114ŌåÆ    compatibility with Django's `intcomma`, this function also accepts floats.
   115ŌåÆ
   116ŌåÆ    Examples:
   117ŌåÆ        ```pycon
   118ŌåÆ        >>> intcomma(100)
   119ŌåÆ        '100'
   120ŌåÆ        >>> intcomma("1000")
   121ŌåÆ        '1,000'
   122ŌåÆ        >>> intcomma(1_000_000)
   123ŌåÆ        '1,000,000'
   124ŌåÆ        >>> intcomma(1_234_567.25)
   125ŌåÆ        '1,234,567.25'
   126ŌåÆ        >>> intcomma(1234.5454545, 2)
   127ŌåÆ        '1,234.55'
   128ŌåÆ        >>> intcomma(14308.40, 1)
   129ŌåÆ        '14,308.4'
   130ŌåÆ        >>> intcomma("14308.40", 1)
   131ŌåÆ        '14,308.4'
   132ŌåÆ        >>> intcomma(None)
   133ŌåÆ        'None'
   134ŌåÆ
   135ŌåÆ        ```
   136ŌåÆ
   137ŌåÆ    Args:
   138ŌåÆ        value (int, float, str): Integer or float to convert.
   139ŌåÆ        ndigits (int, None): Digits of precision for rounding after the decimal point.
   140ŌåÆ
   141ŌåÆ    Returns:
   142ŌåÆ        str: String containing commas every three digits.
   143ŌåÆ    """
   195ŌåÆdef intword(value: NumberOrString, format: str = "%.1f") -> str:
   196ŌåÆ    """Converts a large integer to a friendly text representation.
   197ŌåÆ
   198ŌåÆ    Works best for numbers over 1 million. For example, 1_000_000 becomes "1.0 million",
   199ŌåÆ    1_200_000 becomes "1.2 million" and "1_200_000_000" becomes "1.2 billion". Supports
   200ŌåÆ    up to decillion (33 digits) and googol (100 digits).
   201ŌåÆ
   202ŌåÆ    Examples:
   203ŌåÆ        ```pycon
   204ŌåÆ        >>> intword("100")
   205ŌåÆ        '100'
   206ŌåÆ        >>> intword("12400")
   207ŌåÆ        '12.4 thousand'
   208ŌåÆ        >>> intword("1000000")
   209ŌåÆ        '1.0 million'
   210ŌåÆ        >>> intword(1_200_000_000)
   211ŌåÆ        '1.2 billion'
   212ŌåÆ        >>> intword(8100000000000000000000000000000000)
   213ŌåÆ        '8.1 decillion'
   214ŌåÆ        >>> intword(None)
   215ŌåÆ        'None'
   216ŌåÆ        >>> intword("1234000", "%0.3f")
   217ŌåÆ        '1.234 million'
   218ŌåÆ
   219ŌåÆ        ```
   220ŌåÆ
   221ŌåÆ    Args:
   222ŌåÆ        value (int, float, str): Integer to convert.
   223ŌåÆ        format (str): To change the number of decimal or general format of the number
   224ŌåÆ            portion.
   225ŌåÆ
   226ŌåÆ    Returns:
   227ŌåÆ        str: Friendly text representation as a string, unless the value passed could not
   228ŌåÆ            be coaxed into an `int`.
   229ŌåÆ    """

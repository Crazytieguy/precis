   410ŌåÆ
   411ŌåÆ    >>> from humanize.time import _suitable_minimum_unit, Unit
   412ŌåÆ    >>> _suitable_minimum_unit(Unit.HOURS, []).name
   413ŌåÆ    'HOURS'
   414ŌåÆ
   415ŌåÆ    But if suppressed, find a unit greater than the original one that is not
   416ŌåÆ    suppressed:
   417ŌåÆ
   418ŌåÆ    >>> _suitable_minimum_unit(Unit.HOURS, [Unit.HOURS]).name
   419ŌåÆ    'DAYS'
   420ŌåÆ
   421ŌåÆ    >>> _suitable_minimum_unit(Unit.HOURS, [Unit.HOURS, Unit.DAYS]).name
   422ŌåÆ    'MONTHS'

   435ŌåÆdef _suppress_lower_units(min_unit: Unit, suppress: Iterable[Unit]) -> set[Unit]:
   436ŌåÆ    """Extend suppressed units (if any) with all units lower than the minimum unit.
   437ŌåÆ
   438ŌåÆ    >>> from humanize.time import _suppress_lower_units, Unit
   439ŌåÆ    >>> [x.name for x in sorted(_suppress_lower_units(Unit.SECONDS, [Unit.DAYS]))]
   440ŌåÆ    ['MICROSECONDS', 'MILLISECONDS', 'DAYS']
   441ŌåÆ    """
   451ŌåÆdef precisedelta(
   452ŌåÆ    value: dt.timedelta | float | None,
   453ŌåÆ    minimum_unit: str = "seconds",
   454ŌåÆ    suppress: Iterable[str] = (),
   455ŌåÆ    format: str = "%0.2f",
   456ŌåÆ) -> str:
   457ŌåÆ    """Return a precise representation of a timedelta or number of seconds.
   458ŌåÆ
   459ŌåÆ    ```pycon
   460ŌåÆ    >>> import datetime as dt
   461ŌåÆ    >>> from humanize.time import precisedelta
   462ŌåÆ
   463ŌåÆ    >>> delta = dt.timedelta(seconds=3633, days=2, microseconds=123000)
   464ŌåÆ    >>> precisedelta(delta)
   465ŌåÆ    '2 days, 1 hour and 33.12 seconds'
   466ŌåÆ
   467ŌåÆ    ```
   468ŌåÆ
   469ŌåÆ    A custom `format` can be specified to control how the fractional part
   470ŌåÆ    is represented:
   471ŌåÆ
   472ŌåÆ    ```pycon
   473ŌåÆ    >>> precisedelta(delta, format="%0.4f")
   474ŌåÆ    '2 days, 1 hour and 33.1230 seconds'
   475ŌåÆ
   476ŌåÆ    ```
   477ŌåÆ
   478ŌåÆ    Instead, the `minimum_unit` can be changed to have a better resolution;
   479ŌåÆ    the function will still readjust the unit to use the greatest of the
   480ŌåÆ    units that does not lose precision.
   481ŌåÆ
   482ŌåÆ    For example setting microseconds but still representing the date with milliseconds:
   483ŌåÆ
   484ŌåÆ    ```pycon
   485ŌåÆ    >>> precisedelta(delta, minimum_unit="microseconds")
   486ŌåÆ    '2 days, 1 hour, 33 seconds and 123 milliseconds'
   487ŌåÆ
   488ŌåÆ    ```
   489ŌåÆ
   490ŌåÆ    If desired, some units can be suppressed: you will not see them represented and the
   491ŌåÆ    time of the other units will be adjusted to keep representing the same timedelta:
   492ŌåÆ
   493ŌåÆ    ```pycon
   494ŌåÆ    >>> precisedelta(delta, suppress=['days'])
   495ŌåÆ    '49 hours and 33.12 seconds'
   496ŌåÆ
   497ŌåÆ    ```
   498ŌåÆ
   499ŌåÆ    Note that microseconds precision is lost if the seconds and all
   500ŌåÆ    the units below are suppressed:
   501ŌåÆ
   502ŌåÆ    ```pycon
   503ŌåÆ    >>> delta = dt.timedelta(seconds=90, microseconds=100)
   504ŌåÆ    >>> precisedelta(delta, suppress=['seconds', 'milliseconds', 'microseconds'])
   505ŌåÆ    '1.50 minutes'
   506ŌåÆ
   507ŌåÆ    ```
   508ŌåÆ
   509ŌåÆ    If the delta is too small to be represented with the minimum unit,
   510ŌåÆ    a value of zero will be returned:
   511ŌåÆ
   512ŌåÆ    ```pycon
   513ŌåÆ    >>> delta = dt.timedelta(seconds=1)
   514ŌåÆ    >>> precisedelta(delta, minimum_unit="minutes")
   515ŌåÆ    '0.02 minutes'
   516ŌåÆ
   517ŌåÆ    >>> delta = dt.timedelta(seconds=0.1)
   518ŌåÆ    >>> precisedelta(delta, minimum_unit="minutes")
   519ŌåÆ    '0 minutes'
   520ŌåÆ
   521ŌåÆ    ```
   522ŌåÆ    """
   654ŌåÆdef _rounding_by_fmt(format: str, value: float) -> float | int:
   655ŌåÆ    """Round a number according to the string format provided.
   656ŌåÆ
   657ŌåÆ    The string format is the old printf-style string formatting.

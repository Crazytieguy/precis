    98Ôćĺ	try {
    99Ôćĺ		const data = await response.clone().json();
   100Ôćĺ		validateBusinessLogic(data);
   101Ôćĺ	} catch (error) {
   102Ôćĺ		return ky.retry({
   103Ôćĺ			code: 'VALIDATION_FAILED',

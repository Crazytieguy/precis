   157Ôćĺ@param options - Optional configuration for the retry.
   158Ôćĺ
   159Ôćĺ@example
   160Ôćĺ```
   161Ôćĺimport ky, {isForceRetryError} from 'ky';
   162Ôćĺ
   163Ôćĺconst api = ky.extend({
   164Ôćĺ	hooks: {
   165Ôćĺ		afterResponse: [
   166Ôćĺ			async (request, options, response) => {
   167Ôćĺ				// Retry based on response body content
   168Ôćĺ				if (response.status === 200) {
   169Ôćĺ					const data = await response.clone().json();
   170Ôćĺ
   171Ôćĺ					// Simple retry with default delay
   172Ôćĺ					if (data.error?.code === 'TEMPORARY_ERROR') {
   173Ôćĺ						return ky.retry();
   174Ôćĺ					}
   175Ôćĺ
   176Ôćĺ					// Retry with custom delay from API response
   177Ôćĺ					if (data.error?.code === 'RATE_LIMIT') {
   178Ôćĺ						return ky.retry({
   179Ôćĺ							delay: data.error.retryAfter * 1000,
   180Ôćĺ							code: 'RATE_LIMIT'
   181Ôćĺ						});
   182Ôćĺ					}
   183Ôćĺ
   184Ôćĺ					// Retry with a modified request (e.g., fallback endpoint)
   185Ôćĺ					if (data.error?.code === 'FALLBACK_TO_BACKUP') {
   186Ôćĺ						return ky.retry({
   187Ôćĺ							request: new Request('https://backup-api.com/endpoint', {
   188Ôćĺ								method: request.method,
   189Ôćĺ								headers: request.headers,
   190Ôćĺ							}),
   191Ôćĺ							code: 'BACKUP_ENDPOINT'
   192Ôćĺ						});
   193Ôćĺ					}
   194Ôćĺ
   195Ôćĺ					// Retry with refreshed authentication
   196Ôćĺ					if (data.error?.code === 'TOKEN_REFRESH' && data.newToken) {
   197Ôćĺ						return ky.retry({
   198Ôćĺ							request: new Request(request, {
   199Ôćĺ								headers: {
   200Ôćĺ									...Object.fromEntries(request.headers),
   201Ôćĺ									'Authorization': `Bearer ${data.newToken}`
   202Ôćĺ								}
   203Ôćĺ							}),
   204Ôćĺ							code: 'TOKEN_REFRESHED'
   205Ôćĺ						});
   206Ôćĺ					}
   207Ôćĺ
   208Ôćĺ					// Retry with cause to preserve error chain
   209Ôćĺ					try {
   210Ôćĺ						validateResponse(data);
   211Ôćĺ					} catch (error) {
   212Ôćĺ						return ky.retry({
   213Ôćĺ							code: 'VALIDATION_FAILED',
   214Ôćĺ							cause: error
   215Ôćĺ						});
   216Ôćĺ					}
   217Ôćĺ				}
   218Ôćĺ			}
   219Ôćĺ		],
   220Ôćĺ		beforeRetry: [
   221Ôćĺ			({error, retryCount}) => {
   222Ôćĺ				// Observable in beforeRetry hooks
   223Ôćĺ				if (isForceRetryError(error)) {
   224Ôćĺ					console.log(`Forced retry #${retryCount}: ${error.message}`);
   225Ôćĺ					// Example output: "Forced retry #1: Forced retry: RATE_LIMIT"
   226Ôćĺ				}
   227Ôćĺ			}
   228Ôćĺ		]
   229Ôćĺ	}
   230Ôćĺ});
   231Ôćĺ
   232Ôćĺconst response = await api.get('https://example.com/api');
   233Ôćĺ```
   234Ôćĺ*/

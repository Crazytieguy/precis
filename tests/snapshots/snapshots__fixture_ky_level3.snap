    59Ôćĺexport type Hooks = {
    60Ôćĺ	/**
    61Ôćĺ	This hook enables you to modify the request right before it is sent. Ky will make no further changes to the request after this. The hook function receives the normalized request, options, and a state object. You could, for example, modify `request.headers` here.
    62Ôćĺ
    63Ôćĺ	The `state.retryCount` is `0` for the initial request and increments with each retry. This allows you to distinguish between initial requests and retries, which is useful when you need different behavior for retries (e.g., avoiding overwriting headers set in `beforeRetry`).
    64Ôćĺ
    65Ôćĺ	A [`Response`](https://developer.mozilla.org/en-US/docs/Web/API/Response) can be returned from this hook to completely avoid making an HTTP request. This can be used to mock a request, check an internal cache, etc. An **important** consideration when returning a `Response` from this hook is that all the following hooks will be skipped, so **ensure you only return a `Response` from the last hook**.
    66Ôćĺ
    67Ôćĺ	@example
    68Ôćĺ	```
    69Ôćĺ	import ky from 'ky';
    70Ôćĺ
    71Ôćĺ	const response = await ky('https://example.com', {
    72Ôćĺ		hooks: {
    73Ôćĺ			beforeRequest: [
    74Ôćĺ				(request, options, {retryCount}) => {
    75Ôćĺ					// Only set default auth header on initial request, not on retries
    76Ôćĺ					// (retries may have refreshed token set by beforeRetry)
    77Ôćĺ					if (retryCount === 0) {
    78Ôćĺ						request.headers.set('Authorization', 'token initial-token');
    79Ôćĺ					}
    80Ôćĺ				}
    81Ôćĺ			]
    82Ôćĺ		}
    83Ôćĺ	});
    84Ôćĺ	```
    85Ôćĺ
    86Ôćĺ	@default []
    87Ôćĺ	*/
    88Ôćĺ	beforeRequest?: BeforeRequestHook[];
    89Ôćĺ
    90Ôćĺ	/**
    91Ôćĺ	This hook enables you to modify the request right before retry. Ky will make no further changes to the request after this. The hook function receives an object with the normalized request and options, an error instance, and the retry count. You could, for example, modify `request.headers` here.
    92Ôćĺ
    93Ôćĺ	The hook can return a [`Request`](https://developer.mozilla.org/en-US/docs/Web/API/Request) to replace the outgoing retry request, or return a [`Response`](https://developer.mozilla.org/en-US/docs/Web/API/Response) to skip the retry and use that response instead. **Note:** Returning a request or response skips remaining `beforeRetry` hooks.
    94Ôćĺ
    95Ôćĺ	If the request received a response, the error will be of type `HTTPError` and the `Response` object will be available at `error.response`. Be aware that some types of errors, such as network errors, inherently mean that a response was not received. In that case, the error will not be an instance of `HTTPError`.
    96Ôćĺ
    97Ôćĺ	You can prevent Ky from retrying the request by throwing an error. Ky will not handle it in any way and the error will be propagated to the request initiator. The rest of the `beforeRetry` hooks will not be called in this case. Alternatively, you can return the [`ky.stop`](#ky.stop) symbol to do the same thing but without propagating an error (this has some limitations, see `ky.stop` docs for details).
    98Ôćĺ
    99Ôćĺ	**Modifying headers:**
   100Ôćĺ
   101Ôćĺ	@example
   102Ôćĺ	```
   103Ôćĺ	import ky from 'ky';
   104Ôćĺ
   105Ôćĺ	const response = await ky('https://example.com', {
   106Ôćĺ		hooks: {
   107Ôćĺ			beforeRetry: [
   108Ôćĺ				async ({request, options, error, retryCount}) => {
   109Ôćĺ					const token = await ky('https://example.com/refresh-token');
   110Ôćĺ					request.headers.set('Authorization', `token ${token}`);
   111Ôćĺ				}
   112Ôćĺ			]
   113Ôćĺ		}
   114Ôćĺ	});
   115Ôćĺ	```
   116Ôćĺ
   117Ôćĺ	**Modifying the request URL:**
   118Ôćĺ
   119Ôćĺ	@example
   120Ôćĺ	```
   121Ôćĺ	import ky from 'ky';
   122Ôćĺ
   123Ôćĺ	const response = await ky('https://example.com/api', {
   124Ôćĺ		hooks: {
   125Ôćĺ			beforeRetry: [
   126Ôćĺ				async ({request, error}) => {
   127Ôćĺ					// Add query parameters based on error response
   128Ôćĺ					if (error.response) {

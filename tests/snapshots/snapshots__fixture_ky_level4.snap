    43→			await Promise.resolve();
    44→			// Before using ky.request, _fetch clones it and saves the clone for future retries to use.
    45→			// If retry is not needed, close the cloned request's ReadableStream for memory safety.
    46→			let response = await ky.#fetch();
    47→
    48→			for (const hook of ky.#options.hooks.afterResponse) {
    49→				// Clone the response before passing to hook so we can cancel it if needed
    50→				const clonedResponse = ky.#decorateResponse(response.clone());
    51→
    52→				let modifiedResponse;
    53→				try {
    54→					// eslint-disable-next-line no-await-in-loop
    55→					modifiedResponse = await hook(
    56→						ky.request,
    57→						ky.#getNormalizedOptions(),
    58→						clonedResponse,
    59→						{retryCount: ky.#retryCount},
    60→					);
    61→				} catch (error) {
    62→					// Cancel both responses to prevent memory leaks when hook throws
    63→					ky.#cancelResponseBody(clonedResponse);
    64→					ky.#cancelResponseBody(response);
    65→					throw error;
    66→				}
    67→
    68→				if (modifiedResponse instanceof RetryMarker) {
    69→					// Cancel both the cloned response passed to the hook and the current response to prevent resource leaks (especially important in Deno/Bun).
    70→					// Do not await cancellation since hooks can clone the response, leaving extra tee branches that keep cancel promises pending per the Streams spec.
    71→					ky.#cancelResponseBody(clonedResponse);
    72→					ky.#cancelResponseBody(response);

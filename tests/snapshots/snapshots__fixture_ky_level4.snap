    33→export class Ky {
    34→	static create(input: Input, options: Options): ResponsePromise {
    35→		const ky = new Ky(input, options);
    36→
    37→		const function_ = async (): Promise<Response> => {
    38→			if (typeof ky.#options.timeout === 'number' && ky.#options.timeout > maxSafeTimeout) {
    39→				throw new RangeError(`The \`timeout\` option cannot be greater than ${maxSafeTimeout}`);
    40→			}
    41→

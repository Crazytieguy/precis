   214‚Üí    ///
   215‚Üí    /// When the `kv_serde` or `kv_sval` features are enabled, you can also
   216‚Üí    /// serialize a value using its `Serialize` or `Value` implementation.
   217‚Üí    pub fn visit(&self, visitor: impl VisitValue<'v>) -> Result<(), Error> {
   222‚Üíimpl<'v> fmt::Debug for Value<'v> {
   223‚Üí    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {

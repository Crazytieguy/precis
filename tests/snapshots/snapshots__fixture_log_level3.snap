   491→    /// Visit a big signed integer.
   492→    fn visit_i128(&mut self, value: i128) -> Result<(), Error> {
   496→    /// Visit a floating point.
   497→    fn visit_f64(&mut self, value: f64) -> Result<(), Error> {
   501→    /// Visit a boolean.

   359‚Üí/// Determines if a message logged at the specified level in that module will
   360‚Üí/// be logged.
   361‚Üí///
   362‚Üí/// This can be used to avoid expensive computation of log message arguments if
   363‚Üí/// the message would be ignored anyway.
   364‚Üí///
   365‚Üí/// # Examples
   366‚Üí///
   367‚Üí/// ```
   368‚Üí/// use log::{debug, log_enabled, Level};
   369‚Üí///
   370‚Üí/// # struct Data { x: u32, y: u32 }
   371‚Üí/// # fn expensive_call() -> Data { Data { x: 0, y: 0 } }
   372‚Üí/// # let my_logger = log::__private_api::GlobalLogger;
   373‚Üí/// if log_enabled!(Level::Debug) {
   374‚Üí///     let data = expensive_call();
   375‚Üí///     debug!("expensive debug data: {} {}", data.x, data.y);
   376‚Üí/// }
   377‚Üí///
   378‚Üí/// if log_enabled!(target: "Global", Level::Debug) {
   379‚Üí///    let data = expensive_call();
   380‚Üí///    debug!(target: "Global", "expensive debug data: {} {}", data.x, data.y);
   381‚Üí/// }
   382‚Üí///
   383‚Üí/// if log_enabled!(logger: my_logger, Level::Debug) {
   384‚Üí///    let data = expensive_call();
   385‚Üí///    debug!(target: "Global", "expensive debug data: {} {}", data.x, data.y);
   386‚Üí/// }
   387‚Üí/// ```
   388‚Üí///
   389‚Üí/// This macro accepts the same `target` and `logger` arguments as [`macro@log`].
   390‚Üí#[macro_export]
   391‚Üímacro_rules! log_enabled {

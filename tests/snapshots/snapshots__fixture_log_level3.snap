   796‚Üí/// The "payload" of a log message.
   797‚Üí///
   798‚Üí/// # Use
   799‚Üí///
   800‚Üí/// `Record` structures are passed as parameters to the [`log`][method.log]
   801‚Üí/// method of the [`Log`] trait. Logger implementors manipulate these
   802‚Üí/// structures in order to display log messages. `Record`s are automatically
   803‚Üí/// created by the [`log!`] macro and so are not seen by log users.
   804‚Üí///
   805‚Üí/// Note that the [`level()`] and [`target()`] accessors are equivalent to
   806‚Üí/// `self.metadata().level()` and `self.metadata().target()` respectively.
   807‚Üí/// These methods are provided as a convenience for users of this structure.
   808‚Üí///
   809‚Üí/// # Example
   810‚Üí///
   811‚Üí/// The following example shows a simple logger that displays the level,
   812‚Üí/// module path, and message of any `Record` that is passed to it.
   813‚Üí///
   814‚Üí/// ```
   815‚Üí/// struct SimpleLogger;
   816‚Üí///
   817‚Üí/// impl log::Log for SimpleLogger {
   818‚Üí///    fn enabled(&self, _metadata: &log::Metadata) -> bool {
   819‚Üí///        true
   820‚Üí///    }
   821‚Üí///
   822‚Üí///    fn log(&self, record: &log::Record) {
   823‚Üí///        if !self.enabled(record.metadata()) {
   824‚Üí///            return;
   825‚Üí///        }
   826‚Üí///
   827‚Üí///        println!("{}:{} -- {}",
   828‚Üí///                 record.level(),
   829‚Üí///                 record.target(),
   830‚Üí///                 record.args());
   831‚Üí///    }
   832‚Üí///    fn flush(&self) {}
   833‚Üí/// }
   834‚Üí/// ```
   835‚Üí///
   836‚Üí/// [method.log]: trait.Log.html#tymethod.log
   837‚Üí/// [`Log`]: trait.Log.html

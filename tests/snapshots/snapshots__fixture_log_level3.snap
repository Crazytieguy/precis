  1119‚Üí/// Metadata about a log message.
  1120‚Üí///
  1121‚Üí/// # Use
  1122‚Üí///
  1123‚Üí/// `Metadata` structs are created when users of the library use
  1124‚Üí/// logging macros.
  1125‚Üí///
  1126‚Üí/// They are consumed by implementations of the `Log` trait in the
  1127‚Üí/// `enabled` method.
  1128‚Üí///
  1129‚Üí/// `Record`s use `Metadata` to determine the log message's severity
  1130‚Üí/// and target.
  1131‚Üí///
  1132‚Üí/// Users should use the `log_enabled!` macro in their code to avoid
  1133‚Üí/// constructing expensive log messages.
  1134‚Üí///
  1135‚Üí/// # Examples
  1136‚Üí///
  1137‚Üí/// ```
  1138‚Üí/// use log::{Record, Level, Metadata};
  1139‚Üí///
  1140‚Üí/// struct MyLogger;
  1141‚Üí///
  1142‚Üí/// impl log::Log for MyLogger {
  1143‚Üí///     fn enabled(&self, metadata: &Metadata) -> bool {
  1144‚Üí///         metadata.level() <= Level::Info
  1145‚Üí///     }
  1146‚Üí///
  1147‚Üí///     fn log(&self, record: &Record) {
  1148‚Üí///         if self.enabled(record.metadata()) {
  1149‚Üí///             println!("{} - {}", record.level(), record.args());
  1150‚Üí///         }
  1151‚Üí///     }
  1152‚Üí///     fn flush(&self) {}
  1153‚Üí/// }
  1154‚Üí///
  1155‚Üí/// # fn main(){}
  1156‚Üí/// ```

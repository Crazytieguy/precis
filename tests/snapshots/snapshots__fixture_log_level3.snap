   963‚Üí/// Builder for [`Record`](struct.Record.html).
   964‚Üí///
   965‚Üí/// Typically should only be used by log library creators or for testing and "shim loggers".
   966‚Üí/// The `RecordBuilder` can set the different parameters of `Record` object, and returns
   967‚Üí/// the created object when `build` is called.
   968‚Üí///
   969‚Üí/// # Examples
   970‚Üí///
   971‚Üí/// ```
   972‚Üí/// use log::{Level, Record};
   973‚Üí///
   974‚Üí/// let record = Record::builder()
   975‚Üí///                 .args(format_args!("Error!"))
   976‚Üí///                 .level(Level::Error)
   977‚Üí///                 .target("myApp")
   978‚Üí///                 .file(Some("server.rs"))
   979‚Üí///                 .line(Some(144))
   980‚Üí///                 .module_path(Some("server"))
   981‚Üí///                 .build();
   982‚Üí/// ```
   983‚Üí///
   984‚Üí/// Alternatively, use [`MetadataBuilder`](struct.MetadataBuilder.html):
   985‚Üí///
   986‚Üí/// ```
   987‚Üí/// use log::{Record, Level, MetadataBuilder};
   988‚Üí///
   989‚Üí/// let error_metadata = MetadataBuilder::new()
   990‚Üí///                         .target("myApp")
   991‚Üí///                         .level(Level::Error)
   992‚Üí///                         .build();
   993‚Üí///
   994‚Üí/// let record = Record::builder()
   995‚Üí///                 .metadata(error_metadata)
   996‚Üí///                 .args(format_args!("Error!"))
   997‚Üí///                 .line(Some(433))
   998‚Üí///                 .file(Some("app.rs"))
   999‚Üí///                 .module_path(Some("server"))
  1000‚Üí///                 .build();
  1001‚Üí/// ```

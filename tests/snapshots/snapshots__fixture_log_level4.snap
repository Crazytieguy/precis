   262Ôćĺpub mod value;
kv/source.rs
     9Ôćĺ/// A source of key-values.
    10Ôćĺ///
    11Ôćĺ/// The source may be a single pair, a set of pairs, or a filter over a set of pairs.
    12Ôćĺ/// Use the [`VisitSource`](trait.VisitSource.html) trait to inspect the structured data
    13Ôćĺ/// in a source.
    14Ôćĺ///
    15Ôćĺ/// A source is like an iterator over its key-values, except with a push-based API
    16Ôćĺ/// instead of a pull-based one.
    17Ôćĺ///
    18Ôćĺ/// # Examples
    19Ôćĺ///
    20Ôćĺ/// Enumerating the key-values in a source:
    21Ôćĺ///
    22Ôćĺ/// ```
    23Ôćĺ/// # fn main() -> Result<(), log::kv::Error> {
    24Ôćĺ/// use log::kv::{self, Source, Key, Value, VisitSource};
    25Ôćĺ///
    26Ôćĺ/// // A `VisitSource` that prints all key-values

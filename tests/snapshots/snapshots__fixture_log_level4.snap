   796Ôćĺ/// The "payload" of a log message.
   797Ôćĺ///
   798Ôćĺ/// # Use
   799Ôćĺ///
   800Ôćĺ/// `Record` structures are passed as parameters to the [`log`][method.log]
   801Ôćĺ/// method of the [`Log`] trait. Logger implementors manipulate these
   802Ôćĺ/// structures in order to display log messages. `Record`s are automatically
   803Ôćĺ/// created by the [`log!`] macro and so are not seen by log users.
   804Ôćĺ///
   805Ôćĺ/// Note that the [`level()`] and [`target()`] accessors are equivalent to
   806Ôćĺ/// `self.metadata().level()` and `self.metadata().target()` respectively.
   807Ôćĺ/// These methods are provided as a convenience for users of this structure.
   808Ôćĺ///
   809Ôćĺ/// # Example
   810Ôćĺ///
   811Ôćĺ/// The following example shows a simple logger that displays the level,
   812Ôćĺ/// module path, and message of any `Record` that is passed to it.
   813Ôćĺ///
   814Ôćĺ/// ```
   815Ôćĺ/// struct SimpleLogger;
   816Ôćĺ///
   817Ôćĺ/// impl log::Log for SimpleLogger {
   818Ôćĺ///    fn enabled(&self, _metadata: &log::Metadata) -> bool {
   819Ôćĺ///        true
   820Ôćĺ///    }
   821Ôćĺ///
   822Ôćĺ///    fn log(&self, record: &log::Record) {
   823Ôćĺ///        if !self.enabled(record.metadata()) {
   824Ôćĺ///            return;
   825Ôćĺ///        }
   826Ôćĺ///
   827Ôćĺ///        println!("{}:{} -- {}",
   828Ôćĺ///                 record.level(),
   829Ôćĺ///                 record.target(),
   830Ôćĺ///                 record.args());
   831Ôćĺ///    }
   832Ôćĺ///    fn flush(&self) {}
   833Ôćĺ/// }
   834Ôćĺ/// ```
   835Ôćĺ///
   836Ôćĺ/// [method.log]: trait.Log.html#tymethod.log
   837Ôćĺ/// [`Log`]: trait.Log.html

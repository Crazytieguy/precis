kv/mod.rs
     1Ôćĺ//! Structured logging.
     2Ôćĺ//!
     3Ôćĺ//! Add the `kv` feature to your `Cargo.toml` to enable
     4Ôćĺ//! this module:
     5Ôćĺ//!
     6Ôćĺ//! ```toml
     7Ôćĺ//! [dependencies.log]
     8Ôćĺ//! features = ["kv"]
     9Ôćĺ//! ```
    10Ôćĺ//!
    11Ôćĺ//! # Structured logging in `log`
    12Ôćĺ//!
    13Ôćĺ//! Structured logging enhances traditional text-based log records with user-defined
    14Ôćĺ//! attributes. Structured logs can be analyzed using a variety of data processing
    15Ôćĺ//! techniques, without needing to find and parse attributes from unstructured text first.
    16Ôćĺ//!
    17Ôćĺ//! In `log`, user-defined attributes are part of a [`Source`] on the log record.
    18Ôćĺ//! Each attribute is a key-value; a pair of [`Key`] and [`Value`]. Keys are strings
    19Ôćĺ//! and values are a datum of any type that can be formatted or serialized. Simple types
    20Ôćĺ//! like strings, booleans, and numbers are supported, as well as arbitrarily complex
    21Ôćĺ//! structures involving nested objects and sequences.
    22Ôćĺ//!
    23Ôćĺ//! ## Adding key-values to log records
    24Ôćĺ//!
    25Ôćĺ//! Key-values appear before the message format in the `log!` macros:
    26Ôćĺ//!
    27Ôćĺ//! ```
    28Ôćĺ//! # use log::info;
    29Ôćĺ//! info!(a = 1; "Something of interest");
    30Ôćĺ//! ```
    31Ôćĺ//!
    32Ôćĺ//! Key-values support the same shorthand identifier syntax as `format_args`:
    33Ôćĺ//!
    34Ôćĺ//! ```
    35Ôćĺ//! # use log::info;
    36Ôćĺ//! let a = 1;
    37Ôćĺ//!
    38Ôćĺ//! info!(a; "Something of interest");
    39Ôćĺ//! ```
    40Ôćĺ//!
    41Ôćĺ//! Values are capturing using the [`ToValue`] trait by default. To capture a value
    42Ôćĺ//! using a different trait implementation, use a modifier after its key. Here's how
    43Ôćĺ//! the same example can capture `a` using its `Debug` implementation instead:
    44Ôćĺ//!
    45Ôćĺ//! ```
    46Ôćĺ//! # use log::info;
    47Ôćĺ//! info!(a:? = 1; "Something of interest");
    48Ôćĺ//! ```
    49Ôćĺ//!
    50Ôćĺ//! The following capturing modifiers are supported:
    51Ôćĺ//!
    52Ôćĺ//! - `:?` will capture the value using `Debug`.
    53Ôćĺ//! - `:debug` will capture the value using `Debug`.
    54Ôćĺ//! - `:%` will capture the value using `Display`.
    55Ôćĺ//! - `:display` will capture the value using `Display`.
    56Ôćĺ//! - `:err` will capture the value using `std::error::Error` (requires the `kv_std` feature).
    57Ôćĺ//! - `:sval` will capture the value using `sval::Value` (requires the `kv_sval` feature).
    58Ôćĺ//! - `:serde` will capture the value using `serde::Serialize` (requires the `kv_serde` feature).
    59Ôćĺ//!
    60Ôćĺ//! ## Working with key-values on log records
    61Ôćĺ//!
    62Ôćĺ//! Use the [`Record::key_values`](../struct.Record.html#method.key_values) method to access key-values.
    63Ôćĺ//!
    64Ôćĺ//! Individual values can be pulled from the source by their key:
    65Ôćĺ//!
    66Ôćĺ//! ```
    67Ôćĺ//! # fn main() -> Result<(), log::kv::Error> {
    68Ôćĺ//! use log::kv::{Source, Key, Value};
    69Ôćĺ//! # let record = log::Record::builder().key_values(&[("a", 1)]).build();
    70Ôćĺ//!
    71Ôćĺ//! // info!(a = 1; "Something of interest");
    72Ôćĺ//!
    73Ôćĺ//! let a: Value = record.key_values().get(Key::from("a")).unwrap();
    74Ôćĺ//! assert_eq!(1, a.to_i64().unwrap());
    75Ôćĺ//! # Ok(())
    76Ôćĺ//! # }
    77Ôćĺ//! ```
    78Ôćĺ//!
    79Ôćĺ//! All key-values can also be enumerated using a [`VisitSource`]:
    80Ôćĺ//!
    81Ôćĺ//! ```
    82Ôćĺ//! # fn main() -> Result<(), log::kv::Error> {
    83Ôćĺ//! use std::collections::BTreeMap;
    84Ôćĺ//!
    85Ôćĺ//! use log::kv::{self, Source, Key, Value, VisitSource};
    86Ôćĺ//!
    87Ôćĺ//! struct Collect<'kvs>(BTreeMap<Key<'kvs>, Value<'kvs>>);
    88Ôćĺ//!
    89Ôćĺ//! impl<'kvs> VisitSource<'kvs> for Collect<'kvs> {
    90Ôćĺ//!     fn visit_pair(&mut self, key: Key<'kvs>, value: Value<'kvs>) -> Result<(), kv::Error> {
    91Ôćĺ//!         self.0.insert(key, value);
    92Ôćĺ//!
    93Ôćĺ//!         Ok(())
    94Ôćĺ//!     }
    95Ôćĺ//! }
    96Ôćĺ//!
    97Ôćĺ//! let mut visitor = Collect(BTreeMap::new());
    98Ôćĺ//!
    99Ôćĺ//! # let record = log::Record::builder().key_values(&[("a", 1), ("b", 2), ("c", 3)]).build();
   100Ôćĺ//! // info!(a = 1, b = 2, c = 3; "Something of interest");
   101Ôćĺ//!
   102Ôćĺ//! record.key_values().visit(&mut visitor)?;
   103Ôćĺ//!
   104Ôćĺ//! let collected = visitor.0;
   105Ôćĺ//!
   106Ôćĺ//! assert_eq!(
   107Ôćĺ//!     vec!["a", "b", "c"],
   108Ôćĺ//!     collected
   109Ôćĺ//!         .keys()
   110Ôćĺ//!         .map(|k| k.as_str())
   111Ôćĺ//!         .collect::<Vec<_>>(),
   112Ôćĺ//! );
   113Ôćĺ//! # Ok(())
   114Ôćĺ//! # }
   115Ôćĺ//! ```
   116Ôćĺ//!
   117Ôćĺ//! [`Value`]s have methods for conversions to common types:
   118Ôćĺ//!
   119Ôćĺ//! ```
   120Ôćĺ//! # fn main() -> Result<(), log::kv::Error> {
   121Ôćĺ//! use log::kv::{Source, Key};
   122Ôćĺ//! # let record = log::Record::builder().key_values(&[("a", 1)]).build();
   123Ôćĺ//!
   124Ôćĺ//! // info!(a = 1; "Something of interest");
   125Ôćĺ//!
   126Ôćĺ//! let a = record.key_values().get(Key::from("a")).unwrap();
   127Ôćĺ//!
   128Ôćĺ//! assert_eq!(1, a.to_i64().unwrap());
   129Ôćĺ//! # Ok(())
   130Ôćĺ//! # }
   131Ôćĺ//! ```
   132Ôćĺ//!
   133Ôćĺ//! Values also have their own [`VisitValue`] type. Value visitors are a lightweight
   134Ôćĺ//! API for working with primitives types:
   135Ôćĺ//!
   136Ôćĺ//! ```
   137Ôćĺ//! # fn main() -> Result<(), log::kv::Error> {
   138Ôćĺ//! use log::kv::{self, Source, Key, VisitValue};
   139Ôćĺ//! # let record = log::Record::builder().key_values(&[("a", 1)]).build();
   140Ôćĺ//!
   141Ôćĺ//! struct IsNumeric(bool);
   142Ôćĺ//!
   143Ôćĺ//! impl<'kvs> VisitValue<'kvs> for IsNumeric {
   144Ôćĺ//!     fn visit_any(&mut self, _value: kv::Value) -> Result<(), kv::Error> {
   145Ôćĺ//!         self.0 = false;
   146Ôćĺ//!         Ok(())
   147Ôćĺ//!     }
   148Ôćĺ//!
   149Ôćĺ//!     fn visit_u64(&mut self, _value: u64) -> Result<(), kv::Error> {
   150Ôćĺ//!         self.0 = true;
   151Ôćĺ//!         Ok(())
   152Ôćĺ//!     }
   153Ôćĺ//!
   154Ôćĺ//!     fn visit_i64(&mut self, _value: i64) -> Result<(), kv::Error> {
   155Ôćĺ//!         self.0 = true;
   156Ôćĺ//!         Ok(())
   157Ôćĺ//!     }
   158Ôćĺ//!
   159Ôćĺ//!     fn visit_u128(&mut self, _value: u128) -> Result<(), kv::Error> {
   160Ôćĺ//!         self.0 = true;
   161Ôćĺ//!         Ok(())
   162Ôćĺ//!     }
   163Ôćĺ//!
   164Ôćĺ//!     fn visit_i128(&mut self, _value: i128) -> Result<(), kv::Error> {
   165Ôćĺ//!         self.0 = true;
   166Ôćĺ//!         Ok(())
   167Ôćĺ//!     }
   168Ôćĺ//!
   169Ôćĺ//!     fn visit_f64(&mut self, _value: f64) -> Result<(), kv::Error> {
   170Ôćĺ//!         self.0 = true;
   171Ôćĺ//!         Ok(())
   172Ôćĺ//!     }
   173Ôćĺ//! }
   174Ôćĺ//!
   175Ôćĺ//! // info!(a = 1; "Something of interest");
   176Ôćĺ//!
   177Ôćĺ//! let a = record.key_values().get(Key::from("a")).unwrap();
   178Ôćĺ//!
   179Ôćĺ//! let mut visitor = IsNumeric(false);
   180Ôćĺ//!
   181Ôćĺ//! a.visit(&mut visitor)?;
   182Ôćĺ//!
   183Ôćĺ//! let is_numeric = visitor.0;
   184Ôćĺ//!
   185Ôćĺ//! assert!(is_numeric);
   186Ôćĺ//! # Ok(())
   187Ôćĺ//! # }
   188Ôćĺ//! ```
   189Ôćĺ//!
   190Ôćĺ//! To serialize a value to a format like JSON, you can also use either `serde` or `sval`:
   191Ôćĺ//!
   192Ôćĺ//! ```
   193Ôćĺ//! # fn main() -> Result<(), Box<dyn std::error::Error>> {
   194Ôćĺ//! # #[cfg(feature = "kv_serde")]
   195Ôćĺ//! # {
   196Ôćĺ//! # use log::kv::Key;
   197Ôćĺ//! #[derive(serde::Serialize)]
   198Ôćĺ//! struct Data {
   199Ôćĺ//!     a: i32, b: bool,
   200Ôćĺ//!     c: &'static str,
   201Ôćĺ//! }
   202Ôćĺ//!
   203Ôćĺ//! let data = Data { a: 1, b: true, c: "Some data" };
   204Ôćĺ//!
   205Ôćĺ//! # let source = [("a", log::kv::Value::from_serde(&data))];
   206Ôćĺ//! # let record = log::Record::builder().key_values(&source).build();
   207Ôćĺ//! // info!(a = data; "Something of interest");
   208Ôćĺ//!
   209Ôćĺ//! let a = record.key_values().get(Key::from("a")).unwrap();
   210Ôćĺ//!
   211Ôćĺ//! assert_eq!("{\"a\":1,\"b\":true,\"c\":\"Some data\"}", serde_json::to_string(&a)?);
   212Ôćĺ//! # }
   213Ôćĺ//! # Ok(())
   214Ôćĺ//! # }
   215Ôćĺ//! ```
   216Ôćĺ//!
   217Ôćĺ//! The choice of serialization framework depends on the needs of the consumer.
   218Ôćĺ//! If you're in a no-std environment, you can use `sval`. In other cases, you can use `serde`.
   219Ôćĺ//! Log producers and log consumers don't need to agree on the serialization framework.
   220Ôćĺ//! A value can be captured using its `serde::Serialize` implementation and still be serialized
   221Ôćĺ//! through `sval` without losing any structure or data.
   222Ôćĺ//!
   223Ôćĺ//! Values can also always be formatted using the standard `Debug` and `Display`
   224Ôćĺ//! traits:
   225Ôćĺ//!
   226Ôćĺ//! ```
   227Ôćĺ//! # use log::kv::Key;
   228Ôćĺ//! #[derive(Debug)]
   229Ôćĺ//! struct Data {
   230Ôćĺ//!     a: i32,
   231Ôćĺ//!     b: bool,
   232Ôćĺ//!     c: &'static str,
   233Ôćĺ//! }
   234Ôćĺ//!
   235Ôćĺ//! let data = Data { a: 1, b: true, c: "Some data" };
   236Ôćĺ//!
   237Ôćĺ//! # let source = [("a", log::kv::Value::from_debug(&data))];
   238Ôćĺ//! # let record = log::Record::builder().key_values(&source).build();
   239Ôćĺ//! // info!(a = data; "Something of interest");
   240Ôćĺ//!
   241Ôćĺ//! let a = record.key_values().get(Key::from("a")).unwrap();
   242Ôćĺ//!
   243Ôćĺ//! assert_eq!("Data { a: 1, b: true, c: \"Some data\" }", format!("{a:?}"));
   244Ôćĺ//! ```
   245Ôćĺ
   246Ôćĺmod error;

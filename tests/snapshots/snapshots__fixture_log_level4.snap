    11Ôćĺ/// The standard logging macro.
    12Ôćĺ///
    13Ôćĺ/// This macro will generically log with the specified `Level` and `format!`
    14Ôćĺ/// based argument list.
    15Ôćĺ///
    16Ôćĺ/// ```
    17Ôćĺ/// use log::{log, Level};
    18Ôćĺ///
    19Ôćĺ/// let data = (42, "Forty-two");
    20Ôćĺ/// let private_data = "private";
    21Ôćĺ///
    22Ôćĺ/// log!(Level::Error, "Received errors: {}, {}", data.0, data.1);
    23Ôćĺ/// ```
    24Ôćĺ///
    25Ôćĺ/// Optionally, you can specify a `target` argument to attach a specific target
    26Ôćĺ/// to the log record. By default, the target is the module path of the caller.
    27Ôćĺ///
    28Ôćĺ/// ```
    29Ôćĺ/// use log::{log, Level};
    30Ôćĺ///
    31Ôćĺ/// let data = (42, "Forty-two");
    32Ôćĺ/// let private_data = "private";
    33Ôćĺ///
    34Ôćĺ/// log!(
    35Ôćĺ///     target: "app_events",
    36Ôćĺ///     Level::Error,
    37Ôćĺ///     "Received errors: {}, {}",
    38Ôćĺ///     data.0, data.1
    39Ôćĺ/// );
    40Ôćĺ/// ```
    41Ôćĺ///
    42Ôćĺ/// And optionally, you can specify a `logger` argument to use a specific logger
    43Ôćĺ/// instead of the default global logger.
    44Ôćĺ///
    45Ôćĺ/// ```
    46Ôćĺ/// # struct MyLogger {}
    47Ôćĺ/// # impl Log for MyLogger {
    48Ôćĺ/// #     fn enabled(&self, _metadata: &log::Metadata) -> bool {
    49Ôćĺ/// #         false
    50Ôćĺ/// #     }
    51Ôćĺ/// #     fn log(&self, _record: &log::Record) {}
    52Ôćĺ/// #     fn flush(&self) {}
    53Ôćĺ/// # }
    54Ôćĺ/// use log::{log, Level, Log};
    55Ôćĺ///
    56Ôćĺ/// let data = (42, "Forty-two");
    57Ôćĺ/// let private_data = "private";
    58Ôćĺ///
    59Ôćĺ/// let my_logger = MyLogger {};
    60Ôćĺ/// log!(
    61Ôćĺ///     logger: my_logger,
    62Ôćĺ///     Level::Error,
    63Ôćĺ///     "Received errors: {}, {}",
    64Ôćĺ///     data.0, data.1
    65Ôćĺ/// );
    66Ôćĺ/// ```
    67Ôćĺ///
    68Ôćĺ/// The `logger` argument accepts a value that implements the `Log` trait. The value

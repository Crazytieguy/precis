    26ŌåÆ/// to the log record. By default, the target is the module path of the caller.
    27ŌåÆ///
    28ŌåÆ/// ```
    29ŌåÆ/// use log::{log, Level};
    30ŌåÆ///
    31ŌåÆ/// let data = (42, "Forty-two");
    32ŌåÆ/// let private_data = "private";
    33ŌåÆ///
    34ŌåÆ/// log!(
    35ŌåÆ///     target: "app_events",
    36ŌåÆ///     Level::Error,
    37ŌåÆ///     "Received errors: {}, {}",
    38ŌåÆ///     data.0, data.1
    39ŌåÆ/// );
    40ŌåÆ/// ```
    41ŌåÆ///
    42ŌåÆ/// And optionally, you can specify a `logger` argument to use a specific logger
    43ŌåÆ/// instead of the default global logger.
    44ŌåÆ///
    45ŌåÆ/// ```
    46ŌåÆ/// # struct MyLogger {}

   382→class HookCaller:
   383→    """A caller of all registered implementations of a hook specification."""
   384→
   385→    __slots__ = (
   386→        "name",
   387→        "spec",
   388→        "_hookexec",
   389→        "_hookimpls",
   390→        "_call_history",
   391→    )
   392→
   393→    def __init__(
   394→        self,
   395→        name: str,
   396→        hook_execute: _HookExec,
   397→        specmodule_or_class: _Namespace | None = None,
   398→        spec_opts: HookspecOpts | None = None,
   399→    ) -> None:
   400→        """:meta private:"""
   401→        #: Name of the hook getting called.
   402→        self.name: Final = name
   403→        self._hookexec: Final = hook_execute
   404→        # The hookimpls list. The caller iterates it *in reverse*. Format:
   405→        # 1. trylast nonwrappers
   406→        # 2. nonwrappers
   407→        # 3. tryfirst nonwrappers
   408→        # 4. trylast wrappers
   409→        # 5. wrappers
   410→        # 6. tryfirst wrappers
   411→        self._hookimpls: Final[list[HookImpl]] = []
   412→        self._call_history: _CallHistory | None = None
   413→        # TODO: Document, or make private.
   414→        self.spec: HookSpec | None = None
   415→        if specmodule_or_class is not None:
   416→            assert spec_opts is not None
   417→            self.set_specification(specmodule_or_class, spec_opts)
   418→
   419→    # TODO: Document, or make private.
   420→    def has_spec(self) -> bool:
   421→        return self.spec is not None
   422→
   423→    # TODO: Document, or make private.
   424→    def set_specification(
   425→        self,
   426→        specmodule_or_class: _Namespace,
   427→        spec_opts: HookspecOpts,
   428→    ) -> None:
   429→        if self.spec is not None:
   430→            raise ValueError(
   431→                f"Hook {self.spec.name!r} is already registered "
   432→                f"within namespace {self.spec.namespace}"
   433→            )
   434→        self.spec = HookSpec(specmodule_or_class, self.name, spec_opts)
   435→        if spec_opts.get("historic"):
   436→            self._call_history = []
   437→
   438→    def is_historic(self) -> bool:
   439→        """Whether this caller is :ref:`historic <historic>`."""
   440→        return self._call_history is not None
   441→
   442→    def _remove_plugin(self, plugin: _Plugin) -> None:
   443→        for i, method in enumerate(self._hookimpls):
   444→            if method.plugin == plugin:
   445→                del self._hookimpls[i]
   446→                return
   447→        raise ValueError(f"plugin {plugin!r} not found")
   448→
   449→    def get_hookimpls(self) -> list[HookImpl]:
   450→        """Get all registered hook implementations for this hook."""
   451→        return self._hookimpls.copy()
   452→
   453→    def _add_hookimpl(self, hookimpl: HookImpl) -> None:
   454→        """Add an implementation to the callback chain."""
   455→        for i, method in enumerate(self._hookimpls):
   456→            if method.hookwrapper or method.wrapper:
   457→                splitpoint = i
   458→                break
   459→        else:
   460→            splitpoint = len(self._hookimpls)
   461→        if hookimpl.hookwrapper or hookimpl.wrapper:
   462→            start, end = splitpoint, len(self._hookimpls)
   463→        else:
   464→            start, end = 0, splitpoint
   465→
   466→        if hookimpl.trylast:
   467→            self._hookimpls.insert(start, hookimpl)
   468→        elif hookimpl.tryfirst:
   469→            self._hookimpls.insert(end, hookimpl)
   470→        else:
   471→            # find last non-tryfirst method
   472→            i = end - 1
   473→            while i >= start and self._hookimpls[i].tryfirst:
   474→                i -= 1
   475→            self._hookimpls.insert(i + 1, hookimpl)
   476→
   477→    def __repr__(self) -> str:
   478→        return f"<HookCaller {self.name!r}>"
   479→
   480→    def _verify_all_args_are_provided(self, kwargs: Mapping[str, object]) -> None:
   481→        # This is written to avoid expensive operations when not needed.
   482→        if self.spec:
   483→            for argname in self.spec.argnames:
   484→                if argname not in kwargs:
   485→                    notincall = ", ".join(
   486→                        repr(argname)
   487→                        for argname in self.spec.argnames
   488→                        # Avoid self.spec.argnames - kwargs.keys()
   489→                        # it doesn't preserve order.
   490→                        if argname not in kwargs.keys()
   491→                    )
   492→                    warnings.warn(
   493→                        f"Argument(s) {notincall} which are declared in the hookspec "
   494→                        "cannot be found in this hook call",
   495→                        stacklevel=2,
   496→                    )
   497→                    break
   498→
   499→    def __call__(self, **kwargs: object) -> Any:
   500→        """Call the hook.
   501→
   502→        Only accepts keyword arguments, which should match the hook
   503→        specification.
   504→
   505→        Returns the result(s) of calling all registered plugins, see
   506→        :ref:`calling`.
   507→        """
   508→        assert not self.is_historic(), (
   509→            "Cannot directly call a historic hook - use call_historic instead."
   510→        )
   511→        self._verify_all_args_are_provided(kwargs)
   512→        firstresult = self.spec.opts.get("firstresult", False) if self.spec else False
   513→        # Copy because plugins may register other plugins during iteration (#438).
   514→        return self._hookexec(self.name, self._hookimpls.copy(), kwargs, firstresult)
   515→
   516→    def call_historic(
   517→        self,
   518→        result_callback: Callable[[Any], None] | None = None,
   519→        kwargs: Mapping[str, object] | None = None,
   520→    ) -> None:
   521→        """Call the hook with given ``kwargs`` for all registered plugins and
   522→        for all plugins which will be registered afterwards, see
   523→        :ref:`historic`.
   524→
   525→        :param result_callback:
   526→            If provided, will be called for each non-``None`` result obtained
   527→            from a hook implementation.
   528→        """
   529→        assert self._call_history is not None
   530→        kwargs = kwargs or {}
   531→        self._verify_all_args_are_provided(kwargs)
   532→        self._call_history.append((kwargs, result_callback))
   533→        # Historizing hooks don't return results.
   534→        # Remember firstresult isn't compatible with historic.
   535→        # Copy because plugins may register other plugins during iteration (#438).
   536→        res = self._hookexec(self.name, self._hookimpls.copy(), kwargs, False)
   537→        if result_callback is None:
   538→            return
   539→        if isinstance(res, list):
   540→            for x in res:
   541→                result_callback(x)
   542→
   543→    def call_extra(
   544→        self, methods: Sequence[Callable[..., object]], kwargs: Mapping[str, object]
   545→    ) -> Any:
   546→        """Call the hook with some additional temporarily participating
   547→        methods using the specified ``kwargs`` as call parameters, see
   548→        :ref:`call_extra`."""
   549→        assert not self.is_historic(), (
   550→            "Cannot directly call a historic hook - use call_historic instead."
   551→        )
   552→        self._verify_all_args_are_provided(kwargs)
   553→        opts: HookimplOpts = {
   554→            "wrapper": False,
   555→            "hookwrapper": False,
   556→            "optionalhook": False,
   557→            "trylast": False,
   558→            "tryfirst": False,
   559→            "specname": None,
   560→        }
   561→        hookimpls = self._hookimpls.copy()
   562→        for method in methods:
   563→            hookimpl = HookImpl(None, "<temp>", method, opts)
   564→            # Find last non-tryfirst nonwrapper method.
   565→            i = len(hookimpls) - 1
   566→            while i >= 0 and (
   567→                # Skip wrappers.
   568→                (hookimpls[i].hookwrapper or hookimpls[i].wrapper)
   569→                # Skip tryfirst nonwrappers.
   570→                or hookimpls[i].tryfirst
   571→            ):
   572→                i -= 1
   573→            hookimpls.insert(i + 1, hookimpl)
   574→        firstresult = self.spec.opts.get("firstresult", False) if self.spec else False
   575→        return self._hookexec(self.name, hookimpls, kwargs, firstresult)
   576→
   577→    def _maybe_apply_history(self, method: HookImpl) -> None:
   578→        """Apply call history to a new hookimpl if it is marked as historic."""
   579→        if self.is_historic():
   580→            assert self._call_history is not None
   581→            for kwargs, result_callback in self._call_history:
   582→                res = self._hookexec(self.name, [method], kwargs, False)
   583→                if res and result_callback is not None:
   584→                    # XXX: remember firstresult isn't compat with historic
   585→                    assert isinstance(res, list)
   586→                    result_callback(res[0])
   593→class _SubsetHookCaller(HookCaller):
   594→    """A proxy to another HookCaller which manages calls to all registered
   595→    plugins except the ones from remove_plugins."""
   596→
   597→    # This class is unusual: in inhertits from `HookCaller` so all of
   598→    # the *code* runs in the class, but it delegates all underlying *data*
   599→    # to the original HookCaller.
   600→    # `subset_hook_caller` used to be implemented by creating a full-fledged
   601→    # HookCaller, copying all hookimpls from the original. This had problems
   602→    # with memory leaks (#346) and historic calls (#347), which make a proxy
   603→    # approach better.
   604→    # An alternative implementation is to use a `_getattr__`/`__getattribute__`
   605→    # proxy, however that adds more overhead and is more tricky to implement.
   606→
   607→    __slots__ = (
   608→        "_orig",
   609→        "_remove_plugins",
   610→    )
   611→
   612→    def __init__(self, orig: HookCaller, remove_plugins: Set[_Plugin]) -> None:
   613→        self._orig = orig
   614→        self._remove_plugins = remove_plugins
   615→        self.name = orig.name  # type: ignore[misc]
   616→        self._hookexec = orig._hookexec  # type: ignore[misc]
   617→
   618→    @property  # type: ignore[misc]
   619→    def _hookimpls(self) -> list[HookImpl]:
   620→        return [
   621→            impl
   622→            for impl in self._orig._hookimpls
   623→            if impl.plugin not in self._remove_plugins
   624→        ]
   625→
   626→    @property
   627→    def spec(self) -> HookSpec | None:  # type: ignore[override]
   628→        return self._orig.spec
   629→
   630→    @property
   631→    def _call_history(self) -> _CallHistory | None:  # type: ignore[override]
   632→        return self._orig._call_history
   633→
   634→    def __repr__(self) -> str:
   635→        return f"<_SubsetHookCaller {self.name!r}>"
   638→@final
   639→class HookImpl:
   640→    """A hook implementation in a :class:`HookCaller`."""
   641→
   642→    __slots__ = (
   643→        "function",
   644→        "argnames",
   645→        "kwargnames",
   646→        "plugin",
   647→        "opts",
   648→        "plugin_name",
   649→        "wrapper",
   650→        "hookwrapper",
   651→        "optionalhook",
   652→        "tryfirst",
   653→        "trylast",
   654→    )
   655→
   656→    def __init__(
   657→        self,
   658→        plugin: _Plugin,
   659→        plugin_name: str,
   660→        function: _HookImplFunction[object],
   661→        hook_impl_opts: HookimplOpts,
   662→    ) -> None:
   663→        """:meta private:"""
   664→        #: The hook implementation function.
   665→        self.function: Final = function
   666→        argnames, kwargnames = varnames(self.function)
   667→        #: The positional parameter names of ``function```.
   668→        self.argnames: Final = argnames
   669→        #: The keyword parameter names of ``function```.
   670→        self.kwargnames: Final = kwargnames
   671→        #: The plugin which defined this hook implementation.
   672→        self.plugin: Final = plugin
   673→        #: The :class:`HookimplOpts` used to configure this hook implementation.
   674→        self.opts: Final = hook_impl_opts
   675→        #: The name of the plugin which defined this hook implementation.
   676→        self.plugin_name: Final = plugin_name
   677→        #: Whether the hook implementation is a :ref:`wrapper <hookwrapper>`.
   678→        self.wrapper: Final = hook_impl_opts["wrapper"]
   679→        #: Whether the hook implementation is an :ref:`old-style wrapper
   680→        #: <old_style_hookwrappers>`.
   681→        self.hookwrapper: Final = hook_impl_opts["hookwrapper"]
   682→        #: Whether validation against a hook specification is :ref:`optional
   683→        #: <optionalhook>`.
   684→        self.optionalhook: Final = hook_impl_opts["optionalhook"]
   685→        #: Whether to try to order this hook implementation :ref:`first
   686→        #: <callorder>`.
   687→        self.tryfirst: Final = hook_impl_opts["tryfirst"]
   688→        #: Whether to try to order this hook implementation :ref:`last
   689→        #: <callorder>`.
   690→        self.trylast: Final = hook_impl_opts["trylast"]
   691→
   692→    def __repr__(self) -> str:
   693→        return f"<HookImpl plugin_name={self.plugin_name!r}, plugin={self.plugin!r}>"
   696→@final
   697→class HookSpec:
   698→    __slots__ = (
   699→        "namespace",
   700→        "function",
   701→        "name",
   702→        "argnames",
   703→        "kwargnames",
   704→        "opts",
   705→        "warn_on_impl",
   706→        "warn_on_impl_args",
   707→    )
   708→
   709→    def __init__(self, namespace: _Namespace, name: str, opts: HookspecOpts) -> None:
   710→        self.namespace = namespace
   711→        self.function: Callable[..., object] = getattr(namespace, name)
   712→        self.name = name
   713→        self.argnames, self.kwargnames = varnames(self.function)
   714→        self.opts = opts
   715→        self.warn_on_impl = opts.get("warn_on_impl")
   716→        self.warn_on_impl_args = opts.get("warn_on_impl_args")

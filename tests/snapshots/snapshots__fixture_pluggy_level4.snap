   382‚Üíclass HookCaller:
   383‚Üí    """A caller of all registered implementations of a hook specification."""
   384‚Üí
   385‚Üí    __slots__ = (
   386‚Üí        "name",
   387‚Üí        "spec",
   388‚Üí        "_hookexec",
   389‚Üí        "_hookimpls",
   390‚Üí        "_call_history",
   391‚Üí    )
   392‚Üí
   393‚Üí    def __init__(
   394‚Üí        self,
   395‚Üí        name: str,
   396‚Üí        hook_execute: _HookExec,
   397‚Üí        specmodule_or_class: _Namespace | None = None,
   398‚Üí        spec_opts: HookspecOpts | None = None,
   399‚Üí    ) -> None:
   400‚Üí        """:meta private:"""
   401‚Üí        #: Name of the hook getting called.
   402‚Üí        self.name: Final = name
   403‚Üí        self._hookexec: Final = hook_execute
   404‚Üí        # The hookimpls list. The caller iterates it *in reverse*. Format:
   405‚Üí        # 1. trylast nonwrappers
   406‚Üí        # 2. nonwrappers
   407‚Üí        # 3. tryfirst nonwrappers
   408‚Üí        # 4. trylast wrappers
   409‚Üí        # 5. wrappers
   410‚Üí        # 6. tryfirst wrappers
   411‚Üí        self._hookimpls: Final[list[HookImpl]] = []
   412‚Üí        self._call_history: _CallHistory | None = None
   413‚Üí        # TODO: Document, or make private.
   414‚Üí        self.spec: HookSpec | None = None
   415‚Üí        if specmodule_or_class is not None:
   416‚Üí            assert spec_opts is not None
   417‚Üí            self.set_specification(specmodule_or_class, spec_opts)
   418‚Üí
   419‚Üí    # TODO: Document, or make private.
   420‚Üí    def has_spec(self) -> bool:
   421‚Üí        return self.spec is not None
   422‚Üí
   423‚Üí    # TODO: Document, or make private.
   424‚Üí    def set_specification(
   425‚Üí        self,
   426‚Üí        specmodule_or_class: _Namespace,
   427‚Üí        spec_opts: HookspecOpts,
   428‚Üí    ) -> None:
   429‚Üí        if self.spec is not None:
   430‚Üí            raise ValueError(
   431‚Üí                f"Hook {self.spec.name!r} is already registered "
   432‚Üí                f"within namespace {self.spec.namespace}"
   433‚Üí            )
   434‚Üí        self.spec = HookSpec(specmodule_or_class, self.name, spec_opts)
   435‚Üí        if spec_opts.get("historic"):
   436‚Üí            self._call_history = []
   437‚Üí
   438‚Üí    def is_historic(self) -> bool:
   439‚Üí        """Whether this caller is :ref:`historic <historic>`."""
   440‚Üí        return self._call_history is not None
   441‚Üí
   442‚Üí    def _remove_plugin(self, plugin: _Plugin) -> None:
   443‚Üí        for i, method in enumerate(self._hookimpls):
   444‚Üí            if method.plugin == plugin:
   445‚Üí                del self._hookimpls[i]
   446‚Üí                return
   447‚Üí        raise ValueError(f"plugin {plugin!r} not found")
   448‚Üí
   449‚Üí    def get_hookimpls(self) -> list[HookImpl]:
   450‚Üí        """Get all registered hook implementations for this hook."""
   451‚Üí        return self._hookimpls.copy()
   452‚Üí
   453‚Üí    def _add_hookimpl(self, hookimpl: HookImpl) -> None:
   454‚Üí        """Add an implementation to the callback chain."""
   455‚Üí        for i, method in enumerate(self._hookimpls):
   456‚Üí            if method.hookwrapper or method.wrapper:
   457‚Üí                splitpoint = i
   458‚Üí                break
   459‚Üí        else:
   460‚Üí            splitpoint = len(self._hookimpls)
   461‚Üí        if hookimpl.hookwrapper or hookimpl.wrapper:
   462‚Üí            start, end = splitpoint, len(self._hookimpls)
   463‚Üí        else:
   464‚Üí            start, end = 0, splitpoint
   465‚Üí
   466‚Üí        if hookimpl.trylast:
   467‚Üí            self._hookimpls.insert(start, hookimpl)
   468‚Üí        elif hookimpl.tryfirst:
   469‚Üí            self._hookimpls.insert(end, hookimpl)
   470‚Üí        else:
   471‚Üí            # find last non-tryfirst method
   472‚Üí            i = end - 1
   473‚Üí            while i >= start and self._hookimpls[i].tryfirst:
   474‚Üí                i -= 1
   475‚Üí            self._hookimpls.insert(i + 1, hookimpl)
   476‚Üí
   477‚Üí    def __repr__(self) -> str:
   478‚Üí        return f"<HookCaller {self.name!r}>"
   479‚Üí
   480‚Üí    def _verify_all_args_are_provided(self, kwargs: Mapping[str, object]) -> None:
   481‚Üí        # This is written to avoid expensive operations when not needed.
   482‚Üí        if self.spec:
   483‚Üí            for argname in self.spec.argnames:
   484‚Üí                if argname not in kwargs:
   485‚Üí                    notincall = ", ".join(
   486‚Üí                        repr(argname)
   487‚Üí                        for argname in self.spec.argnames
   488‚Üí                        # Avoid self.spec.argnames - kwargs.keys()
   489‚Üí                        # it doesn't preserve order.
   490‚Üí                        if argname not in kwargs.keys()
   491‚Üí                    )
   492‚Üí                    warnings.warn(
   493‚Üí                        f"Argument(s) {notincall} which are declared in the hookspec "
   494‚Üí                        "cannot be found in this hook call",
   495‚Üí                        stacklevel=2,
   496‚Üí                    )
   497‚Üí                    break
   498‚Üí
   499‚Üí    def __call__(self, **kwargs: object) -> Any:
   500‚Üí        """Call the hook.
   501‚Üí
   502‚Üí        Only accepts keyword arguments, which should match the hook
   503‚Üí        specification.
   504‚Üí
   505‚Üí        Returns the result(s) of calling all registered plugins, see
   506‚Üí        :ref:`calling`.
   507‚Üí        """
   508‚Üí        assert not self.is_historic(), (
   509‚Üí            "Cannot directly call a historic hook - use call_historic instead."
   510‚Üí        )
   511‚Üí        self._verify_all_args_are_provided(kwargs)
   512‚Üí        firstresult = self.spec.opts.get("firstresult", False) if self.spec else False
   513‚Üí        # Copy because plugins may register other plugins during iteration (#438).
   514‚Üí        return self._hookexec(self.name, self._hookimpls.copy(), kwargs, firstresult)
   515‚Üí
   516‚Üí    def call_historic(
   517‚Üí        self,
   518‚Üí        result_callback: Callable[[Any], None] | None = None,
   519‚Üí        kwargs: Mapping[str, object] | None = None,
   520‚Üí    ) -> None:
   521‚Üí        """Call the hook with given ``kwargs`` for all registered plugins and
   522‚Üí        for all plugins which will be registered afterwards, see
   523‚Üí        :ref:`historic`.
   524‚Üí
   525‚Üí        :param result_callback:
   526‚Üí            If provided, will be called for each non-``None`` result obtained
   527‚Üí            from a hook implementation.
   528‚Üí        """
   529‚Üí        assert self._call_history is not None
   530‚Üí        kwargs = kwargs or {}
   531‚Üí        self._verify_all_args_are_provided(kwargs)
   532‚Üí        self._call_history.append((kwargs, result_callback))
   533‚Üí        # Historizing hooks don't return results.
   534‚Üí        # Remember firstresult isn't compatible with historic.
   535‚Üí        # Copy because plugins may register other plugins during iteration (#438).
   536‚Üí        res = self._hookexec(self.name, self._hookimpls.copy(), kwargs, False)
   537‚Üí        if result_callback is None:
   538‚Üí            return
   539‚Üí        if isinstance(res, list):
   540‚Üí            for x in res:
   541‚Üí                result_callback(x)
   542‚Üí
   543‚Üí    def call_extra(
   544‚Üí        self, methods: Sequence[Callable[..., object]], kwargs: Mapping[str, object]
   545‚Üí    ) -> Any:
   546‚Üí        """Call the hook with some additional temporarily participating
   547‚Üí        methods using the specified ``kwargs`` as call parameters, see
   548‚Üí        :ref:`call_extra`."""
   549‚Üí        assert not self.is_historic(), (
   550‚Üí            "Cannot directly call a historic hook - use call_historic instead."
   551‚Üí        )
   552‚Üí        self._verify_all_args_are_provided(kwargs)
   553‚Üí        opts: HookimplOpts = {
   554‚Üí            "wrapper": False,
   555‚Üí            "hookwrapper": False,
   556‚Üí            "optionalhook": False,
   557‚Üí            "trylast": False,
   558‚Üí            "tryfirst": False,
   559‚Üí            "specname": None,
   560‚Üí        }
   561‚Üí        hookimpls = self._hookimpls.copy()
   562‚Üí        for method in methods:
   563‚Üí            hookimpl = HookImpl(None, "<temp>", method, opts)
   564‚Üí            # Find last non-tryfirst nonwrapper method.
   565‚Üí            i = len(hookimpls) - 1
   566‚Üí            while i >= 0 and (
   567‚Üí                # Skip wrappers.
   568‚Üí                (hookimpls[i].hookwrapper or hookimpls[i].wrapper)
   569‚Üí                # Skip tryfirst nonwrappers.
   570‚Üí                or hookimpls[i].tryfirst
   571‚Üí            ):
   572‚Üí                i -= 1
   573‚Üí            hookimpls.insert(i + 1, hookimpl)
   574‚Üí        firstresult = self.spec.opts.get("firstresult", False) if self.spec else False
   575‚Üí        return self._hookexec(self.name, hookimpls, kwargs, firstresult)
   576‚Üí
   577‚Üí    def _maybe_apply_history(self, method: HookImpl) -> None:
   578‚Üí        """Apply call history to a new hookimpl if it is marked as historic."""
   579‚Üí        if self.is_historic():
   580‚Üí            assert self._call_history is not None
   581‚Üí            for kwargs, result_callback in self._call_history:
   582‚Üí                res = self._hookexec(self.name, [method], kwargs, False)
   583‚Üí                if res and result_callback is not None:
   584‚Üí                    # XXX: remember firstresult isn't compat with historic
   585‚Üí                    assert isinstance(res, list)
   586‚Üí                    result_callback(res[0])
   593‚Üíclass _SubsetHookCaller(HookCaller):
   594‚Üí    """A proxy to another HookCaller which manages calls to all registered
   595‚Üí    plugins except the ones from remove_plugins."""
   596‚Üí
   597‚Üí    # This class is unusual: in inhertits from `HookCaller` so all of
   598‚Üí    # the *code* runs in the class, but it delegates all underlying *data*
   599‚Üí    # to the original HookCaller.
   600‚Üí    # `subset_hook_caller` used to be implemented by creating a full-fledged
   601‚Üí    # HookCaller, copying all hookimpls from the original. This had problems
   602‚Üí    # with memory leaks (#346) and historic calls (#347), which make a proxy
   603‚Üí    # approach better.
   604‚Üí    # An alternative implementation is to use a `_getattr__`/`__getattribute__`
   605‚Üí    # proxy, however that adds more overhead and is more tricky to implement.
   606‚Üí
   607‚Üí    __slots__ = (
   608‚Üí        "_orig",
   609‚Üí        "_remove_plugins",
   610‚Üí    )
   611‚Üí
   612‚Üí    def __init__(self, orig: HookCaller, remove_plugins: Set[_Plugin]) -> None:
   613‚Üí        self._orig = orig
   614‚Üí        self._remove_plugins = remove_plugins
   615‚Üí        self.name = orig.name  # type: ignore[misc]
   616‚Üí        self._hookexec = orig._hookexec  # type: ignore[misc]
   617‚Üí
   618‚Üí    @property  # type: ignore[misc]
   619‚Üí    def _hookimpls(self) -> list[HookImpl]:
   620‚Üí        return [
   621‚Üí            impl
   622‚Üí            for impl in self._orig._hookimpls
   623‚Üí            if impl.plugin not in self._remove_plugins
   624‚Üí        ]
   625‚Üí
   626‚Üí    @property
   627‚Üí    def spec(self) -> HookSpec | None:  # type: ignore[override]
   628‚Üí        return self._orig.spec
   629‚Üí
   630‚Üí    @property
   631‚Üí    def _call_history(self) -> _CallHistory | None:  # type: ignore[override]
   632‚Üí        return self._orig._call_history
   633‚Üí
   634‚Üí    def __repr__(self) -> str:
   635‚Üí        return f"<_SubsetHookCaller {self.name!r}>"
   638‚Üí@final
   639‚Üíclass HookImpl:
   640‚Üí    """A hook implementation in a :class:`HookCaller`."""
   641‚Üí
   642‚Üí    __slots__ = (
   643‚Üí        "function",
   644‚Üí        "argnames",
   645‚Üí        "kwargnames",
   646‚Üí        "plugin",
   647‚Üí        "opts",
   648‚Üí        "plugin_name",
   649‚Üí        "wrapper",
   650‚Üí        "hookwrapper",
   651‚Üí        "optionalhook",
   652‚Üí        "tryfirst",
   653‚Üí        "trylast",
   654‚Üí    )
   655‚Üí
   656‚Üí    def __init__(
   657‚Üí        self,
   658‚Üí        plugin: _Plugin,
   659‚Üí        plugin_name: str,
   660‚Üí        function: _HookImplFunction[object],
   661‚Üí        hook_impl_opts: HookimplOpts,
   662‚Üí    ) -> None:
   663‚Üí        """:meta private:"""
   664‚Üí        #: The hook implementation function.
   665‚Üí        self.function: Final = function
   666‚Üí        argnames, kwargnames = varnames(self.function)
   667‚Üí        #: The positional parameter names of ``function```.
   668‚Üí        self.argnames: Final = argnames
   669‚Üí        #: The keyword parameter names of ``function```.
   670‚Üí        self.kwargnames: Final = kwargnames
   671‚Üí        #: The plugin which defined this hook implementation.
   672‚Üí        self.plugin: Final = plugin
   673‚Üí        #: The :class:`HookimplOpts` used to configure this hook implementation.
   674‚Üí        self.opts: Final = hook_impl_opts
   675‚Üí        #: The name of the plugin which defined this hook implementation.
   676‚Üí        self.plugin_name: Final = plugin_name
   677‚Üí        #: Whether the hook implementation is a :ref:`wrapper <hookwrapper>`.
   678‚Üí        self.wrapper: Final = hook_impl_opts["wrapper"]
   679‚Üí        #: Whether the hook implementation is an :ref:`old-style wrapper
   680‚Üí        #: <old_style_hookwrappers>`.
   681‚Üí        self.hookwrapper: Final = hook_impl_opts["hookwrapper"]
   682‚Üí        #: Whether validation against a hook specification is :ref:`optional
   683‚Üí        #: <optionalhook>`.
   684‚Üí        self.optionalhook: Final = hook_impl_opts["optionalhook"]
   685‚Üí        #: Whether to try to order this hook implementation :ref:`first
   686‚Üí        #: <callorder>`.
   687‚Üí        self.tryfirst: Final = hook_impl_opts["tryfirst"]
   688‚Üí        #: Whether to try to order this hook implementation :ref:`last
   689‚Üí        #: <callorder>`.
   690‚Üí        self.trylast: Final = hook_impl_opts["trylast"]
   691‚Üí
   692‚Üí    def __repr__(self) -> str:
   693‚Üí        return f"<HookImpl plugin_name={self.plugin_name!r}, plugin={self.plugin!r}>"
   696‚Üí@final
   697‚Üíclass HookSpec:
   698‚Üí    __slots__ = (
   699‚Üí        "namespace",
   700‚Üí        "function",
   701‚Üí        "name",
   702‚Üí        "argnames",
   703‚Üí        "kwargnames",
   704‚Üí        "opts",
   705‚Üí        "warn_on_impl",
   706‚Üí        "warn_on_impl_args",
   707‚Üí    )
   708‚Üí
   709‚Üí    def __init__(self, namespace: _Namespace, name: str, opts: HookspecOpts) -> None:
   710‚Üí        self.namespace = namespace
   711‚Üí        self.function: Callable[..., object] = getattr(namespace, name)
   712‚Üí        self.name = name
   713‚Üí        self.argnames, self.kwargnames = varnames(self.function)
   714‚Üí        self.opts = opts
   715‚Üí        self.warn_on_impl = opts.get("warn_on_impl")
   716‚Üí        self.warn_on_impl_args = opts.get("warn_on_impl_args")

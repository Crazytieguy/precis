    52‚Üíclass PluginValidationError(Exception):
    53‚Üí    """Plugin failed validation.
    54‚Üí
    55‚Üí    :param plugin: The plugin which failed validation.
    56‚Üí    :param message: Error message.
    57‚Üí    """
    58‚Üí
    59‚Üí    def __init__(self, plugin: _Plugin, message: str) -> None:
    60‚Üí        super().__init__(message)
    61‚Üí        #: The plugin which failed validation.
    62‚Üí        self.plugin = plugin
    65‚Üíclass DistFacade:
    66‚Üí    """Emulate a pkg_resources Distribution"""
    67‚Üí
    68‚Üí    def __init__(self, dist: importlib.metadata.Distribution) -> None:
    69‚Üí        self._dist = dist
    70‚Üí
    71‚Üí    @property
    72‚Üí    def project_name(self) -> str:
    73‚Üí        name: str = self.metadata["name"]
    74‚Üí        return name
    75‚Üí
    76‚Üí    def __getattr__(self, attr: str, default: Any | None = None) -> Any:
    77‚Üí        return getattr(self._dist, attr, default)
    78‚Üí
    79‚Üí    def __dir__(self) -> list[str]:
    80‚Üí        return sorted(dir(self._dist) + ["_dist", "project_name"])
    83‚Üíclass PluginManager:
    84‚Üí    """Core class which manages registration of plugin objects and 1:N hook
    85‚Üí    calling.
    86‚Üí
    87‚Üí    You can register new hooks by calling :meth:`add_hookspecs(module_or_class)
    88‚Üí    <PluginManager.add_hookspecs>`.
    89‚Üí
    90‚Üí    You can register plugin objects (which contain hook implementations) by
    91‚Üí    calling :meth:`register(plugin) <PluginManager.register>`.
    92‚Üí
    93‚Üí    For debugging purposes you can call :meth:`PluginManager.enable_tracing`
    94‚Üí    which will subsequently send debug information to the trace helper.
    95‚Üí
    96‚Üí    :param project_name:
    97‚Üí        The short project name. Prefer snake case. Make sure it's unique!
    98‚Üí    """
    99‚Üí
   100‚Üí    def __init__(self, project_name: str) -> None:
   101‚Üí        #: The project name.
   102‚Üí        self.project_name: Final = project_name
   103‚Üí        self._name2plugin: Final[dict[str, _Plugin]] = {}
   104‚Üí        self._plugin_distinfo: Final[list[tuple[_Plugin, DistFacade]]] = []
   105‚Üí        #: The "hook relay", used to call a hook on all registered plugins.
   106‚Üí        #: See :ref:`calling`.
   107‚Üí        self.hook: Final = HookRelay()
   108‚Üí        #: The tracing entry point. See :ref:`tracing`.
   109‚Üí        self.trace: Final[_tracing.TagTracerSub] = _tracing.TagTracer().get(
   110‚Üí            "pluginmanage"
   111‚Üí        )
   112‚Üí        self._inner_hookexec = _multicall
   113‚Üí
   114‚Üí    def _hookexec(
   115‚Üí        self,
   116‚Üí        hook_name: str,
   117‚Üí        methods: Sequence[HookImpl],
   118‚Üí        kwargs: Mapping[str, object],
   119‚Üí        firstresult: bool,
   120‚Üí    ) -> object | list[object]:
   121‚Üí        # called from all hookcaller instances.
   122‚Üí        # enable_tracing will set its own wrapping function at self._inner_hookexec
   123‚Üí        return self._inner_hookexec(hook_name, methods, kwargs, firstresult)
   124‚Üí
   125‚Üí    def register(self, plugin: _Plugin, name: str | None = None) -> str | None:
   126‚Üí        """Register a plugin and return its name.
   127‚Üí
   128‚Üí        :param name:
   129‚Üí            The name under which to register the plugin. If not specified, a
   130‚Üí            name is generated using :func:`get_canonical_name`.
   131‚Üí
   132‚Üí        :returns:
   133‚Üí            The plugin name. If the name is blocked from registering, returns
   134‚Üí            ``None``.
   135‚Üí
   136‚Üí        If the plugin is already registered, raises a :exc:`ValueError`.
   137‚Üí        """
   138‚Üí        plugin_name = name or self.get_canonical_name(plugin)
   139‚Üí
   140‚Üí        if plugin_name in self._name2plugin:
   141‚Üí            if self._name2plugin.get(plugin_name, -1) is None:
   142‚Üí                return None  # blocked plugin, return None to indicate no registration
   143‚Üí            raise ValueError(
   144‚Üí                "Plugin name already registered: "
   145‚Üí                f"{plugin_name}={plugin}\n{self._name2plugin}"
   146‚Üí            )
   147‚Üí
   148‚Üí        if plugin in self._name2plugin.values():
   149‚Üí            raise ValueError(
   150‚Üí                "Plugin already registered under a different name: "
   151‚Üí                f"{plugin_name}={plugin}\n{self._name2plugin}"
   152‚Üí            )
   153‚Üí
   154‚Üí        # XXX if an error happens we should make sure no state has been
   155‚Üí        # changed at point of return
   156‚Üí        self._name2plugin[plugin_name] = plugin
   157‚Üí
   158‚Üí        # register matching hook implementations of the plugin
   159‚Üí        for name in dir(plugin):
   160‚Üí            hookimpl_opts = self.parse_hookimpl_opts(plugin, name)
   161‚Üí            if hookimpl_opts is not None:
   162‚Üí                normalize_hookimpl_opts(hookimpl_opts)
   163‚Üí                method: _HookImplFunction[object] = getattr(plugin, name)
   164‚Üí                hookimpl = HookImpl(plugin, plugin_name, method, hookimpl_opts)
   165‚Üí                name = hookimpl_opts.get("specname") or name
   166‚Üí                hook: HookCaller | None = getattr(self.hook, name, None)
   167‚Üí                if hook is None:
   168‚Üí                    hook = HookCaller(name, self._hookexec)
   169‚Üí                    setattr(self.hook, name, hook)
   170‚Üí                elif hook.has_spec():
   171‚Üí                    self._verify_hook(hook, hookimpl)
   172‚Üí                    hook._maybe_apply_history(hookimpl)
   173‚Üí                hook._add_hookimpl(hookimpl)
   174‚Üí        return plugin_name
   175‚Üí
   176‚Üí    def parse_hookimpl_opts(self, plugin: _Plugin, name: str) -> HookimplOpts | None:
   177‚Üí        """Try to obtain a hook implementation from an item with the given name
   178‚Üí        in the given plugin which is being searched for hook impls.
   179‚Üí
   180‚Üí        :returns:
   181‚Üí            The parsed hookimpl options, or None to skip the given item.
   182‚Üí
   183‚Üí        This method can be overridden by ``PluginManager`` subclasses to
   184‚Üí        customize how hook implementation are picked up. By default, returns the
   185‚Üí        options for items decorated with :class:`HookimplMarker`.
   186‚Üí        """
   187‚Üí        method: object = getattr(plugin, name)
   188‚Üí        if not inspect.isroutine(method):
   189‚Üí            return None
   190‚Üí        try:
   191‚Üí            res: HookimplOpts | None = getattr(
   192‚Üí                method, self.project_name + "_impl", None
   193‚Üí            )
   194‚Üí        except Exception:  # pragma: no cover
   195‚Üí            res = {}  # type: ignore[assignment] #pragma: no cover
   196‚Üí        if res is not None and not isinstance(res, dict):
   197‚Üí            # false positive
   198‚Üí            res = None  # type:ignore[unreachable] #pragma: no cover
   199‚Üí        return res
   200‚Üí
   201‚Üí    def unregister(
   202‚Üí        self, plugin: _Plugin | None = None, name: str | None = None
   203‚Üí    ) -> Any | None:
   204‚Üí        """Unregister a plugin and all of its hook implementations.
   205‚Üí
   206‚Üí        The plugin can be specified either by the plugin object or the plugin
   207‚Üí        name. If both are specified, they must agree.
   208‚Üí
   209‚Üí        Returns the unregistered plugin, or ``None`` if not found.
   210‚Üí        """
   211‚Üí        if name is None:
   212‚Üí            assert plugin is not None, "one of name or plugin needs to be specified"
   213‚Üí            name = self.get_name(plugin)
   214‚Üí            assert name is not None, "plugin is not registered"
   215‚Üí
   216‚Üí        if plugin is None:
   217‚Üí            plugin = self.get_plugin(name)
   218‚Üí            if plugin is None:
   219‚Üí                return None
   220‚Üí
   221‚Üí        hookcallers = self.get_hookcallers(plugin)
   222‚Üí        if hookcallers:
   223‚Üí            for hookcaller in hookcallers:
   224‚Üí                hookcaller._remove_plugin(plugin)
   225‚Üí
   226‚Üí        # if self._name2plugin[name] == None registration was blocked: ignore
   227‚Üí        if self._name2plugin.get(name):
   228‚Üí            assert name is not None
   229‚Üí            del self._name2plugin[name]
   230‚Üí
   231‚Üí        return plugin
   232‚Üí
   233‚Üí    def set_blocked(self, name: str) -> None:
   234‚Üí        """Block registrations of the given name, unregister if already registered."""
   235‚Üí        self.unregister(name=name)
   236‚Üí        self._name2plugin[name] = None
   237‚Üí
   238‚Üí    def is_blocked(self, name: str) -> bool:
   239‚Üí        """Return whether the given plugin name is blocked."""
   240‚Üí        return name in self._name2plugin and self._name2plugin[name] is None
   241‚Üí
   242‚Üí    def unblock(self, name: str) -> bool:
   243‚Üí        """Unblocks a name.
   244‚Üí
   245‚Üí        Returns whether the name was actually blocked.
   246‚Üí        """
   247‚Üí        if self._name2plugin.get(name, -1) is None:
   248‚Üí            del self._name2plugin[name]
   249‚Üí            return True
   250‚Üí        return False
   251‚Üí
   252‚Üí    def add_hookspecs(self, module_or_class: _Namespace) -> None:
   253‚Üí        """Add new hook specifications defined in the given ``module_or_class``.
   254‚Üí
   255‚Üí        Functions are recognized as hook specifications if they have been
   256‚Üí        decorated with a matching :class:`HookspecMarker`.
   257‚Üí        """
   258‚Üí        names = []
   259‚Üí        for name in dir(module_or_class):
   260‚Üí            spec_opts = self.parse_hookspec_opts(module_or_class, name)
   261‚Üí            if spec_opts is not None:
   262‚Üí                hc: HookCaller | None = getattr(self.hook, name, None)
   263‚Üí                if hc is None:
   264‚Üí                    hc = HookCaller(name, self._hookexec, module_or_class, spec_opts)
   265‚Üí                    setattr(self.hook, name, hc)
   266‚Üí                else:
   267‚Üí                    # Plugins registered this hook without knowing the spec.
   268‚Üí                    hc.set_specification(module_or_class, spec_opts)
   269‚Üí                    for hookfunction in hc.get_hookimpls():
   270‚Üí                        self._verify_hook(hc, hookfunction)
   271‚Üí                names.append(name)
   272‚Üí
   273‚Üí        if not names:
   274‚Üí            raise ValueError(
   275‚Üí                f"did not find any {self.project_name!r} hooks in {module_or_class!r}"
   276‚Üí            )
   277‚Üí
   278‚Üí    def parse_hookspec_opts(
   279‚Üí        self, module_or_class: _Namespace, name: str
   280‚Üí    ) -> HookspecOpts | None:
   281‚Üí        """Try to obtain a hook specification from an item with the given name
   282‚Üí        in the given module or class which is being searched for hook specs.
   283‚Üí
   284‚Üí        :returns:
   285‚Üí            The parsed hookspec options for defining a hook, or None to skip the
   286‚Üí            given item.
   287‚Üí
   288‚Üí        This method can be overridden by ``PluginManager`` subclasses to
   289‚Üí        customize how hook specifications are picked up. By default, returns the
   290‚Üí        options for items decorated with :class:`HookspecMarker`.
   291‚Üí        """
   292‚Üí        method = getattr(module_or_class, name)
   293‚Üí        opts: HookspecOpts | None = getattr(method, self.project_name + "_spec", None)
   294‚Üí        return opts
   295‚Üí
   296‚Üí    def get_plugins(self) -> set[Any]:
   297‚Üí        """Return a set of all registered plugin objects."""
   298‚Üí        return {x for x in self._name2plugin.values() if x is not None}
   299‚Üí
   300‚Üí    def is_registered(self, plugin: _Plugin) -> bool:
   301‚Üí        """Return whether the plugin is already registered."""
   302‚Üí        return any(plugin == val for val in self._name2plugin.values())
   303‚Üí
   304‚Üí    def get_canonical_name(self, plugin: _Plugin) -> str:
   305‚Üí        """Return a canonical name for a plugin object.
   306‚Üí
   307‚Üí        Note that a plugin may be registered under a different name
   308‚Üí        specified by the caller of :meth:`register(plugin, name) <register>`.
   309‚Üí        To obtain the name of a registered plugin use :meth:`get_name(plugin)
   310‚Üí        <get_name>` instead.
   311‚Üí        """
   312‚Üí        name: str | None = getattr(plugin, "__name__", None)
   313‚Üí        return name or str(id(plugin))
   314‚Üí
   315‚Üí    def get_plugin(self, name: str) -> Any | None:
   316‚Üí        """Return the plugin registered under the given name, if any."""
   317‚Üí        return self._name2plugin.get(name)
   318‚Üí
   319‚Üí    def has_plugin(self, name: str) -> bool:
   320‚Üí        """Return whether a plugin with the given name is registered."""
   321‚Üí        return self.get_plugin(name) is not None
   322‚Üí
   323‚Üí    def get_name(self, plugin: _Plugin) -> str | None:
   324‚Üí        """Return the name the plugin is registered under, or ``None`` if
   325‚Üí        is isn't."""
   326‚Üí        for name, val in self._name2plugin.items():
   327‚Üí            if plugin == val:
   328‚Üí                return name
   329‚Üí        return None
   330‚Üí
   331‚Üí    def _verify_hook(self, hook: HookCaller, hookimpl: HookImpl) -> None:
   332‚Üí        if hook.is_historic() and (hookimpl.hookwrapper or hookimpl.wrapper):
   333‚Üí            raise PluginValidationError(
   334‚Üí                hookimpl.plugin,
   335‚Üí                f"Plugin {hookimpl.plugin_name!r}\nhook {hook.name!r}\n"
   336‚Üí                "historic incompatible with yield/wrapper/hookwrapper",
   337‚Üí            )
   338‚Üí
   339‚Üí        assert hook.spec is not None
   340‚Üí        if hook.spec.warn_on_impl:
   341‚Üí            _warn_for_function(hook.spec.warn_on_impl, hookimpl.function)
   342‚Üí
   343‚Üí        # positional arg checking
   344‚Üí        notinspec = set(hookimpl.argnames) - set(hook.spec.argnames)
   345‚Üí        if notinspec:
   346‚Üí            raise PluginValidationError(
   347‚Üí                hookimpl.plugin,
   348‚Üí                f"Plugin {hookimpl.plugin_name!r} for hook {hook.name!r}\n"
   349‚Üí                f"hookimpl definition: {_formatdef(hookimpl.function)}\n"
   350‚Üí                f"Argument(s) {notinspec} are declared in the hookimpl but "
   351‚Üí                "can not be found in the hookspec",
   352‚Üí            )
   353‚Üí
   354‚Üí        if hook.spec.warn_on_impl_args:
   355‚Üí            for hookimpl_argname in hookimpl.argnames:
   356‚Üí                argname_warning = hook.spec.warn_on_impl_args.get(hookimpl_argname)
   357‚Üí                if argname_warning is not None:
   358‚Üí                    _warn_for_function(argname_warning, hookimpl.function)
   359‚Üí
   360‚Üí        if (
   361‚Üí            hookimpl.wrapper or hookimpl.hookwrapper
   362‚Üí        ) and not inspect.isgeneratorfunction(hookimpl.function):
   363‚Üí            raise PluginValidationError(
   364‚Üí                hookimpl.plugin,
   365‚Üí                f"Plugin {hookimpl.plugin_name!r} for hook {hook.name!r}\n"
   366‚Üí                f"hookimpl definition: {_formatdef(hookimpl.function)}\n"
   367‚Üí                "Declared as wrapper=True or hookwrapper=True "
   368‚Üí                "but function is not a generator function",
   369‚Üí            )
   370‚Üí
   371‚Üí        if hookimpl.wrapper and hookimpl.hookwrapper:
   372‚Üí            raise PluginValidationError(
   373‚Üí                hookimpl.plugin,
   374‚Üí                f"Plugin {hookimpl.plugin_name!r} for hook {hook.name!r}\n"
   375‚Üí                f"hookimpl definition: {_formatdef(hookimpl.function)}\n"
   376‚Üí                "The wrapper=True and hookwrapper=True options are mutually exclusive",
   377‚Üí            )
   378‚Üí
   379‚Üí    def check_pending(self) -> None:
   380‚Üí        """Verify that all hooks which have not been verified against a
   381‚Üí        hook specification are optional, otherwise raise
   382‚Üí        :exc:`PluginValidationError`."""
   383‚Üí        for name in self.hook.__dict__:
   384‚Üí            if name[0] == "_":
   385‚Üí                continue
   386‚Üí            hook: HookCaller = getattr(self.hook, name)
   387‚Üí            if not hook.has_spec():
   388‚Üí                for hookimpl in hook.get_hookimpls():
   389‚Üí                    if not hookimpl.optionalhook:
   390‚Üí                        raise PluginValidationError(
   391‚Üí                            hookimpl.plugin,
   392‚Üí                            f"unknown hook {name!r} in plugin {hookimpl.plugin!r}",
   393‚Üí                        )
   394‚Üí
   395‚Üí    def load_setuptools_entrypoints(self, group: str, name: str | None = None) -> int:
   396‚Üí        """Load modules from querying the specified setuptools ``group``.
   397‚Üí
   398‚Üí        :param group:
   399‚Üí            Entry point group to load plugins.
   400‚Üí        :param name:
   401‚Üí            If given, loads only plugins with the given ``name``.
   402‚Üí
   403‚Üí        :return:
   404‚Üí            The number of plugins loaded by this call.
   405‚Üí        """
   406‚Üí        import importlib.metadata
   407‚Üí
   408‚Üí        count = 0
   409‚Üí        for dist in list(importlib.metadata.distributions()):
   410‚Üí            for ep in dist.entry_points:
   411‚Üí                if (
   412‚Üí                    ep.group != group
   413‚Üí                    or (name is not None and ep.name != name)
   414‚Üí                    # already registered
   415‚Üí                    or self.get_plugin(ep.name)
   416‚Üí                    or self.is_blocked(ep.name)
   417‚Üí                ):
   418‚Üí                    continue
   419‚Üí                plugin = ep.load()
   420‚Üí                self.register(plugin, name=ep.name)
   421‚Üí                self._plugin_distinfo.append((plugin, DistFacade(dist)))
   422‚Üí                count += 1
   423‚Üí        return count
   424‚Üí
   425‚Üí    def list_plugin_distinfo(self) -> list[tuple[_Plugin, DistFacade]]:
   426‚Üí        """Return a list of (plugin, distinfo) pairs for all
   427‚Üí        setuptools-registered plugins."""
   428‚Üí        return list(self._plugin_distinfo)
   429‚Üí
   430‚Üí    def list_name_plugin(self) -> list[tuple[str, _Plugin]]:
   431‚Üí        """Return a list of (name, plugin) pairs for all registered plugins."""
   432‚Üí        return list(self._name2plugin.items())
   433‚Üí
   434‚Üí    def get_hookcallers(self, plugin: _Plugin) -> list[HookCaller] | None:
   435‚Üí        """Get all hook callers for the specified plugin.
   436‚Üí
   437‚Üí        :returns:
   438‚Üí            The hook callers, or ``None`` if ``plugin`` is not registered in
   439‚Üí            this plugin manager.
   440‚Üí        """
   441‚Üí        if self.get_name(plugin) is None:
   442‚Üí            return None
   443‚Üí        hookcallers = []
   444‚Üí        for hookcaller in self.hook.__dict__.values():
   445‚Üí            for hookimpl in hookcaller.get_hookimpls():
   446‚Üí                if hookimpl.plugin is plugin:
   447‚Üí                    hookcallers.append(hookcaller)
   448‚Üí        return hookcallers
   449‚Üí
   450‚Üí    def add_hookcall_monitoring(
   451‚Üí        self, before: _BeforeTrace, after: _AfterTrace
   452‚Üí    ) -> Callable[[], None]:
   453‚Üí        """Add before/after tracing functions for all hooks.
   454‚Üí
   455‚Üí        Returns an undo function which, when called, removes the added tracers.
   456‚Üí
   457‚Üí        ``before(hook_name, hook_impls, kwargs)`` will be called ahead
   458‚Üí        of all hook calls and receive a hookcaller instance, a list
   459‚Üí        of HookImpl instances and the keyword arguments for the hook call.
   460‚Üí
   461‚Üí        ``after(outcome, hook_name, hook_impls, kwargs)`` receives the
   462‚Üí        same arguments as ``before`` but also a :class:`~pluggy.Result` object
   463‚Üí        which represents the result of the overall hook call.
   464‚Üí        """
   465‚Üí        oldcall = self._inner_hookexec
   466‚Üí
   467‚Üí        def traced_hookexec(
   468‚Üí            hook_name: str,
   469‚Üí            hook_impls: Sequence[HookImpl],
   470‚Üí            caller_kwargs: Mapping[str, object],
   471‚Üí            firstresult: bool,
   472‚Üí        ) -> object | list[object]:
   473‚Üí            before(hook_name, hook_impls, caller_kwargs)
   474‚Üí            outcome = Result.from_call(
   475‚Üí                lambda: oldcall(hook_name, hook_impls, caller_kwargs, firstresult)
   476‚Üí            )
   477‚Üí            after(outcome, hook_name, hook_impls, caller_kwargs)
   478‚Üí            return outcome.get_result()
   479‚Üí
   480‚Üí        self._inner_hookexec = traced_hookexec
   481‚Üí
   482‚Üí        def undo() -> None:
   483‚Üí            self._inner_hookexec = oldcall
   484‚Üí
   485‚Üí        return undo
   486‚Üí
   487‚Üí    def enable_tracing(self) -> Callable[[], None]:
   488‚Üí        """Enable tracing of hook calls.
   489‚Üí
   490‚Üí        Returns an undo function which, when called, removes the added tracing.
   491‚Üí        """
   492‚Üí        hooktrace = self.trace.root.get("hook")
   493‚Üí
   494‚Üí        def before(
   495‚Üí            hook_name: str, methods: Sequence[HookImpl], kwargs: Mapping[str, object]
   496‚Üí        ) -> None:
   497‚Üí            hooktrace.root.indent += 1
   498‚Üí            hooktrace(hook_name, kwargs)
   499‚Üí
   500‚Üí        def after(
   501‚Üí            outcome: Result[object],
   502‚Üí            hook_name: str,
   503‚Üí            methods: Sequence[HookImpl],
   504‚Üí            kwargs: Mapping[str, object],
   505‚Üí        ) -> None:
   506‚Üí            if outcome.exception is None:
   507‚Üí                hooktrace("finish", hook_name, "-->", outcome.get_result())
   508‚Üí            hooktrace.root.indent -= 1
   509‚Üí
   510‚Üí        return self.add_hookcall_monitoring(before, after)
   511‚Üí
   512‚Üí    def subset_hook_caller(
   513‚Üí        self, name: str, remove_plugins: Iterable[_Plugin]
   514‚Üí    ) -> HookCaller:
   515‚Üí        """Return a proxy :class:`~pluggy.HookCaller` instance for the named
   516‚Üí        method which manages calls to all registered plugins except the ones
   517‚Üí        from remove_plugins."""
   518‚Üí        orig: HookCaller = getattr(self.hook, name)
   519‚Üí        plugins_to_remove = {plug for plug in remove_plugins if hasattr(plug, name)}
   520‚Üí        if plugins_to_remove:
   521‚Üí            return _SubsetHookCaller(orig, plugins_to_remove)
   522‚Üí        return orig
   525‚Üídef _formatdef(func: Callable[..., object]) -> str:

     4‚Üíclass PluggyWarning(UserWarning):
     5‚Üí    """Base class for all warnings emitted by pluggy."""
     6‚Üí
     7‚Üí    __module__ = "pluggy"
    10‚Üí@final
    11‚Üíclass PluggyTeardownRaisedWarning(PluggyWarning):
    12‚Üí    """A plugin raised an exception during an :ref:`old-style hookwrapper
    13‚Üí    <old_style_hookwrappers>` teardown.
    14‚Üí
    15‚Üí    Such exceptions are not handled by pluggy, and may cause subsequent
    16‚Üí    teardowns to be executed at unexpected times, or be skipped entirely.
    17‚Üí
    18‚Üí    This is an issue in the plugin implementation.
    19‚Üí
    20‚Üí    If the exception is unintended, fix the underlying cause.
    21‚Üí
    22‚Üí    If the exception is intended, switch to :ref:`new-style hook wrappers
    23‚Üí    <hookwrappers>`, or use :func:`result.force_exception()
    24‚Üí    <pluggy.Result.force_exception>` to set the exception instead of raising.
    25‚Üí    """
    26‚Üí
    27‚Üí    __module__ = "pluggy"

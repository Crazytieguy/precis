   342→      ? null
   343→      : [T] extends [IsUnion<T>]
   344→        ? EnumSchema<T>
   345→        : T
   346→    : [T] extends [boolean]
   347→      ? [T] extends [IsExactMatch<T, boolean>]
   348→        ? null
   349→        : T
   350→      : T extends
   351→            | bigint
   352→            | symbol
   353→            | undefined
   354→            | null
   355→            | Function
   356→            | Date
   357→            | Error
   358→            | RegExp
   359→            | Map<any, any>
   360→            | WeakMap<any, any>
   361→            | Set<any>

   202→export type UnionToIntersection<U> = (
   203→  U extends any ? (arg: U) => any : never
   204→) extends (arg: infer I) => void
   205→  ? I
   206→  : never
   212→export type Assign<T, U> = Simplify<U & Omit<T, keyof U>>
   218→export type EnumSchema<T extends string | number | undefined | null> = {
   219→  [K in NonNullable<T>]: K
   220→}
   227→export type IsMatch<T, G> = T extends G ? (G extends T ? T : never) : never
   233→export type IsExactMatch<T, U> =
   234→  (<G>() => G extends T ? 1 : 2) extends <G>() => G extends U ? 1 : 2
   235→    ? T
   236→    : never
   242→export type IsRecord<T> = T extends object

   201Ôćĺ
   202Ôćĺexport type UnionToIntersection<U> = (
   203Ôćĺ  U extends any ? (arg: U) => any : never
   204Ôćĺ) extends (arg: infer I) => void
   205Ôćĺ  ? I
   206Ôćĺ  : never
   208Ôćĺ/**
   209Ôćĺ * Assign properties from one type to another, overwriting existing.
   210Ôćĺ */
   211Ôćĺ
   212Ôćĺexport type Assign<T, U> = Simplify<U & Omit<T, keyof U>>
   214Ôćĺ/**
   215Ôćĺ * A schema for enum structs.
   216Ôćĺ */
   217Ôćĺ
   218Ôćĺexport type EnumSchema<T extends string | number | undefined | null> = {
   219Ôćĺ  [K in NonNullable<T>]: K
   220Ôćĺ}
   222Ôćĺ/**
   223Ôćĺ * Check if a type is a match for another whilst treating overlapping
   224Ôćĺ * unions as a match.
   225Ôćĺ */
   226Ôćĺ
   227Ôćĺexport type IsMatch<T, G> = T extends G ? (G extends T ? T : never) : never
   229Ôćĺ/**
   230Ôćĺ * Check if a type is an exact match.
   231Ôćĺ */
   232Ôćĺ
   233Ôćĺexport type IsExactMatch<T, U> =
   234Ôćĺ  (<G>() => G extends T ? 1 : 2) extends <G>() => G extends U ? 1 : 2
   235Ôćĺ    ? T
   236Ôćĺ    : never
   238Ôćĺ/**
   239Ôćĺ * Check if a type is a record type.
   240Ôćĺ */
   241Ôćĺ
   242Ôćĺexport type IsRecord<T> = T extends object
   243Ôćĺ  ? string extends keyof T
   244Ôćĺ    ? T
   245Ôćĺ    : never
   246Ôćĺ  : never
   247Ôćĺ/**
   248Ôćĺ * Check if a type is a tuple.
   249Ôćĺ */
   250Ôćĺ
   251Ôćĺexport type IsTuple<T> = T extends [any]
   252Ôćĺ  ? T
   253Ôćĺ  : T extends [any, any]
   254Ôćĺ    ? T
   255Ôćĺ    : T extends [any, any, any]
   256Ôćĺ      ? T
   257Ôćĺ      : T extends [any, any, any, any]
   258Ôćĺ        ? T
   259Ôćĺ        : T extends [any, any, any, any, any]
   260Ôćĺ          ? T
   261Ôćĺ          : never
   263Ôćĺ/**
   264Ôćĺ * Check if a type is a union.
   265Ôćĺ */
   266Ôćĺ
   267Ôćĺexport type IsUnion<T, U extends T = T> = (
   268Ôćĺ  T extends any ? (U extends T ? false : true) : false
   269Ôćĺ) extends false
   270Ôćĺ  ? never
   271Ôćĺ  : T
   273Ôćĺ/**
   274Ôćĺ * A schema for object structs.
   275Ôćĺ */
   276Ôćĺ
   277Ôćĺexport type ObjectSchema = Record<string, Struct<any, any>>
   279Ôćĺ/**
   280Ôćĺ * Infer a type from an object struct schema.
   281Ôćĺ */
   282Ôćĺ
   283Ôćĺexport type ObjectType<S extends ObjectSchema> = Simplify<
   284Ôćĺ  Optionalize<{ [K in keyof S]: Infer<S[K]> }>
   285Ôćĺ>
   287Ôćĺ/**
   288Ôćĺ * Omit properties from a type that extend from a specific type.
   289Ôćĺ */
   290Ôćĺ
   291Ôćĺexport type OmitBy<T, V> = Omit<
   292Ôćĺ  T,
   293Ôćĺ  { [K in keyof T]: V extends Extract<T[K], V> ? K : never }[keyof T]
   294Ôćĺ>
   296Ôćĺ/**
   297Ôćĺ * Normalize properties of a type that allow `undefined` to make them optional.
   298Ôćĺ */
   299Ôćĺ
   300Ôćĺexport type Optionalize<S extends object> = OmitBy<S, undefined> &
   301Ôćĺ  Partial<PickBy<S, undefined>>
   303Ôćĺ/**
   304Ôćĺ * Transform an object schema type to represent a partial.
   305Ôćĺ */
   306Ôćĺ
   307Ôćĺexport type PartialObjectSchema<S extends ObjectSchema> = {
   308Ôćĺ  [K in keyof S]: Struct<Infer<S[K]> | undefined>
   309Ôćĺ}
   311Ôćĺ/**
   312Ôćĺ * Pick properties from a type that extend from a specific type.
   313Ôćĺ */
   314Ôćĺ
   315Ôćĺexport type PickBy<T, V> = Pick<
   316Ôćĺ  T,
   317Ôćĺ  { [K in keyof T]: V extends Extract<T[K], V> ? K : never }[keyof T]
   318Ôćĺ>
   320Ôćĺ/**
   321Ôćĺ * Simplifies a type definition to its most basic representation.
   322Ôćĺ */
   323Ôćĺ
   324Ôćĺexport type Simplify<T> = T extends any[] | Date
   325Ôćĺ  ? T
   326Ôćĺ  : { [K in keyof T]: T[K] } & {}
   328Ôćĺexport type If<B extends Boolean, Then, Else> = B extends true ? Then : Else
   330Ôćĺ/**
   331Ôćĺ * A schema for any type of struct.
   332Ôćĺ */
   333Ôćĺ
   334Ôćĺexport type StructSchema<T> = [T] extends [string | undefined | null]
   335Ôćĺ  ? [T] extends [IsMatch<T, string | undefined | null>]
   336Ôćĺ    ? null
   337Ôćĺ    : [T] extends [IsUnion<T>]
   338Ôćĺ      ? EnumSchema<T>
   339Ôćĺ      : T
   340Ôćĺ  : [T] extends [number | undefined | null]
   341Ôćĺ    ? [T] extends [IsMatch<T, number | undefined | null>]
   342Ôćĺ      ? null
   343Ôćĺ      : [T] extends [IsUnion<T>]
   344Ôćĺ        ? EnumSchema<T>
   345Ôćĺ        : T
   346Ôćĺ    : [T] extends [boolean]
   347Ôćĺ      ? [T] extends [IsExactMatch<T, boolean>]
   348Ôćĺ        ? null
   349Ôćĺ        : T
   350Ôćĺ      : T extends
   351Ôćĺ            | bigint
   352Ôćĺ            | symbol
   353Ôćĺ            | undefined
   354Ôćĺ            | null
   355Ôćĺ            | Function
   356Ôćĺ            | Date
   357Ôćĺ            | Error
   358Ôćĺ            | RegExp
   359Ôćĺ            | Map<any, any>
   360Ôćĺ            | WeakMap<any, any>
   361Ôćĺ            | Set<any>
   362Ôćĺ            | WeakSet<any>
   363Ôćĺ            | Promise<any>
   364Ôćĺ        ? null
   365Ôćĺ        : T extends Array<infer E>
   366Ôćĺ          ? T extends IsTuple<T>
   367Ôćĺ            ? null
   368Ôćĺ            : Struct<E>
   369Ôćĺ          : T extends object
   370Ôćĺ            ? T extends IsRecord<T>
   371Ôćĺ              ? null
   372Ôćĺ              : { [K in keyof T]: Describe<T[K]> }
   373Ôćĺ            : null
   375Ôćĺ/**
   376Ôćĺ * A schema for tuple structs.
   377Ôćĺ */
   378Ôćĺ
   379Ôćĺexport type TupleSchema<T> = { [K in keyof T]: Struct<T[K]> }
   381Ôćĺ/**
   382Ôćĺ * Shorthand type for matching any `Struct`.
   383Ôćĺ */
   384Ôćĺ
   385Ôćĺexport type AnyStruct = Struct<any, any>
   387Ôćĺ/**
   388Ôćĺ * Infer a tuple of types from a tuple of `Struct`s.
   389Ôćĺ *
   390Ôćĺ * This is used to recursively retrieve the type from `union` `intersection` and
   391Ôćĺ * `tuple` structs.
   392Ôćĺ */
   393Ôćĺ
   394Ôćĺexport type InferStructTuple<
   395Ôćĺ  Tuple extends AnyStruct[],
   396Ôćĺ  Length extends number = Tuple['length'],
   397Ôćĺ> = Length extends Length
   398Ôćĺ  ? number extends Length
   399Ôćĺ    ? Tuple
   400Ôćĺ    : _InferTuple<Tuple, Length, []>
   401Ôćĺ  : never
   402Ôćĺtype _InferTuple<
   403Ôćĺ  Tuple extends AnyStruct[],
   404Ôćĺ  Length extends number,
   405Ôćĺ  Accumulated extends unknown[],
   406Ôćĺ  Index extends number = Accumulated['length'],
   407Ôćĺ> = Index extends Length
   408Ôćĺ  ? Accumulated
   409Ôćĺ  : _InferTuple<Tuple, Length, [...Accumulated, Infer<Tuple[Index]>]>

    17тЖТ/**
    18тЖТ * DistributeMatchingUnions takes two arguments:
    19тЖТ * - a data structure of type `a` containing unions
    20тЖТ * - a pattern `p`, matching this data structure
    21тЖТ * and turns it into a union of all possible
    22тЖТ * combination of each unions contained in `a` that matches `p`.
    23тЖТ *
    24тЖТ * It does this in 3 main steps:
    25тЖТ *  - 1. Find all unions contained in the data structure, that matches `p`
    26тЖТ *    with `FindUnions<a, p>`. It returns a tree of [union, path] pairs.
    27тЖТ *  - 2. this tree is passed to the `Distribute` type level function,
    28тЖТ *    Which turns it into a union of list of `[singleValue, path]` pairs.
    29тЖТ *    Each list correspond to one of the possible combination of the unions
    30тЖТ *    found in `a`.
    31тЖТ *  - 3. build a data structure with the same shape as `a` for each combination
    32тЖТ *    and return the union of these data structures.
    33тЖТ *
    34тЖТ * @example
    35тЖТ * type t1 = DistributeMatchingUnions<['a' | 'b', 1 | 2], ['a', 1]>;
    36тЖТ * // => ['a', 1] | ['a', 2] | ['b', 1] | ['b', 2]
    37тЖТ *
    38тЖТ * type t2 = DistributeMatchingUnions<['a' | 'b', 1 | 2], ['a', unknown]>;
    39тЖТ * // => ['a', 1 | 2] | ['b', 1 | 2]
    40тЖТ */
    41тЖТexport type DistributeMatchingUnions<a, p> = IsAny<a> extends true
    46тЖТexport type FindUnionsMany<
    62тЖТ/**
    63тЖТ * The reason we don't look further down the tree with lists,
    64тЖТ * Set and Maps is that they can be heterogeneous,
    65тЖТ * so matching on a A[] for a in input of (A|B)[]
    66тЖТ * doesn't rule anything out. You can still have
    67тЖТ * a (A|B)[] afterward. The same logic goes for Set and Maps.
    68тЖТ *
    69тЖТ * Kinds are types of types.
    70тЖТ *
    71тЖТ * kind UnionConfig = {
    72тЖТ *  cases: Union<{
    73тЖТ *    value: b,
    74тЖТ *    subUnions: UnionConfig[]
    75тЖТ *  }>,
    76тЖТ *  path: string[]
    77тЖТ * }
    78тЖТ * FindUnions :: Pattern a p => a -> p -> UnionConfig[]
    79тЖТ */
    80тЖТexport type FindUnions<

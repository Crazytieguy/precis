    53Ôćĺ    const handler: (selection: unknown, value: input) => output =
    54Ôćĺ      args[args.length - 1];
    55Ôćĺ
    56Ôćĺ    const patterns: Pattern<input>[] = [args[0]];
    57Ôćĺ    let predicate: ((value: input) => unknown) | undefined = undefined;
    58Ôćĺ

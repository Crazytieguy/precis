    60Ôćĺ      // case with guard as second argument
    61Ôćĺ      predicate = args[1];
    62Ôćĺ    } else if (args.length > 2) {
    63Ôćĺ      // case with several patterns
    64Ôćĺ      patterns.push(...args.slice(1, args.length - 1));
    65Ôćĺ    }
    66Ôćĺ
    67Ôćĺ    let hasSelections = false;

    27Ôćĺ *  - 2. this tree is passed to the `Distribute` type level function,
    28Ôćĺ *    Which turns it into a union of list of `[singleValue, path]` pairs.
    29Ôćĺ *    Each list correspond to one of the possible combination of the unions
    30Ôćĺ *    found in `a`.
    31Ôćĺ *  - 3. build a data structure with the same shape as `a` for each combination
    32Ôćĺ *    and return the union of these data structures.
    33Ôćĺ *
    34Ôćĺ * @example
    35Ôćĺ * type t1 = DistributeMatchingUnions<['a' | 'b', 1 | 2], ['a', 1]>;
    36Ôćĺ * // => ['a', 1] | ['a', 2] | ['b', 1] | ['b', 2]
    37Ôćĺ *
    38Ôćĺ * type t2 = DistributeMatchingUnions<['a' | 'b', 1 | 2], ['a', unknown]>;
    39Ôćĺ * // => ['a', 1 | 2] | ['b', 1 | 2]
    40Ôćĺ */
    41Ôćĺexport type DistributeMatchingUnions<a, p> = IsAny<a> extends true

types/DistributeUnions.ts
    17→/**
    18→ * DistributeMatchingUnions takes two arguments:
    19→ * - a data structure of type `a` containing unions
    20→ * - a pattern `p`, matching this data structure
    21→ * and turns it into a union of all possible
    22→ * combination of each unions contained in `a` that matches `p`.
    23→ *
    24→ * It does this in 3 main steps:
    25→ *  - 1. Find all unions contained in the data structure, that matches `p`
    26→ *    with `FindUnions<a, p>`. It returns a tree of [union, path] pairs.
    27→ *  - 2. this tree is passed to the `Distribute` type level function,
    28→ *    Which turns it into a union of list of `[singleValue, path]` pairs.
    29→ *    Each list correspond to one of the possible combination of the unions
    30→ *    found in `a`.
    31→ *  - 3. build a data structure with the same shape as `a` for each combination
    32→ *    and return the union of these data structures.
    33→ *
    34→ * @example
    35→ * type t1 = DistributeMatchingUnions<['a' | 'b', 1 | 2], ['a', 1]>;
    36→ * // => ['a', 1] | ['a', 2] | ['b', 1] | ['b', 2]
    37→ *
    38→ * type t2 = DistributeMatchingUnions<['a' | 'b', 1 | 2], ['a', unknown]>;
    39→ * // => ['a', 1 | 2] | ['b', 1 | 2]
    40→ */
    41→export type DistributeMatchingUnions<a, p> = IsAny<a> extends true
    46→export type FindUnionsMany<
    62→/**
    63→ * The reason we don't look further down the tree with lists,
    64→ * Set and Maps is that they can be heterogeneous,
    65→ * so matching on a A[] for a in input of (A|B)[]
    66→ * doesn't rule anything out. You can still have
    67→ * a (A|B)[] afterward. The same logic goes for Set and Maps.
    68→ *
    69→ * Kinds are types of types.
    70→ *
    71→ * kind UnionConfig = {
    72→ *  cases: Union<{
    73→ *    value: b,
    74→ *    subUnions: UnionConfig[]
    75→ *  }>,
    76→ *  path: string[]
    77→ * }
    78→ * FindUnions :: Pattern a p => a -> p -> UnionConfig[]
    79→ */

     8→class TypeCheckMemo:
     9→    """
    10→    Contains information necessary for type checkers to do their work.
    11→
    12→    .. attribute:: globals
    13→       :type: dict[str, Any]
    14→
    15→        Dictionary of global variables to use for resolving forward references.
    16→
    17→    .. attribute:: locals
    18→       :type: dict[str, Any]
    19→
    20→        Dictionary of local variables to use for resolving forward references.
    21→
    22→    .. attribute:: self_type
    23→       :type: type | None
    24→
    25→        When running type checks within an instance method or class method, this is the
    26→        class object that the first argument (usually named ``self`` or ``cls``) refers
    27→        to.
    28→
    29→    .. attribute:: config
    30→       :type: TypeCheckConfiguration
    31→
    32→         Contains the configuration for a particular set of type checking operations.
    33→    """
    37→    def __init__(

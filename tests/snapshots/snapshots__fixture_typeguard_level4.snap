   150→def typechecked(
   151→    target: T_CallableOrType | None = None,
   152→    *,
   153→    forward_ref_policy: ForwardRefPolicy | Unset = unset,
   154→    typecheck_fail_callback: TypeCheckFailCallback | Unset = unset,
   155→    collection_check_strategy: CollectionCheckStrategy | Unset = unset,
   156→    debug_instrumentation: bool | Unset = unset,
   157→) -> Any:
   158→    """
   159→    Instrument the target function to perform run-time type checking.
   160→
   161→    This decorator recompiles the target function, injecting code to type check
   162→    arguments, return values, yield values (excluding ``yield from``) and assignments to
   163→    annotated local variables.
   164→
   165→    This can also be used as a class decorator. This will instrument all type annotated
   166→    methods, including :func:`@classmethod <classmethod>`,
   167→    :func:`@staticmethod <staticmethod>`,  and :class:`@property <property>` decorated
   168→    methods in the class.
   169→
   170→    .. note:: When Python is run in optimized mode (``-O`` or ``-OO``, this decorator
   171→        is a no-op). This is a feature meant for selectively introducing type checking
   172→        into a code base where the checks aren't meant to be run in production.
   173→
   174→    :param target: the function or class to enable type checking for
   175→    :param forward_ref_policy: override for
   176→        :attr:`.TypeCheckConfiguration.forward_ref_policy`
   177→    :param typecheck_fail_callback: override for
   178→        :attr:`.TypeCheckConfiguration.typecheck_fail_callback`
   179→    :param collection_check_strategy: override for
   180→        :attr:`.TypeCheckConfiguration.collection_check_strategy`
   181→    :param debug_instrumentation: override for
   182→        :attr:`.TypeCheckConfiguration.debug_instrumentation`
   183→
   184→    """

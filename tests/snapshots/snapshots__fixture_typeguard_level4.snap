   109→class TypeguardFinder(MetaPathFinder):
   110→    """
   111→    Wraps another path finder and instruments the module with
   112→    :func:`@typechecked <typeguard.typechecked>` if :meth:`should_instrument` returns
   113→    ``True``.
   114→
   115→    Should not be used directly, but rather via :func:`~.install_import_hook`.
   116→
   117→    .. versionadded:: 2.6
   118→    """
   120→    def __init__(self, packages: list[str] | None, original_pathfinder: MetaPathFinder):
   124→    def find_spec(
   125→        self,
   126→        fullname: str,
   127→        path: Sequence[str] | None,
   128→        target: types.ModuleType | None = None,
   129→    ) -> ModuleSpec | None:
   138→    def should_instrument(self, module_name: str) -> bool:
   139→        """
   140→        Determine whether the module with the given name should be instrumented.
   141→
   142→        :param module_name: full name of the module that is about to be imported (e.g.
   143→            ``xyz.abc``)
   144→
   145→        """
   156→class ImportHookManager:
   157→    """
   158→    A handle that can be used to uninstall the Typeguard import hook.
   159→    """
   161→    def __init__(self, hook: MetaPathFinder):
   164→    def __enter__(self) -> None:
   167→    def __exit__(
   168→        self,
   169→        exc_type: type[BaseException],
   170→        exc_val: BaseException,
   171→        exc_tb: TracebackType,
   172→    ) -> None:
   175→    def uninstall(self) -> None:
   176→        """Uninstall the import hook."""
   183→def install_import_hook(
   184→    packages: Iterable[str] | None = None,
   185→    *,
   186→    cls: type[TypeguardFinder] = TypeguardFinder,
   187→) -> ImportHookManager:
   188→    """
   189→    Install an import hook that instruments functions for automatic type checking.
   190→
   191→    This only affects modules loaded **after** this hook has been installed.
   192→
   193→    :param packages: an iterable of package names to instrument, or ``None`` to
   194→        instrument all packages
   195→    :param cls: a custom meta path finder class
   196→    :return: a context manager that uninstalls the hook on exit (or when you call
   197→        ``.uninstall()``)
   198→
   199→    .. versionadded:: 2.6
   200→
   201→    """

   117→@dataclass
   118→class TransformMemo:
   119→    node: Module | ClassDef | FunctionDef | AsyncFunctionDef | None
   120→    parent: TransformMemo | None
   121→    path: tuple[str, ...]
   122→    joined_path: Constant = field(init=False)
   123→    return_annotation: expr | None = None
   124→    yield_annotation: expr | None = None
   125→    send_annotation: expr | None = None
   126→    is_async: bool = False
   127→    local_names: set[str] = field(init=False, default_factory=set)
   128→    imported_names: dict[str, str] = field(init=False, default_factory=dict)
   129→    ignored_names: set[str] = field(init=False, default_factory=set)
   130→    load_names: defaultdict[str, dict[str, Name]] = field(
   131→        init=False, default_factory=lambda: defaultdict(dict)
   132→    )
   133→    has_yield_expressions: bool = field(init=False, default=False)
   134→    has_return_expressions: bool = field(init=False, default=False)
   135→    memo_var_name: Name | None = field(init=False, default=None)
   136→    should_instrument: bool = field(init=False, default=True)
   137→    variable_annotations: dict[str, expr] = field(init=False, default_factory=dict)
   138→    configuration_overrides: dict[str, Any] = field(init=False, default_factory=dict)
   139→    code_inject_index: int = field(init=False, default=0)
   140→
   141→    def __post_init__(self) -> None:
   142→        elements: list[str] = []
   143→        memo = self
   144→        while isinstance(memo.node, (ClassDef, FunctionDef, AsyncFunctionDef)):
   145→            elements.insert(0, memo.node.name)
   146→            if not memo.parent:
   147→                break
   148→
   149→            memo = memo.parent
   150→            if isinstance(memo.node, (FunctionDef, AsyncFunctionDef)):
   151→                elements.insert(0, "<locals>")
   152→
   153→        self.joined_path = Constant(".".join(elements))
   154→
   155→        # Figure out where to insert instrumentation code
   156→        if self.node:
   157→            for index, child in enumerate(self.node.body):
   158→                if isinstance(child, ImportFrom) and child.module == "__future__":
   159→                    # (module only) __future__ imports must come first
   160→                    continue
   161→                elif (
   162→                    isinstance(child, Expr)
   163→                    and isinstance(child.value, Constant)
   164→                    and isinstance(child.value.value, str)
   165→                ):
   166→                    continue  # docstring
   167→
   168→                self.code_inject_index = index
   169→                break
   170→
   171→    def get_unused_name(self, name: str) -> str:
   172→        memo: TransformMemo | None = self
   173→        while memo is not None:
   174→            if name in memo.local_names:
   175→                memo = self
   176→                name += "_"
   177→            else:
   178→                memo = memo.parent
   179→
   180→        self.local_names.add(name)
   181→        return name
   182→
   183→    def is_ignored_name(self, expression: expr | Expr | None) -> bool:
   184→        top_expression = (
   185→            expression.value if isinstance(expression, Expr) else expression
   186→        )
   187→
   188→        if isinstance(top_expression, Attribute) and isinstance(
   189→            top_expression.value, Name
   190→        ):
   191→            name = top_expression.value.id
   192→        elif isinstance(top_expression, Name):
   193→            name = top_expression.id
   194→        else:
   195→            return False
   196→
   197→        memo: TransformMemo | None = self
   198→        while memo is not None:
   199→            if name in memo.ignored_names:
   200→                return True
   201→
   202→            memo = memo.parent
   203→
   204→        return False
   205→
   206→    def get_memo_name(self) -> Name:
   207→        if not self.memo_var_name:
   208→            self.memo_var_name = Name(id="memo", ctx=Load())
   209→
   210→        return self.memo_var_name
   211→
   212→    def get_import(self, module: str, name: str) -> Name:
   213→        if module in self.load_names and name in self.load_names[module]:
   214→            return self.load_names[module][name]
   215→
   216→        qualified_name = f"{module}.{name}"
   217→        if name in self.imported_names and self.imported_names[name] == qualified_name:
   218→            return Name(id=name, ctx=Load())
   219→
   220→        alias = self.get_unused_name(name)
   221→        node = self.load_names[module][name] = Name(id=alias, ctx=Load())
   222→        self.imported_names[name] = qualified_name
   223→        return node
   224→
   225→    def insert_imports(self, node: Module | FunctionDef | AsyncFunctionDef) -> None:
   226→        """Insert imports needed by injected code."""
   227→        if not self.load_names:
   228→            return
   229→
   230→        # Insert imports after any "from __future__ ..." imports and any docstring
   231→        for modulename, names in self.load_names.items():
   232→            aliases = [
   233→                alias(orig_name, new_name.id if orig_name != new_name.id else None)
   234→                for orig_name, new_name in sorted(names.items())
   235→            ]
   236→            node.body.insert(self.code_inject_index, ImportFrom(modulename, aliases, 0))
   237→
   238→    def name_matches(self, expression: expr | Expr | None, *names: str) -> bool:
   239→        if expression is None:
   240→            return False
   241→
   242→        path: list[str] = []
   243→        top_expression = (
   244→            expression.value if isinstance(expression, Expr) else expression
   245→        )
   246→
   247→        if isinstance(top_expression, Subscript):
   248→            top_expression = top_expression.value
   249→        elif isinstance(top_expression, Call):
   250→            top_expression = top_expression.func
   251→
   252→        while isinstance(top_expression, Attribute):
   253→            path.insert(0, top_expression.attr)
   254→            top_expression = top_expression.value
   255→
   256→        if not isinstance(top_expression, Name):
   257→            return False
   258→
   259→        if top_expression.id in self.imported_names:
   260→            translated = self.imported_names[top_expression.id]
   261→        elif hasattr(builtins, top_expression.id):
   262→            translated = "builtins." + top_expression.id
   263→        else:
   264→            translated = top_expression.id
   265→
   266→        path.insert(0, translated)
   267→        joined_path = ".".join(path)
   268→        if joined_path in names:
   269→            return True
   270→        elif self.parent:
   271→            return self.parent.name_matches(expression, *names)
   272→        else:
   273→            return False
   274→
   275→    def get_config_keywords(self) -> list[keyword]:
   276→        if self.parent and isinstance(self.parent.node, ClassDef):
   277→            overrides = self.parent.configuration_overrides.copy()
   278→        else:
   279→            overrides = {}
   280→
   281→        overrides.update(self.configuration_overrides)
   282→        return [keyword(key, value) for key, value in overrides.items()]
   285→class NameCollector(NodeVisitor):
   286→    def __init__(self) -> None:
   287→        self.names: set[str] = set()
   288→
   289→    def visit_Import(self, node: Import) -> None:
   290→        for name in node.names:
   291→            self.names.add(name.asname or name.name)
   292→
   293→    def visit_ImportFrom(self, node: ImportFrom) -> None:
   294→        for name in node.names:
   295→            self.names.add(name.asname or name.name)
   296→
   297→    def visit_Assign(self, node: Assign) -> None:
   298→        for target in node.targets:
   299→            if isinstance(target, Name):
   300→                self.names.add(target.id)
   301→
   302→    def visit_NamedExpr(self, node: NamedExpr) -> Any:
   303→        if isinstance(node.target, Name):
   304→            self.names.add(node.target.id)
   305→
   306→    def visit_FunctionDef(self, node: FunctionDef) -> None:
   307→        pass
   308→
   309→    def visit_ClassDef(self, node: ClassDef) -> None:
   310→        pass
   313→class GeneratorDetector(NodeVisitor):
   314→    """Detects if a function node is a generator function."""
   315→
   316→    contains_yields: bool = False
   317→    in_root_function: bool = False
   318→
   319→    def visit_Yield(self, node: Yield) -> Any:
   320→        self.contains_yields = True
   321→
   322→    def visit_YieldFrom(self, node: YieldFrom) -> Any:
   323→        self.contains_yields = True
   324→
   325→    def visit_ClassDef(self, node: ClassDef) -> Any:
   326→        pass
   327→
   328→    def visit_FunctionDef(self, node: FunctionDef | AsyncFunctionDef) -> Any:
   329→        if not self.in_root_function:
   330→            self.in_root_function = True
   331→            self.generic_visit(node)
   332→            self.in_root_function = False
   333→
   334→    def visit_AsyncFunctionDef(self, node: AsyncFunctionDef) -> Any:
   335→        self.visit_FunctionDef(node)
   338→class AnnotationTransformer(NodeTransformer):
   339→    type_substitutions: ClassVar[dict[str, tuple[str, str]]] = {
   340→        "builtins.dict": ("typing", "Dict"),
   341→        "builtins.list": ("typing", "List"),
   342→        "builtins.tuple": ("typing", "Tuple"),
   343→        "builtins.set": ("typing", "Set"),
   344→        "builtins.frozenset": ("typing", "FrozenSet"),
   345→    }
   346→
   347→    def __init__(self, transformer: TypeguardTransformer):
   348→        self.transformer = transformer
   349→        self._memo = transformer._memo
   350→        self._level = 0
   351→
   352→    def visit(self, node: AST) -> Any:
   353→        # Don't process Literals
   354→        if isinstance(node, expr) and self._memo.name_matches(node, *literal_names):
   355→            return node
   356→
   357→        self._level += 1
   358→        new_node = super().visit(node)
   359→        self._level -= 1
   360→
   361→        if isinstance(new_node, Expression) and not hasattr(new_node, "body"):
   362→            return None
   363→
   364→        # Return None if this new node matches a variation of typing.Any
   365→        if (
   366→            self._level == 0
   367→            and isinstance(new_node, expr)
   368→            and self._memo.name_matches(new_node, *anytype_names)
   369→        ):
   370→            return None
   371→
   372→        return new_node
   373→
   374→    def visit_BinOp(self, node: BinOp) -> Any:
   375→        self.generic_visit(node)
   376→
   377→        if isinstance(node.op, BitOr):
   378→            # If either branch of the BinOp has been transformed to `None`, it means
   379→            # that a type in the union was ignored, so the entire annotation should be
   380→            # ignored
   381→            if not hasattr(node, "left") or not hasattr(node, "right"):
   382→                return None
   383→
   384→            # Return Any if either side is Any
   385→            if self._memo.name_matches(node.left, *anytype_names):
   386→                return node.left
   387→            elif self._memo.name_matches(node.right, *anytype_names):
   388→                return node.right
   389→
   390→            # Turn union types to typing.Union constructs on Python 3.9
   391→            if sys.version_info < (3, 10):
   392→                union_name = self.transformer._get_import("typing", "Union")
   393→                return Subscript(
   394→                    value=union_name,
   395→                    slice=Tuple(elts=[node.left, node.right], ctx=Load()),
   396→                    ctx=Load(),
   397→                )
   398→
   399→        return node
   400→
   401→    def visit_Attribute(self, node: Attribute) -> Any:
   402→        if self._memo.is_ignored_name(node):
   403→            return None
   404→
   405→        return node
   406→
   407→    def visit_Subscript(self, node: Subscript) -> Any:
   408→        if self._memo.is_ignored_name(node.value):
   409→            return None
   410→
   411→        # The subscript of typing(_extensions).Literal can be any arbitrary string, so
   412→        # don't try to evaluate it as code
   413→        if node.slice:
   414→            if isinstance(node.slice, Tuple):
   415→                if self._memo.name_matches(node.value, *annotated_names):
   416→                    # Only treat the first argument to typing.Annotated as a potential
   417→                    # forward reference
   418→                    items = cast(
   419→                        typing.List[expr],
   420→                        [self.visit(node.slice.elts[0])] + node.slice.elts[1:],
   421→                    )
   422→                else:
   423→                    items = cast(
   424→                        typing.List[expr],
   425→                        [self.visit(item) for item in node.slice.elts],
   426→                    )
   427→
   428→                # If this is a Union and any of the items is Any, erase the entire
   429→                # annotation
   430→                if self._memo.name_matches(node.value, "typing.Union") and any(
   431→                    item is None
   432→                    or (
   433→                        isinstance(item, expr)
   434→                        and self._memo.name_matches(item, *anytype_names)
   435→                    )
   436→                    for item in items
   437→                ):
   438→                    return None
   439→
   440→                # If all items in the subscript were Any, erase the subscript entirely
   441→                if all(item is None for item in items):
   442→                    return node.value
   443→
   444→                for index, item in enumerate(items):
   445→                    if item is None:
   446→                        items[index] = self.transformer._get_import("typing", "Any")
   447→
   448→                node.slice.elts = items
   449→            else:
   450→                self.generic_visit(node)
   451→
   452→                # If the transformer erased the slice entirely, just return the node
   453→                # value without the subscript (unless it's Optional, in which case erase
   454→                # the node entirely
   455→                if self._memo.name_matches(
   456→                    node.value, "typing.Optional"
   457→                ) and not hasattr(node, "slice"):
   458→                    return None
   459→                if sys.version_info >= (3, 9) and not hasattr(node, "slice"):
   460→                    return node.value
   461→                elif sys.version_info < (3, 9) and not hasattr(node.slice, "value"):
   462→                    return node.value
   463→
   464→        return node
   465→
   466→    def visit_Name(self, node: Name) -> Any:
   467→        if self._memo.is_ignored_name(node):
   468→            return None
   469→
   470→        return node
   471→
   472→    def visit_Call(self, node: Call) -> Any:
   473→        # Don't recurse into calls
   474→        return node
   475→
   476→    def visit_Constant(self, node: Constant) -> Any:
   477→        if isinstance(node.value, str):
   478→            expression = ast.parse(node.value, mode="eval")
   479→            new_node = self.visit(expression)
   480→            if new_node:
   481→                return copy_location(new_node.body, node)
   482→            else:
   483→                return None
   484→
   485→        return node
   488→class TypeguardTransformer(NodeTransformer):
   489→    def __init__(
   490→        self, target_path: Sequence[str] | None = None, target_lineno: int | None = None
   491→    ) -> None:
   492→        self._target_path = tuple(target_path) if target_path else None
   493→        self._memo = self._module_memo = TransformMemo(None, None, ())
   494→        self.names_used_in_annotations: set[str] = set()
   495→        self.target_node: FunctionDef | AsyncFunctionDef | None = None
   496→        self.target_lineno = target_lineno
   497→
   498→    def generic_visit(self, node: AST) -> AST:
   499→        has_non_empty_body_initially = bool(getattr(node, "body", None))
   500→        initial_type = type(node)
   501→
   502→        node = super().generic_visit(node)
   503→
   504→        if (
   505→            type(node) is initial_type
   506→            and has_non_empty_body_initially
   507→            and hasattr(node, "body")
   508→            and not node.body
   509→        ):
   510→            # If we have still the same node type after transformation
   511→            # but we've optimised it's body away, we add a `pass` statement.
   512→            node.body = [Pass()]
   513→
   514→        return node
   515→
   516→    @contextmanager
   517→    def _use_memo(
   518→        self, node: ClassDef | FunctionDef | AsyncFunctionDef
   519→    ) -> Generator[None, Any, None]:
   520→        new_memo = TransformMemo(node, self._memo, self._memo.path + (node.name,))
   521→        old_memo = self._memo
   522→        self._memo = new_memo
   523→
   524→        if isinstance(node, (FunctionDef, AsyncFunctionDef)):
   525→            new_memo.should_instrument = (
   526→                self._target_path is None or new_memo.path == self._target_path
   527→            )
   528→            if new_memo.should_instrument:
   529→                # Check if the function is a generator function
   530→                detector = GeneratorDetector()
   531→                detector.visit(node)
   532→
   533→                # Extract yield, send and return types where possible from a subscripted
   534→                # annotation like Generator[int, str, bool]
   535→                return_annotation = deepcopy(node.returns)
   536→                if detector.contains_yields and new_memo.name_matches(
   537→                    return_annotation, *generator_names
   538→                ):
   539→                    if isinstance(return_annotation, Subscript):
   540→                        if isinstance(return_annotation.slice, Tuple):
   541→                            items = return_annotation.slice.elts
   542→                        else:
   543→                            items = [return_annotation.slice]
   544→
   545→                        if len(items) > 0:
   546→                            new_memo.yield_annotation = self._convert_annotation(
   547→                                items[0]
   548→                            )
   549→
   550→                        if len(items) > 1:
   551→                            new_memo.send_annotation = self._convert_annotation(
   552→                                items[1]
   553→                            )
   554→
   555→                        if len(items) > 2:
   556→                            new_memo.return_annotation = self._convert_annotation(
   557→                                items[2]
   558→                            )
   559→                else:
   560→                    new_memo.return_annotation = self._convert_annotation(
   561→                        return_annotation
   562→                    )
   563→
   564→        if isinstance(node, AsyncFunctionDef):
   565→            new_memo.is_async = True
   566→
   567→        yield
   568→        self._memo = old_memo
   569→
   570→    def _get_import(self, module: str, name: str) -> Name:
   571→        memo = self._memo if self._target_path else self._module_memo
   572→        return memo.get_import(module, name)
   573→
   574→    @overload
   575→    def _convert_annotation(self, annotation: None) -> None: ...
   576→
   577→    @overload
   578→    def _convert_annotation(self, annotation: expr) -> expr: ...
   579→
   580→    def _convert_annotation(self, annotation: expr | None) -> expr | None:
   581→        if annotation is None:
   582→            return None
   583→
   584→        # Convert PEP 604 unions (x | y) and generic built-in collections where
   585→        # necessary, and undo forward references
   586→        new_annotation = cast(expr, AnnotationTransformer(self).visit(annotation))
   587→        if isinstance(new_annotation, expr):
   588→            new_annotation = ast.copy_location(new_annotation, annotation)
   589→
   590→            # Store names used in the annotation
   591→            names = {node.id for node in walk(new_annotation) if isinstance(node, Name)}
   592→            self.names_used_in_annotations.update(names)
   593→
   594→        return new_annotation
   595→
   596→    def visit_Name(self, node: Name) -> Name:
   597→        self._memo.local_names.add(node.id)
   598→        return node
   599→
   600→    def visit_Module(self, node: Module) -> Module:
   601→        self._module_memo = self._memo = TransformMemo(node, None, ())
   602→        self.generic_visit(node)
   603→        self._module_memo.insert_imports(node)
   604→
   605→        fix_missing_locations(node)
   606→        return node
   607→
   608→    def visit_Import(self, node: Import) -> Import:
   609→        for name in node.names:
   610→            self._memo.local_names.add(name.asname or name.name)
   611→            self._memo.imported_names[name.asname or name.name] = name.name
   612→
   613→        return node
   614→
   615→    def visit_ImportFrom(self, node: ImportFrom) -> ImportFrom:
   616→        for name in node.names:
   617→            if name.name != "*":
   618→                alias = name.asname or name.name
   619→                self._memo.local_names.add(alias)
   620→                self._memo.imported_names[alias] = f"{node.module}.{name.name}"
   621→
   622→        return node
   623→
   624→    def visit_ClassDef(self, node: ClassDef) -> ClassDef | None:
   625→        self._memo.local_names.add(node.name)
   626→
   627→        # Eliminate top level classes not belonging to the target path
   628→        if (
   629→            self._target_path is not None
   630→            and not self._memo.path
   631→            and node.name != self._target_path[0]
   632→        ):
   633→            return None
   634→
   635→        with self._use_memo(node):
   636→            for decorator in node.decorator_list.copy():
   637→                if self._memo.name_matches(decorator, "typeguard.typechecked"):
   638→                    # Remove the decorator to prevent duplicate instrumentation
   639→                    node.decorator_list.remove(decorator)
   640→
   641→                    # Store any configuration overrides
   642→                    if isinstance(decorator, Call) and decorator.keywords:
   643→                        self._memo.configuration_overrides.update(
   644→                            {kw.arg: kw.value for kw in decorator.keywords if kw.arg}
   645→                        )
   646→
   647→            self.generic_visit(node)
   648→            return node
   649→
   650→    def visit_FunctionDef(
   651→        self, node: FunctionDef | AsyncFunctionDef
   652→    ) -> FunctionDef | AsyncFunctionDef | None:
   653→        """
   654→        Injects type checks for function arguments, and for a return of None if the
   655→        function is annotated to return something else than Any or None, and the body
   656→        ends without an explicit "return".
   657→
   658→        """
   659→        self._memo.local_names.add(node.name)
   660→
   661→        # Eliminate top level functions not belonging to the target path
   662→        if (
   663→            self._target_path is not None
   664→            and not self._memo.path
   665→            and node.name != self._target_path[0]
   666→        ):
   667→            return None
   668→
   669→        # Skip instrumentation if we're instrumenting the whole module and the function
   670→        # contains either @no_type_check or @typeguard_ignore
   671→        if self._target_path is None:
   672→            for decorator in node.decorator_list:
   673→                if self._memo.name_matches(decorator, *ignore_decorators):
   674→                    return node
   675→
   676→        with self._use_memo(node):
   677→            arg_annotations: dict[str, Any] = {}
   678→            if self._target_path is None or self._memo.path == self._target_path:
   679→                # Find line number we're supposed to match against
   680→                if node.decorator_list:
   681→                    first_lineno = node.decorator_list[0].lineno
   682→                else:
   683→                    first_lineno = node.lineno
   684→
   685→                for decorator in node.decorator_list.copy():
   686→                    if self._memo.name_matches(decorator, "typing.overload"):
   687→                        # Remove overloads entirely
   688→                        return None
   689→                    elif self._memo.name_matches(decorator, "typeguard.typechecked"):
   690→                        # Remove the decorator to prevent duplicate instrumentation
   691→                        node.decorator_list.remove(decorator)
   692→
   693→                        # Store any configuration overrides
   694→                        if isinstance(decorator, Call) and decorator.keywords:
   695→                            self._memo.configuration_overrides = {
   696→                                kw.arg: kw.value for kw in decorator.keywords if kw.arg
   697→                            }
   698→
   699→                if self.target_lineno == first_lineno:
   700→                    assert self.target_node is None
   701→                    self.target_node = node
   702→                    if node.decorator_list:
   703→                        self.target_lineno = node.decorator_list[0].lineno
   704→                    else:
   705→                        self.target_lineno = node.lineno
   706→
   707→                all_args = node.args.posonlyargs + node.args.args + node.args.kwonlyargs
   708→
   709→                # Ensure that any type shadowed by the positional or keyword-only
   710→                # argument names are ignored in this function
   711→                for arg in all_args:
   712→                    self._memo.ignored_names.add(arg.arg)
   713→
   714→                # Ensure that any type shadowed by the variable positional argument name
   715→                # (e.g. "args" in *args) is ignored this function
   716→                if node.args.vararg:
   717→                    self._memo.ignored_names.add(node.args.vararg.arg)
   718→
   719→                # Ensure that any type shadowed by the variable keywrod argument name
   720→                # (e.g. "kwargs" in *kwargs) is ignored this function
   721→                if node.args.kwarg:
   722→                    self._memo.ignored_names.add(node.args.kwarg.arg)
   723→
   724→                for arg in all_args:
   725→                    annotation = self._convert_annotation(deepcopy(arg.annotation))
   726→                    if annotation:
   727→                        arg_annotations[arg.arg] = annotation
   728→
   729→                if node.args.vararg:
   730→                    annotation_ = self._convert_annotation(node.args.vararg.annotation)
   731→                    if annotation_:
   732→                        container = Name("tuple", ctx=Load())
   733→                        subscript_slice = Tuple(
   734→                            [
   735→                                annotation_,
   736→                                Constant(Ellipsis),
   737→                            ],
   738→                            ctx=Load(),
   739→                        )
   740→                        arg_annotations[node.args.vararg.arg] = Subscript(
   741→                            container, subscript_slice, ctx=Load()
   742→                        )
   743→
   744→                if node.args.kwarg:
   745→                    annotation_ = self._convert_annotation(node.args.kwarg.annotation)
   746→                    if annotation_:
   747→                        container = Name("dict", ctx=Load())
   748→                        subscript_slice = Tuple(
   749→                            [
   750→                                Name("str", ctx=Load()),
   751→                                annotation_,
   752→                            ],
   753→                            ctx=Load(),
   754→                        )
   755→                        arg_annotations[node.args.kwarg.arg] = Subscript(
   756→                            container, subscript_slice, ctx=Load()
   757→                        )
   758→
   759→                if arg_annotations:
   760→                    self._memo.variable_annotations.update(arg_annotations)
   761→
   762→            self.generic_visit(node)
   763→
   764→            if arg_annotations:
   765→                annotations_dict = Dict(
   766→                    keys=[Constant(key) for key in arg_annotations.keys()],
   767→                    values=[
   768→                        Tuple([Name(key, ctx=Load()), annotation], ctx=Load())
   769→                        for key, annotation in arg_annotations.items()
   770→                    ],
   771→                )
   772→                func_name = self._get_import(
   773→                    "typeguard._functions", "check_argument_types"
   774→                )
   775→                args = [
   776→                    self._memo.joined_path,
   777→                    annotations_dict,
   778→                    self._memo.get_memo_name(),
   779→                ]
   780→                node.body.insert(
   781→                    self._memo.code_inject_index, Expr(Call(func_name, args, []))
   782→                )
   783→
   784→            # Add a checked "return None" to the end if there's no explicit return
   785→            # Skip if the return annotation is None or Any
   786→            if (
   787→                self._memo.return_annotation
   788→                and (not self._memo.is_async or not self._memo.has_yield_expressions)
   789→                and not isinstance(node.body[-1], Return)
   790→                and (
   791→                    not isinstance(self._memo.return_annotation, Constant)
   792→                    or self._memo.return_annotation.value is not None
   793→                )
   794→            ):
   795→                func_name = self._get_import(
   796→                    "typeguard._functions", "check_return_type"
   797→                )
   798→                return_node = Return(
   799→                    Call(
   800→                        func_name,
   801→                        [
   802→                            self._memo.joined_path,
   803→                            Constant(None),
   804→                            self._memo.return_annotation,
   805→                            self._memo.get_memo_name(),
   806→                        ],
   807→                        [],
   808→                    )
   809→                )
   810→
   811→                # Replace a placeholder "pass" at the end
   812→                if isinstance(node.body[-1], Pass):
   813→                    copy_location(return_node, node.body[-1])
   814→                    del node.body[-1]
   815→
   816→                node.body.append(return_node)
   817→
   818→            # Insert code to create the call memo, if it was ever needed for this
   819→            # function
   820→            if self._memo.memo_var_name:
   821→                memo_kwargs: dict[str, Any] = {}
   822→                if self._memo.parent and isinstance(self._memo.parent.node, ClassDef):
   823→                    for decorator in node.decorator_list:
   824→                        if (
   825→                            isinstance(decorator, Name)
   826→                            and decorator.id == "staticmethod"
   827→                        ):
   828→                            break
   829→                        elif (
   830→                            isinstance(decorator, Name)
   831→                            and decorator.id == "classmethod"
   832→                        ):
   833→                            arglist = node.args.posonlyargs or node.args.args
   834→                            memo_kwargs["self_type"] = Name(
   835→                                id=arglist[0].arg, ctx=Load()
   836→                            )
   837→                            break
   838→                    else:
   839→                        if arglist := node.args.posonlyargs or node.args.args:
   840→                            if node.name == "__new__":
   841→                                memo_kwargs["self_type"] = Name(
   842→                                    id=arglist[0].arg, ctx=Load()
   843→                                )
   844→                            else:
   845→                                memo_kwargs["self_type"] = Attribute(
   846→                                    Name(id=arglist[0].arg, ctx=Load()),
   847→                                    "__class__",
   848→                                    ctx=Load(),
   849→                                )
   850→
   851→                # Construct the function reference
   852→                # Nested functions get special treatment: the function name is added
   853→                # to free variables (and the closure of the resulting function)
   854→                names: list[str] = [node.name]
   855→                memo = self._memo.parent
   856→                while memo:
   857→                    if isinstance(memo.node, (FunctionDef, AsyncFunctionDef)):
   858→                        # This is a nested function. Use the function name as-is.
   859→                        del names[:-1]
   860→                        break
   861→                    elif not isinstance(memo.node, ClassDef):
   862→                        break
   863→
   864→                    names.insert(0, memo.node.name)
   865→                    memo = memo.parent
   866→
   867→                config_keywords = self._memo.get_config_keywords()
   868→                if config_keywords:
   869→                    memo_kwargs["config"] = Call(
   870→                        self._get_import("dataclasses", "replace"),
   871→                        [self._get_import("typeguard._config", "global_config")],
   872→                        config_keywords,
   873→                    )
   874→
   875→                self._memo.memo_var_name.id = self._memo.get_unused_name("memo")
   876→                memo_store_name = Name(id=self._memo.memo_var_name.id, ctx=Store())
   877→                globals_call = Call(Name(id="globals", ctx=Load()), [], [])
   878→                locals_call = Call(Name(id="locals", ctx=Load()), [], [])
   879→                memo_expr = Call(
   880→                    self._get_import("typeguard", "TypeCheckMemo"),
   881→                    [globals_call, locals_call],
   882→                    [keyword(key, value) for key, value in memo_kwargs.items()],
   883→                )
   884→                node.body.insert(
   885→                    self._memo.code_inject_index,
   886→                    Assign([memo_store_name], memo_expr),
   887→                )
   888→
   889→                self._memo.insert_imports(node)
   890→
   891→                # Special case the __new__() method to create a local alias from the
   892→                # class name to the first argument (usually "cls")
   893→                if (
   894→                    isinstance(node, FunctionDef)
   895→                    and node.args
   896→                    and self._memo.parent is not None
   897→                    and isinstance(self._memo.parent.node, ClassDef)
   898→                    and node.name == "__new__"
   899→                ):
   900→                    first_args_expr = Name(node.args.args[0].arg, ctx=Load())
   901→                    cls_name = Name(self._memo.parent.node.name, ctx=Store())
   902→                    node.body.insert(
   903→                        self._memo.code_inject_index,
   904→                        Assign([cls_name], first_args_expr),
   905→                    )
   906→
   907→                # Rmove any placeholder "pass" at the end
   908→                if isinstance(node.body[-1], Pass):
   909→                    del node.body[-1]
   910→
   911→        return node
   912→
   913→    def visit_AsyncFunctionDef(
   914→        self, node: AsyncFunctionDef
   915→    ) -> FunctionDef | AsyncFunctionDef | None:
   916→        return self.visit_FunctionDef(node)
   917→
   918→    def visit_Return(self, node: Return) -> Return:
   919→        """This injects type checks into "return" statements."""
   920→        self.generic_visit(node)
   921→        if (
   922→            self._memo.return_annotation
   923→            and self._memo.should_instrument
   924→            and not self._memo.is_ignored_name(self._memo.return_annotation)
   925→        ):
   926→            func_name = self._get_import("typeguard._functions", "check_return_type")
   927→            old_node = node
   928→            retval = old_node.value or Constant(None)
   929→            node = Return(
   930→                Call(
   931→                    func_name,
   932→                    [
   933→                        self._memo.joined_path,
   934→                        retval,
   935→                        self._memo.return_annotation,
   936→                        self._memo.get_memo_name(),
   937→                    ],
   938→                    [],
   939→                )
   940→            )
   941→            copy_location(node, old_node)
   942→
   943→        return node
   944→
   945→    def visit_Yield(self, node: Yield) -> Yield | Call:
   946→        """
   947→        This injects type checks into "yield" expressions, checking both the yielded
   948→        value and the value sent back to the generator, when appropriate.
   949→
   950→        """
   951→        self._memo.has_yield_expressions = True
   952→        self.generic_visit(node)
   953→
   954→        if (
   955→            self._memo.yield_annotation
   956→            and self._memo.should_instrument
   957→            and not self._memo.is_ignored_name(self._memo.yield_annotation)
   958→        ):
   959→            func_name = self._get_import("typeguard._functions", "check_yield_type")
   960→            yieldval = node.value or Constant(None)
   961→            node.value = Call(
   962→                func_name,
   963→                [
   964→                    self._memo.joined_path,
   965→                    yieldval,
   966→                    self._memo.yield_annotation,
   967→                    self._memo.get_memo_name(),
   968→                ],
   969→                [],
   970→            )
   971→
   972→        if (
   973→            self._memo.send_annotation
   974→            and self._memo.should_instrument
   975→            and not self._memo.is_ignored_name(self._memo.send_annotation)
   976→        ):
   977→            func_name = self._get_import("typeguard._functions", "check_send_type")
   978→            old_node = node
   979→            call_node = Call(
   980→                func_name,
   981→                [
   982→                    self._memo.joined_path,
   983→                    old_node,
   984→                    self._memo.send_annotation,
   985→                    self._memo.get_memo_name(),
   986→                ],
   987→                [],
   988→            )
   989→            copy_location(call_node, old_node)
   990→            return call_node
   991→
   992→        return node
   993→
   994→    def visit_AnnAssign(self, node: AnnAssign) -> Any:
   995→        """
   996→        This injects a type check into a local variable annotation-assignment within a
   997→        function body.
   998→
   999→        """
  1000→        self.generic_visit(node)
  1001→
  1002→        if (
  1003→            isinstance(self._memo.node, (FunctionDef, AsyncFunctionDef))
  1004→            and node.annotation
  1005→            and isinstance(node.target, Name)
  1006→        ):
  1007→            self._memo.ignored_names.add(node.target.id)
  1008→            annotation = self._convert_annotation(deepcopy(node.annotation))
  1009→            if annotation:
  1010→                self._memo.variable_annotations[node.target.id] = annotation
  1011→                if node.value:
  1012→                    func_name = self._get_import(
  1013→                        "typeguard._functions", "check_variable_assignment"
  1014→                    )
  1015→                    targets_arg = List(
  1016→                        [
  1017→                            Tuple(
  1018→                                [Constant(node.target.id), annotation],
  1019→                                ctx=Load(),
  1020→                            )
  1021→                        ],
  1022→                        ctx=Load(),
  1023→                    )
  1024→                    node.value = Call(
  1025→                        func_name,
  1026→                        [
  1027→                            node.value,
  1028→                            targets_arg,
  1029→                            self._memo.get_memo_name(),
  1030→                        ],
  1031→                        [],
  1032→                    )
  1033→
  1034→        return node
  1035→
  1036→    def visit_Assign(self, node: Assign) -> Any:
  1037→        """
  1038→        This injects a type check into a local variable assignment within a function
  1039→        body. The variable must have been annotated earlier in the function body.
  1040→
  1041→        """
  1042→        self.generic_visit(node)
  1043→
  1044→        # Only instrument function-local assignments
  1045→        if isinstance(self._memo.node, (FunctionDef, AsyncFunctionDef)):
  1046→            preliminary_targets: list[
  1047→                PreliminaryNameTypePair | list[PreliminaryNameTypePair]
  1048→            ] = []
  1049→            check_required = False
  1050→            for node_target in node.targets:
  1051→                elts: Sequence[expr]
  1052→                if isinstance(node_target, Name):
  1053→                    elts = [node_target]
  1054→                    single_target = True
  1055→                elif isinstance(node_target, Tuple):
  1056→                    elts = node_target.elts
  1057→                    single_target = False
  1058→                else:
  1059→                    continue
  1060→
  1061→                annotations_: list[PreliminaryNameTypePair] = []
  1062→                for exp in elts:
  1063→                    prefix = ""
  1064→                    if isinstance(exp, Starred):
  1065→                        exp = exp.value
  1066→                        prefix = "*"
  1067→
  1068→                    path: list[str] = []
  1069→                    while isinstance(exp, Attribute):
  1070→                        path.insert(0, exp.attr)
  1071→                        exp = exp.value
  1072→
  1073→                    if isinstance(exp, Name):
  1074→                        if not path:
  1075→                            self._memo.ignored_names.add(exp.id)
  1076→
  1077→                        path.insert(0, exp.id)
  1078→                        name = prefix + ".".join(path)
  1079→                        if len(path) == 1 and (
  1080→                            annotation := self._memo.variable_annotations.get(exp.id)
  1081→                        ):
  1082→                            annotations_.append((Constant(name), annotation))
  1083→                            check_required = True
  1084→                        else:
  1085→                            annotations_.append((Constant(name), None))
  1086→
  1087→                preliminary_targets.append(
  1088→                    annotations_[0] if single_target else annotations_
  1089→                )
  1090→
  1091→            if check_required:
  1092→                # Replace missing annotations with typing.Any
  1093→                targets: list[NameTypePair | list[NameTypePair]] = []
  1094→                for items in preliminary_targets:
  1095→                    if isinstance(items, list):
  1096→                        target_list: list[NameTypePair] = []
  1097→                        targets.append(target_list)
  1098→                        for key, expression_or_none in items:
  1099→                            expression = expression_or_none or self._get_import(
  1100→                                "typing", "Any"
  1101→                            )
  1102→                            target_list.append((key, expression))
  1103→                    else:
  1104→                        key, expression_or_none = items
  1105→                        expression = expression_or_none or self._get_import(
  1106→                            "typing", "Any"
  1107→                        )
  1108→                        targets.append((key, expression))
  1109→
  1110→                func_name = self._get_import(
  1111→                    "typeguard._functions", "check_variable_assignment"
  1112→                )
  1113→                elements: list[expr] = []
  1114→                for target in targets:
  1115→                    if isinstance(target, list):
  1116→                        elements.append(
  1117→                            List(
  1118→                                [
  1119→                                    Tuple([name, ann], ctx=Load())
  1120→                                    for name, ann in target
  1121→                                ],
  1122→                                ctx=Load(),
  1123→                            )
  1124→                        )
  1125→                    else:
  1126→                        name_constant, ann = target
  1127→                        elements.append(Tuple([name_constant, ann], ctx=Load()))
  1128→
  1129→                targets_arg = List(elements, ctx=Load())
  1130→                node.value = Call(
  1131→                    func_name,
  1132→                    [node.value, targets_arg, self._memo.get_memo_name()],
  1133→                    [],
  1134→                )
  1135→
  1136→        return node
  1137→
  1138→    def visit_NamedExpr(self, node: NamedExpr) -> Any:
  1139→        """This injects a type check into an assignment expression (a := foo())."""
  1140→        self.generic_visit(node)
  1141→
  1142→        # Only instrument function-local assignments
  1143→        if isinstance(self._memo.node, (FunctionDef, AsyncFunctionDef)) and isinstance(
  1144→            node.target, Name
  1145→        ):
  1146→            self._memo.ignored_names.add(node.target.id)
  1147→
  1148→            # Bail out if no matching annotation is found
  1149→            annotation = self._memo.variable_annotations.get(node.target.id)
  1150→            if annotation is None:
  1151→                return node
  1152→
  1153→            func_name = self._get_import(
  1154→                "typeguard._functions", "check_variable_assignment"
  1155→            )
  1156→            node.value = Call(
  1157→                func_name,
  1158→                [
  1159→                    node.value,
  1160→                    List(
  1161→                        [
  1162→                            List(
  1163→                                [
  1164→                                    Tuple(
  1165→                                        [Constant(node.target.id), annotation],
  1166→                                        ctx=Load(),
  1167→                                    )
  1168→                                ],
  1169→                                ctx=Load(),
  1170→                            )
  1171→                        ],
  1172→                        ctx=Load(),
  1173→                    ),
  1174→                    self._memo.get_memo_name(),
  1175→                ],
  1176→                [],
  1177→            )
  1178→
  1179→        return node
  1180→
  1181→    def visit_AugAssign(self, node: AugAssign) -> Any:
  1182→        """
  1183→        This injects a type check into an augmented assignment expression (a += 1).
  1184→
  1185→        """
  1186→        self.generic_visit(node)
  1187→
  1188→        # Only instrument function-local assignments
  1189→        if isinstance(self._memo.node, (FunctionDef, AsyncFunctionDef)) and isinstance(
  1190→            node.target, Name
  1191→        ):
  1192→            # Bail out if no matching annotation is found
  1193→            annotation = self._memo.variable_annotations.get(node.target.id)
  1194→            if annotation is None:
  1195→                return node
  1196→
  1197→            # Bail out if the operator is not found (newer Python version?)
  1198→            try:
  1199→                operator_func_name = aug_assign_functions[node.op.__class__]
  1200→            except KeyError:
  1201→                return node
  1202→
  1203→            operator_func = self._get_import("operator", operator_func_name)
  1204→            operator_call = Call(
  1205→                operator_func, [Name(node.target.id, ctx=Load()), node.value], []
  1206→            )
  1207→            targets_arg = List(
  1208→                [Tuple([Constant(node.target.id), annotation], ctx=Load())],
  1209→                ctx=Load(),
  1210→            )
  1211→            check_call = Call(
  1212→                self._get_import("typeguard._functions", "check_variable_assignment"),
  1213→                [
  1214→                    operator_call,
  1215→                    targets_arg,
  1216→                    self._memo.get_memo_name(),
  1217→                ],
  1218→                [],
  1219→            )
  1220→            return Assign(targets=[node.target], value=check_call)
  1221→
  1222→        return node
  1223→
  1224→    def visit_If(self, node: If) -> Any:
  1225→        """
  1226→        This blocks names from being collected from a module-level
  1227→        "if typing.TYPE_CHECKING:" block, so that they won't be type checked.
  1228→
  1229→        """
  1230→        self.generic_visit(node)
  1231→
  1232→        if (
  1233→            self._memo is self._module_memo
  1234→            and isinstance(node.test, Name)
  1235→            and self._memo.name_matches(node.test, "typing.TYPE_CHECKING")
  1236→        ):
  1237→            collector = NameCollector()
  1238→            collector.visit(node)
  1239→            self._memo.ignored_names.update(collector.names)
  1240→
  1241→        return node
